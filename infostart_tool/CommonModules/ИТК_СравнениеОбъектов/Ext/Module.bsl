#Область ПрограммныйИнтерфейс

Процедура ДанныеОтчета(Параметры, АдресРезультата) Экспорт

	ОбъектыСравнения = Параметры.Объекты;
	
	Результат = Новый ТабличныйДокумент;
	Макет = Отчеты.ИТК_СравнениеОбъектов.ПолучитьМакет("Макет");
	
	// Подготовка вспомогательных данных
	СтруктураИДанныеОбъектов = СтруктураИДанныеОбъектов(ОбъектыСравнения);
	ОбщаяСтруктураОбъектов = ОбщаяСтруктураОбъектов(СтруктураИДанныеОбъектов);
	КэшВыделенияОсобыхЗначений = КэшВыделенияОсобыхЗначений(ОбщаяСтруктураОбъектов);
	
	// Сравнение и вывод
	Результат.НачатьАвтогруппировкуСтрок();
	
	ОбластьШапкаПоле = Макет.ПолучитьОбласть("ШапкаПоле");
	Результат.Вывести(ОбластьШапкаПоле);
	
	Для Каждого ОбъектСравнения Из ОбъектыСравнения Цикл 
		
		ОбластьШапкаОбъект = Макет.ПолучитьОбласть("ШапкаОбъект");
		ОбластьШапкаОбъект.Параметры.ПредставлениеОбъекта = ОбъектСравнения;
		ОбластьШапкаОбъект.Параметры.РасшифровкаОбъекта = ОбъектСравнения;
		Результат.Присоединить(ОбластьШапкаОбъект);
		
	КонецЦикла;
	
	ВывестиЗаголовок(Макет, Результат, НСтр("ru = 'Реквизиты';
											|en = 'Requisites'"), 1);
	
	ОбъектАнализа = "Реквизиты";
	Для Каждого СтрокаРеквизит Из ОбщаяСтруктураОбъектов[ОбъектАнализа] Цикл 
		
		ИмяРеквизита = СтрокаРеквизит.Имя;
		Если НЕ ПрисутствуютОтличияПоля(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, ИмяРеквизита) Тогда
			Продолжить;
		КонецЕсли;
		
		ВывестиЗаголовокПоля(Макет, Результат, 2, ИмяРеквизита, СтрокаРеквизит.ТипЗначения);
		
		ЗначенияПолей = ЗначенияПолейРеквизит(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, ИмяРеквизита);
		ВывестиСтрокуЗначенийПоля(Макет, Результат, КэшВыделенияОсобыхЗначений, ОбъектыСравнения, ЗначенияПолей, ИмяРеквизита);
		
	КонецЦикла;
	
	ВывестиЗаголовок(Макет, Результат, НСтр("ru = 'Табличные части';
											|en = 'Tabular parts'"), 1);
	
	ОбъектАнализа = "ТабличныеЧасти";
	Для Каждого СтрокаТабличнаяЧасть Из ОбщаяСтруктураОбъектов[ОбъектАнализа] Цикл 
		
		ИмяКоллекции = СтрокаТабличнаяЧасть.Имя;
		
		Если НЕ ПрисутствуютОтличияКоллекции(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, СтрокаТабличнаяЧасть.Реквизиты, ИмяКоллекции) Тогда
			Продолжить;
		КонецЕсли;
		
		// Вывод заголовка коллекции
		ВывестиЗаголовок(Макет, Результат, ИмяКоллекции, 2, СтрокаТабличнаяЧасть.Картинка);
		
		ЗначенияПолей = ЗначенияПолейЗаголовокКоллекции(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, ИмяКоллекции);
		ВывестиСтрокуЗначенийПоля(Макет, Результат, КэшВыделенияОсобыхЗначений, ОбъектыСравнения, ЗначенияПолей, ИмяКоллекции);
		
		Для НомерСтроки = 1 По СтрокаТабличнаяЧасть.КоличествоСтрок Цикл 
			
			Если НЕ ПрисутствуютОтличияКоллекции(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, СтрокаТабличнаяЧасть.Реквизиты, ИмяКоллекции, НомерСтроки) Тогда
				Продолжить;
			КонецЕсли;
			
			// Вывод заголовка строки коллекции
			Заголовок = СтрШаблон(НСтр("ru = 'Строка №%1';
										|en = 'Row #%1'"), ИТК_Строки.ЧислоВСтроку(НомерСтроки));
			ВывестиЗаголовок(Макет, Результат, Заголовок, 3);

			ЗначенияПолей = ЗначенияПолейЗаголовокСтрокиКоллекции(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, ИмяКоллекции, НомерСтроки);
			ВывестиСтрокуЗначенийПоля(Макет, Результат, КэшВыделенияОсобыхЗначений, ОбъектыСравнения, ЗначенияПолей, ИмяКоллекции);
			
			Для Каждого СтрокаРеквизит Из СтрокаТабличнаяЧасть.Реквизиты Цикл 
				
				ИмяРеквизита = СтрокаРеквизит.Имя;
				Если НЕ ПрисутствуютОтличияКоллекции(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, СтрокаТабличнаяЧасть.Реквизиты, ИмяКоллекции, НомерСтроки, ИмяРеквизита) Тогда
					Продолжить;
				КонецЕсли;
				
				ВывестиЗаголовокПоля(Макет, Результат, 4, ИмяРеквизита, СтрокаРеквизит.ТипЗначения);
				
				ЗначенияПолей = ЗначенияПолейРеквизитКоллекции(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, ИмяКоллекции, НомерСтроки, ИмяРеквизита);
				ВывестиСтрокуЗначенийПоля(Макет, Результат, КэшВыделенияОсобыхЗначений, ОбъектыСравнения, ЗначенияПолей, ИмяРеквизита);
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	ВыводДанныхДвижений(ОбщаяСтруктураОбъектов, КэшВыделенияОсобыхЗначений, ОбъектыСравнения, СтруктураИДанныеОбъектов, Макет, Результат);
	
	Результат.ЗакончитьАвтогруппировкуСтрок();
	
	Результат.ФиксацияСлева = 2;
	Результат.ФиксацияСверху = 2;
	
	ПоместитьВоВременноеХранилище(Результат, АдресРезультата);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОбщаяСтруктураОбъектов(СтруктураИДанныеОбъектов)
	
	Реквизиты = ТаблицаРеквизитовСтруктурыОбъекта();
	ТабличныеЧасти = ТаблицаКоллекцииСтруктурыОбъекта();
	Движения = ТаблицаКоллекцииСтруктурыОбъекта();
	
	Для Каждого ОписаниеСтруктурыИДанныхОбъекта Из СтруктураИДанныеОбъектов Цикл 
		
		СтруктураИДанныеОбъекта = ОписаниеСтруктурыИДанныхОбъекта.Значение;
		
		ОбъединитьРеквизитыСтруктурыОбъекта(Реквизиты, СтруктураИДанныеОбъекта.Реквизиты);
		ОбъединитьКоллекцииСтруктурыОбъекта(ТабличныеЧасти, СтруктураИДанныеОбъекта.ТабличныеЧасти);
		ОбъединитьКоллекцииСтруктурыОбъекта(Движения, СтруктураИДанныеОбъекта.Движения);
		
	КонецЦикла;
	
	Реквизиты.Сортировать("Имя");
	ТабличныеЧасти.Сортировать("Имя");
	Движения.Сортировать("Имя");

	Результат = Новый Структура;
	Результат.Вставить("Реквизиты", Реквизиты);
	Результат.Вставить("ТабличныеЧасти", ТабличныеЧасти);
	Результат.Вставить("Движения", Движения);
	
	Возврат Результат;
	
КонецФункции

Функция ТаблицаРеквизитовСтруктурыОбъекта()
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Имя", ИТК_ТипыКлиентСервер.ОписаниеИмяМетаданных());
	Результат.Колонки.Добавить("Синоним", ИТК_ТипыКлиентСервер.ОписаниеСинонимМетаданных());
	Результат.Колонки.Добавить("ТипЗначения", ИТК_ТипыКлиентСервер.ОписаниеИзСтроки("ОписаниеТипов"));
	
	Возврат Результат;
	
КонецФункции

Функция ТаблицаКоллекцииСтруктурыОбъекта()
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Имя", ИТК_ТипыКлиентСервер.ОписаниеИмяМетаданных());
	Результат.Колонки.Добавить("Синоним", ИТК_ТипыКлиентСервер.ОписаниеСинонимМетаданных());
	Результат.Колонки.Добавить("Картинка", ИТК_ТипыКлиентСервер.ОписаниеКартинка());
	Результат.Колонки.Добавить("Реквизиты");
	Результат.Колонки.Добавить("КоличествоСтрок");
	
	Возврат Результат;
	
КонецФункции

Процедура ОбъединитьРеквизитыСтруктурыОбъекта(ВсеРеквизиты, РеквизитыОбъекта)
	
	Для Каждого СтрокаРеквизит Из РеквизитыОбъекта Цикл 
		
		Если ТипЗнч(СтрокаРеквизит) = Тип("КолонкаТаблицыЗначений") Тогда
			ТипЗначения = СтрокаРеквизит.ТипЗначения;
		Иначе
			ТипЗначения = СтрокаРеквизит.Тип;
		КонецЕсли;
		
		НайденнаяСтрока = ВсеРеквизиты.Найти(СтрокаРеквизит.Имя, "Имя");
		
		Если НайденнаяСтрока = Неопределено Тогда
			
			НоваяСтрока = ВсеРеквизиты.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаРеквизит); 
			НоваяСтрока.ТипЗначения = ТипЗначения;
			
		Иначе
			
			НайденнаяСтрока.ТипЗначения = ИТК_ТипыКлиентСервер.СложитьОписания(НайденнаяСтрока.ТипЗначения, ТипЗначения); 
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбъединитьКоллекцииСтруктурыОбъекта(ВсеКоллекции, КоллекцииОбъекта)
	
	Для Каждого СтрокаТабличнаяЧасть Из КоллекцииОбъекта Цикл 
		
		ТаблицаЗначенийКоллекции = СтрокаТабличнаяЧасть.Значение;
		КоличествоСтрокКоллекции = ТаблицаЗначенийКоллекции.Количество();
		
		НайденнаяСтрока = ВсеКоллекции.Найти(СтрокаТабличнаяЧасть.Имя, "Имя");
		Если НайденнаяСтрока = Неопределено Тогда
			
			НоваяСтрока = ВсеКоллекции.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТабличнаяЧасть); 
			
			РеквизитыТабличнойЧасти = ТаблицаРеквизитовСтруктурыОбъекта();
			НоваяСтрока.Реквизиты = РеквизитыТабличнойЧасти;
			НоваяСтрока.КоличествоСтрок = КоличествоСтрокКоллекции;
			
		Иначе
			
			РеквизитыТабличнойЧасти = НайденнаяСтрока.Реквизиты;
			НайденнаяСтрока.КоличествоСтрок = Макс(НайденнаяСтрока.КоличествоСтрок, КоличествоСтрокКоллекции);
			
		КонецЕсли;
		
		ОбъединитьРеквизитыСтруктурыОбъекта(РеквизитыТабличнойЧасти, ТаблицаЗначенийКоллекции.Колонки);
		РеквизитыТабличнойЧасти.Сортировать("Имя");
		
	КонецЦикла;
	
КонецПроцедуры

Функция КэшВыделенияОсобыхЗначений(ОбщаяСтруктураОбъектов)
	
	ТипыЗначений = Новый Массив;
	
	КэшВыделенияОсобыхЗначенийДобавитьИсточникРеквизитов(ТипыЗначений, ОбщаяСтруктураОбъектов["Реквизиты"]);
	
	КэшВыделенияОсобыхЗначенийДобавитьКоллекцию(ОбщаяСтруктураОбъектов, ТипыЗначений, "ТабличныеЧасти");
	КэшВыделенияОсобыхЗначенийДобавитьКоллекцию(ОбщаяСтруктураОбъектов, ТипыЗначений, "Движения");
	
	Возврат ИТК_Общий.КэшВыделенияОсобыхЗначений(ТипыЗначений);
	
КонецФункции

Процедура КэшВыделенияОсобыхЗначенийДобавитьИсточникРеквизитов(ТипыЗначений, Источник)
	
	Для Каждого СтрокаРеквизит Из Источник Цикл 
		ТипыЗначений.Добавить(СтрокаРеквизит.ТипЗначения);
	КонецЦикла;
	
КонецПроцедуры

Процедура КэшВыделенияОсобыхЗначенийДобавитьКоллекцию(ОбщаяСтруктураОбъектов, ТипыЗначений, ОбъектАнализа)
	
	Для Каждого СтрокаКоллекции Из ОбщаяСтруктураОбъектов[ОбъектАнализа] Цикл 
		
		КэшВыделенияОсобыхЗначенийДобавитьИсточникРеквизитов(ТипыЗначений, СтрокаКоллекции.Реквизиты);

	КонецЦикла;
	
КонецПроцедуры

Функция СтруктураИДанныеОбъектов(Объекты)
	
	Результат = Новый Соответствие;
	Для Каждого Объект Из Объекты Цикл 
		
		СтруктураИДанныеОбъекта = ИТК_РаботаСОбъектом.ПрочитатьСтруктуруИДанные(Объект);
		Результат.Вставить(Объект, СтруктураИДанныеОбъекта);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура ВывестиЗаголовок(Макет, ТабличныйДокумент, Заголовок, Уровень, Картинка = Неопределено)
	
	ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок" + Уровень);
	ОбластьЗаголовок.Параметры.Заголовок = Заголовок;
	ОбластьЗаголовок.Параметры.Картинка = Картинка;
	ТабличныйДокумент.Вывести(ОбластьЗаголовок, Уровень);
	
КонецПроцедуры

Процедура ВывестиЗаголовокПоля(Макет, ТабличныйДокумент, Уровень, Заголовок, ТипЗначения)
	
	ОбластьСтрокаПоле = Макет.ПолучитьОбласть("СтрокаПоле");
	ОбластьСтрокаПоле.Параметры.Поле = Заголовок;
	
	ВыведеннаяОбласть = ТабличныйДокумент.Вывести(ОбластьСтрокаПоле, Уровень);
	
	ОбластьПоля = ТабличныйДокумент.Область(ВыведеннаяОбласть.Низ, 2);
	ОбластьПоля.Примечание.Текст = ИТК_Типы.ПодсказкаОписания(Заголовок, ТипЗначения);
	ОбластьПоля.Картинка = ИТК_Типы.КартинкаОписания(ТипЗначения);
	
КонецПроцедуры

Процедура ВывестиСтрокуЗначенийПоля(Макет, ТабличныйДокумент, КэшВыделенияОсобыхЗначений, ОбъектыСравнения, ЗначенияПолей, ИмяРеквизита)
	
	Для Каждого ОбъектСравнения Из ОбъектыСравнения Цикл 
		
		ЗначениеОтсутствует = Истина;
		РасшифровкаЗначения = Неопределено;
		
		ОписаниеЗначенияПоля = ЗначенияПолей.Получить(ОбъектСравнения);
		Если ОписаниеЗначенияПоля = Неопределено Тогда
			
			ПредставлениеЗначения = НСтр("ru = '<Отсутствует>';
									|en = '<Missing>'");
			
		Иначе
			
			ЗначениеПоля = ОписаниеЗначенияПоля.Значение;
			РасшифровкаЗначения = ИТК_ОбщийКлиентСервер.Свойство(ОписаниеЗначенияПоля, "Расшифровка", ЗначениеПоля);
			
			ОсобоеЗначение = КэшВыделенияОсобыхЗначений.Получить(ЗначениеПоля);
			Если РасшифровкаЗначения = Неопределено
					ИЛИ ОсобоеЗначение <> Неопределено Тогда
					
				ПредставлениеЗначения = ОсобоеЗначение;
				
			Иначе
				
				ЗначениеОтсутствует = Ложь;
				ПредставлениеЗначения = ЗначениеПоля;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЗначениеОтсутствует Тогда
			ИмяОбласти = "СтрокаЗначениеПустогоПоля";
		Иначе
			ИмяОбласти = "СтрокаЗначениеПоля";
		КонецЕсли;
		Область = Макет.ПолучитьОбласть(ИмяОбласти);
		
		Область.Параметры.Значение = ПредставлениеЗначения;
		Область.Параметры.РасшифровкаЗначения = РасшифровкаЗначения;
		
		ТабличныйДокумент.Присоединить(Область);
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПрисутствуютОтличияПоля(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, ИмяРеквизита)
	
	ПредыдущееЗначение = Неопределено;
	
	Для Каждого ОбъектСравнения Из ОбъектыСравнения Цикл 
		
		Если ПрисутствуетПоле(ОбъектСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, ИмяРеквизита) Тогда
			ЗначениеРеквизита = ЗначениеПоля(ОбъектСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, ИмяРеквизита);
		Иначе
			Возврат Истина;
		КонецЕсли;
		
		НайденнаяСтрока = НайтиСтрокуЗначенияПоля(ОбъектСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, ИмяРеквизита);
		Если НайденнаяСтрока = Неопределено Тогда
			Возврат Истина;
		Иначе
			ЗначениеРеквизита = НайденнаяСтрока.Значение;
		КонецЕсли;
		
		Если ПредыдущееЗначение = Неопределено Тогда
			ПредыдущееЗначение = ЗначениеРеквизита;
		КонецЕсли;
		
		Если ПредыдущееЗначение <> ЗначениеРеквизита Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

Функция НайтиСтрокуЗначенияПоля(ОбъектСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, Имя)
	
	СтруктураИДанныеОбъекта = СтруктураИДанныеОбъектов.Получить(ОбъектСравнения);
	КоллекцияДанныхОбъекта = СтруктураИДанныеОбъекта[ОбъектАнализа];
		
	Результат = КоллекцияДанныхОбъекта.Найти(Имя, "Имя");
	Возврат Результат;
	
КонецФункции

Функция ПрисутствуетПоле(ОбъектСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, Имя)
	
	НайденнаяСтрока = НайтиСтрокуЗначенияПоля(ОбъектСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, Имя);
	Возврат (НайденнаяСтрока <> Неопределено);
	
КонецФункции

Функция ЗначениеПоля(ОбъектСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, Имя)
	
	НайденнаяСтрока = НайтиСтрокуЗначенияПоля(ОбъектСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, Имя);
	Возврат НайденнаяСтрока.Значение;
	
КонецФункции

Функция ПрисутствуютОтличияКоллекции(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, ОбщиеРеквизитыКоллекции, ИмяКоллекции, НомерСтрокиКоллекции = Неопределено, ИмяРеквизита = Неопределено)
	
	ПредыдущаяКоллекция = Неопределено;
	ПредыдущееКоличествоСтрок = Неопределено;
	Для Каждого ОбъектСравнения Из ОбъектыСравнения Цикл 
		
		Если ПрисутствуетПоле(ОбъектСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, ИмяКоллекции) Тогда
			
			НайденнаяСтрока = НайтиСтрокуЗначенияПоля(ОбъектСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, ИмяКоллекции);
			Коллекция = НайденнаяСтрока.Значение;
			
		Иначе
			Возврат Истина;
		КонецЕсли;
		
		Если ПредыдущаяКоллекция = Неопределено Тогда
			ПредыдущаяКоллекция = Коллекция;
		КонецЕсли;
		
		КоличествоСтрок = Коллекция.Количество();
		Если КоличествоСтрок = 0
				И ПредыдущееКоличествоСтрок = 0 Тогда 
			Возврат Ложь;
		КонецЕсли;
		
		Если ПредыдущееКоличествоСтрок = Неопределено Тогда
			ПредыдущееКоличествоСтрок = КоличествоСтрок;
		КонецЕсли;
		
		Если НомерСтрокиКоллекции = Неопределено Тогда
			
			Если ПредыдущееКоличествоСтрок <> КоличествоСтрок Тогда 
				Возврат Истина;
			КонецЕсли;
			
			НачальныйНомерСтроки = 1;
			КонечныйНомерСтроки = КоличествоСтрок;
			
		Иначе
			
			НачальныйНомерСтроки = НомерСтрокиКоллекции;
			КонечныйНомерСтроки = НомерСтрокиКоллекции;
			
		КонецЕсли;
		
		Для НомерСтроки = НачальныйНомерСтроки По КонечныйНомерСтроки Цикл
			
			Если НомерСтроки > Коллекция.Количество()
					ИЛИ НомерСтроки > ПредыдущаяКоллекция.Количество() Тогда
				Возврат Истина;
			КонецЕсли;
			
			СтрокаТаблицыЗначений = Коллекция[НомерСтроки - 1];
			СтрокаПредыдущейТаблицыЗначений = ПредыдущаяКоллекция[НомерСтроки - 1];
			
			Для Каждого РеквизитКоллекции Из ОбщиеРеквизитыКоллекции Цикл 
				
				ИмяРеквизитаКоллекции = РеквизитКоллекции.Имя;
				Если ИмяРеквизита <> Неопределено 
						И ИмяРеквизитаКоллекции <> ИмяРеквизита Тогда
					Продолжить;
				КонецЕсли;
				
				Если Коллекция.Колонки.Найти(ИмяРеквизитаКоллекции) = Неопределено
						ИЛИ ПредыдущаяКоллекция.Колонки.Найти(ИмяРеквизитаКоллекции) = Неопределено Тогда
					Возврат Истина;
				КонецЕсли;
				
				Если СтрокаПредыдущейТаблицыЗначений[ИмяРеквизитаКоллекции] <> СтрокаТаблицыЗначений[ИмяРеквизитаКоллекции] Тогда
					Возврат Истина;
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Ложь;

КонецФункции

Функция ЗначенияПолейРеквизит(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, Имя)
	
	Результат = Новый Соответствие;
	Для Каждого ОбъектСравнения Из ОбъектыСравнения Цикл 
		
		Если ПрисутствуетПоле(ОбъектСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, Имя) Тогда
			
			ОписаниеЗначения = Новый Структура;
			
			ЗначениеРеквизита = ЗначениеПоля(ОбъектСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, Имя);
			ОписаниеЗначения.Вставить("Значение", ЗначениеРеквизита);
			
			Результат.Вставить(ОбъектСравнения, ОписаниеЗначения);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ЗначенияПолейЗаголовокКоллекции(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, Имя)
	
	Результат = Новый Соответствие;
	Для Каждого ОбъектСравнения Из ОбъектыСравнения Цикл 
		
		Если НЕ ПрисутствуетПоле(ОбъектСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, Имя) Тогда
			Продолжить;
		КонецЕсли;     				
		
		НайденнаяСтрока = НайтиСтрокуЗначенияПоля(ОбъектСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, Имя);
		
		ОписаниеЗначения = Новый Структура;
		ОписаниеЗначения.Вставить("Расшифровка", Неопределено);
		
		Заголовок = ИТК_Строки.ТекстНекотороеКоличествоСтрок(НайденнаяСтрока.КоличествоСтрок);
		ОписаниеЗначения.Вставить("Значение", Заголовок);
		
		Результат.Вставить(ОбъектСравнения, ОписаниеЗначения);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ЗначенияПолейЗаголовокСтрокиКоллекции(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, Имя, НомерСтроки)
	
	Результат = Новый Соответствие;
	Для Каждого ОбъектСравнения Из ОбъектыСравнения Цикл 
		
		Если НЕ ПрисутствуетПоле(ОбъектСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, Имя) Тогда
			Продолжить;
		КонецЕсли;     				
		
		НайденнаяСтрока = НайтиСтрокуЗначенияПоля(ОбъектСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, Имя);
		Если НайденнаяСтрока = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ТаблицаЗначений = НайденнаяСтрока.Значение;
		Если ТаблицаЗначений.Количество() < НомерСтроки Тогда
			Продолжить;
		КонецЕсли;
		
		ОписаниеЗначения = Новый Структура;
		ОписаниеЗначения.Вставить("Значение", СтрШаблон(НСтр("ru = '№%1';
															|en = '#%1'"), НомерСтроки));
		ОписаниеЗначения.Вставить("Расшифровка", Неопределено);
		
		Результат.Вставить(ОбъектСравнения, ОписаниеЗначения);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ЗначенияПолейРеквизитКоллекции(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, ИмяКоллекции, НомерСтроки, ИмяРеквизита)
	
	Результат = Новый Соответствие;
	Для Каждого ОбъектСравнения Из ОбъектыСравнения Цикл 
		
		НайденнаяСтрока = НайтиСтрокуЗначенияПоля(ОбъектСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, ИмяКоллекции);
		Если НайденнаяСтрока = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ТаблицаЗначений = НайденнаяСтрока.Значение;
		Если ТаблицаЗначений.Количество() < НомерСтроки
			ИЛИ ТаблицаЗначений.Колонки.Найти(ИмяРеквизита) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ОписаниеЗначения = Новый Структура;
		
		ЗначениеРеквизита = ТаблицаЗначений[НомерСтроки - 1][ИмяРеквизита];
		ОписаниеЗначения.Вставить("Значение", ЗначениеРеквизита);
		
		Результат.Вставить(ОбъектСравнения, ОписаниеЗначения);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура ВыводДанныхДвижений(ОбщаяСтруктураОбъектов, КэшВыделенияОсобыхЗначений, ОбъектыСравнения, СтруктураИДанныеОбъектов, Макет, Результат) 
	
	ОбъектАнализа = "Движения";
	ТаблицаДвижений = ИТК_ОбщийКлиентСервер.Свойство(ОбщаяСтруктураОбъектов, "Движения");
	Если НЕ ЗначениеЗаполнено(ТаблицаДвижений) Тогда
		Возврат;
	КонецЕсли;
	
	ВывестиЗаголовок(Макет, Результат, НСтр("ru = 'Движения'; en = 'Movements'"), 1);
	Для Каждого СтрокаДвиженияВРегистре Из ТаблицаДвижений Цикл 
		
		ИмяКоллекции = СтрокаДвиженияВРегистре.Имя;
		
		Если НЕ ПрисутствуютОтличияКоллекции(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, СтрокаДвиженияВРегистре.Реквизиты, ИмяКоллекции) Тогда
			Продолжить;
		КонецЕсли;
		
		// Вывод заголовка коллекции движений
		ВывестиЗаголовок(Макет, Результат, СтрокаДвиженияВРегистре.Синоним, 2, СтрокаДвиженияВРегистре.Картинка);
		
		ЗначенияПолей = ЗначенияПолейЗаголовокКоллекции(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, ИмяКоллекции);
		ВывестиСтрокуЗначенийПоля(Макет, Результат, КэшВыделенияОсобыхЗначений, ОбъектыСравнения, ЗначенияПолей, ИмяКоллекции);
		
		Для НомерСтроки = 1 По СтрокаДвиженияВРегистре.КоличествоСтрок Цикл 
			
			Если НЕ ПрисутствуютОтличияКоллекции(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, СтрокаДвиженияВРегистре.Реквизиты, ИмяКоллекции, НомерСтроки) Тогда
				Продолжить;
			КонецЕсли;
			
			// Вывод заголовка строки коллекции
			Заголовок = СтрШаблон(НСтр("ru = 'Запись №%1'; en = 'Record #%1'"), ИТК_Строки.ЧислоВСтроку(НомерСтроки));
			ВывестиЗаголовок(Макет, Результат, Заголовок, 3);
			
			ЗначенияПолей = ЗначенияПолейЗаголовокСтрокиКоллекции(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, ИмяКоллекции, НомерСтроки);
			ВывестиСтрокуЗначенийПоля(Макет, Результат, КэшВыделенияОсобыхЗначений, ОбъектыСравнения, ЗначенияПолей, ИмяКоллекции);
			
			Для Каждого СтрокаРеквизит Из СтрокаДвиженияВРегистре.Реквизиты Цикл 
				
				ИмяРеквизита = СтрокаРеквизит.Имя;
				Если НЕ ПрисутствуютОтличияКоллекции(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, СтрокаДвиженияВРегистре.Реквизиты, ИмяКоллекции, НомерСтроки, ИмяРеквизита) Тогда
					Продолжить;
				КонецЕсли;
				
				ВывестиЗаголовокПоля(Макет, Результат, 4, ИмяРеквизита, СтрокаРеквизит.ТипЗначения);
				
				ЗначенияПолей = ЗначенияПолейРеквизитКоллекции(ОбъектыСравнения, СтруктураИДанныеОбъектов, ОбъектАнализа, ИмяКоллекции, НомерСтроки, ИмяРеквизита);
				ВывестиСтрокуЗначенийПоля(Макет, Результат, КэшВыделенияОсобыхЗначений, ОбъектыСравнения, ЗначенияПолей, ИмяРеквизита);
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти
