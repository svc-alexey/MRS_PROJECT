#Область ПрограммныйИнтерфейс

Процедура Инициализировать(Форма, ИмяКоллекции, ДополнительныеПараметры) Экспорт
	
	ЭлементРодительКнопки = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "ЭлементРодительКнопки");
	ГруппаКонтекстногоМеню = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "ГруппаКонтекстногоМеню");
	ЭлементВставкиКолонкиПеред = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "ЭлементВставкиКолонкиПеред");
	
	ИмяТолькоИзбранные = ИТК_ИзбранноеКлиентСервер.ИмяРеквизитаТолькоИзбранные();
	
	// Добавление реквизита
	ДобавляемыеРеквизиты = Новый Массив;
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, ИмяТолькоИзбранные, "Булево", , , Истина);

	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, "Избранное", "Булево", , ИмяКоллекции);
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, "ИзбранноеКартинка", "Картинка",
									НСтр("ru = 'Избранное'; en = 'Favorites'"), ИмяКоллекции);
	
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
   	Форма[ИмяТолькоИзбранные] = Ложь;
	
	// Добавление команд
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Картинка", БиблиотекаКартинок.ИТК_ИзбранноеФильтр);
	ДополнительныеПараметры.Вставить("Подсказка",
		НСтр("ru = 'Отображать только избранные'; en = 'Show only favorites'"));
	
	ИТК_Форма.ДобавитьКоманду(Форма, ИмяТолькоИзбранные, "Подключаемый_" + ИмяТолькоИзбранные,
								НСтр("ru = 'Только избранные'; en = 'Only favorites'"), ДополнительныеПараметры);
								
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Картинка", БиблиотекаКартинок.ИТК_ИзбранноеДобавить);
	
	ИТК_Форма.ДобавитьКоманду(Форма, "Подключаемый_ДобавитьВИзбранное", "Подключаемый_ДобавитьВИзбранное",
								НСтр("ru = 'Добавить в избранное'; en = 'Add to favorites'"), ДополнительныеПараметры);
								
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Картинка", БиблиотекаКартинок.ИТК_ИзбранноеУдалить);
	
	ИТК_Форма.ДобавитьКоманду(Форма, "Подключаемый_УдалитьИзИзбранного", "Подключаемый_УдалитьИзИзбранного",
								НСтр("ru = 'Удалить из избранного'; en = 'Remove from favorites'"), ДополнительныеПараметры);

	// Добавление кнопок и пунктов контекстного меню
	Поля = Новый Структура;
	Поля.Вставить("ИмяКоманды", ИмяТолькоИзбранные);
	Поля.Вставить("Пометка", Истина);
	ИТК_Форма.ДобавитьЭлемент(Форма, ИмяТолькоИзбранные, "Кнопка", Поля, ЭлементРодительКнопки);

	Поля = Новый Структура;
	Поля.Вставить("ИмяКоманды", "Подключаемый_ДобавитьВИзбранное");
	ИТК_Форма.ДобавитьЭлемент(Форма, ИмяКоллекции + "КонтекстноеМенюДобавитьВИзбранное", "Кнопка", Поля, ГруппаКонтекстногоМеню);

	Поля = Новый Структура;
	Поля.Вставить("ИмяКоманды", "Подключаемый_УдалитьИзИзбранного");
	ИТК_Форма.ДобавитьЭлемент(Форма, ИмяКоллекции + "КонтекстноеМенюУдалитьИзИзбранного", "Кнопка", Поля, ГруппаКонтекстногоМеню);

	// Добавление колонки
	ЭлементКоллекция = Форма.Элементы[ИмяКоллекции];
	НоваяКолонка = Форма.Элементы.Вставить(ЭлементКоллекция.Имя + "ИзбранноеКартинка", Тип("ПолеФормы"),
						ЭлементКоллекция, ЭлементВставкиКолонкиПеред);
	НоваяКолонка.Вид = ВидПоляФормы.ПолеКартинки;
	НоваяКолонка.ПутьКДанным = ИмяКоллекции + ".ИзбранноеКартинка";
	НоваяКолонка.КартинкаШапки = БиблиотекаКартинок.ИТК_Избранное;
	НоваяКолонка.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет
								
КонецПроцедуры

Процедура ДополнитьКолонкиТаблицыЗначений(ТаблицаЗначений) Экспорт
	
	ТаблицаЗначений.Колонки.Добавить("Избранное", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	ТаблицаЗначений.Колонки.Добавить("ИзбранноеКартинка", ИТК_ТипыКлиентСервер.ОписаниеКартинка());
	
КонецПроцедуры

Процедура ЗаполнитьСтрокуТаблицыЗначений(КоллекцияИзбранные, Строка, Ключ) Экспорт
	
	Избранное = (КоллекцияИзбранные.Получить(Ключ) <> Неопределено);
	Строка.Избранное = Избранное;
	Строка.ИзбранноеКартинка = ИТК_ОбщийКлиентСерверПовтИсп.КартинкаИзбранное(Избранное);
	
КонецПроцедуры

Функция КоллекцияИзбранныеОбъекты(ВидИнструмента) Экспорт

	Настройки = ИТК_Настройки.Загрузить(ВидИнструмента);
	ИмяНастройки = ИТК_ИзбранноеКлиентСервер.ИмяНастройкиХранения(ВидИнструмента);
	Возврат Настройки[ИмяНастройки];
	
КонецФункции

Процедура ЗаписатьВИзбранное(ВидИнструмента, Приемник, Избранное) Экспорт
	
	Если ТипЗнч(Приемник) = Тип("Массив") Тогда
		Ключи = Приемник;
	Иначе
		
		Ключи = Новый Массив;
		Ключи.Добавить(Приемник);
		
	КонецЕсли;
	
	Настройки = ИТК_Настройки.Загрузить(ВидИнструмента);
	ИмяНастройки = ИТК_ИзбранноеКлиентСервер.ИмяНастройкиХранения(ВидИнструмента);
	ИзбранныеОбъекты = Настройки[ИмяНастройки];
	
	Для Каждого Ключ Из Ключи Цикл 
		
		Если Избранное Тогда
			ИзбранныеОбъекты.Вставить(Ключ, Истина);
		Иначе
			ИзбранныеОбъекты.Удалить(Ключ);
		КонецЕсли;
		
	КонецЦикла;
	
	ИТК_Настройки.Сохранить(Настройки, ВидИнструмента);
	
КонецПроцедуры

Функция ОбъектВИзбранном(ВидИнструмента, Ключ) Экспорт
	
	ИзбранныеОбъекты = КоллекцияИзбранныеОбъекты(ВидИнструмента);
	
	НайденныйЭлемент = ИзбранныеОбъекты.Получить(Ключ);
	Возврат НайденныйЭлемент <> Неопределено;
	
КонецФункции

Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(ЭтотОбъект, Настройки) Экспорт

	ИмяТолькоИзбранные = ИТК_ИзбранноеКлиентСервер.ИмяРеквизитаТолькоИзбранные();
	
	ТолькоИзбранные = Настройки.Получить(ИмяТолькоИзбранные);
	Если ТолькоИзбранные <> Неопределено Тогда
		ЭтотОбъект[ИмяТолькоИзбранные] = Настройки[ИмяТолькоИзбранные];
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриСохраненииДанныхВНастройкахНаСервере(ЭтотОбъект, Настройки) Экспорт

	ИмяТолькоИзбранные = ИТК_ИзбранноеКлиентСервер.ИмяРеквизитаТолькоИзбранные();
	Настройки.Вставить(ИмяТолькоИзбранные, ЭтотОбъект[ИмяТолькоИзбранные]);
	
КонецПроцедуры

