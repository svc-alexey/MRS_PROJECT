#Область ПрограммныйИнтерфейс

Функция СоответствиеОписаниеСвойств() Экспорт
	
	Результат = Новый Соответствие;
	
	Описание = ОписаниеСвойства();
	Описание["Представление"] = НСтр("ru = 'ИмяФормы'; en = 'FormName'");
	Описание["Группа"] = "Основные";
	Описание["Порядок"] = 10;
	Описание["ТолькоПросмотр"] = Истина;
	
	Результат.Вставить("ИмяФормы", Описание);

	Описание = ОписаниеСвойства();
	Описание["Представление"] = НСтр("ru = 'Заголовок'; en = 'Caption'");
	Описание["Группа"] = "Основные";
	Описание["Порядок"] = 20;

	Результат.Вставить("Заголовок", Описание);

	Описание = ОписаниеСвойства();
	Описание["Представление"] = НСтр("ru = 'АвтоЗаголовок'; en = 'AutoTitle'");
	Описание["Группа"] = "Основные";
	Описание["Порядок"] = 30;
	
	Результат.Вставить("АвтоЗаголовок", Описание);
	
	Описание = ОписаниеСвойства();
	Описание["Представление"] = НСтр("ru = 'Доступность'; en = 'Enabled'");
	Описание["Группа"] = "Основные";
	Описание["Порядок"] = 40;

	Результат.Вставить("Доступность", Описание);
	
	Описание = ОписаниеСвойства();
	Описание["Представление"] = НСтр("ru = 'Модифицированность'; en = 'Modified'");
	Описание["Группа"] = "Основные";
	Описание["Порядок"] = 50;

	Результат.Вставить("Модифицированность", Описание);
	
	#Область ОбщееДозаполнение
	СоответствиеГруппыСвойств = СоответствиеГруппыСвойств();
	Для Каждого КлючЗначение Из Результат Цикл 
		
		ОписаниеСвойства = КлючЗначение.Значение;
		
		ОписаниеГруппы = СоответствиеГруппыСвойств.Получить(ОписаниеСвойства.Группа);
		ОписаниеСвойства.Группа = ОписаниеГруппы.Представление;
		ОписаниеСвойства.ГруппаПорядок = ОписаниеГруппы.Порядок;
		
	КонецЦикла;
	#КонецОбласти
	
	Возврат Результат;

КонецФункции

Функция СоответствиеГруппыСвойств() Экспорт
	
	Результат = Новый Соответствие;
	
	// Основные
	Описание = ОписаниеГруппыСвойств();
	
	Имя = "Основные";
	Описание["Представление"] = НСтр("ru = 'Основные'; en = 'Main'");
	
	Результат.Вставить(Имя, Описание);
	
	// Использование
	Описание = ОписаниеГруппыСвойств();
	
	Имя = "Использование";
	Описание["Представление"] = НСтр("ru = 'Использование'; en = 'Use'");
	Описание["Порядок"] = 20;
	
	Результат.Вставить(Имя, Описание);
	
	// Оформление
	Описание = ОписаниеГруппыСвойств();
	
	Имя = "Оформление";
	Описание["Представление"] = НСтр("ru = 'Оформление'; en = 'Appearance'");
	Описание["Порядок"] = 30;
	
	Результат.Вставить(Имя, Описание);
	
	Возврат Результат;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОписаниеСвойства()

	Результат = Новый Структура;
	
	Результат.Вставить("Представление", "");
	Результат.Вставить("Порядок", 0);
	Результат.Вставить("Группа", "");
	Результат.Вставить("ГруппаПорядок", "");
	Результат.Вставить("ТолькоПросмотр", Ложь);
		
	Возврат Результат;

КонецФункции

Функция ОписаниеГруппыСвойств()

	Результат = Новый Структура;
	
	Результат.Вставить("Представление", "");
	Результат.Вставить("Порядок", 0);
	
	Возврат Результат;

КонецФункции

#КонецОбласти
