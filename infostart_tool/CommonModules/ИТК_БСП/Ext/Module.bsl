		|	ГруппыДоступаПользователи.Ссылка,
		|	ГруппыДоступаПользователи.Ссылка.Профиль,
		|	ПрофилиГруппДоступаРоли.Роль.Имя,
		|	СоставГруппПользователей.Пользователь";
		
	КонецЕсли;
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ПолноеИмяФормыСтандартнойОбработки(Идентификатор) Экспорт
	
	ОбъектМетаданных = Метаданные.Обработки.Найти(Идентификатор);
	
	Если ОбъектМетаданных <> Неопределено Тогда
		Возврат СтрШаблон("Обработка.%1.Форма", Идентификатор);
	КонецЕсли;
	
	АнглийскийИдентификатор = ИТК_БСПКлиентСерверПовтИсп.АнглийскийИдентификаторСтандартнойОбработки(Идентификатор);
	ОбъектМетаданных = Метаданные.Обработки.Найти(АнглийскийИдентификатор);
	
	Если ОбъектМетаданных = Неопределено Тогда
		Результат = Неопределено;
	Иначе	
		Результат = СтрШаблон("Обработка.%1.Форма", АнглийскийИдентификатор);
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

Функция ДанныеФормыШаблонаОтчетаНаСКД(НавигационнаяСсылка) Экспорт
	
	ВариантОтчета = ИТК_Общий.СсылкаПоНавигационнойСсылке(НавигационнаяСсылка);
	
	Если НЕ ЗначениеСоответствуетТипуСсылкаВариантОтчета(ВариантОтчета) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ВариантОтчета", ВариантОтчета);
	
	ИмяПоля = "Отчет.Имя";
	Если ИТК_БСППовтИсп.АнглийскаяБСП() Тогда
		ИмяПоля = "Report.Name";
	КонецЕсли;
	ИмяОтчета = ИТК_Общий.ЗначениеРеквизитаОбъекта(ВариантОтчета, ИмяПоля);
	Результат.Вставить("НавигационнаяСсылка", "e1cib/app/Отчет." + ИмяОтчета);
	
	Возврат Результат;
	
КонецФункции

Функция ИдентификаторПользователяИБИзСсылкиСправочникаПользователи(Пользователь) Экспорт

	ИмяПоляИдентификаторПользователяИБ = "ИдентификаторПользователяИБ";
	Если ИТК_БСППовтИсп.АнглийскаяБСП() Тогда
		ИмяПоляИдентификаторПользователяИБ = "IBUserID";
	КонецЕсли;
	
	Возврат ИТК_Общий.ЗначениеРеквизитаОбъекта(Пользователь, ИмяПоляИдентификаторПользователяИБ);

КонецФункции

Функция НайтиПользователяПоУникальномуИдентификатору(УникальныйИдентификатор) Экспорт
	
	Возврат ИТК_БСППовтИсп.НайтиПользователяПоУникальномуИдентификатору(Строка(УникальныйИдентификатор));
	
КонецФункции

Функция ИспользуютсяВнешниеПользователи() Экспорт 
	
	Если НЕ ИТК_БСПКлиентСервер.ИспользуетсяБСП() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ИмяКонстанты = "ИспользоватьВнешнихПользователей";
	Если ИТК_БСПКлиентСерверПовтИсп.АнглийскаяБСП() Тогда
		ИмяКонстанты = "UseExternalUsers";
	КонецЕсли;
	
	Возврат Константы[ИмяКонстанты].Получить();
	
КонецФункции

Функция ТекстЗапросаДанныеВнешнихПользователей() Экспорт
	
	Если ИТК_БСПКлиентСерверПовтИсп.АнглийскаяБСП() Тогда

		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ВнешниеПользователи.Ссылка КАК Ссылка,
		|	ВнешниеПользователи.Invalid КАК Недействителен,
		|	ВнешниеПользователи.AuthorizationObject КАК ОбъектАвторизации,
		|	ТИПЗНАЧЕНИЯ(ВнешниеПользователи.AuthorizationObject) КАК ТипОбъекта,
		|	ВнешниеПользователи.IBUserID КАК ИдентификаторПользователяИБ,
		|	ВнешниеПользователи.Comment КАК Комментарий
		|ИЗ
		|	Справочник.ExternalUsers КАК ВнешниеПользователи";
		
	Иначе
		
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ВнешниеПользователи.Ссылка КАК Ссылка,
		|	ВнешниеПользователи.Недействителен КАК Недействителен,
		|	ВнешниеПользователи.ОбъектАвторизации КАК ОбъектАвторизации,
		|	ТИПЗНАЧЕНИЯ(ВнешниеПользователи.ОбъектАвторизации) КАК ТипОбъекта,
		|	ВнешниеПользователи.ИдентификаторПользователяИБ КАК ИдентификаторПользователяИБ,
		|	ВнешниеПользователи.Комментарий КАК Комментарий
		|ИЗ
		|	Справочник.ВнешниеПользователи КАК ВнешниеПользователи";
		
	КонецЕсли;
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ПройденКонтрольОграниченийВыгрузкиОбъекта(Узел, ОбъектРегистрации) Экспорт
	
	Если НЕ ИТК_БСППовтИсп.СуществуетПодсистема("СтандартныеПодсистемы.ОбменДанными") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Отправка = ОтправкаЭлементаДанных.Авто;
	
	ПараметрыПроцедуры = Новый Массив;
	ПараметрыПроцедуры.Добавить(ОбъектРегистрации);
	ПараметрыПроцедуры.Добавить(Отправка);
	ПараметрыПроцедуры.Добавить(Ложь);
	ПараметрыПроцедуры.Добавить(Узел);
	
	ИТК_БСПКлиентСервер.ВыполнитьПроцедуру("ОбменДаннымиСобытия.ПриОтправкеДанныхКорреспонденту", ПараметрыПроцедуры);
	Возврат Отправка = ОтправкаЭлементаДанных.Авто;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

