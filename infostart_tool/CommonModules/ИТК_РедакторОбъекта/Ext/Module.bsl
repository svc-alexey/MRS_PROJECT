#Область ПрограммныйИнтерфейс

Процедура ДанныеОбъекта(Параметры, АдресРезультата) Экспорт

	ВыбранныйОбъект = Параметры.ВыбранныйОбъект;
	
	Если ВыбранныйОбъект = Неопределено Тогда
		Результат = Неопределено
	Иначе
		
		Если Параметры.ДобавитьВИсториюВыбранных Тогда
			ИТК_РаботаСОбъектом.ДобавитьВИсториюВыбранных(ВыбранныйОбъект, ИТК_Перечисления.ИнструментРедакторОбъекта());
		КонецЕсли;
		
		ПодготовкаОбъектаЗаполнения = ПодготовкаОбъектаЗаполнения(ВыбранныйОбъект, Параметры.ОбъектЗаполнения);
		Если ЗначениеЗаполнено(ПодготовкаОбъектаЗаполнения.ТекстОшибки) Тогда 
			ВызватьИсключение ПодготовкаОбъектаЗаполнения.ТекстОшибки;
		КонецЕсли;
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("ОбъектЗаполнения", ПодготовкаОбъектаЗаполнения.Объект);
		ДополнительныеПараметры.Вставить("ВключатьСлужебныеПоля", Истина);
		ДополнительныеПараметры.Вставить("ПрочитатьДанныеКоллекций", Ложь);
		
		Результат = ИТК_РаботаСОбъектом.ПрочитатьСтруктуруИДанные(ВыбранныйОбъект, ДополнительныеПараметры);
		
	КонецЕсли;
	
	ПоместитьВоВременноеХранилище(Результат, АдресРезультата);
	
КонецПроцедуры

Процедура ДанныеТабличнойЧасти(Параметры, АдресРезультата) Экспорт

	Объект = Параметры.Объект;
	ИмяТабличнойЧасти = Параметры.ИмяТабличнойЧасти;
	
	Запрос = Новый Запрос;
	
	ОбъектМетаданных = Объект.Метаданные();
	СтандартнаяТабличнаяЧасть = (ОбъектМетаданных.ТабличныеЧасти.Найти(ИмяТабличнойЧасти) = Неопределено);
	Если СтандартнаяТабличнаяЧасть Тогда
		
		ИсточникРеквизитовТабличнойЧасти = ОбъектМетаданных.СтандартныеТабличныеЧасти[ИмяТабличнойЧасти].СтандартныеРеквизиты;
		Колонки = ИТК_Метаданные.СписокИменИзКоллекции(ИсточникРеквизитовТабличнойЧасти, "НомерСтроки");
		
		СписокКолонок = Новый СписокЗначений;
		СписокКолонок.ЗагрузитьЗначения(Колонки);
		СписокКолонок.СортироватьПоЗначению();
		
		Колонки = СписокКолонок.ВыгрузитьЗначения();
		
		Если ИТК_Метаданные.ЭтоПланСчетов(ОбъектМетаданных) Тогда
			
			Для Каждого ПризнакУчетаСубконто Из ОбъектМетаданных.ПризнакиУчетаСубконто Цикл 
				Колонки.Добавить(ПризнакУчетаСубконто.Имя);
			КонецЦикла;
			
		КонецЕсли;
		
	Иначе
		
		ИсточникРеквизитовТабличнойЧасти = ОбъектМетаданных.ТабличныеЧасти[ИмяТабличнойЧасти].Реквизиты;
		Колонки = ИТК_Метаданные.СписокИменИзКоллекции(ИсточникРеквизитовТабличнойЧасти);
		
	КонецЕсли;
	
	Запрос.Текст = СтрШаблон("ВЫБРАТЬ %1 ИЗ %2.%3 ГДЕ Ссылка = &Ссылка", СтрСоединить(Колонки, ","), ОбъектМетаданных.ПолноеИмя(), ИмяТабличнойЧасти);
	Запрос.УстановитьПараметр("Ссылка", Объект);
	
	РезультатЗапроса = Запрос.Выполнить();
	Результат = РезультатЗапроса.Выгрузить();
	
	Если НЕ СтандартнаяТабличнаяЧасть Тогда
		
		// Заполнение заголовков колонок
		Для Каждого Колонка Из Результат.Колонки Цикл 
			Колонка.Заголовок = ИсточникРеквизитовТабличнойЧасти.Найти(Колонка.Имя).Представление();
		КонецЦикла;
		
	КонецЕсли;
	
	ПоместитьВоВременноеХранилище(Результат, АдресРезультата);
	
КонецПроцедуры

Процедура ДанныеДвижений(Параметры, АдресРезультата) Экспорт

	Объект = Параметры.Объект;
	ПолноеИмяОбъектаМетаданных = Параметры.ПолноеИмяРегистра;
	ОбъектМетаданных = Метаданные.НайтиПоПолномуИмени(ПолноеИмяОбъектаМетаданных);
	ИмяОбъектаКоллекции = ИТК_Метаданные.ИмяОбъектаКоллекции(ОбъектМетаданных);
	
	УдаляемыеКолонки = "НомерСтроки,Регистратор,МоментВремени";
	Если ИТК_ОбщийПовтИсп.ВариантВстроенногоЯзыкаАнглийский() Тогда
		УдаляемыеКолонки = "LineNumber,Recorder,PointInTime";
	КонецЕсли;
	
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоРегистрБухгалтерии(ИмяОбъектаКоллекции) Тогда
		
		Код = СтрШаблон("%1.%2.СоздатьНаборЗаписей()", ИТК_Метаданные.ИмяКоллекции(ОбъектМетаданных), ОбъектМетаданных.Имя);
		
		// Опасности не представляет код фиксированный
		// BSLLS:ExecuteExternalCodeInCommonModule-off
		НаборЗаписей = Вычислить(Код);
		// BSLLS:ExecuteExternalCodeInCommonModule-on
		
		НаборЗаписей.Отбор.Регистратор.Установить(Объект);
		НаборЗаписей.Прочитать();
		
		Результат = НаборЗаписей.Выгрузить();
		ИТК_ТаблицаЗначений.УдалитьКолонкиСИгнорированиемНаличия(Результат, УдаляемыеКолонки);
		
	Иначе
		
		Колонки = ИТК_Метаданные.СписокИменИзКоллекции(ОбъектМетаданных.СтандартныеРеквизиты, УдаляемыеКолонки);
		// Добавим общие реквизиты
		Для Каждого ОбщийРеквизит Из Метаданные.ОбщиеРеквизиты Цикл 
			
			Если НЕ ИТК_Метаданные.ОбщийРеквизитИспользуетсяВОбъекте(ОбщийРеквизит, ОбъектМетаданных) Тогда
				Продолжить;
			КонецЕсли;
			
			Колонки.Добавить(ОбщийРеквизит.Имя);
			
		КонецЦикла;
		ИТК_ОбщийКлиентСервер.ДополнитьМассив(Колонки, ИТК_Метаданные.СписокИменИзКоллекции(ОбъектМетаданных.Измерения));
		ИТК_ОбщийКлиентСервер.ДополнитьМассив(Колонки, ИТК_Метаданные.СписокИменИзКоллекции(ОбъектМетаданных.Реквизиты));
		ИТК_ОбщийКлиентСервер.ДополнитьМассив(Колонки, ИТК_Метаданные.СписокИменИзКоллекции(ОбъектМетаданных.Ресурсы));
		
		Запрос = Новый Запрос;
		Запрос.Текст = СтрШаблон("ВЫБРАТЬ %1 ИЗ %2 ГДЕ Регистратор = &Регистратор", СтрСоединить(Колонки, ","), ПолноеИмяОбъектаМетаданных);
		Запрос.УстановитьПараметр("Регистратор", Объект);
		
		Результат = Запрос.Выполнить().Выгрузить();
		
	КонецЕсли;	
	
	// Заполнение заголовков колонок
	ПредставленияПоИмени = ПредставленияПоИмениПоляДвижений(ОбъектМетаданных);
	Для Каждого Колонка Из Результат.Колонки Цикл 
		Колонка.Заголовок = ПредставленияПоИмени.Получить(Колонка.Имя);
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(Результат, АдресРезультата);
	
КонецПроцедуры

Функция КоличествоЗаписейВДвижениях(ПолноеИмяРегистра, Регистратор) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = СтрШаблон("ВЫБРАТЬ КОЛИЧЕСТВО(*) КАК Количество ИЗ %1 ГДЕ Регистратор = &Регистратор", ПолноеИмяРегистра);
	Запрос.УстановитьПараметр("Регистратор", Регистратор);
	
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.Количество;

КонецФункции

Процедура ИзменитьДанныеОбъекта(Параметры, АдресРезультата) Экспорт
	
	Действие = Параметры.Действие;
	ВыбранныйОбъект = Параметры.ВыбранныйОбъект;
	НастройкиЗаписи = Параметры.НастройкиЗаписи;

	НачатьТранзакцию();
	
	Попытка
		
		Результат = ЗаписатьДанныеОбъекта(ВыбранныйОбъект, Действие, НастройкиЗаписи);
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		
		ТекстОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ВызватьИсключение ТекстОшибки;
		
	КонецПопытки;
	
	ПоместитьВоВременноеХранилище(Результат, АдресРезультата);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПредставленияПоИмениПоляДвижений(ОбъектМетаданных)
	
	Результат = Новый Соответствие;
	
	ДобавитьПредставленияПоляДвижений(Результат, ОбъектМетаданных.Измерения);
	ДобавитьПредставленияПоляДвижений(Результат, ОбъектМетаданных.Реквизиты);
	ДобавитьПредставленияПоляДвижений(Результат, ОбъектМетаданных.Ресурсы);

	Возврат Результат;
	
КонецФункции

Процедура ДобавитьПредставленияПоляДвижений(Представления, Коллекция)
	
	Для Каждого ОбъектМетаданныхПоле Из Коллекция Цикл
		Представления.Вставить(ОбъектМетаданныхПоле.Имя, ОбъектМетаданныхПоле.Представление());
	КонецЦикла;
	
КонецПроцедуры

Функция ПодготовкаОбъектаЗаполнения(ВыбранныйОбъект, Объект)

	ТекстОшибки = Неопределено;
	ОбъектЗаполнения = Неопределено;

	Если ТипЗнч(Объект) = Тип("ДвоичныеДанные") Тогда
		
		ЧтениеXML = Новый ЧтениеXML;
		ЧтениеXML.ОткрытьПоток(Объект.ОткрытьПотокДляЧтения()); 
		
		Попытка
			
			ОбъектМетаданных = ВыбранныйОбъект.Метаданные();
			ТипИзменяемогоОбъекта = Тип(СтрШаблон("%1Объект.%2", ИТК_Метаданные.ИмяОбъектаКоллекции(ОбъектМетаданных), ОбъектМетаданных.Имя));
			
			ОбъектЗаполнения = ПрочитатьXML(ЧтениеXML, ТипИзменяемогоОбъекта);
			
		Исключение
			
			ТекстОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			
		КонецПопытки;
		
		ЧтениеXML.Закрыть();
		
	Иначе
		
		Если Объект = Неопределено Тогда
			ОбъектЗаполнения = Неопределено;
		Иначе
			ОбъектЗаполнения = Объект.ПолучитьОбъект();	
		КонецЕсли;
		
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ТекстОшибки", ТекстОшибки);
	Результат.Вставить("Объект", ОбъектЗаполнения);
	
	Возврат Результат;

КонецФункции

Функция ЗаписатьДанныеОбъекта(ВыбранныйОбъект, Действие, НастройкиЗаписи)
	
	Результат = Неопределено;
	
	// Инициализация
	РежимЗаписать = (Действие = "Записать");
	РежимВыполнитьЗадачу = (Действие = "ВыполнитьЗадачу");
	РежимПровести = (Действие = "Провести");
	РежимОтменаПроведения = (Действие = "ОтменаПроведения");
	РежимСозданиеНового = (Действие = "СозданиеНового");
	РежимУдалитьНепосредственно = (Действие = "УдалитьНепосредственно");
	
	ТребуетсяИзменениеОбъекта = (РежимЗаписать ИЛИ РежимВыполнитьЗадачу ИЛИ РежимПровести ИЛИ РежимОтменаПроведения ИЛИ РежимСозданиеНового);
	ЗаписыватьДвижения = (РежимЗаписать ИЛИ РежимСозданиеНового);
	
	ПараметрыЗаписи = НастройкиЗаписи.ПараметрыЗаписи;
	ДополнительныеСвойства = ПараметрыЗаписи.ДополнительныеСвойства;
	Если ПараметрыЗаписи.Привилегированный Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	// Получение объекта
	Если РежимСозданиеНового Тогда
		
		ИзменяемыйОбъект = ИТК_РаботаСОбъектом.НовыйОбъект(ТипЗнч(ВыбранныйОбъект), НастройкиЗаписи.ЭтоГруппа);
		ИзменяемыйОбъект.Заполнить(Неопределено);
		
	Иначе
		ИзменяемыйОбъект = ВыбранныйОбъект.ПолучитьОбъект();
	КонецЕсли;
	
	// Заполнение объекта
	Если ТребуетсяИзменениеОбъекта Тогда
		
		UIDНового = НастройкиЗаписи.UIDНового;
		Если UIDНового <> Неопределено Тогда
		
			ПолноеИмяОбъектаМетаданных = ВыбранныйОбъект.Метаданные().ПолноеИмя();
			МенеджерОбъекта = ИТК_Метаданные.МенеджерОбъектаПоПолномуИмени(ПолноеИмяОбъектаМетаданных);
			
			СсылкаНового = МенеджерОбъекта.ПолучитьСсылку(UIDНового);
			ИзменяемыйОбъект.УстановитьСсылкуНового(СсылкаНового);
		
		КонецЕсли;
		
		// Заполнение реквизитов
		Для Каждого Реквизит Из НастройкиЗаписи.ИзменяемыеРеквизиты Цикл 
			ИзменяемыйОбъект[Реквизит.Ключ] = Реквизит.Значение;
		КонецЦикла;
		
		// Запись свойств
		Для Каждого Свойство Из НастройкиЗаписи.ИзменяемыеСвойства Цикл 
			ИТК_БСП.УстановитьЗначениеДополнительногоСвойстваОбъекта(ИзменяемыйОбъект, Свойство.Ключ, Свойство.Значение);
		КонецЦикла;
		
		// Заполнение табличных частей
		Для Каждого ТабличнаяЧасть Из НастройкиЗаписи.ИзменяемыеТабличныеЧасти Цикл 
			ИзменяемыйОбъект[ТабличнаяЧасть.Ключ].Загрузить(ТабличнаяЧасть.Значение);
		КонецЦикла;
		
	КонецЕсли;
	
	Загрузка = ПараметрыЗаписи.БезПроверок;
	ИТК_ПараметрыЗаписи.Установка(ИзменяемыйОбъект, Загрузка, ДополнительныеСвойства);
	
	// Особенность записи движений их можно записать вместе с объектом, но только если Загрузка у объекта не установлена,
	// при установленной загрузке движения пропускаются
	Если НЕ Загрузка Тогда
		ЗаписьДвижений(ИзменяемыйОбъект, НастройкиЗаписи.ЗаписываемыеДвижения, ЗаписыватьДвижения, ДополнительныеСвойства, Ложь);
	КонецЕсли;
	
	// Запись
	Если РежимЗаписать Тогда
		
		ИзменяемыйОбъект.Записать();
		
	ИначеЕсли РежимВыполнитьЗадачу Тогда
		
		ИзменяемыйОбъект.ВыполнитьЗадачу();
		
	ИначеЕсли РежимПровести Тогда
		
		ИзменяемыйОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
	ИначеЕсли РежимОтменаПроведения Тогда
		
		ИзменяемыйОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
		
	ИначеЕсли РежимУдалитьНепосредственно Тогда
		
		ИзменяемыйОбъект.Удалить();
		
	ИначеЕсли РежимСозданиеНового Тогда
		
		ИзменяемыйОбъект.Записать();
		Результат = ИзменяемыйОбъект.Ссылка;
		
	КонецЕсли;
	
	Если Загрузка Тогда
		ЗаписьДвижений(ИзменяемыйОбъект, НастройкиЗаписи.ЗаписываемыеДвижения, ЗаписыватьДвижения, ДополнительныеСвойства);
	КонецЕсли;
	
	Если ПараметрыЗаписи.Привилегированный Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаписьДвижений(ИзменяемыйОбъект, ЗаписываемыеДвижения, ЗаписыватьДвижения, ДополнительныеСвойства, Отдельно = Истина)
	
	Если Не ЗаписыватьДвижения Тогда 
		Возврат;
	КонецЕсли;
		
	Для Каждого Движение Из ЗаписываемыеДвижения Цикл 
		
		НаборЗаписей = ИзменяемыйОбъект.Движения[Движение.Ключ];
		НаборЗаписей.Записывать = Истина;
		НаборЗаписей.Загрузить(Движение.Значение);
		
		ОбъектМетаданныхРегистр = НаборЗаписей.Метаданные();
		
		ИмяКоллекцииМетаданных = ИТК_Метаданные.ИмяКоллекции(ОбъектМетаданныхРегистр);
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоРегистрБухгалтерии(ИмяКоллекцииМетаданных) Тогда
			
			Корреспонденции = Новый Массив;
			Если ОбъектМетаданныхРегистр.Корреспонденция Тогда
				Корреспонденции.Добавить("Дт");
				Корреспонденции.Добавить("Кт");
			Иначе
				Корреспонденции.Добавить("");
			КонецЕсли; 
			
			ОчиститьПоляРегистраБухгалтерииПоПризнакамУчета(НаборЗаписей, Корреспонденции, ОбъектМетаданныхРегистр.Измерения);
			ОчиститьПоляРегистраБухгалтерииПоПризнакамУчета(НаборЗаписей, Корреспонденции, ОбъектМетаданныхРегистр.Ресурсы);
			
		КонецЕсли;
		
		ИТК_ПараметрыЗаписи.Установка(НаборЗаписей, Истина, ДополнительныеСвойства);
		
		Если Отдельно Тогда
			НаборЗаписей.Записать();
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОчиститьПоляРегистраБухгалтерииПоПризнакамУчета(НаборЗаписей, Корреспонденции, Поля) 
	
	Для Каждого Поле Из Поля Цикл
		
		ПризнакУчета = Поле.ПризнакУчета;
		Если Поле.Балансовый 
				ИЛИ ПризнакУчета = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого Проводка Из НаборЗаписей Цикл 
			
			Для Каждого Корреспонденция Из Корреспонденции Цикл
				
				Если Проводка["Счет" + Корреспонденция][ПризнакУчета.Имя] Тогда
					Продолжить;
				КонецЕсли;
				
				Проводка[Поле.Имя + Корреспонденция] = Неопределено;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

