#Область ПрограммныйИнтерфейс

Процедура ОбработчикПриВыбореДействия(ЭлементРезультата, Действие) Экспорт
	
	Если ТипЗнч(Действие) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	ПереопределенноеДействие = Действие.Свойство(ИТК_ГлобальныйПоискКлиентСервер.ИмяСвойстваПризнакПереопределяемогоДействия());
	Если НЕ ПереопределенноеДействие Тогда 
		Возврат;
	КонецЕсли;
	
	ИТК_ТуллкитКлиент.ОткрытьИнструмент(Действие.Инструмент, Действие.Параметр);
	
КонецПроцедуры

#КонецОбласти

