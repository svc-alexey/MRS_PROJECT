#Область ПрограммныйИнтерфейс

Процедура СоздатьЭлементыИРеквизиты(Форма, Родитель, РодительИндикации) Экспорт
	
	СоздатьЭлементыИРеквизитыРезультат(Форма, Родитель);
	СоздатьЭлементыИРеквизитыИндикации(Форма, РодительИндикации);
	
	ИдентификаторАдресаЖурналаРезультата = ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаЖурналаРезультата();
	
	// Добавляем реквизиты
	ДобавляемыеРеквизиты = Новый Массив;
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаДанных(), "Строка");
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаРезультатов(), "Строка");
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, ИдентификаторАдресаЖурналаРезультата, "Строка");
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторДлительнаяОбработка());
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторИндексПоследнегоОбрабатываемогоОбъекта(), "Число");
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторСообщенияОбработкиПоследнегоОбъекта(), "СписокЗначений");
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	// Связывание Адрес и Табличного документа результата
	АдресЖурналаРезультата = ПоместитьВоВременноеХранилище(Новый ТабличныйДокумент, Форма.УникальныйИдентификатор);
	Форма[ИдентификаторАдресаЖурналаРезультата] = АдресЖурналаРезультата;
	
	ИдентификаторЖурналаРезультата = ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторЖурналаРезультата();
	Форма[ИдентификаторЖурналаРезультата] = ПолучитьИзВременногоХранилища(АдресЖурналаРезультата);	
	
КонецПроцедуры

Процедура ОчиститьЖурналаРезультата(Форма) Экспорт
	
	АдресЖурналаРезультата = Форма[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаЖурналаРезультата()];
	
	ТабличныйДокумент = ПолучитьИзВременногоХранилища(АдресЖурналаРезультата);
	ТабличныйДокумент.Очистить();
	
КонецПроцедуры

Функция ОбработатьСообщенияПрогресса(АдресЖурнала, АдресРезультатов, ПоследниеСообщения, ИндексПоследнегоОбрабатываемого, Сообщения, АдресДанных = Неопределено) Экспорт
	
	Журнал = ПолучитьИзВременногоХранилища(АдресЖурнала);
	РезультатыОбработки = ПолучитьИзВременногоХранилища(АдресРезультатов);
	
	Если ЗначениеЗаполнено(АдресДанных) Тогда
		ОбрабатываемыеДанные = ПолучитьИзВременногоХранилища(АдресДанных);
	КонецЕсли;
	
	Ошибок = 0; Обработано = 0;
	
	ПрефиксНачало = ИТК_ДлительныеОперацииКлиентСервер.ПрефиксНачалоОбработкиОбъекта();
	ПрефиксКонец = ИТК_ДлительныеОперацииКлиентСервер.ПрефиксКонецОбработкиОбъекта();
	
	Если Сообщения = Неопределено Тогда
		Сообщения = Новый Массив;
	КонецЕсли;
	
	Для Каждого Сообщение Из Сообщения Цикл 
		
		ТекстСообщения = Сообщение.Текст;
		
		Если СтрНачинаетсяС(ТекстСообщения, ПрефиксНачало) Тогда // Начало
			
			ПоследниеСообщения.Очистить(); 
			ИндексПоследнегоОбрабатываемого = ИТК_ДлительныеОперацииКлиентСервер.ПрочитатьИндексОбъектаИзСообщенияНачала(ТекстСообщения);
			
		ИначеЕсли СтрНачинаетсяС(ТекстСообщения, ПрефиксКонец) Тогда // Конец
			
			Ошибка = ИТК_ДлительныеОперацииКлиентСервер.ПрочитатьОшибкуОбработкиОбъектаИзСообщенияКонца(ТекстСообщения);
			
			Результат = Новый Структура;
			
			Если ЗначениеЗаполнено(Ошибка) Тогда
				Результат.Вставить("Ошибка", Ошибка);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ПоследниеСообщения) Тогда 
				
				СообщенияСтроки = Новый Массив;
				Для Каждого ПоследняяДобавляемаяСтрокаСообщение Из ПоследниеСообщения Цикл 
					СообщенияСтроки.Добавить(ПоследняяДобавляемаяСтрокаСообщение.Значение);
				КонецЦикла;
				
				Результат.Вставить("Сообщения", СообщенияСтроки);
				
			КонецЕсли;
			
			ИндексОбъекта = ИндексПоследнегоОбрабатываемого;
			
			Если РезультатыОбработки.Получить(ИндексОбъекта) = Неопределено Тогда
				
				РезультатыОбработки.Вставить(ИндексОбъекта, Результат);
				
				РезультатДобавления = ДобавитьРезультатВЖурнал(Журнал, ИндексОбъекта, Результат, ИТК_ОбработкаРезультата.ПредставлениеОбъектаЖурнала(ОбрабатываемыеДанные, ИндексОбъекта));
				Ошибок = Ошибок + РезультатДобавления.Ошибок;
				Обработано = Обработано + РезультатДобавления.Обработано;
												
			КонецЕсли;
			
		Иначе // Сообщение
			
			ПоследниеСообщения.Добавить(ТекстСообщения);
			
		КонецЕсли;

	КонецЦикла;
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибок", Ошибок);
	Результат.Вставить("Обработано", Обработано);
	
	Возврат Результат;
	
КонецФункции

Процедура УстановкаПараметровЗаписи(Объект, Загрузка = Ложь, ДополнительныеСвойства = Неопределено) Экспорт
	
	Если Загрузка Тогда
		
		Объект.ОбменДанными.Загрузка = Загрузка;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДополнительныеСвойства) Тогда
		
		Для Каждого ДополнительноеСвойство Из ДополнительныеСвойства Цикл 
			
			Объект.ДополнительныеСвойства.Вставить(ДополнительноеСвойство.Ключ, ДополнительноеСвойство.Значение);
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ВернутьРезультат(НачалоОбработки) Экспорт
	
	ВремяОбработки = (ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоОбработки);
	Если ВремяОбработки = 0 Тогда
		ВремяОбработки = 5;
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ВремяОбработки", ВремяОбработки);
	Результат.Вставить("Сообщения", ПолучитьСообщенияПользователю(Истина));
	
	Возврат Результат;
	
КонецФункции

Функция ИнициализацияПередОбработкой(АдресОбрабатываемыхДанных, АдресЖурнала, АдресРезультатов, ПоследниеСообщения, ИндексПоследнегоОбъекта, Данные, Код, УникальныйИдентификатор, ДополнительныеСвойства) Экспорт
	
	ОбрабатываемыеДанные = ПолучитьИзВременногоХранилища(АдресОбрабатываемыхДанных);
	ЗначенияПараметров = ИТК_Запрос.ЗначенияПараметров(Данные);
	Ошибка = "";
	
	Если ЗначениеЗаполнено(Код) Тогда

		ИТК_ДлительныеОперацииКлиентСервер.СообщениеНачалоОбработкиОбъекта(ИТК_ОбработкаРезультатаКлиентСервер.НомерСтрокиКодПеред());
		Ошибка = ИТК_ОбработкаРезультата.ВыполнитьКодОбработки(Код, ЗначенияПараметров, ДополнительныеСвойства, ОбрабатываемыеДанные);
		ИТК_ДлительныеОперацииКлиентСервер.СообщениеКонецОбработкиОбъекта(Ошибка);
		
		ОбработатьСообщенияПрогресса(АдресЖурнала, АдресРезультатов, ПоследниеСообщения, ИндексПоследнегоОбъекта, ПолучитьСообщенияПользователю(Истина));
		
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибка", Ошибка);
	Результат.Вставить("АдресЗначенийПараметров", ИТК_ВременноеХранилище.Поместить(ЗначенияПараметров, , УникальныйИдентификатор));
	
	Возврат Результат;

КонецФункции

Процедура ВыполнениеОбработкиПосле(АдресЖурнала, АдресРезультатов, ПоследниеСообщения, ИндексПоследнегоОбъекта, АдресЗначенийПараметров, Код, ДополнительныеСвойства) Экспорт
	
	ЗначенияПараметров = ПолучитьИзВременногоХранилища(АдресЗначенийПараметров);
	
	ИТК_ДлительныеОперацииКлиентСервер.СообщениеНачалоОбработкиОбъекта(ИТК_ОбработкаРезультатаКлиентСервер.НомерСтрокиКодПосле());
	Ошибка = ИТК_ОбработкаРезультата.ВыполнитьКодОбработки(Код, ЗначенияПараметров, ДополнительныеСвойства);
	ИТК_ДлительныеОперацииКлиентСервер.СообщениеКонецОбработкиОбъекта(Ошибка);
	
	ОбработатьСообщенияПрогресса(АдресЖурнала, АдресРезультатов, ПоследниеСообщения, ИндексПоследнегоОбъекта, ПолучитьСообщенияПользователю(Истина));
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура СоздатьЭлементыИРеквизитыРезультат(Форма, Родитель)
	
	// Ссылка Журнал регистрации
	ИмяКоманды = "ЖурналРегистрации";
	
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("Подсказка", НСтр("ru = 'Открыть журнал регистрации (по пользователю)';
												|en = 'Open the event log (per user)'"));
	ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИТК_ОбработкаОбъектовКлиентСервер.ИмяОбработчикаКоманд(),
								ИТК_ТуллкитКлиентСервер.ЖурналРегистрацииПредставление(), ПараметрыКоманды);
		
	Поля = Новый Структура;
	Поля.Вставить("ИмяКоманды", ИмяКоманды);
	Поля.Вставить("Вид", ВидКнопкиФормы.Гиперссылка);
	ИТК_Форма.ДобавитьЭлемент(Форма, ИмяКоманды, "Кнопка", Поля, Родитель);
	
	// Табличный документ результат
	ИдентификаторЖурналаОбработки = ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторЖурналаРезультата();
	
	ДобавляемыеРеквизиты = Новый Массив;
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, ИдентификаторЖурналаОбработки, "ТабличныйДокумент");
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	Поля = Новый Структура;
	Поля.Вставить("ПутьКДанным", ИдентификаторЖурналаОбработки);
	Поля.Вставить("ПоложениеЗаголовка", ПоложениеЗаголовкаЭлементаФормы.Нет);
	
	ЖурналРезультатов = ИТК_Форма.ДобавитьЭлемент(Форма, ИдентификаторЖурналаОбработки, "ПолеТабличногоДокумента", Поля, Родитель);
	ЖурналРезультатов.УстановитьДействие("ОбработкаРасшифровки", "ПодключаемыйЖурналРезультатовОбработкаРасшифровки");
	
КонецПроцедуры

Процедура СоздатьЭлементыИРеквизитыИндикации(Форма, Родитель)
	
	ИдентификаторИндикацияСостояние = ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторИндикацияСостояние();
	ИдентификаторИндикацияПрогресс = ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторИндикацияПрогресс();
	ИдентификаторИндикацияПрошло = ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторИндикацияПрошло();
	ИдентификаторИндикацияОкончание = ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторИндикацияОкончание();
	
	// Создаем реквизиты
	ДобавляемыеРеквизиты = Новый Массив;
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, ИдентификаторИндикацияСостояние, "Строка(100)", НСтр("ru = 'Состояние';
																											|en = 'Status'"));
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, ИдентификаторИндикацияПрогресс, "Число(3)", НСтр("ru = 'Прогресс';
																										|en = 'Progress'"));
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, ИдентификаторИндикацияПрошло, "Строка(20)", НСтр("ru = 'Прошло';
																										|en = 'Passed'"));
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, ИдентификаторИндикацияОкончание, "Строка(20)", НСтр("ru = 'Окончание';
																										|en = 'Ending'"));
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	// Создаем элементы
	Префикс = "ИндикацияДлительнойОперации";
	
	Поля = Новый Структура;
	Поля.Вставить("Видимость", Ложь);
	Поля.Вставить("Заголовок", НСтр("ru = 'Прогресс длительной операции';
									|en = 'Progress of long-term surgery'"));
	Поля.Вставить("ОтображатьЗаголовок", Ложь);
	Поля.Вставить("Группировка", ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная);
	Поля.Вставить("ЦветФона", ЦветаСтиля.ЦветФонаПодсказки);
	Поля.Вставить("РастягиватьПоГоризонтали", Ложь);
	ОсновнаяГруппа = ИТК_Форма.ДобавитьЭлемент(Форма, "ГруппаПрогрессДлительнойОперации", "Группа", Поля, Родитель);
	
	Поля = Новый Структура;
	Поля.Вставить("Заголовок", НСтр("ru = 'Картинка';
									|en = 'Picture'"));
	Поля.Вставить("Картинка", БиблиотекаКартинок.ИТК_ДлительнаяОперацияАнимация48); 
	Поля.Вставить("ВертикальноеПоложениеВГруппе", ВертикальноеПоложениеЭлемента.Центр); 
	ИТК_Форма.ДобавитьЭлемент(Форма, СтрШаблон("%1Картинка", Префикс), "ДекорацияКартинка", Поля, ОсновнаяГруппа);
	
	Поля = Новый Структура;
	Поля.Вставить("Заголовок", НСтр("ru = 'Индикация';
									|en = 'Indication'"));
	Поля.Вставить("ОтображатьЗаголовок", Ложь);
	Поля.Вставить("Группировка", ГруппировкаПодчиненныхЭлементовФормы.Вертикальная);
	Поля.Вставить("Ширина", 70);
	ГруппаИндикации = ИТК_Форма.ДобавитьЭлемент(Форма, СтрШаблон("%1ГруппаИндикации", Префикс), "Группа", Поля, ОсновнаяГруппа);
	
	Поля = Новый Структура;
	Поля.Вставить("ПоложениеЗаголовка", ПоложениеЗаголовкаЭлементаФормы.Нет);
	Поля.Вставить("Шрифт", ИТК_ОбщийКлиентСервер.ШрифтЖирный());
	Поля.Вставить("ПутьКДанным", ИдентификаторИндикацияСостояние);
	Поля.Вставить("Ширина", 60);
	ИТК_Форма.ДобавитьЭлемент(Форма, СтрШаблон("%1Состояние", Префикс), "ПолеНадписи", Поля, ГруппаИндикации);
	
	Поля = Новый Структура;
	Поля.Вставить("ПоложениеЗаголовка", ПоложениеЗаголовкаЭлементаФормы.Нет);
	Поля.Вставить("ПутьКДанным", ИдентификаторИндикацияПрогресс);
	Поля.Вставить("ОтображатьПроценты", Истина);
	ИТК_Форма.ДобавитьЭлемент(Форма, СтрШаблон("%1Прогресс", Префикс), "ПолеИндикатора", Поля, ГруппаИндикации);

	Поля = Новый Структура;
	Поля.Вставить("Заголовок", НСтр("ru = 'Состояние';
									|en = 'Status'"));
	Поля.Вставить("ОтображатьЗаголовок", Ложь);
	Поля.Вставить("Группировка", ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная);
	ГруппаСостояние = ИТК_Форма.ДобавитьЭлемент(Форма, СтрШаблон("%1ГруппаСостояние", Префикс), "Группа", Поля, ГруппаИндикации);
	
	Поля = Новый Структура;
	Поля.Вставить("ПутьКДанным", ИдентификаторИндикацияПрошло);
	Поля.Вставить("Ширина", 12);
	ИТК_Форма.ДобавитьЭлемент(Форма, СтрШаблон("%1Прошло", Префикс), "ПолеНадписи", Поля, ГруппаСостояние);
	
	Поля = Новый Структура;
	Поля.Вставить("ПутьКДанным", ИдентификаторИндикацияОкончание);
	Поля.Вставить("Ширина", 12);
	ИТК_Форма.ДобавитьЭлемент(Форма, СтрШаблон("%1Окончание", Префикс), "ПолеНадписи", Поля, ГруппаСостояние);
	
	Поля = Новый Структура;
	Поля.Вставить("Вид", ВидДекорацииФормы.Надпись);
	Поля.Вставить("РастягиватьПоГоризонтали", Истина);
	ИТК_Форма.ДобавитьЭлемент(Форма, СтрШаблон("%1ВыравниваниеНаправо", Префикс), "ДекорацияНадпись", Поля, ГруппаСостояние);
	
	Поля = Новый Структура;
	Поля.Вставить("ИмяКоманды", "ОтменитьДлительнуюОперацию");
	ИТК_Форма.ДобавитьЭлемент(Форма, "ОтменитьДлительнуюОперацию", "Кнопка", Поля, ГруппаСостояние);
	
	// Группа информация о последней обработке
	Поля = Новый Структура;
	Поля.Вставить("Видимость", Ложь);
	Поля.Вставить("Заголовок", НСтр("ru = 'Информация о последней обработке';
									|en = 'Last processing information'"));
	Поля.Вставить("ОтображатьЗаголовок", Ложь);
	Поля.Вставить("ЦветФона", ЦветаСтиля.ЦветФонаПодсказки);
	ГруппаИнформацияОПоследнейОбработке = ИТК_Форма.ДобавитьЭлемент(Форма, "ГруппаИнформацияОПоследнейОбработке", "Группа", Поля,	Родитель);
	
	Поля = Новый Структура;
	Поля.Вставить("Шрифт", ИТК_ОбщийКлиентСервер.ШрифтЖирный());
	Поля.Вставить("Ширина", 70);
	ИТК_Форма.ДобавитьЭлемент(Форма, "ИнформацияОПоследнейОбработке", "ДекорацияНадпись", Поля, ГруппаИнформацияОПоследнейОбработке);
	
КонецПроцедуры

Функция ДобавитьРезультатВЖурнал(Журнал, Индекс, Результат, Представление)
	
	ШрифтГруппы = Новый Шрифт("Arial", 12, Истина);
	ЦветТекстаОшибка = ИТК_ОбщийКлиентСервер.ЦветТекстаВажнойГиперссылки();
	
	Ошибок = 0; Обработано = 0;
	
	Ошибка = ИТК_ОбщийКлиентСервер.Свойство(Результат, "Ошибка");
	Если ЗначениеЗаполнено(Ошибка) Тогда
		
		Ошибок = Ошибок + 1;
		ЦветТекста = ЦветТекстаОшибка;
		
		Родитель = НайтиСоздатьГруппировкуВЖурнале(Журнал, НСтр("ru = 'Ошибки';
																|en = 'Errors'"), "Ошибки", ШрифтГруппы, БиблиотекаКартинок.ИТК_ПредупреждениеВажное, ЦветТекста);
		
		Сообщения = Новый Массив;
		Сообщения.Добавить(Ошибка);
		
	Иначе
		
		Родитель = НайтиСоздатьГруппировкуВЖурнале(Журнал, НСтр("ru = 'Успешно';
																|en = 'Successfully'"), "Успешно", ШрифтГруппы, БиблиотекаКартинок.ИТК_ОбработанныеУспешно);

		Сообщения = ИТК_ОбщийКлиентСервер.Свойство(Результат, "Сообщения", Неопределено);
		ЦветТекста = Неопределено
		
	КонецЕсли;
	
	НоваяСтрокаЖурнала(Журнал, Родитель, Сообщения, Представление, Индекс, ЦветТекста);
	
	Если ИТК_ОбработкаРезультатаКлиентСервер.ЭтоИндексОбъекта(Индекс) Тогда
		
		Обработано = Обработано + 1;
		
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибок", Ошибок);
	Результат.Вставить("Обработано", Обработано);
	Возврат Результат;
	
КонецФункции

Функция НоваяГруппировкаВЖурнале(Журнал, Текст, Имя, Шрифт, Картинка, ЦветТекста)
	
	ОбластьГруппировки = ОбластьЖурналаГруппировка(Имя, Текст, Шрифт, Картинка, ЦветТекста);
	
	Журнал.Вывести(ОбластьГруппировки, , Имя);
	Журнал.НачатьГруппуСтрок(Имя);
	
	ОбластьКонец = ОбластьЖурналаГруппировка(ИмяОбластиКонец(Имя));
	Журнал.Вывести(ОбластьКонец);
	Журнал.ЗакончитьГруппуСтрок();
	
	Возврат Журнал.Области.Найти(Имя);
	
КонецФункции

Функция НайтиСоздатьГруппировкуВЖурнале(Журнал, Текст, Имя, Шрифт, Картинка, ЦветТекста = Неопределено)
	
	Результат = Журнал.Области.Найти(Имя);

	Если Результат = Неопределено Тогда
		
		Результат = НоваяГруппировкаВЖурнале(Журнал, Текст, Имя, Шрифт, Картинка, ЦветТекста);
		
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

Процедура НоваяСтрокаЖурнала(Журнал, Родитель, Сообщения, Представление, Индекс, ЦветТекста)
	
	ШрифтОбъекта = Новый Шрифт("Arial", 10, Истина);
	ШрифтСообщения = Новый Шрифт("Arial", 8, , Истина);
	
	ОбластьРодительКонец = Журнал.Области.Найти(ИмяОбластиКонец(Родитель.Имя));
	
	ТабличныйДокументОбъект = Новый ТабличныйДокумент;
	
	ОбластьОбъекта = ОбластьЖурналаСтрока(Представление, ШрифтОбъекта, 1, Индекс, ЦветТекста);
	ТабличныйДокументОбъект.Вывести(ОбластьОбъекта);
	
	// Вывод сообщений
	Если ЗначениеЗаполнено(Сообщения) Тогда
		
		Для Каждого Сообщение Из Сообщения Цикл 
			
			ОбластьСообщение = ОбластьЖурналаСтрока(Сообщение, ШрифтСообщения, 2, Индекс, ЦветТекста);
			ТабличныйДокументОбъект.Вывести(ОбластьСообщение);
			
		КонецЦикла;
		
	КонецЕсли;
	
	// Вставка области
	ВставляемаяОбласть = ТабличныйДокументОбъект.Область(1, , ТабличныйДокументОбъект.ВысотаТаблицы);
	ВставляемаяОбласть.Сгруппировать();
	
	Журнал.ВставитьОбласть(ВставляемаяОбласть, ОбластьРодительКонец, ТипСмещенияТабличногоДокумента.ПоВертикали);
	
КонецПроцедуры

Функция ОбластьЖурналаГруппировка(Имя, Текст = Неопределено, Шрифт = Неопределено, Картинка = Неопределено, ЦветТекста = Неопределено)
	
	Возврат ОбластьЖурнала(Имя, Текст, Шрифт, Картинка, , , ЦветТекста);
	
КонецФункции

Функция ОбластьЖурналаСтрока(Текст = Неопределено, Шрифт = Неопределено, Уровень = 0, Расшифровка = Неопределено, ЦветТекста = Неопределено)
	
	Возврат ОбластьЖурнала("", Текст, Шрифт, , Уровень, Расшифровка, ЦветТекста);
	
КонецФункции

Функция ОбластьЖурнала(Имя, Текст = Неопределено, Шрифт = Неопределено, Картинка = Неопределено, Уровень = 0, Расшифровка = Неопределено, ЦветТекста = Неопределено)
	
	Результат = Новый ТабличныйДокумент;
	
	Область = Результат.Область(1,1);
	Область.Текст = Текст;
	Область.Отступ = Уровень * 3;
	Область.ШиринаКолонки = 100;
	
	Если Шрифт <> Неопределено Тогда
		Область.Шрифт = Шрифт;
	КонецЕсли;
	
	Если Картинка <> Неопределено Тогда
		Область.Картинка = Картинка;
	КонецЕсли;
	
	Если Имя <> Неопределено Тогда
		Область.Имя = Имя;
	КонецЕсли;
	
	Если Расшифровка <> Неопределено Тогда
		Область.Расшифровка = Расшифровка;
	КонецЕсли;
	
	Если ЦветТекста <> Неопределено Тогда
		Область.ЦветТекста = ЦветТекста;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИмяОбластиКонец(Имя)
	
	Возврат Имя + "Конец";
	
КонецФункции

#КонецОбласти
