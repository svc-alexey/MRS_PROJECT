#Область ПрограммныйИнтерфейс

Функция КартинкиЭлементов() Экспорт
	
	Результат = Новый Соответствие;
	Результат.Вставить(Тип("ПолеФормы"), БиблиотекаКартинок.ИТК_ЭлементПоле);
	Результат.Вставить(Тип("ДекорацияФормы"), БиблиотекаКартинок.ИТК_ЭлементДекорация);
	Результат.Вставить(Тип("КнопкаФормы"), БиблиотекаКартинок.ИТК_ЭлементКнопка);
	Результат.Вставить(Тип("ТаблицаФормы"), БиблиотекаКартинок.ИТК_ЭлементТаблица);
	
	КартинкиГруппыФормы = Новый Соответствие;
	КартинкиГруппыФормы.Вставить(ВидГруппыФормы.ОбычнаяГруппа, БиблиотекаКартинок.ИТК_ЭлементГруппа);
	КартинкиГруппыФормы.Вставить(ВидГруппыФормы.ГруппаКнопок, БиблиотекаКартинок.ИТК_ЭлементГруппа);
	КартинкиГруппыФормы.Вставить(ВидГруппыФормы.ГруппаКолонок, БиблиотекаКартинок.ИТК_ЭлементГруппа);
	КартинкиГруппыФормы.Вставить(ВидГруппыФормы.КонтекстноеМеню, БиблиотекаКартинок.ИТК_ЭлементКонтекстноеМеню);
	КартинкиГруппыФормы.Вставить(ВидГруппыФормы.Подменю, БиблиотекаКартинок.ИТК_ЭлементГруппа);
	КартинкиГруппыФормы.Вставить(ВидГруппыФормы.Страница, БиблиотекаКартинок.ИТК_ЭлементГруппа);
	КартинкиГруппыФормы.Вставить(ВидГруппыФормы.Страницы, БиблиотекаКартинок.ИТК_ЭлементГруппа);
	КартинкиГруппыФормы.Вставить(ВидГруппыФормы.КоманднаяПанель, БиблиотекаКартинок.ИТК_ЭлементКоманднаяПанель);
	Результат.Вставить(Тип("ГруппаФормы"), КартинкиГруппыФормы);
	
	Возврат Результат;
	
КонецФункции

Функция ТипыЭлементовИмеющиеВид() Экспорт
	
	Результат = Новый Соответствие;
	Результат.Вставить(Тип("ПолеФормы"), Истина);
	Результат.Вставить(Тип("ДекорацияФормы"), Истина);
	Результат.Вставить(Тип("КнопкаФормы"), Истина);
	Результат.Вставить(Тип("ГруппаФормы"), Истина);
	Результат.Вставить(Тип("ДополнениеЭлементаФормы"), Истина);
	
	Возврат Результат;
	
КонецФункции

Функция ТипыЭлементовСДоступнымТолькоПросмотр() Экспорт
	
	Результат = Новый Соответствие;
	Результат.Вставить(Тип("ПолеФормы"), Истина);
	Результат.Вставить(Тип("ГруппаФормы"), Истина);
	Результат.Вставить(Тип("ТаблицаФормы"), Истина);
	
	Возврат Результат;
	
КонецФункции

Функция ЦветФонаАктивизированногоЭлемента() Экспорт
	
	Возврат ИТК_МенеджерФормВызовСервера.ЦветФонаАктивизированногоЭлемента();
	
КонецФункции

Функция ЦветТекстаЗаголовкаАктивизированногоЭлемента() Экспорт
	
	Возврат ИТК_МенеджерФормВызовСервера.ЦветТекстаЗаголовкаАктивизированногоЭлемента();
	
КонецФункции

