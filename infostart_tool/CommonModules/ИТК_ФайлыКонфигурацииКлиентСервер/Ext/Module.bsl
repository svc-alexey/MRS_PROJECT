#Область ПрограммныйИнтерфейс

Функция ПолноеИмяФайлаМодуляФорматКонфигуратора(Путь, ОписаниеМодуля) Экспорт
	
	Возврат ПолноеИмяФайлаМодуля(Путь, ОписаниеМодуля);
	
КонецФункции

Функция ПолноеИмяФайлаМодуляФорматЕДТ(Путь, ОписаниеМодуля) Экспорт
	
	Возврат ПолноеИмяФайлаМодуля(Путь, ОписаниеМодуля, Истина);
	
КонецФункции

Функция ОписаниеМодуляПерейтиКОпределению(ПолноеИмяМодуля) Экспорт
	
	Коллекция = "";
	ИмяОбъектаКоллекции = "";
	КоллекцияПредставление = "";
	
	Если СтрНайти(ПолноеИмяМодуля, ".") Тогда
		
		ЧастиОписанияМодуля = СтрРазделить(ПолноеИмяМодуля, ".");

		ИмяОбъектаКоллекции = ЧастиОписанияМодуля[0];
		ТипОбъекта = ИТК_МетаданныеКлиентСерверПовтИсп.ИмяКоллекции(ИмяОбъектаКоллекции);
		
		ИмяМодуля = ЧастиОписанияМодуля[1];
		
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоОбщийМодуль(ИмяОбъектаКоллекции) Тогда
			ТипМодуля = "";
		Иначе
			
			ТипМодуляИлиКоллекция = ЧастиОписанияМодуля[2];
			Если ТипМодуляИлиКоллекция = "МодульОбъекта" Тогда
				ТипМодуля = "object";
			ИначеЕсли ТипМодуляИлиКоллекция = "МодульМенеджера" Тогда
				ТипМодуля = "manager";
			ИначеЕсли ТипМодуляИлиКоллекция = "МодульМенеджераЗначения" Тогда
				ТипМодуля = "valuemanager";
			ИначеЕсли ТипМодуляИлиКоллекция = "МодульНабораЗаписей" Тогда
				ТипМодуля = "recordset";
			ИначеЕсли ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоКоманда(ТипМодуляИлиКоллекция) Тогда
				
				ТипМодуля = "command";
				Коллекция = "Commands";
				КоллекцияПредставление = НСтр("ru = 'Команды'; en = 'Commands'");
				ИмяОбъектаКоллекции = ЧастиОписанияМодуля[3];
				
			ИначеЕсли ТипМодуляИлиКоллекция = "МодульКоманды" Тогда
				ТипМодуля = "command";
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли ПолноеИмяМодуля = "ManagedApplication"
				ИЛИ ПолноеИмяМодуля = "ExternalConnectio"
				ИЛИ ПолноеИмяМодуля = "OrdinaryApplication"
				ИЛИ ПолноеИмяМодуля = "Session" Тогда
		
		ТипОбъекта = "";
		ТипМодуля = ПолноеИмяМодуля;
		ИмяМодуля = "";
		
	Иначе
		
		ТипОбъекта = "ОбщиеМодули";
		ТипМодуля = "";
		ИмяМодуля = ПолноеИмяМодуля;
		
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ТипМодуля", ТипМодуля);
	Результат.Вставить("ТипОбъекта", ТипОбъекта);
	Результат.Вставить("ИмяОбъекта", ИмяМодуля);
	
	Результат.Вставить("Коллекция", Коллекция);
	Результат.Вставить("КоллекцияПредставление", КоллекцияПредставление);
	Результат.Вставить("ИмяОбъектаКоллекции", ИмяОбъектаКоллекции);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПолноеИмяФайлаМодуля(Путь, ОписаниеМодуля, ФорматEDT = Ложь) Экспорт

	ИмяКаталогаВыгрузкиКоллекции = ИТК_РедакторКодаКлиентСерверПовтИсп.ИмяКаталогаВыгрузкиПоТипу(ОписаниеМодуля.ТипОбъекта);

	Если ФорматEDT Тогда
		ШаблонПути = "%1\%2\%3\%4\%5Module.bsl";
	Иначе
		ШаблонПути = "%1\%2\%3\%4\Ext\%5Module.bsl";
	КонецЕсли;
	
	Результат = СтрШаблон(ШаблонПути, Путь, ИмяКаталогаВыгрузкиКоллекции, ОписаниеМодуля.ИмяОбъекта,
								ОписаниеМодуля.Коллекция, ОписаниеМодуля.ТипМодуля);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
