#Область ПрограммныйИнтерфейс

Процедура ПереопределениеСтандартногоПоискаДанные(СтрокаПоиска, РезультатыПоиска, ДополнительныеПараметры) Экспорт 
	
	СписокПолнотекстовогоПоиска = ПолнотекстовыйПоиск.СоздатьСписок(СтрокаПоиска);
	СписокПолнотекстовогоПоиска.ПерваяЧасть();
	
	Для Каждого Элемент Из СписокПолнотекстовогоПоиска Цикл 
		
		ЭлементПоиска = Новый ЭлементРезультатаГлобальногоПоиска;
		ЭлементПоиска.ВидПоиска = СтандартныйВидГлобальногоПоиска.Данные;
		ЭлементПоиска.Значение = Элемент.Значение;
		
		ОформленноеОписание = СтрНайтиИВыделитьОформлением(Элемент.Описание, СтрокаПоиска);
		ЭлементПоиска.Представление = ПредставлениеДанные(Элемент.Представление, ОформленноеОписание);
		
		ЗаполнитьДоступныеДействия(ЭлементПоиска);
		РезультатыПоиска.Добавить(ЭлементПоиска);

	КонецЦикла;
	
КонецПроцедуры

Процедура ПереопределениеСтандартногоПоискаНавигационнаяСсылка(СтрокаПоиска, РезультатыПоиска, ДополнительныеПараметры) Экспорт 
	
	Ссылка = ИТК_Общий.СсылкаПоНавигационнойСсылке(СтрокаПоиска);
	Если НЕ ЗначениеЗаполнено(Ссылка) Тогда 
		Возврат;
	КонецЕсли;
	
	ЭлементПоиска = Новый ЭлементРезультатаГлобальногоПоиска;
	ЭлементПоиска.ВидПоиска = СтандартныйВидГлобальногоПоиска.НавигационнаяСсылка;
	ЭлементПоиска.Значение = Ссылка;
	ЭлементПоиска.Представление = ПредставлениеДанные(Ссылка);
	
	ЗаполнитьДоступныеДействия(ЭлементПоиска);
	РезультатыПоиска.Добавить(ЭлементПоиска);
	
КонецПроцедуры

Процедура ПоискОбъектаПоГУИД(СтрокаПоиска, РезультатыПоиска, ДополнительныеПараметры) Экспорт
	
	УникальныйИдентификатор = Новый УникальныйИдентификатор(СтрокаПоиска);
	
	НайденныеСсылки = ПоискСсылокПоУникальномуИдентификатору(УникальныйИдентификатор);
	Для Каждого НайденнаяСсылка Из НайденныеСсылки Цикл 
		
		ЭлементПоиска = Новый ЭлементРезультатаГлобальногоПоиска;
		ЭлементПоиска.ВидПоиска = СтандартныйВидГлобальногоПоиска.Данные;
		ЭлементПоиска.Значение = НайденнаяСсылка;
		ЭлементПоиска.Представление = ПредставлениеДанные(НайденнаяСсылка, ПредставлениеПоискаОбъектаПоГУИД());
		
		ЗаполнитьДоступныеДействия(ЭлементПоиска);
		РезультатыПоиска.Добавить(ЭлементПоиска);
		
	КонецЦикла;

КонецПроцедуры

Функция ПоискСсылокПоУникальномуИдентификатору(УникальныйИдентификатор, ДоступныеТипы = Неопределено) Экспорт
	
	ПакетЗапросов = Новый Массив;
	
	ЧастиЗапроса = Новый Массив;
	Запрос = Новый Запрос;
	НомерЗапроса = 1;
	
	ОбщиеПараметры = Новый Структура;
	ОбщиеПараметры.Вставить("Запрос", Запрос);
	ОбщиеПараметры.Вставить("ПакетЗапросов", ПакетЗапросов);
	ОбщиеПараметры.Вставить("ЧастиЗапроса", ЧастиЗапроса);
	ОбщиеПараметры.Вставить("УникальныйИдентификатор", УникальныйИдентификатор);
	
	// Собираем запрос
	Если ЗначениеЗаполнено(ДоступныеТипы) Тогда
		
		Для Каждого Тип Из ДоступныеТипы.Типы() Цикл 
			
			Если НЕ ИТК_ТипыКлиентСервер.ЭтоСсылочный(Тип, Истина) Тогда
				Продолжить;
			КонецЕсли;
			
			ОбъектМетаданных = Метаданные.НайтиПоТипу(Тип);
			ИмяОбъектаКоллекции = ИТК_Метаданные.ИмяОбъектаКоллекции(ОбъектМетаданных);
			Менеджер = ИТК_Метаданные.МенеджерОбъектаПоПолномуИмени(ОбъектМетаданных.ПолноеИмя());
			
			ДобавлениеЗапросаПоиска(ОбщиеПараметры, НомерЗапроса, Менеджер, ИмяОбъектаКоллекции, ОбъектМетаданных);
			
		КонецЦикла;
		
	Иначе
		
		ОписаниеСсылочныхТипов = ИТК_МетаданныеПовтИсп.ОписаниеСсылочныхТипов();
		Для Каждого ОписаниеСсылочногоТипа Из ОписаниеСсылочныхТипов Цикл
			
			Для Каждого ОбъектМетаданных Из ОписаниеСсылочногоТипа.Метаданные Цикл
				
				ИмяОбъектаКоллекции = ОписаниеСсылочногоТипа.Имя;
				Имя = ОбъектМетаданных.Имя;
				Менеджер = ОписаниеСсылочногоТипа.Менеджер[Имя];

				ДобавлениеЗапросаПоиска(ОбщиеПараметры, НомерЗапроса, Менеджер, ИмяОбъектаКоллекции, ОбъектМетаданных);
				
			КонецЦикла; 
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЧастиЗапроса) Тогда
		ДобавлениеЗапросовПоискаВПакет(ПакетЗапросов, ЧастиЗапроса);
	КонецЕсли;
	
	Результат = Новый Массив;
	
	// Выполняем запросы
	Для Каждого ЗапросПакета Из ПакетЗапросов Цикл 
		
		Запрос.Текст = ЗапросПакета;
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			Результат.Добавить(Выборка.Ссылка);
		КонецЦикла; 
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаполнитьДоступныеДействия(ЭлементПоиска)
	
	Если НЕ ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.18") Тогда
		Возврат;
	КонецЕсли;
	
	ДобавитьДействиеИнструмент(ЭлементПоиска, ИТК_Перечисления.ИнструментОткрытьОбъект(), Истина);
	ДобавитьДействиеИнструмент(ЭлементПоиска, ИТК_Перечисления.ИнструментРедакторОбъекта());
	ДобавитьДействиеИнструмент(ЭлементПоиска, ИТК_Перечисления.ИнструментГлобальноеМеню());
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПредставлениеПоискаОбъектаПоГУИД()
	
	Возврат НСтр("ru = 'Поиск по уникальному идентификатору'; en = 'Search by unique identifier'");
	
КонецФункции

Процедура ДобавлениеЗапросаПоиска(ОбщиеПараметры, НомерЗапроса, Менеджер, ИмяОбъектаКоллекции, ОбъектМетаданных)
	
	Если НЕ ПравоДоступа("Чтение", ОбъектМетаданных) Тогда
		Возврат;
	КонецЕсли;
	
	ИмяОбъекта = ОбъектМетаданных.Имя;
	
	ШаблонЗапроса = "ВЫБРАТЬ Ссылка ИЗ %1.%2 КАК Т ГДЕ Ссылка = &%3";
	ШаблонПараметра = "П%1";
	МаксимальныйРазмерПакета = 200;
	
	Запрос = ОбщиеПараметры.Запрос;
	ПакетЗапросов = ОбщиеПараметры.ПакетЗапросов;
	ЧастиЗапроса = ОбщиеПараметры.ЧастиЗапроса;
	УникальныйИдентификатор = ОбщиеПараметры.УникальныйИдентификатор;
	
	ИмяПараметра = СтрШаблон(ШаблонПараметра, Формат(НомерЗапроса, "ЧГ="));
	Ссылка = Менеджер.ПолучитьСсылку(УникальныйИдентификатор);
	Запрос.УстановитьПараметр(ИмяПараметра, Ссылка);
	
	ТекстЗапроса = СтрШаблон(ШаблонЗапроса, ИмяОбъектаКоллекции, ИмяОбъекта, ИмяПараметра);
	ЧастиЗапроса.Добавить(ТекстЗапроса);
	
	Если НомерЗапроса % МаксимальныйРазмерПакета = 0 Тогда
		ДобавлениеЗапросовПоискаВПакет(ПакетЗапросов, ЧастиЗапроса);
	КонецЕсли;
	
	НомерЗапроса = НомерЗапроса + 1;
	
КонецПроцедуры

Процедура ДобавлениеЗапросовПоискаВПакет(ПакетЗапросов, ЧастиЗапроса)
	
	ТекстЗапросаПакета = СтрСоединить(ЧастиЗапроса, " ОБЪЕДИНИТЬ ВСЕ ");
	ПакетЗапросов.Добавить(ТекстЗапросаПакета);
	ЧастиЗапроса.Очистить();
	
КонецПроцедуры

Процедура ДобавитьДействиеИнструмент(ЭлементПоиска, Инструмент, ДействиеПоУмолчанию = Ложь)
	
	ОписаниеИнструмента = ИТК_ТуллкитКлиентСервер.ОписаниеИнструмента(Инструмент);
	Если НЕ ОписаниеИнструмента.Доступ Тогда
		Возврат;
	КонецЕсли;
	
	ЗначениеДействия = Новый Структура;
	ЗначениеДействия.Вставить(ИТК_ГлобальныйПоискКлиентСервер.ИмяСвойстваПризнакПереопределяемогоДействия());
	
	ЗначениеДействия.Вставить("Инструмент", Инструмент);
	
	ПараметрДействия = ЭлементПоиска.Значение;
	ЗначениеДействия.Вставить("Параметр", ПараметрДействия);

	ПредставленияДействия = ОписаниеИнструмента.ПредставленияДействияКратко;
	Если ДействиеПоУмолчанию Тогда
		ПредставленияДействия = Новый ФорматированнаяСтрока(ПредставленияДействия, ИТК_ОбщийКлиентСервер.ШрифтЖирный());
	КонецЕсли;
	
	ЭлементПоиска.Действия.Добавить(ЗначениеДействия, ПредставленияДействия, ОписаниеИнструмента.Картинка);
	
КонецПроцедуры

Функция ПредставлениеДанные(Данные, Описание = Неопределено)
	
	ЧастиПредставления = Новый Массив;
	ЧастиПредставления.Добавить(Строка(Данные));
	
	Если ЗначениеЗаполнено(Описание) Тогда
		
		ЧастиПредставления.Добавить(Символы.ПС);
		ЧастиПредставления.Добавить(Новый ФорматированнаяСтрока(Описание, , WebЦвета.Серый));
		
	КонецЕсли;
		
	Возврат Новый ФорматированнаяСтрока(ЧастиПредставления);
	
КонецФункции

#КонецОбласти
