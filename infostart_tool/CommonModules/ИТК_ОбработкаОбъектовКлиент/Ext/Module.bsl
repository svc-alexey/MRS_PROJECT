#Область ПрограммныйИнтерфейс

Процедура Инициализация(Форма, Обрабатывается, ОписаниеОперации, Оповещение) Экспорт
	
	ИТК_ДлительныеОперацииКлиент.НачатьОперацию(Форма, Оповещение, ОписаниеОперации);
	
	// Инициализируем описание длительной обработки
	ОписаниеДлительнойОбработки = Новый Структура;
	ОписаниеДлительнойОбработки.Вставить("Начало", ТекущаяУниверсальнаяДатаВМиллисекундах());
	ОписаниеДлительнойОбработки.Вставить("ДатаНачала", ИТК_ОбщийВызовСервера.ТекущаяДатаСервера());
	ОписаниеДлительнойОбработки.Вставить("Состояние", Новый Структура("Ошибок, Обработано, Обрабатывается", 0, 0, Обрабатывается)); 
	
	ИдентификаторДлительнаяОбработка = ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторДлительнаяОбработка();
	Форма[ИдентификаторДлительнаяОбработка] = ОписаниеДлительнойОбработки;
	
	// Очищаем результаты обработки
	ИдентификаторАдресаРезультатов = ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаРезультатов();
	Форма[ИдентификаторАдресаРезультатов] = ИТК_ВременноеХранилище.Поместить(Новый Соответствие, Форма[ИдентификаторАдресаРезультатов], Форма.УникальныйИдентификатор);
	
КонецПроцедуры

Процедура ИнициализацияДлительнойОперации(Форма, ДлительнаяОперация, ОписаниеОперации, ОповещениеОПрогрессеВыполнения, ОповещениеОЗавершении) Экспорт
	
	ИТК_ДлительныеОперацииКлиент.ЗаполнитьОписаниеОперации(ДлительнаяОперация, ОписаниеОперации);
	
	ПараметрыОжидания = ИТК_ДлительныеОперацииКлиент.ПараметрыОжидания(Форма, ОповещениеОПрогрессеВыполнения);
	
	ИТК_ДлительныеОперацииКлиент.ДобавитьОповещениеПользователя(Форма, ПараметрыОжидания);
	ИТК_ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

Процедура ЗаполняемДанныеСледующегоПакета(Обрабатывается, ВремяОбработки, ИндексНачала, Количество, ИнтервалОбновления) Экспорт
	
	ВремяОбработкиСтроки = ВремяОбработки / Количество;
	ИндексНачала = ИндексНачала + Количество;
	РасчетноеКоличествоСтрокВДиапазоне = Макс(Цел(ИнтервалОбновления / ВремяОбработкиСтроки), 1);
	ИТК_ДлительныеОперацииКлиент.СледующийШагИнтервалаОжидания(ИнтервалОбновления);
	Количество = Мин(РасчетноеКоличествоСтрокВДиапазоне, Обрабатывается - ИндексНачала);
	
КонецПроцедуры

Функция СостояниеОбработки(Форма) Экспорт
	
	Возврат Форма[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторДлительнаяОбработка()].Состояние;
	
КонецФункции

Процедура ПоказатьПрогрессНаФорме(Форма, ПоказываетсяПрогресс) Экспорт
	
	ОписаниеДлительнойОбработки = Форма[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторДлительнаяОбработка()];
	ПрошлоВремени = ИТК_ОбщийКлиентСервер.МиллисекВСек(ТекущаяУниверсальнаяДатаВМиллисекундах() - ОписаниеДлительнойОбработки.Начало);
	
	Если Не ПоказываетсяПрогресс И ПрошлоВремени > 3 Тогда
		
		ИТК_ДлительныеОперацииКлиент.ПоказатьПрогресс(Форма, Ложь);
		ПоказываетсяПрогресс = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбновитьПрогресс(Форма, ФоновоеВыполнение = Истина) Экспорт
	
	ОписаниеДлительнойОбработки = Форма[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторДлительнаяОбработка()];
	
	Состояние = ОписаниеДлительнойОбработки.Состояние;
	Обрабатывается = Состояние.Обрабатывается;
	Обработано = Состояние.Обработано;
	Ошибок = Состояние.Ошибок;
	
	Прошло = ИТК_ОбщийКлиентСервер.МиллисекВСек(ТекущаяУниверсальнаяДатаВМиллисекундах() - ОписаниеДлительнойОбработки.Начало);
	
	ОцениваетсяТекст = НСтр("ru = 'оценивается...';
							|en = 'estimates...'");
	
	Если Обработано = 0 
			ИЛИ Прошло = 0 Тогда
			
		Если Обработано = 0 Тогда
			ПреставлениеОсталось = ОцениваетсяТекст;
		Иначе
			ПреставлениеОсталось = ИТК_Строки.КраткоеПредставлениеИнтервалаВремени(0);
		КонецЕсли;
		
		ДатаОкончания = Неопределено;                                                     
		
	Иначе
		
		Осталось = ((Обрабатывается - Обработано) * Прошло) / Обработано;
		ПреставлениеОсталось = ИТК_Строки.КраткоеПредставлениеИнтервалаВремени(Окр(Осталось));
		
		ДатаОкончания = ОписаниеДлительнойОбработки.ДатаНачала + Прошло + Осталось;
		
	КонецЕсли;
	
	ТекущаяДата = ИТК_ОбщийВызовСервера.ТекущаяДатаСервера();
	НачалоСледующегоДня = НачалоДня(ТекущаяДата + ИТК_ОбщийКлиентСервер.КоличествоСекундВДне());
	Если ДатаОкончания = Неопределено Тогда	
		
		ПредставлениеОкончания = ОцениваетсяТекст;
		
	ИначеЕсли НачалоДня(ТекущаяДата) = НачалоДня(ДатаОкончания) Тогда
		
		ПредставлениеОкончания = Формат(ДатаОкончания, "ДЛФ=T");
		
	ИначеЕсли НачалоСледующегоДня = НачалоДня(ДатаОкончания) Тогда
		
		ПредставлениеОкончания = СтрШаблон(НСтр("ru = 'завтра %1';
												|en = 'tomorrow %1'"), Формат(ДатаОкончания, "ДЛФ=T"));
		
	Иначе
		
		ПредставлениеОкончания = Формат(ДатаОкончания, "ДЛФ=DT");
		
	КонецЕсли;

	Состояние = СтрШаблон(НСтр("ru = 'Обработано: %1/%2, осталось: %3';
								|en = 'Processed: %1/%2, %3 left'"),	Обработано,	Обрабатывается,	ПреставлениеОсталось);
	
	Если ЗначениеЗаполнено(Ошибок) Тогда
		Состояние = Состояние + СтрШаблон(НСтр("ru = ', ошибок: %1';
												|en = ', errors: %1'"), Ошибок);
	КонецЕсли;
		
	Если Не ФоновоеВыполнение Тогда
		Состояние = Состояние + НСтр("ru = ' (Ctrl + Break - прервать)';
									|en = ' (Ctrl + Break - break)'");
	КонецЕсли;
	
	Форма[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторИндикацияОкончание()] = ПредставлениеОкончания;
	Форма[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторИндикацияПрогресс()] = ИТК_ОбщийКлиентСервер.ПроцентОтОбщего(Обработано, Обрабатывается);
	Форма[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторИндикацияПрошло()] = ИТК_Строки.КраткоеПредставлениеИнтервалаВремени(Окр(Прошло));
	Форма[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторИндикацияСостояние()] = Состояние;
	
КонецПроцедуры

Процедура ПоказатьИнформациюОПоследнейОбработке(Форма) Экспорт
	
	Элементы = Форма.Элементы;
	
	Элементы.ГруппаИнформацияОПоследнейОбработке.Видимость = Истина;
	Элементы.ИнформацияОПоследнейОбработке.Заголовок = ИнформацияОПоследнейОбработке(Форма);
	
КонецПроцедуры

Процедура ОбработатьКоманду(Форма, Имя) Экспорт
	
	Если СтрНайти(Имя, "ЖурналРегистрации") Тогда
		
		ИТК_ФормаКлиент.ОткрытьЖурналРегистрацииПоТекущемуПользователю();
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ИнформацияОПоследнейОбработке(Форма)
	
	СостояниеОбработки = ИТК_ОбработкаОбъектовКлиент.СостояниеОбработки(Форма);
	
	Ошибок = СостояниеОбработки.Ошибок;
	Обработано = СостояниеОбработки.Обработано;
	
	Прошло = Форма[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторИндикацияПрошло()];
	Если ЗначениеЗаполнено(Ошибок) Тогда
		
		Шаблон = НСтр("ru = 'Последней операцией обработано (%1), ошибок: %2, за %3';
						|en = 'Last operation processed (%1), errors: %2, for %3'");
		Результат = СтрШаблон(Шаблон, Обработано, Ошибок, Прошло);
		
	Иначе
		
		Шаблон = НСтр("ru = 'Последней операцией обработано (%1), за %2';
						|en = 'Last operation processed (%1), for %2'");
		Результат = СтрШаблон(Шаблон, Обработано, Прошло);
		
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

Процедура ДобавлениеВыделенныхСтрок(ВыделенныеСтроки, Строка)
	
	Если Строка.ЭтоГруппа Тогда
		
		Для Каждого ВложеннаяСтрока Из Строка.ПолучитьЭлементы() Цикл 
			ДобавлениеВыделенныхСтрок(ВыделенныеСтроки, ВложеннаяСтрока);
		КонецЦикла;
		
	Иначе
		
		Если ВыделенныеСтроки.Найти(Строка.НомерСтроки) = Неопределено Тогда
			ВыделенныеСтроки.Добавить(Строка.НомерСтроки);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция СтрокаЖурналаПоНомеру(Строка, НомерСтроки)
	
	Результат = Неопределено;
	
	Для Каждого ПодчиненнаяСтрока Из Строка.ПолучитьЭлементы() Цикл 
		
		Если ПодчиненнаяСтрока.НомерСтроки = НомерСтроки Тогда 
			
			Результат = ПодчиненнаяСтрока;
			Прервать;
			
		Иначе
			
			НайденнаяСтрока = СтрокаЖурналаПоНомеру(ПодчиненнаяСтрока, НомерСтроки);
			Если НайденнаяСтрока <> Неопределено Тогда
				
				Результат = НайденнаяСтрока;
				Прервать;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат
	
КонецФункции

Процедура ОбновитьГруппыЖурнала(Родитель)
	
	Для Каждого СтрокаЖурнала Из Родитель.ПолучитьЭлементы() Цикл 
		
		Если СтрокаЖурнала.ЭтоГруппа Тогда
			
			КоличествоПодчиненныхСтрок = КоличествоОбработанныхСтрок(СтрокаЖурнала);
			Если ЗначениеЗаполнено(КоличествоПодчиненныхСтрок) Тогда
				Представление = СтрШаблон("%1 (%2)", СтрокаЖурнала.Текст, КоличествоПодчиненныхСтрок);
			Иначе
				Представление = СтрокаЖурнала.Текст;
			КонецЕсли;
			СтрокаЖурнала.Представление = Представление;
			
			ОбновитьГруппыЖурнала(СтрокаЖурнала);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция КоличествоОбработанныхСтрок(Строка)
	
	ПодчиненныеСтроки = Строка.ПолучитьЭлементы();
	Количество = ПодчиненныеСтроки.Количество();
	Результат = Количество;
	
	Если ЗначениеЗаполнено(Количество) Тогда
		
		ПерваяСтрока = ПодчиненныеСтроки[0];
		Если Не СтрокаСчитаетсяОбработанной(ПерваяСтрока) Тогда
			
			Результат = Результат - 1;
			
		КонецЕсли;
		
		ПоследняяСтрока = ПодчиненныеСтроки[Количество - 1];
		Если Не СтрокаСчитаетсяОбработанной(ПоследняяСтрока)
				И ПерваяСтрока <> ПоследняяСтрока Тогда
				
			Результат = Результат - 1;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СтрокаСчитаетсяОбработанной(Строка)
	
	Возврат (Строка.ЭтоГруппа 
				ИЛИ ИТК_ОбработкаРезультатаКлиентСервер.ЭтоИндексОбъекта(Строка.НомерСтроки));
	
КонецФункции

Процедура ОбработатьСообщенияПрогресса(Форма, Сообщения) Экспорт
	
	ПоследняяДобавляемаяСтрокаСообщения = Форма["ПоследняяДобавляемаяСтрокаСообщения"];

	РезультатыОбработки = Форма["РезультатыОбработки"];

	ПапкаУспешно = Неопределено; ПапкаОшибка = Неопределено; 
	ПапкиПоТекстуОшибки = Новый Соответствие;
	
	Для Каждого Сообщение Из Сообщения Цикл 
		
		ТекстСообщения = Сообщение.Текст;
		ПрефиксНачало = ИТК_ДлительныеОперацииКлиентСервер.ПрефиксНачалоОбработкиОбъекта();
		ПрефиксКонец = ИТК_ДлительныеОперацииКлиентСервер.ПрефиксКонецОбработкиОбъекта();
		
		Если СтрНачинаетсяС(ТекстСообщения, ПрефиксНачало) Тогда // Начало
			
			ПоследняяДобавляемаяСтрокаСообщения.Очистить(); 
			ПоследняяДобавляемаяСтрокаНомер = ИТК_ДлительныеОперацииКлиентСервер.ПрочитатьИндексОбъектаИзСообщенияНачала(ТекстСообщения);
			
		ИначеЕсли СтрНачинаетсяС(ТекстСообщения, ПрефиксКонец) Тогда // Конец
			
			Ошибка = ИТК_ДлительныеОперацииКлиентСервер.ПрочитатьОшибкуОбработкиОбъектаИзСообщенияКонца(ТекстСообщения);
			
			Результат = Новый Структура;
			
			Если ЗначениеЗаполнено(Ошибка) Тогда
				Результат.Вставить("Ошибка", Ошибка);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ПоследняяДобавляемаяСтрокаСообщения) Тогда 
				
				СообщенияСтроки = Новый Массив;
				Для Каждого ПоследняяДобавляемаяСтрокаСообщение Из ПоследняяДобавляемаяСтрокаСообщения Цикл 
					СообщенияСтроки.Добавить(ПоследняяДобавляемаяСтрокаСообщение.Значение);
				КонецЦикла;
				
				Результат.Вставить("Сообщения", СообщенияСтроки);
				
			КонецЕсли;
			
			НомерСтроки = ПоследняяДобавляемаяСтрокаНомер;
			
			Если РезультатыОбработки.Получить(НомерСтроки) = Неопределено Тогда
				
				РезультатыОбработки.Вставить(НомерСтроки, Результат);
				
				Представление = ""; 
				ДобавитьСтрокаРезультатВЖурнал(Форма, НомерСтроки, Результат, Представление,
												ПапкаУспешно, ПапкаОшибка, ПапкиПоТекстуОшибки);
				
			КонецЕсли;
			
		Иначе // Сообщение
			
			ПоследняяДобавляемаяСтрокаСообщения.Добавить(ТекстСообщения);
			
		КонецЕсли;

	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьСтрокаРезультатВЖурнал(Форма, Номер, Результат, Представление, ПапкаУспешно, ПапкаОшибка, ПапкиПоТекстуОшибки)
	
	ИТК_ДлительнаяОперация = Форма["ИТК_ДлительнаяОперация"];
	СостояниеОбработки = ИТК_ДлительнаяОперация.СостояниеОбработки;

	Если ИТК_ОбработкаРезультатаКлиентСервер.ЭтоИндексОбъекта(Номер) Тогда
		
		СостояниеОбработки.Обработано = СостояниеОбработки.Обработано + 1;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

