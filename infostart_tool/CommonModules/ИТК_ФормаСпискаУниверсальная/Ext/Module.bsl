#Область ПрограммныйИнтерфейс

Функция ПоляОбъектаМетаданных(ОбъектМетаданных) Экспорт
	
	ИмяКоллекции = ИТК_Метаданные.ИмяКоллекции(ОбъектМетаданных);
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Имя");
	Результат.Колонки.Добавить("ТипЗначения", ИТК_ТипыКлиентСервер.ОписаниеИзСтроки("ОписаниеТипов"));
	Результат.Колонки.Добавить("Представление");
	
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ИмеетСтандартныеРеквизиты(ИмяКоллекции) Тогда
		
		ПоляИсключения = ПоляИсключенияСтандартныхРеквизитов(ИмяКоллекции, ОбъектМетаданных);
		ДобавитьПоляНабораОбъектовМетаданных(Результат, ОбъектМетаданных.СтандартныеРеквизиты, ПоляИсключения);
		
	КонецЕсли;

	Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоРегистр(ИмяКоллекции) Тогда
		
		ДобавитьПоляНабораОбъектовМетаданных(Результат, ОбъектМетаданных.Измерения);
		ДобавитьПоляНабораОбъектовМетаданных(Результат, ОбъектМетаданных.Ресурсы);
		
	ИначеЕсли ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоЖурналДокументов(ИмяКоллекции) Тогда
		
		ДобавитьПоляНабораОбъектовМетаданных(Результат, ОбъектМетаданных.Графы, , Ложь);
		
	ИначеЕсли ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоВнешнийИсточникДанных(ИмяКоллекции) Тогда
		
		ДобавитьПоляНабораОбъектовМетаданных(Результат, ОбъектМетаданных.Поля);
		
	КонецЕсли;
	
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ИмеетРеквизиты(ИмяКоллекции) Тогда
		
		ДобавитьПоляНабораОбъектовМетаданных(Результат, ОбъектМетаданных.Реквизиты);
		
	КонецЕсли;
	
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПланСчетов(ИмяКоллекции) Тогда
		
		ДобавитьПоляНабораОбъектовМетаданных(Результат, ОбъектМетаданных.ПризнакиУчета);
		
	КонецЕсли;
	
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоСсылочныйОбъект(ИмяКоллекции)
			ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоЖурналДокументов(ИмяКоллекции) Тогда
			
		ПолеСсылка = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Ссылка");
		НовоеПоле = ДобавитьПоле(Результат, ПолеСсылка, НСтр("ru = 'Cсылка'; en = 'Ref'"));
		
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ДобавитьПоляНабораОбъектовМетаданных(Поля, НаборОбъектов, ПоляИсключения = Неопределено, ЗаполнениеТипа = Истина)
	
	Для Каждого ОбъектМетаданных Из НаборОбъектов Цикл 
		
		ИмяПоля = ОбъектМетаданных.Имя;
		Если ПоляИсключения <> Неопределено
				И ПоляИсключения.Свойство(ИмяПоля) Тогда
				
			Продолжить;
			
		КонецЕсли;
		
		НовоеПоле = ДобавитьПоле(Поля, ИмяПоля, ОбъектМетаданных.Представление());
		
		Если ЗаполнениеТипа Тогда
			НовоеПоле.ТипЗначения = ОбъектМетаданных.Тип;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ДобавитьПоле(Поля, Имя, Представление)
	
	НовоеПоле = Поля.Добавить();
	НовоеПоле.Имя = Имя;
	НовоеПоле.Представление = Представление;
	
	Возврат НовоеПоле;
	
КонецФункции

Функция ПоляИсключенияСтандартныхРеквизитов(ИмяКоллекции, ОбъектМетаданных)
	
	Результат = Новый Структура;
	
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ОбъектCПредопределенными(ИмяКоллекции) Тогда
		
		ПолеИмяПредопределенныхДанных = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("ИмяПредопределенныхДанных");
		Результат.Вставить(ПолеИмяПредопределенныхДанных);
		
		ПолеПредопределенный = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Предопределенный");
		Результат.Вставить(ПолеПредопределенный);
		
	КонецЕсли;
	
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоДокумент(ИмяКоллекции) Тогда
		
		ПолеПроведен = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Проведен");
		Результат.Вставить(ПолеПроведен);
		
	ИначеЕсли ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПланОбмена(ИмяКоллекции) Тогда
		
		ПолеЭтотУзел = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("ЭтотУзел");
		Результат.Вставить(ПолеЭтотУзел);
		
	КонецЕсли;
	
	Если ИТК_Метаданные.ОбъектСИерархией(ОбъектМетаданных) Тогда
		
		ПолеРодитель = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Родитель");
		Результат.Вставить(ПолеРодитель);
		
	КонецЕсли;
	
	Если ИТК_Метаданные.ОбъектСИерархиейГрупп(ОбъектМетаданных) Тогда
		
		ПолеЭтоГруппа = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("ЭтоГруппа");
		Результат.Вставить(ПолеЭтоГруппа);
		
	КонецЕсли;
	
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоСсылочныйОбъект(ИмяКоллекции)
			ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоЖурналДокументов(ИмяКоллекции) Тогда
			
		ПолеСсылка = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Ссылка");
		Результат.Вставить(ПолеСсылка);
		
		ПолеПометкаУдаления = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("ПометкаУдаления");
		Результат.Вставить(ПолеПометкаУдаления);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
