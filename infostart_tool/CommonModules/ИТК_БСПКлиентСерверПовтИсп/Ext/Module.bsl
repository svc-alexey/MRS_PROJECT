#Область ПрограммныйИнтерфейс

Функция АнглийскийИдентификаторСтандартнойОбработки(Идентификатор) Экспорт 
	
	СоответствиеИмен = Новый Соответствие;
	СоответствиеИмен.Вставить("ГрупповоеИзменениеРеквизитов", "BatchEditAttributes");
	СоответствиеИмен.Вставить("ЖурналРегистрации", "EventLog");
	СоответствиеИмен.Вставить("ПоискИУдалениеДублей", "DuplicateObjectsDetection");
	СоответствиеИмен.Вставить("УдалениеПомеченныхОбъектов", "MarkedObjectsDeletion");
	СоответствиеИмен.Вставить("РегистрацияИзмененийДляОбменаДанными", "RegisterChangesForDataExchange");
	
	Возврат СоответствиеИмен.Получить(Идентификатор);
	
КонецФункции

Функция ОбщийМодуль(Модуль) Экспорт
	
	ОписаниеМодуля = Модуль(Модуль);
	
	Если ТипЗнч(ОписаниеМодуля) = Тип("Массив") Тогда
		
		Для Каждого ИмяМодуля Из ОписаниеМодуля Цикл
			
			Результат = ИТК_МетаданныеКлиентСерверПовтИсп.ОбщийМодуль(ИмяМодуля);
			Если Результат <> Неопределено Тогда
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
	Иначе
		
		Результат = ИТК_МетаданныеКлиентСерверПовтИсп.ОбщийМодуль(ОписаниеМодуля);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Модуль(Имя) Экспорт
	
	Результат = Имя;
	Если ИТК_ОбщийПовтИсп.ВариантВстроенногоЯзыкаАнглийский() Тогда
		Результат = ИмяМодуляНаАнглийском(Имя);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИмяФункцииМодуля(Имя) Экспорт
	
	Результат = Имя;
	Если АнглийскаяБСП() Тогда
		Результат = ИмяМетодаНаАнглийском(Имя);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция АнглийскаяБСП() Экспорт
	
	Возврат ИТК_БСППовтИсп.АнглийскаяБСП();
	
КонецФункции

Функция ПолноеИмяФормыШаблонаОтчетаНаСКД() Экспорт
	
	Если НЕ ИТК_БСППовтИсп.ИспользуетсяБСП() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат "ОбщаяФорма.ФормаОтчета";
	
КонецФункции

Функция РежимОтладки() Экспорт
	
	Если НЕ ИТК_БСППовтИсп.ИспользуетсяБСП() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат ИТК_БСПКлиентСервер.ВыполнитьФункцию("ОбщегоНазначенияКлиентСервер.РежимОтладки");
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ИмяМодуляНаАнглийском(Имя)
	
	СоответствиеИмен = Новый Соответствие;
	
	ВариантыИменМодулей = Новый Массив;
	ВариантыИменМодулей.Добавить("CommonUtil");
	ВариантыИменМодулей.Добавить("Common");
	
	СоответствиеИмен.Вставить("ОбщегоНазначения", ВариантыИменМодулей);
	
	ВариантыИменМодулей = Новый Массив;
	ВариантыИменМодулей.Добавить("CommonUtilCached");
	ВариантыИменМодулей.Добавить("CommonCached");
	
	СоответствиеИмен.Вставить("ОбщегоНазначенияПовтИсп", ВариантыИменМодулей);
	
	ВариантыИменМодулей = Новый Массив;
	ВариантыИменМодулей.Добавить("CommonUtilClientServer");
	ВариантыИменМодулей.Добавить("CommonClientServer");
	
	СоответствиеИмен.Вставить("ОбщегоНазначенияКлиентСервер", ВариантыИменМодулей);
	
	СоответствиеИмен.Вставить("ЗапретРедактированияРеквизитовОбъектов", "ObjectAttributesLock");
	СоответствиеИмен.Вставить("ЗапретРедактированияРеквизитовОбъектовСлужебный", "ObjectAttributesLockInternal");
	
	СоответствиеИмен.Вставить("ДлительныеОперации", "TimeConsumingOperations");
	СоответствиеИмен.Вставить("ДлительныеОперацииКлиент", "TimeConsumingOperationsClient");
	
	СоответствиеИмен.Вставить("РегламентныеЗаданияСервер", "ScheduledJobsServer");
	СоответствиеИмен.Вставить("РегламентныеЗаданияСлужебный", "ScheduledJobsInternal");
	
	СоответствиеИмен.Вставить("РаботаВМоделиСервиса", "SaaS");
	СоответствиеИмен.Вставить("УправлениеСвойствами", "PropertyManager");
	СоответствиеИмен.Вставить("СтандартныеПодсистемыСервер", "StandardSubsystemsServer");
	СоответствиеИмен.Вставить("ЗагрузкаДанныхИзФайлаКлиент", "ImportDataFromFileClient");
	СоответствиеИмен.Вставить("ОбменДаннымиСобытия", "DataExchangeEvents");
	
	Результат = СоответствиеИмен.Получить(Имя);
	Если Результат = Неопределено Тогда
		ВызватьИсключение СтрШаблон("Неизвестное имя модуля %1 для английской БСП", Имя);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИмяМетодаНаАнглийском(Имя)
	
	СоответствиеИмен = Новый Соответствие;
	СоответствиеИмен.Вставить("РежимОтладки", "DebugMode");
	СоответствиеИмен.Вставить("ВерсияБиблиотеки", "LibraryVersion");
	СоответствиеИмен.Вставить("ПодсистемаСуществует", "SubsystemExists");
	СоответствиеИмен.Вставить("РегламентныеЗаданияЗависимыеОтФункциональныхОпций", "ScheduledJobsDependentOnFunctionalOptions");
	СоответствиеИмен.Вставить("РегламентноеЗаданиеДоступноПоФункциональнымОпциям", "ScheduledJobAvailableByFunctionalOptions");
	СоответствиеИмен.Вставить("ПолучитьОбщийСписокИсключенийПоискаСсылок", "RefSearchExceptions");
	СоответствиеИмен.Вставить("ИсключенияПоискаСсылок", "RefSearchExceptions");
	СоответствиеИмен.Вставить("РазделениеВключено", "DataSeparationEnabled");
	СоответствиеИмен.Вставить("ИспользованиеРазделителяСеанса", "SessionSeparatorUsage");
	СоответствиеИмен.Вставить("ПолучитьСписокСвойств", "GetPropertyList");
	СоответствиеИмен.Вставить("ПолучитьЗначенияСвойств", "GetValuesProperties");
	СоответствиеИмен.Вставить("БлокируемыеРеквизитыОбъекта", "ObjectAttributesToLock");
	СоответствиеИмен.Вставить("ЗапретРедактированияПредусмотрен", "LockSupported");
	СоответствиеИмен.Вставить("ИспользоватьДопРеквизиты", "UseAddlAttributes");
	СоответствиеИмен.Вставить("ИспользоватьДопСведения", "UseAddlInfo");
	СоответствиеИмен.Вставить("РазблокироватьРаботуСВнешнимиРесурсами", "UnlockOperationsWithExternalResources");
	СоответствиеИмен.Вставить("РаботаСВнешнимиРесурсамиЗаблокирована", "ExternalResourceUsageLockSet");
	СоответствиеИмен.Вставить("ПсевдонимПользователяИнформационнойБазы", "AliasOfTheDatabaseUser");
	СоответствиеИмен.Вставить("ПриОтправкеДанныхКорреспонденту", "OnSendDataToRecipient");
	
	// ДлительныеОперации
	СоответствиеИмен.Вставить("ЗаданиеВыполнено", "JobCompleted");
	СоответствиеИмен.Вставить("СообщитьПрогресс", "ReportProgress");
	
	ИмяФункцииПараметрыВыполненияВФоне = "FunctionExecutionParameters";
	Если ИТК_МетаданныеПовтИсп.ИмяКонфигурации() = "Drive" Тогда
		ИмяФункцииПараметрыВыполненияВФоне = "BackgroundExecutionParameters";
	КонецЕсли;
	СоответствиеИмен.Вставить("ПараметрыВыполненияВФоне", ИмяФункцииПараметрыВыполненияВФоне);
	
	СоответствиеИмен.Вставить("ВыполнитьВФоне", "ExecuteInBackground");
	СоответствиеИмен.Вставить("ОтменитьВыполнениеЗадания", "CancelJobExecution");
	
	// ДлительныеОперацииКлиент
	СоответствиеИмен.Вставить("ИнициализироватьПараметрыОбработчикаОжидания", "InitIdleHandlerParameters");
	СоответствиеИмен.Вставить("ПараметрыОжидания", "IdleParameters");
	
	ИмяФункцииОжидатьЗавершение = "WaitCompletion";
	Если ИТК_МетаданныеПовтИсп.ИмяКонфигурации() = "Drive" Тогда
		ИмяФункцииОжидатьЗавершение = "WaitForCompletion";
	КонецЕсли;
	СоответствиеИмен.Вставить("ОжидатьЗавершение", ИмяФункцииОжидатьЗавершение);
	
	//ЗагрузкаДанныхИзФайлаКлиент
	СоответствиеИмен.Вставить("ПоказатьФормуЗаполненияСсылок", "ShowRefFillingForm");
	
	Результат = СоответствиеИмен.Получить(Имя);
	Если Результат = Неопределено Тогда
		ВызватьИсключение СтрШаблон("Неизвестное имя функции %1 для английской БСП", Имя);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
