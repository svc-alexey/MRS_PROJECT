Функция Исполнить(Код, Режим) Экспорт
	
	ВыполнениеСРезультатом = (Режим = ИТК_Перечисления.РежимВыполненияКодаВыполнение());
	
	Результат = Неопределено;
	Result = Неопределено;
	
	ИсполняемыйКод = ПодготовкаКодаИсполнения(Код);
	
	// Начало замера времени выполнения --------------------------------------------------------------------------------- {
	НачалоЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Попытка	
		
		// BSLLS:ExecuteExternalCodeInCommonModule-off
		Выполнить(ИсполняемыйКод);
		// BSLLS:ExecuteExternalCodeInCommonModule-on
		РезультатВыполнения = Результат;
		
	Исключение
		
		ВремяВыполнения = Неопределено;
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ПодробнаяИнформацияОбОшибке = ПодробнаяИнформацияООшибке(ИнформацияОбОшибке);
		
	КонецПопытки;
		
	// Конец замера { ---------------------------------------------------------------------------------------------------
	ВремяВыполнения = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоЗамера;
	
	ОписаниеРезультата = Новый Структура;
	ОписаниеРезультата.Вставить("РежимВыполнения", Режим);
	ОписаниеРезультата.Вставить("ВремяВыполнения", ВремяВыполнения);
	ОписаниеРезультата.Вставить("ОшибкаПриВыполнении", ПодробнаяИнформацияОбОшибке);
	ОписаниеРезультата.Вставить("Результат", РезультатВыполнения);
	
	Возврат ОписаниеРезультата;
	
КонецФункции

Функция ЗначениеСтрока(Значение, ЗаключитьВКавычки = Истина) Экспорт
	
	Результат = СтрЗаменить(Значение, ИТК_Строки.СимволКавычки(), ИТК_Строки.СимволДвойныеКавычки()); // Заменяем кавычки в тексте двойными кавычками
	
	Если ИТК_Строки.МногострочнаяСтрока(Значение) Тогда
		Результат = СтрЗаменить(Результат, Символы.ПС, Символы.ПС + "|");
	КонецЕсли;
	
	Если ЗаключитьВКавычки Тогда
		Результат = СтрШаблон("""%1""", Результат);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СтрокуВЗначение(Строка) Экспорт
	
	СимволКавычки = ИТК_Строки.СимволКавычки();
	
	Результат = СтрЗаменить(Строка, ИТК_Строки.СимволДвойныеКавычки(), СимволКавычки);
	
	Если ИТК_Строки.МногострочнаяСтрока(Строка) Тогда
		Результат = СтрЗаменить(Результат, Символы.ПС + "|", Символы.ПС);
	КонецЕсли;
		
	Если СтрНачинаетсяС(Результат, СимволКавычки) Тогда
		Результат = Сред(Результат, 2);
	КонецЕсли;
	
	Если СтрЗаканчиваетсяНа(Результат, СимволКавычки) Тогда
		Результат = Лев(Результат, СтрДлина(Результат) - 1);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПодробнаяИнформацияООшибке(ИнформацияОбОшибке) Экспорт
	
	Результат = Новый Структура;
	
	ОписаниеОшибки = ПодробноеОписаниеОшибки(ИнформацияОбОшибке);
	Результат.Вставить("ОписаниеОшибки", ОписаниеОшибки);
	
	// Подготовка стека вызовов
	СтекВызовов = Новый Массив;
	
	Если ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.15") Тогда // С 15 платформы ПодробноеПредставлениеОшибки() возвращает стек вызовов
		ЗаполнитьСтекВызовов(СтекВызовов, ИнформацияОбОшибке);
	КонецЕсли;
	
	Результат.Вставить("СтекВызовов", СтекВызовов);
	
	Возврат Результат;
	
КонецФункции

Функция ПредставлениеОшибки(Ошибка) Экспорт
	
	ОписаниеОшибки = Ошибка.ОписаниеОшибки;
	
	ЗаполненоИмяМодуля = ЗначениеЗаполнено(ОписаниеОшибки.ИмяМодуля);
	НомерСтроки = ИТК_Строки.ЧислоВСтроку(ОписаниеОшибки.НомерСтроки);
	
	ЧастиОшибки = Новый Массив;
	
	// Представление ошибки
	Если ЗаполненоИмяМодуля Тогда
		
		ЧастьОшибка = ОписаниеОшибки.Описание;
		
	Иначе
		
		ЧастьОшибка = СтрШаблон("{%1} %2", НомерСтроки, ОписаниеОшибки.Описание);
		
	КонецЕсли;
	
	ЧастиОшибки.Добавить(ЧастьОшибка);
	
	// Представление модуля
	Если ЗаполненоИмяМодуля Тогда
		
		ЧастьМодуль = СтрШаблон("%1(%2): %3", ОписаниеОшибки.ИмяМодуля, НомерСтроки, ОписаниеОшибки.ИсходнаяСтрока);
		ЧастиОшибки.Добавить(ЧастьМодуль);
			
	КонецЕсли;
	
	Возврат СтрСоединить(ЧастиОшибки, Символы.ПС);
	
КонецФункции

Функция ОписаниеОшибкиВМодуле(Текст) Экспорт
	
	ПервыйСимвол = ИТК_Строки.РазборПрочитатьСимвол(Текст);
	Если ПервыйСимвол <> "{" Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	НомерСимвола = 1;
	ИТК_Строки.РазборПропуститьНаборСимволов(Текст, "{", НомерСимвола);
	ИмяМодуля = ИТК_Строки.РазборПрочитатьДоСимвола(Текст, "(", НомерСимвола);

	ИТК_Строки.РазборПропуститьНаборСимволов(Текст, "(", НомерСимвола);
	НомерСтроки = ИТК_Строки.РазборПрочитатьЦелоеЧисло(Текст, НомерСимвола);
	ИТК_Строки.РазборПропуститьНаборСимволов(Текст, ")}:", НомерСимвола);

	ИсходнаяСтрока = ИТК_Строки.РазборПрочитатьДоСимвола(Текст, "", НомерСимвола);
	ИсходнаяСтрока = СокрЛП(ИсходнаяСтрока);

	Результат = Новый Структура;
	Результат.Вставить("ИмяМодуля", ИмяМодуля);
	Результат.Вставить("НомерСтроки", НомерСтроки);
	Результат.Вставить("ИсходнаяСтрока", ИсходнаяСтрока);
	
	Возврат Результат;
	
КонецФункции

Функция ОписаниеОшибкиВКоде(Текст) Экспорт
	
	// Варианты текста
	// {(1,63)}: Ожидается символ ')'
	// {<Неизвестный модуль>(1,1)}: Объявления переменных должны быть расположены в начале модуля, процедуры или функции
	
	НомерСтроки = Неопределено;
	НомерКолонки = Неопределено;
	
	ПервыйСимвол = ИТК_Строки.РазборПрочитатьСимвол(Текст);
	Если ПервыйСимвол <> "{" Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	НомерСимвола = 1;
	ИТК_Строки.РазборПропуститьНаборСимволов(Текст, "{", НомерСимвола);
	ИТК_Строки.РазборПрочитатьДоСимвола(Текст, "(", НомерСимвола);
	ИТК_Строки.РазборПропуститьНаборСимволов(Текст, "(", НомерСимвола);
	
	НомерСтроки = ИТК_Строки.РазборПрочитатьЦелоеЧисло(Текст, НомерСимвола);
	
	Символ = ИТК_Строки.РазборПрочитатьСимвол(Текст, НомерСимвола, Ложь);
	Если Символ = "," Тогда
		
		ИТК_Строки.РазборПропуститьНаборСимволов(Текст, ",", НомерСимвола);
		ИТК_Строки.РазборПрочитатьНезначимые(Текст, НомерСимвола);
		НомерКолонки = ИТК_Строки.РазборПрочитатьЦелоеЧисло(Текст, НомерСимвола);
		
	КонецЕсли;
	ИТК_Строки.РазборПропуститьНаборСимволов(Текст, ")}: ", НомерСимвола);
	
	Ошибка = ИТК_Строки.РазборПрочитатьДоСимвола(Текст, "", НомерСимвола);

	Результат = Новый Структура;
	Результат.Вставить("НомерСтроки", НомерСтроки);
	Результат.Вставить("НомерКолонки", НомерКолонки);
	Результат.Вставить("Ошибка", Ошибка);
	
	Возврат Результат;
	
КонецФункции

