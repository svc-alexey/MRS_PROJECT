#Область СлужебныеПроцедурыИФункции

Функция ПодготовкаКодаИсполнения(Код)
	
	Результат = Код;
	
	Разделитель = Символы.ПС;
	
	ДобавлятьМетку = Ложь;
	ИмяМеткиВыхода = "~МеткаВКонце";
	
	// Заменим Возврат на Перейти
	СтрокиКода = СтрРазделить(Код, Разделитель);
	Для ИндексСтроки = 0 По СтрокиКода.ВГраница() Цикл 
		
		СтрокаКода = СтрокиКода[ИндексСтроки];
		
		НомерСимвола = 1;
		ИТК_Строки.РазборПрочитатьНезначимые(СтрокаКода, НомерСимвола);
		Идентификатор = ИТК_Строки.РазборПрочитатьИдентификатор(СтрокаКода, НомерСимвола);
		
		Если ПустаяСтрока(Идентификатор) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ВРег(Идентификатор) = "ВОЗВРАТ"
				ИЛИ ВРег(Идентификатор) = "RETURN" Тогда
				
			ДобавлятьМетку = Истина;
			
			ИТК_Строки.РазборПрочитатьНезначимые(СтрокаКода, НомерСимвола);
			СледующийСимвол = ИТК_Строки.РазборПрочитатьСимвол(СтрокаКода, НомерСимвола, Ложь);
			
			ВыражениеВозврата = ИТК_Строки.РазборПрочитатьДоСимвола(СтрокаКода, ";", НомерСимвола);
			
			НоваяСтрокаКода = "Перейти " + ИмяМеткиВыхода + ";";
			Если СледующийСимвол <> ";" Тогда
				НоваяСтрокаКода = "Результат = " + ВыражениеВозврата + ";" + НоваяСтрокаКода;
			КонецЕсли;
			
			СтрокиКода[ИндексСтроки] = НоваяСтрокаКода;
				
		КонецЕсли;
		
	КонецЦикла;
	
	Результат = СтрСоединить(СтрокиКода, Разделитель);
	
	// Добавление метки выхода
	Если ДобавлятьМетку Тогда 
		
		Результат = Результат + "
		|" + ИмяМеткиВыхода + ":";
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаполнитьСтекВызовов(СтекВызовов, ИнформацияОбОшибке)
	
	// Дополнение начала стека
	// https://github.com/infostart-hub/toolkit/issues/948
	ПричинаОшибки = ИнформацияОбОшибке.Причина;
	Пока ПричинаОшибки <> Неопределено Цикл 
		
		ПричинаОшибки = ПричинаОшибки.Причина;
		Если ПричинаОшибки = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ОписаниеСтрокиСтекаВызовов = Новый Структура;
		ОписаниеСтрокиСтекаВызовов.Вставить("ИмяМодуля", ПричинаОшибки.ИмяМодуля);
		ОписаниеСтрокиСтекаВызовов.Вставить("НомерСтроки", ПричинаОшибки.НомерСтроки);
		ОписаниеСтрокиСтекаВызовов.Вставить("ИсходнаяСтрока", ПричинаОшибки.ИсходнаяСтрока);
		ОписаниеСтрокиСтекаВызовов.Вставить("ТекстОшибки", ПричинаОшибки.Описание);
		
		СтекВызовов.Добавить(ОписаниеСтрокиСтекаВызовов);
		
		Если НЕ ЗначениеЗаполнено(ПричинаОшибки.ИмяМодуля) Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если НЕ ЗначениеЗаполнено(ИнформацияОбОшибке.ИмяМодуля) Тогда
		Возврат;
	КонецЕсли;
	
	ОшибкаПодробно = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
	
	// Удалим ошибку в начале текста
	Если ИнформацияОбОшибке.Причина = Неопределено Тогда
		ТекстОшибки = ИнформацияОбОшибке.Описание;
	Иначе
		ТекстОшибки = ИнформацияОбОшибке.Причина.Описание;
	КонецЕсли;
	
	ОшибкаПодробно = ИТК_Строки.УдалитьПрефикс(ОшибкаПодробно, ТекстОшибки);
	ОшибкаПодробно = СокрЛП(ОшибкаПодробно);
	
	// Удалим строки вызова выполенения кода (вызовы из разширения)
	СтрокаПоиска = "{" + ИТК_ТуллкитКлиентСервер.Идентификатор();
	НомерСимвола = СтрНайти(ОшибкаПодробно, СтрокаПоиска);
	Если ЗначениеЗаполнено(НомерСимвола) Тогда
		ОшибкаПодробно = Лев(ОшибкаПодробно, НомерСимвола - 1);
	КонецЕсли;
	ОшибкаПодробно = СокрЛП(ОшибкаПодробно);
	
	// Обходим строки исключая последнию строку
	КоличествоСтрок = СтрЧислоСтрок(ОшибкаПодробно);
	Для НомерСтрокиСтекаВызовов = 1 По КоличествоСтрок - 1 Цикл 
		
		// СтрокаСтекаВызовов = "{ОбщийМодуль.ОбщегоНазначения.Модуль(2776)}:	Возврат Ссылка.Метаданные().ПолноеИмя();"
		СтрокаСтекаВызовов = СтрПолучитьСтроку(ОшибкаПодробно, НомерСтрокиСтекаВызовов);
		ОписаниеСтрокиСтекаВызовов = ОписаниеОшибкиВМодуле(СтрокаСтекаВызовов);
		Если ОписаниеСтрокиСтекаВызовов = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СтекВызовов.Добавить(ОписаниеСтрокиСтекаВызовов);
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПодробноеОписаниеОшибки(ИнформацияОбОшибке)
	
	Результат = Новый Структура;
	Результат.Вставить("ИмяМодуля");
	Результат.Вставить("НомерСтроки");
	Результат.Вставить("ИсходнаяСтрока");
	Результат.Вставить("Описание");
	
	Если ИнформацияОбОшибке.Причина = Неопределено Тогда
		Источник = ИнформацияОбОшибке;
	Иначе
		Источник = ИнформацияОбОшибке.Причина;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Результат, Источник);
	Если НЕ ЗначениеЗаполнено(ИнформацияОбОшибке.ИмяМодуля) Тогда
		ЗаполнитьЗначенияСвойств(Результат, ИнформацияОбОшибке, "НомерСтроки, ИсходнаяСтрока");
	КонецЕсли;
	
	Если Результат.НомерСтроки = 0 Тогда
		
		ОписаниеОшибки = ОписаниеОшибкиВКоде(Результат.Описание);
		Если ОписаниеОшибки = Неопределено Тогда
			Результат.НомерСтроки = 1;
		Иначе
			
			Результат.НомерСтроки = ОписаниеОшибки.НомерСтроки;
			Результат.Описание = ОписаниеОшибки.Ошибка;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция БезСтроковыхЛитералов(Код)
	
	СимволДвойныеКавычки = """";
	Результат = СтрЗаменить(Код, СимволДвойныеКавычки + СимволДвойныеКавычки, "");
	
	СостояниеСтроковойЛитерал = Ложь;
	Для Сч = 1 По СтрДлина(Код) Цикл 
		
		Символ = Сред(Код, Сч, 1);
		Если Символ = СимволДвойныеКавычки Тогда
			
			Если Сч = СтрДлина(Код) Тогда
				СледующийСимвол = Неопределено;
			Иначе
				СледующийСимвол = Сред(Код, Сч + 1, 1);
			КонецЕсли;
			
			Если СледующийСимвол = СимволДвойныеКавычки Тогда
				
				СостояниеСтроковойЛитерал = Истина;
				Сч = Сч + 1;
				
			Иначе
				
				СостояниеСтроковойЛитерал = НЕ СостояниеСтроковойЛитерал;
				Продолжить;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если СостояниеСтроковойЛитерал Тогда
			Продолжить;
		КонецЕсли;
		
		Результат = Результат + Символ;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура НайтиИспользуемыеПеременныеВСтрокеКода(Результат, СтрокаКода)
	
	ПоискИспользуемыхПеременныхВозврат(Результат, СтрокаКода);
	ПоискИспользуемыхПеременныхВПрисвоениях(Результат, СтрокаКода);
	ПоискИспользуемыхПеременныхВСчетчикахЦикла(Результат, СтрокаКода);
	
КонецПроцедуры

Процедура ПоискИспользуемыхПеременныхВСчетчикахЦикла(Результат, СтрокаКода)
	
	НомерСимвола = 1;
	ИТК_Строки.РазборПрочитатьНезначимые(СтрокаКода, НомерСимвола);
	Идентификатор = ИТК_Строки.РазборПрочитатьИдентификатор(СтрокаКода, НомерСимвола);
	Если НРег(Идентификатор) = НРег("Для")
			ИЛИ НРег(Идентификатор) = НРег("For") Тогда
			
		ИТК_Строки.РазборПрочитатьНезначимые(СтрокаКода, НомерСимвола);
		
		СледующийИдентификатор = ИТК_Строки.РазборПрочитатьИдентификатор(СтрокаКода, НомерСимвола);
		Если НРег(СледующийИдентификатор) = НРег("Каждого")
				ИЛИ НРег(СледующийИдентификатор) = НРег("Each") Тогда
				
			ИТК_Строки.РазборПрочитатьНезначимые(СтрокаКода, НомерСимвола);
			
			ИмяСчетчика = ИТК_Строки.РазборПрочитатьИдентификатор(СтрокаКода, НомерСимвола);
			ДобавитьИспользуемуюПеременнуюВРезультат(Результат, ИмяСчетчика);
			
		Иначе
			ДобавитьИспользуемуюПеременнуюВРезультат(Результат, СледующийИдентификатор);
		КонецЕсли;
			
	КонецЕсли;
	
КонецПроцедуры

Процедура ПоискИспользуемыхПеременныхВПрисвоениях(Результат, СтрокаКода)
	
	НомерСимвола = 1;
	ИТК_Строки.РазборПрочитатьНезначимые(СтрокаКода, НомерСимвола);
	Идентификатор = ИТК_Строки.РазборПрочитатьИдентификатор(СтрокаКода, НомерСимвола);
	Если НРег(Идентификатор) = НРег("Если")
			ИЛИ НРег(Идентификатор) = НРег("If")
			ИЛИ НРег(Идентификатор) = НРег("ИначеЕсли")
			ИЛИ НРег(Идентификатор) = НРег("ElseIf") Тогда
		Возврат;
	КонецЕсли;
	
	ИТК_Строки.РазборПрочитатьНезначимые(СтрокаКода, НомерСимвола);
	СледующийСимвол = ИТК_Строки.РазборПрочитатьСимвол(СтрокаКода, НомерСимвола);
	
	Если СледующийСимвол = "=" Тогда
		ДобавитьИспользуемуюПеременнуюВРезультат(Результат, Идентификатор);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПоискИспользуемыхПеременныхВозврат(Результат, СтрокаКода)
	
	НомерСимвола = 1;
	ИТК_Строки.РазборПрочитатьНезначимые(СтрокаКода, НомерСимвола);
	Идентификатор = ИТК_Строки.РазборПрочитатьИдентификатор(СтрокаКода, НомерСимвола);
	Если НРег(Идентификатор) = НРег("Возврат")
			ИЛИ НРег(Идентификатор) = НРег("Return") Тогда
		ДобавитьИспользуемуюПеременнуюВРезультат(Результат, "");
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьИспользуемуюПеременнуюВРезультат(Результат, Имя)
	
	Для Каждого Элемент Из Результат Цикл 
		
		Если НРег(Элемент.Значение) = НРег(Имя) Тогда
			Возврат;
		КонецЕсли;
		
	КонецЦикла;
	
	Результат.Добавить(Имя);
	
КонецПроцедуры

#КонецОбласти
