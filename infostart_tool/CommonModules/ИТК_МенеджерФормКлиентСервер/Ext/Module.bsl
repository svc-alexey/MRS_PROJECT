#Область ПрограммныйИнтерфейс

Функция КартинкаЭлемента(Элемент) Экспорт
	
	КартинкиЭлементов = ИТК_МенеджерФормКлиентСерверПовтИсп.КартинкиЭлементов();

	КартинкаЭлемента = КартинкиЭлементов.Получить(ТипЗнч(Элемент));
	Если ТипЗнч(КартинкаЭлемента) = Тип("Соответствие") Тогда
		КартинкаЭлемента = КартинкаЭлемента.Получить(Элемент.Вид);
	КонецЕсли;
	
	Возврат КартинкаЭлемента;
	
КонецФункции

Функция ВидЭлемента(Элемент) Экспорт
	
	ТипыЭлементовИмеющиеВид = ИТК_МенеджерФормКлиентСерверПовтИсп.ТипыЭлементовИмеющиеВид();
	
	ЭлементИмеетВид = ТипыЭлементовИмеющиеВид.Получить(ТипЗнч(Элемент));
	Если ЭлементИмеетВид = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат Элемент.Вид;
	
КонецФункции

Функция ДоступенТолькоПросмотр(Элемент) Экспорт
	
	ТипыЭлементовСДоступнымТолькоПросмотр = ИТК_МенеджерФормКлиентСерверПовтИсп.ТипыЭлементовСДоступнымТолькоПросмотр();
	
	ДоступенТолькоПросмотр = ТипыЭлементовСДоступнымТолькоПросмотр.Получить(ТипЗнч(Элемент));
	Если ДоступенТолькоПросмотр = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция ОформлениеАктивизированногоЭлемента(Элемент) Экспорт
	
	Результат = Новый Соответствие;
	
	ЭтоПолеВвода = (ТипЗнч(Элемент) = Тип("ПолеФормы") И Элемент.Вид = ВидПоляФормы.ПолеВвода);
	ЭтоПолеФлажка = (ТипЗнч(Элемент) = Тип("ПолеФормы") И Элемент.Вид = ВидПоляФормы.ПолеФлажка);
	ЭтоПолеНадписи = (ТипЗнч(Элемент) = Тип("ПолеФормы") И Элемент.Вид = ВидПоляФормы.ПолеНадписи);
	ЭтоПолеПериода = (ТипЗнч(Элемент) = Тип("ПолеФормы") И Элемент.Вид = ВидПоляФормы.ПолеПериода);
	ЭтоПолеКартинки = (ТипЗнч(Элемент) = Тип("ПолеФормы") И Элемент.Вид = ВидПоляФормы.ПолеКартинки);
	ЭтоПолеКалендаря = (ТипЗнч(Элемент) = Тип("ПолеФормы") И Элемент.Вид = ВидПоляФормы.ПолеКалендаря);
	ЭтоПолеИндикатора = (ТипЗнч(Элемент) = Тип("ПолеФормы") И Элемент.Вид = ВидПоляФормы.ПолеИндикатора);
	ЭтоПолеПланировщика = (ТипЗнч(Элемент) = Тип("ПолеФормы") И Элемент.Вид = ВидПоляФормы.ПолеПланировщика);
	ЭтоПолеПереключателя = (ТипЗнч(Элемент) = Тип("ПолеФормы") И Элемент.Вид = ВидПоляФормы.ПолеПереключателя);	
	ЭтоПолеПолосыРегулирования = (ТипЗнч(Элемент) = Тип("ПолеФормы") И Элемент.Вид = ВидПоляФормы.ПолеПолосыРегулирования);
	ЭтоПолеТабличногоДокумента = (ТипЗнч(Элемент) = Тип("ПолеФормы") И Элемент.Вид = ВидПоляФормы.ПолеТабличногоДокумента);
	ЭтоПолеHTMLДокумента = (ТипЗнч(Элемент) = Тип("ПолеФормы") И Элемент.Вид = ВидПоляФормы.ПолеHTMLДокумента);
	ЭтоПолеТекстовогоДокумента = (ТипЗнч(Элемент) = Тип("ПолеФормы") И Элемент.Вид = ВидПоляФормы.ПолеТекстовогоДокумента);
	ЭтоПолеФорматированногоДокумента = (ТипЗнч(Элемент) = Тип("ПолеФормы") И Элемент.Вид = ВидПоляФормы.ПолеФорматированногоДокумента);
	ЭтоПолеPDFДокумента = (ТипЗнч(Элемент) = Тип("ПолеФормы")
								И ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.21")
								И Элемент.Вид = Вычислить("ВидПоляФормы.ПолеPDFДокумента"));

	ЭтоПолеДиаграммы = (ТипЗнч(Элемент) = Тип("ПолеФормы") И Элемент.Вид = ВидПоляФормы.ПолеДиаграммы);
	ЭтоПолеДендрограммы = (ТипЗнч(Элемент) = Тип("ПолеФормы") И Элемент.Вид = ВидПоляФормы.ПолеДендрограммы);
	ЭтоПолеГеографическойСхемы = (ТипЗнч(Элемент) = Тип("ПолеФормы") И Элемент.Вид = ВидПоляФормы.ПолеГеографическойСхемы);
	ЭтоПолеДиаграммыГанта = (ТипЗнч(Элемент) = Тип("ПолеФормы") И Элемент.Вид = ВидПоляФормы.ПолеДиаграммыГанта);
	
	ЭтоДекорацияНадпись = (ТипЗнч(Элемент) = Тип("ДекорацияФормы") И Элемент.Вид = ВидДекорацииФормы.Надпись);
	ЭтоДекорацияКартинка = (ТипЗнч(Элемент) = Тип("ДекорацияФормы") И Элемент.Вид = ВидДекорацииФормы.Картинка);
	
	ЭтоКнопка = (ТипЗнч(Элемент) = Тип("КнопкаФормы"));
	ЭтоТаблица = (ТипЗнч(Элемент) = Тип("ТаблицаФормы"));
	
	ЭтоОбычнаяГруппа = (ТипЗнч(Элемент) = Тип("ГруппаФормы") И Элемент.Вид = ВидГруппыФормы.ОбычнаяГруппа);
	ЭтоГруппаСтраница = (ТипЗнч(Элемент) = Тип("ГруппаФормы") И Элемент.Вид = ВидГруппыФормы.Страница);
	ЭтоГруппаПодменю = (ТипЗнч(Элемент) = Тип("ГруппаФормы") И Элемент.Вид = ВидГруппыФормы.Подменю);
	
	Если ЭтоОбычнаяГруппа
			ИЛИ ЭтоГруппаПодменю
			ИЛИ ЭтоГруппаСтраница
			ИЛИ ЭтоПолеВвода
			ИЛИ ЭтоПолеНадписи
			ИЛИ ЭтоПолеПереключателя
			ИЛИ ЭтоКнопка
			ИЛИ ЭтоДекорацияНадпись
			ИЛИ ЭтоТаблица
			ИЛИ ЭтоПолеТекстовогоДокумента
			Тогда
		Результат.Вставить("ЦветФона", ИТК_МенеджерФормКлиентСерверПовтИсп.ЦветФонаАктивизированногоЭлемента());
	КонецЕсли;
	
	Если ЭтоПолеВвода
			ИЛИ ЭтоПолеКартинки
			ИЛИ ЭтоПолеФлажка
			ИЛИ ЭтоПолеПериода
			ИЛИ ЭтоПолеКалендаря
			ИЛИ ЭтоТаблица
			ИЛИ ЭтоПолеТабличногоДокумента
			ИЛИ ЭтоПолеФорматированногоДокумента
			ИЛИ ЭтоПолеPDFДокумента
			ИЛИ ЭтоПолеHTMLДокумента
			ИЛИ ЭтоДекорацияКартинка
			Тогда
		Результат.Вставить("ЦветРамки", ИТК_МенеджерФормКлиентСерверПовтИсп.ЦветФонаАктивизированногоЭлемента());
	КонецЕсли;
	
	Если ЭтоПолеВвода
			ИЛИ ЭтоПолеФлажка
			ИЛИ ЭтоПолеНадписи
			ИЛИ ЭтоПолеИндикатора
			ИЛИ ЭтоПолеПериода
			ИЛИ ЭтоПолеПланировщика
			ИЛИ ЭтоПолеКалендаря
			ИЛИ ЭтоПолеТабличногоДокумента
			ИЛИ ЭтоПолеФорматированногоДокумента
			ИЛИ ЭтоПолеPDFДокумента
			ИЛИ ЭтоПолеHTMLДокумента
			ИЛИ ЭтоПолеПереключателя
			ИЛИ ЭтоПолеПолосыРегулирования
			ИЛИ ЭтоПолеДиаграммы
			ИЛИ ЭтоПолеДендрограммы
			ИЛИ ЭтоПолеДиаграммыГанта
			ИЛИ ЭтоПолеГеографическойСхемы
			Тогда
		Результат.Вставить("ЦветТекстаЗаголовка", ИТК_МенеджерФормКлиентСерверПовтИсп.ЦветТекстаЗаголовкаАктивизированногоЭлемента());
	КонецЕсли;
	
	Если ЭтоПолеКартинки
			ИЛИ ЭтоПолеПериода
			ИЛИ ЭтоПолеКалендаря
			ИЛИ ЭтоДекорацияКартинка
			Тогда
		Результат.Вставить("Рамка", Новый Рамка(ТипРамкиЭлементаУправления.Одинарная, 3));
	КонецЕсли;
	
	Если ЭтоПолеВвода
			ИЛИ ЭтоПолеФлажка
			ИЛИ ЭтоПолеПереключателя
			ИЛИ ЭтоПолеНадписи
			ИЛИ ЭтоПолеИндикатора
			ИЛИ ЭтоПолеПериода
			ИЛИ ЭтоПолеПланировщика
			ИЛИ ЭтоПолеКалендаря
			ИЛИ ЭтоПолеТабличногоДокумента
			ИЛИ ЭтоПолеФорматированногоДокумента
			ИЛИ ЭтоПолеТекстовогоДокумента
			ИЛИ ЭтоПолеPDFДокумента
			ИЛИ ЭтоПолеHTMLДокумента
			ИЛИ ЭтоПолеПолосыРегулирования
			ИЛИ ЭтоПолеДиаграммы
			ИЛИ ЭтоПолеДендрограммы
			ИЛИ ЭтоПолеДиаграммыГанта
			ИЛИ ЭтоПолеГеографическойСхемы
			Тогда
		Результат.Вставить("ШрифтЗаголовка", ИТК_ОбщийКлиентСервер.ШрифтЖирный());
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

#КонецОбласти
