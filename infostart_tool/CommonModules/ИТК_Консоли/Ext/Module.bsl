Процедура СоздатьКомандыГруппыДанные(Форма, Инструмент)
	
	ИмяДействия = "ПодключаемыйОбработчикРаботаСДанными";
	ИспользоватьОбъединение = (Инструмент = ИТК_Перечисления.ИнструментКонсольЗапросов());
	
	// Новые
	ИмяКоманды = ИТК_КонсолиКлиентСервер.ГруппаДанныеИмяКомандыНовые();
	ЗаголовокКоманды = НСтр("ru = 'Новые'; en = 'New'");
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Картинка", ИТК_ТуллкитКлиентСервер.КартинкаИнструмента(Инструмент));
	ДополнительныеПараметры.Вставить("Подсказка", НСтр("ru = 'Новые данные'; en = 'New data'"));
	
	ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяДействия, ЗаголовокКоманды, ДополнительныеПараметры);
	
	// Сохранить
	ИмяКоманды = ИТК_КонсолиКлиентСервер.ГруппаДанныеИмяКомандыСохранить();
	ЗаголовокКоманды = НСтр("ru = 'Сохранить'; en = 'Save'");
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Картинка", БиблиотекаКартинок.СохранитьФайл);
	ДополнительныеПараметры.Вставить("Отображение", ОтображениеКнопки.Картинка);
	
	ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяДействия, ЗаголовокКоманды, ДополнительныеПараметры);
	
	// Работа с файлом -----------------------------------------------------------
	// Открыть файл
	ИмяКоманды = ИТК_КонсолиКлиентСервер.ГруппаДанныеИмяКомандыОткрытьФайл();
	ЗаголовокКоманды = НСтр("ru = 'Открыть файл...'; en = 'File open...'");
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Картинка", БиблиотекаКартинок.ОткрытьФайл);
	
	ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяДействия, ЗаголовокКоманды, ДополнительныеПараметры);
	
	// Сохранить файл как
	ИмяКоманды = ИТК_КонсолиКлиентСервер.ГруппаДанныеИмяКомандыСохранитьФайлКак();
	ЗаголовокКоманды = НСтр("ru = 'Сохранить файл как...'; en = 'Save file as...'");
	
	ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяДействия, ЗаголовокКоманды);
	
	// Объединить с файлом
	Если ИспользоватьОбъединение Тогда
		
		ИмяКоманды = ИТК_КонсолиКлиентСервер.ГруппаДанныемяКомандыОбъединитьСФайлом();
		ЗаголовокКоманды = НСтр("ru = 'Объединить с файлом...'; en = 'Merge with file...'");
		
		ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяДействия, ЗаголовокКоманды);
		
	КонецЕсли;
	
	// Открыть папку содержащую файл
	ИмяКоманды = ИТК_КонсолиКлиентСервер.ГруппаДанныеИмяКомандыОткрытьПапкуСодержащуюФайл();
	ЗаголовокКоманды = НСтр("ru = 'Открыть папку содержащую файл'; en = 'Open the folder containing the file'");
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Картинка", БиблиотекаКартинок.ИТК_ОткрытьПапку);
	
	ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяДействия, ЗаголовокКоманды, ДополнительныеПараметры);
	
	// Работа с настройкой -----------------------------------------------------------
	// Открыть настройку
	ИмяКоманды = ИТК_КонсолиКлиентСервер.ГруппаДанныеИмяКомандыОткрытьНастройку();
	ЗаголовокКоманды = НСтр("ru = 'Открыть настройку...'; en = 'Open setting...'");
	
	ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяДействия, ЗаголовокКоманды);
	
	// Сохранить настройку как
	ИмяКоманды = ИТК_КонсолиКлиентСервер.ГруппаДанныеИмяКомандыСохранитьНастройкиКак();
	ЗаголовокКоманды = НСтр("ru = 'Сохранить настройку как...'; en = 'Save setting as...'");
	
	ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяДействия, ЗаголовокКоманды);
	
	// Объединить с настройкой
	Если ИспользоватьОбъединение Тогда
		
		ИмяКоманды = ИТК_КонсолиКлиентСервер.ГруппаДанныеИмяКомандыОбъединитьСНастройкой();
		ЗаголовокКоманды = НСтр("ru = 'Объединить с настройкой...'; en = 'Merge with setting...'");
		
		ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяДействия, ЗаголовокКоманды);
		
	КонецЕсли;
	
КонецПроцедуры

Функция ДобавитьСтрокуВДеревоДанных(Представление, ТипСтроки, Родитель, ДополнительныеПараметры = Неопределено)
	
	// Добавление новой строки
	НоваяСтрока = Родитель.ПолучитьЭлементы().Добавить();
	ИТК_КонсолиКлиентСервер.ЗаполнениеСтрокиДереваДанных(НоваяСтрока, ТипСтроки, Представление, ДополнительныеПараметры);
	
	Возврат НоваяСтрока;
	
КонецФункции

Функция ПоследниеРабочиеДанные(Форма)
	
	КлючОбъекта = ИТК_ТуллкитКлиентСервер.ПредставлениеИнструмента(Форма["Инструмент"]);
	КлючНастроек = ПоследниеРабочиеДанные_КлючНастроек();
	
	Результат = ХранилищеСистемныхНастроек.Загрузить(КлючОбъекта, КлючНастроек);
	Если Результат = Неопределено Тогда
		Результат = ПоследниеРабочиеДанные_Пустые();
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ПоследниеРабочиеДанные_Сохранить(Форма, ПоследниеРабочиеДанные)
	
	Инструмент = Форма["Инструмент"];
	КлючОбъекта = ИТК_ТуллкитКлиентСервер.ПредставлениеИнструмента(Инструмент);
	
	// Обновляем ключ обновления
	КлючНастроек = ПоследниеРабочиеДанные_КлючОбновленияКлючНастроек();
	ХранилищеСистемныхНастроек.Сохранить(КлючОбъекта, КлючНастроек, ТекущаяУниверсальнаяДатаВМиллисекундах());
	
	// Сохраняем новые настройки
	КлючНастроек = ПоследниеРабочиеДанные_КлючНастроек();
	ХранилищеСистемныхНастроек.Сохранить(КлючОбъекта, КлючНастроек, ПоследниеРабочиеДанные);
	
КонецПроцедуры

Процедура ПоследниеРабочиеДанные_ДобавитьЭлемент(Форма, Тип, Имя)
	
	ПоследниеРабочиеДанные = ПоследниеРабочиеДанные(Форма);
	
	// Добавить элемент
	НайденныеСтроки = ПоследниеРабочиеДанные.НайтиСтроки(Новый Структура("Тип, Имя", Тип, Имя));
	Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
		
		Строка = НайденныеСтроки[0];
		ПоследниеРабочиеДанные.Сдвинуть(Строка, -ПоследниеРабочиеДанные.Индекс(Строка));
		
	Иначе 
		
		Строка = ПоследниеРабочиеДанные.Вставить(0);
		Строка.Тип = Тип;
		Строка.Имя = Имя;
		
	КонецЕсли;
	
	// Удалим лишние строки
	НайденныеСтроки = ПоследниеРабочиеДанные.НайтиСтроки(Новый Структура("Тип", Тип));
	Если НайденныеСтроки.Количество() > 7 Тогда
		ПоследниеРабочиеДанные.Удалить(НайденныеСтроки[НайденныеСтроки.ВГраница()]);
	КонецЕсли;
	
	ПоследниеРабочиеДанные_Сохранить(Форма, ПоследниеРабочиеДанные)
	
КонецПроцедуры

Функция ПоследниеРабочиеДанные_КлючНастроек()
	
	Возврат "Последние рабочие данные";
	
КонецФункции

Функция ПоследниеРабочиеДанные_КлючОбновленияКлючНастроек()
	
	Возврат ПоследниеРабочиеДанные_КлючНастроек() + " (ключ обновления)";
	
КонецФункции

Функция ПоследниеРабочиеДанные_Пустые()
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Тип");
	Результат.Колонки.Добавить("Имя", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
		
	Возврат Результат;
	
КонецФункции

Процедура ВосстановлениеДанныхПослеАварийногоЗавершения(Форма, ДанныеАвтосохранения)
	
	РабочиеДанные = Форма["РабочиеДанные"];

	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Модифицированность", Истина);
	ИТК_КонсолиФорматДанных.Загрузка(Форма, ДанныеАвтосохранения.Данные, ДополнительныеПараметры);
	
	ЗаполнитьЗначенияСвойств(РабочиеДанные, ДанныеАвтосохранения.Тип);
	РабочиеДанные.Комментарий = НСтр("ru = 'восстановлен, аварийное завершение';
									|en = 'restored crash'");
		
	ИТК_КонсолиКлиентСервер.СброситьМодифицированностьДанных(Форма);
	
КонецПроцедуры

