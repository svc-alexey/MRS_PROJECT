#Область ПрограммныйИнтерфейс

Процедура ПодключитьГруппуДанные(Форма, Родитель) Экспорт
	
	Инструмент = Форма["Инструмент"];
	СоздатьКомандыГруппыДанные(Форма, Инструмент);
	
	ПрефиксИмени = ИТК_КонсолиКлиентСервер.ГруппаДанныеПрефикс();
	
	// Подменю данные ----------------------------------------------------------
	Поля = Новый Структура;
	Поля.Вставить("Заголовок", НСтр("ru = 'Данные'; en = 'Date'"));
	ПодменюДанные = ИТК_Форма.ДобавитьЭлемент(Форма, ПрефиксИмени + "Группа", "Подменю", Поля, Родитель);
	
	// Новые
	Поля = Новый Структура;
	Поля.Вставить("ИмяКоманды", ИТК_КонсолиКлиентСервер.ГруппаДанныеИмяКомандыНовые());
	ИТК_Форма.ДобавитьЭлемент(Форма, ПрефиксИмени + "Новые", "Кнопка", Поля, ПодменюДанные);
	
	// Подменю файл ----------------------------------------------------------
	Поля = Новый Структура;
	Поля.Вставить("Заголовок", НСтр("ru = 'Файл'; en = 'File'"));
	ГруппаДанныеФайл = ИТК_Форма.ДобавитьЭлемент(Форма, ПрефиксИмени + "ГруппаФайл", "Группа", Поля, ПодменюДанные);
	
	// Открыть файл
	Поля = Новый Структура;
	Поля.Вставить("ИмяКоманды", ИТК_КонсолиКлиентСервер.ГруппаДанныеИмяКомандыОткрытьФайл());
	ИТК_Форма.ДобавитьЭлемент(Форма, ПрефиксИмени + "ОткрытьФайл", "Кнопка", Поля, ГруппаДанныеФайл);
	
	// Сохранить файл как
	Поля = Новый Структура;
	Поля.Вставить("ИмяКоманды", ИТК_КонсолиКлиентСервер.ГруппаДанныеИмяКомандыСохранитьФайлКак());
	ИТК_Форма.ДобавитьЭлемент(Форма, ПрефиксИмени + "СохранитьФайлКак", "Кнопка", Поля, ГруппаДанныеФайл);
	
	// Объединить с файлом
	ИмяКоманды = ИТК_КонсолиКлиентСервер.ГруппаДанныеИмяКомандыОбъединитьСФайлом();
	Если Форма.Команды.Найти(ИмяКоманды) <> Неопределено Тогда
		Поля = Новый Структура;
		Поля.Вставить("ИмяКоманды", ИмяКоманды);
		ИТК_Форма.ДобавитьЭлемент(Форма, ПрефиксИмени + "ОбъединитьСФайлом", "Кнопка", Поля, ГруппаДанныеФайл);
	КонецЕсли;
	
	// Открыть папку содержащую файл
	Поля = Новый Структура;
	Поля.Вставить("ИмяКоманды", ИТК_КонсолиКлиентСервер.ГруппаДанныеИмяКомандыОткрытьПапкуСодержащуюФайл());
	ИТК_Форма.ДобавитьЭлемент(Форма, ПрефиксИмени + "ОткрытьПапкуСодержащуюФайл", "Кнопка", Поля, ГруппаДанныеФайл);
	
	// Подменю настройка ----------------------------------------------------------
	Поля = Новый Структура;
	Поля.Вставить("Заголовок", НСтр("ru = 'Настройка'; en = 'Setting'"));
	ГруппаДанныеНастройка = ИТК_Форма.ДобавитьЭлемент(Форма, ПрефиксИмени + "ГруппаНастройка", "Группа", Поля, ПодменюДанные);
	
	// Открыть настройку
	Поля = Новый Структура;
	Поля.Вставить("ИмяКоманды", ИТК_КонсолиКлиентСервер.ГруппаДанныеИмяКомандыОткрытьНастройку());
	ИТК_Форма.ДобавитьЭлемент(Форма, ПрефиксИмени + "ОткрытьНастройку", "Кнопка", Поля, ГруппаДанныеНастройка);
	
	// Сохранить настройки как
	Поля = Новый Структура;
	Поля.Вставить("ИмяКоманды", ИТК_КонсолиКлиентСервер.ГруппаДанныеИмяКомандыСохранитьНастройкиКак());
	ИТК_Форма.ДобавитьЭлемент(Форма, ПрефиксИмени + "СохранитьНастройкиКак", "Кнопка", Поля, ГруппаДанныеНастройка);
	
	// Объединить с настройкой
	ИмяКоманды = ИТК_КонсолиКлиентСервер.ГруппаДанныеИмяКомандыОбъединитьСНастройкой();
	Если Форма.Команды.Найти(ИмяКоманды) <> Неопределено Тогда
		Поля = Новый Структура;
		Поля.Вставить("ИмяКоманды", ИмяКоманды);
		ИТК_Форма.ДобавитьЭлемент(Форма, ПрефиксИмени + "ОбъединитьСНастройкой", "Кнопка", Поля, ГруппаДанныеНастройка);
	КонецЕсли;
	
	// Кнопка панели Сохранить
	Поля = Новый Структура;
	Поля.Вставить("ИмяКоманды", ИТК_КонсолиКлиентСервер.ГруппаДанныеИмяКомандыСохранить());
	Поля.Вставить("СочетаниеКлавиш", Новый СочетаниеКлавиш(Клавиша.S, , Истина));
	Поля.Вставить("Картинка", ИТК_КонсолиКлиентСервер.КартинкаКнопкиСохранить(Форма));
	ИТК_Форма.ДобавитьЭлемент(Форма, ПрефиксИмени + "Сохранить", "Кнопка", Поля, Родитель);
	
	// Подменю Последние рабочие Данные
	Поля = Новый Структура;
	Поля.Вставить("Заголовок", НСтр("ru = 'Последние рабочие данные'; en = 'Latest working data'"));
	ИТК_Форма.ДобавитьЭлемент(Форма, ПрефиксИмени + "ПоследниеРабочиеДанные", "Группа", Поля, ПодменюДанные);
	
КонецПроцедуры

Процедура ПриСозданииНаСервере(Форма, Инструмент) Экспорт
	
	// Добавляем реквизиты
	ДобавляемыеРеквизиты = Новый Массив;
	
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, "Инструмент");
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, "РабочиеДанные");
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, "ПоследниеРабочиеДанные_Адрес");
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, "ПоследниеРабочиеДанные_КлючОбновления");
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, "ИдентификаторПоследнейВыделеннойСтроки");
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, "ЗакрытиеРазрешено");
	
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, "РезультатВыполнения");
	
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, "ДлительнаяОперацияАвтоматическоеСохранение");
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, "МодифицированностьАвтоСохранение", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, "МодифицированностьПослеОтменыРедактированияДереваДанных", ИТК_ТипыКлиентСервер.ОписаниеБулево());

    Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	// Заполнение служебных полей
	Форма["Инструмент"] = Инструмент;
	Форма["РабочиеДанные"] = Новый Структура("Тип, Имя, Комментарий");
	
	// Устанавливаем условное оформление
	ОформлениеЖирныйШрифт = Новый Структура("Шрифт", ИТК_ОбщийКлиентСервер.ШрифтЖирный());
	ИТК_Форма.ДобавитьУсловноеОформление(Форма.УсловноеОформление, "ДеревоДанныхПредставление",
											ОформлениеЖирныйШрифт, "ДеревоДанных.Выделение", Истина);
											
	ПодключитьГруппуДанные(Форма, Форма.Элементы["ГруппаДанные"]);
	
	ПоследниеРабочиеДанные_ОбновитьЭлементы(Форма);

	// Начальные данные и восстановление аварийного завершения
	КлючОбъекта = ИТК_НастройкиКлиентСерверПовтИсп.КлючОбъектаСлужебные(Инструмент);
	ЗавершеноАварийно = ХранилищеСистемныхНастроек.Загрузить(КлючОбъекта, "ЗавершеноАварийно");
	
	Если ЗавершеноАварийно = Ложь Тогда // Может быть Неопределено когда настроек нет
		
		ХранилищеСистемныхНастроек.Сохранить(КлючОбъекта, "Автосохранение", Неопределено);
		ИТК_Консоли.НовыеДанные(Форма);
		
	Иначе
		
		ХранилищеСистемныхНастроек.Сохранить(КлючОбъекта, "Автосохранение", Неопределено);
		ДанныеАвтосохранения = ХранилищеСистемныхНастроек.Загрузить(КлючОбъекта, "Автосохранение");
		Если ЗначениеЗаполнено(ДанныеАвтосохранения) Тогда
			ВосстановлениеДанныхПослеАварийногоЗавершения(Форма, ДанныеАвтосохранения);
		Иначе
			ИТК_Консоли.НовыеДанные(Форма);
		КонецЕсли;
		
	КонецЕсли;
	ХранилищеСистемныхНастроек.Сохранить(КлючОбъекта, "ЗавершеноАварийно", Истина);
	
КонецПроцедуры

Процедура ПриСохраненииДанныхВНастройкахНаСервере(Форма) Экспорт
	
	Инструмент = Форма["Инструмент"];
	КлючОбъекта = ИТК_НастройкиКлиентСерверПовтИсп.КлючОбъектаСлужебные(Инструмент);
	ХранилищеСистемныхНастроек.Сохранить(КлючОбъекта, "ЗавершеноАварийно", Ложь);
	
КонецПроцедуры

Процедура НовыеДанные(Форма) Экспорт
	
	ОчиститьДанные(Форма);
	ИТК_КонсолиКлиентСервер.УстановитьРабочиеДанные(Форма);
	
	Инструмент = Форма["Инструмент"];
	
	ТипНовойСтроки = ИТК_КонсолиКлиентСервер.ТипДобавляемойСтрокиПоУмолчанию(Инструмент);
	ПредставлениеНовойСтроки = ИТК_КонсолиКлиентСервер.ПредставлениеСтрокиПоУмолчанию(Инструмент);
	
	ДополнительныеПараметры = Новый Структура;
	
	Если Инструмент = ИТК_Перечисления.ИнструментКонсольКода() Тогда 
		
		ОбрабатываемыеОбъекты = ИТК_ОбщийКлиентСервер.Свойство(Форма.Параметры, "ОбрабатываемыеОбъекты");
		
		Если ЗначениеЗаполнено(ОбрабатываемыеОбъекты) Тогда
			
			НачальныеДанные = ИТК_КонсолиКлиентСервер.НовыеДанныеСтрокиДереваДанных(ТипНовойСтроки);
			ДополнительныеПараметры.Вставить("НачальныеДанные", НачальныеДанные);
			
			КодЯзыкаПрограммирования = ИТК_Общий.КодЯзыкаПрограммирования();
			Если ОбрабатываемыеОбъекты.Количество() = 1 Тогда
				
				ИмяПараметра = НСтр("ru = 'Объект'; en = 'Object'", КодЯзыкаПрограммирования);
				ЗначениеПараметра = ОбрабатываемыеОбъекты[0];
				
				ТекстКода = НСтр("ru = 'Объект = Параметры.Объект.ПолучитьОбъект();
                                  |<!>';
								  |en = 'Object = Parametrs.Object.GetObject();
                                  |<!>'", КодЯзыкаПрограммирования);
				
			Иначе
				
				ИмяПараметра = НСтр("ru = 'Объекты'; en = 'Objects'", КодЯзыкаПрограммирования);
				ЗначениеПараметра = Новый СписокЗначений;
				ЗначениеПараметра.ЗагрузитьЗначения(ОбрабатываемыеОбъекты);
				
				ТекстКода = НСтр("ru = 'Для Каждого Ссылка Из Параметры.Объекты Цикл
                             |	
                             |	Объект = Ссылка.ПолучитьОбъект();
                             |	<!>
							 |	
                             |КонецЦикла;';
							 |en = 'For Each Ref To Parametrs.Objects Do
							 |	
                             |	Object = Ref.GetObject();
                             |	<!>
							 |	
                             |EndDo;'", КодЯзыкаПрограммирования);
				
			КонецЕсли;
			
			// Параметры
			НачальныеДанные.Параметры.Вставить(ИмяПараметра, ЗначениеПараметра);
			
			// Положение курсора
			ГраницыВыделенияТекста = ИТК_РедакторКодаКлиентСервер.ПустойГраницыВыделения();
			
			НомерСимвола = СтрНайти(ТекстКода, "<!>");
			ПозицияКурсора = ИТК_РедакторКодаКлиентСервер.КурсорПоНомеруСимвола(ТекстКода, НомерСимвола);
			
			ГраницыВыделенияТекста.НачалоСтроки = ПозицияКурсора.НомерСтроки;
			ГраницыВыделенияТекста.КонецСтроки = ПозицияКурсора.НомерСтроки;
			
			ГраницыВыделенияТекста.НачалоКолонки = ПозицияКурсора.НомерКолонки;
			ГраницыВыделенияТекста.КонецКолонки = ПозицияКурсора.НомерКолонки;
			
			НачальныеДанные.ГраницыВыделенияТекста = ГраницыВыделенияТекста;

			// Текст кода
			НачальныеДанные.Текст = СтрЗаменить(ТекстКода, "<!>", "");
			ИТК_КонсолиКлиентСервер.СброситьОригинальныйТекстДанныхДереваДанных(НачальныеДанные);
			
		КонецЕсли;
		
	КонецЕсли;
	
	ДобавитьСтрокуВДеревоДанных(ПредставлениеНовойСтроки, ТипНовойСтроки, Форма["ДеревоДанных"], ДополнительныеПараметры);
	
КонецПроцедуры

Процедура ОчиститьДанные(Форма) Экспорт
	
	ИТК_КонсолиКлиентСервер.СброситьМодифицированностьДанных(Форма);
	
	Форма["ДеревоДанных"].ПолучитьЭлементы().Очистить();
	Форма["ИдентификаторПоследнейВыделеннойСтроки"] = Неопределено;
	//
	//РезультатКоличество = "";
	//ПоследняяАктивнаяОбласть = Неопределено;
	//
	//ОбновитьРезультатСервер();
	//ИТК_КонсольРазработчикаКлиентСервер.НовыйРезультат(ТекущийРезультат);
	
КонецПроцедуры

Процедура ПоследниеРабочиеДанные_ОбновитьЭлементы(Форма, Тип = Неопределено, ИмяДобавляемого = Неопределено, ИмяУдаляемого = Неопределено) Экспорт
	
	ЭлементРодитель = Форма.Элементы[ИТК_КонсолиКлиентСервер.ГруппаДанныеПрефикс() + "ПоследниеРабочиеДанные"];
	
	//Если ЗначениеЗаполнено(ИмяУдаляемого) Тогда
	//	ИТК_КонсольРазработчика.УдалитьИзПоследнихРабочихДанных(ИмяУдаляемого, Тип);
	//КонецЕсли;
	//
	Если ЗначениеЗаполнено(ИмяДобавляемого) Тогда
		ПоследниеРабочиеДанные_ДобавитьЭлемент(Форма, Тип, ИмяДобавляемого);
	КонецЕсли;
	
	// Уберем видимость всех кнопок
	Для Каждого Кнопка Из ЭлементРодитель.ПодчиненныеЭлементы Цикл
		Кнопка.Видимость = Ложь;
	КонецЦикла;
	
	ПоследниеРабочиеДанные = ПоследниеРабочиеДанные(Форма);
	Форма["ПоследниеРабочиеДанные_Адрес"] = ПоместитьВоВременноеХранилище(ПоследниеРабочиеДанные);
	
	КлючОбновления = ИТК_Консоли.ПоследниеРабочиеДанные_КлючОбновления(Форма["Инструмент"]);
	Форма["ПоследниеРабочиеДанные_КлючОбновления"] = КлючОбновления;
	
	Индекс = 0;
	Для Индекс = 0 По ПоследниеРабочиеДанные.Количество() - 1 Цикл 
		
		ЭлементПоследниеРабочиеДанные = ПоследниеРабочиеДанные[Индекс];
		ТипДанных = ЭлементПоследниеРабочиеДанные.Тип;
		ИмяДанных = ЭлементПоследниеРабочиеДанные.Имя;
		
		ИмяКнопки = "ОткрытьПоследниеРабочиеДанные" + Индекс;
		Команда = Форма.Команды.Найти(ИмяКнопки);
		Если Команда = Неопределено Тогда
			
			// Добавление команды
			Команда = Форма.Команды.Добавить(ИмяКнопки);
			Команда.Действие = "ПодключаемыйОбработчикРаботаСДанными";
			
		КонецЕсли;
		
		Кнопка = Форма.Элементы.Найти(ИмяКнопки);
		Если Кнопка = Неопределено Тогда
			
			// Добавление кнопки
			Кнопка = ИТК_Форма.ДобавитьЭлемент(Форма, ИмяКнопки, "Кнопка", , ЭлементРодитель);
			Кнопка.ИмяКоманды = ИмяКнопки; 
			
		КонецЕсли;
		
		Кнопка.Видимость = Истина;
		
		Если ТипДанных = ИТК_Перечисления.ТипХраненияДанныхФайл() Тогда 
			Кнопка.Заголовок = ИТК_ФайлыКлиентСервер.ПолноеИмяФайлаКратко(ИмяДанных);
		Иначе 
			Кнопка.Заголовок = ИмяДанных;
		КонецЕсли;	
		
		Кнопка.Картинка = ИТК_КонсолиКлиентСерверПовтИсп.КартинкаТипаХраненияДанных(ТипДанных);
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПоследниеРабочиеДанные_ДанныеЭлементаПоИндексу(Форма, Индекс) Экспорт
	
	ПоследниеРабочиеДанные = ПоследниеРабочиеДанные(Форма);
	
	Результат = Новый Структура("Имя,Тип");
	ЗаполнитьЗначенияСвойств(Результат, ПоследниеРабочиеДанные[Индекс]);
	
	Возврат Результат;

КонецФункции

Функция СохранитьДанныеВНастройки(Форма, Имя) Экспорт

	Инструмент = Форма["Инструмент"];

	КлючНастроек = ИТК_КонсолиКлиентСерверПовтИсп.КлючНастроекДанные(Инструмент);
	АдресДанных = ИТК_КонсолиФорматДанных.ДанныеВоВременномХранилище(Форма);
	
	ИТК_ДанныеВНастройках.Сохранить(КлючНастроек, Имя, АдресДанных);
	
КонецФункции

Процедура ЗагрузитьДанныеИзНастроек(Форма, Имя, Пользователь = Неопределено, Объединение = Ложь) Экспорт
	
	Инструмент = Форма["Инструмент"];
	КлючНастроек = ИТК_КонсолиКлиентСерверПовтИсп.КлючНастроекДанные(Инструмент);
	
	Попытка
		Данные = ИТК_ДанныеВНастройках.Загрузить(КлючНастроек, Имя, Пользователь);
	Исключение
		Возврат;
	КонецПопытки;
	
	Если НЕ Объединение Тогда
		ОчиститьДанные(Форма);
	КонецЕсли;
	
	ТипыХраненияДанных =  ИТК_Перечисления.ТипХраненияДанныхНастройка();

	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Тип", ТипыХраненияДанных);
	ДополнительныеПараметры.Вставить("ПолноеИмя", Имя);
	ДополнительныеПараметры.Вставить("Объединение", Объединение);
	
	Модифицированность = НЕ (Объединение ИЛИ Пользователь = Неопределено);
	ДополнительныеПараметры.Вставить("Модифицированность", Модифицированность);
	
	ИТК_КонсолиФорматДанных.Загрузка(Форма, Данные, ДополнительныеПараметры);
	
	ПоследниеРабочиеДанные_ОбновитьЭлементы(Форма, ТипыХраненияДанных, Имя);
	
КонецПроцедуры

Функция Автосохранение(Форма) Экспорт
	
	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("Инструмент", Форма["Инструмент"]);
	ПараметрыПроцедуры.Вставить("Тип", Форма["РабочиеДанные"]);
	ПараметрыПроцедуры.Вставить("АдресДанных", ИТК_КонсолиФорматДанных.ДанныеВоВременномХранилище(Форма));
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(Форма.УникальныйИдентификатор);
	
	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_Консоли.АвтосохранениеВФоне", ПараметрыПроцедуры, ПараметрыВыполнения);
	
КонецФункции

Процедура АвтосохранениеВФоне(Параметры, АдресРезультата = Неопределено) Экспорт
	
	СохраняемыеДанные = Новый Структура;
	СохраняемыеДанные.Вставить("Тип", Параметры.Тип);
	
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(Параметры.АдресДанных);
	ЗаписываемыеДанные = Новый ХранилищеЗначения(ДвоичныеДанные, Новый СжатиеДанных(9));
	СохраняемыеДанные.Вставить("Данные", ЗаписываемыеДанные);
	
	КлючОбъекта = ИТК_НастройкиКлиентСерверПовтИсп.КлючОбъектаСлужебные(Параметры.Инструмент);
	ХранилищеСистемныхНастроек.Сохранить(КлючОбъекта, "Автосохранение", СохраняемыеДанные);
	
КонецПроцедуры

Процедура УдалитьДанныеВНастройках(Инструмент, Имя) Экспорт
	
	КлючНастроек = ИТК_КонсолиКлиентСерверПовтИсп.КлючНастроекДанные(Инструмент);
	ХранилищеСистемныхНастроек.Удалить(КлючНастроек, Имя, Неопределено);
	
КонецПроцедуры

#КонецОбласти

