Функция ОписаниеПоляПеречисляемогоТипа(Контекст = Неопределено)
	
	Результат = Новый Структура;
	Результат.Вставить("Имя");
	Результат.Вставить("ИмяНаАнглийском");
	Результат.Вставить("Тип", Тип("Строка"));
	
	ДоступноНаКлиенте = (Контекст = Неопределено) ИЛИ Контекст = "Клиент";
	Результат.Вставить("ДоступноНаКлиенте", ДоступноНаКлиенте);
	
	ДоступноНаСервере = (Контекст = Неопределено) ИЛИ Контекст = "Сервер";
	Результат.Вставить("ДоступноНаСервере", ДоступноНаСервере);
	
	Результат.Вставить("ИмяФункцииОповещения");
	
	Возврат Результат;
	
КонецФункции

