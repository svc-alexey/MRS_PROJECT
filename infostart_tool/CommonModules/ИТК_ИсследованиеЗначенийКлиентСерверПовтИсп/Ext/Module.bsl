	Типы.Добавить(Тип("Дата"));
	Типы.Добавить(Тип("Число"));
	Типы.Добавить(Тип("Булево"));
	Типы.Добавить(Тип("Строка"));
	
	Результат = Новый Соответствие;
	Для Каждого Тип Из Типы Цикл 
		Результат.Вставить(Тип, Истина);
	КонецЦикла;
	
	Возврат Результат;
	
