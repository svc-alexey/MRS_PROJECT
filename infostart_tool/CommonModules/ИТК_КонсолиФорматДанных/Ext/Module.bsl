#Область ПрограммныйИнтерфейс

Функция ДанныеВоВременномХранилище(Форма) Экспорт
	
	Инструмент = Форма["Инструмент"];
	ДеревоДанных = Форма["ДеревоДанных"];
	
	ТребуемаяВерсия = "1.0";

	// Подготовка данных
	ПодготовленныеДанные = Новый Массив;
	ПодготовкаДанных(Инструмент, ДеревоДанных, ПодготовленныеДанные, ТребуемаяВерсия);
	
	ЗаписьXML = Новый ЗаписьXML;
	
	ПотокЗаписи = Новый ПотокВПамяти;
	ЗаписьXML.ОткрытьПоток(ПотокЗаписи);
	
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("Data"); // <Data>
	
	ЗаписатьПолеВXML(ЗаписьXML, "Version", ТребуемаяВерсия);
	ЗаписатьПолеВXML(ЗаписьXML, "Comment", ИТК_ТуллкитКлиентСервер.ПолноеПредставление());
	ЗаписатьДанныеВXML(ЗаписьXML, ПодготовленныеДанные);
	
	ЗаписьXML.ЗаписатьКонецЭлемента(); // </Data>
	ЗаписьXML.Закрыть();
	
	ДвоичныеДанные = ПотокЗаписи.ЗакрытьИПолучитьДвоичныеДанные();
	Возврат ПоместитьВоВременноеХранилище(ДвоичныеДанные);
	
	
КонецФункции

Процедура Загрузка(Форма, Данные, ДополнительныеПараметры = Неопределено) Экспорт
	
	Инструмент = Форма["Инструмент"];

	ТипХранения = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "Тип");
	ПолноеИмя = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "ПолноеИмя");
	Объединение = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "Объединение", Ложь);
	Модифицированность = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "Модифицированность", Ложь);
	
	Если ДополнительныеПараметры = Неопределено Тогда
		ДополнительныеПараметры = Новый Структура;
	КонецЕсли;
	
	Если ЭтоАдресВременногоХранилища(Данные) Тогда
		ДвоичныеДанные = ПолучитьИзВременногоХранилища(Данные);
	Иначе
		ДвоичныеДанные = Данные;
	КонецЕсли;
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.ОткрытьПоток(ДвоичныеДанные.ОткрытьПотокДляЧтения());
	
	ДанныеВДереве = ИТК_XML.ПрочитатьВДерево(ЧтениеXML);
	
	ЧтениеXML.Закрыть();
	
	КорневойЭлемент = ДанныеВДереве.Строки[0];
	ВерсияДанных = КорневойЭлемент.Значение.Version;
	
	ПоддерживаемаяВерсия = Неопределено;
	Если Инструмент = ИТК_Перечисления.ИнструментКонсольКода() Тогда
		ПоддерживаемаяВерсия = КонсольКода_ПоддерживаемаяВерсия();
	КонецЕсли;
	
	Если ВерсияДанных > ПоддерживаемаяВерсия Тогда
		
		Шаблон = НСтр("ru = 'Неподдерживаемая версия данных %1, требуется обновление.';
						|en = 'Unsupported version of data %1, update required.'");
		ВызватьИсключение СтрШаблон(Шаблон, ВерсияДанных);
		
	КонецЕсли;
	
	Данные = ПодготовкаДанныхЗагрузка(Инструмент, КорневойЭлемент);
	
	Если НЕ Объединение Тогда
		ИТК_Консоли.ОчиститьДанные(Форма);
	КонецЕсли;
	
	ЗагрузкаВФорму(Форма, Форма["ДеревоДанных"], Данные, ВерсияДанных);
	
	ИТК_КонсолиКлиентСервер.УстановитьМодифицированностьДанных(Форма, Модифицированность);
	
	Если ЗначениеЗаполнено(ТипХранения) Тогда
		
		Если НЕ Модифицированность Тогда
			ИТК_КонсолиКлиентСервер.УстановитьРабочиеДанные(Форма, ТипХранения, ПолноеИмя);
		КонецЕсли;
		
		Если НЕ Объединение Тогда
			ИТК_Консоли.ПоследниеРабочиеДанные_ОбновитьЭлементы(Форма, ТипХранения, ПолноеИмя);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПодготовкаДанных(Инструмент, Родитель, Результат, ТребуемаяВерсия)
	
	Для Каждого Строка Из Родитель.ПолучитьЭлементы() Цикл 
		
		ТипСтроки = Строка["Тип"];
		ДанныеСтроки = ИТК_КонсолиКлиентСервер.РаботаСДаннымиДанныеСтроки(Строка);
		
		ОписаниеЭлементаДанных = Новый Структура;
		
		ИдентификаторТипаСтроки = ИТК_КонсолиКлиентСервер.ПреобразованиеПеречисленияЭлементДанных(ТипСтроки);
		ОписаниеЭлементаДанных.Вставить("Тип", ИдентификаторТипаСтроки);
		
		ОписаниеЭлементаДанных.Вставить("Представление");
		ОписаниеЭлементаДанных.Вставить("Выделение");
		ОписаниеЭлементаДанных.Вставить("Развернуто");

		// Подготовка значений полей
		ЗначенияПолей = Новый Структура;
		
		Если Строка.Представление <> ЗначениеПоляПоУмолчанию("Представление") Тогда
			ЗначенияПолей.Вставить("Presentation", Строка["Представление"]);
		КонецЕсли;

		Если Строка.Развернуто <> ЗначениеПоляПоУмолчанию("Развернуто") Тогда
			ЗначенияПолей.Вставить("Open", Ложь);
		КонецЕсли;
		
		Если Строка.Выделение <> ЗначениеПоляПоУмолчанию("Выделение") Тогда
			ЗначенияПолей.Вставить("Selected", Истина);
		КонецЕсли;
		
		// Запись специфичных для каждой консоли
		Если Инструмент = ИТК_Перечисления.ИнструментКонсольКода() Тогда
			ИТК_КонсольКода.ПодготовкаДанныхДополнение(ТипСтроки, ЗначенияПолей, ДанныеСтроки);
		КонецЕсли;
		
		ОписаниеЭлементаДанных.Вставить("Поля", ЗначенияПолей);
		
		// Подчиненые элементы
		ПодчиненныеЭлементы = Новый Массив;
		Если ИТК_КонсолиКлиентСервер.ЭтоТипСтрокиДереваДанныхСодержащийСохраняемыеСтроки(ТипСтроки) Тогда
			ПодготовкаДанных(Инструмент, Строка, ПодчиненныеЭлементы, ТребуемаяВерсия);
		КонецЕсли;
		ОписаниеЭлементаДанных.Вставить("Элементы", ПодчиненныеЭлементы);
		
		Результат.Добавить(ОписаниеЭлементаДанных)
		
	КонецЦикла;
	
КонецФункции

Процедура ЗаписатьЗначениеВXML(ЗаписьXML, Значение, ЗаписыватьТип = Истина)
	
	ТипЗначения = ТипЗнч(Значение);
	Если ТипЗначения = Тип("Тип") Тогда
		ИмяТипа = "Type";
	Иначе
		ИмяТипа = ИТК_XML.ИмяТипа(Значение);
	КонецЕсли;
	
	Если ЗаписыватьТип Тогда
		ЗаписатьПолеВXML(ЗаписьXML, "Type", ИмяТипа);
	КонецЕсли;
	
	Если ТипЗначения = Тип("МоментВремени") Тогда
		ЗаписатьМоментВремениВXML(ЗаписьXML, Значение);
	ИначеЕсли ТипЗначения = Тип("ОписаниеТипов") Тогда
		ЗаписатьОписаниеТиповВXML(ЗаписьXML, Значение);
	ИначеЕсли ТипЗначения = Тип("Тип") Тогда
		ЗаписатьПолеВXML(ЗаписьXML, "Value", ИТК_XML.ИмяТипа(Значение));
	Иначе
		ЗаписатьПолеВXML(ЗаписьXML, "Value", Значение);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаписатьПолеВXML(ЗаписьXML, Имя, Значение, ЗначениеПоУмолчанию = Неопределено)
	
	// Значение по умолчанию и пустые значения не записываем
	Если Значение = ЗначениеПоУмолчанию Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеПоУмолчанию = Неопределено
			И НЕ ЗначениеЗаполнено(Значение) Тогда
		Возврат;
	КонецЕсли;
	
	// Получение строки значения
	XMLСтрока = XMLСтрока(Значение);
	Если НЕ ЗначениеЗаполнено(XMLСтрока) Тогда
		Возврат;
	КонецЕсли;
	
	// Запись поля (многострочный текст записываем как элемент, нельзя записывать как атрибут)
	Если ИТК_Строки.МногострочнаяСтрока(XMLСтрока) Тогда 
		ЗаписатьТекстВXML(ЗаписьXML, Имя, XMLСтрока);
	Иначе
		ЗаписьXML.ЗаписатьАтрибут(Имя, XMLСтрока);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаписатьТекстВXML(ЗаписьXML, Имя, Текст)
	
	Если НЕ ЗначениеЗаполнено(Текст) Тогда
		Возврат;
	КонецЕсли;
	
	ЗаписьXML.ЗаписатьНачалоЭлемента(Имя);
	ЗаписьXML.ЗаписатьТекст(Текст);
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
КонецПроцедуры

Процедура ЗаписатьМоментВремениВXML(ЗаписьXML, Значение)
	
	ЗаписатьПолеВXML(ЗаписьXML, "Date", Значение.Дата);
	
	Ссылка = Значение.Ссылка;
	Если Ссылка = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	ЗаписатьПолеВXML(ЗаписьXML, "TypeRef", ИТК_XML.ИмяТипа(Ссылка));
	ЗаписатьПолеВXML(ЗаписьXML, "ValueRef", Ссылка);
	
КонецПроцедуры

Процедура ЗаписатьОписаниеТиповВXML(ЗаписьXML, ОписаниеТипа)
	
	ЗаписатьПолеВXML(ЗаписьXML, "Types", ИТК_XML.СписокИменТипов(ОписаниеТипа));
	
	Если ОписаниеТипа.СодержитТип(Тип("Число")) Тогда
		
		КвалификаторыЧисла = ОписаниеТипа.КвалификаторыЧисла;
		
		ЗаписатьПолеВXML(ЗаписьXML, "Digits", КвалификаторыЧисла.Разрядность);
		ЗаписатьПолеВXML(ЗаписьXML, "FractionDigits", КвалификаторыЧисла.РазрядностьДробнойЧасти);
		ЗаписатьПолеВXML(ЗаписьXML, "AllowedSign", КвалификаторыЧисла.ДопустимыйЗнак, ДопустимыйЗнак.Любой);
		
	КонецЕсли;
	
	Если ОписаниеТипа.СодержитТип(Тип("Строка")) Тогда
		
		КвалификаторыСтроки = ОписаниеТипа.КвалификаторыСтроки;
		
		ЗаписатьПолеВXML(ЗаписьXML, "Length", КвалификаторыСтроки.Длина);
		ЗаписатьПолеВXML(ЗаписьXML, "AllowedLength", КвалификаторыСтроки.ДопустимаяДлина, ДопустимаяДлина.Переменная);
		
	КонецЕсли;
	
	Если ОписаниеТипа.СодержитТип(Тип("Дата")) Тогда
		
		КвалификаторыДаты = ОписаниеТипа.КвалификаторыДаты;
		ЗаписатьПолеВXML(ЗаписьXML, "DateFractions", КвалификаторыДаты.ЧастиДаты, ЧастиДаты.ДатаВремя);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаписатьДанныеВXML(ЗаписьXML, Данные)
	
	Для Каждого ОписаниеЭлементаДанных Из Данные Цикл
		
		ЗаписьXML.ЗаписатьНачалоЭлемента(ОписаниеЭлементаДанных.Тип);
		
		Для Каждого Поле Из ОписаниеЭлементаДанных.Поля Цикл 
			
			Если Поле.Ключ = "CodeParametrs" Тогда
				
				ЗаписьXML.ЗаписатьНачалоЭлемента("Parametrs");
				Для Каждого Параметр Из Поле.Значение Цикл 
					ЗаписатьЗначениеПараметраКодаВXML(ЗаписьXML, Параметр.Ключ, Параметр.Значение);
				КонецЦикла;
				ЗаписьXML.ЗаписатьКонецЭлемента(); 
				
			Иначе
				ЗаписатьПолеВXML(ЗаписьXML, Поле.Ключ, Поле.Значение);
			КонецЕсли;
			
		КонецЦикла;
		
		ЗаписатьДанныеВXML(ЗаписьXML, ОписаниеЭлементаДанных.Элементы);
		
		ЗаписьXML.ЗаписатьКонецЭлемента(); 
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьЗначениеПараметраКодаВXML(ЗаписьXML, Имя, Значение)
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("Parameter"); // <Parameter>
	ЗаписатьПолеВXML(ЗаписьXML, "Name", Имя);
	
	Если ТипЗнч(Значение) = Тип("СписокЗначений") Тогда
		
		ЗаписатьПолеВXML(ЗаписьXML, "Type", "ValueList");	
		
		Для Каждого ЭлементСписка Из Значение Цикл
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("Item"); // <Item>
			ЗаписатьЗначениеВXML(ЗаписьXML, ЭлементСписка.Значение);
			ЗаписьXML.ЗаписатьКонецЭлемента(); // </Item>
			
		КонецЦикла;
		
	Иначе
		
		ЗаписатьЗначениеВXML(ЗаписьXML, Значение);
		
	КонецЕсли;
	
	ЗаписьXML.ЗаписатьКонецЭлемента(); // </Parameter>
	
КонецПроцедуры

Функция ЗначениеПоляПоУмолчанию(Поле)
	
	Если Поле = "Развернуто" Тогда
		Результат = Истина;
	ИначеЕсли Поле = "Представление" Тогда 
		Результат = "";
	ИначеЕсли Поле = "Выделение" Тогда 
		Результат = Ложь;
	Иначе
		Результат = Неопределено;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция КонсольКода_ПоддерживаемаяВерсия()
	
	Возврат "1.0";
	
КонецФункции

#КонецОбласти

Процедура ЗагрузкаВФорму(Форма, Родитель, Элементы, ТребуемаяВерсия)

	Инструмент = Форма["Инструмент"];

	Для Каждого ОписаниеЭлемента Из Элементы Цикл 
		
		НоваяСтрока = Родитель.ПолучитьЭлементы().Добавить();
		НоваяСтрока.УникальныйИдентификатор = Новый УникальныйИдентификатор;
		
		ТипСтроки = ИТК_КонсолиКлиентСервер.ПреобразованиеПеречисленияЭлементДанных(ОписаниеЭлемента.Тип, Истина);
		НоваяСтрока.Тип = ТипСтроки;
		НоваяСтрока.Картинка = ИТК_КонсолиКлиентСервер.КартинкаСтрокиДереваДанных(ТипСтроки);
		
		ИмяПоля = "Представление";
		НоваяСтрока[ИмяПоля] = ИТК_ОбщийКлиентСервер.Свойство(ОписаниеЭлемента.Поля, "Presentation", ЗначениеПоляПоУмолчанию(ИмяПоля));
		
		ИмяПоля = "Выделение";
		НоваяСтрока[ИмяПоля] = ИТК_ОбщийКлиентСервер.Свойство(ОписаниеЭлемента.Поля, "Selected", ЗначениеПоляПоУмолчанию(ИмяПоля));
		
		ИмяПоля = "Развернуто";
		НоваяСтрока[ИмяПоля] = ИТК_ОбщийКлиентСервер.Свойство(ОписаниеЭлемента.Поля, "Open", ЗначениеПоляПоУмолчанию(ИмяПоля));
		
		ДанныеСтроки = ИТК_КонсолиКлиентСервер.НовыеДанныеСтрокиДереваДанных(ТипСтроки);
		
		// Загрузка специфичных для каждой консоли данных
		Если Инструмент = ИТК_Перечисления.ИнструментКонсольКода() Тогда
			ИТК_КонсольКода.ЗагрузкаДанныхДополнение(ТипСтроки, ДанныеСтроки, ОписаниеЭлемента.Поля);
		КонецЕсли;
		
		НоваяСтрока.Данные = ДанныеСтроки;
		
		Если ОписаниеЭлемента.Свойство("Элементы") Тогда
			ЗагрузкаВФорму(Форма, НоваяСтрока, ОписаниеЭлемента.Элементы, ТребуемаяВерсия);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПодготовкаДанныхЗагрузка(Инструмент, Строка, ЗначенияПолей = Неопределено)
	
	Данные = Новый Массив;
	
	Для Каждого ПодчиненнаяСтрока Из Строка.Строки Цикл 
		
		Если ПодчиненнаяСтрока.Имя = "Parametrs" Тогда
			ЗначенияПолей.Вставить("Parameters", ЧтениеПараметровКода(ПодчиненнаяСтрока));
		Иначе
			
			ДанныеНовогоЭлемента = Новый Структура;
			ДанныеНовогоЭлемента.Вставить("Тип", ПодчиненнаяСтрока.Имя);
			
			ЗначенияПолей = Новый Структура;
			
			ДанныеНовогоЭлемента.Вставить("Поля", ЗначенияПолей);

			Если ТипЗнч(ПодчиненнаяСтрока.Значение) = Тип("Структура") Тогда
				
				Для Каждого Поле Из ПодчиненнаяСтрока.Значение Цикл 
					
					ТипПоля = ТипЗначенияПоля(Инструмент, Поле.Ключ);
					ЗначенияПолей.Вставить(Поле.Ключ, XMLЗначение(ТипПоля, Поле.Значение));
					
				КонецЦикла;
				
			КонецЕсли;
			
			ДанныеНовогоЭлемента.Вставить("Элементы", ПодготовкаДанныхЗагрузка(Инструмент, ПодчиненнаяСтрока, ЗначенияПолей));
			
			Данные.Добавить(ДанныеНовогоЭлемента);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Данные;
	
КонецФункции

Функция ЧтениеПараметровКода(Строка)
	
	ЗначенияПараметров = Новый Соответствие;
	
	Для Каждого ПодчиненнаяСтрока Из Строка.Строки Цикл 
		
		ДанныеПараметра = ПодчиненнаяСтрока.Значение;
		ЗначениеПараметра = ЧтениеЗначенияПараметраКода(ПодчиненнаяСтрока);
		
		ЗначенияПараметров.Вставить(ДанныеПараметра.Name, ЗначениеПараметра);
		
	КонецЦикла;
	
	Возврат ЗначенияПараметров;
	
КонецФункции

Функция ЧтениеЗначенияПараметраКода(Строка)
	
	ДанныеПараметра = Строка.Значение;
	ТипПараметра = ИТК_ОбщийКлиентСервер.Свойство(ДанныеПараметра, "Type");
	
	ЗначениеПараметра = Неопределено;
	Если ТипПараметра = "PointInTime" Тогда // Момент времени
		
		ЗначениеПараметра = ЧтениеМоментаВремени(ДанныеПараметра);
		
	ИначеЕсли ТипПараметра = "ValueList" Тогда // Список значений
		
		ЗначениеПараметра = Новый СписокЗначений;
		Для Каждого СтрокаПараметр Из Строка.Строки Цикл // Блок Items
			ЗначениеПараметра.Добавить(ЧтениеЗначенияПараметраКода(СтрокаПараметр));
		КонецЦикла;
		
	ИначеЕсли ТипПараметра = "Type" Тогда
		ЗначениеПараметра = Тип(ДанныеПараметра.Value);
	Иначе
		ЗначениеПараметра = ЧтениеЗначенияСТипом(ДанныеПараметра);
	КонецЕсли;
	
	Возврат ЗначениеПараметра;
	
КонецФункции

Функция ЧтениеМоментаВремени(Данные)
	
	Если Данные.Свойство("Date") Тогда 
		Дата = XMLЗначение(Тип("Дата"), Данные.Date);
	Иначе
		Дата = ИТК_ОбщийКлиентСервер.ПустаяДата();
	КонецЕсли;
	
	Ссылка = Неопределено;
	Если Данные.Свойство("ValueRef") Тогда
		Ссылка = XMLЗначение(Тип(Данные.TypeRef), Данные.ValueRef);
	КонецЕсли;
	
	Результат = Новый МоментВремени(Дата, Ссылка);
	Возврат Результат;
	
КонецФункции

Функция ЧтениеЗначенияСТипом(ДанныеЗначения, ОписаниеТипов = Неопределено)
	
	Попытка
		
		Если ОписаниеТипов = Неопределено Тогда
			
			Типы = ДанныеЗначения.Type;
			Тип = Тип(ДанныеЗначения.Type);
			
		Иначе
			
			Типы = Новый Массив;
			Если ЗначениеЗаполнено(ОписаниеТипов) Тогда
				Тип = ОписаниеТипов.Типы()[0];
				Типы.Добавить(Тип);
			КонецЕсли;
			
		КонецЕсли;
		
		Значение = Неопределено;
		ОписаниеТипов = Новый ОписаниеТипов(Типы);
	
		Если ДанныеЗначения.Свойство("Value") Тогда
			
			Если Тип = Тип("Тип") Тогда
				Значение = Тип(ДанныеЗначения.Value);
			Иначе
				Значение = XMLЗначение(Тип, ДанныеЗначения.Value);
			КонецЕсли;
			
		КонецЕсли;
		
		Если ДанныеЗначения.Свойство("Type") 
				И ДанныеЗначения.Type = "TypeDescription" Тогда
				
			Результат = Новый ОписаниеТипов(ДанныеЗначения.Types);
			
		Иначе
			Результат = ОписаниеТипов.ПривестиЗначение(Значение);
		КонецЕсли;
		
	Исключение
		
		Результат = Неопределено;
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция ТипЗначенияПоля(Инструмент, Имя)
	
	Соответствие = Новый Соответствие;
	Соответствие.Вставить("Presentation", Тип("Строка"));
	Соответствие.Вставить("Open", Тип("Булево"));
	Соответствие.Вставить("Selected", Тип("Булево"));
	
	Если Инструмент = ИТК_Перечисления.ИнструментКонсольКода() Тогда
		
		Соответствие.Вставить("Text", Тип("Строка"));
		Соответствие.Вставить("Context", Тип("Строка"));
		
	КонецЕсли;
	
	Возврат Соответствие.Получить(Имя);
	
КонецФункции
