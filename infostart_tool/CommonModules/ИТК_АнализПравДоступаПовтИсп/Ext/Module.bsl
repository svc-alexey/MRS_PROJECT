#Область ПрограммныйИнтерфейс

Функция ВсеПраваДоступа(Коллекция = Неопределено) Экспорт
	
	ТаблицаПравДоступа = Новый ТаблицаЗначений;
	ТаблицаПравДоступа.Колонки.Добавить("Имя", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	ТаблицаПравДоступа.Колонки.Добавить("Представление", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	ТаблицаПравДоступа.Колонки.Добавить("Порядок", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10));
	
	ОписаниеПравДоступа = ИТК_МетаданныеКлиентСерверПовтИсп.СоответствиеОписаниеПравДоступа();
	Для Каждого КлючЗначение Из ОписаниеПравДоступа Цикл 
		
		ПравоДоступа = КлючЗначение.Ключ;
		ОписаниеПраваДоступа = КлючЗначение.Значение;
		
		Если Коллекция = Неопределено Тогда
			ДобавитьПравоДоступа = Истина;
		Иначе
			
			КоллекцииПраваДоступа = СтрРазделить(ОписаниеПраваДоступа["Коллекции"], ",");
			ДобавитьПравоДоступа = (КоллекцииПраваДоступа.Найти(Коллекция) <> Неопределено);
			
		КонецЕсли;

		Если НЕ ДобавитьПравоДоступа Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = ТаблицаПравДоступа.Добавить();
		НоваяСтрока.Имя = ПравоДоступа;
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ОписаниеПраваДоступа, "Представление, Порядок");
		
	КонецЦикла;
	
	ТаблицаПравДоступа.Сортировать("Порядок");

	Результат = Новый СписокЗначений;
	
	Для Каждого Строка Из ТаблицаПравДоступа Цикл 
		Результат.Добавить(Строка.Имя, Строка.Представление);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция МинимальныеПраваДоступа(Коллекция = Неопределено) Экспорт
	
	Результат = Новый Массив;
	
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоВнешнийИсточникДанных(Коллекция) Тогда
		
		Результат.Добавить("Использование");
		Результат.Добавить("Администрирование");
		Результат.Добавить("ИзменениеСтандартнойАутентификации");
		Результат.Добавить("ИзменениеСтандартнойАутентификацииСеанса");
		Результат.Добавить("ИзменениеАутентификацииОССеанса");
		
	ИначеЕсли ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоОтчет(Коллекция)
				ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоОбработка(Коллекция) Тогда
		
		Результат.Добавить("Использование");
		
	ИначеЕсли ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоКонстанта(Коллекция)
				ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоСправочник(Коллекция)
				ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоДокумент(Коллекция)
				ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоЖурналДокументов(Коллекция)
				ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПланСчетов(Коллекция)
				ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПланВидовРасчета(Коллекция)
				ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПланВидовХарактеристик(Коллекция)
				ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоРегистр(Коллекция)
				ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоБизнесПроцесс(Коллекция)
				ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоЗадача(Коллекция)
				ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПланОбмена(Коллекция)
				ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПоследовательность(Коллекция)
				Тогда
		
		Результат.Добавить("Чтение");
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ВсеРоли() Экспорт
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Имя");
	Результат.Колонки.Добавить("Представление");
	Результат.Колонки.Добавить("Метаданные");
	
	Для Каждого Роль Из Метаданные.Роли Цикл 

		НоваяСтрока = Результат.Добавить();
		НоваяСтрока.Имя = Роль.Имя;
		НоваяСтрока.Представление = Роль.Представление();
		НоваяСтрока.Метаданные = Роль;
		
	КонецЦикла;
	
	Результат.Сортировать("Представление");
	
	Возврат Результат;
	
КонецФункции

Функция ВсеРолиСписок() Экспорт
	
	Результат = Новый СписокЗначений;
	
	Для Каждого ОписаниеРоли Из ВсеРоли() Цикл 

		Результат.Добавить(ОписаниеРоли.Имя, ОписаниеРоли.Представление);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ВсеПраваДоступаКромеИсторииДанных() Экспорт 
	
	Результат = Новый СписокЗначений;
	
	ВсеПраваДоступа = ВсеПраваДоступа();
	Для Каждого ЭлементПравоДоступа Из ВсеПраваДоступа Цикл 
		
		ПравоДоступа = ЭлементПравоДоступа.Значение;
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ПравоДоступаИсторииДанных(ПравоДоступа) Тогда
			Продолжить;
		КонецЕсли;
		
		Результат.Добавить(ПравоДоступа, ЭлементПравоДоступа.Представление);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

