#Область ПрограммныйИнтерфейс

Функция КоллекцияПоУмолчанию() Экспорт
	Возврат Новый Соответствие;
КонецФункции

Функция ИмяНастройкиХранения(ВидИнструмента) Экспорт
	
	Соответствие = Новый Соответствие;
	Соответствие.Вставить(ИТК_Перечисления.ИнструментРедакторКонстант(), "ИзбранныеКонстанты");
	Соответствие.Вставить(ИТК_Перечисления.ИнструментПользователи(), "ИзбранныеПользователиИБ");
	Соответствие.Вставить(ИТК_Перечисления.ИнструментРедакторПараметровСеанса(), "ИзбранныеПараметрыСеанса");
	Соответствие.Вставить(ИТК_Перечисления.ИнструментРегламентныеИФоновыеЗадания(), "ИзбранныеРегламентныеЗадания");

	Результат = Соответствие.Получить(ВидИнструмента);
	Если Результат = Неопределено Тогда
		ВызватьИсключение "Неизвестный инструмент настроек избранного";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИмяРеквизитаТолькоИзбранные() Экспорт
	Возврат "ТолькоИзбранные";
КонецФункции

Процедура ИнициализацияНастроек(Настройки, ВидИнструмента) Экспорт

	ИмяНастройки = ИТК_ИзбранноеКлиентСервер.ИмяНастройкиХранения(ВидИнструмента);
	НачальноеЗначение = ИТК_ИзбранноеКлиентСервер.КоллекцияПоУмолчанию();

	Настройки.Вставить(ИмяНастройки, НачальноеЗначение);
	
КонецПроцедуры

#КонецОбласти

