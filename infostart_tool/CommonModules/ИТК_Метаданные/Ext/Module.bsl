#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ИмяМетаданных(Объект) 
	
	Если ТипЗнч(Объект) = Тип("ОбъектМетаданных") Тогда
		
		ИмяОбъекта = Объект.ПолноеИмя();
		
	ИначеЕсли ТипЗнч(Объект) = Тип("Тип") Тогда
		
		ОбъектМетаданных = Метаданные.НайтиПоТипу(Объект);
		
		Если ОбъектМетаданных = Неопределено Тогда
			
			ВызватьИсключение СтрШаблон("Неподдерживаемый тип: %1", Объект);
			
		Иначе
			
			ИмяОбъекта = ОбъектМетаданных.ПолноеИмя();
			
		КонецЕсли;
		
	Иначе
		
		ИмяОбъекта = Объект;
		
	КонецЕсли;
	
	ЧастиОбъекта = СтрРазделить(ИмяОбъекта, ".");
	
	Возврат ЧастиОбъекта[0];
	
КонецФункции

Функция ТекстЗапросаПредопределенные(ОбъектМетаданных)
	
	ИерархияГрупп = ЭтоСправочник(ОбъектМетаданных)
			И ОбъектМетаданных.Иерархический 
			И ОбъектМетаданных.ВидИерархии = Метаданные.СвойстваОбъектов.ВидИерархии.ИерархияГруппИЭлементов;

	СхемаЗапроса = Новый СхемаЗапроса;
	
	ЗапросПакета = СхемаЗапроса.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Запрос = ЗапросПакета.Операторы[0];
	
	// Источники
	Запрос.Источники.Добавить(ОбъектМетаданных.ПолноеИмя(), "Таблица");
	
	// Выбираемые поля
	
	ДобавитьКолонкуВСхемуЗапросаОбязательно(ЗапросПакета, Запрос, "Ссылка", );
	ДобавитьКолонкуВСхемуЗапросаОбязательно(ЗапросПакета, Запрос, "Представление");
	ДобавитьКолонкуВСхемуЗапросаОбязательно(ЗапросПакета, Запрос, "Имя", "ИмяПредопределенныхДанных");
	
	ДобавитьКолонкуВСхемуЗапросаОбязательно(ЗапросПакета, Запрос, "Код", , ЗначениеЗаполнено(ОбъектМетаданных.ДлинаКода), "");
	ДобавитьКолонкуВСхемуЗапросаОбязательно(ЗапросПакета, Запрос, "Наименование", , ЗначениеЗаполнено(ОбъектМетаданных.ДлинаНаименования), "");
	ДобавитьКолонкуВСхемуЗапросаОбязательно(ЗапросПакета, Запрос, "ЭтоГруппа", , ИерархияГрупп, Ложь);
	ДобавитьКолонкуВСхемуЗапросаОбязательно(ЗапросПакета, Запрос, "ТипЗначения", , ЭтоПланВидовХарактеристик(ОбъектМетаданных));
	
	// Условия
	ПолеПредопределенный = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Предопределенный");
	Запрос.Отбор.Добавить(ПолеПредопределенный);
	
	Если ИерархияГрупп Тогда
		
		ПолеЭтоГруппа = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("ЭтоГруппа");
		Запрос.Отбор.Добавить("НЕ " + ПолеЭтоГруппа);
		
	КонецЕсли;
	
	// Порядок
	ЗапросПакета.Порядок.Добавить("Имя");
	
	// Итоги
	Иерархический =  ЭтоПланСчетов(ОбъектМетаданных) 
						ИЛИ (ЭтоСправочник(ОбъектМетаданных)
									ИЛИ ЭтоПланВидовХарактеристик(ОбъектМетаданных))
								И ОбъектМетаданных.Иерархический;
	Если Иерархический Тогда
		
		ТочкаИтогов = ЗапросПакета.КонтрольныеТочкиИтогов.Добавить("Ссылка");
		ТочкаИтогов.ТипКонтрольнойТочки = ТипКонтрольнойТочкиСхемыЗапроса.ТолькоИерархия;
		
	КонецЕсли;
	
	Возврат СхемаЗапроса.ПолучитьТекстЗапроса();

КонецФункции

Процедура ДобавитьКолонкуВСхемуЗапросаОбязательно(ЗапросПакета, Запрос, Псевдоним, Поле = Неопределено, КакПоле = Истина, ЗначениеВыражения = Неопределено)
	
	Если КакПоле Тогда
		
		Если Поле = Неопределено Тогда
			Поле = Псевдоним;
		КонецЕсли;
		
		ИмяПоля = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта(Поле);

		Запрос.ВыбираемыеПоля.Добавить(ИмяПоля);
		ЗапросПакета.Колонки.Найти(ИмяПоля).Псевдоним = Псевдоним;
		
	Иначе
		
		Выражение = ИТК_Код.Значение(ЗначениеВыражения);
		Запрос.ВыбираемыеПоля.Добавить(Выражение);
		
		СтандартныйПсевдонимПоля = "Поле1";
		Если ИТК_ОбщийПовтИсп.ВариантВстроенногоЯзыкаАнглийский() Тогда
			СтандартныйПсевдонимПоля = "Field1";
		КонецЕсли;
		ЗапросПакета.Колонки.Найти(СтандартныйПсевдонимПоля).Псевдоним = Псевдоним;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ДобавитьПодсистемыОбъекта(Родитель, Источник, ОбъектМетаданных)
	
	Результат = Ложь;
	Для Каждого Подсистема Из Источник.Подсистемы Цикл
		
		ВходитВПодсистему = Подсистема.Состав.Содержит(ОбъектМетаданных);
		
		НоваяСтрока = Родитель.Строки.Добавить();
		НоваяСтрока.Подсистема = Подсистема;
		НоваяСтрока.ПолноеИмя = Подсистема.ПолноеИмя();
		НоваяСтрока.Расширение = ИТК_Метаданные.ИмяРасширения(Подсистема);
		
		НоваяСтрока.Имя = Подсистема.Имя;
		НоваяСтрока.Представление = Подсистема.Представление();
		НоваяСтрока.Комментарий = Подсистема.Комментарий;
		
		Если ВходитВПодсистему Тогда
			Картинка = ИТК_ОбщийПовтИсп.КартинкаБиблиотеки("ИТК_МетаданныеПодсистема");
		Иначе
			Картинка = ИТК_ОбщийПовтИсп.КартинкаБиблиотеки("ИТК_МетаданныеПодсистемыНедоступные");
		КонецЕсли;	
		НоваяСтрока.Картинка = Картинка;
		
		ВходитВПодчиненныеПодсистемы = ДобавитьПодсистемыОбъекта(НоваяСтрока, Подсистема, ОбъектМетаданных);
		Если ВходитВПодсистему 
				ИЛИ ВходитВПодчиненныеПодсистемы Тогда
			Результат = Истина;
		Иначе
			Родитель.Строки.Удалить(НоваяСтрока);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура ДобавитьПодсистемыБезИерархии(Результат, ОбъектМетаданных)
	
	Для Каждого Подсистема Из ОбъектМетаданных.Подсистемы Цикл 
		
		Результат.Добавить(Подсистема);
		ДобавитьПодсистемыБезИерархии(Результат, Подсистема);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти