Функция ОбъектПоНавигационнойСсылке(НавигационнаяСсылка) Экспорт
	
	Префиксы = Новый Массив;
	Префиксы.Добавить("e1cib/app/");
	Префиксы.Добавить("e1cib/list/");
	Префиксы.Добавить("e1cib/command/");
	
	НачинаетсяСПрефикса = Ложь;
	Для Каждого Префикс Из Префиксы Цикл 
		
		Если СтрНачинаетсяС(НавигационнаяСсылка, Префикс) Тогда
			НачинаетсяСПрефикса = Истина;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если Не НачинаетсяСПрефикса Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПолноеИмя = ИТК_Строки.УдалитьПрефикс(НавигационнаяСсылка, Префикс);
	
	Если Префикс = "e1cib/command/" Тогда
		
		ЧастиИмени = СтрРазделить(ПолноеИмя, ".");
		Если ЧастиИмени.Количество() < 2 Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		РодительскийОбъект = ЧастиИмени[0];
		ПодчиненныйОбъект = ЧастиИмени[1];
		
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоОбщаяКоманда(РодительскийОбъект) Тогда
			Возврат Неопределено;
		КонецЕсли;
			
		ПолноеИмя = РодительскийОбъект + "." + ПодчиненныйОбъект;
		
	КонецЕсли;
	
	Результат = Метаданные.НайтиПоПолномуИмени(ПолноеИмя);
	
	Возврат Результат;
	
КонецФункции

