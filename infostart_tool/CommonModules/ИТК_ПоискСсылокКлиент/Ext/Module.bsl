#Область ПрограммныйИнтерфейс

Процедура НайденныеСсылкиВыбор(Форма, ВыбраннаяСтрока, СтандартнаяОбработка) Экспорт
	
	ВыбраннаяСтрока = Форма["НайденныеСсылки"].НайтиПоИдентификатору(ВыбраннаяСтрока);
	
	Данные = ВыбраннаяСтрока.Данные;
	Если ЗначениеЗаполнено(Данные) Тогда
		
		СтандартнаяОбработка = Ложь;
		ПоказатьЗначение(, Данные);
		
	КонецЕсли;

КонецПроцедуры

Процедура ОбработатьПодключеннуюКоманду(Форма, Имя, ПоискИЗаменаСсылок = Ложь) Экспорт
	
	Поле = ИТК_Строки.РазборПрочитатьДоСимвола(Имя, "_");
	Элемент = Форма.Элементы[Поле];
	
	Если ТипЗнч(Элемент) = Тип("ПолеФормы") Тогда
		
		ИТК_ПодключаемыеКомандыКлиент.ОбработатьКоманду(Форма, Имя);
		
	ИначеЕсли ТипЗнч(Элемент) = Тип("ТаблицаФормы") Тогда
		
		ТекущиеДанные = Элемент.ТекущиеДанные;
		Если ТекущиеДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		Реквизит = Форма[Поле];
		Если СтрНайти(Имя, "СвернутьВсе") Тогда
			
			Если ПоискИЗаменаСсылок Тогда
				Уровень = 2;
			Иначе
				Уровень = 1;
			КонецЕсли;
			ИТК_ФормаКлиент.СвернутьДерево(Элемент, Реквизит, Уровень);
			
		ИначеЕсли СтрНайти(Имя, "РазвернутьВсе") Тогда
			
			ИТК_ФормаКлиент.РазвернутьДерево(Элемент, Реквизит, Истина);
			
		Иначе
			
			ИТК_ПодключаемыеКомандыКлиент.ОбработатьКоманду(Форма, Имя, "Данные");
			
		КонецЕсли;
		
	КонецЕсли;
	
	
КонецПроцедуры

Процедура РазвернутьНайденныеСсылки(Форма, ПоискИЗаменаСсылок = Ложь) Экспорт
	
	Имя = "НайденныеСсылки";
	НайденныеСсылки = Форма[Имя];
	Элемент = Форма.Элементы[Имя];
	
	КоличествоНайденныхСсылок = 0;
	Если ТипЗнч(Форма.КоличествоНайденныхСсылок) = Тип("Число") Тогда
		КоличествоНайденныхСсылок = Форма.КоличествоНайденныхСсылок;
	КонецЕсли;
	
	Если КоличествоНайденныхСсылок <= ИТК_ПоискСсылокНаОбъектКлиентСервер.КоличествоСсылокОтображаемыхРазвернутыми() Тогда
		
		ИТК_ФормаКлиент.РазвернутьДерево(Элемент, НайденныеСсылки, Истина);
		
	Иначе
		
		// Развернуть ветки до уровня метаданных
		Если ПоискИЗаменаСсылок Тогда
			
			Для Каждого СтрокаВсе Из НайденныеСсылки.ПолучитьЭлементы() Цикл 
				
				Элемент.Развернуть(СтрокаВсе.ПолучитьИдентификатор());
				ИТК_ФормаКлиент.РазвернутьДерево(Элемент, СтрокаВсе);
				
			КонецЦикла;
			
		Иначе
			
			ИТК_ФормаКлиент.РазвернутьДерево(Элемент, НайденныеСсылки);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
