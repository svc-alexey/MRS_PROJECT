#Область ПрограммныйИнтерфейс

// Вычисляет суммы выделенных ячеек табличного документа.
//
// Параметры:
//	ПолеСумма - Число - Сумма ячеек.
//	Результат - ТабличныйДокумент - Табличный документ с ячейками.
//	КэшВыделеннойОбласти - Структура - Содержит ранее рассчитанные значения ячеек.
//	НеобходимоВычислятьНаСервере - Булево - Признак того, что необходим вызов сервера.
//
Процедура ВычислитьСуммуВыделенныхЯчеек(ПолеСумма, Результат, КэшВыделеннойОбласти, НеобходимоВычислятьНаСервере) Экспорт
	
	Если НеобходимоОбновитьСумму(Результат, КэшВыделеннойОбласти) Тогда
		
		ПолеСумма = 0;
		КоличествоВыделенныхОбластей = КэшВыделеннойОбласти.Количество();
		
		Если КоличествоВыделенныхОбластей = 0      // Ничего не выделено.
				ИЛИ КэшВыделеннойОбласти.Свойство("T") Тогда // Выделен весь табличный документ (Ctrl+A).
				
			КэшВыделеннойОбласти.Вставить("Сумма", 0);
				
		ИначеЕсли КоличествоВыделенныхОбластей = 1 Тогда
			
			// Если выделено небольшое количество ячеек, то получим сумму на клиенте.
			Для каждого КлючИЗначение Из КэшВыделеннойОбласти Цикл
				СтруктураАдресВыделеннойОбласти = КлючИЗначение.Значение;
			КонецЦикла;
			
			РазмерОбластиПоВертикали   = СтруктураАдресВыделеннойОбласти.Низ   - СтруктураАдресВыделеннойОбласти.Верх;
			РазмерОбластиПоГоризонтали = СтруктураАдресВыделеннойОбласти.Право - СтруктураАдресВыделеннойОбласти.Лево;
			
			// В некоторых отчетах показатели (да и аналитика на которую может встать пользователь)
			// выводятся в "объединенных" ячейках - не желательно в этом случае делать серверный вызов. 
			// Выделенная область из 10 ячеек закрывает все такие случае и скорее всего всегда будет доступна на клиенте.
			// Максимум, может быть сделан один неявный серверный вызов.
			ВычислитьНаКлиенте = (РазмерОбластиПоВертикали + РазмерОбластиПоГоризонтали) < 12;
			Если ВычислитьНаКлиенте Тогда
				
				ОписаниеТипаЧисло = Новый ОписаниеТипов("Число");
				СуммаВЯчейках = 0;
				Для ИндексСтрока = СтруктураАдресВыделеннойОбласти.Верх По СтруктураАдресВыделеннойОбласти.Низ Цикл
					
					Для ИндексКолонка = СтруктураАдресВыделеннойОбласти.Лево По СтруктураАдресВыделеннойОбласти.Право Цикл
						
						Ячейка = Результат.Область(ИндексСтрока, ИндексКолонка, ИндексСтрока, ИндексКолонка);
						
						Если Ячейка.Видимость = Истина Тогда
							
							ЧислоВЯчейке  = ОписаниеТипаЧисло.ПривестиЗначение(Ячейка.Текст);
							СуммаВЯчейках = СуммаВЯчейках + ЧислоВЯчейке;
							
						КонецЕсли;
						
					КонецЦикла;
					
				КонецЦикла;
				
				ПолеСумма = СуммаВЯчейках;
				КэшВыделеннойОбласти.Вставить("Сумма", ПолеСумма);
				
			Иначе
				
				// Если ячеек много, то лучше вычислим сумму ячеек на сервере за один вызов,
				// т.к. неявных серверных вызовов может быть гораздо больше.
				НеобходимоВычислятьНаСервере = Истина;
				
			КонецЕсли;
		Иначе
			
			// Вычислим сумму ячеек на сервере.
			НеобходимоВычислятьНаСервере = Истина;
			
		КонецЕсли;
	Иначе
		
		ПолеСумма = КэшВыделеннойОбласти.Сумма;
		
	КонецЕсли;
	
КонецПроцедуры

// Обработчик в табличном документе "ПриАктивизацииОбласти"
//
// Параметры:
//	Форма - Форма - Форма
//	ТабличныйДокумент - ТабличныйДокумент - Табличный документ
//
Процедура ПриАктивизацииОбластиОбработка(Форма, ТабличныйДокумент) Экспорт
	
	НеобходимоВычислятьНаСервере = Ложь;
	ВычислитьСуммуВыделенныхЯчеек(Форма["ПолеСумма"], ТабличныйДокумент, Форма["КэшВыделеннойОбласти"], НеобходимоВычислятьНаСервере);
	
	Если НеобходимоВычислятьНаСервере Тогда
		
		АдресРезультата = Форма.ТекущийРезультат.Адрес;
		Если ЗначениеЗаполнено(АдресРезультата) Тогда
			
			Форма["ПолеСумма"] = ИТК_ТабличныйДокумент.ВычислитьСуммуВыделенныхЯчеек(АдресРезультата, Форма["КэшВыделеннойОбласти"]);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Обработка команды выделить ячейки табличного документа
//
// Параметры:
//	АдресТабличногоДокумента - Строка - Адрес табличного документа во временном хранилище
//	ТабличныйДокумент - ТабличныйДокумент - Табличный документ
//
Процедура КомандаВыделитьЯчейки(АдресТабличногоДокумента, ТабличныйДокумент) Экспорт
	
	Если НЕ ЗначениеЗаполнено(АдресТабличногоДокумента) Тогда
		Возврат;
	КонецЕсли;
		
	ТекущаяОбласть = ТабличныйДокумент.ТекущаяОбласть;
	ВыделеннаяОбласть = Новый Структура;
	ВыделеннаяОбласть.Вставить("Лево", ТекущаяОбласть.Лево);
	ВыделеннаяОбласть.Вставить("Верх", ТекущаяОбласть.Верх);
	ВыделеннаяОбласть.Вставить("Право", ТекущаяОбласть.Право);
	ВыделеннаяОбласть.Вставить("Низ", ТекущаяОбласть.Низ);
	
	ИТК_ТабличныйДокументКлиентСервер.ВыделитьЯчейки(ТабличныйДокумент, ВыделеннаяОбласть);
	ИТК_ТабличныйДокумент.ВыделитьЯчейки(АдресТабличногоДокумента, ВыделеннаяОбласть);
	
КонецПроцедуры

// Обработка команды выделить ячейки табличного документа
//
// Параметры:
//	ТабличныйДокумент - ТабличныйДокумент - Табличный документ
//	АдресДанныхРасшифровки - Строка - Адрес данных расшифровки во временном хранилище
//	НаВстроенномЯзыке - Булево - На встроенном языке
//
Процедура КомандаКопироватьСсылку(ТабличныйДокумент, АдресДанныхРасшифровки, НаВстроенномЯзыке = Ложь) Экспорт
	
	Результат = Неопределено;
	
	Если НаВстроенномЯзыке Тогда
		
		Расшифровка = Неопределено;
		Если РасшифровкаЭтоСсылка(ТабличныйДокумент, АдресДанныхРасшифровки, Расшифровка) Тогда
			
			Результат = ИТК_Код.Значение(Расшифровка);
			
		КонецЕсли;
		
	Иначе
		
		Результат = ИТК_ТабличныйДокумент.СсылкиВыделеннойОбласти(ТабличныйДокумент, ВыделенныеОбласти(ТабличныйДокумент), АдресДанныхРасшифровки);
		
	КонецЕсли;
	
	Если Результат <> Неопределено Тогда 
		
		ИТК_БуферОбменаКлиент.Копировать(Результат);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура КомандаПоказатьУровеньГруппировокСтрок(ТабличныйДокумент, Команда) Экспорт
	
	Если Команда.Имя = "СвернутьВсе" Тогда
		НомерГруппировки = 1;
	ИначеЕсли Команда.Имя = "РазвернутьВсе" Тогда
		НомерГруппировки = ТабличныйДокумент.КоличествоУровнейГруппировокСтрок();
	Иначе
		НомерГруппировки = ИТК_Строки.ИндексИдентификатора(Команда.Имя);
	КонецЕсли;
	
	ТабличныйДокумент.ПоказатьУровеньГруппировокСтрок(НомерГруппировки - 1);
	
КонецПроцедуры

Процедура ОбработкаКомандыРезультатВТабличномДокументе(Форма, Команда, ТабличныйДокумент, АдресДанных = Неопределено, АдресДанныхРасшифровки = Неопределено) Экспорт
	
	Имя = Команда.Имя;
	Элементы = Форма.Элементы;
	
	Если СтрНайти(Имя, "УровеньГруппировки")
			ИЛИ Имя = "РазвернутьВсе"
			ИЛИ Имя = "СвернутьВсе" Тогда
			
		КомандаПоказатьУровеньГруппировокСтрок(ТабличныйДокумент, Команда);
		
	ИначеЕсли Имя = "НайтиСсылкиНаОбъект" Тогда
		
		НайтиСсылкиНаОбъект(Форма, ТабличныйДокумент, АдресДанныхРасшифровки);

	ИначеЕсли Имя = "РедакторОбъекта" Тогда
		
		РедакторОбъекта(ТабличныйДокумент, АдресДанныхРасшифровки);

	ИначеЕсли Имя = "ВсеИнструменты" Тогда
		
		ИТК_ГлобальноеМенюКлиент.Открыть();

	ИначеЕсли Имя = "ВыделитьЯчейки" Тогда
		
		КомандаВыделитьЯчейки(АдресДанных, ТабличныйДокумент);
	
	ИначеЕсли Имя = "КопироватьUIDСсылки" Тогда
		
		КомандаКопироватьСсылку(ТабличныйДокумент, АдресДанныхРасшифровки);
	
	ИначеЕсли Имя = "КопироватьСсылкуКодНаВстроенномЯзыке" Тогда
		
		КомандаКопироватьСсылку(ТабличныйДокумент, АдресДанныхРасшифровки, Истина);
	
	ИначеЕсли Имя = "ФиксацияШапки" Тогда
		
		ФиксацияШапки = Не Элементы.КнопкаФиксацияШапки.Пометка;
		Элементы.КнопкаФиксацияШапки.Пометка = ФиксацияШапки;
		
		ИТК_ТабличныйДокументКлиентСервер.ЗафиксироватьШапку(ТабличныйДокумент, ФиксацияШапки);
		
	КонецЕсли;
	
КонецПроцедуры

// Обработка команды найти ссылки на объект табличного документа
//
// Параметры:
//	Форма - Форма - Форма
//	ТабличныйДокумент - ТабличныйДокумент - Табличный документ
//	АдресДанныхРасшифровки - Строка - Адрес данных расшифровки во временном хранилище
//
Процедура НайтиСсылкиНаОбъект(Форма, ТабличныйДокумент, АдресДанныхРасшифровки) Экспорт
	
	Расшифровка = Неопределено;
	Если РасшифровкаЭтоСсылка(ТабличныйДокумент, АдресДанныхРасшифровки, Расшифровка) Тогда
		
		ИТК_ТуллкитКлиент.ОткрытьИнструмент(ИТК_Перечисления.ИнструментПоискСсылокНаОбъект(), Расшифровка);

	КонецЕсли;
	
КонецПроцедуры

Процедура РедакторОбъекта(ТабличныйДокумент, АдресДанныхРасшифровки) Экспорт
	
	Расшифровка = Неопределено;
	Если РасшифровкаЭтоСсылка(ТабличныйДокумент, АдресДанныхРасшифровки, Расшифровка, Истина) Тогда
		
		ИТК_ТуллкитКлиент.ОткрытьИнструмент(ИТК_Перечисления.ИнструментРедакторОбъекта(), Расшифровка);

	КонецЕсли;
	
КонецПроцедуры

// Обработчик выбора в табличном документа
//
// Параметры:
//	Форма - Форма - Форма
//	АдресДанныхРасшифровки - Строка - Адрес данных расшифровки во временном хранилище
//	Область - ОбластьТабличногоДокумента - Область табличного документа
//	СтандартнаяОбработка - Булево - Стандартная обработка
//
Процедура ОбработчикВыбор(Форма, АдресДанныхРасшифровки, Область, СтандартнаяОбработка) Экспорт
	
	СтандартнаяОбработка = Ложь;
	
	Расшифровка = РасшифровкаОбласти(Область, АдресДанныхРасшифровки);
	
	Если ТипЗнч(Расшифровка) = Тип("Структура") Тогда
		
		Сообщение = ИТК_ОбщийКлиентСервер.Свойство(Расшифровка, "Сообщение");
		Если ЗначениеЗаполнено(Сообщение) Тогда
			ПоказатьПредупреждение( , Сообщение);
		КонецЕсли;
		
		ЗначениеРасшифровки = ИТК_ОбщийКлиентСервер.Свойство(Расшифровка, "Значение");
		Если ЗначениеЗаполнено(ЗначениеРасшифровки) Тогда
			
			АдресЗначения = ИТК_ОбщийВызовСервера.АдресТаблицыЗначенийПоРасшифровке(АдресДанныхРасшифровки, ЗначениеРасшифровки);
			ИТК_ФормаКлиент.ОткрытьТаблицуЗначений(АдресЗначения, Форма, Ложь);
			
		КонецЕсли;
		
	ИначеЕсли Расшифровка <> Неопределено Тогда
		
		ПоказатьЗначение(, Расшифровка);
		
	КонецЕсли;
	
КонецПроцедуры

// Обработчик ПриАктивизацииОбласти в табличном документа
//
// Параметры:
//	Форма - Форма - Форма
//	Элемент - ЭлементФормы - Элемент формы
//	ТабличныйДокумент - ТабличныйДокумент - Табличный документ
//	ОписаниеАктивнойОбласти - Структура - Описание активной области
//	АдресДанныхРасшифровки - Строка - Адрес данных расшифровки во временном хранилище
//
Процедура ОбработчикПриАктивизацииОбласти(Форма, Элемент, ТабличныйДокумент, ОписаниеАктивнойОбласти = Неопределено, АдресДанныхРасшифровки = Неопределено) Экспорт
	
	ТекущаяОбласть = Элемент.ТекущаяОбласть;
	Если ТипЗнч(ТекущаяОбласть) = Тип("РисунокТабличногоДокумента") Тогда
		Возврат;
	КонецЕсли;
	
	Расшифровка = РасшифровкаОбласти(ТекущаяОбласть, АдресДанныхРасшифровки);
	РасшифровкаЭтоСсылка = ИТК_ОбщийКлиентСервер.ЭтоСсылка(Расшифровка);
	
	// Обновить элементы управления
	КонтекстноеМенюЭлементы = Элемент.КонтекстноеМеню.ПодчиненныеЭлементы;
	
	ГруппаКопированиеСсылки = КонтекстноеМенюЭлементы.Найти("ТабличныйДокументРезультатКонтекстноеМенюГруппаКопированиеСсылки");
	Если ГруппаКопированиеСсылки <> Неопределено Тогда
		
		КнопкаКопироватьСсылкуКодНаВстроенномЯзыке = ГруппаКопированиеСсылки.ПодчиненныеЭлементы.КнопкаКопироватьСсылкуКодНаВстроенномЯзыке;
		КнопкаКопироватьСсылкуКодНаВстроенномЯзыке.Доступность = РасшифровкаЭтоСсылка;
		
	КонецЕсли;
	
	ГруппаИнструменты = КонтекстноеМенюЭлементы.ТабличныйДокументРезультатКонтекстноеМенюГруппаИнструменты;

	КнопкаНайтиСсылкиНаОбъект = ГруппаИнструменты.ПодчиненныеЭлементы.Найти("КнопкаНайтиСсылкиНаОбъект");
	Если КнопкаНайтиСсылкиНаОбъект <> Неопределено Тогда
		КнопкаНайтиСсылкиНаОбъект.Доступность = РасшифровкаЭтоСсылка;
	КонецЕсли;
	
	КнопкаРедакторОбъекта = ГруппаИнструменты.ПодчиненныеЭлементы.Найти("КнопкаРедакторОбъекта");
	Если КнопкаРедакторОбъекта <> Неопределено Тогда
		КнопкаРедакторОбъекта.Доступность = РасшифровкаЭтоСсылка;
	КонецЕсли;
	
	Если СтрНайти(Форма.ИмяФормы, "СравнениеОбъектов") Тогда
		Возврат;
	КонецЕсли;
	
	// Снятие установка выделения
	НомерАктивнойСтроки = ТекущаяОбласть.Низ;
	
	КоличествоКолонок = 0;
	Пока Истина Цикл 
		
		ТипЛинии = ТабличныйДокумент.Область(НомерАктивнойСтроки, КоличествоКолонок + 1).ГраницаСправа.ТипЛинии;
		
		Если ТипЛинии <> ТипЛинииЯчейкиТабличногоДокумента.Сплошная Тогда
			Прервать;
		КонецЕсли;
		
		КоличествоКолонок = КоличествоКолонок + 1;
		
	КонецЦикла;
	
	Если ИТК_НастройкиКлиент.ЗначениеНастройки(Форма, "ВыделятьАктивнуюСтроку") Тогда
		
		ВосстановитьФонОбласти(ТабличныйДокумент, ОписаниеАктивнойОбласти);
		
		Если КоличествоКолонок > 0 Тогда
			
			АктивнаяСтрокаОбласть = ТабличныйДокумент.Область(НомерАктивнойСтроки, 1, НомерАктивнойСтроки, КоличествоКолонок);
			ОписаниеАктивнойОбласти = Новый Структура("НомерСтроки, КоличествоКолонок, ЦветФона", НомерАктивнойСтроки, КоличествоКолонок, АктивнаяСтрокаОбласть.ЦветФона);
			АктивнаяСтрокаОбласть.ЦветФона = WebЦвета.СветлоЗолотистый;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ИТК_НастройкиКлиент.ЗначениеНастройки(Форма, "РасчетСуммыВыделенныхЯчеек") Тогда
		
		Если ТипЗнч(ТабличныйДокумент.ВыделенныеОбласти) = Тип("ВыделенныеОбластиТабличногоДокумента") Тогда
			
			Если ПолучитьСкоростьКлиентскогоСоединения() = СкоростьКлиентскогоСоединения.Низкая Тогда
				ИнтервалОжидания = 1;
			Иначе
				ИнтервалОжидания = 0.2;
			КонецЕсли;
			
			Форма.ПодключитьОбработчикОжидания("РезультатПриАктивизацииОбластиПодключаемый", ИнтервалОжидания, Истина);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Обработка команды ЭкспортВExcel
//
// Параметры:
//	ОписаниеОповещения - ОписаниеОповещения - Описание оповещения
//
Процедура ЭкспортВExcel(ОписаниеОповещения) Экспорт
	
	ДиалогСохраненияФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	ДиалогСохраненияФайла.ПолноеИмяФайла = НСтр("ru = 'Результат.xlsx';
												|en = 'Result.xlsx'");
	ДиалогСохраненияФайла.Фильтр = СтрШаблон("%1 Excel 2007 (*.xlsx)|*.xlsx", НСтр("ru = 'Файлы';
																					|en = 'Files'"));
	ДиалогСохраненияФайла.Заголовок = НСтр("ru = 'Сохранение результата в Excel';
											|en = 'Save result to Excel'");
	ДиалогСохраненияФайла.МножественныйВыбор = Ложь;
	
	ДиалогСохраненияФайла.Показать(ОписаниеОповещения);
	
КонецПроцедуры

Процедура ЭкспортФайлаЗакончен(ТабличныйДокумент, Результат, ПоследняяАктивнаяОбласть) Экспорт
	
	ПодготовитьДляЭкспорта(ТабличныйДокумент, Результат.Формат, ПоследняяАктивнаяОбласть);
	
	ИмяФайла = Результат.ИмяФайла;
	
	ИТК_ФайлыКлиент.СоздатьНесуществующиеКаталоги(ИмяФайла);
	Если Результат.ОткрытьПослеСохранения Тогда
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("ИмяФайла", ИмяФайла);
		ДополнительныеПараметры.Вставить("Формат", Результат.Формат);
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ОткрытьЭкспортированныйФайлПослеСохранения", ЭтотОбъект, ДополнительныеПараметры);
		
	Иначе
			
		ОписаниеОповещения = ИТК_ОбщийКлиент.ПустойОбработчикОповещений();
		
	КонецЕсли;
	
	ТабличныйДокумент.НачатьЗапись(ОписаниеОповещения, ИмяФайла, ТипФайлаТабличногоДокумента[Результат.Формат]);
	
КонецПроцедуры

Процедура ОткрытьЭкспортированныйФайлПослеСохранения(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИмяФайла = ДополнительныеПараметры.ИмяФайла;
	Если ДополнительныеПараметры.Формат = "MXL" Тогда
		
		ДвоичныеДанные = Новый ДвоичныеДанные(ИмяФайла);
		ТабличныйДокументФайла = ИТК_ТабличныйДокумент.ПрочитатьДвоичныхДанных(ДвоичныеДанные);
		ТабличныйДокументФайла.Показать(ИмяФайла, ИмяФайла);
		ТабличныйДокументФайла = Неопределено;
		
	Иначе
		
		ОписаниеОповещения = ИТК_ОбщийКлиент.ОповещениеЗапускПриложения(Новый Структура("Команда", ИмяФайла));
		ВыполнитьОбработкуОповещения(ОписаниеОповещения, Истина);
		
	КонецЕсли;
	
КонецПроцедуры

Функция ЗначенияРасшифровокВыделенныхОбластей(ТабличныйДокумент, ЭлементТабличныйДокумент, ДоступныДанныеРасшифровки = Истина) Экспорт
	
	Результат = Новый Массив;

	ВыделенныеОбласти = ЭлементТабличныйДокумент.ПолучитьВыделенныеОбласти();	
	Для Каждого ВыделеннаяОбласть Из ВыделенныеОбласти Цикл 
		
		Для Строка = ВыделеннаяОбласть.Верх По ВыделеннаяОбласть.Низ Цикл 
			
			Для Столбец = ВыделеннаяОбласть.Лево По ВыделеннаяОбласть.Право Цикл 
				
				ОбластьЯчейки = ТабличныйДокумент.Область(Строка, Столбец);
				Расшифровка = ОбластьЯчейки.Расшифровка;
				Если Расшифровка = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				
				Если НЕ ДоступныДанныеРасшифровки
						И ТипЗнч(Расшифровка) = Тип("ИдентификаторРасшифровкиКомпоновкиДанных") Тогда
					Продолжить;
				КонецЕсли;
				
				Результат.Добавить(Расшифровка);
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция РасшифровкаЭтоСсылка(ТабличныйДокумент, АдресДанныхРасшифровки, Расшифровка = Неопределено, ИсключаяПеречисления = Ложь)

	ТекущаяОбласть = ТабличныйДокумент.ТекущаяОбласть;
	Расшифровка = РасшифровкаОбласти(ТекущаяОбласть, АдресДанныхРасшифровки);
	
	Результат = ИТК_ОбщийКлиентСервер.ЭтоСсылка(Расшифровка, ИсключаяПеречисления);
	
	Возврат Результат;

КонецФункции

Функция РасшифровкаОбласти(Область, АдресДанныхРасшифровки)
	
	// У области может не быть расшифровки (например когда выделен весь документ)
	Попытка
		
		Расшифровка = Область.Расшифровка;
		
	Исключение
		
		Расшифровка = Неопределено;
		
	КонецПопытки;
	
	Если ТипЗнч(Расшифровка) = Тип("ИдентификаторРасшифровкиКомпоновкиДанных") Тогда
		
		Результат = ИТК_СКД.РасшифровкаОбласти(АдресДанныхРасшифровки, Расшифровка);
		
	Иначе
		
		Результат = Расшифровка;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция НеобходимоОбновитьСумму(Результат, КэшВыделеннойОбласти)
	Перем СтруктураАдресВыделеннойОбласти;
	
	ВыделенныеОбласти    = Результат.ВыделенныеОбласти;
	КоличествоВыделенных = ВыделенныеОбласти.Количество();
	
	Если КоличествоВыделенных = 0 Тогда
		КэшВыделеннойОбласти = Новый Структура;
		Возврат Истина;
	КонецЕсли;
	
	ВозвращаемоеЗначение = Ложь;
	Если ТипЗнч(КэшВыделеннойОбласти) <> Тип("Структура") Тогда
		КэшВыделеннойОбласти = Новый Структура;
		ВозвращаемоеЗначение = Истина;
	ИначеЕсли ВыделенныеОбласти.Количество() <> КэшВыделеннойОбласти.Количество() Тогда
		КэшВыделеннойОбласти = Новый Структура;
		ВозвращаемоеЗначение = Истина;
	Иначе
		Для ИндексОбласти = 0 По КоличествоВыделенных - 1 Цикл
			ВыделеннаяОбласть = ВыделенныеОбласти[ИндексОбласти];
			ИмяОбласти = СтрЗаменить(ВыделеннаяОбласть.Имя, ":", "_");
			КэшВыделеннойОбласти.Свойство(ИмяОбласти, СтруктураАдресВыделеннойОбласти);
			
			// Не нашли нужную область в кэше, поэтому заново инициализируем кэш.
			Если ТипЗнч(СтруктураАдресВыделеннойОбласти) <> Тип("Структура") Тогда
				КэшВыделеннойОбласти = Новый Структура;
				ВозвращаемоеЗначение = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Для ИндексОбласти = 0 По КоличествоВыделенных - 1 Цикл
		ВыделеннаяОбласть = ВыделенныеОбласти[ИндексОбласти];
		ИмяОбласти = СтрЗаменить(ВыделеннаяОбласть.Имя, ":", "_");
		
		Если ТипЗнч(ВыделеннаяОбласть) <> Тип("ОбластьЯчеекТабличногоДокумента") Тогда
			СтруктураАдресВыделеннойОбласти = Новый Структура;
			СтруктураАдресВыделеннойОбласти.Вставить("Верх", 0);
			СтруктураАдресВыделеннойОбласти.Вставить("Низ",  0);
			СтруктураАдресВыделеннойОбласти.Вставить("Лево", 0);
			СтруктураАдресВыделеннойОбласти.Вставить("Право", 0);
			КэшВыделеннойОбласти.Вставить(ИмяОбласти, СтруктураАдресВыделеннойОбласти);
			ВозвращаемоеЗначение = Истина;
			Продолжить;
		КонецЕсли;
		
		КэшВыделеннойОбласти.Свойство(ИмяОбласти, СтруктураАдресВыделеннойОбласти);
		Если ТипЗнч(СтруктураАдресВыделеннойОбласти) <> Тип("Структура") Тогда
			СтруктураАдресВыделеннойОбласти = Новый Структура;
			СтруктураАдресВыделеннойОбласти.Вставить("Верх", 0);
			СтруктураАдресВыделеннойОбласти.Вставить("Низ",  0);
			СтруктураАдресВыделеннойОбласти.Вставить("Лево", 0);
			СтруктураАдресВыделеннойОбласти.Вставить("Право", 0);
			КэшВыделеннойОбласти.Вставить(ИмяОбласти, СтруктураАдресВыделеннойОбласти);
			ВозвращаемоеЗначение = Истина;
		КонецЕсли;
		
		Если СтруктураАдресВыделеннойОбласти.Верх <> ВыделеннаяОбласть.Верх
			ИЛИ СтруктураАдресВыделеннойОбласти.Низ <> ВыделеннаяОбласть.Низ
			ИЛИ СтруктураАдресВыделеннойОбласти.Лево <> ВыделеннаяОбласть.Лево
			ИЛИ СтруктураАдресВыделеннойОбласти.Право <> ВыделеннаяОбласть.Право Тогда
				СтруктураАдресВыделеннойОбласти = Новый Структура;
				СтруктураАдресВыделеннойОбласти.Вставить("Верх",  ВыделеннаяОбласть.Верх);
				СтруктураАдресВыделеннойОбласти.Вставить("Низ",   ВыделеннаяОбласть.Низ);
				СтруктураАдресВыделеннойОбласти.Вставить("Лево",  ВыделеннаяОбласть.Лево);
				СтруктураАдресВыделеннойОбласти.Вставить("Право", ВыделеннаяОбласть.Право);
				КэшВыделеннойОбласти.Вставить(ИмяОбласти, СтруктураАдресВыделеннойОбласти);
				ВозвращаемоеЗначение = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

Процедура ПодготовитьДляЭкспорта(ТабличныйДокумент, Формат, ОписаниеАктивнойОбласти)
	
	ВосстановитьФонОбласти(ТабличныйДокумент, ОписаниеАктивнойОбласти);
	
	ВысотаТаблицы = ТабличныйДокумент.ВысотаТаблицы;
	ШиринаТаблицы = ТабличныйДокумент.ШиринаТаблицы;
	
	Если Формат = "MXL" Тогда
		
		// Установим защиту всех ячеек
		Для НомерСтроки = 1 По ВысотаТаблицы Цикл 
			ТабличныйДокумент.Область(НомерСтроки, 1, НомерСтроки, ШиринаТаблицы).Защита = Истина;
		КонецЦикла;
		
	ИначеЕсли СтрНайти(Формат, "XLS") Тогда
		
		// Убираем картинки колонок (проблема в том что при выгрузке в Excel колонки с картинкой в одной колонки их будет две)
		Для НомерСтроки = 1 По ВысотаТаблицы Цикл 
			
			Область = ТабличныйДокумент.Область(НомерСтроки, 1);
			
			Если Область.Картинка <> Неопределено Тогда
				
				Область.Картинка = Неопределено;
				Область.Примечание.Текст = Неопределено;
				
				Для НомерСтолбца = 2 По ШиринаТаблицы Цикл 
					
					Область = ТабличныйДокумент.Область(НомерСтроки, НомерСтолбца);
					
					Область.Картинка = Неопределено;
					Область.Примечание.Текст = Неопределено;
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ВосстановитьФонОбласти(ТабличныйДокумент, ОписаниеАктивнойОбласти)
	
	Если ЗначениеЗаполнено(ОписаниеАктивнойОбласти) Тогда
		
		Если ОписаниеАктивнойОбласти.ЦветФона <> Неопределено Тогда // Иногда непонятным образом попадает значение неопределено (возможно при переключении результатов запрос, СКД) 
			СтрокаОбласть = ТабличныйДокумент.Область(ОписаниеАктивнойОбласти.НомерСтроки, 1, ОписаниеАктивнойОбласти.НомерСтроки, ОписаниеАктивнойОбласти.КоличествоКолонок);
			СтрокаОбласть.ЦветФона = ОписаниеАктивнойОбласти.ЦветФона;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ВыделенныеОбласти(ТабличныйДокумент)
	
	Результат = Новый Массив;
	Для Каждого ВыделеннаяОбласть Из ТабличныйДокумент.ВыделенныеОбласти Цикл 
		
		ОписаниеВыделеннойОбласти = Новый Структура("Лево,Низ,Право,Верх");
		ЗаполнитьЗначенияСвойств(ОписаниеВыделеннойОбласти, ВыделеннаяОбласть);

		Результат.Добавить(ОписаниеВыделеннойОбласти);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти