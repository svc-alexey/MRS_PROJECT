#Область ПрограммныйИнтерфейс

// Возвращает строку имени элемента данных для запроса из отладки (по умолчанию)
//
// Параметры:
//	Тип - Перечисление.ИТК_ЭлементыДанных - Тип элементов
//
// Возвращаемое значение:
//   Строку - Имя данных используемое при загрузке данных из отладки
//
Функция ИмяДанныхПоУмолчанию(Тип) Экспорт
	
	Если Тип = ИТК_Перечисления.ЭлементДанныхЗапрос() Тогда
		
		Результат = НСтр("ru = 'Запрос (из отладки)';
						|en = 'Query (from debug)'");
		
	ИначеЕсли Тип = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных() Тогда
		
		Результат = НСтр("ru = 'Схема компоновки данных (из отладки)';
						|en = 'Data composition schema (from debug)'");
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИмяЭлементаДанных(Тип, Имя) Экспорт
	
	Если ЗначениеЗаполнено(Имя) Тогда
		Результат = Имя;
	Иначе
		
		Если Тип = ИТК_Перечисления.ЭлементДанныхЗапрос() Тогда
			
			Результат = НСтр("ru = 'Запрос'; en = 'Query'");
			
		ИначеЕсли Тип = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных() Тогда
			
			Результат = НСтр("ru = 'Схема'; en = 'Scheme'");
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает строку подсказку к описанию вызова
//
// Параметры:
//	Тип - Перечисление.ИТК_ЭлементыДанных - Тип элементов
//	ТипХранения - Перечисление.ИТК_ТипыХраненияДанных - Тип хранения данных
//
// Возвращаемое значение:
//   Строка - Подсказка к описанию вызова
//
Функция ПодсказкаОписаниеВызова(Тип, ТипХранения) Экспорт
	
	Строки = Новый Массив;
	Строки.Добавить(ИмяФункции(ТипХранения));
	Строки.Добавить("");
	Строки.Добавить(НСтр("ru = 'Параметры:';
						|en = 'Parametrs:'"));
	
	Параметры = Новый Массив;
	Параметры.Добавить(НСтр("ru = 'Объект  - Запрос, СхемаКомпоновкиДанных, ПостроительЗапроса, ПостроительОтчета, ДинамическийСписок, МакетКомпоновкиДанных - Объект';
							|en = 'Object - Query, DataCompositionSchema, QueryBuilder, ReportBuilder, DynamicList, DataCompositionTemplate - Object'"));
	
	
	Если ТипХранения = ИТК_Перечисления.ТипХраненияДанныхФайл() Тогда
		Параметры.Добавить(НСтр("ru = 'Путь  - Строка - Путь';
								|en = 'Path - String - Path'"));
	КонецЕсли;
	
	Параметры.Добавить(НСтр("ru = 'Имя - Строка - Имя (необязательный)';
							|en = 'Name - String - Name (optional)'"));
	
	Если Тип = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных() Тогда
		
		Параметры.Добавить(НСтр("ru = 'Настройки - НастройкиКомпоновкиДанных - Настройки компоновки данных (необязательный)';
								|en = 'Settings - DataCompositionSettings - Data composition settings (optional)'"));
		Параметры.Добавить(НСтр("ru = 'ВнешниеНаборыДанных - Структура - Внешние наборы данных (необязательный)';
								|en = 'ExternalDatasets - Structure - External datasets (optional)'"));
		
		Если ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.17") Тогда
			
			Параметры.Добавить(НСтр("ru = 'МенеджерВременныхТаблиц - МенеджерВременныхТаблиц - Менеджер временных таблиц (необязательный), доступен с платформы 8.3.17';
									|en = 'TempTablesManager - TempTablesManager - Temporary table manager (optional), available since platform 8.3.17'"));
			
		КонецЕсли;
		
	КонецЕсли;
	
	Для Индекс = 0 По Параметры.ВГраница() Цикл 
		Параметры[Индекс] = "  " + Параметры[Индекс];
	КонецЦикла;
	Строки.Добавить(СтрСоединить(Параметры, Символы.ПС));
	
	Строки.Добавить("");
	Строки.Добавить(НСтр("ru = 'Возвращаемое значение:';
						|en = 'Return value:'"));
	
	ПояснениеЗначенияВозврата = НСтр("ru = 'Строка - Информация о результате';
									|en = 'String - Result information'");
	Строки.Добавить(ИТК_Строки.ДобавитьТабВМногострочныйТекст(ПояснениеЗначенияВозврата));
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Возвращает строку имя функции
//
// Параметры:
//	Тип - Перечисление.ИТК_ТипыХраненияДанных - Тип хранения данных
//
// Возвращаемое значение:
//   Строка - Имя функции
//
Функция ИмяФункции(Тип) Экспорт
	
	Результат = "Отл";
	
	Если Тип = ИТК_Перечисления.ТипХраненияДанныхФайл() Тогда
		
		Результат = Результат + "ВФайл";
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

