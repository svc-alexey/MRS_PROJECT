#Область ПрограммныйИнтерфейс

// Получает подсказку к описанию типа
//
// Параметры:
//   Имя - Строка - Имя
//   ОписаниеТипов - ОписаниеТипов - Описание типов
//   УчитыватьNull - Булево - Учитывать Null
//
// Возвращаемое значение:
//   Строка	- Подсказка описания типа
//
Функция ПодсказкаОписания(Имя, ОписаниеТипов, УчитыватьNull = Ложь) Экспорт
	
	КоличествоТипов = ИТК_ТипыКлиентСервер.Количество(ОписаниеТипов, Не УчитыватьNull);
	ПредставлениеОписания = ПредставлениеОписания(ОписаниеТипов, Символы.ПС, УчитыватьNull);
	
	Если КоличествоТипов = 1 Тогда
		
		Шаблон = НСтр("ru = '%1
					|Тип: %2';
					|en = '%1
					|Type: %2'");
		Результат = СтрШаблон(Шаблон, Имя, ПредставлениеОписания);
		
	Иначе
		
		Шаблон = НСтр("ru = '%1
					|Типы (%2):
					|%3';
					|en = '%1
					|Types (%2):
					|%3'");
		Результат = СтрШаблон(Шаблон, Имя, КоличествоТипов, ПредставлениеОписания);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Получает подсказку к описанию типа
//
// Параметры:
//   ОписаниеТипов - ОписаниеТипов - Описание типов
//   Разделитель - Строка - Разделитель
//   УчитыватьNull - Булево - Учитывать тип Null
//   МаксимальноеКоличество - Число - Максимальное количество типов
//
// Возвращаемое значение:
//   Строка	- Подсказка описания типа
//
Функция ПредставлениеОписания(ОписаниеТипов, Разделитель = ", ", УчитыватьNull = Ложь, МаксимальноеКоличество = 10) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ОписаниеТипов) Тогда
		Возврат НСтр("ru = 'Неопределено'; en = 'Undefined'");
	КонецЕсли;
	
	Результат = Новый Массив;
	Для Каждого Тип Из ОписаниеТипов.Типы() Цикл
		
		Если Результат.Количество() = МаксимальноеКоличество Тогда
			Прервать;
		КонецЕсли;
		
		Если Тип = Тип("Null") И Не УчитыватьNull Тогда
			Продолжить;
		КонецЕсли;
		
		Представление = ПредставлениеТипа(Тип, ОписаниеТипов);
		Результат.Добавить(Представление);
		
	КонецЦикла;
	
	Возврат СтрСоединить(Результат, Разделитель);
	
КонецФункции

Функция ПредставлениеТипа(Тип, ОписаниеТипов = Неопределено, Язык = Неопределено) Экспорт
	
	Если Язык = Неопределено Тогда
		Язык = ИТК_ОбщийКлиентСервер.КодТекущегоЯзыка();
	КонецЕсли;
	
	Если Тип = Тип("Строка") Тогда
		
		Результат = НСтр("ru = 'Строка'; |en = 'String'", Язык);
		Если ОписаниеТипов = Неопределено Тогда
			Возврат Результат;
		КонецЕсли;

		КвалификаторыСтроки = ОписаниеТипов.КвалификаторыСтроки;
		Если КвалификаторыСтроки.Длина = 0 Тогда // Строка неограниченной длины
			
			Результат = Результат + НСтр("ru = ' (неограниченная)';
										|en = ' (unlimited)'", Язык);
			
		Иначе
			
			Если КвалификаторыСтроки.ДопустимаяДлина = ДопустимаяДлина.Фиксированная Тогда
				ТипСтроки = НСтр("ru = 'фиксированная';
							|en = 'fixed'", Язык);
			Иначе
				ТипСтроки = НСтр("ru = 'переменная';
							|en = 'variable'", Язык);
			КонецЕсли;
			Результат = Результат + СтрШаблон(" (%1, %2)", КвалификаторыСтроки.Длина, ТипСтроки);
			
		КонецЕсли;
		
	ИначеЕсли Тип = Тип("Дата") Тогда
		
		Результат = НСтр("ru = 'Дата'; |en = 'Date'", Язык);
		
		Если ОписаниеТипов = Неопределено Тогда
			Возврат Результат;
		КонецЕсли;
		
		Результат = Результат + СтрШаблон(" (%1)", ОписаниеТипов.КвалификаторыДаты.ЧастиДаты);
		
	ИначеЕсли Тип = Тип("Число") Тогда
		
		Результат = НСтр("ru = 'Число';
							|en = 'Number'", Язык);
		Если ОписаниеТипов = Неопределено Тогда
			Возврат Результат;
		КонецЕсли;
		
		КвалификаторыЧисла = ОписаниеТипов.КвалификаторыЧисла;
		Если КвалификаторыЧисла = ДопустимыйЗнак.Неотрицательный Тогда
			ПредставлениеФормата = СтрШаблон(НСтр("ru = '(%1.%2, неотрицательное)'; en = '(%1.%2, non-negative)'"), КвалификаторыЧисла.Разрядность, КвалификаторыЧисла.РазрядностьДробнойЧасти);
		Иначе
			ПредставлениеФормата = СтрШаблон(НСтр("ru = '(%1.%2)'; en = '(%1.%2)'"), КвалификаторыЧисла.Разрядность, КвалификаторыЧисла.РазрядностьДробнойЧасти);
		КонецЕсли;
		Результат = Результат + Символы.НПП + ПредставлениеФормата;
		
	ИначеЕсли Тип = Тип("РезультатЗапроса")
				ИЛИ Тип = Тип("ТаблицаЗначений") Тогда
		
		Результат = НСтр("ru = 'ТаблицаЗначений';
									|en = 'ValueTable'");
		
	ИначеЕсли Тип = Тип("ВидДвиженияНакопления")
				ИЛИ Тип = Тип("Тип")
				ИЛИ Тип = Тип("ВидСчета")
				ИЛИ Тип = Тип("ХранилищеЗначения") 
				ИЛИ Тип = Тип("УникальныйИдентификатор")
				ИЛИ Тип = Тип("Булево")
				ИЛИ Тип = Тип("МоментВремени")
				ИЛИ Тип = Тип("ФиксированныйМассив")
				ИЛИ Тип = Тип("ФиксированнаяСтруктура")
				ИЛИ Тип = Тип("ФиксированноеСоответствие")
				Тогда
		
		Результат = Строка(Тип);
		
	ИначеЕсли Тип = Тип("ОписаниеТипов") Тогда
		
		Результат = НСтр("ru = 'ОписаниеТипов';
									|en = 'TypeDescription'", Язык);
		
	ИначеЕсли Тип = Неопределено
			ИЛИ Тип = Тип("Неопределено") Тогда
		
		Результат = НСтр("ru = 'Неопределено';
									|en = 'Undefined'", Язык);
		
	ИначеЕсли ЭтоТипОбъект(Тип) Тогда
		
		Результат = XMLТип(Тип).ИмяТипа;

	Иначе
		
		ОбъектМетаданных = Метаданные.НайтиПоТипу(Тип);
		Если ОбъектМетаданных = Неопределено Тогда
			Результат = Строка(Тип);
		Иначе
			Результат = ОбъектМетаданных.ПолноеИмя();
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции	

Функция ПользовательскоеПредставлениеТипа(Тип, ОписаниеТипов = Неопределено, Язык = Неопределено) Экспорт
	
	ОбъектМетаданных = Метаданные.НайтиПоТипу(Тип);
	Если ОбъектМетаданных = Неопределено Тогда
			
		Результат = ПредставлениеТипа(Тип, ОписаниеТипов, Язык);
			
	Иначе
			
		Результат = ОбъектМетаданных.Представление();
			
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции	

// Проверяет содержит ли описание типов тип ТаблицаЗначений
//
// Параметры:
//   ОписаниеТипов - ОписаниеТипов - Описание типов
//
// Возвращаемое значение:
//   Булево - Истина, если тип содержит тип ТаблицаЗначений
//
Функция СодержитТипТаблицаЗначений(ОписаниеТипов) Экспорт 
	
	Возврат ОписаниеТипов.СодержитТип(Тип("ТаблицаЗначений"))
	
КонецФункции

// Получает картинку по описание типов
//
// Параметры:
//  ОписаниеТипов  - ОписаниеТипов - Описание типов
//
// Возвращаемое значение:
//   Картинка - Картинка описания типов
//
Функция КартинкаОписания(ОписаниеТипов) Экспорт
	
	Если ИТК_КонсольРазработчикаДанныеКлиентСервер.ТипПараметраТаблицаЗначений(ОписаниеТипов) Тогда
		Возврат БиблиотекаКартинок.ВнешнийИсточникДанныхТаблица;
	КонецЕсли;
	
	Если ТипЗнч(ОписаниеТипов) <> Тип("ОписаниеТипов") Тогда
		Возврат (Новый Картинка);
	КонецЕсли;
	
	КоличествоТипов = ИТК_ТипыКлиентСервер.Количество(ОписаниеТипов);
	
	Если КоличествоТипов = 0 Тогда 
		
		Результат = Новый Картинка;
		
	ИначеЕсли КоличествоТипов > 1 Тогда 
		
		Результат = ИТК_ОбщийКлиентСерверПовтИсп.БиблиотекаКартинок("ИТК_ТипСоставной");
		
	Иначе
		
		Результат = Картинка(Первый(ОписаниеТипов), ОписаниеТипов);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция КартинкаЗначения(Значение, ОписаниеТипов) Экспорт
	
	Если Значение = Неопределено Тогда
		Результат = ИТК_Типы.КартинкаОписания(ОписаниеТипов);
	Иначе
		Результат = ИТК_Типы.Картинка(ТипЗнч(Значение), ОписаниеТипов);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Получает картинку типа
//
// Параметры:
//  Тип  - Тип - Тип
//  ОписаниеТипов - ОписаниеТипов - Описание типов
//
// Возвращаемое значение:
//   Картинка - Картинка типа
//
Функция Картинка(Тип, ОписаниеТипов = Неопределено) Экспорт
	
	Если Тип = Неопределено Тогда
		Результат = Новый Картинка;
	ИначеЕсли Тип = Тип("Дата") Тогда 
		
		Если ОписаниеТипов = Неопределено Тогда
			
			Результат = БиблиотекаКартинок.ИТК_ТипДата;
			
		Иначе
			
			Если ОписаниеТипов.КвалификаторыДаты.ЧастиДаты = ЧастиДаты.Время Тогда
				
				Результат = БиблиотекаКартинок.ИТК_ТипВремя;
				
			ИначеЕсли ОписаниеТипов.КвалификаторыДаты.ЧастиДаты = ЧастиДаты.Дата Тогда
				
				Результат = БиблиотекаКартинок.ИТК_ТипДата;
				
			Иначе
				
				Результат = БиблиотекаКартинок.ИТК_ТипПолнаяДата;
				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		Результат = ИТК_ТипыПовтИсп.КартинкаПростого(Строка(Тип));
		
		Если Результат = Неопределено Тогда
			
			ОбъектМетаданных = Метаданные.НайтиПоТипу(Тип);
			
			Если ОбъектМетаданных <> Неопределено Тогда
				
				ИмяОбъектаКоллекции = ИТК_Метаданные.ИмяОбъектаКоллекции(ОбъектМетаданных);
				Результат = ИТК_ОбщийПовтИсп.КартинкаБиблиотеки(ИмяОбъектаКоллекции);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ТипыКоллекцииРасширений(Коллекция) Экспорт
	
	Результат = Новый Массив;
	Для Каждого Объект Из Коллекция Цикл 
		
		Если Объект.РасширениеКонфигурации() = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Результат.Добавить(Объект.ПолноеИмя());
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция РедактируетсяВТаблицеЗначений(ОписаниеТипов) Экспорт
	
	Возврат НЕ (ОписаниеТипов.СодержитТип(Тип("ДвоичныеДанные"))
					ИЛИ ОписаниеТипов.СодержитТип(Тип("ФиксированныйМассив"))
					ИЛИ ОписаниеТипов.СодержитТип(Тип("ФиксированнаяСтруктура"))
					ИЛИ ОписаниеТипов.СодержитТип(Тип("ФиксированноеСоответствие")));
	
КонецФункции

Функция ВсеИспользуемыеТипыКолонкиТЗ(ТаблицаЗначений, ИмяКолонки) Экспорт
	
	ИспользуемыеТипы = Новый Соответствие;
	Для Каждого Строка Из ТаблицаЗначений Цикл 
		
		Тип = Строка[ИмяКолонки];
		
		Если ИспользуемыеТипы.Получить(Тип) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ИспользуемыеТипы.Вставить(Тип, Истина);
		
	КонецЦикла;
	
	Типы = Новый Массив;
	Для Каждого ИспользуемыйТип Из ИспользуемыеТипы Цикл 
		Типы.Добавить(ИспользуемыйТип.Ключ);
	КонецЦикла;
	
	Возврат Новый ОписаниеТипов(Типы);
	
КонецФункции

Функция ЭтоТипОбъект(Тип) Экспорт
	
	ТипДанныхXML = XMLТип(Тип);
	Если ТипДанныхXML = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПрефиксыТипыОбъект = Новый Массив;
	ПрефиксыТипыОбъект.Добавить("CatalogObject");
	ПрефиксыТипыОбъект.Добавить("DocumentObject");
	ПрефиксыТипыОбъект.Добавить("ChartOfCharacteristicTypesObject");
	ПрефиксыТипыОбъект.Добавить("ChartOfAccountsObject");
	ПрефиксыТипыОбъект.Добавить("ChartOfCalculationTypesObject");
	ПрефиксыТипыОбъект.Добавить("BusinessProcessObject");
	ПрефиксыТипыОбъект.Добавить("TaskObject");
	ПрефиксыТипыОбъект.Добавить("ExchangePlanObject");
	
	Для Каждого ПрефиксаТипаОбъект Из ПрефиксыТипыОбъект Цикл 
		
		Если СтрНачинаетсяС(ТипДанныхXML.ИмяТипа, ПрефиксаТипаОбъект) Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция Первый(ОписаниеТипов, ИсключатьNull = Истина)
	
	Результат = Неопределено;
	
	Для Каждого Тип Из ОписаниеТипов.Типы() Цикл
		
		Если ИсключатьNull И Тип = Тип("Null") Тогда
			
			Продолжить;
			
		Иначе
			
			Результат = Тип;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
