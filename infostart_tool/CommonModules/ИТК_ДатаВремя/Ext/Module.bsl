#Область ПрограммныйИнтерфейс

Функция КраткоеПредставлениеМесяца(НомерМесяца) Экспорт
	
	Возврат Формат(ДатаПоНомеруМесяца(НомерМесяца), "ДФ='MMM'");
	
КонецФункции

Функция ПолноеПредставлениеМесяца(НомерМесяца) Экспорт
	
	Возврат Формат(ДатаПоНомеруМесяца(НомерМесяца), "ДФ='MMMM'");
	
КонецФункции

Функция КраткоеПредставлениеДняНедели(НомерДняНедели) Экспорт
	
	Возврат Формат(ДатаПоНомеруДняНедели(НомерДняНедели), "ДФ='ddd'");
	
КонецФункции

Функция ПолноеПредставлениеДняНедели(НомерДняНедели) Экспорт
	
	Возврат Формат(ДатаПоНомеруДняНедели(НомерДняНедели), "ДФ='dddd'");
	
КонецФункции

Функция ПредставлениеПериодаВремени(Период) Экспорт
	
	ЧастиПредставления = Новый Массив;
	
	КоличествоЧасов = Цел(Период / 3600);
	Если КоличествоЧасов > 0 Тогда
		
		Подстрока = СтрШаблон(НСтр("ru = '%1 ч.'; en = '%1 h.'"), КоличествоЧасов);
		ЧастиПредставления.Добавить(Подстрока);
		
	КонецЕсли;
	
	КоличествоМинут = Цел(Период / 60) % 60;
	Если КоличествоМинут > 0 Тогда
		
		Подстрока = СтрШаблон(НСтр("ru = '%1 мин.'; en = '%1 min.'"), КоличествоМинут);
		ЧастиПредставления.Добавить(Подстрока);
		
	КонецЕсли;
	
	КоличествоСекунд = Период % 60;
	Если КоличествоСекунд > 0 ИЛИ Период = 0 Тогда
		
		Подстрока = СтрШаблон(НСтр("ru = '%1 сек.'; en = '%1 sec.'"), КоличествоСекунд);
		ЧастиПредставления.Добавить(Подстрока);
		
	КонецЕсли;
	
	Представление = СтрСоединить(ЧастиПредставления, Символы.НПП);
	Возврат Представление;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ДатаПоНомеруМесяца(НомерМесяца)
	
	Возврат Дата(1900, НомерМесяца, 1);
	
КонецФункции

Функция ДатаПоНомеруДняНедели(НомерДняНедели)
	
	Возврат '1900-01-01' + (НомерДняНедели - 1) * 86400;
	
КонецФункции

#КонецОбласти