#Область ПрограммныйИнтерфейс

// Инициализирует форму для работы с результатов в виде табличного документа
//
// Параметры:
//	Форма - Форма - Форма
//
Процедура ИнициализироватьФорму(Форма, РезультатВОтдельномОкне = Ложь) Экспорт
	
	Элементы = Форма.Элементы;
	
	ДобавляемыеРеквизиты = Новый Массив;
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, "КэшВыделеннойОбласти");
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, "ПолеСумма", "Строка(50)");
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	СоздаватьКнопкуНеВсеСтрокиВыведены = Не РезультатВОтдельномОкне;
	
	Если РезультатВОтдельномОкне Тогда
		
		ГруппаПодключаемые = Элементы.ГруппаПодключаемые;
		ЭлементГруппаДополнение = Элементы.ГруппаДополнение;
		
	Иначе
		
		ГруппаПодключаемые = Элементы.ТабличныйДокументРезультатКоманднаяПанельПодключаемые;
		ЭлементГруппаДополнение = Элементы.ТабличныйДокументРезультатКоманднаяПанельДополнение;
		
	КонецЕсли;
	
	Поля = Новый Структура;
	Поля.Вставить("ОтображатьЗаголовок", Ложь);
	Поля.Вставить("Заголовок", НСтр("ru = 'Не все строки выведены (группа)';
									|en = 'Not all lines are output (group)'"));
	Поля.Вставить("ЦветФона", ЦветаСтиля.ЦветФонаПодсказки);
	ГруппаНеВсеСтрокиВыведены = ИТК_Форма.ДобавитьЭлемент(Форма, "ГруппаНеВсеСтрокиВыведены", "Группа", Поля, ЭлементГруппаДополнение);
	
	Поля = Новый Структура;
	Поля.Вставить("ОтображатьЗаголовок", Ложь);
	Поля.Вставить("Заголовок", НСтр("ru = 'Сумма (группа)';
									|en = 'Amount (group)'"));
	Поля.Вставить("Группировка", ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная);
	ГруппаСумма = ИТК_Форма.ДобавитьЭлемент(Форма, "ГруппаСумма", "Группа", Поля, ЭлементГруппаДополнение);
	
	КонтекстноеМенюТабличныйДокументРезультат = Элементы.ТабличныйДокументРезультат.КонтекстноеМеню;

	// Группировки развернуть/свернуть все
	Поля = Новый Структура;
	Поля.Вставить("ОтображатьЗаголовок", Ложь);
	Поля.Вставить("Отображение", ОтображениеГруппыКнопок.Компактное);
	Поля.Вставить("Заголовок", НСтр("ru = 'Свернуть/развернуть группировки';
									|en = 'Collapse/expand groupings'"));
	ГруппаСвернутьРазвернутьГруппировки = ИТК_Форма.ДобавитьЭлемент(Форма, "ГруппаСвернутьРазвернутьГруппировки", "Группа", Поля, ГруппаПодключаемые);
	
	// Развернуть все
	ИмяКоманды = "РазвернутьВсе";
	
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("Картинка", БиблиотекаКартинок.РазвернутьВсе);
	ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяОсновногоОбработчика(),
								НСтр("ru = 'Развернуть все'; en = 'Expand all'"), ПараметрыКоманды);

	Поля = Новый Структура("ИмяКоманды", ИмяКоманды);
	ИТК_Форма.ДобавитьЭлемент(Форма, "ТабличныйДокументРезультатРазвернутьВсе", "Кнопка", Поля, ГруппаСвернутьРазвернутьГруппировки);
	
	// Свернуть все
	ИмяКоманды = "СвернутьВсе";
	
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("Картинка", БиблиотекаКартинок.СвернутьВсе);
	ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяОсновногоОбработчика(),
								НСтр("ru = 'Свернуть все'; en = 'Collapse all'"), ПараметрыКоманды);

	Поля = Новый Структура("ИмяКоманды", ИмяКоманды);
	ИТК_Форма.ДобавитьЭлемент(Форма, "ТабличныйДокументРезультатСвернутьВсе", "Кнопка", Поля, ГруппаСвернутьРазвернутьГруппировки);
	
	// Экспорт в...
	ИмяКоманды = "ЭкспортВ";
	
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("Подсказка", НСтр("ru = 'Экспорт результата в xls и другие форматы...';
												|en = 'Export the result to xls and other formats...'"));
	ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, "ПодключаемаяКоманда" + ИмяКоманды,
								НСтр("ru = 'Экспорт в...';
									|en = 'Export to...'"), ПараметрыКоманды);

	Поля = Новый Структура("ИмяКоманды", ИмяКоманды);
	ИТК_Форма.ДобавитьЭлемент(Форма, "ТабличныйДокументРезультатЭкспортВ", "Кнопка", Поля, ГруппаПодключаемые);

	ИмяКоманды = "ФиксацияШапки";
	
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("Подсказка", НСтр("ru = 'Включить/Выключить фиксацию шапки';
												|en = 'Enable/Disable fixation of a cap'"));
	ПараметрыКоманды.Вставить("Картинка", БиблиотекаКартинок.ЗафиксироватьТаблицу);
	ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, "ПодключаемаяКоманда" + ИмяКоманды, НСтр("ru = 'Фиксация шапки';
																							|en = 'Fixing caps'"), ПараметрыКоманды);
	
	Поля = Новый Структура;
	Поля.Вставить("ИмяКоманды", ИмяКоманды);
	Поля.Вставить("Пометка", Истина);
	Поля.Вставить("ТолькоВоВсехДействиях", Истина);
	ИТК_Форма.ДобавитьЭлемент(Форма, "Кнопка" + ИмяКоманды, "Кнопка", Поля, ГруппаПодключаемые);
	
	// Выделить ячейки
	ИмяКоманды = "ВыделитьЯчейки";
	
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("Картинка", БиблиотекаКартинок.ИТК_Выделенный);
	ПараметрыКоманды.Вставить("СочетаниеКлавиш", Новый СочетаниеКлавиш(Клавиша.B, , Истина));
	ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяОсновногоОбработчика(),
											НСтр("ru = 'Выделить/отменить выделение';
												|en = 'Select / deselect'"), ПараметрыКоманды); 
	
	Поля = Новый Структура("ИмяКоманды", ИмяКоманды);
	ИТК_Форма.ДобавитьЭлемент(Форма, "Кнопка" + ИмяКоманды, "Кнопка", Поля, КонтекстноеМенюТабличныйДокументРезультат); 
	
	ДобавитьГруппуИнструментыВКонтекстноеМеню(Форма, КонтекстноеМенюТабличныйДокументРезультат);
	
	// Уровень группировок
	Поля = Новый Структура;
	Поля.Вставить("Заголовок", НСтр("ru = 'Уровень группировки';
									|en = 'Grouping level'"));
	ПодменюГруппировка = ИТК_Форма.ДобавитьЭлемент(Форма, "ТабличныйДокументРезультатКонтекстноеМенюУровеньГруппировки", "Группа",
													Поля, КонтекстноеМенюТабличныйДокументРезультат);
	
	// Уровень группировки...
	Для Уровень = 1 По 13 Цикл 
		
		ИмяКоманды = "УровеньГруппировки" + Уровень;
		ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяОсновногоОбработчика());
		
		Поля = Новый Структура;
		Поля.Вставить("ИмяКоманды", ИмяКоманды);
		Поля.Вставить("Видимость", Ложь);
		ИТК_Форма.ДобавитьЭлемент(Форма, ИмяКоманды, "Кнопка", Поля, ПодменюГруппировка);
		
	КонецЦикла;
	
	// Группа копирование ссылки
	Поля = Новый Структура;
	Поля.Вставить("Заголовок", НСтр("ru = 'Копирование ссылки';
									|en = 'Copy link'"));
	ГруппаКопированиеСсылки = ИТК_Форма.ДобавитьЭлемент(Форма, "ТабличныйДокументРезультатКонтекстноеМенюГруппаКопированиеСсылки", "Группа",
															Поля, КонтекстноеМенюТабличныйДокументРезультат);  
	
	// Копировать UID Ссылки
	ИмяКоманды = "КопироватьUIDСсылки";
	
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("Картинка", БиблиотекаКартинок.ИТК_КопироватьВБуферОбмена);
	ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяОсновногоОбработчика(),
								НСтр("ru = 'UID ссылки';
									|en = 'Copy UID'"), ПараметрыКоманды); 
	
	Поля = Новый Структура("ИмяКоманды", ИмяКоманды);
	ИТК_Форма.ДобавитьЭлемент(Форма, "Кнопка" + ИмяКоманды, "Кнопка", Поля, ГруппаКопированиеСсылки);
	
	// Копировать ссылку на встроенном языке
	ИмяКоманды = "КопироватьСсылкуКодНаВстроенномЯзыке";
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("Картинка", БиблиотекаКартинок.ИТК_КопироватьВБуферОбмена);
	ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяОсновногоОбработчика(),
								НСтр("ru = 'Ссылка (на встроенном языке)';
									|en = 'Ref (in built-in language)'"),	ПараметрыКоманды); 
								
	Поля = Новый Структура("ИмяКоманды", ИмяКоманды);
	ИТК_Форма.ДобавитьЭлемент(Форма, "Кнопка" + ИмяКоманды, "Кнопка", Поля, ГруппаКопированиеСсылки);
	
	Поля = Новый Структура;
	Поля.Вставить("Заголовок", НСтр("ru = 'Картинка';
									|en = 'Picture'"));
	Поля.Вставить("ВертикальноеПоложениеВГруппе", ВертикальноеПоложениеЭлемента.Центр);
	Поля.Вставить("Картинка", БиблиотекаКартинок.ИТК_ПредупреждениеВажное);
	Поля.Вставить("Высота", 1);
	ИТК_Форма.ДобавитьЭлемент(Форма, "КартинкаНеВсеСтрокиВыведены", "ДекорацияКартинка", Поля, ГруппаНеВсеСтрокиВыведены);
	
	Поля = Новый Структура;
	Поля.Вставить("Заголовок", НСтр("ru = 'Не все строки выведены';
									|en = 'Not all lines are output'"));
	Поля.Вставить("ВертикальноеПоложениеВГруппе", ВертикальноеПоложениеЭлемента.Центр);
	ИТК_Форма.ДобавитьЭлемент(Форма, "НадписьНеВсеСтрокиВыведены", "ДекорацияНадпись", Поля, ГруппаНеВсеСтрокиВыведены);
	
	Если СоздаватьКнопкуНеВсеСтрокиВыведены Тогда
		
		ИмяКоманды = "ВывестиВсеСтрокиРезультата";
		
		ПараметрыКоманды = Новый Структура;
		ПараметрыКоманды.Вставить("Подсказка", НСтр("ru = 'Вывести все строки результата';
													|en = 'Output all result lines'"));
		ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, "ПодключаемаяКоманда" + ИмяКоманды,
									НСтр("ru = 'Вывести все';
										|en = 'Output all'"), ПараметрыКоманды);
		
		Поля = Новый Структура;
		Поля.Вставить("ИмяКоманды", ИмяКоманды);
		ИТК_Форма.ДобавитьЭлемент(Форма, "КнопкаНеВсеСтрокиВыведены", "ГиперСсылка", Поля, ГруппаНеВсеСтрокиВыведены); 
		
	КонецЕсли;
	
	// Элементы группы Сумма
	Поля = Новый Структура;
	Поля.Вставить("Картинка", БиблиотекаКартинок.ИТК_Сумма);
	Поля.Вставить("Заголовок", НСтр("ru = 'Картинка';
									|en = 'Picture'"));
	Поля.Вставить("ВертикальноеПоложениеВГруппе", ВертикальноеПоложениеЭлемента.Центр);
	Поля.Вставить("Высота", 1);
	ИТК_Форма.ДобавитьЭлемент(Форма, "КартинкаСумма", "ДекорацияКартинка", Поля, ГруппаСумма); 
	
	Поля = Новый Структура;
	Поля.Вставить("ПутьКДанным", "ПолеСумма");
	Поля.Вставить("РедактированиеТекста", Ложь);
	Поля.Вставить("Ширина", 20);
	Поля.Вставить("ПоложениеЗаголовка", ПоложениеЗаголовкаЭлементаФормы.Нет);
	Поля.Вставить("Заголовок", НСтр("ru = 'Поле';
									|en = 'Field'"));
	Поля.Вставить("РастягиватьПоГоризонтали", Ложь);
	Поля.Вставить("ГоризонтальноеПоложение", ГоризонтальноеПоложениеЭлемента.Право);
	Поля.Вставить("Подсказка", НСтр("ru = 'Сумма выделенных ячеек';
									|en = 'Sum of selected cells'"));
	ИТК_Форма.ДобавитьЭлемент(Форма, "ПолеСумма", "ПолеВвода", Поля, ГруппаСумма); 

КонецПроцедуры

Процедура ДобавитьГруппуИнструментыВКонтекстноеМеню(Форма, КонтекстноеМеню) Экспорт
	
	// Группа прочие инструменты
	Поля = Новый Структура;
	Поля.Вставить("Заголовок", НСтр("ru = 'Инструменты';
									|en = 'Tools'"));
	ГруппаИнструменты = ИТК_Форма.ДобавитьЭлемент(Форма, "ТабличныйДокументРезультатКонтекстноеМенюГруппаИнструменты", "Группа",
													Поля, КонтекстноеМеню);  
	
	// Найти ссылки на объект
	ОписаниеИнструмента = ИТК_ТуллкитКлиентСервер.ОписаниеИнструмента(ИТК_Перечисления.ИнструментПоискСсылокНаОбъект());
	Если ОписаниеИнструмента["Доступ"] Тогда
		
		ИмяКоманды = "НайтиСсылкиНаОбъект";
		ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяОсновногоОбработчика(), ОписаниеИнструмента["Представление"]);
		
		Поля = Новый Структура("ИмяКоманды", ИмяКоманды);
		ИТК_Форма.ДобавитьЭлемент(Форма, "Кнопка" + ИмяКоманды, "Кнопка", Поля, ГруппаИнструменты);
		
	КонецЕсли;
	
	// Редактор объекта
	ОписаниеИнструмента = ИТК_ТуллкитКлиентСервер.ОписаниеИнструмента(ИТК_Перечисления.ИнструментРедакторОбъекта());
	Если ОписаниеИнструмента["Доступ"] Тогда
		
		ИмяКоманды = "РедакторОбъекта";
		ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяОсновногоОбработчика(), ОписаниеИнструмента["Представление"]);
		
		Поля = Новый Структура("ИмяКоманды", ИмяКоманды);
		ИТК_Форма.ДобавитьЭлемент(Форма, "Кнопка" + ИмяКоманды, "Кнопка", Поля, ГруппаИнструменты);
		
	КонецЕсли;
	
	ИмяКоманды = "ВсеИнструменты";
	ЗаголовокКоманды = НСтр("ru = 'Все инструменты...';
							|en = 'All instruments...'");
	ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяОсновногоОбработчика(), ЗаголовокКоманды);
									
	Поля = Новый Структура;
	Поля.Вставить("ИмяКоманды", ИмяКоманды);
	Поля.Вставить("СочетаниеКлавиш", Новый СочетаниеКлавиш(Клавиша.T, Истина));
	Поля.Вставить("Картинка", БиблиотекаКартинок.ИТК_Подсистема);
	ИТК_Форма.ДобавитьЭлемент(Форма, "Кнопка" + ИмяКоманды, "Кнопка", Поля, ГруппаИнструменты);
	
КонецПроцедуры

Функция ПрочитатьДвоичныхДанных(ДвоичныеДанные) Экспорт
	
	Результат = Новый ТабличныйДокумент;
	Результат.Прочитать(ДвоичныеДанные.ОткрытьПотокДляЧтения());
	
	Возврат Результат;
	
КонецФункции

Процедура ОформитьЧередованиеСтрок(Результат, ЦветЧередования = Неопределено) Экспорт
	
	Если ЦветЧередования = Неопределено Тогда
		ЦветЧередования = Новый Цвет(245, 245, 245);
	КонецЕсли;
	
	Для НомерСтроки = 1 По Результат.ВысотаТаблицы Цикл 
		
		Область = Результат.Область(НомерСтроки, 1, НомерСтроки, Результат.ШиринаТаблицы);
		
		Если Область.ЦветФона = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если Область.ЦветФона.Вид = ВидЦвета.АвтоЦвет
				И НомерСтроки % 2 = 0 Тогда
				
			Область.ЦветФона = ЦветЧередования;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Возвращает сумму выделенных ячеек табличного документа.
//
// Параметры:
//	ТабличныйДокумент - ТабличныйДокумент - Табличный документ, содержащий ячейки для суммирования.
//	КэшВыделеннойОбласти - Структура - Содержит ячейки выделенной области.
//
// Возвращаемое значение:
//	Число - Сумма значений ячеек.
//
Функция ВычислитьСуммуВыделенныхЯчеек(ТабличныйДокумент, КэшВыделеннойОбласти) Экспорт
	
	АнализируемыйТабличныйДокумент = Новый ТабличныйДокумент;
	Если ЭтоАдресВременногоХранилища(ТабличныйДокумент) Тогда
		
		АнализируемыйТабличныйДокумент = ПолучитьИзВременногоХранилища(ТабличныйДокумент);
		
	КонецЕсли;
	
	ОписаниеТипаЧисло = Новый ОписаниеТипов("Число");
	
	Сумма = 0;
	Для Каждого КлючИЗначение Из КэшВыделеннойОбласти Цикл
		
		СтруктураАдресВыделеннойОбласти = КлючИЗначение.Значение;
		
		Для ИндексСтрока = СтруктураАдресВыделеннойОбласти.Верх По СтруктураАдресВыделеннойОбласти.Низ Цикл
			
			Для ИндексКолонка = СтруктураАдресВыделеннойОбласти.Лево По СтруктураАдресВыделеннойОбласти.Право Цикл
				
				Ячейка = АнализируемыйТабличныйДокумент.Область(ИндексСтрока, ИндексКолонка, ИндексСтрока, ИндексКолонка);
				
				Если Ячейка.Видимость = Истина Тогда
					
					ЧислоВЯчейке  = ОписаниеТипаЧисло.ПривестиЗначение(Ячейка.Текст);
					Сумма = Сумма + ЧислоВЯчейке;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
	КонецЦикла;
	
	КэшВыделеннойОбласти.Вставить("Сумма", Сумма);
	
	Возврат Сумма;
	
КонецФункции

// Выделить ячейки табличного документа
//
// Параметры:
//	АдресТабличногоДокумента - Строка - Адрес табличного документа во временном хранилище
//	ВыделеннаяОбласть - Структура - Выделенная область
//
Процедура ВыделитьЯчейки(АдресТабличногоДокумента, ВыделеннаяОбласть) Экспорт
	
	Если ЭтоАдресВременногоХранилища(АдресТабличногоДокумента) Тогда
		ТабличныйДокумент = ПолучитьИзВременногоХранилища(АдресТабличногоДокумента);
	Иначе
		ТабличныйДокумент = Новый ТабличныйДокумент;
	КонецЕсли;
	
	ИТК_ТабличныйДокументКлиентСервер.ВыделитьЯчейки(ТабличныйДокумент, ВыделеннаяОбласть);
	
КонецПроцедуры

// Вывести табличный документ (источник) в приемник
//
// Параметры:
//	Приемник - ТабличныйДокумент - Табличный документ (приемник)
//	Источник - ТабличныйДокумент - Табличный документ (источник)
//
Процедура ВывестиВТабличныйДокумент(Приемник, Источник) Экспорт
	
	Приемник.Вывести(Источник);
	
КонецПроцедуры

Функция СсылкиВыделеннойОбласти(ТабличныйДокумент, ВыделенныеОбласти, АдресДанныхРасшифровки) Экспорт
	
	Область = ВыделенныеОбласти[0];
	
	Результат = Новый Массив;
	ДанныеРасшифровки = ПолучитьИзВременногоХранилища(АдресДанныхРасшифровки);
	Для Строка = Область.Верх По Область.Низ Цикл 
		
		ДанныеСтроки = Новый Массив;
		Для Столбец = Область.Лево По Область.Право Цикл 
			
			ОбластьЯчейки = ТабличныйДокумент.Область(Строка, Столбец);
			Расшифровка = ОбластьЯчейки.Расшифровка;
			Если ТипЗнч(Расшифровка) = Тип("ИдентификаторРасшифровкиКомпоновкиДанных") Тогда
				Расшифровка = ДанныеРасшифровки.Элементы[Расшифровка].ПолучитьПоля()[0].Значение
			КонецЕсли;
			
			Попытка
				ДанныеЯчейки = ВРег(Расшифровка.УникальныйИдентификатор());
			Исключение
				ДанныеЯчейки = ОбластьЯчейки.Текст;
			КонецПопытки;
			
			ДанныеСтроки.Добавить(ДанныеЯчейки);
			
		КонецЦикла;
		
		Результат.Добавить(СтрСоединить(ДанныеСтроки, Символы.Таб));
		
	КонецЦикла;
	
	Возврат СтрСоединить(Результат, Символы.ПС);

КонецФункции

Функция ЗначенияРасшифровокСЗаполнениеРасшифровокСКД(ЗначенияРасшифровок, АдресДанныхРасшифровки) Экспорт
	
	Результат = Новый Массив;
	
	Если НЕ ЭтоАдресВременногоХранилища(АдресДанныхРасшифровки) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ДанныеРасшифровки = ПолучитьИзВременногоХранилища(АдресДанныхРасшифровки);
	
	Для Каждого ЗначениеРасшифровки Из ЗначенияРасшифровок Цикл 
		
		Если ТипЗнч(ЗначениеРасшифровки) = Тип("ИдентификаторРасшифровкиКомпоновкиДанных") Тогда
			Расшифровка = ДанныеРасшифровки.Элементы[ЗначениеРасшифровки].ПолучитьПоля()[0].Значение;
		Иначе
			Расшифровка = ЗначениеРасшифровки;
		КонецЕсли;

		Попытка

			Если ИТК_ОбщийКлиентСервер.ЭтоСсылка(Расшифровка)
					И Результат.Найти(Расшифровка) = Неопределено Тогда
						
				Результат.Добавить(Расшифровка);
				
			КонецЕсли;

		Исключение

		КонецПопытки;
		
	КонецЦикла;
	
	Возврат Результат;

КонецФункции

#КонецОбласти

