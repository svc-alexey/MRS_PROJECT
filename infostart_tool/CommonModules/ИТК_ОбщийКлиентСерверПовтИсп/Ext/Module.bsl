#Область ПрограммныйИнтерфейс

Функция ИнформационнаяБазаФайловая() Экспорт 
	
	СтрокаСоединенияИнформационнойБазы = СтрокаСоединенияИнформационнойБазы();
	Возврат СтрНайти(ВРег(СтрокаСоединенияИнформационнойБазы), "FILE=") = 1;
	
КонецФункции

Функция БиблиотекаКартинок(Имя) Экспорт
	
	Возврат БиблиотекаКартинок[Имя];
	
КонецФункции

Функция ВариантВстроенногоЯзыкаРусский() Экспорт
	
	Возврат ИТК_ОбщийПовтИсп.ВариантВстроенногоЯзыкаРусский();

КонецФункции

Функция ВариантВстроенногоЯзыкаАнглийский() Экспорт
	
	Возврат ИТК_ОбщийПовтИсп.ВариантВстроенногоЯзыкаАнглийский();
	
КонецФункции

Функция КодЯзыкаПрограммированияКонфигурации() Экспорт
	
	Если ИТК_ОбщийПовтИсп.ВариантВстроенногоЯзыкаРусский() Тогда
		Результат = ИТК_ОбщийКлиентСервер.КодЯзыкаРусский();
	Иначе
		Результат = ИТК_ОбщийКлиентСервер.КодЯзыкаАнглийский();
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция КартинкаИзбранное(Избранное) Экспорт 
	
	Если Избранное Тогда
		Результат = БиблиотекаКартинок.ИТК_Избранное;
	Иначе
		Результат = Новый Картинка;
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

Функция ОсобыеПредставленияКлавишы() Экспорт
	
	Результат = Новый Соответствие;
	Результат.Вставить(Клавиша.NumAdd, """+""");
	Результат.Вставить(Клавиша.NumDecimal, ".");
	Результат.Вставить(Клавиша.NumDivide, "/");
	Результат.Вставить(Клавиша.NumMultiply, "*");
	Результат.Вставить(Клавиша.NumSubtract, """-""");
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
