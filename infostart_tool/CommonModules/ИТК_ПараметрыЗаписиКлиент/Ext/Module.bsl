#Область ПрограммныйИнтерфейс

Процедура ОбновитьЭлементы(Форма, ЭтоДокумент = Ложь) Экспорт 
	
	Элементы = Форма.Элементы;
	Элементы[ИТК_ПараметрыЗаписиКлиентСервер.ИмяПараметраПропуститьПроверкуЗапретаИзмененияВФорме()].Видимость = ЭтоДокумент;
	
КонецПроцедуры

Процедура ОбработатьКоманду(Форма, Имя) Экспорт
	
	Если СтрНайти(Имя, "ДополнительныеСвойства") Тогда
		
		ПараметрыФормы = Новый Структура;
		ПараметрыЗаписи = ИТК_ПараметрыЗаписиКлиентСервер.Значения(Форма);
		ПараметрыФормы.Вставить("Значение", ПараметрыЗаписи.ДополнительныеСвойства);
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Форма", Форма);
		ОписаниеОповещения = Новый ОписаниеОповещения("ЗавершеноРедактированиеДополнительныхСвойств", ЭтотОбъект, ДополнительныеПараметры);
		
		ОткрытьФорму("ОбщаяФорма.ИТК_РедактированиеДополнительныхСвойств", ПараметрыФормы, Форма, , , , ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗавершеноРедактированиеДополнительныхСвойств(Результат, ДополнительныеПараметры) Экспорт 
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Форма = ДополнительныеПараметры.Форма;
	
	СписокДополнительныйСвойства = Новый СписокЗначений;
	Для Каждого ОписаниеДополнительногоСвойства Из Результат Цикл 
		СписокДополнительныйСвойства.Добавить(ОписаниеДополнительногоСвойства.Значение, ОписаниеДополнительногоСвойства.Ключ);
	КонецЦикла;
	
	Форма[ИТК_ПараметрыЗаписиКлиентСервер.ИмяПараметраДополнительныйСвойства()] = СписокДополнительныйСвойства;
	Форма.Элементы["ДополнительныеСвойства"].Заголовок = ИТК_ФормаКлиентСервер.ЗаголовокСКоличеством(НСтр("ru = 'Дополнительные свойства';
																											|en = 'Additional properties'"),
																									СписокДополнительныйСвойства.Количество());
	
КонецПроцедуры

#КонецОбласти