Функция ТипыКоторыеНельзяХранитьВПолеФормы() Экспорт
	
	Результат = Новый Соответствие;
	
	Результат.Вставить(Тип("Массив"), Истина);
	Результат.Вставить(Тип("ДанныеФормыДерево"), Истина);
	Результат.Вставить(Тип("ДанныеФормыСтруктура"), Истина);
	Результат.Вставить(Тип("ДанныеФормыКоллекция"), Истина);
	Результат.Вставить(Тип("ДинамическийСписок"), Истина);
	
	Возврат Результат;
	
КонецФункции

