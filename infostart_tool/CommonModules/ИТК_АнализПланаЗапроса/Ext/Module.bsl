#Область ПрограммныйИнтерфейс

// Заполняет список сортировок плана запроса
//
// Параметры:
//   Элемент  - ЭлементФормы - Элемент формы список выбора
//   ТипСУБД  - Перечисления.ИТК_СУБД - Тип СУБД анализируемого плана
//
// Возвращаемое значение:
//   Строка	- Значение сортировки (по умолчанию)
//
Функция ЗаполнитьСписокСортировкиПлана(Элемент, ТипСУБД) Экспорт
	
	ЭтоФайловая = (ТипСУБД = ИТК_Перечисления.СУБДФайловая());
	ЭтоMicrosoftSQL = (ТипСУБД = ИТК_Перечисления.СУБДMicrosoftSQL());
	ЭтоPostgreSQL = (ТипСУБД = ИТК_Перечисления.СУБДPostgreSQL());
	
	СписокВыбора = Элемент.СписокВыбора;
	СписокВыбора.Добавить("Порядку", НСтр("ru = 'Порядку';
											|en = 'Order'"));
	
	Если ЭтоФайловая Тогда
		
		СписокВыбора.Добавить("ВремениВыполнения", НСтр("ru = 'Времени выполнения';
														|en = 'Execution time'"));
		
	КонецЕсли;
	
	Если ЭтоMicrosoftSQL ИЛИ ЭтоPostgreSQL Тогда
		
		СписокВыбора.Добавить("Стоимости", НСтр("ru = 'Стоимости';
												|en = 'Costs'"));
		
	КонецЕсли;
	
	Если ЭтоMicrosoftSQL Тогда
 
		СписокВыбора.Добавить("ВремениВводаВывода", НСтр("ru = 'Времени ввода вывода';
														|en = 'Time input / output'"));
	
	КонецЕсли;
	
	
	Если ЭтоФайловая Тогда
		
		Результат = "ВремениВыполнения";
		
	Иначе
		
		Результат = "Стоимости";
	
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Производит анализ технологического журнала для получения данных плана выполнения запроса
// Параметры:
//   ПолноеИмяФайла  - Строка - Полное имя файла лога журнала
//   UIDМетки  - Строка - UID метки для поиска данных запроса в журнале
//   ОписанияТиповЗадействованныхПараметров  - Массив - Используемые типы параметров
//
// Возвращаемое значение:
//   Структура	- Данные анализа (ТипСУБД, Дерево)
//
Функция Данные(ПолноеИмяФайла, UIDМетки, ОписанияТиповЗадействованныхПараметров) Экспорт 
	
	Результат = ПрочитатьДанныеИзТехнологическогоЖурнала(ПолноеИмяФайла, UIDМетки);
	ТипСУБД = Результат.ТипСУБД;
	
	ХранениеБазыДанных = Новый Структура;
	ХранениеБазыДанных.Вставить("Имя", ИТК_ОбщийПовтИсп.ИмяИнформационнойБазы());
	ХранениеБазыДанных.Вставить("ТипСУБД", ТипСУБД);
	
	// Подготовка структуры хранения
	СтруктураХраненияБазыДанных = ПолучитьСтруктуруХраненияБазыДанных(, Истина); // !!! Работа в англ. языке
	Если ТипСУБД = ИТК_Перечисления.СУБДФайловая() Тогда
		
		Для Каждого СтрокаХранения Из СтруктураХраненияБазыДанных Цикл 
			СтрокаХранения.ИмяТаблицыХранения = ВРег(СтрокаХранения.ИмяТаблицыХранения);
		КонецЦикла;
		
	КонецЕсли;
	ХранениеБазыДанных.Вставить("Структура", СтруктураХраненияБазыДанных);

	ДеревоПланаЗапроса = Новый ДеревоЗначений;
	ДеревоПланаЗапроса.Колонки.Добавить("Оператор", ИТК_ТипыКлиентСервер.ОписаниеСтрока(100));
	ДеревоПланаЗапроса.Колонки.Добавить("Контекст", ИТК_ТипыКлиентСервер.ОписаниеСтрока(150));
	ДеревоПланаЗапроса.Колонки.Добавить("Контекст1С", ИТК_ТипыКлиентСервер.ОписаниеСтрока(150));
	ДеревоПланаЗапроса.Колонки.Добавить("SQLЗапрос", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	ДеревоПланаЗапроса.Колонки.Добавить("SQLЗапрос1С", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	ДеревоПланаЗапроса.Колонки.Добавить("План", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	ДеревоПланаЗапроса.Колонки.Добавить("План1С", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	
	// Общие показатели
	ДеревоПланаЗапроса.Колонки.Добавить("UID", Новый ОписаниеТипов("УникальныйИдентификатор"));
	ДеревоПланаЗапроса.Колонки.Добавить("Количество", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10));
	ДеревоПланаЗапроса.Колонки.Добавить("НомерСтроки", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10));
	ДеревоПланаЗапроса.Колонки.Добавить("ПроцентОтОбщего", ИТК_ТипыКлиентСервер.ОписаниеЧисло());

	Если ТипСУБД = ИТК_Перечисления.СУБДMicrosoftSQL() Тогда
		
		ДеревоПланаЗапроса.Колонки.Добавить("XML", ИТК_ТипыКлиентСервер.ОписаниеСтрока(10));
		
		ДеревоПланаЗапроса.Колонки.Добавить("Стоимость", ИТК_ТипыКлиентСервер.ОписаниеЧисло());
		ДеревоПланаЗапроса.Колонки.Добавить("ЗатратыВводВывод", ИТК_ТипыКлиентСервер.ОписаниеЧисло());
		ДеревоПланаЗапроса.Колонки.Добавить("ЗагрузкаЦП", ИТК_ТипыКлиентСервер.ОписаниеЧисло());
		
		ДеревоПланаЗапроса.Колонки.Добавить("ДанныеСтрок", ИТК_ТипыКлиентСервер.ОписаниеСтрока(100));
		ДеревоПланаЗапроса.Колонки.Добавить("СтрокиПлан", ИТК_ТипыКлиентСервер.ОписаниеЧисло());
		ДеревоПланаЗапроса.Колонки.Добавить("СтрокиФакт", ИТК_ТипыКлиентСервер.ОписаниеЧисло());
		ДеревоПланаЗапроса.Колонки.Добавить("СреднийРазмерСтроки", ИТК_ТипыКлиентСервер.ОписаниеЧисло());
		
		ДеревоПланаЗапроса.Колонки.Добавить("Вызовы", ИТК_ТипыКлиентСервер.ОписаниеСтрока(100));
		ДеревоПланаЗапроса.Колонки.Добавить("ВызовыПлан", ИТК_ТипыКлиентСервер.ОписаниеЧисло());
		ДеревоПланаЗапроса.Колонки.Добавить("ВызовыФакт", ИТК_ТипыКлиентСервер.ОписаниеЧисло());
		
	ИначеЕсли ТипСУБД = ИТК_Перечисления.СУБДФайловая() Тогда
		
		ДеревоПланаЗапроса.Колонки.Добавить("ВремяВыполнения", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10, 3));
		ДеревоПланаЗапроса.Колонки.Добавить("ВремяРазбора", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10, 3));
		ДеревоПланаЗапроса.Колонки.Добавить("ОбработаноЗаписей", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10));
		ДеревоПланаЗапроса.Колонки.Добавить("БуферыПамяти", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10));
		ДеревоПланаЗапроса.Колонки.Добавить("ЗаписейВРезультате", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10));
		ДеревоПланаЗапроса.Колонки.Добавить("РазмерЗаписи", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10));
		
	ИначеЕсли ТипСУБД = ИТК_Перечисления.СУБДPostgreSQL() Тогда
		
		ДеревоПланаЗапроса.Колонки.Добавить("Стоимость", ИТК_ТипыКлиентСервер.ОписаниеЧисло());
		ДеревоПланаЗапроса.Колонки.Добавить("ВремяВыполнения", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10, 3));
		ДеревоПланаЗапроса.Колонки.Добавить("ОбработаноЗаписей", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10));
		ДеревоПланаЗапроса.Колонки.Добавить("ЗаписейВРезультате", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10));
		ДеревоПланаЗапроса.Колонки.Добавить("РазмерЗаписи", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10));
		
	КонецЕсли;
	
	КореньДерева = ДеревоПланаЗапроса.Строки.Добавить();
	
	НомерЗапроса = 1;
	Для Каждого ОписаниеЗапроса Из Результат.Запросы Цикл 
		
		НоваяСтрока = КореньДерева.Строки.Добавить();
		НоваяСтрока.Оператор = СтрШаблон(НСтр("ru = 'Запрос %1';
												|en = 'Query %1'"), НомерЗапроса);
		
		НоваяСтрока.SQLЗапрос = ОписаниеЗапроса.SQLТекст;
		
		ОписаниеЗапросаВТерминах1С = SQLЗапросВТерминах1С(ОписаниеЗапроса.SQLТекст, ХранениеБазыДанных, ОписанияТиповЗадействованныхПараметров);
		НоваяСтрока.SQLЗапрос1С = ОписаниеЗапросаВТерминах1С.Текст;
		
		ТекстПланаЗапроса = ОписаниеЗапроса.План;
		
		Если ТипСУБД = ИТК_Перечисления.СУБДPostgreSQL() Тогда
			
			Индекс = СтрНайти(ТекстПланаЗапроса, "Planning time:");
			Если ЗначениеЗаполнено(Индекс) Тогда
				ТекстПланаЗапроса = Лев(ТекстПланаЗапроса, Индекс - 1);
			КонецЕсли;

		ИначеЕсли ТипСУБД = ИТК_Перечисления.СУБДMicrosoftSQL() Тогда
			
			НоваяСтрока.XML = "XML";
			
		КонецЕсли;
		
		РазборПланаВыполненияЗапроса(НоваяСтрока, ТекстПланаЗапроса, ХранениеБазыДанных, ОписаниеЗапросаВТерминах1С);
		
		НомерЗапроса = НомерЗапроса + 1;
		
	КонецЦикла;
	
	// Дополнительная обработка данных расчет итогов, заполнение номера по порядку и т.д.
	ЗаполнитьВспомогательныеСтрокиДереваАнализаПланаЗапроса(КореньДерева);
	КореньДерева.Количество = ИтогВДереве(КореньДерева, "Количество", Ложь);
	
	Если ТипСУБД = ИТК_Перечисления.СУБДMicrosoftSQL() Тогда
		
		ИтогоСтоимость = 0; ИтогоЗагрузкаЦП = 0; ИтогоЗатратыВводВывод = 0;
		Для Каждого ВложеннаяСтрока Из КореньДерева.Строки Цикл 
			
			Стоимость = ИтогВДереве(ВложеннаяСтрока, "Стоимость");
			ВложеннаяСтрока.Стоимость = Стоимость;
			ИтогоСтоимость = ИтогоСтоимость + Стоимость;
			
			ЗагрузкаЦП = ИтогВДереве(ВложеннаяСтрока, "ЗагрузкаЦП");
			ВложеннаяСтрока.ЗагрузкаЦП = ЗагрузкаЦП;
			ИтогоЗагрузкаЦП = ИтогоЗагрузкаЦП + ЗагрузкаЦП;
			
			ЗатратыВводВывод = ИтогВДереве(ВложеннаяСтрока, "ЗатратыВводВывод");
			ВложеннаяСтрока.ЗатратыВводВывод = ЗатратыВводВывод;
			ИтогоЗатратыВводВывод = ИтогоЗатратыВводВывод + ЗатратыВводВывод;
			
		КонецЦикла;
		КореньДерева.Стоимость = ИтогоСтоимость;
		КореньДерева.ЗагрузкаЦП = ИтогоЗагрузкаЦП;
		КореньДерева.ЗатратыВводВывод = ИтогоЗатратыВводВывод;
		
		РассчитатьПроцентОтОбщегоВДереве(КореньДерева, КореньДерева.Стоимость, "Стоимость");
		
	ИначеЕсли ТипСУБД = ИТК_Перечисления.СУБДPostgreSQL() Тогда
		
		ИтогоСтоимость = 0; ИтогоЗаписейВРезультате = 0;
		Для Каждого ВложеннаяСтрока Из КореньДерева.Строки Цикл 
			
			Стоимость = ИтогВДереве(ВложеннаяСтрока, "Стоимость", Ложь);
			ВложеннаяСтрока.Стоимость = Стоимость;
			ИтогоСтоимость = ИтогоСтоимость + Стоимость;
			
			ЗаписейВРезультате = ИтогВДереве(ВложеннаяСтрока, "ЗаписейВРезультате", Ложь);
			ВложеннаяСтрока.ЗаписейВРезультате = ЗаписейВРезультате;
			ИтогоЗаписейВРезультате = ИтогоЗаписейВРезультате + ЗаписейВРезультате;
			
		КонецЦикла;
		КореньДерева.Стоимость = ИтогоСтоимость;
		КореньДерева.ЗаписейВРезультате = ИтогоЗаписейВРезультате;
		
		РассчитатьПроцентОтОбщегоВДереве(КореньДерева, КореньДерева.Стоимость, "Стоимость");
		
	ИначеЕсли ТипСУБД = ИТК_Перечисления.СУБДФайловая() Тогда
		
		КореньДерева.ВремяВыполнения = ИтогВДереве(КореньДерева, "ВремяВыполнения");
		КореньДерева.ВремяРазбора = ИтогВДереве(КореньДерева, "ВремяРазбора");
		
		РассчитатьПроцентОтОбщегоВДереве(КореньДерева, КореньДерева.ВремяВыполнения, "ВремяВыполнения");
		
	КонецЕсли;
	
	КореньДерева.План = ИтогПоСтрокеВДереве(КореньДерева, "План", Символы.ПС + Символы.ПС);
	КореньДерева.SQLЗапрос = ИтогПоСтрокеВДереве(КореньДерева, "SQLЗапрос", ИТК_Запрос.РазделительПакетов());
	КореньДерева.SQLЗапрос1С = ИтогПоСтрокеВДереве(КореньДерева, "SQLЗапрос1С", ИТК_Запрос.РазделительПакетов());
	
	Результат = Новый Структура;
	Результат.Вставить("ТипСУБД", ТипСУБД);
	Результат.Вставить("Дерево", ДеревоПланаЗапроса);
	
	Возврат Результат;

КонецФункции

// Возвращает идентификатор процесса ОС
//
// Возвращаемое значение:
//   Строка	- идентификатор процесса ОС
//
Функция ИдентификаторПроцессаОС() Экспорт
	
	// Функция из типовой консоли запросов, может выполнятся долго
	Если ОбщегоНазначения.ЭтоLinuxСервер() Тогда
		
		ПолноеИмяТекстовогоФайла = ПолучитьИмяВременногоФайла(".txt");
		
		Команда = СтрШаблон("ps -o ppid= -p $(echo $$) > '%1'", ПолноеИмяТекстовогоФайла);
		ЗапуститьПриложение(Команда, , Истина);
				
		ЧтениеТекста = Новый ЧтениеТекста(ПолноеИмяТекстовогоФайла, КодировкаТекста.UTF8);
		Строка = ЧтениеТекста.Прочитать();
		ЧтениеТекста.Закрыть();
		
		ИдентификаторПроцесса = Число(СокрЛП(Строка));
		
	Иначе
		
		WScriptShell = Новый COMОбъект("WScript.Shell");
		Процесс = WScriptShell.Exec("rundll32.exe kernel32,Sleep");
		ИдентификаторПроцесса = ПолучитьCOMОбъект("winmgmts:{impersonationLevel=impersonate}!\\.\root\CIMV2:Win32_Process.Handle='" + Формат(Процесс.ProcessID,"ЧГ=0") + "'").ParentProcessID;
		Процесс.Terminate(); 
		
	КонецЕсли;
	
	Возврат ИдентификаторПроцесса;	
	
КонецФункции

// Находит на сервере файл логов технологического журнала
//
// Параметры:
//   IDПроцесса - Число - ID процесса на сервере
//   КаталогЛогов - Строка - Каталог логов технологического журнала
//   ДатаСобытия - Дата - Дата, время события
//
// Возвращаемое значение:
//   Строка	- Полное имя файла, Неопределено - файл не найден
//
Функция ПолноеИмяLogФайлаТехнологическогоЖурнала(IDПроцесса, ДатаСобытия) Экспорт
	
	НастройкиКонсолиРазработчика = ИТК_Настройки.Загрузить(ИТК_Перечисления.ИнструментКонсольРазработчика());
	ПараметрыПолученияПлана = НастройкиКонсолиРазработчика["ПараметрыПолученияПлана"];
	
	КаталогЛоговЖурнала = ПараметрыПолученияПлана.Каталог;

	Если ОбщегоНазначения.ЭтоLinuxСервер() Тогда
		МаскаПоиска = "*";
	Иначе
		МаскаПоиска = "*.*";
	КонецЕсли;
	НайденныеФайлы = НайтиФайлы(ПараметрыПолученияПлана.Каталог, МаскаПоиска);
	
	Для Каждого НайденныйФайл Из НайденныеФайлы Цикл 
		
		Если Не НайденныйФайл.ЭтоКаталог() Тогда
			Продолжить;
		КонецЕсли;

		ИмяКаталога = НайденныйФайл.Имя;
		Если СтрНачинаетсяС(ИмяКаталога, "dbgs_") Тогда
			Продолжить;
		КонецЕсли;
		
		ШаблонПоиска = "_" + ИТК_Строки.ЧислоВСтроку(IDПроцесса);
		Если СтрЗаканчиваетсяНа(ИмяКаталога, ШаблонПоиска) Тогда
			
			КаталогЛоговЖурнала = НайденныйФайл.ПолноеИмя;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(КаталогЛоговЖурнала) Тогда
		Результат = КаталогЛоговЖурнала + ПолучитьРазделительПутиСервера() + ИмяФайлаТехнологическогоЖурнала(КаталогЛоговЖурнала, ДатаСобытия);
	Иначе
		Результат = Неопределено;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПрочитатьДанныеИзТехнологическогоЖурнала(ПолноеИмяФайла, UIDМетки)
	
	СтрокиЖурнала = Новый Массив;
	ДобавлятьВМассив = Ложь;
	
	ЧтениеДанных = Новый ЧтениеДанных(ПолноеИмяФайла);
	ЧтениеДанных.ПропуститьДо(UIDМетки);
	Строка = ЧтениеДанных.ПрочитатьСтроку();
	
	ВременнаяСтрока = "";
	Пока Не ЧтениеДанных.ЧтениеЗавершено Цикл
		
		Если ДобавлятьВМассив Тогда 
			
			Если Не СтрНайти(Строка, UIDМетки + "_end") Тогда
				
				Если Сред(Строка, 3, 1) = ":" И Сред(Строка, 6, 1) = "." Тогда
					
					Если ЗначениеЗаполнено(ВременнаяСтрока) 
						И СтрНайти(ВременнаяСтрока, "Sql=")
						И СтрНайти(ВременнаяСтрока, "planSQLText=") 
						И Не СтрНайти(ВременнаяСтрока, UIDМетки) Тогда 
							СтрокиЖурнала.Добавить(ВременнаяСтрока);	
					КонецЕсли;
						
					ВременнаяСтрока = Строка;
				Иначе
					ВременнаяСтрока =  ВременнаяСтрока + Символы.ПС + Строка;
				КонецЕсли;
				
			Иначе
				Прервать;
			КонецЕсли;
			
		КонецЕсли;
		
		Если СтрНайти(Строка, UIDМетки + "_begin") Тогда
			ДобавлятьВМассив = Истина;
		КонецЕсли;
		
		Строка = ЧтениеДанных.ПрочитатьСтроку();
		
	КонецЦикла;
	
	ЧтениеДанных.Закрыть();
	
	ПланыЗапросов = Новый Массив;
	Для Каждого Строка Из СтрокиЖурнала Цикл 
		
		Индекс = 1;
		ИТК_Строки.РазборНайтиТекст(Строка, ",", Индекс);
		IDСУБД = ИТК_Строки.РазборПрочитатьДоСимвола(Строка, ",", Индекс);
		ТипСУБД = ТипСУБД(ВРег(IDСУБД));
		
		Если ТипСУБД = ИТК_Перечисления.СУБДMicrosoftSQL() Тогда 
			
			SQLТекстТекущегоЗапроса = ИТК_Строки.РазборПрочитатьБлок(Строка, "Sql=", ",Rows");
			ПланТекущегоЗапроса = ИТК_Строки.РазборПрочитатьБлок(Строка, "planSQLText=", ",Context");
			
		ИначеЕсли ТипСУБД = ИТК_Перечисления.СУБДPostgreSQL() Тогда 

			// Пример строки журнала
			// 04:41.075004-1,DBPOSTGRS,...,Sql='SELECT
 			// T3._C_1RRef AS IDRRef...
			// FROM pg_temp.tt2 T3',planSQLText='Seq Scan on tt2 t3  (cost=0.00..19.05 rows=405 width=238) (actual time=0.013..0.208 rows=663 loops=1)
			// Planning time: 0.112 ms
			// Execution time: 0.243 ms
			// ',RowsAffected=663,Result=PGRES_TUPLES_OK,Context='Форма.Вызов : 			
			
			БлокПараметры = ",Prm=";
			БлокПланЗапроса = ",planSQLText=";
			Если СтрНайти(Строка, БлокПараметры) Тогда
				SQLТекстТекущегоЗапроса = ИТК_Строки.РазборПрочитатьБлок(Строка, "Sql=", БлокПараметры);
			Иначе
				SQLТекстТекущегоЗапроса = ИТК_Строки.РазборПрочитатьБлок(Строка, "Sql=", БлокПланЗапроса);
			КонецЕсли;
			
			ПланТекущегоЗапроса = ИТК_Строки.РазборПрочитатьБлок(Строка, БлокПланЗапроса, ",Rows");
			
		ИначеЕсли ТипСУБД = ИТК_Перечисления.СУБДФайловая() Тогда 
			
			// Пример строки журнала
			// 02:56.766003-3,DBV8DBEng,5,process=1CV8,OSThread=6064,Usr=Администратор,Trans=0,Sql='SELECT
			// T1._IDRRef,...',NParams=0,planSQLText='Fields:(
			// T1._IDRRef,...) _REFERENCE9 (T1) RANGE SCAN USING INDEX (_IDRREFIDX) (1 fields)
			// Statistics: RecordsScanned = 2, ParseTime = 0, ExecuteTime = 0, BuffersMemory = 25083, ResultRecords = 2,
			// RecordSize = 123',Rows=2,Context='Форма.Вызов...
			SQLТекстТекущегоЗапроса = ИТК_Строки.РазборПрочитатьБлок(Строка, "Sql=", ",NParams=");
			ПланТекущегоЗапроса = ИТК_Строки.РазборПрочитатьБлок(Строка, "planSQLText=", ",Rows");
			
		КонецЕсли;
		
		ПланыЗапросов.Добавить(Новый Структура("SQLТекст, План", SQLТекстТекущегоЗапроса, СокрЛП(ПланТекущегоЗапроса)));

	КонецЦикла;
	
	Результат = Новый Структура;
	Результат.Вставить("ТипСУБД", ТипСУБД);
	Результат.Вставить("Запросы", ПланыЗапросов);
	
	Возврат Результат;
	
КонецФункции

Процедура РазборПланаВыполненияЗапроса(СтрокаПриемник, ПланЗапросаТекст, ХранениеБазыДанных, ОписаниеЗапросаВТерминах1С)
	
	Если ХранениеБазыДанных.ТипСУБД = ИТК_Перечисления.СУБДMicrosoftSQL() Тогда

		СтрокиПоУровню = Новый Соответствие;
		СтрокиПоУровню.Вставить(1, СтрокаПриемник);
		Для Каждого СтрокаПлана Из СтрРазделить(ПланЗапросаТекст, Символы.ПС, Ложь) Цикл 
			
			Индекс = 1;
			ПоказателиПлана = СтрРазделить(ИТК_Строки.РазборПрочитатьДоСимвола(СтрокаПлана, "|", Индекс), ",");
			Для ИндексПоказателяПлана = 0 По ПоказателиПлана.ВГраница() Цикл 
				ПоказателиПлана[ИндексПоказателяПлана] = ИТК_Строки.ЭкспоненциальноеЧисло(ПоказателиПлана[ИндексПоказателяПлана]);
			КонецЦикла;
			
			ИскомаяСтрока = "|--";
			Индекс = СтрНайти(СтрокаПлана, ИскомаяСтрока, , Индекс);
			ИТК_Строки.РазборПропуститьНаборСимволов(СтрокаПлана, ИскомаяСтрока, Индекс);
			
			ТекстПлана = Сред(СтрокаПлана, Индекс);
			ОписаниеПланаВТерминах1С = SQLПланЗапросаВТерминах1С(ТекстПлана, ХранениеБазыДанных, ОписаниеЗапросаВТерминах1С);
			
			ИндексНачалаСтрокиОператор = СтрНайти(СтрокаПлана, ",", НаправлениеПоиска.СКонца, Индекс - СтрДлина(ИскомаяСтрока));  
			
			// Идет отступ 3, 8, 13 символов т.е. первый 3 дальше 3 + 5
			Отступ = Сред(СтрокаПлана, ИндексНачалаСтрокиОператор + 1, Индекс -  ИндексНачалаСтрокиОператор - 1 - СтрДлина(ИскомаяСтрока));
			ДлинаОтступа = СтрДлина(Отступ);
			Если ДлинаОтступа = 3 Тогда
				Уровень = 2;
			Иначе
				Уровень = 2 + Цел((ДлинаОтступа - 3) / 5);
			КонецЕсли;
			
			СтрокаРодитель = СтрокиПоУровню.Получить(Уровень - 1);
			Если СтрокаРодитель = Неопределено Тогда
				СтрокаРодитель = СтрокиПоУровню.Получить(Уровень - 2);
			КонецЕсли;
			НоваяСтрока = СтрокаРодитель.Строки.Добавить();
			СтрокиПоУровню.Вставить(Уровень, НоваяСтрока);
			
			НоваяСтрока.Оператор = ОписаниеПланаВТерминах1С.Оператор;
			НоваяСтрока.Контекст = СтрСоединить(ОписаниеПланаВТерминах1С.Метаданные, ", ");
			НоваяСтрока.Контекст1С = СтрСоединить(ОписаниеПланаВТерминах1С.Метаданные1C, ", ");
			НоваяСтрока.План = ТекстПлана;
			НоваяСтрока.План1С = ОписаниеПланаВТерминах1С.Текст;
			НоваяСтрока.СтрокиФакт = ПоказателиПлана[0];
			НоваяСтрока.ВызовыФакт = ПоказателиПлана[1];
			НоваяСтрока.СтрокиПлан = ПоказателиПлана[2];
			НоваяСтрока.ЗатратыВводВывод = ПоказателиПлана[3];
			НоваяСтрока.ЗагрузкаЦП = ИТК_Строки.ЭкспоненциальноеЧисло(ПоказателиПлана[4]);
			НоваяСтрока.СреднийРазмерСтроки = ПоказателиПлана[5];
			НоваяСтрока.Стоимость = ИТК_Строки.ЭкспоненциальноеЧисло(ПоказателиПлана[6]);
			НоваяСтрока.ВызовыПлан = ПоказателиПлана[7];
			НоваяСтрока.Вызовы = СтрШаблон("%1/%2", НоваяСтрока.ВызовыПлан, НоваяСтрока.ВызовыФакт);		
			НоваяСтрока.ДанныеСтрок = СтрШаблон("%1/%2 (%3)", НоваяСтрока.СтрокиПлан, НоваяСтрока.СтрокиФакт, НоваяСтрока.СреднийРазмерСтроки);		
			
		КонецЦикла;
		
	ИначеЕсли ХранениеБазыДанных.ТипСУБД = ИТК_Перечисления.СУБДPostgreSQL() Тогда
		
		НачалоБлокаПлана = "->";
		// Сбор строк плана (объединяем подчиненные строки)
		ЭлементыПлана = Новый Массив;
		Для Каждого СтрокаПлана Из СтрРазделить(НачалоБлокаПлана + ПланЗапросаТекст, Символы.ПС, Ложь) Цикл 
			
			Если СтрНайти(СтрокаПлана, НачалоБлокаПлана) Тогда
				ЭлементыПлана.Добавить(СтрокаПлана);
			Иначе
				ЭлементыПлана[ЭлементыПлана.ВГраница()] = ЭлементыПлана[ЭлементыПлана.ВГраница()] + Символы.ПС + СтрокаПлана;
			КонецЕсли;
			
		КонецЦикла;
		
		СтрокиПоУровню = Новый Соответствие;
		Для Каждого СтрокаПлана Из ЭлементыПлана Цикл 
			
			// Примеры строк:
			// Insert on tt2  (cost=0.00..84.13 rows=663 width=270)
			//   ->  Subquery Scan on "*SELECT*"  (cost=0.00..84.13 rows=663 width=270)
			//   ->  Seq Scan on tt2 t3  (cost=0.00..19.05 rows=405 width=238) (actual time=0.026..0.487 rows=663 loops=1)
			
			БлокСтоимость = " (cost=";
			Стоимость = 0; КоличествоСтрок = 0; РазмерСтроки = 0; ФактическоеВремя = 0; КоличествоОбработанныхСтрок = 0;
			Индекс = 1;
			Если ИТК_Строки.РазборНайтиТекст(СтрокаПлана, БлокСтоимость, Индекс) Тогда
				
				НачалоБлокаПоказателей = Индекс - СтрДлина(БлокСтоимость);

				ИТК_Строки.РазборНайтиТекст(СтрокаПлана, "..", Индекс);
				СтоимостьЦелаяЧасть = ИТК_Строки.РазборПрочитатьЦелоеЧисло(СтрокаПлана, Индекс);
				ИТК_Строки.РазборПропуститьНаборСимволов(СтрокаПлана, ".", Индекс);
				СтоимостьДробнаяЧасть = ИТК_Строки.РазборПрочитатьЦелоеЧисло(СтрокаПлана, Индекс);
				Стоимость = СтоимостьЦелаяЧасть + СтоимостьДробнаяЧасть / 100;
				
				ИТК_Строки.РазборНайтиТекст(СтрокаПлана, "rows=", Индекс);
				КоличествоСтрок = ИТК_Строки.РазборПрочитатьЦелоеЧисло(СтрокаПлана, Индекс);
				
				ИТК_Строки.РазборНайтиТекст(СтрокаПлана, "width=", Индекс);
				РазмерСтроки = ИТК_Строки.РазборПрочитатьЦелоеЧисло(СтрокаПлана, Индекс);
				ИТК_Строки.РазборПропуститьНаборСимволов(СтрокаПлана, ")", Индекс);
				
				СтрокаПлана = Лев(СтрокаПлана, НачалоБлокаПоказателей - 1) + Сред(СтрокаПлана, Индекс);
				
				БлокДополнительныеПоказатели = " (actual time=";
				Индекс = 1;
				Если ИТК_Строки.РазборНайтиТекст(СтрокаПлана, БлокДополнительныеПоказатели, Индекс) Тогда
					
					НачалоБлокаДополнительныхПоказателей = Индекс - СтрДлина(БлокДополнительныеПоказатели);

					ИТК_Строки.РазборНайтиТекст(СтрокаПлана, "..", Индекс);
					ФактическоеВремяЦелаяЧасть = ИТК_Строки.РазборПрочитатьЦелоеЧисло(СтрокаПлана, Индекс);
					ИТК_Строки.РазборПропуститьНаборСимволов(СтрокаПлана, ".", Индекс);
					ФактическоеВремяДробнаяЧасть = ИТК_Строки.РазборПрочитатьЦелоеЧисло(СтрокаПлана, Индекс);
					ФактическоеВремя = ФактическоеВремяЦелаяЧасть + ФактическоеВремяДробнаяЧасть / 100;
					
					ИТК_Строки.РазборНайтиТекст(СтрокаПлана, "rows=", Индекс);
					КоличествоОбработанныхСтрок = ИТК_Строки.РазборПрочитатьЦелоеЧисло(СтрокаПлана, Индекс);
					
					ИТК_Строки.РазборНайтиТекст(СтрокаПлана, "loops=", Индекс);
					КоличествоЦиклов = ИТК_Строки.РазборПрочитатьЦелоеЧисло(СтрокаПлана, Индекс);
					ИТК_Строки.РазборПропуститьНаборСимволов(СтрокаПлана, ")", Индекс);
					
					СтрокаПлана = Лев(СтрокаПлана, НачалоБлокаДополнительныхПоказателей - 1) + Сред(СтрокаПлана, Индекс);
					
				КонецЕсли;

			КонецЕсли;
			
			ИскомаяСтрока = "->";
			Индекс = СтрНайти(СтрокаПлана, ИскомаяСтрока);
			Если ЗначениеЗаполнено(Индекс) Тогда
				ТекстПлана = Сред(СтрокаПлана, Индекс + СтрДлина(ИскомаяСтрока));
				ОтступПередОператором = Лев(СтрокаПлана, Индекс - 1);
			Иначе 
				ТекстПлана = СтрокаПлана;
				ОтступПередОператором = ИТК_Строки.РазборПрочитатьНезначимые(СтрокаПлана);
			КонецЕсли;
			ТекстПлана = СокрЛП(ТекстПлана);

			ОписаниеПланаВТерминах1С = SQLПланЗапросаВТерминах1С(ТекстПлана, ХранениеБазыДанных, ОписаниеЗапросаВТерминах1С);
			
			ДлинаОтступа = СтрДлина(ОтступПередОператором);
			Если ДлинаОтступа = 0 Тогда
				Уровень = 0;
			Иначе
				Уровень = (ДлинаОтступа - 2) / 6 + 1;
			КонецЕсли;	
			
			СтрокаРодитель = СтрокиПоУровню.Получить(Уровень - 1);
			Если СтрокаРодитель = Неопределено Тогда
				НоваяСтрока = СтрокаПриемник.Строки.Добавить();
			Иначе
				НоваяСтрока = СтрокаРодитель.Строки.Добавить();
			КонецЕсли;
			СтрокиПоУровню.Вставить(Уровень, НоваяСтрока);
			
			НоваяСтрока.Оператор = ОписаниеПланаВТерминах1С.Оператор;
			НоваяСтрока.Контекст = СтрСоединить(ОписаниеПланаВТерминах1С.Метаданные, ", ");
			НоваяСтрока.Контекст1С = СтрСоединить(ОписаниеПланаВТерминах1С.Метаданные1C, ", ");
			НоваяСтрока.План = ТекстПлана;
			НоваяСтрока.План1С = ОписаниеПланаВТерминах1С.Текст;
			НоваяСтрока.Стоимость = Стоимость;
			НоваяСтрока.ЗаписейВРезультате = КоличествоСтрок;
			НоваяСтрока.РазмерЗаписи = РазмерСтроки;
			НоваяСтрока.ВремяВыполнения = ФактическоеВремя;
			НоваяСтрока.ОбработаноЗаписей = КоличествоОбработанныхСтрок;

		КонецЦикла;
		
	ИначеЕсли ХранениеБазыДанных.ТипСУБД = ИТК_Перечисления.СУБДФайловая() Тогда
		
		Показатели = Новый СписокЗначений;
		Показатели.Добавить("RecordsScanned", "ОбработаноЗаписей");
		Показатели.Добавить("ParseTime", "ВремяРазбора");
		Показатели.Добавить("ExecuteTime", "ВремяВыполнения");
		Показатели.Добавить("BuffersMemory", "БуферыПамяти");
		Показатели.Добавить("ResultRecords", "ЗаписейВРезультате");
		Показатели.Добавить("RecordSize", "РазмерЗаписи");
		
		ИскомыйТекст = "Statistics:";
		Индекс = СтрНайти(ПланЗапросаТекст, ИскомыйТекст);
		
		ТекстПлана = Лев(ПланЗапросаТекст, Индекс - 1);
		ТекстПлана = СокрЛП(ТекстПлана);
		
		ОписаниеПланаВТерминах1С = SQLПланЗапросаВТерминах1С(ТекстПлана, ХранениеБазыДанных, ОписаниеЗапросаВТерминах1С);
		
		СтрокаПриемник.План = ТекстПлана;
		СтрокаПриемник.План1С = ОписаниеПланаВТерминах1С.Текст;
		
		Индекс = Индекс + СтрДлина(ИскомыйТекст);
		Для Каждого Показатель Из Показатели Цикл 
			
			ИТК_Строки.РазборПрочитатьНезначимые(ПланЗапросаТекст, Индекс);
			ИТК_Строки.РазборПропуститьНаборСимволов(ПланЗапросаТекст, Показатель.Значение, Индекс);
			ИТК_Строки.РазборПропуститьНаборСимволов(ПланЗапросаТекст, " = ", Индекс);
			СтрокаПриемник[Показатель.Представление] = ИТК_Строки.РазборПрочитатьЦелоеЧисло(ПланЗапросаТекст, Индекс);
			ИТК_Строки.РазборПропуститьНаборСимволов(ПланЗапросаТекст, ",", Индекс);
			
		КонецЦикла;
		
		СтрокаПриемник.ВремяВыполнения = ИТК_ОбщийКлиентСервер.МиллисекВСек(СтрокаПриемник.ВремяВыполнения);
		СтрокаПриемник.ВремяРазбора = ИТК_ОбщийКлиентСервер.МиллисекВСек(СтрокаПриемник.ВремяРазбора);
		
	КонецЕсли;
	
КонецПроцедуры

Функция SQLЗапросВТерминах1С(Текст, ХранениеБазыДанных, ОписанияТиповЗадействованныхПараметров)
	
	НовыйТекст = Текст;
	
	// Заменяем имена таблиц
	ПсевдонимыТаблиц = Новый Соответствие;
	ПредставлениеПараметров = Новый Соответствие;
	
	Если ХранениеБазыДанных.ТипСУБД = ИТК_Перечисления.СУБДФайловая()
		ИЛИ ХранениеБазыДанных.ТипСУБД = ИТК_Перечисления.СУБДPostgreSQL() Тогда
		
		// SELECT
		// T1._IDRRef AS _C_1RRef...
		// FROM _Document17 T1
		// INNER JOIN _Document18 T2 ON 1=1
		SQLЗапросЗаполнениеПсевдонимовТаблиц(ХранениеБазыДанных, ПсевдонимыТаблиц, НовыйТекст, "FROM");
		SQLЗапросЗаполнениеПсевдонимовТаблиц(ХранениеБазыДанных, ПсевдонимыТаблиц, НовыйТекст, "JOIN");

	Иначе
		
		SQLЗапросЗаполнениеПсевдонимовТаблиц(ХранениеБазыДанных, ПсевдонимыТаблиц, НовыйТекст, "FROM", "dbo.");
		SQLЗапросЗаполнениеПсевдонимовТаблиц(ХранениеБазыДанных, ПсевдонимыТаблиц, НовыйТекст, "JOIN", "dbo.");
		
		НовыйТекст = СтрЗаменить(НовыйТекст, СтрШаблон("[%1].[dbo].[Config]", ХранениеБазыДанных.Имя), "[Конфигурация]");
	
	КонецЕсли;
	
	// Заменяем имена полей
	ЗаменаПолейВЗапросеПланеSQL(НовыйТекст, ХранениеБазыДанных, ПсевдонимыТаблиц);
	
	Если ХранениеБазыДанных.ТипСУБД = ИТК_Перечисления.СУБДMicrosoftSQL() 
			ИЛИ ХранениеБазыДанных.ТипСУБД = ИТК_Перечисления.СУБДФайловая() Тогда		
		
		ИскомаяСтрока = "0x";
		Индекс = 1;
		
		Пока Истина Цикл 
			
			Индекс = СтрНайти(НовыйТекст, ИскомаяСтрока, , Индекс);
			
			Если Индекс = 0 Тогда
				Прервать;
			КонецЕсли;
			
			ИндексНачала = Индекс;
			Индекс = Индекс + СтрДлина(ИскомаяСтрока);
			UIDSQL = ИТК_Строки.РазборПрочитатьШестнадцатеричноеЧисло(НовыйТекст, Индекс);
			
			Если UIDSQL <> ИТК_Строки.ПустойUID()
				И СтрДлина(UIDSQL) = 32 Тогда
				
				ОписаниеSQLUIDСсылки = НайтиОписаниеSQLUIDСсылки(UIDSQL, ОписанияТиповЗадействованныхПараметров);
				
				Если ЗначениеЗаполнено(ОписаниеSQLUIDСсылки) Тогда
					
					ПредставлениеПараметров.Вставить(UIDSQL, ОписаниеSQLUIDСсылки); 
					
					НовоеПредставление = СтрШаблон("[%1 (%2)]", ОписаниеSQLUIDСсылки.ПолноеИмяМетаданных,  ОписаниеSQLUIDСсылки.Представление);
					НовыйТекст = Лев(НовыйТекст, ИндексНачала - 1) + НовоеПредставление + Сред(НовыйТекст, Индекс);
					Индекс = ИндексНачала;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Текст", НовыйТекст);
	Результат.Вставить("ПсевдонимыТаблиц", ПсевдонимыТаблиц);
	Результат.Вставить("ПредставлениеПараметров", ПредставлениеПараметров);
	
	Возврат Результат;
	
КонецФункции

Функция SQLПланЗапросаВТерминах1С(Текст, ХранениеБазыДанных, ОписаниеЗапросаВТерминах1С)
	
	НовыйТекст = Текст;
	ИспользуемыеМетаданные = Новый Массив;
	ИспользуемыеМетаданные1C = Новый Массив;
	
	Если ХранениеБазыДанных.ТипСУБД = ИТК_Перечисления.СУБДФайловая() Тогда
		
		Оператор = "";
		// CONST WHERE
		//   TRUE
		// Fields:(
		//    T1._IDRRef..)
		// _DOCUMENT17 (T1) FULL SCAN
		// NESTED LOOP
		// _DOCUMENT18 (T2) FULL SCAN

		ЗаменитьИменаТаблицФайловПланеЗапроса(НовыйТекст, ХранениеБазыДанных, "FULL SCAN");
		ЗаменитьИменаТаблицФайловПланеЗапроса(НовыйТекст, ХранениеБазыДанных, "RANGE SCAN");
		
	Иначе
		
		Оператор = ИТК_Строки.РазборПрочитатьДоСимвола(НовыйТекст, "(");
		
		Пока Истина Цикл 
			
			ИскомыйТекст = СтрШаблон("[%1].[dbo].[", ХранениеБазыДанных.Имя);
			Индекс = СтрНайти(НовыйТекст, ИскомыйТекст);
			
			Если Индекс = 0 Тогда
				Прервать;
			КонецЕсли;
			
			ИндексТаблицы = Индекс + СтрДлина(ИскомыйТекст);
			ИмяТаблицы = ИТК_Строки.РазборПрочитатьИдентификатор(НовыйТекст, ИндексТаблицы);
			ИТК_Строки.РазборПропуститьНаборСимволов(НовыйТекст, "].[", ИндексТаблицы);
			ИмяПоля = ИТК_Строки.РазборПрочитатьИдентификатор(НовыйТекст, ИндексТаблицы);
			ИТК_Строки.РазборПропуститьНаборСимволов(НовыйТекст, "]", ИндексТаблицы);
			
			ИмяТаблицыВ1С = ИмяSQLТаблицыВ1С(ИмяТаблицы, ХранениеБазыДанных);
			ИмяПоляВТерминах1С = ИмяSQLПоляТаблицыВ1С(ИмяПоля, ИмяТаблицы, ХранениеБазыДанных);
			
			НовыйТекст = Лев(НовыйТекст, Индекс - 1) + СтрШаблон("[%1].[%2]", ИмяТаблицыВ1С, ИмяПоляВТерминах1С) + Сред(НовыйТекст, ИндексТаблицы);
			
			Если Оператор <> "Table Insert" Тогда
				
				НовыеИспользуемыеМетаданные = СтрШаблон("%1.%2", ИмяТаблицы, ИмяПоля);
				Если ИспользуемыеМетаданные.Найти(НовыеИспользуемыеМетаданные) = Неопределено Тогда
					ИспользуемыеМетаданные.Добавить(НовыеИспользуемыеМетаданные);
				КонецЕсли;
				
				НовыеИспользуемыеМетаданные1С = СтрШаблон("%1.%2", ИмяТаблицыВ1С, ИмяПоляВТерминах1С);
				Если ИспользуемыеМетаданные1C.Найти(НовыеИспользуемыеМетаданные1С) = Неопределено Тогда
					ИспользуемыеМетаданные1C.Добавить(НовыеИспользуемыеМетаданные1С);
				КонецЕсли;
				
			КонецЕсли;

		КонецЦикла;
		
	КонецЕсли;
	
	// Замена имен полей по псевдонимам
	ЗаменаПолейВЗапросеПланеSQL(НовыйТекст, ХранениеБазыДанных, ОписаниеЗапросаВТерминах1С.ПсевдонимыТаблиц);
	
	// Замена ссылок на параметры
	Для Каждого ПредставлениеПараметра Из ОписаниеЗапросаВТерминах1С.ПредставлениеПараметров Цикл 
		ОписаниеПредставления = ПредставлениеПараметра.Значение;
		НовыйТекст = СтрЗаменить(НовыйТекст, ПредставлениеПараметра.Ключ, ОписаниеПредставления.ПолноеПредставление);
	КонецЦикла;
	
	Результат = Новый Структура;
	Результат.Вставить("Оператор", Оператор);
	Результат.Вставить("Текст", НовыйТекст);
	Результат.Вставить("Метаданные", ИспользуемыеМетаданные);
	Результат.Вставить("Метаданные1C", ИспользуемыеМетаданные1C);
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаполнитьВспомогательныеСтрокиДереваАнализаПланаЗапроса(Строка)
	
	НомерСтроки = 1;
	Для Каждого ВложеннаяСтрока Из Строка.Строки Цикл 
		
		ВложеннаяСтрока.НомерСтроки = НомерСтроки;
		ВложеннаяСтрока.Количество = 1;
		ВложеннаяСтрока.UID = Новый УникальныйИдентификатор;
		ЗаполнитьВспомогательныеСтрокиДереваАнализаПланаЗапроса(ВложеннаяСтрока);
		
		НомерСтроки = НомерСтроки + 1;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ИтогВДереве(Строка, ИмяПоля, Рекурсивно = Истина)
	
	Итого = 0;
	Для Каждого ВложеннаяСтрока Из Строка.Строки Цикл 
		
		Итого = Итого + ВложеннаяСтрока[ИмяПоля];
		Если Рекурсивно Тогда
			Итого = Итого + ИтогВДереве(ВложеннаяСтрока, ИмяПоля, Рекурсивно);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Итого;
	
КонецФункции

Функция ИтогПоСтрокеВДереве(Строка, ИмяПоля, Разделитель = ",")
	
	Строки = Новый Массив;
	Для Каждого ВложеннаяСтрока Из Строка.Строки Цикл 
		
		Строки.Добавить(ВложеннаяСтрока[ИмяПоля]);
		
	КонецЦикла;
	
	Возврат СтрСоединить(Строки, Разделитель);
	
КонецФункции

Процедура РассчитатьПроцентОтОбщегоВДереве(Строка, Общее, ИмяПоля, ИмяПоляПроцентОтОбщего = "ПроцентОтОбщего")
	
	Для Каждого ВложеннаяСтрока Из Строка.Строки Цикл 
		
		Если Общее = 0 Тогда
			Результат = 0;
		Иначе
			Результат = ИТК_ОбщийКлиентСервер.ПроцентОтОбщего(ВложеннаяСтрока[ИмяПоля], Общее);
		КонецЕсли;
		ВложеннаяСтрока[ИмяПоляПроцентОтОбщего] = Результат;
		
		РассчитатьПроцентОтОбщегоВДереве(ВложеннаяСтрока, Общее, ИмяПоля, ИмяПоляПроцентОтОбщего);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура SQLЗапросЗаполнениеПсевдонимовТаблиц(ХранениеБазыДанных, ПсевдонимыТаблиц, Текст, Блок, ДопБлок = "")
	
	БлокПоиска = СтрШаблон("%1 %2", Блок, ДопБлок);
	
	НомерВхождения = 1;
	Пока Истина Цикл 
		
		Индекс = 1;
		Если НЕ ИТК_Строки.РазборНайтиТекст(Текст, БлокПоиска, Индекс, НомерВхождения) Тогда
			Прервать;
		КонецЕсли;
		
		ИндексНачалоИмениТаблицы = Индекс;
		ИмяТаблицы = ИТК_Строки.РазборПрочитатьИдентификатор(Текст, Индекс);
		ИТК_Строки.РазборПрочитатьНезначимые(Текст, Индекс);
		ПсевдонимТаблицы = ИТК_Строки.РазборПрочитатьИдентификатор(Текст, Индекс);
		ИмяТаблицыВ1С = ИмяSQLТаблицыВ1С(ИмяТаблицы, ХранениеБазыДанных);
		
		Текст = Лев(Текст, ИндексНачалоИмениТаблицы - 1 - СтрДлина(ДопБлок)) + ИмяТаблицыВ1С + Сред(Текст, ИндексНачалоИмениТаблицы + СтрДлина(ИмяТаблицы));
		ПсевдонимыТаблиц.Вставить(ПсевдонимТаблицы, ИмяТаблицы);
		
		НомерВхождения = НомерВхождения + 1;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаменитьИменаТаблицФайловПланеЗапроса(Текст, ХранениеБазыДанных, БлокПоиска)
	
	НомерВхождения = 1;
	Пока Истина Цикл 
		
		ИндексБлока = СтрНайти(Текст, БлокПоиска, , , НомерВхождения);
		
		Если ИндексБлока = 0 Тогда
			Прервать;
		КонецЕсли;
		
		Индекс = СтрНайти(Текст, Символы.ПС, НаправлениеПоиска.СКонца, ИндексБлока);
		Индекс = Индекс + 1;
		ИндексНачалоИмениТаблицы = Индекс;
		ИмяТаблицы = ИТК_Строки.РазборПрочитатьИдентификатор(Текст, Индекс);
		ИТК_Строки.РазборПропуститьНаборСимволов(Текст, "(", Индекс);
		
		ИмяТаблицыВ1С = ИмяSQLТаблицыВ1С(ИмяТаблицы, ХранениеБазыДанных);
		Текст = Лев(Текст, ИндексНачалоИмениТаблицы - 1) + ИмяТаблицыВ1С + Сред(Текст, ИндексНачалоИмениТаблицы + СтрДлина(ИмяТаблицы));
		
		НомерВхождения = НомерВхождения + 1;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаменаПолейВЗапросеПланеSQL(Текст, ХранениеБазыДанных, ПсевдонимыТаблиц)
	
	// Заменяем имена полей в запросе
	Для Каждого ПсевдонимТаблицы Из ПсевдонимыТаблиц Цикл 
		
		НомерВхождения = 1;
		Пока Истина Цикл 
			
			Индекс = 1;
			Если НЕ ИТК_Строки.РазборНайтиТекст(Текст, ПсевдонимТаблицы.Ключ + ".", Индекс, НомерВхождения) Тогда
				Прервать;
			КонецЕсли;
			
			ИндексНачалаПоля = Индекс;
			ИмяПоля = ИТК_Строки.РазборПрочитатьИдентификатор(Текст, ИндексНачалаПоля, Ложь);
			
			ИмяПоляВТерминах1С = ИмяSQLПоляТаблицыВ1С(ИмяПоля, ПсевдонимТаблицы.Значение, ХранениеБазыДанных);
			Текст = Лев(Текст, ИндексНачалаПоля - 1) + ИмяПоляВТерминах1С + Сред(Текст, ИндексНачалаПоля + СтрДлина(ИмяПоля));
			
			НомерВхождения = НомерВхождения + 1;
			
		КонецЦикла;

	КонецЦикла;
	
	Если ХранениеБазыДанных.ТипСУБД <> ИТК_Перечисления.СУБДФайловая() Тогда
	
		// Заменяем имена полей по псевдонимам в плане
		Для Каждого ПсевдонимТаблицы Из ПсевдонимыТаблиц Цикл 
			
			НомерВхождения = 1;
			Пока Истина Цикл 
				
				ИскомыйТекст = СтрШаблон("[%1].[", ПсевдонимТаблицы.Ключ);
				Индекс = СтрНайти(Текст, ИскомыйТекст, , , НомерВхождения);
				
				Если Индекс = 0 Тогда
					Прервать;
				КонецЕсли;
				
				ИндексНачалаПоля = Индекс + СтрДлина(ИскомыйТекст);
				ИмяПоля = ИТК_Строки.РазборПрочитатьИдентификатор(Текст, ИндексНачалаПоля, Ложь);
				ИмяПоляВТерминах1С = ИмяSQLПоляТаблицыВ1С(ИмяПоля, ПсевдонимТаблицы.Значение, ХранениеБазыДанных);
				Текст = Лев(Текст, ИндексНачалаПоля - 1) + ИмяПоляВТерминах1С + Сред(Текст, ИндексНачалаПоля + СтрДлина(ИмяПоля));
				
				НомерВхождения = НомерВхождения + 1;
				
			КонецЦикла;

		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Функция НайтиОписаниеSQLUIDСсылки(SQLUID, ОписанияТиповЗадействованныхПараметров)
	
	Для Каждого ОписаниеТиповПараметра Из ОписанияТиповЗадействованныхПараметров Цикл 
		
		Если ТипЗнч(ОписаниеТиповПараметра) <> Тип("ОписаниеТипов") Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого Тип Из ОписаниеТиповПараметра.Типы() Цикл 
			
			ОбъектМетаданных = Метаданные.НайтиПоТипу(Тип);
			
			Если ОбъектМетаданных <> Неопределено Тогда
				
				ПолноеИмяМетаданных = ИТК_Метаданные.ПолноеИмя(ОбъектМетаданных);
				
				ШаблонЗапроса = "ВЫБРАТЬ ""%1"" КАК ПолноеИмяМетаданных, ПРЕДСТАВЛЕНИЕ(Таблица.Ссылка) КАК ПредставлениеСсылки ИЗ %1 КАК Таблица ГДЕ Таблица.Ссылка = &Ссылка";
				Запрос = Новый Запрос(СтрШаблон(ШаблонЗапроса, ПолноеИмяМетаданных));
				Запрос.УстановитьПараметр("Ссылка", ИТК_Общий.СсылкаПоВнутреннемуUID(SQLUID, Тип));
				Результат = Запрос.Выполнить();
				
				Если Не Результат.Пустой() Тогда
					
					Выборка = Результат.Выбрать();
					Выборка.Следующий();
					
					
					Результат = Новый Структура;
					Результат.Вставить("ПолноеИмяМетаданных", Выборка.ПолноеИмяМетаданных);
					Результат.Вставить("Представление", Выборка.ПредставлениеСсылки);
					Результат.Вставить("ПолноеПредставление", СтрШаблон("[%1 (%2)]", Результат.ПолноеИмяМетаданных,  Результат.Представление));

					Возврат Результат;
					
				КонецЕсли;
	
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Неопределено;

КонецФункции

Функция ОписаниеХраненияТаблицы(Имя, ХранениеБазыДанных)
	
	Если ХранениеБазыДанных.ТипСУБД = ИТК_Перечисления.СУБДФайловая() Тогда
		Результат = ХранениеБазыДанных.Структура.Найти(ВРег(Имя), "ИмяТаблицыХранения");
	Иначе
		Результат = ХранениеБазыДанных.Структура.Найти(Имя, "ИмяТаблицыХранения");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИмяSQLТаблицыВ1С(Имя, ХранениеБазыДанных)
	
	ОписаниеХраненияТаблицы = ОписаниеХраненияТаблицы(Имя, ХранениеБазыДанных);
	
	Если ОписаниеХраненияТаблицы = Неопределено Тогда
		Результат = Имя;
	Иначе 
		Результат = ОписаниеХраненияТаблицы.ИмяТаблицы;
		Если ОписаниеХраненияТаблицы.Назначение <> "Основная" Тогда
			Результат = СтрШаблон("%1 (%2)", Результат, ОписаниеХраненияТаблицы.Назначение);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИмяSQLПоляТаблицыВ1С(ИмяПоля, ИмяТаблицы, ХранениеБазыДанных)
	
	ОписаниеХраненияТаблицы = ОписаниеХраненияТаблицы (ИмяТаблицы, ХранениеБазыДанных);
	
	Если ОписаниеХраненияТаблицы = Неопределено Тогда
		
		Результат = ИмяПоля;
		
	Иначе 
		
		ОписаниеХраненияПоля = ОписаниеХраненияТаблицы.Поля.Найти(ИмяПоля, "ИмяПоляХранения");
		Если ОписаниеХраненияПоля = Неопределено Тогда
			
			ОписаниеХраненияИндекс = ОписаниеХраненияТаблицы.Индексы.Найти(ИмяПоля, "ИмяИндексаХранения");
			Если ОписаниеХраненияИндекс = Неопределено Тогда
				Результат = ИмяПоля;
			Иначе 
				Результат = СтрСоединить(ОписаниеХраненияИндекс.Поля.ВыгрузитьКолонку("ИмяПоля"), ", ");
			КонецЕсли;
			
		Иначе 
			
			Если ЗначениеЗаполнено(ОписаниеХраненияПоля.ИмяПоля) Тогда
				Результат = ОписаниеХраненияПоля.ИмяПоля;
			Иначе
				Результат = ИмяПоля;
			КонецЕсли;
			
		КонецЕсли;

	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ТипСУБД(Идентификатор) Экспорт
	
	Результат = Неопределено;
	Если Идентификатор = "DBMSSQL" Тогда
		Результат = ИТК_Перечисления.СУБДMicrosoftSQL();
	ИначеЕсли Идентификатор = "DBPOSTGRS" Тогда
		Результат = ИТК_Перечисления.СУБДPostgreSQL();
	ИначеЕсли Идентификатор = "DBV8DBENG" Тогда
		Результат = ИТК_Перечисления.СУБДФайловая();
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИмяФайлаТехнологическогоЖурнала(КаталогЛогов, Дата)
	
	ИмяБезРасширения = "";
	ИмяБезРасширенияПоСобытию = Формат(Дата, "ДФ=yyMMddHH");
	
	НайденныеФайлы = НайтиФайлы(КаталогЛогов, "*.log");
	Для Каждого НайденныйФайл Из НайденныеФайлы Цикл 
		
		Если НайденныйФайл.ЭтоКаталог() Тогда
			Продолжить;
		КонецЕсли;
			
		Если НайденныйФайл.ИмяБезРасширения <= ИмяБезРасширенияПоСобытию Тогда
			ИмяБезРасширения = Макс(ИмяБезРасширения, НайденныйФайл.ИмяБезРасширения);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ИмяБезРасширения + ".log";
	
КонецФункции

#КонецОбласти
