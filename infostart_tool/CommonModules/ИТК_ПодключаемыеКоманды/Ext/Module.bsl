#Область ПрограммныйИнтерфейс

Процедура ДополнительныеКТаблицеЗначений(Форма, Имя, Редактирование = Истина) Экспорт
	
	Если Редактирование Тогда
		
		ИмяКоманды = ИТК_ПодключаемыеКомандыКлиентСервер.ИмяКомандыЗаполнитьКолонку();
		ЗаголовокКоманды = НСтр("ru = 'Заполнить...'; en = 'Fill...'");
		ПодсказкаКоманды = НСтр("ru = 'Заполнить колонку...'; en = 'Fill in the column...'");
		
		ДобавитьКомандуДополнительноеКТаблицеЗначений(Форма, Имя, ИмяКоманды, ЗаголовокКоманды, ПодсказкаКоманды);
		
	КонецЕсли;

	ИмяКоманды = ИТК_ПодключаемыеКомандыКлиентСервер.ИмяКомандыПерейтиКСтрокеПоНомеру();
	ЗаголовокКоманды = НСтр("ru = 'Перейти к строке по номеру...';
								|en = 'Go to line by number...'");
	КартинкаКоманды = БиблиотекаКартинок.ИТК_НайтиПоНомеру;
		
	ДобавитьКомандуДополнительноеКТаблицеЗначений(Форма, Имя, ИмяКоманды, ЗаголовокКоманды, , КартинкаКоманды);
	
	ИмяКоманды = ИТК_ПодключаемыеКомандыКлиентСервер.ИмяКомандыНайтиКолонку();
	ЗаголовокКоманды = НСтр("ru = 'Найти колонку...';
								|en = 'Find column...'");
	КартинкаКоманды = БиблиотекаКартинок.ИТК_НайтиКолонку;
		
	ДобавитьКомандуДополнительноеКТаблицеЗначений(Форма, Имя, ИмяКоманды, ЗаголовокКоманды, , КартинкаКоманды);
	
КонецПроцедуры

Процедура ИнструментыКТаблицеЗначений(Форма, Имя) Экспорт
	
	Элементы = Форма.Элементы;
	ДобавитьГруппуИнструменты(Форма, Имя, Элементы[Имя].КонтекстноеМеню, Истина, Истина, Истина);
	
КонецПроцедуры

Процедура ИнструментыКПолю(Форма, Имя, РедакторОбъекта = Ложь, ПоискСсылокНаОбъект = Ложь, УниверсальнаяФормаВыбора = Истина) Экспорт
	
	Элементы = Форма.Элементы;
	ДобавитьГруппуИнструменты(Форма, Имя, Элементы[Имя].КонтекстноеМеню, ПоискСсылокНаОбъект, РедакторОбъекта, УниверсальнаяФормаВыбора);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ДобавитьГруппуИнструменты(Форма, Реквизит, Элемент, ПоискСсылокНаОбъект = Ложь, РедакторОбъекта = Ложь, УниверсальнаяФормаВыбора = Ложь)
	
	ИмяДействия = "ПодключаемаяКоманда";
	
	ГруппаИнструменты = ИТК_Форма.ДобавитьЭлемент(Форма, Реквизит + "ГруппаИнструменты", "Группа", , Элемент);  
	
	ОписаниеИнструмента = ИТК_ТуллкитКлиентСервер.ОписаниеИнструмента(ИТК_Перечисления.ИнструментРедакторОбъекта());
	Если РедакторОбъекта 
			И ОписаниеИнструмента["Доступ"] Тогда
		
		ИмяКоманды = Реквизит + "_РедакторОбъекта";
		
		ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяДействия, ОписаниеИнструмента["Представление"]);
		
		Поля = Новый Структура("ИмяКоманды", ИмяКоманды);
		ИТК_Форма.ДобавитьЭлемент(Форма, ИТК_ПодключаемыеКомандыКлиентСервер.РедакторОбъектаИмяЭлемента(Реквизит), "Кнопка", Поля, ГруппаИнструменты);
		
	КонецЕсли;
	
	ОписаниеИнструмента = ИТК_ТуллкитКлиентСервер.ОписаниеИнструмента(ИТК_Перечисления.ИнструментПоискСсылокНаОбъект());
	Если ПоискСсылокНаОбъект
			И ОписаниеИнструмента["Доступ"] Тогда
		
		ИмяКоманды = Реквизит + "_ПоискСсылокНаОбъект";
		ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяДействия, ОписаниеИнструмента["Представление"]);
		
		Поля = Новый Структура("ИмяКоманды", ИмяКоманды);
		ИТК_Форма.ДобавитьЭлемент(Форма, ИТК_ПодключаемыеКомандыКлиентСервер.ПоискСсылокНаОбъектИмяЭлемента(Реквизит), "Кнопка", Поля, ГруппаИнструменты);
		
	КонецЕсли;
	
	ОписаниеИнструмента = ИТК_ТуллкитКлиентСервер.ОписаниеИнструмента(ИТК_Перечисления.ИнструментУниверсальнаяФормаВыбора());
	Если УниверсальнаяФормаВыбора
			И ОписаниеИнструмента["Доступ"] Тогда
		
		ИмяКоманды = Реквизит + "_УниверсальнаяФормаВыбора";
		ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИмяДействия, ОписаниеИнструмента["Представление"]);
		
		Поля = Новый Структура("ИмяКоманды", ИмяКоманды);
		ИТК_Форма.ДобавитьЭлемент(Форма, ИТК_ПодключаемыеКомандыКлиентСервер.УниверсальнаяФормаВыбораИмяЭлемента(Реквизит), "Кнопка", Поля, ГруппаИнструменты);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьКомандуДополнительноеКТаблицеЗначений(Форма, ИмяРодителя, ИмяКоманды, Заголовок, Подсказка = Неопределено, Картинка = Неопределено)
	
	Если Картинка = Неопределено Тогда
		Картинка = Новый Картинка;
	КонецЕсли;
	
	Если Подсказка = Неопределено Тогда
		Подсказка = Заголовок;
	КонецЕсли;

	Элементы = Форма.Элементы;
	ЭлементКоллекция = Элементы[ИмяРодителя];
	ИмяДействияПодключаемойКоманды = "ПодключаемаяКомандаРаботаСТаблицейЗначений";
	
	ПолноеИмяКоманды = ИмяРодителя + "_" + ИмяКоманды;
	ИмяЭлементаКоманды = ИмяРодителя + ИмяКоманды;
	
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("Картинка", Картинка);
	ПараметрыКоманды.Вставить("Подсказка", Подсказка);
	ИТК_Форма.ДобавитьКоманду(Форма, ПолноеИмяКоманды, ИмяДействияПодключаемойКоманды, Заголовок, ПараметрыКоманды);
														
	Поля = Новый Структура("ИмяКоманды", ПолноеИмяКоманды);
	ИТК_Форма.ДобавитьЭлемент(Форма, ИмяЭлементаКоманды + "КонтекстноеМеню", "Кнопка", Поля, ЭлементКоллекция.КонтекстноеМеню);
	ИТК_Форма.ДобавитьЭлемент(Форма, ИмяЭлементаКоманды + "КоманднаяПанель", "Кнопка", Поля, ЭлементКоллекция.КоманднаяПанель);
	
КонецПроцедуры

#КонецОбласти
