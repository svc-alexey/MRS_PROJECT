#Область ПрограммныйИнтерфейс

Функция ДоступныеУзлыПлановОбмена(ПроверяемыеМетаданные = Неопределено) Экспорт
	
	Результат = Новый Массив;
	Для Каждого ПланОбмена Из Метаданные.ПланыОбмена Цикл 
		
		Если НЕ ПравоДоступа("Чтение", ПланОбмена) Тогда
			Продолжить;
		КонецЕсли;
		
		// Получение узлов планов обмена
		СхемаЗапроса = Новый СхемаЗапроса;
		ЗапросПакета = СхемаЗапроса.ПакетЗапросов[0];
		ЗапросПакета.Автопорядок = Истина;
		
		Оператор = ЗапросПакета.Операторы[0];
		Источник = Оператор.Источники.Добавить("ПланОбмена." + ПланОбмена.Имя, "ПланОбмена");
		
		// Поля
		Для Каждого КлючИЗначение Из КонструкторОписанияУзла() Цикл 
			Оператор.ВыбираемыеПоля.Добавить("ПланОбмена." + КлючИЗначение.Ключ);
		КонецЦикла;
		
		Оператор.Отбор.Добавить("НЕ ПланОбмена.ЭтотУзел");
		
		КолонкаСсылка = ЗапросПакета.Колонки.Найти("Ссылка");
		ВыражениеПорядка = ЗапросПакета.Порядок.Добавить(КолонкаСсылка);
		
		Запрос = Новый Запрос;
		Запрос.Текст = СхемаЗапроса.ПолучитьТекстЗапроса();
		
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
			Продолжить;
		КонецЕсли;
		
		Узлы = Новый Массив;
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл 
			
			ОписаниеУзла = КонструкторОписанияУзла();
			ЗаполнитьЗначенияСвойств(ОписаниеУзла, Выборка);
			Узлы.Добавить(ОписаниеУзла);
			
		КонецЦикла;
		
		Если ЗначениеЗаполнено(ПроверяемыеМетаданные) Тогда
			
			ВходитВСостав = Ложь;
			Для Каждого ПроверяемыйОбъектМетаднныхКлючИЗначение Из ПроверяемыеМетаданные Цикл 
				
				Если ПланОбмена.Состав.Найти(ПроверяемыйОбъектМетаднныхКлючИЗначение.Ключ) <> Неопределено Тогда
					
					ВходитВСостав = Истина;
					Прервать;
					
				КонецЕсли;
				
			КонецЦикла;
			
		Иначе
			ВходитВСостав = Истина;
		КонецЕсли;
		
		Если НЕ ВходитВСостав Тогда
			Продолжить;
		КонецЕсли;
		
		ОписаниеПланаОбмена = Новый Структура;
		ОписаниеПланаОбмена.Вставить("Имя", ПланОбмена.Имя);
		ОписаниеПланаОбмена.Вставить("Представление", ПланОбмена.Представление());
		ОписаниеПланаОбмена.Вставить("Узлы", Узлы);
		Результат.Добавить(ОписаниеПланаОбмена);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура ИнициализацияДереваУзловНаФорме(Форма, Поле, ДоступныеУзлы, ВыбранноеЗначение = Неопределено) Экспорт
	
	КартинкаПланаОбмена = БиблиотекаКартинок.ПланОбмена;
	КартинкаУзелОбмена = БиблиотекаКартинок.ИТК_УзелОбмена;
	КартинкаУзелОбменаПомеченныйНаУдаление = БиблиотекаКартинок.ИТК_УзелОбменаПомеченныйНаУдаление;
	
	ДеревоУзлов = Форма[Поле];
	ЭлементДеревоУзлов = Форма.Элементы[Поле];
	Для Каждого ОписаниеПланаОбмена Из ДоступныеУзлы Цикл
		
		НоваяСтрокаПланОбмена = ДеревоУзлов.ПолучитьЭлементы().Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаПланОбмена, ОписаниеПланаОбмена);
		НоваяСтрокаПланОбмена.Картинка = КартинкаПланаОбмена;
		
		Для Каждого ОписаниеУзла Из ОписаниеПланаОбмена.Узлы Цикл 
			
			НоваяСтрокаУзел = НоваяСтрокаПланОбмена.ПолучитьЭлементы().Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаУзел, ОписаниеУзла);
			
			Если ОписаниеУзла.ПометкаУдаления Тогда
				НоваяСтрокаУзел.Картинка = КартинкаУзелОбменаПомеченныйНаУдаление;
			Иначе
				НоваяСтрокаУзел.Картинка = КартинкаУзелОбмена;
			КонецЕсли;
			
			// Активация текущей строки
			Если НоваяСтрокаУзел.Ссылка = ВыбранноеЗначение Тогда 
				ЭлементДеревоУзлов.ТекущаяСтрока = НоваяСтрокаУзел.ПолучитьИдентификатор();
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Функция НомераСообщенийУзлаОбмена(Узел) Экспорт
	
	Возврат ИТК_Общий.ЗначенияРеквизитовОбъекта(Узел, "НомерПринятого, НомерОтправленного");
	
КонецФункции

Процедура УстановитьПараметрыУзлаОбмена(Узел, Параметры) Экспорт
	
	ОбъектУзла = Узел.ПолучитьОбъект();
	ЗаполнитьЗначенияСвойств(ОбъектУзла, Параметры);
	ОбъектУзла.Записать();
	
КонецПроцедуры

Функция ВыполнитьИзменениеРегистрации(Параметры, АдресРезультата = Неопределено) Экспорт
	
	ВидИзменения = Параметры.ВидИзменения;
	ВыбранныеУзлы = Параметры.ВыбранныеУзлы;
	ОбрабатываемыеОбъекты = Параметры.Объекты;
	ПроверятьОграниченияМиграцииДанныхБСП = ИТК_БСПКлиентСервер.ИспользуетсяБСП()
												И Параметры.ПроверятьОграниченияМиграцииДанныхБСП;
	
	ОбработаноОбъектов = 0;
	ВсегоОбъектов = ОбрабатываемыеОбъекты.Количество();
	
	ДатаВремяПрогресса = Неопределено;
	Для Каждого ЭлементОбъект Из ОбрабатываемыеОбъекты Цикл 
		
		Данные = ЭлементОбъект.Значение;
		ДанныеОбъектМетаданных = Данные.Метаданные();
		
		Для Каждого Узел Из ВыбранныеУзлы Цикл
			
			ПланОбменаОбъектМетаданных = Узел.Метаданные();
			Если ПланОбменаОбъектМетаданных.Состав.Найти(ДанныеОбъектМетаданных) = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			Если ВидИзменения = "Зарегистрировать" Тогда
				
				Если ПроверятьОграниченияМиграцииДанныхБСП Тогда
					
					Если НЕ ИТК_БСП.ПройденКонтрольОграниченийВыгрузкиОбъекта(Узел, Данные.ПолучитьОбъект()) Тогда
						Продолжить;
					КонецЕсли;
					
				КонецЕсли;
				
				ПланыОбмена.ЗарегистрироватьИзменения(Узел, Данные);
				
			ИначеЕсли ВидИзменения = "СнятьСРегистрации" Тогда
				ПланыОбмена.УдалитьРегистрациюИзменений(Узел, Данные);
			КонецЕсли;
			
		КонецЦикла;
		
		ОбработаноОбъектов = ОбработаноОбъектов + 1;
		Если ДатаВремяПрогресса <> ТекущаяДатаСеанса() Тогда
			
			Если ВидИзменения = "Зарегистрировать" Тогда
				ВидОперации = НСтр("ru = 'Регистрация объектов'; en = 'Registration of objects'");
			ИначеЕсли ВидИзменения = "СнятьСРегистрации" Тогда
				ВидОперации = НСтр("ru = 'Снятие с регистрации объектов'; en = 'Deregistration of objects'");
			КонецЕсли;
			ШаблонТекстаПрогресса = "%1: %2/%3";
			ТекстПрогресса = СтрШаблон(ШаблонТекстаПрогресса, ВидОперации, ОбработаноОбъектов, ВсегоОбъектов);
			
			ДатаВремяПрогресса = ТекущаяДатаСеанса();
			ПрогрессПроцент = (ОбработаноОбъектов * 100) / ВсегоОбъектов;
			
			ИТК_ДлительныеОперации.СообщитьПрогресс(ТекстПрогресса, ПрогрессПроцент);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Результат = Неопределено;
	ПоместитьВоВременноеХранилище(Результат, АдресРезультата);
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция КонструкторОписанияУзла()
	
	ОписаниеУзла = Новый Структура;
	ОписаниеУзла.Вставить("Ссылка");
	ОписаниеУзла.Вставить("Код");
	ОписаниеУзла.Вставить("Представление");
	ОписаниеУзла.Вставить("ПометкаУдаления");
	
	Возврат ОписаниеУзла;
	
	
КонецФункции

#КонецОбласти