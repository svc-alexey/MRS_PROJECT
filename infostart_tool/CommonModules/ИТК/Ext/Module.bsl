#Область ПрограммныйИнтерфейс

// Сохраняет объект отладки в хранилище настроек
//
// Параметры:
//  Объект  - Запрос, СхемаКомпоновкиДанных, ПостроительЗапроса, ПостроительОтчета, ДинамическийСписок, МакетКомпоновкиДанных - Объект
//  Имя  - Строка - Имя настройки (необязательный)
//  Параметр1  - НастройкиКомпоновкиДанных - Настройки СКД (необязательный)
//  Параметр2  - Структура - Внешние наборы данных (необязательный)
//
// Возвращаемое значение:
//   Строка - "Сохранено успешно", в случае ошибки текст ошибки
//
Функция Отл(Объект, Имя = Неопределено, Параметр1 = Неопределено, Параметр2 = Неопределено, Параметр3 = Неопределено) Экспорт
	Возврат СохранитьДанныеОтладки(Объект, ИТК_Перечисления.ТипХраненияДанныхНастройка(), Имя, Параметр1, Параметр2, Параметр3);
КонецФункции

// Добавляет объект отладки в хранилище настроек (аналогична Отл)
//
Функция ДобавитьОтл(Объект, Имя = Неопределено, Параметр1 = Неопределено, Параметр2 = Неопределено, Параметр3 = Неопределено) Экспорт
	Возврат СохранитьДанныеОтладки(Объект, ИТК_Перечисления.ТипХраненияДанныхНастройка(), Имя, Параметр1, Параметр2, Параметр3, , Истина);
КонецФункции

// Сохраняет объект отладки в файл
//
// Параметры:
//  Объект  - Запрос, СхемаКомпоновкиДанных, ПостроительЗапроса, ПостроительОтчета, ДинамическийСписок, МакетКомпоновкиДанных - Объект
//  Путь  - Строка - Путь сохранения файла
//  Имя  - Строка - Имя файла (необязательный)
//  Параметр1  - НастройкиКомпоновкиДанных - Настройки СКД (необязательный)
//  Параметр2  - Структура - Внешние наборы данных (необязательный)
//
// Возвращаемое значение:
//   Строка - "Сохранено успешно", в случае ошибки текст ошибки
//
Функция ОтлВФайл(Объект, Путь, Имя = Неопределено, Параметр1 = Неопределено, Параметр2 = Неопределено, Параметр3 = Неопределено) Экспорт
	Возврат СохранитьДанныеОтладки(Объект, ИТК_Перечисления.ТипХраненияДанныхФайл(), Имя, Параметр1, Параметр2, Параметр3, Путь);
КонецФункции

// Добавляет объект отладки в файл (аналогична ОтлВФайл)
//
Функция ДобавитьОтлВФайл(Объект, Путь, Имя = Неопределено, Параметр1 = Неопределено, Параметр2 = Неопределено, Параметр3 = Неопределено) Экспорт
	Возврат СохранитьДанныеОтладки(Объект, ИТК_Перечисления.ТипХраненияДанныхФайл(), Имя, Параметр1, Параметр2, Параметр3, Путь, Истина);
КонецФункции

// Собирает временные таблицы в структуру для удобства просмотра
//
// Параметры:
//  Объект  - Запрос, МенеджерВременныхТаблиц - Объект
//  ВключатьПустые  - Булево - Включать пустые
//
// Возвращаемое значение:
//   Структура, Строка - Данные временных таблиц, строка в случае ошибки
//
Функция МВТ(Объект, ВключатьПустые = Истина) Экспорт
	
	Если Тип(Объект) = Тип("Запрос") Тогда
		МенеджерВременныхТаблиц = Объект.МенеджерВременныхТаблиц;
	ИначеЕсли Тип(Объект) = Тип("МенеджерВременныхТаблиц") Тогда
		МенеджерВременныхТаблиц = Объект;
	Иначе
		МенеджерВременныхТаблиц = Неопределено;
	КонецЕсли;
	
	Если МенеджерВременныхТаблиц = Неопределено Тогда
		
		Результат = НСтр("ru = 'Недопустимый тип объекта, принимаются Запрос или МенеджерВременныхТаблиц';
						|en = 'Invalid object type, Query or TempTablesManager accepted'");
		
	Иначе
		
		Результат = ИТК_Отладка.ПредставлениеМенеджераВременныхТаблиц(МенеджерВременныхТаблиц, ВключатьПустые);
	
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СохранитьДанныеОтладки(Объект, ТипХранения, Имя, Параметр1, Параметр2, Параметр3, Путь = Неопределено, Объединение = Ложь)
	
	ДополнительныеПараметры = Новый Структура;
	
	Если ЗначениеЗаполнено(Путь) Тогда
		ДополнительныеПараметры.Вставить("Путь", Путь);
	КонецЕсли;
	
	ДополнительныеПараметры.Вставить("Объединение", Объединение);
	
	Если ТипЗнч(Объект) = Тип("СхемаКомпоновкиДанных") Тогда
		
		ТипОбъекта = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных();
		
		ДополнительныеПараметры.Вставить("Настройки", Параметр1);
		ДополнительныеПараметры.Вставить("ВнешниеНаборыДанных", Параметр2);
		ДополнительныеПараметры.Вставить("МенеджерВременныхТаблиц", Параметр3);
		
	Иначе
		ТипОбъекта = ИТК_Перечисления.ЭлементДанныхЗапрос();
	КонецЕсли;
	
	Если Имя = Неопределено Тогда
		Имя = ИТК_ОтладкаКлиентСервер.ИмяДанныхПоУмолчанию(ТипОбъекта);
	КонецЕсли;
	ДополнительныеПараметры.Вставить("Имя", Имя);
	
	Возврат ИТК_Отладка.СохранитьДанные(Объект, ТипОбъекта, ТипХранения, ДополнительныеПараметры);
	
КонецФункции

#КонецОбласти
