КонецФункции

Функция ОписаниеИнструмента(Инструмент) Экспорт
	
	ОписанияИнструментов = ИТК_ТуллкитКлиентСерверПовтИсп.СоответствиеОписаниеИнструментов();

	Результат = ОписанияИнструментов.Получить(Инструмент);
	Если Результат = Неопределено Тогда
		ВызватьИсключение "Не задано описание инструмента: " + Инструмент;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПредставлениеИнструмента(Инструмент) Экспорт
	
	ОписаниеИнструмента = ОписаниеИнструмента(Инструмент);
	Если ОписаниеИнструмента = Неопределено Тогда
		ВызватьИсключение "Не задано описание инструмента: " + Инструмент;
	КонецЕсли;
	
	Возврат ОписаниеИнструмента["Представление"];
	
КонецФункции

Функция КартинкаИнструмента(Инструмент) Экспорт
	
	ОписаниеИнструмента = ОписаниеИнструмента(Инструмент);
	Если ОписаниеИнструмента = Неопределено Тогда
		ВызватьИсключение "Не задано описание инструмента: " + Инструмент;
	КонецЕсли;
	
	Возврат ОписаниеИнструмента["Картинка"];
	
КонецФункции

Функция ДоступенИнструмент(Инструмент) Экспорт
	
	ОписаниеИнструмента = ОписаниеИнструмента(Инструмент);
	Если ОписаниеИнструмента = Неопределено Тогда
		ВызватьИсключение "Не задано описание инструмента: " + Инструмент;
	КонецЕсли;
	
	Возврат ОписаниеИнструмента["Доступ"];
	
КонецФункции

Функция ПараметрИнструментаИзПолногоИмени(Инструмент, ПолноеИмя) Экспорт
	
	Если Инструмент = ИТК_Перечисления.ИнструментРедакторКонстант()
			ИЛИ Инструмент = ИТК_Перечисления.ИнструментРедакторПараметровСеанса()
			ИЛИ Инструмент = ИТК_Перечисления.ИнструментРегламентныеИФоновыеЗадания() Тогда
		
		ЧастиИмени = СтрРазделить(ПолноеИмя, ".");
		Результат = ЧастиИмени[1];
		
	Иначе
		Результат = ПолноеИмя;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

