#Область ПрограммныйИнтерфейс

Процедура ЗаполнитьТипВыбранного(Форма, Имя) Экспорт
	
	Объект = Форма[Имя];
	Типы = Новый Массив;
	
	Если ИТК_ФормаКлиентСервер.ВыбранТипОбъекта(Объект) Тогда
		
		ТипОбъекта = ИТК_Метаданные.ПолноеИмя(Объект.Метаданные());
		Типы.Добавить(ТипЗнч(Объект));
		
	Иначе
		
		Типы.Добавить(Тип("Неопределено"));
		Типы.Добавить(Тип("Строка"));
		ТипОбъекта = НСтр("ru = 'Объект';
							|en = 'Object'");
		
	КонецЕсли;
	
	Форма["ТипВыбранногоОбъекта"] = ТипОбъекта;
	Форма.Элементы[Имя].ОграничениеТипа = Новый ОписаниеТипов(Типы);
	
КонецПроцедуры

Процедура ДобавитьВИсториюВыбранных(Ссылка, ВидИнструмента) Экспорт
	
	Если Ссылка = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Загружаем настройки
	Настройки = ИТК_Настройки.Загрузить(ВидИнструмента);
    ИсторияВыбранных = Настройки["ИсторияВыбранных"];
	
	ТипЗначения = ТипЗнч(Ссылка);
	ПустаяСсылка = Новый (ТипЗначения);
	НайденныеМетаданные = Метаданные.НайтиПоТипу(ТипЗначения);

	Представление = СтрШаблон("%1 (%2)", ТипЗначения, НайденныеМетаданные.Имя); 
	Картинка = ИТК_Типы.Картинка(ТипЗначения);
	
	НайденныйЭлемент = ИсторияВыбранных.НайтиПоЗначению(ПустаяСсылка);
	Если НайденныйЭлемент = Неопределено Тогда

		ИсторияВыбранных.Вставить(0, ПустаяСсылка, Представление, , Картинка);
		
	Иначе
		
		ИсторияВыбранных.Сдвинуть(НайденныйЭлемент, -ИсторияВыбранных.Индекс(НайденныйЭлемент));		
		НайденныйЭлемент.Представление = Представление;
		НайденныйЭлемент.Картинка = Картинка;
	
	КонецЕсли;
	
	// Удалим лишние элементы
	МаксимальноеКоличество = 15;
	УдаляемыеЭлементы = Новый Массив;
	
	Номер = 1;
	Для Номер = 1 По  ИсторияВыбранных.Количество() Цикл 
		
		Если Номер <= МаксимальноеКоличество Тогда
			Продолжить;
		КонецЕсли;
		
		Элемент = ИсторияВыбранных[Номер - 1];
		УдаляемыеЭлементы.Добавить(Элемент);
		
	КонецЦикла;
	
	Для Каждого УдаляемыйЭлемент Из УдаляемыеЭлементы Цикл 
		ИсторияВыбранных.Удалить(УдаляемыйЭлемент);
	КонецЦикла;
	
	// Сохраняем настройки
	ИТК_Настройки.Сохранить(Настройки, ВидИнструмента);
	
КонецПроцедуры

Процедура ОбновитьСписокИсторииВыбранных(Элемент, ВидИнструмента) Экспорт
	
	СписокВыбора = Элемент.СписокВыбора;
	СписокВыбора.Очистить();
	
	Настройки = ИТК_Настройки.Загрузить(ВидИнструмента);
	Для Каждого ЭлементИстории Из Настройки["ИсторияВыбранных"] Цикл 
		
		СписокВыбора.Добавить(ЭлементИстории.Значение, ЭлементИстории.Представление, , ЭлементИстории.Картинка);
		
	КонецЦикла;
	
КонецПроцедуры

Функция ЭтоГруппа(ИзменяемыйОбъект, ОбъектСИерархиейГрупп, БитаяСсылка = Ложь) Экспорт
	
	Если ОбъектСИерархиейГрупп Тогда
		
		Если БитаяСсылка Тогда
			
			Результат = Неопределено;
			
		Иначе
			
			Поле = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("ЭтоГруппа");
			Результат = ИТК_Общий.ЗначениеРеквизитаОбъекта(ИзменяемыйОбъект, Поле);
			
		КонецЕсли;
		
	Иначе 
		
		Результат = Ложь;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПрочитатьСтруктуруИДанные(Объект, ДополнительныеПараметры = Неопределено) Экспорт
	
	ПрочитатьДанныеКоллекций = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "ПрочитатьДанныеКоллекций", Истина);
	ВключатьСлужебныеПоля = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "ВключатьСлужебныеПоля", Ложь);
	
	ОбъектМетаданных = Объект.Метаданные();
	ИмяКоллекции = ИТК_Метаданные.ИмяКоллекции(ОбъектМетаданных);
	
	ОбъектСИерархиейГрупп = ИТК_Метаданные.ОбъектСИерархиейГрупп(ОбъектМетаданных);
	БитаяСсылка = ИТК_Общий.БитаяСсылка(Объект);
	ЭтоГруппа = ЭтоГруппа(Объект, ОбъектСИерархиейГрупп, БитаяСсылка);
	
	ЗаполненОбъект = ЗначениеЗаполнено(Объект);
	Если ЗаполненОбъект Тогда
		УникальныйИдентификаторОбъекта = Объект.УникальныйИдентификатор();
	Иначе
		УникальныйИдентификаторОбъекта = Неопределено;
	КонецЕсли;
	
	ОбъектЗаполнения = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "ОбъектЗаполнения");
	ЗаполнениеПоОбъекту = (ОбъектЗаполнения <> Неопределено);
	Если ЗаполненОбъект И НЕ БитаяСсылка Тогда
		ОбъектЗаполнения = Объект.ПолучитьОбъект();
	Иначе 
		
		Если НЕ ЗаполнениеПоОбъекту Тогда
			ОбъектЗаполнения = НовыйОбъект(ТипЗнч(Объект));
		КонецЕсли;
		
	КонецЕсли;
	
	ЭтоЗадача = ИТК_Метаданные.ЭтоЗадача(ОбъектМетаданных);
	ЭтоДокумент = ИТК_Метаданные.ЭтоДокумент(ОбъектМетаданных);
	ЭтоСправочник = ИТК_Метаданные.ЭтоСправочник(ОбъектМетаданных);
	ЭтоБизнесПроцесс = ИТК_Метаданные.ЭтоБизнесПроцесс(ОбъектМетаданных);
	ЭтоПланВидовХарактеристик = ИТК_Метаданные.ЭтоПланВидовХарактеристик(ОбъектМетаданных);
	ЭтоПланСчетов = ИТК_Метаданные.ЭтоПланСчетов(ОбъектМетаданных);
	
	// Реквизиты
	Реквизиты = Новый ТаблицаЗначений;
	Реквизиты.Колонки.Добавить("Имя", ИТК_ТипыКлиентСервер.ОписаниеИмяМетаданных());
	Реквизиты.Колонки.Добавить("Синоним", ИТК_ТипыКлиентСервер.ОписаниеСинонимМетаданных());
	Реквизиты.Колонки.Добавить("Подсказка", ИТК_ТипыКлиентСервер.ОписаниеПодсказкаМетаданных());
	Реквизиты.Колонки.Добавить("Картинка", ИТК_ТипыКлиентСервер.ОписаниеКартинка());
	Реквизиты.Колонки.Добавить("Порядок", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10));
	Реквизиты.Колонки.Добавить("Изменять", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	Реквизиты.Колонки.Добавить("Доступность", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	Реквизиты.Колонки.Добавить("Заблокирован", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	Реквизиты.Колонки.Добавить("АвтоПоле", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	Реквизиты.Колонки.Добавить("Использование", ИТК_ТипыКлиентСервер.ОписаниеКартинка());
	Реквизиты.Колонки.Добавить("Свойство");
	Реквизиты.Колонки.Добавить("Тип");
	Реквизиты.Колонки.Добавить("Значение");
	
	КартинкаСтандартныйРеквизит = БиблиотекаКартинок.ИТК_МетаданныеСтандартныйРеквизит;
	ЗаблокированныеРеквизиты = ИТК_БСП.ЗапрешенныеКРедактированиюРеквизитыОбъекта(ОбъектМетаданных.ПолноеИмя());
	
	Для Каждого Реквизит Из ОбъектМетаданных.СтандартныеРеквизиты Цикл 
		
		ИмяРеквизита = Реквизит.Имя;
		Если НЕ ИспользуетсяСтандартныйРеквизит(ИмяРеквизита, ЭтоГруппа, ЭтоПланВидовХарактеристик) Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = Реквизиты.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Реквизит);
		
		Доступность = НЕ (ИмяРеквизита = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Предопределенный")
						ИЛИ (ИмяРеквизита = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("ЭтоГруппа")
								И ОбъектСИерархиейГрупп
								И ЭтоГруппа <> Неопределено));
		НоваяСтрока.Доступность = Доступность;
		
		НоваяСтрока.Заблокирован = РеквизитЗаблокирован(ЗаблокированныеРеквизиты, Реквизит, БитаяСсылка);
		
		НоваяСтрока.Картинка = КартинкаСтандартныйРеквизит;
		НоваяСтрока.Использование = КартинкаИспользованияПоля();
		НоваяСтрока.Синоним = Реквизит.Представление();
		НоваяСтрока.Изменять = ИзменятьОбластьОбъекта(Объект, "Реквизит", ИмяРеквизита, БитаяСсылка, ЗаполнениеПоОбъекту);
		НоваяСтрока.Значение = ОбъектЗаполнения[ИмяРеквизита];
		
		Если НЕ ЗаполненОбъект Тогда
			
			НоваяСтрока.АвтоПоле = (ИмяРеквизита = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Код")
										И (ЭтоСправочник
											ИЛИ ЭтоПланВидовХарактеристик))
									ИЛИ (ИмяРеквизита = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Номер")
										И (ЭтоДокумент
											ИЛИ ЭтоБизнесПроцесс
											ИЛИ ЭтоЗадача));
			
		КонецЕсли;
		
	КонецЦикла;
	
	// Подготовка реквизитов объекта
	КартинкаРеквизит = БиблиотекаКартинок.Реквизит;
	
	РеквизитыОбъекта = Новый СписокЗначений;
	Для Каждого Реквизит Из ОбъектМетаданных.Реквизиты Цикл 
		РеквизитыОбъекта.Добавить(Реквизит, , , КартинкаРеквизит);
	КонецЦикла;
	
	Если ЭтоЗадача Тогда
		
		КартинкаРеквизитАдресации = БиблиотекаКартинок.ИТК_МетаданныеРеквизитАдресации;
		Для Каждого Реквизит Из ОбъектМетаданных.РеквизитыАдресации Цикл 
			
			РеквизитыОбъекта.Добавить(Реквизит, , , КартинкаРеквизитАдресации);
			
		КонецЦикла;
		
	КонецЕсли;
	
	// Признаки учета
	Если ЭтоПланСчетов Тогда 
		
		КартинкаПризнакаУчета = БиблиотекаКартинок.ИТК_МетаданныеПризнакУчета;
		Для Каждого ПризнакУчета Из ОбъектМетаданных.ПризнакиУчета Цикл 
			РеквизитыОбъекта.Добавить(ПризнакУчета, , , КартинкаПризнакаУчета);
		КонецЦикла;
		
	КонецЕсли;
	
	КартинкаОбщийРеквизит = БиблиотекаКартинок.ИТК_МетаданныеОбщийРеквизит;
	Для Каждого ОбщийРеквизит Из Метаданные.ОбщиеРеквизиты Цикл 
		
		Если НЕ ИТК_Метаданные.ОбщийРеквизитИспользуетсяВОбъекте(ОбщийРеквизит, ОбъектМетаданных) Тогда
			Продолжить;
		КонецЕсли;
		
		РеквизитыОбъекта.Добавить(ОбщийРеквизит, , , КартинкаОбщийРеквизит);
		
	КонецЦикла;
	
	Для Каждого ЭлементРеквизит Из РеквизитыОбъекта Цикл 
		
		Реквизит = ЭлементРеквизит.Значение;
		Картинка = ЭлементРеквизит.Картинка;
		
		Использование = Неопределено;
		Если ОбъектСИерархиейГрупп Тогда
			
			Использование = ИТК_Метаданные.ИспользованиеПоляОбъекта(Реквизит);
			Если ИспользуетсяРеквизит(Использование, ЭтоГруппа) = Ложь Тогда
				Продолжить;
			КонецЕсли;
			
		КонецЕсли;
		
		НоваяСтрока = Реквизиты.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Реквизит);
		НоваяСтрока.Картинка = Картинка;
		НоваяСтрока.Порядок = 1;
		НоваяСтрока.Изменять = ИзменятьОбластьОбъекта(Объект, "Реквизит", Реквизит.Имя, БитаяСсылка, ЗаполнениеПоОбъекту);
		НоваяСтрока.Доступность = Истина;
		НоваяСтрока.Значение = ОбъектЗаполнения[Реквизит.Имя];
		
		Если ОбъектСИерархиейГрупп Тогда
			НоваяСтрока.Использование = КартинкаИспользованияПоля(Использование);
		КонецЕсли;
		
		НоваяСтрока.Заблокирован = РеквизитЗаблокирован(ЗаблокированныеРеквизиты, Реквизит, БитаяСсылка);
		
	КонецЦикла;
	
	ДобавитьДополнительныеРеквизитыИСведения(Реквизиты, Объект, ОбъектЗаполнения, ЗаполнениеПоОбъекту);
	
	Реквизиты.Сортировать("Порядок, Имя");
	
	Если ВключатьСлужебныеПоля Тогда
		
		// Вставляем Уникальный идентификатор ссылки
		НоваяСтрока = Реквизиты.Вставить(0);
		НоваяСтрока.Имя = ИмяУникальногоИдентификаторСсылки();
		НоваяСтрока.Синоним = НСтр("ru = 'Уникальный идентификатор';
									|en = 'Unique identificator'");
		НоваяСтрока.Изменять = БитаяСсылка;
		НоваяСтрока.Тип = Новый ОписаниеТипов("УникальныйИдентификатор");
		НоваяСтрока.Значение = УникальныйИдентификаторОбъекта;
		НоваяСтрока.Картинка = КартинкаСтандартныйРеквизит;
		НоваяСтрока.Доступность = НЕ ЗаполненОбъект;
		НоваяСтрока.АвтоПоле = Истина;
		
	КонецЕсли;
	
	// Табличные части
	ВсеТабличныеЧасти = Новый Массив;
	Для Каждого ТабличнаяЧасть Из ОбъектМетаданных.ТабличныеЧасти Цикл 
		ВсеТабличныеЧасти.Добавить(ТабличнаяЧасть);
	КонецЦикла;
	
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ИмеетСтандартныеТабличныеЧасти(ИмяКоллекции) Тогда
		
		Для Каждого ТабличнаяЧасть Из ОбъектМетаданных.СтандартныеТабличныеЧасти Цикл 
			ВсеТабличныеЧасти.Добавить(ТабличнаяЧасть);
		КонецЦикла;
	
	КонецЕсли;
	
	ТабличныеЧасти = Новый ТаблицаЗначений;
	ТабличныеЧасти.Колонки.Добавить("Использование", ИТК_ТипыКлиентСервер.ОписаниеКартинка());
	ТабличныеЧасти.Колонки.Добавить("Имя", ИТК_ТипыКлиентСервер.ОписаниеИмяМетаданных());
	ТабличныеЧасти.Колонки.Добавить("Синоним", ИТК_ТипыКлиентСервер.ОписаниеСинонимМетаданных());
	ТабличныеЧасти.Колонки.Добавить("Картинка", ИТК_ТипыКлиентСервер.ОписаниеКартинка());
	ТабличныеЧасти.Колонки.Добавить("Изменять", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	ТабличныеЧасти.Колонки.Добавить("КоличествоСтрок", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10));
	ТабличныеЧасти.Колонки.Добавить("Значение");
	
	Для Каждого ТабличнаяЧасть Из ВсеТабличныеЧасти Цикл 
		
		Использование = Неопределено;
		Если ОбъектСИерархиейГрупп  Тогда
			
			Использование = ИТК_Метаданные.ИспользованиеПоляОбъекта(ТабличнаяЧасть);
			Если ИспользуетсяРеквизит(Использование, ЭтоГруппа) = Ложь Тогда
				Продолжить;
			КонецЕсли;
			
		КонецЕсли;
		
		НоваяСтрока = ТабличныеЧасти.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТабличнаяЧасть);
		НоваяСтрока.Картинка = ИТК_ОбщийПовтИсп.КартинкаБиблиотеки("ВложеннаяТаблица");
		НоваяСтрока.Изменять = ИзменятьОбластьОбъекта(Объект, "ТабличнаяЧасть", ТабличнаяЧасть.Имя, БитаяСсылка, ЗаполнениеПоОбъекту);
		
		Если ОбъектСИерархиейГрупп Тогда
			НоваяСтрока.Использование = КартинкаИспользованияПоля(Использование);
		КонецЕсли;
		
		ЗначениеТабличнаяЧасть = ОбъектЗаполнения[ТабличнаяЧасть.Имя];
		Если ПрочитатьДанныеКоллекций 
				ИЛИ ЗаполнениеПоОбъекту Тогда
			
			ЗначениеТаблицаЗначений = ВыгрузитьТабличнуюЧастьВТаблицуЗначений(ЗначениеТабличнаяЧасть);
			НоваяСтрока.Значение = ЗначениеТаблицаЗначений;
			
		КонецЕсли;
		НоваяСтрока.КоличествоСтрок = ЗначениеТабличнаяЧасть.Количество();
		
	КонецЦикла;

	ТабличныеЧасти.Сортировать("Имя");
	
	// Движения
	Движения = Новый ТаблицаЗначений;
	Движения.Колонки.Добавить("Имя", ИТК_ТипыКлиентСервер.ОписаниеИмяМетаданных());
	Движения.Колонки.Добавить("ПолноеИмя", ИТК_ТипыКлиентСервер.ОписаниеСтрока(120));
	Движения.Колонки.Добавить("Синоним", ИТК_ТипыКлиентСервер.ОписаниеСинонимМетаданных());
	Движения.Колонки.Добавить("Картинка", ИТК_ТипыКлиентСервер.ОписаниеКартинка());
	Движения.Колонки.Добавить("Изменять", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	Движения.Колонки.Добавить("КоличествоСтрок", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10));
	Движения.Колонки.Добавить("Значение");
	
	Если ЭтоДокумент Тогда
		
		Для Каждого ЭлементДвижения Из ОбъектМетаданных.Движения Цикл 
			
			ОбъектМетаданныхДвиженияПолноеИмя = ЭлементДвижения.ПолноеИмя();
			
			НоваяСтрока = Движения.Добавить();
			НоваяСтрока.Изменять = ИзменятьОбластьОбъекта(Объект, "Движение", ЭлементДвижения.Имя, БитаяСсылка, ЗаполнениеПоОбъекту);
			НоваяСтрока.Имя = ЭлементДвижения.Имя;
			НоваяСтрока.ПолноеИмя = ОбъектМетаданныхДвиженияПолноеИмя;
			НоваяСтрока.Синоним = ЭлементДвижения.Синоним;
			
			ИмяТипаРегистра = ИТК_Метаданные.ИмяОбъектаКоллекции(ОбъектМетаданныхДвиженияПолноеИмя);
			НоваяСтрока.Картинка = ИТК_ОбщийПовтИсп.КартинкаБиблиотеки(ИмяТипаРегистра);
			
			Если ПрочитатьДанныеКоллекций Тогда
				
				ЗначениеДвижения = ОбъектЗаполнения.Движения[ЭлементДвижения.Имя];
				ЗначениеДвижения.Прочитать();
				
				ЗначениеТаблицаДвижений = ВыгрузитьДвиженияВТаблицуЗначений(ЗначениеДвижения);
				НоваяСтрока.Значение = ЗначениеТаблицаДвижений;
				
				КоличествоСтрок = ЗначениеДвижения.Количество();
				
			Иначе
				КоличествоСтрок = ИТК_РедакторОбъекта.КоличествоЗаписейВДвижениях(ОбъектМетаданныхДвиженияПолноеИмя, ОбъектЗаполнения.Ссылка);
			КонецЕсли;
			
			НоваяСтрока.КоличествоСтрок = КоличествоСтрок;
			
		КонецЦикла;
		
	КонецЕсли;
	Движения.Сортировать("Имя");
	
	Результат = Новый Структура;
	Результат.Вставить("БитаяСсылка", БитаяСсылка);
	Результат.Вставить("Реквизиты", Реквизиты);
	Результат.Вставить("ТабличныеЧасти", ТабличныеЧасти);
	Результат.Вставить("Движения", Движения);
	Возврат Результат;
	
КонецФункции

Функция НовыйОбъект(Тип, ЭтоГруппа = Ложь) Экспорт
	
	ОбъектМетаданных = Метаданные.НайтиПоТипу(Тип);
	ПолноеИмяОбъектаМетаданных = ОбъектМетаданных.ПолноеИмя();
	
	ОбъектМенеджер = ИТК_Метаданные.МенеджерОбъектаПоПолномуИмени(ПолноеИмяОбъектаМетаданных);
	Если ИТК_Метаданные.ЭтоДокумент(ПолноеИмяОбъектаМетаданных) Тогда
		
		НовыйОбъект = ОбъектМенеджер.СоздатьДокумент();
		
	ИначеЕсли ИТК_Метаданные.ЭтоБизнесПроцесс(ПолноеИмяОбъектаМетаданных) Тогда
		
		НовыйОбъект = ОбъектМенеджер.СоздатьБизнесПроцесс();
		
	ИначеЕсли ИТК_Метаданные.ЭтоЗадача(ПолноеИмяОбъектаМетаданных) Тогда
		
		НовыйОбъект = ОбъектМенеджер.СоздатьЗадачу();
		
	ИначеЕсли ИТК_Метаданные.ЭтоПланСчетов(ПолноеИмяОбъектаМетаданных) Тогда
		
		НовыйОбъект = ОбъектМенеджер.СоздатьСчет();
		
	ИначеЕсли ИТК_Метаданные.ЭтоПланОбмена(ПолноеИмяОбъектаМетаданных) Тогда
		
		НовыйОбъект = ОбъектМенеджер.СоздатьУзел();
		
	ИначеЕсли ИТК_Метаданные.ЭтоПланВидовРасчета(ПолноеИмяОбъектаМетаданных) Тогда
		
		НовыйОбъект = ОбъектМенеджер.СоздатьВидРасчета();
		
	Иначе
		
		Если ЭтоГруппа Тогда
			НовыйОбъект = ОбъектМенеджер.СоздатьГруппу();
		Иначе
			НовыйОбъект = ОбъектМенеджер.СоздатьЭлемент();
		КонецЕсли;
		
	КонецЕсли;
	
	НовыйОбъект.Заполнить(Неопределено);
	
	Возврат НовыйОбъект;
	
КонецФункции

Функция ИмяУникальногоИдентификаторСсылки() Экспорт
	
	Возврат НСтр("ru = 'UID';
				|en = 'UID'");
	
КонецФункции

Функция ВыгрузитьТабличнуюЧастьВТаблицуЗначений(ТабличнаяЧасть) Экспорт
	
	УдаляемыеКолонки = "НомерСтроки,ИсходныйНомерСтроки";
	Если ИТК_ОбщийПовтИсп.ВариантВстроенногоЯзыкаАнглийский() Тогда
		УдаляемыеКолонки = "LineNumber,SourceLineNumber";
	КонецЕсли;
	
	Возврат ВыгрузитьОбъектВТаблицуЗначений(ТабличнаяЧасть, УдаляемыеКолонки);
	
КонецФункции

Функция ВыгрузитьДвиженияВТаблицуЗначений(Движения) Экспорт
	
	УдаляемыеКолонки = "НомерСтроки,Регистратор";
	Если ИТК_ОбщийПовтИсп.ВариантВстроенногоЯзыкаАнглийский() Тогда
		УдаляемыеКолонки = "LineNumber,Recorder";
	КонецЕсли;
	
	Возврат ВыгрузитьОбъектВТаблицуЗначений(Движения, УдаляемыеКолонки);
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ИспользуетсяСтандартныйРеквизит(Имя, ЭтоГруппа, ЭтоПланВидовХарактеристик)
	
	Если Имя = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Ссылка")
			ИЛИ (ЭтоПланВидовХарактеристик
					И Имя = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("ТипЗначения")
					И ЭтоГруппа = Истина) Тогда
					
		Возврат Ложь;
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция ИспользуетсяРеквизит(Использование, ЭтоГруппа)
	
	Если ЭтоГруппа = Неопределено Тогда
		
		Результат = Истина;
		
	Иначе 
		
		ИспользованиеРеквизита = Метаданные.СвойстваОбъектов.ИспользованиеРеквизита;
		Результат = (Использование = ИспользованиеРеквизита.ДляГруппыИЭлемента)
						ИЛИ (ЭтоГруппа И Использование = ИспользованиеРеквизита.ДляГруппы)
						ИЛИ (Не ЭтоГруппа И Использование = ИспользованиеРеквизита.ДляЭлемента);
		
	КонецЕсли;
					
	Возврат Результат;
	
КонецФункции

Функция ИзменятьОбластьОбъекта(ИзменяемыйОбъект, Тип, Имя, БитаяСсылка, ЗаполнениеПоОбъекту)
	
	ПолноеИмяОбъектаМетаданных = ИзменяемыйОбъект.Метаданные().ПолноеИмя();
	Результат = ЗаполнениеПоОбъекту ИЛИ Не ЗначениеЗаполнено(ИзменяемыйОбъект) ИЛИ БитаяСсылка;
	
	Если Тип = "Реквизит" Тогда
		
		Если РеквизитИсключениеИзменения(ПолноеИмяОбъектаМетаданных, Имя, БитаяСсылка, ЗаполнениеПоОбъекту) Тогда
			
			Результат = Ложь;
			
		КонецЕсли;
		
	ИначеЕсли Тип = "ТабличнаяЧасть" Тогда
		
	ИначеЕсли Тип = "Движение" Тогда
		
		Если ЗаполнениеПоОбъекту Тогда
			
			Результат = Ложь;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция РеквизитЗаблокирован(Заблокированные, Реквизит, БитаяСсылка)
	
	Возврат Заблокированные.Найти(Реквизит.Имя) <> Неопределено
				И НЕ БитаяСсылка;
	
КонецФункции

Функция РеквизитИсключениеИзменения(ПолноеИмяОбъектаМетаданных, ИмяРеквизита, БитаяСсылка, ЗаполнениеПоОбъекту)
	
	ИмяОбъектаКоллекции = ИТК_Метаданные.ИмяОбъектаКоллекции(ПолноеИмяОбъектаМетаданных);
	Если ИмяРеквизита = ИмяУникальногоИдентификаторСсылки() Тогда
		
		Результат = НЕ БитаяСсылка;
		
	ИначеЕсли ИмяРеквизита = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Номер") Тогда
		
		Результат = ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоДокумент(ИмяОбъектаКоллекции)
							ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоЗадача(ИмяОбъектаКоллекции) 
							ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоБизнесПроцесс(ИмяОбъектаКоллекции);
		
	ИначеЕсли ИмяРеквизита = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Предопределенный")
				ИЛИ ИмяРеквизита = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Код")
				ИЛИ ИмяРеквизита = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("ЭтоГруппа")
				ИЛИ ИмяРеквизита = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("ИмяПредопределенныхДанных") Тогда
		
		Результат = Истина;
		
	Иначе
		
		Результат = Ложь;
		
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

Функция КартинкаИспользованияПоля(Использование = Неопределено)
	
	ИспользованиеРеквизита = Метаданные.СвойстваОбъектов.ИспользованиеРеквизита;
	
	Если Использование = ИспользованиеРеквизита.ДляЭлемента Тогда
		
		Результат = БиблиотекаКартинок.Реквизит;
		
	ИначеЕсли Использование = ИспользованиеРеквизита.ДляГруппы Тогда
		
		Результат = БиблиотекаКартинок.ИТК_Папка;
		
	Иначе
		
		Результат = БиблиотекаКартинок.РежимПросмотраСписка;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ДобавитьДополнительныеРеквизитыИСведения(Реквизиты, Ссылка, ОбъектЗаполнения, ЗаполнениеПоОбъекту)
	
	ИспользуютсяДополнительныеРеквизиты = ИТК_БСП.ИспользуютсяДополнительныеРеквизиты(Ссылка);
	ИспользуютсяДополнительныеСведения = ИТК_БСП.ИспользуютсяДополнительныеСведения(Ссылка);
	
	Если Не (ИспользуютсяДополнительныеРеквизиты
			ИЛИ ИспользуютсяДополнительныеСведения) Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыФункции = Новый Массив;
	ПараметрыФункции.Добавить(Ссылка);
	ПараметрыФункции.Добавить(ИспользуютсяДополнительныеРеквизиты);
	ПараметрыФункции.Добавить(ИспользуютсяДополнительныеСведения);
	Свойства = ИТК_БСПКлиентСервер.ВыполнитьФункцию("УправлениеСвойствами.ПолучитьСписокСвойств", ПараметрыФункции);
	
	// Получение значений свойств
	Если ЗаполнениеПоОбъекту Тогда
		СсылкаЗначенийСвойств = ОбъектЗаполнения.Ссылка;
	Иначе 
		СсылкаЗначенийСвойств = Ссылка;
	КонецЕсли;
	
	ПараметрыФункции = Новый Массив;
	ПараметрыФункции.Добавить(СсылкаЗначенийСвойств);
	ПараметрыФункции.Добавить(ИспользуютсяДополнительныеРеквизиты);
	ПараметрыФункции.Добавить(ИспользуютсяДополнительныеСведения);
	ПараметрыФункции.Добавить(Свойства);
	ЗначенияСвойств = ИТК_БСПКлиентСервер.ВыполнитьФункцию("УправлениеСвойствами.ПолучитьЗначенияСвойств", ПараметрыФункции);
	
	СтруктураЗначенияСвойства = ИТК_БСП.СтруктураЗначенияСвойства();
	
	Для Каждого Свойство Из Свойства Цикл
		
		ОписаниеСвойства = ИТК_Общий.ЗначенияРеквизитовОбъекта(Свойство, СтруктураЗначенияСвойства.Список);
		
		НовыйРеквизит = Реквизиты.Добавить();
		НовыйРеквизит.Имя = ОписаниеСвойства[СтруктураЗначенияСвойства.ПолеЗаголовок];
		НовыйРеквизит.Синоним = НовыйРеквизит.Имя;
		НовыйРеквизит.Порядок = 2;
		НовыйРеквизит.Тип = ОписаниеСвойства[СтруктураЗначенияСвойства.ПолеТипЗначения];
		Если ОписаниеСвойства[СтруктураЗначенияСвойства.ПолеЭтоДополнительноеСведение] Тогда
			Картинка = БиблиотекаКартинок.ИТК_ДополнительноеСведение;
		Иначе
			Картинка = БиблиотекаКартинок.ИТК_ДополнительныйРеквизит;
		КонецЕсли;
		НовыйРеквизит.Картинка = Картинка;
		НовыйРеквизит.Свойство = Свойство;
		
		НайденнаяСтрока = ЗначенияСвойств.Найти(Свойство, СтруктураЗначенияСвойства.ПолеСвойство);
		Если НайденнаяСтрока = Неопределено Тогда
			Значение = Неопределено;
		Иначе 
			Значение = НайденнаяСтрока[СтруктураЗначенияСвойства.ПолеЗначение];
		КонецЕсли;
		
		Изменять = ЗаполнениеПоОбъекту;
		НовыйРеквизит.Изменять = Изменять;
		
		НовыйРеквизит.Доступность = Истина;
		НовыйРеквизит.Значение = Значение;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ВыгрузитьОбъектВТаблицуЗначений(Объект, УдаляемыеКолонки)
	
	Результат = Объект.Выгрузить();
	ИТК_ТаблицаЗначений.УдалитьКолонкиСИгнорированиемНаличия(Результат, УдаляемыеКолонки);
			
	Возврат Результат;
	
КонецФункции

#КонецОбласти