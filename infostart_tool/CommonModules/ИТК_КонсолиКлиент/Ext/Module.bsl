#Область ПрограммныйИнтерфейс

Процедура ПриОткрытии(Форма) Экспорт
	
	Форма.ПодключитьОбработчикОжидания("Подключаемый_ОбновлениеПоследнихРабочихДанных", 3);
	ОбновитьОбработчикАвтоСохранения(Форма);
	
	Форма["СохраняемыеВНастройкахДанныеМодифицированы"] = Истина; 
	
	ОбновитьЭлементыФормы(Форма);
	
КонецПроцедуры

Процедура ПередЗакрытием(Форма, Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка) Экспорт
	
	Если ЗавершениеРаботы = Истина Тогда
		
		Если Форма["Модифицированность"] Тогда
			
			Отказ = Истина;
			
			ТекстПредупреждения = НСтр("ru = 'В консоли имеются несохраненные данные, они будут потеряны.
										|Для сохранения изменений нажмите ""Продолжить работу"", сохраните данные, а потом завершите работу.';
										|en = 'The console has unsaved data, it will be lost.
										|To save your changes, click Continue, save the data, and then exit.'");

		КонецЕсли;
		
	Иначе
		
		Если Форма["ЗакрытиеРазрешено"] = Неопределено Тогда
			
			Отказ = Истина;
			
			ДополнительныеПараметры = ДополнительныеПараметрыФормы(Форма);
			ОписаниеОбработчика = Новый ОписаниеОповещения("ОбработчикЗакрытиеРазрешеноЗакрыть", ЭтотОбъект, ДополнительныеПараметры);
			
			ЗапуститьОбработчикСПроверкойНаСохранностьДанных(ОписаниеОбработчика);
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

Процедура ОбработкаОповещения(Форма, ИмяСобытия, Параметр, Источник) Экспорт
	
	Если ИмяСобытия <> ИТК_НастройкиКлиентСервер.ИмяСобытияНастройкиИзменены() Тогда
		Возврат;
	КонецЕсли;
	
	ОбновитьЭлементыФормы(Форма);
	ОбновитьОбработчикАвтоСохранения(Форма);
	
КонецПроцедуры

Процедура СтандартныйОбработчикРаботаСДанными(Форма, Имя, ОписаниеОповещенияОЗавершении = Неопределено) Экспорт 
	
	Инструмент = Форма["Инструмент"];
	ДополнительныеПараметры = ДополнительныеПараметрыФормы(Форма);
	ДополнительныеПараметры.Вставить("Имя", Имя);
	ДополнительныеПараметры.Вставить("ОписаниеОповещенияОЗавершении", ОписаниеОповещенияОЗавершении);
	
	Если Найти(Имя, "Новые") Тогда
		
		ОписаниеОбработчика = Новый ОписаниеОповещения("ОбработчикНовыеДанные", ЭтотОбъект, ДополнительныеПараметры);
		ЗапуститьОбработчикСПроверкойНаСохранностьДанных(ОписаниеОбработчика);
		
	ИначеЕсли Найти(Имя, "СохранитьФайлКак") Тогда
		
		ДиалогСохраненияФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
		ДиалогСохраненияФайла.Фильтр = ИТК_КонсолиКлиентСервер.ФильтрФайловДанных(Инструмент);
		ДиалогСохраненияФайла.Расширение = ИТК_КонсолиКлиентСервер.ОсновноеРасширениеФайловДанных(Инструмент);
		ДиалогСохраненияФайла.Заголовок = НСтр("ru = 'Сохранение данных';
												|en = 'Saving data'");
		
		ОписаниеОбработчика = Новый ОписаниеОповещения("ОбработчикСохраненниеВФайлЗакончено", ЭтотОбъект, ДополнительныеПараметры);
		ДиалогСохраненияФайла.Показать(ОписаниеОбработчика);
		
	ИначеЕсли Найти(Имя, "СохранитьНастройкиКак") Тогда

		РабочиеДанные = Форма["РабочиеДанные"];
		
		ТекущееИмяНастройки = Неопределено;
		Если РабочиеДанные.Тип = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда
			ТекущееИмяНастройки = РабочиеДанные.Имя;
		КонецЕсли;

		ОписаниеОповещения = Новый ОписаниеОповещения("ОбработчикСохраненниеВНастройкиЗакончено", ЭтотОбъект, ДополнительныеПараметры);
		
		КлючНастроек = ИТК_КонсолиКлиентСерверПовтИсп.КлючНастроекДанные(Инструмент);
		ИТК_ФормаКлиент.ОткрытьДиалогВыбораНастроекДанных(Форма, ИТК_Перечисления.РежимДиалогаУправлениеДаннымиВНастройкахСохранение(), 
												КлючНастроек, ТекущееИмяНастройки, ОписаниеОповещения);
		
	ИначеЕсли Найти(Имя, "Сохранить") Тогда
		
		СохранитьДанные(Форма);
		
	ИначеЕсли Найти(Имя, "ОткрытьФайл") Тогда
		
		ОписаниеОповещения = ОписаниеОбработчикаЗагрузкиФайла(Форма);
		ЗапуститьОбработчикСПроверкойНаСохранностьДанных(ОписаниеОповещения);
		
	ИначеЕсли Найти(Имя, "ОткрытьНастройку") Тогда
		
		ОписаниеОповещения = ОписаниеОбработчикаЗагрузкиНастройки(Форма);
		ЗапуститьОбработчикСПроверкойНаСохранностьДанных(ОписаниеОповещения);
		
	ИначеЕсли Найти(Имя, "ОткрытьПапкуСодержащуюФайл") Тогда
		
		РабочиеДанные = Форма["РабочиеДанные"];
		ИТК_ФайлыКлиент.ОткрытьВПроводнике(РабочиеДанные.Имя);
		
	ИначеЕсли Найти(Имя, "ОткрытьПоследниеРабочиеДанные") Тогда

		ИндексОбработчика = ИТК_Строки.ИндексИдентификатора(Имя);
		ДополнительныеПараметры.Вставить("Индекс", ИндексОбработчика);
		
		ОписаниеОбработчика = Новый ОписаниеОповещения("ОткрытьПоследниеРабочиеДанные", ЭтотОбъект, ДополнительныеПараметры);
		
		ЗапуститьОбработчикСПроверкойНаСохранностьДанных(ОписаниеОбработчика);
		
	КонецЕсли;
	
	ОбновитьЭлементыФормы(Форма);

КонецПроцедуры

Функция ОбновитьЭлементыФормы(Форма) Экспорт
	
	ОбновитьЗаголовок(Форма);
	ОбновитьЭлементыВыделенияСтрокиДереваДанных(Форма);
	ОбновитьЭлементыГруппыДанные(Форма);
	ОбновитьКнопкуСохранить(Форма);
	
	Форма.ОбновитьЭлементыФормы();
	
КонецФункции

Процедура ПоследниеРабочиеДанные_Обновить(Форма) Экспорт
	
	КлючОбновления = ИТК_Консоли.ПоследниеРабочиеДанные_КлючОбновления(Форма["Инструмент"]);
	
	Если КлючОбновления = Форма["ПоследниеРабочиеДанные_КлючОбновления"] Тогда
		Возврат;
	КонецЕсли;
	
	Форма.ВызовСервераВКонтекстеФормы("ИТК_Консоли.ПоследниеРабочиеДанные_ОбновитьЭлементы");
	Форма["ПоследниеРабочиеДанные_КлючОбновления"] = КлючОбновления;
	
КонецПроцедуры

Процедура ДеревоДанныхПриАктивизацииСтроки(Форма, Элемент) Экспорт
	
	ОбновитьЭлементыФормы(Форма);
	
КонецПроцедуры

Процедура ДеревоДанныхПриИзменении(Форма, Элемент) Экспорт
	
	ИТК_КонсолиКлиентСервер.ДанныеМодифицированы(Форма);
	ОбновитьЭлементыФормы(Форма);
	
КонецПроцедуры

Процедура ДеревоДанныхПередУдалением(Форма, Элемент, Отказ) Экспорт
	
	Отказ = Истина;
	
	ЗаголовокВопроса = НСтр("ru = 'Удаление строк(и)';
							|en = 'Deleting rows'");
	ТекстВопроса = НСтр("ru = 'Данные будут потеряны. Продолжить?';
						|en = 'Data will be lost. Continue?'");
	КоличествоВыделенныхСтрок = Элемент.ВыделенныеСтроки.Количество();
	Если КоличествоВыделенныхСтрок > 1 Тогда
		
		ТекстВопроса = СтрШаблон(НСтр("ru = 'Выделено: %1';
										|en = 'Lines selected: %1'"), КоличествоВыделенныхСтрок)
							+ Символы.ПС + ТекстВопроса;
							
	КонецЕсли;

	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Форма", Форма);
	ОписаниеОповещенияОЗавершении = Новый ОписаниеОповещения("ВопросПередУдалениемДеревоДанныхЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	
	КнопкиВопроса = ИТК_ФормаКлиент.КнопкиВопросаПродолжитьОтмена();
	
	ГруппаНастроек = ИТК_Перечисления.ГруппаИнструментовКонсоли();
	
	ИТК_ФормаКлиент.ЗадатьВопрос(ОписаниеОповещенияОЗавершении, ТекстВопроса, КнопкиВопроса, Истина, ЗаголовокВопроса, Форма, "ВопросПередУдалениемСтрокДанных", ГруппаНастроек);
	
КонецПроцедуры

Процедура ДеревоДанныхПередНачаломДобавления(Форма, Элемент, Отказ, Копирование, Родитель) Экспорт
	
	Отказ = Истина;
	
	Форма["МодифицированностьПослеОтменыРедактированияДереваДанных"] = Форма.Модифицированность;
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если Копирование Тогда // Добавлено копированием
		
		Родитель = РодительСтрокиДереваДанных(Форма, ТекущиеДанные);
		ПереместитьСтрокуДереваДанных(Форма, ТекущиеДанные, Родитель, Истина, Истина);
		
	Иначе
		
		ТипСтроки = ИТК_КонсолиКлиентСервер.ТипДобавляемойСтрокиПоУмолчанию(Форма["Инструмент"]);
		ДобавитьСтрокуВДеревоДанных(Форма, ТипСтроки);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ДеревоДанныхПриОкончанииРедактирования(Форма, Элемент, НоваяСтрока, ОтменаРедактирования) Экспорт
	
	Если ОтменаРедактирования Тогда
		
		ИТК_КонсолиКлиентСервер.УстановитьМодифицированностьДанных(Форма, Форма["МодифицированностьПослеОтменыРедактированияДереваДанных"]);
		
		УдаляемыеСтроки = Новый Массив;
		УдаляемыеСтроки.Добавить(Элемент.ТекущиеДанные);
		УдалитьСтрокиДереваДанных(Форма, УдаляемыеСтроки);
		
		Возврат;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ДеревоДанныхПередРазворачиванием(Форма, ИдентификаторСтроки, Отказ) Экспорт
	
	ДеревоДанныхУстановитьРазвернутостьСтроки(Форма, ИдентификаторСтроки, Истина);
	
КонецПроцедуры

Процедура ДеревоДанныхПередСворачиванием(Форма, ИдентификаторСтроки, Отказ) Экспорт
	
	ДеревоДанныхУстановитьРазвернутостьСтроки(Форма, ИдентификаторСтроки, Ложь);
	
КонецПроцедуры

Процедура ДеревоДанныхПроверкаПеретаскивания(Форма, Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Поле) Экспорт
	
	СтандартнаяОбработка = Ложь;
	
	// Проверим есть ли строки для которых доступно перетаскивание
	ПриемникПеретаскивания = СтрокаПриемникПеретаскиванияДереваДанных(Форма, Строка);
	СтрокиКоторыеМожноПеренести = СтрокиДереваДанныхКоторыеМожноПеренести(Форма, Элемент.ВыделенныеСтроки, ПараметрыПеретаскивания, ПриемникПеретаскивания);
	
	Если НЕ ЗначениеЗаполнено(СтрокиКоторыеМожноПеренести) Тогда
		ПараметрыПеретаскивания.Действие = ДействиеПеретаскивания.Отмена;
	КонецЕсли;
	
КонецПроцедуры

Процедура ДеревоДанныхПеретаскивание(Форма, Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Поле) Экспорт
	
	СтандартнаяОбработка = Ложь;
	
	ДеревоДанных = Форма["ДеревоДанных"];

	СтрокаПриемникПеретаскивания = СтрокаПриемникПеретаскиванияДереваДанных(Форма, Строка);
	СтрокиКоторыеМожноПеренести = СтрокиДереваДанныхКоторыеМожноПеренести(Форма, Элемент.ВыделенныеСтроки, ПараметрыПеретаскивания, СтрокаПриемникПеретаскивания);
	
	Копирование = (ПараметрыПеретаскивания.Действие = ДействиеПеретаскивания.Копирование);
	
	Для Каждого Идентификатор Из СтрокиКоторыеМожноПеренести Цикл
		
		ПереносимаяСтрока = ДеревоДанных.НайтиПоИдентификатору(Идентификатор);
		
		ПереносВКорень = (ТипЗнч(СтрокаПриемникПеретаскивания) = Тип("ДанныеФормыДерево"));
		Если ПереносВКорень 
			ИЛИ ИТК_КонсолиКлиентСервер.ПереносСтрокиДереваДанныхВнутрь(СтрокаПриемникПеретаскивания.Тип, ПереносимаяСтрока.Тип) Тогда
			
			ИндексВставки = Неопределено;
			
		Иначе
			
			ПриемникПеретаскиванияРодитель = РодительСтрокиДереваДанных(Форма, СтрокаПриемникПеретаскивания);
			ИндексВставки = ПриемникПеретаскиванияРодитель.ПолучитьЭлементы().Индекс(СтрокаПриемникПеретаскивания);
			СтрокаПриемникПеретаскивания = ПриемникПеретаскиванияРодитель;
			
		КонецЕсли;
		
		АктивироватьСтроку = Копирование;
		ПереместитьСтрокуДереваДанных(Форма, ПереносимаяСтрока, СтрокаПриемникПеретаскивания, Копирование, АктивироватьСтроку, ИндексВставки);
		
		// Удалим перемещенную строку (сделали копию строки на новом месте и нужно удалить старую)
		Если НЕ Копирование Тогда
			
			РодительПереносимойСтроки = РодительСтрокиДереваДанных(Форма, ПереносимаяСтрока);
			
			Если ПереносимаяСтрока <> Неопределено Тогда // Возможно уже была удалена
				РодительПереносимойСтроки.ПолучитьЭлементы().Удалить(ПереносимаяСтрока);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ПереносВКорень = (ТипЗнч(СтрокаПриемникПеретаскивания) = Тип("ДанныеФормыДерево"));
	Если НЕ ПереносВКорень Тогда
		Элемент.Развернуть(СтрокаПриемникПеретаскивания.ПолучитьИдентификатор());
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьСтрокуГруппуВДеревоДанных(Форма) Экспорт
	
	ДобавитьСтрокуВДеревоДанных(Форма, ИТК_Перечисления.ЭлементДанныхГруппа());
	
КонецПроцедуры

Процедура ВыделитьСтрокиДеревоДанных(Форма) Экспорт
	
	ВыделенныеСтроки = Форма.Элементы["ДеревоДанных"].ВыделенныеСтроки;
	ИнвертироватьВыделениеСтрокДереваДанных(Форма, ВыделенныеСтроки);
	
	ИТК_КонсолиКлиентСервер.ДанныеМодифицированы(Форма);
	ОбновитьЭлементыВыделенияСтрокиДереваДанных(Форма);
	
КонецПроцедуры

Процедура РаботаСДаннымиИзменитьПоле(Форма, Строка, Имя, Значение, УстанавливатьМодифицированность = Истина) Экспорт 
	
	Данные = ИТК_КонсолиКлиентСервер.РаботаСДаннымиДанныеСтроки(Строка);

	Если Данные[Имя] = Значение Тогда
		Возврат;
	КонецЕсли;
		
	Данные.Вставить(Имя, Значение);
		
	Если УстанавливатьМодифицированность Тогда 
		ИТК_КонсолиКлиентСервер.ДанныеМодифицированы(Форма);
	КонецЕсли;
		
	//Если Форма.ТекущаяСтрока = Форма.ТекущийРезультат.АктуаленПоСтроке Тогда
	//	Форма.ТекущийРезультат.АктуаленПоСтроке = Неопределено;
	//КонецЕсли;
	
КонецПроцедуры

Процедура РаботаСДаннымиИзменитьПоля(Форма, Строка, ИзменяемыеПоля, УстанавливатьМодифицированность = Истина) Экспорт 

	Для Каждого ИзменяемоеПоле Из ИзменяемыеПоля Цикл 
		РаботаСДаннымиИзменитьПоле(Форма, Строка, ИзменяемоеПоле.Ключ, ИзменяемоеПоле.Значение, УстанавливатьМодифицированность);
	КонецЦикла;
	
КонецПроцедуры

Процедура СохранитьИзмененныеДанныеСтроки(Форма) Экспорт
	
	ИдентификаторПоследнейВыделеннойСтроки = ИТК_КонсолиКлиентСервер.ИдентификаторПоследнейВыделеннойСтроки(Форма);
	Если ИдентификаторПоследнейВыделеннойСтроки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДеревоДанных = Форма["ДеревоДанных"];
	
	Строка = ДеревоДанных.НайтиПоИдентификатору(ИдентификаторПоследнейВыделеннойСтроки);
	Если Строка = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТипСтроки = Строка.Тип;
	
	ЭлементТекст = ЭлементТекстПоТипуСтроки(Форма, ТипСтроки);
	Если ЭлементТекст = Неопределено Тогда 
		Возврат;
	КонецЕсли;

	ИзменяемыеПоля = Новый Структура;
	
	ГраницыВыделения = ИТК_РедакторКодаКлиент.ГраницыВыделения(ЭлементТекст);
	Если ГраницыВыделения <> Неопределено Тогда
		ИзменяемыеПоля.Вставить("ГраницыВыделенияТекста", ГраницыВыделения);
	КонецЕсли;
	
	Закладки = ИТК_РедакторКодаКлиент.УстановленныеЗакладки(ЭлементТекст);
	Если Закладки <> Неопределено Тогда
		ИзменяемыеПоля.Вставить("Закладки", Закладки);
	КонецЕсли;
	
	СостояниеРедактора = ИТК_РедакторКодаКлиент.СостояниеРедактора(ЭлементТекст);
	Если СостояниеРедактора <> Неопределено Тогда
		ИзменяемыеПоля.Вставить("СостояниеРедактора", СостояниеРедактора);
	КонецЕсли;
	
	ИТК_ИнтеграцияOneDebuggerКлиент.СохранитьСостояниеОтладчика(Форма, ЭлементТекст, ИзменяемыеПоля);
		
	РаботаСДаннымиИзменитьПоля(Форма, Строка, ИзменяемыеПоля, Ложь);
	
КонецПроцедуры

Процедура ЗагрузитьСостояниеРедактора(Форма) Экспорт
	
	ТекущиеДанные = Форма.Элементы["ДеревоДанных"].ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТипСтроки = ТекущиеДанные.Тип;
	ДанныеСтроки = ИТК_КонсолиКлиентСервер.РаботаСДаннымиДанныеСтроки(ТекущиеДанные);
	
	ЭлементТекст = ЭлементТекстПоТипуСтроки(Форма, ТипСтроки);
	Если ЭлементТекст = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	//Если НЕ ИТК_РедакторКодаКлиент.Инициализирован(ЭлементТекст) Тогда
	//	
	//	ПодключитьОбработчикОжидания("ПодключаемыйЗагрузитьСостояниеРедактораКода", 0.1, Истина);
	//	Возврат;
	//	
	//КонецЕсли;
	
	Текст = ДанныеСтроки["Текст"];
	//ДоступноРедактированиеТекста = ИТК_КонсольРазработчикаДанныеКлиентСервер.ДоступноРедактированиеТекстаДляСтроки(ТипСтроки);
	ДоступноРедактированиеТекста = Истина;
	
	ИТК_РедакторКодаКлиент.УстановитьДоступностьРедактирования(Форма, ЭлементТекст, ДоступноРедактированиеТекста);
	ИТК_РедакторКодаКлиент.УстановитьТекст(Форма, ЭлементТекст, Текст);
	
	// Восстановление выделения
	ИТК_РедакторКодаКлиент.УстановитьВыделение(ЭлементТекст, ДанныеСтроки["ГраницыВыделенияТекста"]);
	Если ИТК_РедакторКодаКлиентСервер.ЭтоРедакторКодаMonaco(ЭлементТекст) Тогда
		
		// Восстановление закладок
		ИТК_РедакторКодаКлиент.УстановитьЗакладки(ЭлементТекст, ДанныеСтроки["Закладки"]);
		
		// Установим оригинальный текст
		Если ИТК_КонсолиКлиентСервер.ЭтоТипСтрокиДереваДанныхСИспользованиемОригинальногоТекста(ТипСтроки) Тогда
			ИТК_РедакторКодаКлиент.УстановитьОригинальныйТекст(ЭлементТекст, ДанныеСтроки["ОригинальныйТекст"]);
		КонецЕсли;
		
		// Восстановление состояния редактора
		ИТК_РедакторКодаКлиент.УстановитьСостояниеРедактора(ЭлементТекст, ДанныеСтроки["СостояниеРедактора"]);
		
	КонецЕсли;
	
	//ЗагрузитьПользовательскиеОбъектыПодсказки();
	
	ИТК_ИнтеграцияOneDebuggerКлиент.УстановитьСостояниеОтладчика(Форма, ЭлементТекст, ДанныеСтроки);
	
КонецПроцедуры

Процедура ОбновитьОбработчикАвтоСохранения(Форма)
	
	ИмяОбработчика = "ПодключаемыйАвтоСохранениеДанных";
	Форма.ОтключитьОбработчикОжидания(ИмяОбработчика);
	
	Автоcохранение = ИТК_Настройки.Значение(ИТК_Перечисления.ГруппаИнструментовКонсоли(), "Автоcохранение");
	Если Автоcохранение Тогда
		Форма.ПодключитьОбработчикОжидания(ИмяОбработчика, 60);
	КонецЕсли;
	
КонецПроцедуры

Процедура АвтосохранениеДанных(Форма) Экспорт
	
	Если НЕ Форма["МодифицированностьАвтосохранение"] Тогда
		Возврат;
	КонецЕсли;
	
	//Элементы.ФормаАвтоСохранение.Видимость = Истина;
	
	ДлительнаяОперацияАвтоматическоеСохранение = Форма["ДлительнаяОперацияАвтоматическоеСохранение"];
	ДлительнаяОперацияАвтоматическоеСохранение = Форма.ВызовФункцииСервераВКонтекстеФормы("ИТК_Консоли.Автосохранение");
	
	ПараметрыОжидания = ИТК_ДлительныеОперацииКлиент.ПараметрыОжидания(Форма);
	
	ДополнительныеПараметры = ДополнительныеПараметрыФормы(Форма);
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершениеАвтоматическогоСохранения", ЭтотОбъект, ДополнительныеПараметры);
	ИТК_ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперацияАвтоматическоеСохранение, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

Процедура СохранениеПередВыполнением(Форма) Экспорт
	
	ТребуетсяСохранениеПередВыполнением = ИТК_Настройки.Значение(ИТК_Перечисления.ГруппаИнструментовКонсоли(), "СохранениеПередВыполнением");
	Если НЕ ТребуетсяСохранениеПередВыполнением Тогда
		Возврат;
	КонецЕсли;
	
	АвтосохранениеДанных(Форма);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ВопросПередУдалениемДеревоДанныхЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Форма = ДополнительныеПараметры.Форма;
	ДеревоДанных = Форма["ДеревоДанных"];
	ЭлементДеревоДанных = Форма.Элементы["ДеревоДанных"];
	
	ИТК_КонсолиКлиентСервер.ДанныеМодифицированы(Форма);
	
	// Удаляем строки
	УдаляемыеСтроки = Новый Массив;
	Для Каждого ВыделеннаяСтрока Из ЭлементДеревоДанных.ВыделенныеСтроки Цикл 
		УдаляемыеСтроки.Добавить(ДеревоДанных.НайтиПоИдентификатору(ВыделеннаяСтрока));
	КонецЦикла;
	
	УдалитьСтрокиДереваДанных(Форма, УдаляемыеСтроки);
	
	ОбновитьЭлементыФормы(Форма);
	
КонецПроцедуры

Процедура ВопросСохраненияДанныхЗавершение(Результат, ОписаниеОбработчика) Экспорт
	
	Если Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
		
	Если Результат = КодВозвратаДиалога.Да Тогда
		СохранитьДанные(ОписаниеОбработчика.ДополнительныеПараметры.Форма, ОписаниеОбработчика);
	Иначе
		ВыполнитьОбработкуОповещения(ОписаниеОбработчика);
	КонецЕсли;

КонецПроцедуры

Процедура ОбработчикНовыеДанные(Результат = Неопределено, ДополнительныеПараметры) Экспорт
	
	Форма = ДополнительныеПараметры.Форма;
	
	Форма.ВызовСервераВКонтекстеФормы("ИТК_Консоли.НовыеДанные");

	ПерваяСтрока = Форма["ДеревоДанных"].ПолучитьЭлементы()[0];
	Форма.Элементы["ДеревоДанных"].ТекущаяСтрока = ПерваяСтрока.ПолучитьИдентификатор();
	
	ОбновитьЭлементыФормы(Форма);
	
	Если ДополнительныеПараметры.ОписаниеОповещенияОЗавершении <> Неопределено Тогда
		ВыполнитьОбработкуОповещения(ДополнительныеПараметры.ОписаниеОповещенияОЗавершении, ДополнительныеПараметры.Имя);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработчикЗакрытиеРазрешеноЗакрыть(Результат, ДополнительныеПараметры) Экспорт
	
	Форма = ДополнительныеПараметры.Форма;
	
	Форма["ЗакрытиеРазрешено"] = Истина;
	Форма.Закрыть();
	
КонецПроцедуры

Процедура ОбработчикСохраненниеВФайлЗакончено(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт 
	
	Если НЕ ЗначениеЗаполнено(ВыбранныеФайлы) Тогда
		Возврат;
	КонецЕсли;
	
	СохранитьДанныеВФайл(ДополнительныеПараметры.Форма, ВыбранныеФайлы[0]);
	
КонецПроцедуры

Функция НайтиСтрокуДереваДанных(Родитель, УникальныйИдентификатор) Экспорт
	
	Результат = Неопределено;
	
	Для Каждого Строка Из Родитель.ПолучитьЭлементы() Цикл
		
		Если Строка.УникальныйИдентификатор = УникальныйИдентификатор Тогда
			Результат = Строка;
			Прервать;
		КонецЕсли;
		
		НайденнаяСтрока = НайтиСтрокуДереваДанных(Строка, УникальныйИдентификатор);
		
		Если НайденнаяСтрока <> Неопределено Тогда
			Результат = НайденнаяСтрока; 
			Прервать;
		КонецЕсли;
			
	КонецЦикла;
		
	Возврат Результат;	

КонецФункции

Процедура ОбработчикЗагрузитьФайл(Результат, ДополнительныеПараметры) Экспорт
	
	ЗагрузитьФайл(ДополнительныеПараметры.Форма, ДополнительныеПараметры.Объединение);
	
КонецПроцедуры

Процедура ЗагрузкаФайлаЗакончена(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт 
	
	Если ВыбранныеФайлы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗагрузитьДанныеИзФайла(ДополнительныеПараметры.Форма, ВыбранныеФайлы[0], , ДополнительныеПараметры.Объединение);
	
КонецПроцедуры

Процедура ЗаконченоПомещениеФайлаВХранилищеДляЗагрузки(Результат, Адрес, ВыбранноеИмяФайла, ДополнительныеПараметры) Экспорт 

	Форма = ДополнительныеПараметры["Форма"];
	
	Состояние(НСтр("ru = 'Загрузка файла:';
					|en = 'Load file:'"), , ВыбранноеИмяФайла, БиблиотекаКартинок.ИТК_ДлительнаяОперацияАнимация48);
	
	Попытка
		
		ПараметрыВызова = Новый Массив;
		ПараметрыВызова.Добавить(Адрес);
		
		ДополнительныеПараметры =  Новый Структура;
		ДополнительныеПараметры.Вставить("Тип", ИТК_Перечисления.ТипХраненияДанныхФайл());
		ДополнительныеПараметры.Вставить("ПолноеИмя", ВыбранноеИмяФайла);
		ПараметрыВызова.Добавить(ДополнительныеПараметры);
		
		Форма.ВызовСервераВКонтекстеФормы("ИТК_КонсолиФорматДанных.Загрузка", ПараметрыВызова);
		
	Исключение
		
		КраткоеПредставлениеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ПоказатьПредупреждение(, СтрШаблон(НСтр("ru = 'Ошибка при загрузке файла: %1
												|%2';
												|en = 'Error loading file: %1
												|%2'"), ВыбранноеИмяФайла, КраткоеПредставлениеОшибки), , ИТК_КонсольРазработчикаКлиентСервер.Представление());
		
	КонецПопытки;
	
КонецПроцедуры

Процедура ОбработчикЗагрузитьНастройку(Результат, ДополнительныеПараметры) Экспорт
	
	Форма = ДополнительныеПараметры.Форма;
	
	Инструмент = Форма["Инструмент"];
	РабочиеДанные = Форма["РабочиеДанные"];
	
	ТекущееИмяНастройки = Неопределено;
	Если РабочиеДанные.Тип = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда
		ТекущееИмяНастройки = РабочиеДанные.Имя;
	КонецЕсли;

	КлючНастроек = ИТК_КонсолиКлиентСерверПовтИсп.КлючНастроекДанные(Инструмент);
	ОписаниеОповещения = Новый ОписаниеОповещения("ЗагрузкаНастройкиЗавершена", ЭтотОбъект, ДополнительныеПараметры);
	ИТК_ФормаКлиент.ОткрытьДиалогВыбораНастроекДанных(ЭтотОбъект, ИТК_Перечисления.РежимДиалогаУправлениеДаннымиВНастройкахЗагрузка(),
														КлючНастроек, ТекущееИмяНастройки, ОписаниеОповещения);

КонецПроцедуры

Процедура ЗагрузкаНастройкиЗавершена(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Форма = ДополнительныеПараметры.Форма;
	
	Если ТипЗнч(Результат) = Тип("Структура") Тогда // Загрузка чужой настройки
		ЗагрузитьДанныеИзНастроек(Форма, Результат.Имя, Результат.Пользователь, ДополнительныеПараметры.Объединение);
	Иначе
		ЗагрузитьДанныеИзНастроек(Форма, Результат, , ДополнительныеПараметры.Объединение);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОткрытьПоследниеРабочиеДанные(Результат, ДополнительныеПараметры) Экспорт
	
	Форма = ДополнительныеПараметры["Форма"];
	
	ПараметрыВызова = Новый Массив;
	ПараметрыВызова.Добавить(ДополнительныеПараметры.Индекс);
	
	ДанныеЭлемента = Форма.ВызовФункцииСервераВКонтекстеФормы("ИТК_Консоли.ПоследниеРабочиеДанные_ДанныеЭлементаПоИндексу", ПараметрыВызова);

	Если ДанныеЭлемента.Тип = ИТК_Перечисления.ТипХраненияДанныхФайл() Тогда
		ЗагрузитьДанныеИзФайла(Форма, ДанныеЭлемента.Имя);
	ИначеЕсли ДанныеЭлемента.Тип = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда
		ЗагрузитьДанныеИзНастроек(Форма, ДанныеЭлемента.Имя);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработчикСохраненниеВНастройкиЗакончено(Результат, ДополнительныеПараметры) Экспорт 
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	Форма = ДополнительныеПараметры["Форма"];
	СохранитьДанныеВНастройки(Форма, Результат);
	
КонецПроцедуры

Процедура ЗавершениеАвтоматическогоСохранения(Результат, ДополнительныеПараметры) Экспорт
	
	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Форма = ДополнительныеПараметры.Форма;
	Форма["МодифицированностьАвтоСохранение"] = Ложь;
	//Элементы.ФормаАвтоСохранение.Видимость = Ложь;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОбновитьЗаголовок(Форма)
	
	РабочиеДанные = Форма["РабочиеДанные"];

	Если РабочиеДанные.Тип = Неопределено Тогда
		
		Заголовок = НСтр("ru = 'Новый';
						|en = 'New'");
		
	ИначеЕсли РабочиеДанные.Тип = ИТК_Перечисления.ТипХраненияДанныхФайл() Тогда 
		
		Заголовок = ИТК_ФайлыКлиентСервер.ПолноеИмяФайлаКратко(РабочиеДанные.Имя);
		
	ИначеЕсли РабочиеДанные.Тип = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда 
		
		Заголовок = СтрШаблон("(%1)", РабочиеДанные.Имя);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РабочиеДанные.Комментарий) Тогда
		Заголовок = СтрШаблон("%1 - (%2)", Заголовок, РабочиеДанные.Комментарий);
	КонецЕсли;
	
	Форма.Заголовок = Заголовок;
	
КонецПроцедуры

Процедура ОбновитьКнопкуСохранить(Форма)

	ПрефиксИмени = ИТК_КонсолиКлиентСервер.ГруппаДанныеПрефикс();
	
	ЭлементКнопка = Форма.Элементы[ПрефиксИмени + "Сохранить"];
	ЭлементКнопка.Картинка = ИТК_КонсолиКлиентСервер.КартинкаКнопкиСохранить(Форма);
	
КонецПроцедуры

Функция РодительСтрокиДереваДанных(Форма, Строка = Неопределено)
	
	Если Строка = Неопределено Тогда // Родителя нет (это корень дерева)
		Возврат Форма["ДеревоДанных"];
	КонецЕсли;
	
	Результат = Строка.ПолучитьРодителя();
	Если Результат = Неопределено Тогда
		Результат = РодительСтрокиДереваДанных(Форма);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ДобавитьСтрокуВДеревоДанных(Форма, Тип, ДополнительныеПараметры = Неопределено)
	
	Элемент = Форма.Элементы["ДеревоДанных"];
	ТекущаяСтрока = Элемент.ТекущиеДанные;

	Родитель = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "Родитель");
	Если Родитель = Неопределено Тогда
		
		Если ТекущаяСтрока <> Неопределено
				И ТекущаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхГруппа() Тогда
			Родитель = ТекущаяСтрока;
		Иначе
			Родитель = РодительСтрокиДереваДанных(Форма, ТекущаяСтрока);
		КонецЕсли;
		
	КонецЕсли;
	
	Представление = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "Представление");
	Если Представление = Неопределено Тогда
		Представление = НовоеПредставлениеСтрокиДереваДанных(Родитель, Тип);
	КонецЕсли;
	
	УстанавливатьМодифицированность = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "УстанавливатьМодифицированность", Истина);
	Если УстанавливатьМодифицированность Тогда
		Форма.Модифицированность = Истина;
	КонецЕсли;
	
	// Добавление новой строки
	НоваяСтрока = Родитель.ПолучитьЭлементы().Добавить();
	ИТК_КонсолиКлиентСервер.ЗаполнениеСтрокиДереваДанных(НоваяСтрока, Тип, Представление, ДополнительныеПараметры);
	
	Активизировать = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "Активизировать", Истина);
	Если Активизировать Тогда
		АктивизироватьНовуюСтрокуДереваДанных(Элемент, НоваяСтрока);
	КонецЕсли;
	
	Возврат НоваяСтрока;
	
КонецФункции

Функция ПереместитьСтрокуДереваДанных(Форма, СтрокаИсточник, СтрокаПриемник, Копирование = Ложь, Активизировать = Ложь, ИндексВставки = Неопределено)
	
	Элемент = Форма.Элементы["ДеревоДанных"];
	
	Если Копирование Тогда
		
		ТипСтроки = СтрокаИсточник.Тип;
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Родитель", СтрокаПриемник);
		ДополнительныеПараметры.Вставить("Активизировать", Ложь);
		Если ТипСтроки = ИТК_Перечисления.ЭлементДанныхПодзапрос() Тогда
			ДополнительныеПараметры.Вставить("Картинка", СтрокаИсточник.Картинка);
		КонецЕсли;
		
		// Подготовка представления
		ПредставлениеНовойСтроки = СтрокаИсточник.Представление;
		Если ТипСтроки <> ИТК_Перечисления.ЭлементДанныхПодзапрос() Тогда
			ПредставлениеНовойСтроки = СтрШаблон(НСтр("ru = '%1 - копия';
											|en = '%1 - copy'"), СтрокаИсточник.Представление);
		КонецЕсли;
		ДополнительныеПараметры.Вставить("Представление", ПредставлениеНовойСтроки);
		
		// Подготовка Начальных данных
		НачальныеДанные = ИТК_КонсолиКлиентСервер.НовыеДанныеСтрокиДереваДанных(ТипСтроки);
		ЗаполнитьЗначенияСвойств(НачальныеДанные, ИТК_КонсолиКлиентСервер.РаботаСДаннымиДанныеСтроки(СтрокаИсточник));
		
		Если ИТК_КонсолиКлиентСервер.ЭтоТипСтрокиДереваДанныхСИспользованиемОригинальногоТекста(ТипСтроки) Тогда
			ИТК_КонсолиКлиентСервер.СброситьОригинальныйТекстДанныхДереваДанных(НачальныеДанные);
		КонецЕсли;
		
		ИТК_ИнтеграцияOneDebuggerКлиент.ОчиститьСостояниеОтладчика(НачальныеДанные);
				
		ДополнительныеПараметры.Вставить("НачальныеДанные", НачальныеДанные);
		
		НоваяСтрока = ДобавитьСтрокуВДеревоДанных(Форма, ТипСтроки, ДополнительныеПараметры);
		НоваяСтрока.Выделение = СтрокаИсточник.Выделение;
		
	Иначе // Перемещение
		
		СтрокаПриемникЭлементы = СтрокаПриемник.ПолучитьЭлементы();
		Если ИндексВставки = Неопределено Тогда
			НоваяСтрока = СтрокаПриемникЭлементы.Добавить();
		Иначе 
			НоваяСтрока = СтрокаПриемникЭлементы.Вставить(ИндексВставки + 1);
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИсточник);
		
	КонецЕсли;	
	
	Для Каждого ОбрабатываемаяСтрока Из СтрокаИсточник.ПолучитьЭлементы() Цикл
		
		ПереместитьСтрокуДереваДанных(Форма, ОбрабатываемаяСтрока, НоваяСтрока, Копирование);
		
		// Развернем в соответствии с источником
		Если Элемент.Развернут(СтрокаИсточник.ПолучитьИдентификатор()) Тогда
			Элемент.Развернуть(НоваяСтрока.ПолучитьИдентификатор());
		КонецЕсли;
		
	КонецЦикла;
	
	Если Активизировать Тогда
		АктивизироватьНовуюСтрокуДереваДанных(Элемент, НоваяСтрока);
	КонецЕсли;
	
	Возврат НоваяСтрока;
	
КонецФункции

Процедура УдалитьСтрокиДереваДанных(Форма, Строки)
	
	ОчищаемыеАдресаВоВременноХранилище = Новый Массив;
	УдалитьСтрокиДереваДанныхРекурсивно(Форма, Строки, ОчищаемыеАдресаВоВременноХранилище);
	
	Если ЗначениеЗаполнено(ОчищаемыеАдресаВоВременноХранилище) Тогда
		ИТК_ВременноеХранилище.Удалить(ОчищаемыеАдресаВоВременноХранилище);
	КонецЕсли;
	
КонецПроцедуры

Процедура УдалитьСтрокиДереваДанныхРекурсивно(Форма, Строки, ОчищаемыеАдресаВоВременноХранилище)
	
	ЭлементДеревоДанных = Форма.Элементы.ДеревоДанных;
	
	Для Каждого УдаляемаяСтрока Из Строки Цикл 
		
		ДанныеСтроки = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(УдаляемаяСтрока);
		
		// Собираем вложенные строки и удаляем
		УдаляемыеСтроки = Новый Массив;
		Для Каждого ВложеннаяСтрока Из УдаляемаяСтрока.ПолучитьЭлементы() Цикл 
			УдаляемыеСтроки.Добавить(ВложеннаяСтрока);
		КонецЦикла;
		
		УдалитьСтрокиДереваДанныхРекурсивно(Форма, УдаляемыеСтроки, ОчищаемыеАдресаВоВременноХранилище);
		
		// Сбрасываем выделение строк
		Если ЭлементДеревоДанных.ТекущиеДанные = УдаляемаяСтрока Тогда 
			ЭлементДеревоДанных.ТекущаяСтрока = Неопределено; 
		КонецЕсли;
		
		// Собираем адреса временных хранилищ и удаляем
		
		// Удаляем строку
		Родитель = РодительСтрокиДереваДанных(Форма, УдаляемаяСтрока);
		Родитель.ПолучитьЭлементы().Удалить(УдаляемаяСтрока);
		
	КонецЦикла;
	
КонецПроцедуры

Функция НовоеПредставлениеСтрокиДереваДанных(Родитель, Тип)
	
	МаксИндекс = МаксимальныйИндексСтрокДереваДанных(Родитель, Тип);
	Представление = ИТК_Перечисления.Представление(Тип);
	
	Возврат СтрШаблон("%1 №%2", Представление, МаксИндекс + 1);
	
КонецФункции

Функция МаксимальныйИндексСтрокДереваДанных(Родитель, Тип)
	
	Результат = 0;
	Для Каждого Строка Из Родитель.ПолучитьЭлементы() Цикл 
		
		Если Строка.Тип <> Тип Тогда
			Продолжить;
		КонецЕсли;
		
		Значение = Строка["Представление"];
		Индекс = ИТК_Строки.ИндексИдентификатора(Значение);
		
		Если Индекс > Результат Тогда
			Результат = Индекс;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура АктивизироватьНовуюСтрокуДереваДанных(Элемент, Строка)
	
	Элемент.ТекущаяСтрока = Строка.ПолучитьИдентификатор();
	Элемент.ИзменитьСтроку();
	
КонецПроцедуры

Процедура ИнвертироватьВыделениеСтрокДереваДанных(Форма, ОбрабатываемыеСтроки)
	
	ДеревоДанных = Форма["ДеревоДанных"];
	
	Для Каждого ИдентификаторСтроки Из ОбрабатываемыеСтроки Цикл
		
		ОбрабатываемаяСтрока = ДеревоДанных.НайтиПоИдентификатору(ИдентификаторСтроки);
		ОбрабатываемаяСтрока.Выделение = НЕ ОбрабатываемаяСтрока.Выделение;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбновитьЭлементыВыделенияСтрокиДереваДанных(Форма)
	
	Элементы = Форма.Элементы;
	ДеревоДанных = Форма["ДеревоДанных"];
		
	ПрисутствуютВыделенныеСтроки = Ложь;
	ВыделенныеСтроки = Элементы["ДеревоДанных"].ВыделенныеСтроки;
	Для Каждого ВыделеннаяСтрока Из ВыделенныеСтроки Цикл
		
		ОбрабатываемаяСтрока = ДеревоДанных.НайтиПоИдентификатору(ВыделеннаяСтрока);
		Если ОбрабатываемаяСтрока <> Неопределено 
			И ОбрабатываемаяСтрока.Выделение Тогда
			
			ПрисутствуютВыделенныеСтроки = Истина; // Есть отмеченные строки значит кнопка должна быть Нажатой (отмеченной)
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Элемент = Элементы.ДеревоДанныхКонтекстноеМенюВыделитьСтроку;
	Элемент.Доступность = ЗначениеЗаполнено(ДеревоДанных.ПолучитьЭлементы());
	Элемент.Пометка = ПрисутствуютВыделенныеСтроки;
	
КонецПроцедуры

Процедура ОбновитьЭлементыГруппыДанные(Форма)
	
	ЭлементыФормы = Форма.Элементы;
	
	ПрефиксГруппыДанные = ИТК_КонсолиКлиентСервер.ГруппаДанныеПрефикс();
	РабочиеДанные = Форма["РабочиеДанные"];
	
	ЭлементыФормы[ПрефиксГруппыДанные + "ОткрытьПапкуСодержащуюФайл"].Доступность = ЗначениеЗаполнено(РабочиеДанные.Имя)
																И РабочиеДанные.Тип = ИТК_Перечисления.ТипХраненияДанныхФайл();
	
КонецПроцедуры

Процедура ДеревоДанныхУстановитьРазвернутостьСтроки(Форма, Идентификатор, Развернуто)
	
	Строка = Форма["ДеревоДанных"].НайтиПоИдентификатору(Идентификатор);
	Если Строка = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Строка["Развернуто"] = Развернуто;
	
КонецПроцедуры

Функция СтрокаПриемникПеретаскиванияДереваДанных(Форма, Идентификатор)
	
	ДеревоДанных = Форма["ДеревоДанных"];
	
	Если Идентификатор = Неопределено Тогда // Перенос в корень дерева
		Возврат ДеревоДанных;
	КонецЕсли;
	
	Возврат ДеревоДанных.НайтиПоИдентификатору(Идентификатор);
	
КонецФункции

Функция СтрокиДереваДанныхКоторыеМожноПеренести(Форма, АнализируемыеСтроки, ПараметрыПеретаскивания, ПриемникПеретаскивания)
	
	ДеревоДанных = Форма["ДеревоДанных"];
	
	Результат = Новый Массив;
	Для Каждого Идентификатор Из АнализируемыеСтроки Цикл
		
		ПеретаскиваемаяСтрока = ДеревоДанных.НайтиПоИдентификатору(Идентификатор);
		
		Если МожноПереместитьСтрокуДереваДанных(ПеретаскиваемаяСтрока, ПараметрыПеретаскивания, ПриемникПеретаскивания) Тогда
			
			Результат.Добавить(Идентификатор);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция МожноПереместитьСтрокуДереваДанных(ПроверяемаяСтрока, ПараметрыПеретаскивания, ПриемникПеретаскивания)
	
	// Правила перетаскивания Drag & Drop
	// 1. В корень дерева можно переносить элементы Запрос, Код, СКД, Группа
	// 2. Нельзя переносить/копировать элементы вложенный запрос
	// 3. Строку нельзя переносить саму в себя
	// 4. Необходимо проверять не перемещается ли группа внутрь самой себя для избежания бесконечной рекурсии
	// В группу переносить можно, но только не в туже самую... копированием можно и в туже самую
	// 5. Группу можно переносить только в другую группу
	// 6. Переносить в родительскую группу только копированием
	// 7. Вариант отчета СКД можно переносить только в другой вариант (т.е. перемещение элементов)
	//     в вариант можно переносить только вариант или пользовательскую настройку
	// 8. Пользовательскую настройку СКД можно перемешать в СКД или Вариант отчета СКД или в другую пользовательскую настройку (перемещение)
	//    внутрь пользовательской настройки ничего перемещать нельзя
	
	Если  ТипЗнч(ПриемникПеретаскивания) = Тип("ДанныеФормыДерево") Тогда // (должно быть начальной проверкой) // 1
		
		Возврат ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхГруппа()
				ИЛИ ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхЗапрос()
				ИЛИ ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных()
				ИЛИ ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхКод();
		
	ИначеЕсли ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхПодзапрос() Тогда // 2
			
		Возврат Ложь;
		
	ИначеЕсли ПроверяемаяСтрока = ПриемникПеретаскивания Тогда // 3
		
		Возврат Ложь;
		
	ИначеЕсли ИТК_ФормаКлиент.СтрокаДеревоВходитВСтроку(ПриемникПеретаскивания, ПроверяемаяСтрока) Тогда // 4
		
		Возврат Ложь;
		
	ИначеЕсли ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхГруппа() 
				И ПриемникПеретаскивания.Тип <> ИТК_Перечисления.ЭлементДанныхГруппа() Тогда // 5
				
		Возврат Ложь;
				
	ИначеЕсли ПриемникПеретаскивания = ПроверяемаяСтрока.ПолучитьРодителя() И ПараметрыПеретаскивания.Действие <> ДействиеПеретаскивания.Копирование Тогда // 6
		
		Возврат Ложь;
	
	ИначеЕсли (ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД() 
				И ПриемникПеретаскивания.Тип <> ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД())
			 ИЛИ (ПриемникПеретаскивания.Тип = ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД()
			 		И НЕ(ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД()
							ИЛИ ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхПользовательскаяНастройкаСКД())) Тогда // 7
				
		Возврат Ложь;
				
	ИначеЕсли ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхПользовательскаяНастройкаСКД() 
				И ПриемникПеретаскивания.Тип <> ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД() Тогда // 8
				
		Возврат ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоОдинИзТиповСтрокиСКД(ПриемникПеретаскивания.Тип);
				
	ИначеЕсли ПриемникПеретаскивания.Тип = ИТК_Перечисления.ЭлементДанныхПользовательскаяНастройкаСКД() Тогда // 8
				
		Возврат Ложь;
				
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Процедура ЗапуститьОбработчикСПроверкойНаСохранностьДанных(ОписаниеОбработчика)
	
	Форма = ОписаниеОбработчика.ДополнительныеПараметры.Форма;
	Если Форма.Модифицированность Тогда
		
		// Вопрос "Сохранить данные"?
		ОписаниеОповещения = Новый ОписаниеОповещения("ВопросСохраненияДанныхЗавершение", ЭтотОбъект, ОписаниеОбработчика);
		ТекстВопроса = НСтр("ru = 'Сохранить изменения?';
									|en = 'Save the changes?'");

		ВариантыОтвета = Новый СписокЗначений;
		ВариантыОтвета.Добавить(КодВозвратаДиалога.Да,		НСтр("ru = 'Сохранить';
																	|en = 'Save'"));
		ВариантыОтвета.Добавить(КодВозвратаДиалога.Нет,		НСтр("ru = 'Не сохранять';
																	|en = 'Not save'"));
		ВариантыОтвета.Добавить(КодВозвратаДиалога.Отмена,	НСтр("ru = 'Отмена';
																	|en = 'Cancel'"));
		
		ЗаголовокВопроса = ИТК_ТуллкитКлиентСервер.ПредставлениеИнструмента(Форма["Инструмент"]);
		
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, ВариантыОтвета, , КодВозвратаДиалога.Да, ЗаголовокВопроса);
		
	Иначе 
		
		ВыполнитьОбработкуОповещения(ОписаниеОбработчика);
		
	КонецЕсли;

КонецПроцедуры

Функция ДополнительныеПараметрыФормы(Форма)
	
	Результат = Новый Структура;
	Результат.Вставить("Форма", Форма);
	
	Возврат Результат;
	
КонецФункции

Процедура СохранитьДанныеВФайл(Форма, ПолноеИмяФайла)
	
	Состояние(НСтр("ru = 'Сохранение файла:';
					|en = 'Saving file:'"), , ПолноеИмяФайла, БиблиотекаКартинок.ИТК_ДлительнаяОперацияАнимация48);
	
	Попытка
		
		АдресХранилища = Форма.ВызовФункцииСервераВКонтекстеФормы("ИТК_КонсолиФорматДанных.ДанныеВоВременномХранилище");
		ПолучитьФайл(АдресХранилища, ПолноеИмяФайла, Ложь);
		
		ИТК_КонсолиКлиентСервер.СброситьМодифицированностьДанных(Форма);
		
		ТипыХраненияДанных = ИТК_Перечисления.ТипХраненияДанныхФайл();
		ИТК_КонсолиКлиентСервер.УстановитьРабочиеДанные(Форма, ТипыХраненияДанных, ПолноеИмяФайла);
		
		ПараметрыВызова = Новый Массив;
		ПараметрыВызова.Добавить(ТипыХраненияДанных);
		ПараметрыВызова.Добавить(ПолноеИмяФайла);
		
		Форма.ВызовСервераВКонтекстеФормы("ИТК_Консоли.ПоследниеРабочиеДанные_ОбновитьЭлементы", ПараметрыВызова);
		
		ПослеСохраненияДанных(Форма);
		
	Исключение
		
		// Ошибка файл не удалось сохранить
		ПредставлениеОшибки = НСтр("ru = 'Ошибка сохранения :';
									|en = 'Save failed :'") + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ПоказатьПредупреждение( , ПредставлениеОшибки, , ИТК_КонсольРазработчикаКлиентСервер.Представление());
		Возврат; 
		
	КонецПопытки;

	ОбновитьЭлементыФормы(Форма);
	
КонецПроцедуры

Функция ОписаниеОбработчикаЗагрузкиФайла(Форма, Объединение = Ложь)
	
	Возврат ОповещениеЗагрузкиДанных(Форма, "ОбработчикЗагрузитьФайл", Объединение);
	
КонецФункции

Функция ОповещениеЗагрузкиДанных(Форма, ИмяОбработчика, Объединение = Ложь)
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Форма", Форма);
	ДополнительныеПараметры.Вставить("Объединение", Объединение);
	
	Результат = Новый ОписаниеОповещения(ИмяОбработчика, ЭтотОбъект, ДополнительныеПараметры);
	
	Возврат Результат;
	
КонецФункции

Процедура ЗагрузитьФайл(Форма, Объединение)
	
	Инструмент = Форма["Инструмент"];

	ДиалогОткрытияФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ДиалогОткрытияФайла.Фильтр = ИТК_КонсолиКлиентСервер.ФильтрФайловДанных(Инструмент);
	ДиалогОткрытияФайла.Расширение = ИТК_КонсолиКлиентСервер.ОсновноеРасширениеФайловДанных(Инструмент);
	ДиалогОткрытияФайла.МножественныйВыбор = Ложь;
	Если Объединение Тогда
		ЗаголовокДиалога = НСтр("ru = 'Объединение с данными';
								|en = 'Data merge'");
	Иначе
		ЗаголовокДиалога = НСтр("ru = 'Открытие данных';
								|en = 'Opening data'");
	КонецЕсли;
	ДиалогОткрытияФайла.Заголовок = ЗаголовокДиалога;
	
	ОписаниеОповещения = ОповещениеЗагрузкиДанных(Форма, "ЗагрузкаФайлаЗакончена", Объединение);
	ДиалогОткрытияФайла.Показать(ОписаниеОповещения);
	
КонецПроцедуры

Процедура ЗагрузитьДанныеИзФайла(Форма, ИмяФайла, ОбновитьЭлементы = Истина, Объединение = Ложь)
	
	Попытка
		
		ОписаниеОповещения = ОповещениеЗагрузкиДанных(Форма, "ЗаконченоПомещениеФайлаВХранилищеДляЗагрузки", Объединение);
		НачатьПомещениеФайла(ОписаниеОповещения, , ИмяФайла, Ложь);
		
		//Если ОбновитьЭлементы Тогда
		//	
		//	РаскрытьВеткиДереваВ5СоответствииСДанными(ДеревоДанных);
		//	ОбновитьЭлементыФормы();
		//	
		//КонецЕсли;
		
	Исключение
		
		ПараметрыВызова = Новый Массив;
		ПараметрыВызова.Добавить(ИТК_Перечисления.ТипХраненияДанныхФайл());
		ПараметрыВызова.Добавить(ИмяФайла);
		
		Форма.ВызовСервераВКонтекстеФормы("ИТК_Консоли.ПоследниеРабочиеДанные_ОбновитьЭлементы", ПараметрыВызова);
		
		Шаблон = НСтр("ru = 'Ошибка загрузки файла: %1';
						|en = 'Error loading file: %1'");
		ПредставлениеОшибки = СтрШаблон(Шаблон, ИмяФайла);
		ПоказатьПредупреждение( , ПредставлениеОшибки, , ИТК_КонсольКодаКлиентСервер.Представление());

	КонецПопытки;
	
КонецПроцедуры

Процедура СохранитьДанные(Форма, ОписаниеОбработчикаПослеВыполнения = Неопределено)
	
	РабочиеДанные = Форма["РабочиеДанные"];
	РабочиеДанныеИмя = РабочиеДанные.Имя;
	Если ПустаяСтрока(РабочиеДанныеИмя) Тогда
		
		ИмяНастройкиСохранятьДанныеПоУмолчаниюВ = ИТК_НастройкиКлиентСерверПовтИсп.ИмяНастройкиСохранятьДанныеПоУмолчаниюВ();
		СохранятьДанныеПоУмолчаниюВ = ИТК_Настройки.Значение(ИТК_Перечисления.ГруппаИнструментовКонсоли(), ИмяНастройкиСохранятьДанныеПоУмолчаниюВ);
		Если СохранятьДанныеПоУмолчаниюВ = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда
			СтандартныйОбработчикРаботаСДанными(Форма, "СохранитьНастройкиКак");
		Иначе
			СтандартныйОбработчикРаботаСДанными(Форма, "СохранитьФайлКак");
		КонецЕсли;
		
	Иначе
		
		Если РабочиеДанные.Тип = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда
			СохранитьДанныеВНастройки(Форма, РабочиеДанныеИмя);
		Иначе 
			СохранитьДанныеВФайл(Форма, РабочиеДанныеИмя);
		КонецЕсли;
		
		Если ОписаниеОбработчикаПослеВыполнения <> Неопределено Тогда
			ВыполнитьОбработкуОповещения(ОписаниеОбработчикаПослеВыполнения);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура СохранитьДанныеВНастройки(Форма, Имя)
	
	Состояние(НСтр("ru = 'Сохранение настройки:';
					|en = 'Saving settings:'"), , Имя, БиблиотекаКартинок.ИТК_ДлительнаяОперацияАнимация48);

	ПараметрыВызова = Новый Массив;
	ПараметрыВызова.Добавить(Имя);
	Форма.ВызовСервераВКонтекстеФормы("ИТК_Консоли.СохранитьДанныеВНастройки", ПараметрыВызова);
	
	ИТК_КонсолиКлиентСервер.СброситьМодифицированностьДанных(Форма);
	
	ТипыХраненияДанных = ИТК_Перечисления.ТипХраненияДанныхНастройка();
	ИТК_КонсолиКлиентСервер.УстановитьРабочиеДанные(Форма, ТипыХраненияДанных, Имя);
	
	ПараметрыВызова = Новый Массив;
	ПараметрыВызова.Добавить(ТипыХраненияДанных);
	ПараметрыВызова.Добавить(Имя);
	
	Форма.ВызовСервераВКонтекстеФормы("ИТК_Консоли.ПоследниеРабочиеДанные_ОбновитьЭлементы", ПараметрыВызова);
	
	ПослеСохраненияДанных(Форма);
	
	ОбновитьЭлементыФормы(Форма);
	
КонецПроцедуры

Функция ОписаниеОбработчикаЗагрузкиНастройки(Форма, Объединение = Ложь)
	
	Возврат ОповещениеЗагрузкиДанных(Форма, "ОбработчикЗагрузитьНастройку", Объединение);
	
КонецФункции

Процедура ЗагрузитьДанныеИзНастроек(Форма, Имя, Пользователь = Неопределено, Объединение = Ложь)
	
	Если Пользователь = Неопределено Тогда
		Пояснение = Имя;
	Иначе
		Пояснение = СтрШаблон("%1\%2", Пользователь, Имя);
	КонецЕсли;
	
	Если Объединение Тогда
		
		ЗаголовокСостояния = НСтр("ru = 'Объединение с настройкой';
									|en = 'Merge with customization'");
		
	Иначе
		
		ЗаголовокСостояния = НСтр("ru = 'Загрузка настройки';
									|en = 'Loading settings'");
		
	КонецЕсли;
	
	Состояние(ЗаголовокСостояния, , Пояснение, БиблиотекаКартинок.ИТК_ДлительнаяОперацияАнимация48);
	
	ПараметрыВызова = Новый Массив;
	ПараметрыВызова.Добавить(Имя);
	ПараметрыВызова.Добавить(Пользователь);
	ПараметрыВызова.Добавить(Объединение);
		
	Форма.ВызовСервераВКонтекстеФормы("ИТК_Консоли.ЗагрузитьДанныеИзНастроек", ПараметрыВызова);
	
	ОбновитьЭлементыФормы(Форма);
	
КонецПроцедуры

Функция ЭлементТекстПоТипуСтроки(Форма, Тип)
	
	Элементы = Форма.Элементы;
	Если Тип = ИТК_Перечисления.ЭлементДанныхКод() Тогда
		Результат = Элементы.Код;
	Иначе
		Результат = Неопределено;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ПослеСохраненияДанных(Форма)
	
	ДеревоДанных = Форма["ДеревоДанных"];
	
	СброситьОригинальныйТекст(ДеревоДанных);
	ЗагрузитьСостояниеРедактора(Форма);
	
КонецПроцедуры

&НаКлиенте
Процедура СброситьОригинальныйТекст(СтрокаРодитель)
	
	Для Каждого Строка Из СтрокаРодитель.ПолучитьЭлементы() Цикл
		
		Если НЕ ИТК_КонсолиКлиентСервер.ЭтоТипСтрокиДереваДанныхСИспользованиемОригинальногоТекста(Строка.Тип) Тогда
			Продолжить;
		КонецЕсли;
		
		Данные = ИТК_КонсолиКлиентСервер.РаботаСДаннымиДанныеСтроки(Строка);
		ИТК_КонсолиКлиентСервер.СброситьОригинальныйТекстДанныхДереваДанных(Данные);
		
		СброситьОригинальныйТекст(Строка);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти