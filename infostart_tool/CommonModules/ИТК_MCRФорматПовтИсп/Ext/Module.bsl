#Область ПрограммныйИнтерфейс

Функция ПреобразованиеПеречисленияЭлементДанных(Значение, Обратное = Ложь) Экспорт
	
	Соответствие = СоответствиеЭлементДанных(Обратное);
	Возврат Соответствие.Получить(Значение);

КонецФункции

Функция ПреобразованиеПеречисленияТипТранзакцииОбработкиРезультата(Значение, Обратное = Ложь) Экспорт
	
	Соответствие = СоответствиеТипТранзакцииОбработкиРезультата(Обратное);
	Возврат Соответствие.Получить(Значение);

КонецФункции

// Получает тип поля данных по имени
//
// Параметры:
//   Имя - Строка - Имя поля данных
//
// Возвращаемое значение:
//   Тип - Тип поля данных
//
Функция ТипЗначенияПоляДанных(Имя) Экспорт
	
	Соответствие = Новый Соответствие;
	Соответствие.Вставить("Name", Тип("Строка"));
	Соответствие.Вставить("Text", Тип("Строка"));
	Соответствие.Вставить("Dedicated", Тип("Булево"));
	Соответствие.Вставить("UsingExternalFunctions", Тип("Булево"));
	Соответствие.Вставить("Deploy", Тип("Булево"));
	Соответствие.Вставить("MaxCount", Тип("Число"));
	
	Возврат Соответствие.Получить(Имя);
	
КонецФункции

// Получает значение поля по умолчанию по имени
//
// Параметры:
//   Имя - Строка - Имя поля
//
// Возвращаемое значение:
//   Произвольный - Значение поля по умолчанию
//
Функция ЗначениеПоляДанныхПоУмолчанию(Имя) Экспорт
	
	Соответствие = Новый Соответствие;
	Соответствие.Вставить("Deploy", Истина);
	Соответствие.Вставить("UsingExternalFunctions", Ложь);
	Соответствие.Вставить("Dedicated", Ложь);
	
	Возврат Соответствие.Получить(Имя);
	
КонецФункции

// Собирает словарь перевода имен полей для указанного языка
//
// Параметры:
//   Язык - Строка - Код языка (ru, en)
//
// Возвращаемое значение:
//   Соответствие - Словарь перевода
//
Функция СловарьПереводаИменПолей(Язык) Экспорт
	
	Результат = Новый Соответствие;
	Результат.Вставить("Имя", "Name");
	Результат.Вставить("Тип", "Type");
	Результат.Вставить("Выделение", "Dedicated");
	Результат.Вставить("Текст", "Text");
	Результат.Вставить("Развернуто", "Deploy");
	Результат.Вставить("ЗначенияПараметров", "Parameters");
	Результат.Вставить("МаксимумСтрок", "MaxCount");
	Результат.Вставить("Строки", "Elements");
	Результат.Вставить("ВременныеТаблицы", "TemporaryTables");
	Результат.Вставить("ВнешниеИсточники", "ExternalSources");
	Результат.Вставить("ТаблицыМВТ", "TTMTables");
	Результат.Вставить("АлгоритмыОбработки", "ProcessingAlgorithms");
	Результат.Вставить("ИспользованиеВнешнихФункций", "UsingExternalFunctions");
	Результат.Вставить("НастройкиВыводаТаблиц", "OutputTemporaryTables");
	Результат.Вставить("НастройкиВыводаТаблиц", "SettingsOutputTables");

	Обратное = (Язык = "en");
	Если Обратное Тогда
		Результат = ИТК_ОбщийКлиентСервер.ОбратноеСоответствие(Результат);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СоответствиеЭлементДанных(Обратное = Ложь)
	
	Результат = Новый Соответствие;
	Результат.Вставить(ИТК_Перечисления.ЭлементДанныхЗапрос(), "Query");
	Результат.Вставить(ИТК_Перечисления.ЭлементДанныхГруппа(), "Group");
	Результат.Вставить(ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных(), "DataCompositionSchema");
	Результат.Вставить(ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД(), "DCSSettingsVariant");
	Результат.Вставить(ИТК_Перечисления.ЭлементДанныхПользовательскаяНастройкаСКД(), "DCSUserSettings");
	Результат.Вставить(ИТК_Перечисления.ЭлементДанныхКод(), "Code");
	
	Если Обратное Тогда
		Результат = ИТК_ОбщийКлиентСервер.ОбратноеСоответствие(Результат);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СоответствиеТипТранзакцииОбработкиРезультата(Обратное = Ложь)

	Результат = Новый Соответствие;
	Результат.Вставить(ИТК_Перечисления.ТипТранзакцииОбработкиРезультатаПоСтроке(), "Row");
	Результат.Вставить(ИТК_Перечисления.ТипТранзакцииОбработкиРезультатаНеИспользовать(), "NotUse");
	Результат.Вставить(ИТК_Перечисления.ТипТранзакцииОбработкиРезультатаНаВсе(), "ForAll");
	
	Если Обратное Тогда
		
		Результат = ИТК_ОбщийКлиентСервер.ОбратноеСоответствие(Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
