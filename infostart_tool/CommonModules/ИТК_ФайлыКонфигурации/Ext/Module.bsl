#Область ПрограммныйИнтерфейс

Функция ПутьКФайлам() Экспорт
	
	ВсеНастройки = ИТК_Настройки.ЗагрузитьВсе();
	ОбщиеНастройки = ВсеНастройки[ИТК_НастройкиКлиентСервер.ИмяРеквизитаНастройкиОбщие()];
		
	Возврат ОбщиеНастройки["ВыгруженныеФайлы"];
	
КонецФункции

Функция ТекстМодуля(ПутьКВыгруженнымФайлам, ОписаниеМодуля, Расширение = Неопределено) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ПутьКВыгруженнымФайлам) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПутиПоиска = ПутиПоиска(ПутьКВыгруженнымФайлам, Расширение);
	Для Каждого ПутьПоиска Из ПутиПоиска Цикл 

		ПолноеИмяФайла = ИТК_ФайлыКонфигурацииКлиентСервер.ПолноеИмяФайлаМодуляФорматКонфигуратора(ПутьПоиска, ОписаниеМодуля);
		Результат = ИТК_ФайлыКлиентСервер.ПрочитатьТекст(ПолноеИмяФайла);
		Если Результат <> Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		ПолноеИмяФайла = ИТК_ФайлыКонфигурацииКлиентСервер.ПолноеИмяФайлаМодуляФорматЕДТ(ПутьПоиска, ОписаниеМодуля);
		Результат = ИТК_ФайлыКлиентСервер.ПрочитатьТекст(ПолноеИмяФайла);
		Если Результат <> Неопределено Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ИспользуетсяМодуль(Путь, ОписаниеМодуля, Расширение = Неопределено) Экспорт
	
	ПутиПоиска = ПутиПоиска(Путь, Расширение);
	Для Каждого ПутьПоиска Из ПутиПоиска Цикл 
		
		ПолноеИмяФайла = ИТК_ФайлыКонфигурацииКлиентСервер.ПолноеИмяФайлаМодуляФорматКонфигуратора(ПутьПоиска, ОписаниеМодуля);
		Если ИТК_Файлы.СуществуетИЗаполнен(ПолноеИмяФайла) Тогда
			Возврат Истина;
		КонецЕсли;
		
		ПолноеИмяФайла = ИТК_ФайлыКонфигурацииКлиентСервер.ПолноеИмяФайлаМодуляФорматЕДТ(ПутьПоиска, ОписаниеМодуля);
		Если ИТК_Файлы.СуществуетИЗаполнен(ПолноеИмяФайла) Тогда
			Возврат Истина;
		КонецЕсли;

	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПутиПоиска(Путь, Расширение)

	ПутьРасширений = Путь + ПолучитьРазделительПути() + "EXTENSIONS" + ПолучитьРазделительПути();
	
	Результат = Новый Массив;
	
	Если ЗначениеЗаполнено(Расширение) Тогда
		Результат.Добавить(ПутьРасширений + Расширение);
	Иначе
		
		Результат.Добавить(Путь);
		
		НайденныеКаталоги = НайтиФайлы(ПутьРасширений, "*.*");
		Для Каждого НайденныйКаталог Из НайденныеКаталоги Цикл 
			
			Если НайденныйКаталог.ЭтоФайл() Тогда
				Продолжить;
			КонецЕсли;
			
			Результат.Добавить(ПутьРасширений + НайденныйКаталог.Имя);

		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
