#Область ПрограммныйИнтерфейс

Процедура ДеревоЗначенийПередРазворачиванием(Форма, Элемент, ИдентификаторСтроки, Отказ) Экспорт
	
	ИмяКоллекции = Элемент.Имя;
	
	РазворачиваемаяСтрока = Форма[ИмяКоллекции].НайтиПоИдентификатору(ИдентификаторСтроки);
	Если НЕ ИТК_ФормаКлиентСервер.НеобходимоРазвернутьСтроку(РазворачиваемаяСтрока) Тогда
		Возврат;
	КонецЕсли;
	
	Если ИТК_ФормаКлиентСервер.УровеньРазворачиваемойСтроки(РазворачиваемаяСтрока) > 30 Тогда
		Возврат;
	КонецЕсли;
	
	Контекст = Форма.ИТК_ИсследованиеЗначений_Контекст();
	Если Контекст = ИТК_КонсольКодаКлиентСервер.КонтекстСервер() Тогда
		
		ПараметрыВызова = Новый Массив;
		ПараметрыВызова.Добавить(ИмяКоллекции);
		ПараметрыВызова.Добавить(ИдентификаторСтроки);
		
		Форма.ВызовСервераВКонтекстеФормы("ИТК_ИсследованиеЗначенийСервер.РазвернутьСтрокуВФорме", ПараметрыВызова);

	Иначе
		
		ОсновноеЗначение = Форма.ИТК_ИсследованиеЗначенийОсновноеЗначениеКлиент(РазворачиваемаяСтрока);
		ИсследуемоеЗначение = ИТК_ИсследованиеЗначенийКлиентСервер.ИсследуемоеЗначениеСтрокиФормы(ОсновноеЗначение, РазворачиваемаяСтрока);
		ИТК_ИсследованиеЗначенийКлиентСервер.РазвернутьСтрокуВФорме(ОсновноеЗначение, РазворачиваемаяСтрока, ИсследуемоеЗначение);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура РезультатПеременныеВыбор(Форма, Элемент, ИдентификаторСтроки, Поле, СтандартнаяОбработка) Экспорт
	
	ИмяКоллекции = Элемент.Имя;
	Если Поле.Имя <> ИмяКоллекции + "ПредставлениеГиперссылки" Тогда
		Возврат;
	КонецЕсли;
	
	ВыбраннаяСтрока = Форма[ИмяКоллекции].НайтиПоИдентификатору(ИдентификаторСтроки);
	Контекст = Форма.ИТК_ИсследованиеЗначений_Контекст();
	ТипЗначения = ТипЗнч(ВыбраннаяСтрока.Значение);
	
	// Открытие значений опеределенных типов
	Если ТипЗначения = Тип("Строка") Тогда
		
		Текст = ВыбраннаяСтрока.Значение;
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Заголовок", ВыбраннаяСтрока.Имя);
		
		ИТК_ФормаКлиент.ОткрытьМногострочныйТекст(ЭтотОбъект, Текст, Ложь, ДополнительныеПараметры, СтандартнаяОбработка);
		Возврат;
		
	ИначеЕсли ИТК_ТипыКлиентСервер.ЭтоСсылочный(ТипЗначения) Тогда
		
		ПоказатьЗначение( , ВыбраннаяСтрока.Значение);
		Возврат;
		
	КонецЕсли;
	
	// Открытие в исследователе
	Если Контекст = ИТК_КонсольКодаКлиентСервер.КонтекстСервер() Тогда
		
		ПараметрыВызова = Новый Массив;
		ПараметрыВызова.Добавить(ИмяКоллекции);
		ПараметрыВызова.Добавить(ИдентификаторСтроки);
		
		ИсследуемоеЗначение = Форма.ВызовФункцииСервераВКонтекстеФормы("ИТК_ИсследованиеЗначенийСервер.АдресИсследуемогоЗначения", ПараметрыВызова);
		
	Иначе
		
		ОсновноеЗначение = Форма.ИТК_ИсследованиеЗначенийОсновноеЗначениеКлиент(ВыбраннаяСтрока);
		ИсследуемоеЗначение = ИТК_ИсследованиеЗначенийКлиентСервер.ИсследуемоеЗначениеСтрокиФормы(ОсновноеЗначение, ВыбраннаяСтрока);
		
		Попытка
			ИТК_ИсследованиеЗначенийСервер.ПроверкаПередачиЗначенияНаСервер(ИсследуемоеЗначение);
		Исключение
			
			ПоказатьПредупреждение(, НСтр("ru = 'Данное значение нельзя анализировать в отдельном окне'; en = 'This value cannot be analyzed in a separate window'"));
			Возврат;
			
		КонецПопытки;
		
	КонецЕсли;
	
	ОткрытьФормуИсследованияЗначений(ЭтотОбъект, Контекст, ВыбраннаяСтрока.Имя, ИсследуемоеЗначение, СтандартнаяОбработка);
	
КонецПроцедуры

Процедура ОбработкаФункцииОповещенияРасшифровкиПоля(ОсновноеЗначение, Строка, ОписаниеПоля) Экспорт
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Строка", Строка);
	ДополнительныеПараметры.Вставить("ОсновноеЗначение", ОсновноеЗначение);
	ДополнительныеПараметры.Вставить("ОписаниеПоля", ОписаниеПоля);
	
	Если ТипЗнч(ОсновноеЗначение) = Тип("Файл") Тогда 
		
		Оповещение = Новый ОписаниеОповещения("ПроверкаСуществованияФайла", ЭтотОбъект, ДополнительныеПараметры);
		ОсновноеЗначение.НачатьПроверкуСуществования(Оповещение);
		
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ПроверкаСуществованияФайла(Существует, ДополнительныеПараметры) Экспорт 
	
	Если НЕ Существует Тогда 
		Возврат;
	КонецЕсли;
	
	ОсновноеЗначение = ДополнительныеПараметры.ОсновноеЗначение;
	Оповещение = Новый ОписаниеОповещения("ОбработкаОповещенияФункции", ЭтотОбъект, ДополнительныеПараметры);
	Выполнить("ОсновноеЗначение." + ДополнительныеПараметры.ОписаниеПоля.ИмяФункцииОповещения + "(Оповещение)");
	
КонецПроцедуры
	
Процедура ОбработкаОповещенияФункции(Результат, ДополнительныеПараметры) Экспорт
	
	Строка = ДополнительныеПараметры.Строка;
	ИТК_ИсследованиеЗначенийКлиентСервер.ЗаполнениеСтрокиНаФорме(Строка, Строка.Имя, Результат);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОткрытьФормуИсследованияЗначений(Владелец, Контекст, Имя, Значение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если Контекст = ИТК_КонсольКодаКлиентСервер.КонтекстСервер() Тогда
		ПолноеИмяФормы = ИТК_ИсследованиеЗначенийСервер.ПолноеИмяФормыЗначения(Значение);
	Иначе
		ПолноеИмяФормы = ПолноеИмяФормыЗначения(Значение);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПолноеИмяФормы) Тогда
		Заголовок = СтрШаблон("%1: %2", Имя, НСтр("ru = 'Исследование значений (Toolkit)'; en = 'Meaning research (Toolkit)'"));
	Иначе
		
		Заголовок = Неопределено;
		ПолноеИмяФормы = "Обработка.ИТК_ИсследованиеЗначений.Форма";
		
	КонецЕсли;
	
	// Открытие формы
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Заголовок", Заголовок);
	ПараметрыФормы.Вставить("Контекст", Контекст);
	ПараметрыФормы.Вставить("Имя", Имя);
	ПараметрыФормы.Вставить("Значение", Значение);
	ПараметрыФормы.Вставить("Редактирование", Ложь);
		
	ОткрытьФорму(ПолноеИмяФормы, ПараметрыФормы, Владелец, Истина);
	
КонецПроцедуры

Функция ПолноеИмяФормыЗначения(Значение)
	
	Возврат Неопределено;
	
КонецФункции

#КонецОбласти