#Область ПрограммныйИнтерфейс

Функция Исполнить(Параметры, АдресРезультата) Экспорт
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("УникальныйИдентификатор", Параметры.Строка);
	
	Результат = ИТК_КонсольКодаКлиентСервер.Исполнить(Параметры.Код, Параметры.Параметры,
										ИТК_КонсольКодаКлиентСервер.КонтекстСервер(), ДополнительныеПараметры);
	
	ПоместитьВоВременноеХранилище(Результат, АдресРезультата);
	Возврат Результат;
	
КонецФункции

Процедура ПодготовкаДанныхДополнение(Тип, Поля, Данные) Экспорт

	Если Тип <> ИТК_Перечисления.ЭлементДанныхКод() Тогда
		Возврат;
	КонецЕсли;
	
	Если Данные.Контекст = ИТК_КонсольКодаКлиентСервер.КонтекстКлиент() Тогда
		Поля.Вставить("Context", "Client");
	КонецЕсли;

	Если ЗначениеЗаполнено(Данные.Текст) Тогда
		Поля.Вставить("Text", Данные.Текст);
	КонецЕсли;
	
	// Параметры
	Если ЗначениеЗаполнено(Данные.Параметры) Тогда

		ПараметрыКода = Новый Соответствие;
		Для Каждого ОписаниеПараметра Из Данные.Параметры Цикл 
			ПараметрыКода.Вставить(ОписаниеПараметра.Ключ, ОписаниеПараметра.Значение);
		КонецЦикла;
		
		Поля.Вставить("CodeParametrs", ПараметрыКода);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗагрузкаДанныхДополнение(Тип, Строка, Данные) Экспорт

	Если Тип <> ИТК_Перечисления.ЭлементДанныхКод() Тогда
		Возврат;
	КонецЕсли;
	
	КонтекстВДанных = ИТК_ОбщийКлиентСервер.Свойство(Данные, "Context");
	Если КонтекстВДанных = Неопределено Тогда
		КонтекстВыполнения = ИТК_КонсольКодаКлиентСервер.КонтекстСервер();
	Иначе
		КонтекстВыполнения = ИТК_КонсольКодаКлиентСервер.КонтекстКлиент();
	КонецЕсли;
    Строка.Контекст = КонтекстВыполнения;

	Строка.Текст = ИТК_ОбщийКлиентСервер.Свойство(Данные, "Text");
	ИТК_КонсолиКлиентСервер.СброситьОригинальныйТекстДанныхДереваДанных(Строка);
	
	// Параметры
	Параметры = ИТК_ОбщийКлиентСервер.Свойство(Данные, "Parameters");
	Если ЗначениеЗаполнено(Параметры) Тогда
		
		Для Каждого ОписаниеПараметра Из Параметры Цикл 
			Строка.Параметры.Вставить(ОписаниеПараметра.Ключ, ОписаниеПараметра.Значение);
		КонецЦикла;
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

