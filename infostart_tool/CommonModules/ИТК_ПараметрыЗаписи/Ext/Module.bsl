#Область ПрограммныйИнтерфейс

Процедура СоздатьЭлементыИРеквизиты(Форма, Родитель, ИспользоватьБезПроверок = Истина) Экспорт
	
	ИмяПараметраБезПроверок = ИТК_ПараметрыЗаписиКлиентСервер.ИмяПараметраБезПроверок();
	ИмяПараметраОтключитьМеханизмРегистрации = ИТК_ПараметрыЗаписиКлиентСервер.ИмяПараметраОтключитьМеханизмРегистрацииВФорме();
	ИмяПараметраПропуститьПроверкуЗапретаИзменения = ИТК_ПараметрыЗаписиКлиентСервер.ИмяПараметраПропуститьПроверкуЗапретаИзмененияВФорме();
	ИмяПараметраПривилегированный = ИТК_ПараметрыЗаписиКлиентСервер.ИмяПараметраПривилегированный();
	ИмяПараметраДополнительныйСвойства = ИТК_ПараметрыЗаписиКлиентСервер.ИмяПараметраДополнительныйСвойства();
	
	// Добавляем реквизиты
	ДобавляемыеРеквизиты = Новый Массив;
	Если ИспользоватьБезПроверок Тогда
		ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, ИмяПараметраБезПроверок, "Булево");
	КонецЕсли;
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, ИмяПараметраОтключитьМеханизмРегистрации, "Булево");
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, ИмяПараметраПропуститьПроверкуЗапретаИзменения, "Булево");
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, ИмяПараметраПривилегированный, "Булево");
	ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, ИмяПараметраДополнительныйСвойства, "СписокЗначений");
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	// Добавляем элементы
	Если ИспользоватьБезПроверок Тогда
		
		Поля = Новый Структура;
		Поля.Вставить("Заголовок", НСтр("ru = 'Без проверок (режим загрузки)';
										|en = 'No checks (boot mode)'"));
		Поля.Вставить("ПоложениеЗаголовка", ПоложениеЗаголовкаЭлементаФормы.Право);
		Поля.Вставить("Подсказка", НСтр("ru = 'ОбменДанными.Загрузка = Истина';
										|en = 'DataExchange.Load = True'"));
		Поля.Вставить("ОтображениеПодсказки", ОтображениеПодсказки.Кнопка);
		Поля.Вставить("ПутьКДанным", ИмяПараметраБезПроверок);
		ИТК_Форма.ДобавитьЭлемент(Форма, ИмяПараметраБезПроверок, "ПолеФлажка", Поля, Родитель);
		
	КонецЕсли;
	
	Поля = Новый Структура;
	Поля.Вставить("Заголовок", НСтр("ru = 'Отключить механизм регистрации';
									|en = 'Disable registration mechanism'"));
	Поля.Вставить("ПоложениеЗаголовка", ПоложениеЗаголовкаЭлементаФормы.Право);
	Поля.Вставить("ПутьКДанным", ИмяПараметраОтключитьМеханизмРегистрации);
	ИТК_Форма.ДобавитьЭлемент(Форма, ИмяПараметраОтключитьМеханизмРегистрации, "ПолеФлажка", Поля, Родитель);
	
	Поля = Новый Структура;
	Поля.Вставить("Заголовок", НСтр("ru = 'Пропустить проверку запрета изменения';
									|en = 'Skip the test ban changes'"));
	Поля.Вставить("ПоложениеЗаголовка", ПоложениеЗаголовкаЭлементаФормы.Право);
	Поля.Вставить("ПутьКДанным", ИмяПараметраПропуститьПроверкуЗапретаИзменения);
	ИТК_Форма.ДобавитьЭлемент(Форма, ИмяПараметраПропуститьПроверкуЗапретаИзменения, "ПолеФлажка", Поля, Родитель);

	Поля = Новый Структура;
	Поля.Вставить("Заголовок", НСтр("ru = 'Привилегированный';
									|en = 'Privileged'"));
	Поля.Вставить("ПоложениеЗаголовка", ПоложениеЗаголовкаЭлементаФормы.Право);
	Поля.Вставить("ПутьКДанным", ИмяПараметраПривилегированный);
	ИТК_Форма.ДобавитьЭлемент(Форма, ИмяПараметраПривилегированный, "ПолеФлажка", Поля, Родитель);
	
	ИмяКоманды = "ДополнительныеСвойства";
	ИТК_Форма.ДобавитьКоманду(Форма, ИмяКоманды, ИТК_ПараметрыЗаписиКлиентСервер.ИмяОбработчикаКоманд(),
								НСтр("ru = 'Дополнительные свойства';
									|en = 'Additional properties'"));
		
	Поля = Новый Структура;
	Поля.Вставить("ИмяКоманды", ИмяКоманды);
	Поля.Вставить("Вид", ВидКнопкиФормы.Гиперссылка);
	ИТК_Форма.ДобавитьЭлемент(Форма, ИмяКоманды, "Кнопка", Поля, Родитель);

КонецПроцедуры

Процедура Установка(Объект, Загрузка, ДополнительныеСвойства) Экспорт
	
	Если Загрузка Тогда
		Объект.ОбменДанными.Загрузка = Загрузка;
	КонецЕсли;
	
	Для Каждого ДополнительноеСвойство Из ДополнительныеСвойства Цикл 
		Объект.ДополнительныеСвойства.Вставить(ДополнительноеСвойство.Ключ, ДополнительноеСвойство.Значение);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти
