	ОписаниеИнструмента["Порядок"] = 65;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментОбработкаВКонсолиКода(), ОписаниеИнструмента);

	// Пользователи
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Обработка.ИТК_Пользователи";
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Пользователи';
												|en = 'Users'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.Пользователь;
	ОписаниеИнструмента["СочетаниеКлавиш"] = Новый СочетаниеКлавиш(Клавиша.U, Истина, , Истина);
	
	Результат.Вставить(ИТК_Перечисления.ИнструментПользователи(), ОписаниеИнструмента);
	
	// Редактор объекта
