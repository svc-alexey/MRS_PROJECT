#Область ПрограммныйИнтерфейс

Функция СоответствиеОписаниеИнструментов() Экспорт
	
	Результат = Новый Соответствие;
	
	// Все инструменты
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Доступ"] = Истина;
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Все инструменты';
												|en = 'All instruments'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ИТК_Подсистема;
	ОписаниеИнструмента["СочетаниеКлавиш"] = Новый СочетаниеКлавиш(Клавиша.T, Истина);
	
	Результат.Вставить(ИТК_Перечисления.Инструменты(), ОписаниеИнструмента);
	
	// Открыть объект
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Доступ"] = Истина;
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Открыть объект';
												|en = 'Open object'");
	ОписаниеИнструмента["ПредставленияДействия"] = НСтр("ru = 'Открыть объект';
														|en = 'Open object'");
	ОписаниеИнструмента["ПредставленияДействияКратко"] = НСтр("ru = 'Открыть';
														|en = 'Open'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ПоказатьДанные;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментОткрытьОбъект(), ОписаниеИнструмента);
	
	// Копировать навигационную ссылку в буфер обмена
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Доступ"] = Истина;
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Копировать навигационную ссылку';
												|en = 'Copy navigation link'");
