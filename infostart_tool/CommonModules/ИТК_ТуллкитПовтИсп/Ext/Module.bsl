	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ИТК_КопироватьВБуферОбмена;
	ОписаниеИнструмента["Порядок"] = 1000;
	ОписаниеИнструмента["ДоступенДляПеречислений"] = Истина;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментКопироватьНавигационнуюСсылку(), ОписаниеИнструмента);
	
	// Форма списка
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Доступ"] = Истина;
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Форма списка';
												|en = 'List form'");
	ОписаниеИнструмента["ПредставленияДействия"] = НСтр("ru = 'Открыть форму списка';
														|en = 'Open list form'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ПоказатьВСписке;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментФормаСписка(), ОписаниеИнструмента);
	
	// Универсальная форма выбора
