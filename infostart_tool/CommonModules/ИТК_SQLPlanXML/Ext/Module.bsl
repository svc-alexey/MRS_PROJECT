#Область ПрограммныйИнтерфейс

Функция ПолучитьДанные(Данные, ОтображатьВТерминах) Экспорт
	
	ПотокЗаписи = Новый ПотокВПамяти;
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.ОткрытьПоток(ПотокЗаписи);
	
	ЗаписатьЗаголовок(ЗаписьXML);
	
	Параметры = Новый Структура;
	Параметры.Вставить("ОтображатьВТерминах1С", (ОтображатьВТерминах = "1С"));
	
	Номер = 1;
	Если ТипЗнч(Данные) = Тип("Массив") Тогда
		
		Для Каждого Строка Из Данные Цикл 
			ЗаписатьЗапрос(ЗаписьXML, Параметры, Строка, Номер);
			Номер = Номер + 1;
		КонецЦикла;
		
	Иначе
		
		ЗаписатьЗапрос(ЗаписьXML, Параметры, Данные);
		
	КонецЕсли;
	
	ЗакончитьЗапись(ЗаписьXML);

	Возврат ПотокЗаписи.ЗакрытьИПолучитьДвоичныеДанные();
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаписатьЗаголовок(ЗаписьXML)
	
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	ЗаписьXML.ЗаписатьНачалоЭлемента("ShowPlanXML");
	ЗаписьXML.ЗаписатьАтрибут("xmlns", "http://schemas.microsoft.com/sqlserver/2004/07/showplan");
	ЗаписьXML.ЗаписатьАтрибут("Version", "1.6");
	ЗаписьXML.ЗаписатьАтрибут("Build", "14.0.2002.14");
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("BatchSequence");
	ЗаписьXML.ЗаписатьНачалоЭлемента("Batch");
	ЗаписьXML.ЗаписатьНачалоЭлемента("Statements");
	
КонецПроцедуры

Процедура ЗакончитьЗапись(ЗаписьXML)
	
	ЗаписьXML.ЗаписатьКонецЭлемента();
	ЗаписьXML.ЗаписатьКонецЭлемента();
	ЗаписьXML.ЗаписатьКонецЭлемента();
	ЗаписьXML.ЗаписатьКонецЭлемента();
	ЗаписьXML.Закрыть();
	
КонецПроцедуры

Процедура ЗаписатьЗапрос(ЗаписьXML, Параметры, ГлавнаяСтрока, Номер = 1)
	
	Строка = ГлавнаяСтрока.Строки[0];
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("StmtSimple");
	
	Если Параметры.ОтображатьВТерминах1С Тогда
		StatementText = ГлавнаяСтрока.SQLЗапрос1С;
	Иначе
		StatementText = ГлавнаяСтрока.SQLЗапрос;
	КонецЕсли;
	ЗаписьXML.ЗаписатьАтрибут("StatementText", XMLСтрока(StatementText));
	
	ЗаписьXML.ЗаписатьАтрибут("StatementId", XMLСтрока(Номер));
	ЗаписьXML.ЗаписатьАтрибут("StatementType", ОператорЗапроса(Строка.Оператор));
	ЗаписьXML.ЗаписатьАтрибут("StatementSubTreeCost", XMLСтрока(Строка.Стоимость));
	ЗаписьXML.ЗаписатьАтрибут("StatementEstRows", XMLСтрока(Строка.СтрокиФакт));
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("QueryPlan");
	ЗаписьПлана(ЗаписьXML, Параметры, ГлавнаяСтрока);
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
КонецПроцедуры

Процедура ЗаписьПлана(ЗаписьXML, Параметры, СтрокаПлана)
	
	Для Каждого Строка Из СтрокаПлана.Строки Цикл 
		
		// <OuterReferences>
		// <ColumnReference Database="[mcr]" Schema="[dbo]" Table="[_Document39]" Column="_Fld2575RRef" Alias="[T1]"/>
		// </OuterReferences>	

		ЗаписьXML.ЗаписатьНачалоЭлемента("RelOp");
		ЗаписьXML.ЗаписатьАтрибут("PhysicalOp", Строка.Оператор);
		ЗаписьXML.ЗаписатьАтрибут("EstimatedExecutionMode", "Row");
		
		ЗаписьXML.ЗаписатьАтрибут("EstimatedTotalSubtreeCost", XMLСтрока(Строка.Стоимость));
		ЗаписьXML.ЗаписатьАтрибут("AvgRowSize", XMLСтрока(Строка.СреднийРазмерСтроки));
		ЗаписьXML.ЗаписатьАтрибут("EstimateRows", XMLСтрока(Строка.СтрокиФакт));
		ЗаписьXML.ЗаписатьАтрибут("EstimateCPU", XMLСтрока(Строка.ЗагрузкаЦП));
		ЗаписьXML.ЗаписатьАтрибут("EstimateIO", XMLСтрока(Строка.ЗатратыВводВывод));
		
		ОписаниеЛогическогоОператора = ЛогическийОператор(Строка);
		ВложенныйБлок = ОписаниеЛогическогоОператора.ВложенныйБлок;
		ЛогическийОператор = ОписаниеЛогическогоОператора.ЛогическийОператор;
		
		Если ЗначениеЗаполнено(ЛогическийОператор) Тогда
			ЗаписьXML.ЗаписатьАтрибут("LogicalOp", ЛогическийОператор);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ВложенныйБлок) Тогда
			ЗаписьXML.ЗаписатьНачалоЭлемента(ВложенныйБлок);
		КонецЕсли;
		
		ЗаписьПлана(ЗаписьXML, Параметры, Строка);
		
		Если ЗначениеЗаполнено(ВложенныйБлок) Тогда
			ЗаписьXML.ЗаписатьКонецЭлемента();
		КонецЕсли;
		
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
	КонецЦикла;
	
КонецПроцедуры

Функция ОператорЗапроса(Оператор)
	
	Если СтрНайти(Оператор, "Insert") Тогда
		Результат = "INSERT";
	Иначе
		Результат = "SELECT";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЛогическийОператор(Строка)
	
	ВложенныйБлок = ""; 
	Если Строка.Оператор = "Table Insert" Тогда
		
		ВложенныйБлок = "Update";
		
	ИначеЕсли Строка.Оператор = "Clustered Index Seek"
			ИЛИ Строка.Оператор = "Index Seek" Тогда
			
		ВложенныйБлок = "IndexScan";
		
	ИначеЕсли Строка.Оператор = "Concatenation" Тогда
		
		ВложенныйБлок = "Concat";
		
	Иначе
		
		ВложенныйБлок = СтрЗаменить(Строка.Оператор, " ", "");
		
	КонецЕсли;
	
	ЛогическийОператор = "";
	Если Строка.Оператор = "Table Insert" Тогда
		
		ЛогическийОператор = "Insert";
		
	ИначеЕсли Строка.Оператор = "Nested Loops" Тогда
		
		ЛогическийОператор = ЛогическийОператорNestedLoops(Строка.План);
		
	Иначе
		
		ЛогическийОператор = Строка.Оператор;
		
	КонецЕсли;
	
	Возврат Новый Структура("ЛогическийОператор, ВложенныйБлок", ЛогическийОператор, ВложенныйБлок);
	
КонецФункции

Функция ЛогическийОператорNestedLoops(План)
	
	Индекс = 1;
	Оператор = ИТК_Строки.РазборПрочитатьДоСимвола(План, "(", Индекс);
	ИТК_Строки.РазборПропуститьНаборСимволов(План, "(", Индекс);
	ЛогическийОператор = ИТК_Строки.РазборПрочитатьДоСимвола(План, ",", Индекс);
	
	Возврат ЛогическийОператор;
	
КонецФункции

#КонецОбласти
