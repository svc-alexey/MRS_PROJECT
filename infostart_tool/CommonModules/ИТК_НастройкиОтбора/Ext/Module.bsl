#Область ПрограммныйИнтерфейс

Функция СхемаКомпоновкиДанных(Объект) Экспорт
	
	ПоДоступнымТипам = (ТипЗнч(Объект) = Тип("Массив"));
	ОсновноеИмяНабора = "НаборДанных";
	
	Результат = Новый СхемаКомпоновкиДанных;
	
	ИсточникДанных = Результат.ИсточникиДанных.Добавить();
	ИсточникДанных.Имя = "ИсточникДанных";
	ИсточникДанных.ТипИсточникаДанных = "local";
	
	Если ПоДоступнымТипам Тогда
		
		НаборДанных = Результат.НаборыДанных.Добавить(Тип("НаборДанныхОбъектСхемыКомпоновкиДанных"));
		НаборДанных.Имя = ОсновноеИмяНабора;
		НаборДанных.ИсточникДанных = ИсточникДанных.Имя;
		
		ДоступныеПоля = Новый ТаблицаЗначений;
		ДоступныеПоля.Колонки.Добавить("Имя", ИТК_ТипыКлиентСервер.ОписаниеИмяМетаданных());
		ДоступныеПоля.Колонки.Добавить("ТипЗначения", Новый ОписаниеТипов("ОписаниеТипов"));
		
		ДоступныеПоля.Индексы.Добавить("Имя");
		
		Для Каждого ПолноеИмяМетаданных Из Объект Цикл 
			
			ДобавитьДоступныеПоляОбъектаМетаданных(ДоступныеПоля, ПолноеИмяМетаданных);
			
		КонецЦикла;
		
		Для Каждого ДоступноеПоле Из ДоступныеПоля Цикл 
			
			НовоеПоле = НаборДанных.Поля.Добавить(Тип("ПолеНабораДанныхСхемыКомпоновкиДанных"));
			НовоеПоле.Поле = ДоступноеПоле.Имя;
			НовоеПоле.ТипЗначения = ДоступноеПоле.ТипЗначения;
			
		КонецЦикла;
		
	Иначе
		
		ИмяОбъектаКоллекции = ИТК_Метаданные.ИмяОбъектаКоллекции(Объект);
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоРегистрСведений(ИмяОбъектаКоллекции) Тогда
			
			НаборДанных = Результат.НаборыДанных.Добавить(Тип("НаборДанныхОбъектСхемыКомпоновкиДанных"));
			НаборДанных.Имя = ОсновноеИмяНабора;
			НаборДанных.ИмяОбъекта = ОсновноеИмяНабора;
			НаборДанных.ИсточникДанных = ИсточникДанных.Имя;
			
			ТипыКлючейРегистраСведений = ИТК_Метаданные.ТипыКлючейРегистраСведений(Объект);
			Для Каждого Поле Из ТипыКлючейРегистраСведений Цикл 
				
				НовоеПоле = НаборДанных.Поля.Добавить(Тип("ПолеНабораДанныхСхемыКомпоновкиДанных"));
				НовоеПоле.Поле = Поле.Представление;
				НовоеПоле.ТипЗначения = Поле.Значение;
				
			КонецЦикла;
			
		Иначе
			
			НаборДанных = Результат.НаборыДанных.Добавить(Тип("НаборДанныхЗапросСхемыКомпоновкиДанных"));
			НаборДанных.Имя = ОсновноеИмяНабора;
			НаборДанных.ИсточникДанных = ИсточникДанных.Имя;
			НаборДанных.Запрос = СтрШаблон("ВЫБРАТЬ * ИЗ %1 ГДЕ Ссылка В (&Ссылки)", Объект);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОбрабатываемыеСсылки(ИмяОбъектаМетаданных, Настройки, Ссылки) Экспорт
	
	ИмяКоллекцииМетаданных = ИТК_Метаданные.ИмяОбъектаКоллекции(ИмяОбъектаМетаданных);
	ВнешниеНаборыДанных = Новый Структура;
	ЭтоРегистрСведений = ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоРегистрСведений(ИмяКоллекцииМетаданных);
	
	Если ЭтоРегистрСведений Тогда
		
		ТаблицаЗначенийСсылки = Новый ТаблицаЗначений;
		
		ТипыКлючейРегистраСведений = ИТК_Метаданные.ТипыКлючейРегистраСведений(ИмяОбъектаМетаданных);
		Для Каждого Ключ Из ТипыКлючейРегистраСведений Цикл 
			
			ТаблицаЗначенийСсылки.Колонки.Добавить(Ключ.Представление, Ключ.Значение);
			
		КонецЦикла;
		
		Для Каждого КлючиЗаписиРегистраСведений Из Ссылки Цикл 
			
			НоваяСтрока = ТаблицаЗначенийСсылки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, КлючиЗаписиРегистраСведений);
			
		КонецЦикла;
		
		Ключи = ИТК_Метаданные.КлючиРегистраСведений(ИмяОбъектаМетаданных);
		ВнешниеНаборыДанных.Вставить("НаборДанных", ТаблицаЗначенийСсылки);
		
	Иначе
		
		Ключи = Новый Массив;
		
		ПолеСсылка = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Ссылка");
		Ключи.Добавить(ПолеСсылка);
		
	КонецЕсли;
	
	// Инициализация схемы
	СхемаКомпоновкиДанных = ИТК_НастройкиОтбора.СхемаКомпоновкиДанных(ИмяОбъектаМетаданных);
	
	// Инициализация настроек
	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаКомпоновкиДанных));
	КомпоновщикНастроек.ЗагрузитьНастройки(Настройки);
	
	НастройкиКомпоновщика = КомпоновщикНастроек.Настройки;
	
	// Отключим неприменимые отборы
	Для Каждого ЭлементОтбора Из НастройкиКомпоновщика.Отбор.Элементы Цикл 
		
		ЭлементОтбора.Использование = (НастройкиКомпоновщика.Отбор.ДоступныеПоляОтбора.НайтиПоле(ЭлементОтбора.ЛевоеЗначение) <> Неопределено);
		
	КонецЦикла;
	
	// Добавление выводимых полей
	ГруппировкаКомпоновкиДанных = НастройкиКомпоновщика.Структура.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
	
	Для Каждого Ключ Из Ключи Цикл 
		
		ПолеГруппировки =  ГруппировкаКомпоновкиДанных.Выбор.Элементы.Добавить(Тип("ВыбранноеПолеКомпоновкиДанных"));
		ПолеГруппировки.Поле = Новый ПолеКомпоновкиДанных(Ключ);
		
	КонецЦикла;
	
	// Инициализация макета компоновки
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, НастройкиКомпоновщика, , ,	Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	// Установка параметров
	НовыйПараметр = МакетКомпоновки.ЗначенияПараметров.Добавить();
	НовыйПараметр.Имя = "Ссылки";
	НовыйПараметр.Значение = Ссылки;
	
	// Выполнение компоновки, получение результата
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки, ВнешниеНаборыДанных);
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	
	ТаблицаЗначений = Новый ТаблицаЗначений;
	ПроцессорВывода.УстановитьОбъект(ТаблицаЗначений);
	ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	
	Если ЭтоРегистрСведений Тогда
		
		// Подготавливаем ключ записи регистра сведений
		МенеджерРегистраСведений = ИТК_Метаданные.МенеджерОбъектаПоПолномуИмени(ИмяОбъектаМетаданных);
		
		КлючиРегистраСведений = Новый Структура;
		Для Каждого Ключ Из Ключи Цикл 
			КлючиРегистраСведений.Вставить(Ключ);
		КонецЦикла;
		
		Результат = Новый Массив;
		Для Каждого Строка Из ТаблицаЗначений Цикл 
			
			ЗаполнитьЗначенияСвойств(КлючиРегистраСведений, Строка);
			КлючЗаписи = МенеджерРегистраСведений.СоздатьКлючЗаписи(КлючиРегистраСведений);
			
			Результат.Добавить(КлючЗаписи);
			
		КонецЦикла;
		
	Иначе
		
		Колонки = СтрСоединить(Ключи, ",");
		Результат = ТаблицаЗначений.ВыгрузитьКолонку(Колонки);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ДобавитьДоступныеПоляОбъектаМетаданных(ДоступныеПоля, ПолноеИмяМетаданных)
	
	ОбъектМетаданных = Метаданные.НайтиПоПолномуИмени(ПолноеИмяМетаданных);
	
	Если ИТК_Метаданные.ЭтоРегистрСведений(ОбъектМетаданных) Тогда
		
		ТипыКлючейРегистраСведений = ИТК_Метаданные.ТипыКлючейРегистраСведений(ПолноеИмяМетаданных);
		Для Каждого ТипКлюча Из ТипыКлючейРегистраСведений Цикл 
			ДобавитьДоступноеПоле(ДоступныеПоля, ТипКлюча.Представление, ТипКлюча.Значение);
		КонецЦикла;
		
		Возврат;
		
	КонецЕсли;
	
	ДобавитьДоступныеПоляКоллекцииРеквизитов(ДоступныеПоля, ОбъектМетаданных.СтандартныеРеквизиты);
	ДобавитьДоступныеПоляКоллекцииРеквизитов(ДоступныеПоля, ОбъектМетаданных.Реквизиты);
	
	Если ИТК_Метаданные.ЭтоЗадача(ОбъектМетаданных) Тогда
		
		ДобавитьДоступныеПоляКоллекцииРеквизитов(ДоступныеПоля, ОбъектМетаданных.РеквизитыАдресации);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьДоступныеПоляКоллекцииРеквизитов(ДоступныеПоля, КоллекцияРеквизитов)
	
	Для Каждого Реквизит Из КоллекцияРеквизитов Цикл 
		
		ДобавитьДоступноеПоле(ДоступныеПоля, Реквизит.Имя, Реквизит.Тип);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьДоступноеПоле(ДоступныеПоля, Имя, ТипЗначения)
	
	НайденнаяСтрока = ДоступныеПоля.Найти(Имя, "Имя");
	
	Если НайденнаяСтрока = Неопределено Тогда
		
		НоваяСтрока = ДоступныеПоля.Добавить();
		НоваяСтрока.Имя = Имя;
		НоваяСтрока.ТипЗначения = ТипЗначения;
		
	Иначе
		
		НайденнаяСтрока.ТипЗначения = ИТК_ТипыКлиентСервер.СложитьОписания(НайденнаяСтрока.ТипЗначения, ТипЗначения);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти