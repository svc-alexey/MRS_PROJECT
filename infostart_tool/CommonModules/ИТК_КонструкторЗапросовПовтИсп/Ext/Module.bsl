	Соответствие.Вставить(ИТК_МетаданныеКлиентСерверПовтИсп.ИмяКоллекции("РегистрБухгалтерии", Язык), БиблиотекаКартинок.РегистрБухгалтерии);
	Соответствие.Вставить(ИТК_МетаданныеКлиентСерверПовтИсп.ИмяКоллекции("РегистрРасчета", Язык), БиблиотекаКартинок.РегистрРасчета);
