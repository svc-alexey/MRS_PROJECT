#Область ПрограммныйИнтерфейс

// Получает подсказку к описанию типа
//
// Параметры:
//   Параметры - Структуры - Параметры
//   	*Код - Строка - Код
//   	*КодПеред - Строка - Код (перед)
//   	*КодПосле - Строка - Код (после)
//   	*ПрерыватьПриОшибке - Булево - Код (после)
//   	*Транзакция - ТипТранзакцииОбработкиРезультата - Тип транзакции
//
// Возвращаемое значение:
//   Структура	- Описание алгоритма
//
Функция ОписаниеАлгоритмаОбработки(Параметры = Неопределено) Экспорт
	
	Если Параметры = Неопределено Тогда
		Параметры = Новый Структура;
	КонецЕсли;
	
	Код = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "Код", "");
	КодПеред = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "КодПеред", "");
	КодПосле = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "КодПосле", "");
	ПрерыватьПриОшибке = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "ПрерыватьПриОшибке", Ложь);
	Транзакция = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "Транзакция", Неопределено);
	
	Результат = Новый Структура;
	Результат.Вставить("Код", Код);
	Результат.Вставить("КодПеред", КодПеред);
	Результат.Вставить("КодПосле", КодПосле);
	
	Если ПрерыватьПриОшибке = Неопределено Тогда
		
		ПрерыватьПриОшибке = Ложь;
		
	КонецЕсли;
	Результат.Вставить("ПрерыватьПриОшибке", ПрерыватьПриОшибке);
	
	Если Транзакция = Неопределено Тогда
		
		Транзакция = ТипТранзакцииОбработкиРезультатаПоУмолчанию();
		
	КонецЕсли;
	Результат.Вставить("Транзакция", Транзакция);
	
	Возврат Результат;
	
КонецФункции

Функция ТипТранзакцииОбработкиРезультатаПоУмолчанию() Экспорт
	
	Возврат ИТК_Перечисления.ТипТранзакцииОбработкиРезультатаПоСтроке();
	
КонецФункции

// Значение вывода таблицы значений по умолчанию
//
// Возвращаемое значение:
//   Перечисление.ИТК_ВыводТаблицы - Значение по умолчанию вывода таблицы значений
//
Функция ВыводТаблицыЗначениеПоУмолчанию() Экспорт
	
	Возврат ИТК_Перечисления.ВидВыводаТаблицыВыводить();
	
КонецФункции

#КонецОбласти
