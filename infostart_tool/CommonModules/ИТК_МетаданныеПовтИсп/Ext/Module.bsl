#Область ПрограммныйИнтерфейс

Функция ТипВсеСсылкиКоллекции(Имя) Экспорт
	
	Если ИТК_Строки.НекорректныйИдентификатор(Имя) Тогда
		ВызватьИсключение "Некорректное имя менеджера";
	КонецЕсли;
	
	Менеджер = МенеджерПоИмени(Имя);
	
	Возврат Менеджер.ТипВсеСсылки();
	
КонецФункции

Функция ОписаниеСсылочныхТипов() Экспорт
	
	Результат = Новый ТаблицаЗначений;	
	Результат.Колонки.Добавить("Имя");
	Результат.Колонки.Добавить("Менеджер");
	Результат.Колонки.Добавить("Метаданные");
	
	ДобавитьОписаниеСсылочногоТипа(Результат, "Справочник");
	ДобавитьОписаниеСсылочногоТипа(Результат, "Документ");
	ДобавитьОписаниеСсылочногоТипа(Результат, "ПланВидовХарактеристик");
	ДобавитьОписаниеСсылочногоТипа(Результат, "ПланСчетов");
	ДобавитьОписаниеСсылочногоТипа(Результат, "ПланВидовРасчета");
	ДобавитьОписаниеСсылочногоТипа(Результат, "ПланОбмена");
	ДобавитьОписаниеСсылочногоТипа(Результат, "БизнесПроцесс");
	ДобавитьОписаниеСсылочногоТипа(Результат, "Задача");

	Возврат Результат;
	
КонецФункции

Функция МенеджерПоИмени(Имя) Экспорт
	
	Если ИТК_Строки.НекорректныйИдентификатор(Имя) Тогда
		ВызватьИсключение "Некорректное имя менеджера";
	КонецЕсли;
	
	// Опасности не представляет т.к. это должен быть идентификатор и это проверяется выше
	// BSLLS:ExecuteExternalCodeInCommonModule-off
	Результат = Вычислить(Имя);
	// BSLLS:ExecuteExternalCodeInCommonModule-on
	
	Возврат Результат;
	
КонецФункции

Функция КэшФункциональныхОпций() Экспорт
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Имя", ИТК_ТипыКлиентСервер.ОписаниеИмяМетаданных());
	Результат.Колонки.Добавить("ПолноеИмяОбъекта", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	Результат.Колонки.Добавить("ОбъектМетаданных");
	Результат.Колонки.Добавить("Объект", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	
	Для Каждого ФункциональнаяОпция Из Метаданные.ФункциональныеОпции Цикл 
		
		Для Каждого СоставФункциональнойОпции Из ФункциональнаяОпция.Состав Цикл 
			
			ОбъектВСоставе = СоставФункциональнойОпции.Объект;
			Если ОбъектВСоставе = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			НоваяСтрока = Результат.Добавить();
			НоваяСтрока.Имя = ФункциональнаяОпция.Имя;
			НоваяСтрока.ОбъектМетаданных = ФункциональнаяОпция;
			НоваяСтрока.ПолноеИмяОбъекта = ОбъектВСоставе.ПолноеИмя();
			
			ЧастиИмени = СтрРазделить(ОбъектВСоставе.ПолноеИмя(), ".");
			НоваяСтрока.Объект = ЧастиИмени[0] + "." + ЧастиИмени[1];
			
		КонецЦикла;
		
	КонецЦикла;
	
	// Добавляем индексы
	Результат.Индексы.Добавить("Объект");
	
	Возврат Результат;
	
КонецФункции

Функция КэшИменКоллекции(Имя, ПроверятьПрава = Истина) Экспорт
	
	Результат = Новый СписокЗначений;
	ИмяПраваДоступа = ИТК_МетаданныеКлиентСерверПовтИсп.Право(Имя);
	
	КоллекцияМетаданных = КоллекцияМетаданныхПоИмени(Имя);
	Для Каждого ОбъектМетаданных Из КоллекцияМетаданных Цикл 
		
		Если ПроверятьПрава
				И ЗначениеЗаполнено(ИмяПраваДоступа)
				И НЕ ПравоДоступа(ИмяПраваДоступа, ОбъектМетаданных) Тогда
			Продолжить;
		КонецЕсли;
		
		Результат.Добавить( , ОбъектМетаданных.Имя);
		
	КонецЦикла;

	Результат.СортироватьПоПредставлению();
	
	Возврат Результат;
	
КонецФункции

Функция КэшПредставленийИИменКоллекции(Имя) Экспорт
	
	Результат = Новый СписокЗначений;
	
	КоллекцияМетаданных = Метаданные[Имя];
	Для Каждого ОбъектМетаданных Из КоллекцияМетаданных Цикл 
		Результат.Добавить(ОбъектМетаданных.Имя, ОбъектМетаданных.Представление());
	КонецЦикла;

	Результат.СортироватьПоПредставлению();
	
	Возврат Результат;
	
КонецФункции

Функция КоллекцияМетаданныхПоИмени(Имя) Экспорт
	
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоТочкаМаршрутаБизнесПроцесса(Имя) Тогда
		
		Результат = Метаданные.БизнесПроцессы;
		
	Иначе
		
		Результат = Метаданные[Имя];
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СуществуетОбщийМодуль(Имя) Экспорт
	
	Возврат (Метаданные.ОбщиеМодули.Найти(Имя) <> Неопределено);
	
КонецФункции

Функция СвойстваПоКоллекции(Коллекция) Экспорт
	
	Результат = Новый ТаблицаЗначений;
	
	Результат.Колонки.Добавить("Имя", ИТК_ТипыКлиентСервер.ОписаниеИмяМетаданных());
	Результат.Колонки.Добавить("Представление", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	Результат.Колонки.Добавить("Важное", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	Результат.Колонки.Добавить("Базовое", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	Результат.Колонки.Добавить("Картинка", ИТК_ТипыКлиентСервер.ОписаниеКартинка());
	Результат.Колонки.Добавить("Порядок", ИТК_ТипыКлиентСервер.ОписаниеЧисло());
	Результат.Колонки.Добавить("ДанныеГиперссылки");
	Результат.Колонки.Добавить("ПреобразоватьВСтроку", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	
	Результат.Колонки.Добавить("Группа", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	Результат.Колонки.Добавить("ГруппаПорядок", ИТК_ТипыКлиентСервер.ОписаниеЧисло());	
	
	Для Каждого КлючЗначение Из ИТК_МетаданныеКлиентСерверПовтИсп.СоответствиеОписаниеСвойств() Цикл 
		
		ОписаниеСвойства = КлючЗначение.Значение;
		
		Если НЕ ИспользуетсяСвойство(ОписаниеСвойства.ОбластьПрименения, Коллекция) Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = Результат.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ОписаниеСвойства);
		
		НоваяСтрока.Имя = КлючЗначение.Ключ;

	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ВсеКоллекцииПоПорядку() Экспорт
	
	ТаблицаЗначений = Новый ТаблицаЗначений;
	ТаблицаЗначений.Колонки.Добавить("Имя", ИТК_ТипыКлиентСервер.ОписаниеИмяМетаданных());
	ТаблицаЗначений.Колонки.Добавить("Порядок", ИТК_ТипыКлиентСервер.ОписаниеЧисло());
	Для Каждого КлючЗначенияКоллекция Из ИТК_МетаданныеКлиентСерверПовтИсп.СоответствиеОписаниеКоллекций() Цикл 
		
		ОписаниеКоллекции = КлючЗначенияКоллекция.Значение;
		
		НоваяСтрока = ТаблицаЗначений.Добавить();
		
		ИмяКоллекции = КлючЗначенияКоллекция.Ключ;
		Если ИТК_ОбщийПовтИсп.ВариантВстроенногоЯзыкаАнглийский() Тогда
			ИмяКоллекции = ОписаниеКоллекции.ИмяНаАнглийском;
		КонецЕсли;
		НоваяСтрока.Имя = ИмяКоллекции;
		
		НоваяСтрока.Порядок = ОписаниеКоллекции.Порядок;
		
	КонецЦикла;
	
	ТаблицаЗначений.Сортировать("Порядок");
	
	Возврат ТаблицаЗначений.ВыгрузитьКолонку("Имя");
	
КонецФункции

Функция ОбъектыВводимыеНаОсновании() Экспорт
	
	Результат = Новый Массив;
	
	Для Каждого ИмяКоллекции Из ИТК_МетаданныеКлиентСерверПовтИсп.КоллекцииВводНаОсновании() Цикл 
		
		Для Каждого ОбъектМетаданных Из Метаданные[ИмяКоллекции] Цикл 
			
			Если ЗначениеЗаполнено(ОбъектМетаданных.ВводитсяНаОсновании) Тогда
				Результат.Добавить(ОбъектМетаданных);
			КонецЕсли;
				
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ИмяКонфигурации() Экспорт
	
	Возврат Метаданные.Имя;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ДобавитьОписаниеСсылочногоТипа(Результат, Имя)
	
	НоваяСтрока = Результат.Добавить();
	НоваяСтрока.Имя = Имя;
	
	ИмяКоллекции = ИТК_МетаданныеКлиентСерверПовтИсп.ИмяКоллекции(Имя);
	НоваяСтрока.Менеджер = МенеджерПоИмени(ИмяКоллекции);
	
	НоваяСтрока.Метаданные = Метаданные[ИмяКоллекции];

КонецПроцедуры

Функция ИспользуетсяСвойство(ОбластьПрименения, Коллекция)
	
	Если ОбластьПрименения = Неопределено Тогда
		Возврат Истина;
	КонецЕсли;
	
	НайденныйЭлемент = ОбластьПрименения.НайтиПоЗначению(Коллекция);
	Если НайденныйЭлемент = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ТребуетсяПлатформа = НайденныйЭлемент.Представление;
	Если НЕ ЗначениеЗаполнено(ТребуетсяПлатформа) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформойИРежимомСовместимости(ТребуетсяПлатформа);
	
КонецФункции

#КонецОбласти
