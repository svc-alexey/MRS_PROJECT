#Область СлужебныйПрограммныйИнтерфейс

Процедура АктивизацияЗначенияВФорме(Элемент, Значение) Экспорт
	
	ОписаниеЗначения = ИТК_ПроизвольноеЗначениеВызовСервера.ОписаниеЗначения(Значение);
	Если ОписаниеЗначения.РедактируетсяВПоле Тогда
		ИТК_ФормаКлиент.АктивизацияЗначенияВФорме(Элемент, ОписаниеЗначения.Значение);
	Иначе
		
		Элемент.ВыбиратьТип = Ложь;
		Элемент.КнопкаВыбора = Истина;
		Элемент.КартинкаКнопкиВыбора = Новый Картинка;
		
	КонецЕсли;
	Элемент.РедактированиеТекста = ОписаниеЗначения.РедактируетсяВПоле;
	
КонецПроцедуры

Процедура ОбработкаНачалоВыбора(Элемент, Значение, ОписаниеОповещенияЗавершение, СтандартнаяОбработка) Экспорт
	
	ЗаголовокФормы = НСтр("ru = 'Значения хранилища'; en = 'Value storage'");
	
	ОписаниеЗначения = ИТК_ПроизвольноеЗначениеВызовСервера.ОписаниеЗначения(Значение);
	Если ОписаниеЗначения.Заполнено Тогда
		
		Если ОписаниеЗначения.РедактируетсяВПоле Тогда
			
			ИТК_ФормаКлиент.ВводЗначенияСтрокиВФорме(
				ЗаголовокФормы, Элемент, ОписаниеЗначения.Значение, ОписаниеЗначения.ТипЗначения, СтандартнаяОбработка, ОписаниеОповещенияЗавершение);
			
		Иначе
			
			Тип = ОписаниеЗначения.ТипЗначения.Типы()[0];
			СтандартнаяОбработка = Ложь;
			Если Тип = Тип("Массив")
					ИЛИ Тип = Тип("ФиксированныйМассив")
					ИЛИ Тип = Тип("Структура")
					ИЛИ Тип = Тип("ФиксированнаяСтруктура")
					ИЛИ Тип = Тип("Соответствие")
					ИЛИ Тип = Тип("ФиксированноеСоответствие") Тогда
				
				ИТК_ФормаКлиент.ОткрытьРедактированиеМассиваСтруктурыСоответствия(Элемент, Значение, ОписаниеОповещенияЗавершение);
				
			ИначеЕсли Тип = Тип("СписокЗначений") Тогда
				
				ИТК_ФормаКлиент.ОткрытьСписокЗначений(ЭтотОбъект, ИТК_Перечисления.ВариантФормыСписокЗначенийРедактированиеСПредставлением(),
					Значение, Новый ОписаниеТипов, ОписаниеОповещенияЗавершение);
				
			ИначеЕсли Тип = Тип("ДвоичныеДанные") Тогда
				
				ИТК_ФормаКлиент.ОткрытьРедактированиеДвоичныхДанных(ЭтотОбъект, Значение, ОписаниеОповещенияЗавершение);
				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		ИТК_ФормаКлиент.ОткрытьРедактированиеТипаЗначения(
			Элемент, ЗаголовокФормы, ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборПроизвольногоТипа(),
			ОписаниеЗначения.ТипЗначенияВКонтейнере, ОписаниеОповещенияЗавершение, СтандартнаяОбработка);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаОчистка(Элемент, СтандартнаяОбработка, Значение) Экспорт
	
	СтандартнаяОбработка = Ложь;
	Значение = ИТК_ПроизвольноеЗначениеВызовСервера.ЗначениеНеопределено();
	
	АктивизацияЗначенияВФорме(Элемент, Значение);
	
КонецПроцедуры

#КонецОбласти
