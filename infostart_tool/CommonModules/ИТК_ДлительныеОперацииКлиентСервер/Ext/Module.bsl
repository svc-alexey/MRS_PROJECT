#Область ПрограммныйИнтерфейс

Процедура СообщениеНачалоОбработкиОбъекта(Индекс) Экспорт
	
	СообщениеПользователю = Новый СообщениеПользователю;
	СообщениеПользователю.Текст = СтрШаблон("%1%2", ПрефиксНачалоОбработкиОбъекта(), ИТК_Строки.ЧислоВСтроку(Индекс));
	СообщениеПользователю.Сообщить();
	
КонецПроцедуры

Процедура СообщениеКонецОбработкиОбъекта(Ошибка) Экспорт
	
	СообщениеПользователю = Новый СообщениеПользователю;
	СообщениеПользователю.Текст = СтрШаблон("%1%2", ПрефиксКонецОбработкиОбъекта(), Ошибка);
	СообщениеПользователю.Сообщить();
	
КонецПроцедуры

Функция ПрочитатьИндексОбъектаИзСообщенияНачала(Текст) Экспорт
	
	Индекс = 1;
	ИТК_Строки.РазборПропуститьНаборСимволов(Текст, ПрефиксНачалоОбработкиОбъекта(), Индекс);
	
	ИндексОбъекта = ИТК_Строки.РазборПрочитатьДоСимвола(Текст, "", Индекс);
	
	Возврат Число(ИндексОбъекта);
	
КонецФункции

Функция ПрочитатьОшибкуОбработкиОбъектаИзСообщенияКонца(Текст) Экспорт
	
	ПрефиксКонец = ПрефиксКонецОбработкиОбъекта();
	
	Если Текст = ПрефиксКонец Тогда
		
		Результат = "";
		
	Иначе
		
		Индекс = 1;
		ИТК_Строки.РазборПропуститьНаборСимволов(Текст, ПрефиксКонец, Индекс);
		Результат = ИТК_Строки.РазборПрочитатьДоСимвола(Текст, "", Индекс);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПрефиксНачалоОбработкиОбъекта() Экспорт
	
	Возврат "{Н}";
	
КонецФункции

Функция ПрефиксКонецОбработкиОбъекта() Экспорт
	
	Возврат "{К}";
	
КонецФункции

