Функция Получить(Ключ, ВключатьЧужые = Ложь) Экспорт
	
	ТекущийПользователь = ПользователиИнформационнойБазы.ТекущийПользователь().Имя;
	
	Отбор = Новый Структура;
	Отбор.Вставить("КлючОбъекта", Ключ);
	
	Если НЕ ВключатьЧужые Тогда
		Отбор.Вставить("Пользователь", ТекущийПользователь);
	КонецЕсли;
	
	НастройкиПользователя = Новый СписокЗначений;
	НастройкиДругихПользователей = Новый СписокЗначений;
	
	Выборка = ХранилищеСистемныхНастроек.Выбрать(Отбор);
	Пока Выборка.Следующий() Цикл 
		
		ОписаниеНастройки = Новый Структура;
		ОписаниеНастройки.Вставить("Ключ", Выборка.КлючНастроек);
		
		Если ЗначениеЗаполнено(Выборка.Представление) Тогда
			ДатаИзменения = Дата(Выборка.Представление);
		Иначе
			ДатаИзменения = ИТК_ОбщийКлиентСервер.ПустаяДата();
		КонецЕсли;
		ОписаниеНастройки.Вставить("ДатаИзменения", ДатаИзменения);
		
		Если Выборка.Пользователь = ТекущийПользователь Тогда
			НастройкиПользователя.Добавить(ОписаниеНастройки, Выборка.КлючНастроек);
		Иначе
			ОписаниеНастройки.Вставить("Пользователь", Выборка.Пользователь);
			НастройкиДругихПользователей.Добавить(ОписаниеНастройки, Выборка.КлючНастроек);
		КонецЕсли;
		
	КонецЦикла;
	
	Результат = Новый Структура;
	
	НастройкиПользователя.СортироватьПоПредставлению();
	Результат.Вставить("Пользователь", НастройкиПользователя);
	
	НастройкиДругихПользователей.СортироватьПоПредставлению();
	Результат.Вставить("Чужие", НастройкиДругихПользователей);
	
	Возврат Результат;
	
КонецФункции

Процедура Сохранить(Ключ, Имя, АдресДанных) Экспорт
	
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресДанных);
	ЗаписываемыеДанные = Новый ХранилищеЗначения(ДвоичныеДанные, Новый СжатиеДанных(9));
	ХранилищеСистемныхНастроек.Сохранить(Ключ, Имя, ЗаписываемыеДанные);
	
КонецПроцедуры

Функция Загрузить(Ключ, Имя, Пользователь = Неопределено) Экспорт
	
	ХранилищеЗначения = ХранилищеСистемныхНастроек.Загрузить(Ключ, Имя, , Пользователь);
	Возврат ХранилищеЗначения.Получить();
	
КонецФункции