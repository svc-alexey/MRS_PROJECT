#Область ПрограммныйИнтерфейс

Функция СоответствиеЭлементДанных(Обратное = Ложь) Экспорт
	
	Результат = Новый Соответствие;
	Результат.Вставить(ИТК_Перечисления.ЭлементДанныхГруппа(), "Group");
	Результат.Вставить(ИТК_Перечисления.ЭлементДанныхКод(), "Code");
	//Результат.Вставить(ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД(), "SettingsVariant");
	//Результат.Вставить(ИТК_Перечисления.ЭлементДанныхПользовательскаяНастройкаСКД(), "UserSettings");
	
	Если Обратное Тогда
		Результат = ИТК_ОбщийКлиентСервер.ОбратноеСоответствие(Результат);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СоответствиеЭлементДанныхКартинка() Экспорт 
	
	Результат = Новый Соответствие;
	Результат.Вставить(ИТК_Перечисления.ЭлементДанныхКод(), "ИТК_Код");
	Результат.Вставить(ИТК_Перечисления.ЭлементДанныхГруппа(), "ИТК_Папка");
	Результат.Вставить(ИТК_Перечисления.ЭлементДанныхЗапрос(), "ИТК_Запрос");
	Результат.Вставить(ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД(), "ИТК_ВариантОтчетаСКД");
	Результат.Вставить(ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных(), "ИТК_СхемаКомпоновкиДанных");
	Результат.Вставить(ИТК_Перечисления.ЭлементДанныхПользовательскаяНастройкаСКД(), "ИТК_ПользовательскаяНастройкаСКД");
	
	Для Каждого КлючЗначения Из Результат Цикл 
		Результат.Вставить(КлючЗначения.Ключ, ИТК_ОбщийКлиентСерверПовтИсп.БиблиотекаКартинок(КлючЗначения.Значение));
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция КартинкаТипаХраненияДанных(Тип) Экспорт
	
	Если Тип = ИТК_Перечисления.ТипХраненияДанныхФайл() Тогда
		
		Результат = БиблиотекаКартинок.ИТК_ТипХраненияДанныхФайл;
		
	ИначеЕсли Тип = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда
		
		Результат = БиблиотекаКартинок.ИТК_ТипХраненияДанныхНастройка;
		
	Иначе
		
		Результат = Новый Картинка;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция КлючНастроекДанные(Инструмент) Экспорт
	
	ПредставлениеИнструмента = ИТК_ТуллкитКлиентСервер.ПредставлениеИнструмента(Инструмент);
	ПредставлениеРасширения = ИТК_ТуллкитКлиентСервер.Представление();
	
	КодЯзыкаПрограммированияКонфигурации = ИТК_ОбщийКлиентСерверПовтИсп.КодЯзыкаПрограммированияКонфигурации();
	Шаблон = НСтр("ru = '%1 (%2) (данные)'; en = '%1 (%2) (data)'", КодЯзыкаПрограммированияКонфигурации);
	
	Результат = СтрШаблон(Шаблон, ПредставлениеИнструмента, ПредставлениеРасширения);
	
	Возврат Результат;
	
КонецФункции

Функция КлючНастроек() Экспорт
	
	КодЯзыкаПрограммированияКонфигурации = ИТК_ОбщийКлиентСерверПовтИсп.КодЯзыкаПрограммированияКонфигурации();
	Шаблон = НСтр("ru = 'Консоли (%1) (настройки)'; en = 'Consoles (%1) (settings)'", КодЯзыкаПрограммированияКонфигурации);
	
	ПредставлениеРасширения = ИТК_ТуллкитКлиентСервер.Представление();
	Результат = СтрШаблон(Шаблон, ПредставлениеРасширения);
	
	Возврат Результат;
	
КонецФункции

