#Область ПрограммныйИнтерфейс

Функция Представление() Экспорт
	
	Инструмент = ИТК_Перечисления.ИнструментАнализПравДоступа();
	Возврат ИТК_ТуллкитКлиентСервер.ПредставлениеИнструмента(Инструмент);
	
КонецФункции

Функция ПредставлениеПоляОтчета(Поле) Экспорт
	
	Соответствие = Новый Соответствие;
	Соответствие.Вставить("", НСтр("ru = '<Пусто>';
											|en = '<Empty>'"));
	Соответствие.Вставить("Коллекция", НСтр("ru = 'Коллекция';
											|en = 'Collection'"));
	Соответствие.Вставить("Метаданные", НСтр("ru = 'Метаданные';
											|en = 'Metadata'"));
	Соответствие.Вставить("Роль", НСтр("ru = 'Роль';
										|en = 'Role'"));
	Соответствие.Вставить("Пользователь", НСтр("ru = 'Пользователь';
												|en = 'User'"));
	Соответствие.Вставить("ПользовательДоступный", "");
	Соответствие.Вставить("ПравоДоступа", НСтр("ru = 'Право доступа';
												|en = 'Access right'"));
	Соответствие.Вставить("Доступ", НСтр("ru = 'Доступ';
										|en = 'Access'"));
	Соответствие.Вставить("ПрофильГруппДоступа", НСтр("ru = 'Профиль групп доступа (БСП)';
										|en = 'Access groups profile (SSL)'"));
	Соответствие.Вставить("ГруппаПользователей", НСтр("ru = 'Группа пользователей (БСП)';
										|en = 'User group (SSL)'"));
	Соответствие.Вставить("ГруппаДоступа", НСтр("ru = 'Группа доступа (БСП)';
										|en = 'Access group (SSL)'"));
	
	Результат = Соответствие.Получить(Поле);
	Если Результат = Неопределено Тогда
		ВызватьИсключение "Неизвестное поле отчета Анализ прав доступа";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПредставлениеВыбранныхПравДоступа(ВыбранныеПраваДоступа) Экспорт
	
	ТекстВсе = НСтр("ru = 'Все'; en = 'All'");
	Если НЕ ЗначениеЗаполнено(ВыбранныеПраваДоступа) Тогда
		Возврат ТекстВсе;
	КонецЕсли;
	
	ВыбраныВсе = Истина; ВыбраныВсеКромеИсторииДанных = Истина;
	ВсеПраваДоступа = ИТК_АнализПравДоступаПовтИсп.ВсеПраваДоступа();
	Для Каждого ЭлементПравоДоступа Из ВсеПраваДоступа Цикл 
		
		ПравоДоступа = ЭлементПравоДоступа.Значение;
		
		Если ВыбранныеПраваДоступа.НайтиПоЗначению(ПравоДоступа) = Неопределено Тогда
			
			ВыбраныВсе = Ложь;
			
			Если НЕ ИТК_МетаданныеКлиентСерверПовтИсп.ПравоДоступаИсторииДанных(ПравоДоступа) Тогда
				ВыбраныВсеКромеИсторииДанных = Ложь;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ВыбраныВсе Тогда
		Результат = ТекстВсе;
	ИначеЕсли ВыбраныВсеКромеИсторииДанных Тогда
		Результат = НСтр("ru = 'Все, кроме истории данных'; en = 'Everything except data history'");
	Иначе
		Результат = ИТК_ФормаКлиентСервер.ПредставлениеСписка(ВыбранныеПраваДоступа, 80);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти