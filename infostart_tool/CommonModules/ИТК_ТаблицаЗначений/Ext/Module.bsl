#Область ПрограммныйИнтерфейс

// Определяет индексируется колонка таблицы значений или нет (т.к. у ИндексыКоллекции нет метода Найти)
//
// Параметры:
//  ТаблицаЗначений  - ТаблицаЗначений - Таблица значений
//  ИмяКолонки  - Строка - Имя колонки
//
// Возвращаемое значение:
//   Булево - Истина, колонка индексируется
//
Функция ИндексируетсяКолонка(Значение, Имя) Экспорт
	
	Результат = Ложь;
	
	Для Каждого ОписаниеИндекса Из Значение.Индексы Цикл 
		
		Если Строка(ОписаниеИндекса) = Имя Тогда 
			
			Результат = Истина;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Изменяет тип существующей колонки
//
// Параметры:
//  Приемник  - ТаблицаЗначений - Приемник
//  Имя - Строка - Имя колонки
//  Тип - ОписаниеТипов - Тип значения колонки
//  Источник  - ТаблицаЗначений - Источник
//
Процедура ИзменитьТипКолонки(Приемник, Имя, Тип, Источник = Неопределено) Экспорт
	
	Если Источник = Неопределено Тогда
		Источник = Приемник;
	КонецЕсли;
	
	// Добавляем временную колонку с новым типом
	ИмяВременнойКолонки = Имя + "ВременнаяКолонка";
	Приемник.Колонки.Добавить(ИмяВременнойКолонки, Тип);
	
	// Загружаем значения
	Приемник.ЗагрузитьКолонку(Источник.ВыгрузитьКолонку(Имя), ИмяВременнойКолонки);
	
	// Удаляем колонку
	Приемник.Колонки.Удалить(Имя);
	
	// Переименовываем временную колонку
	Приемник.Колонки[ИмяВременнойКолонки].Имя = Имя;
	
КонецПроцедуры

Процедура УдалитьКолонкиСИгнорированиемНаличия(ТаблицаЗначений, УдаляемыеКолонки) Экспорт
	
	Колонки = ТаблицаЗначений.Колонки;
	
	Если ТипЗнч(УдаляемыеКолонки) = Тип("Строка") Тогда
		УдаляемыеКолонки = СтрРазделить(УдаляемыеКолонки, ",");
	КонецЕсли;
	
	Для Каждого УдаляемаяКолонка Из УдаляемыеКолонки Цикл 
		
		Если Колонки.Найти(УдаляемаяКолонка) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Колонки.Удалить(УдаляемаяКолонка);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти