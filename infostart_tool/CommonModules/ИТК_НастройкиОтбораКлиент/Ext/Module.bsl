#Область ПрограммныйИнтерфейс

Функция НастройкиСУчетомНастроекРодителей(Отбор, Строка) Экспорт 
	
	Результат = Отбор.Получить(Строка.Метаданные);

	Родитель = Строка;
	Пока Истина Цикл 
		
		Родитель = Родитель.ПолучитьРодителя();
		Если Родитель = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		НастройкиРодителя = Отбор.Получить(Родитель.Метаданные);
		
		Если НастройкиРодителя <> Неопределено Тогда
			
			Если Результат = Неопределено Тогда
				
				Результат = НастройкиРодителя;
				
			Иначе
				
				ОбъединитьНастройкиОтборов(Результат.Отбор, НастройкиРодителя.Отбор);
				
			КонецЕсли;
			
		КонецЕсли;
	
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОбъединитьНастройкиОтборов(ОтборПриемник, ОтборИсточник)
	
	Для Каждого Отбор Из ОтборИсточник.Элементы Цикл 
		
		ТипОтбора = Тип(Отбор);
		ЭтоТипОтбораГруппа = (ТипОтбора = Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		
		ЭлементОтбораПриемника = НайтиОтбораПоИдентификаторуПользовательскойНастройки(ОтборПриемник, Отбор.ИдентификаторПользовательскойНастройки);
		Если ЭлементОтбораПриемника = Неопределено Тогда
			
			ЭлементОтбораПриемника = ОтборПриемник.Элементы.Добавить(ТипОтбора);
			ЗаполнитьЗначенияСвойств(ЭлементОтбораПриемника, Отбор);
			
		Иначе
			
			Если ЭтоТипОтбораГруппа Тогда
				
				НовыйИдентификатор = (ЭлементОтбораПриемника.ТипГруппы <> Отбор.ТипГруппы);
				
			Иначе
				
				НовыйИдентификатор = (ЭлементОтбораПриемника.ЛевоеЗначение <> Отбор.ЛевоеЗначение);
				
			КонецЕсли;
			
			Если НовыйИдентификатор Тогда 
				
				ЭлементОтбораПриемника.ИдентификаторПользовательскойНастройки = Новый УникальныйИдентификатор;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЭтоТипОтбораГруппа Тогда
			
			ОбъединитьНастройкиОтборов(ЭлементОтбораПриемника, Отбор);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция НайтиОтбораПоИдентификаторуПользовательскойНастройки(Отбор, Идентификатор)
	
	Результат = Неопределено;
	Для Каждого ПодчиненныйОтбор Из Отбор.Элементы Цикл 
		
		Если ПодчиненныйОтбор.ИдентификаторПользовательскойНастройки = Идентификатор Тогда
			Результат = ПодчиненныйОтбор;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти