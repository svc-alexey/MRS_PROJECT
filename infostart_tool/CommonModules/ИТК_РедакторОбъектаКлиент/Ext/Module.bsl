#Область ПрограммныйИнтерфейс

Функция ОписаниеВопросаВыполненияДействия(Имя, Объект, ОтсутствуютИзменения) Экспорт
	
	Если Имя = "Провести" Тогда
		
		Заголовок = НСтр("ru = 'Провести?';
						|en = 'Post?'");
		
	ИначеЕсли Имя = "ОтменаПроведения" Тогда
		
		Заголовок = НСтр("ru = 'Отмена проведения?';
						|en = 'Undo posting?'");
		
	ИначеЕсли Имя = "СозданиеНового" Тогда
		
		Заголовок = НСтр("ru = 'Создание нового?';
						|en = 'Creation new?'");
		
	ИначеЕсли Имя = "ПометитьНаУдаление" Тогда
		
		Заголовок = НСтр("ru = 'Пометить на удаление?';
						|en = 'Flag for deletion?'");
		
	ИначеЕсли Имя = "УдалитьНепосредственно" Тогда
		
		Заголовок = НСтр("ru = 'Удалить навсегда?';
						|en = 'Delete forever?'");
		
	ИначеЕсли Имя = "ВыполнитьЗадачу" Тогда
		
		Заголовок = НСтр("ru = 'Выполнить задачу (записывается)?';
						|en = 'Complete task (being recorded)?'");
		
	Иначе
		
		Заголовок = НСтр("ru = 'Записать?';
						|en = 'Write?'");
		
	КонецЕсли;
	
	Если Имя = "СозданиеНового" Тогда
		
		Текст = СтрШаблон(НСтр("ru = 'Новый объект: %1';
								|en = 'New object: %1'"), ТипЗнч(Объект));
		
	Иначе 
		
		Текст = СтрШаблон(НСтр("ru = 'Объект: %1';
								|en = 'Object: %1'"), Объект);
		Если ОтсутствуютИзменения Тогда
			
			Текст = НСтр("ru = 'Нет изменений для записи объекта.';
						|en = 'No changes to record an object.'") + Символы.ПС + Текст;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Новый Структура("Заголовок, Текст", Заголовок, Текст);
	
КонецФункции

#КонецОбласти
