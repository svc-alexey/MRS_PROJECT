#Область ПрограммныйИнтерфейс

Функция Представление() Экспорт
	
	Инструмент = ИТК_Перечисления.ИнструментРегламентныеИФоновыеЗадания();
	Возврат ИТК_ТуллкитКлиентСервер.ПредставлениеИнструмента(Инструмент);
	
КонецФункции

// Представление расписания регламентного задания.
// 
// Параметры:
//  Расписание - РасписаниеРегламентногоЗадания
// 
// Возвращаемое значение:
//  Строка
//
Функция ПредставлениеРасписания(Расписание) Экспорт
	
	ЧастиРезультата = Новый Массив;
	
	// Общее расписание
	Представление = ПредставлениеОбщегоРасписания(Расписание);
	ДобавитьЧастьПредставления(ЧастиРезультата, Представление);
	
	// Недельное расписание
	Представление = ПредставлениеДнейНедели(Расписание);
	ДобавитьЧастьПредставления(ЧастиРезультата, Представление);
	
	Представление = ПредставлениеПериодаНедель(Расписание);
	ДобавитьЧастьПредставления(ЧастиРезультата, Представление);
	
	// Месячное расписание
	Представление = ПредставлениеМесяцев(Расписание);
	ДобавитьЧастьПредставления(ЧастиРезультата, Представление);
	
	Представление = ПредставлениеДняВМесяце(Расписание);
	ДобавитьЧастьПредставления(ЧастиРезультата, Представление);
	
	Представление = ПредставлениеДняНеделиВМесяце(Расписание);
	ДобавитьЧастьПредставления(ЧастиРезультата, Представление);
	
	// Дневное расписание
	Представление = ПредставлениеДневногоРасписания(Расписание);
	ДобавитьЧастьПредставления(ЧастиРезультата, Представление);
	
	Возврат СтрСоединить(ЧастиРезультата, "; ");
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ДобавитьЧастьПредставления(Результат, ЧастьПредставления)
	
	Если ПустаяСтрока(ЧастьПредставления) Тогда
		Возврат;
	КонецЕсли;
	
	Результат.Добавить(ЧастьПредставления);
	
КонецПроцедуры

Функция ПредставлениеДневногоРасписания(Расписание)
		
	Если ЗначениеЗаполнено(Расписание.ДетальныеРасписанияДня) Тогда
		
		ЧастиПредставления = Новый Массив();
		
		Для Каждого Элемент Из Расписание.ДетальныеРасписанияДня Цикл
			
			Представление = ПредставлениеДетальногоРасписанияДня(Элемент);
			ЧастиПредставления.Добавить(Представление);
			
		КонецЦикла;
		
		Представление = СтрСоединить(ЧастиПредставления, НСтр("ru = ' и '; en = ' and '"));
		
	Иначе
		Представление = ПредставлениеДетальногоРасписанияДня(Расписание);
	КонецЕсли;
	
	Возврат Представление;
	
КонецФункции

Функция ПредставлениеДетальногоРасписанияДня(Расписание)
	
	ВремяСодержитСекунды = Секунда(Расписание.ВремяНачала) > 0
		ИЛИ Секунда(Расписание.ВремяКонца) > 0
		ИЛИ Секунда(Расписание.ВремяЗавершения) > 0;
		
	Если ВремяСодержитСекунды Тогда			
		ФорматВремени = "ДФ=HH:mm:ss; ДП=;";
	Иначе
		ФорматВремени = "ДФ=HH:mm; ДП=;";
	КонецЕсли;
	
	ЧастиПредставленияПовтора = Новый Массив;
	
	Если ЗначениеЗаполнено(Расписание.ПериодПовтораВТечениеДня) Тогда
		
		Подстрока = СтрШаблон( НСтр("ru = 'раз в %1'; en = 'once every %1'"),
						ИТК_ДатаВремя.ПредставлениеПериодаВремени(Расписание.ПериодПовтораВТечениеДня));
		ЧастиПредставленияПовтора.Добавить(Подстрока);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Расписание.ПаузаПовтора)
		И ЗначениеЗаполнено(Расписание.ПериодПовтораВТечениеДня) Тогда
		
		Подстрока = СтрШаблон(НСтр("ru = 'с паузой %1'; en = 'with pause %1'"),
						ИТК_ДатаВремя.ПредставлениеПериодаВремени(Расписание.ПаузаПовтора));
		ЧастиПредставленияПовтора.Добавить(Подстрока);
		
	КонецЕсли;
	
	ПоказатьВремяЗапуска = ЗначениеЗаполнено(Расписание.ВремяНачала)
		ИЛИ ЗначениеЗаполнено(Расписание.ВремяКонца)
		ИЛИ ЗначениеЗаполнено(Расписание.ВремяЗавершения)
		ИЛИ ЗначениеЗаполнено(Расписание.ИнтервалЗавершения)
		ИЛИ НЕ ЗначениеЗаполнено(Расписание.ПериодПовтораВТечениеДня);

	Если ПоказатьВремяЗапуска Тогда
		
		Если ЗначениеЗаполнено(Расписание.ВремяКонца) Тогда
			
			Подстрока = СтрШаблон(НСтр("ru = 'с %1 по %2'; en = '%1 to %2'"), 
							Формат(Расписание.ВремяНачала, ФорматВремени), Формат(Расписание.ВремяКонца, ФорматВремени));
			ЧастиПредставленияПовтора.Добавить(Подстрока);
			
		ИначеЕсли Расписание.ПериодПовтораВТечениеДня > 0 Тогда 
			
			Подстрока = СтрШаблон(НСтр("ru = 'с %1'; en = 'from %1'"),
							Формат(Расписание.ВремяНачала, ФорматВремени));
			ЧастиПредставленияПовтора.Добавить(Подстрока);
			
		Иначе 
			
			Подстрока = СтрШаблон(НСтр("ru = 'в %1'; en = 'in %1'"),
							Формат(Расписание.ВремяНачала, ФорматВремени));
			ЧастиПредставленияПовтора.Добавить(Подстрока);
			
		КонецЕсли;
			
	КонецЕсли;
	
	ЧастиПредставления = Новый Массив;
	
	ПредставлениеПовтора = СтрСоединить(ЧастиПредставленияПовтора, " ");
	ЧастиПредставления.Добавить(ПредставлениеПовтора);	
	
	Если ЗначениеЗаполнено(Расписание.ВремяЗавершения)
		И ЗначениеЗаполнено(Расписание.ИнтервалЗавершения) Тогда
		
		Подстрока = СтрШаблон(НСтр("ru = 'завершить с %1 или через %2'; en = 'end at %1 or after %2'"),
			Формат(Расписание.ВремяЗавершения, ФорматВремени),
			ИТК_ДатаВремя.ПредставлениеПериодаВремени(Расписание.ИнтервалЗавершения));
		ЧастиПредставления.Добавить(Подстрока);
		
	ИначеЕсли ЗначениеЗаполнено(Расписание.ВремяЗавершения) Тогда 
		
		Подстрока = СтрШаблон(НСтр("ru = 'завершить после %1'; en = 'end after %1'"),
						Формат(Расписание.ВремяЗавершения, ФорматВремени));
		ЧастиПредставления.Добавить(Подстрока);
		
	ИначеЕсли ЗначениеЗаполнено(Расписание.ИнтервалЗавершения) Тогда 
		
		Подстрока = СтрШаблон(НСтр("ru = 'завершить через %1'; en = 'end in %1'"),
						ИТК_ДатаВремя.ПредставлениеПериодаВремени(Расписание.ИнтервалЗавершения));
		ЧастиПредставления.Добавить(Подстрока);
		
	КонецЕсли;
	
	Представление = СтрСоединить(ЧастиПредставления, ", ");
	
	Возврат Представление;
	
КонецФункции

Функция ПредставлениеОбщегоРасписания(Расписание)
	
	ЧастиПредставления = Новый Массив;
	
	Если ЗначениеЗаполнено(Расписание.ДатаНачала) Тогда
		
		Подстрока = СтрШаблон(НСтр("ru = 'с %1'; en = 'from %1'"),
						Формат(Расписание.ДатаНачала, "ДЛФ=D;"));
		ЧастиПредставления.Добавить(Подстрока);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Расписание.ДатаКонца) Тогда
		
		Подстрока = СтрШаблон(НСтр("ru = 'по %1'; en = 'by %1'"),
						Формат(Расписание.ДатаКонца, "ДЛФ=D;"));
		ЧастиПредставления.Добавить(Подстрока);
		
	КонецЕсли;
	
	Если Расписание.ПериодПовтораДней > 1 Тогда
		
		Подстрока = СтрШаблон(НСтр("ru = 'каждый %1-й день'; en = 'every %1st day'"),
						Расписание.ПериодПовтораДней);
		ЧастиПредставления.Добавить(Подстрока);
		
	ИначеЕсли Расписание.ПериодПовтораДней = 1 Тогда
		
		Если Расписание.ДеньВМесяце = 0
			И Не СодержитПериодическоеДневноеРасписание(Расписание) Тогда 
		
			Подстрока = НСтр("ru = 'ежедневно'; en = 'daily'");
			ЧастиПредставления.Добавить(Подстрока);
			
		КонецЕсли;
		
	Иначе
		
		Если СодержитНесколькоДневныхЗапусков(Расписание) Тогда
			
			Подстрока = НСтр("ru = 'один день'; en = 'one day'");
			ЧастиПредставления.Добавить(Подстрока);
		
		Иначе
			
			Подстрока = НСтр("ru = 'однажды'; en = 'once'");
			ЧастиПредставления.Добавить(Подстрока);
		
		КонецЕсли;
		
	КонецЕсли;
	
	Представление = СтрСоединить(ЧастиПредставления, " ");
	
	Возврат Представление;
	
КонецФункции

Функция ПредставлениеДнейНедели(Расписание)
	
	Если Расписание.ДниНедели.Количество() = 0
			ИЛИ Расписание.ДниНедели.Количество() = 7 Тогда
		Представление = "";
	ИначеЕсли Расписание.ДниНедели.Количество() = 1 Тогда
		
		НомерДня = Расписание.ДниНедели[0];
		Представление = ИТК_ДатаВремя.ПолноеПредставлениеДняНедели(НомерДня);
		
	Иначе
		
		ЧастиПредставления = Новый Массив;
		
		Для Каждого НомерДня Из Расписание.ДниНедели Цикл
			
			Представление = ИТК_ДатаВремя.КраткоеПредставлениеДняНедели(НомерДня);
			ЧастиПредставления.Добавить(Представление);
			
		КонецЦикла;
		
		Представление = СтрШаблон(НСтр("ru = 'в дни: %1'; en = 'in days: %1'"),
							СтрСоединить(ЧастиПредставления, ", "));
		
	КонецЕсли;
	
	Возврат Представление;
	
КонецФункции

Функция ПредставлениеПериодаНедель(Расписание)
	
	Если Расписание.ПериодПовтораДней = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Если Расписание.ПериодНедель <= 1 Тогда
		Возврат "";
	КонецЕсли;
	
	Представление = СтрокаСЧислом(НСтр("ru = '; каждую %1 неделю; ; каждые %1 недели; каждые %1 недель; каждые %1 недель';
										|en = '; every %1 week; ; every %1 week; every %1 weeks; every %1 weeks'"),
						Расписание.ПериодНедель, ВидЧисловогоЗначения.Количественное);
	
	Возврат Представление;
	
КонецФункции

Функция ПредставлениеМесяцев(Расписание)
	
	Если Расписание.Месяцы.Количество() = 0
			ИЛИ Расписание.Месяцы.Количество() = 12 Тогда
		Представление = "";
	ИначеЕсли Расписание.Месяцы.Количество() = 1 Тогда
		
		НомерМесяца = Расписание.Месяцы[0];
		Представление = ИТК_ДатаВремя.ПолноеПредставлениеМесяца(НомерМесяца);
		
	Иначе
		
		ЧастиПредставления = Новый Массив();
		
		Для Каждого НомерМесяца Из Расписание.Месяцы Цикл
			
			Представление = ИТК_ДатаВремя.КраткоеПредставлениеМесяца(НомерМесяца);
			ЧастиПредставления.Добавить(Представление);
			
		КонецЦикла;
		
		Представление = СтрШаблон(НСтр("ru = 'в месяцы: %1'; en = 'in months: %1'"),
							СтрСоединить(ЧастиПредставления, ", "));
		
	КонецЕсли;
	
	Возврат Представление;
	
КонецФункции

Функция ПредставлениеДняВМесяце(Расписание)
	
	Если Расписание.ДеньВМесяце = 1 Тогда
		Представление = НСтр("ru = 'первого числа месяца'; en = 'first of the month'");
	ИначеЕсли Расписание.ДеньВМесяце = -1 Тогда 
		Представление = НСтр("ru = 'последнего числа месяца'; en = 'last day of the month'");
	ИначеЕсли Расписание.ДеньВМесяце > 1 Тогда 
		
		Представление = СтрШаблон(НСтр("ru = '%1-го числа месяца'; en = '%1st day of the month'"),
							Расписание.ДеньВМесяце);
		
	ИначеЕсли Расписание.ДеньВМесяце < -1 Тогда 
		
		Представление = СтрШаблон(НСтр("ru = '%1-го дня с конца месяца'; en = '%1st day from the end of the month'"),
							-Расписание.ДеньВМесяце);
		
	Иначе
		Представление = "";
	КонецЕсли;
	
	Возврат Представление;
	
КонецФункции

Функция ПредставлениеДняНеделиВМесяце(Расписание)
	
	Если Расписание.ДеньНеделиВМесяце = 1 Тогда
		Представление = НСтр("ru = 'первого дня недели в месяце'; en = 'first day of the week in the month'");
	ИначеЕсли Расписание.ДеньНеделиВМесяце = -1 Тогда 
		Представление = НСтр("ru = 'последнего дня недели в месяце'; en = 'last day of the week in the month'");
	ИначеЕсли Расписание.ДеньНеделиВМесяце > 1 Тогда 
		
		Представление = СтрШаблон(НСтр("ru = '%1-го дня недели в месяце'; en = '%1st day of week in month'"),
							Расписание.ДеньНеделиВМесяце);
		
	ИначеЕсли Расписание.ДеньНеделиВМесяце < -1 Тогда 
		
		Представление = СтрШаблон(НСтр("ru = '%1-го дня недели с конца месяца'; en = '%1st day of the week from the end of the month'"),
							-Расписание.ДеньНеделиВМесяце);
		
	Иначе
		Представление = "";
	КонецЕсли;
	
	Возврат Представление;
	
КонецФункции

Функция СодержитПериодическоеДневноеРасписание(Расписание)

	ДетальныеРасписанияДня = Расписание.ДетальныеРасписанияДня;
	Если НЕ ЗначениеЗаполнено(ДетальныеРасписанияДня) Тогда
		ДетальныеРасписанияДня.Добавить(Расписание);
	КонецЕсли;
		
	Для Каждого Элемент Из ДетальныеРасписанияДня Цикл
		
		Если Элемент.ПериодПовтораВТечениеДня > 0 Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

Функция СодержитНесколькоДневныхЗапусков(Расписание)

	Если Расписание.ДетальныеРасписанияДня.Количество() > 1 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Расписание.ДетальныеРасписанияДня) Тогда
		ДетальноеРасписаниеДня = Расписание.ДетальныеРасписанияДня[0];
	Иначе
		ДетальноеРасписаниеДня = Расписание;
	КонецЕсли;
	
	Если ДетальноеРасписаниеДня.ПериодПовтораВТечениеДня > 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

#КонецОбласти