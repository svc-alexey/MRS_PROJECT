#Область ПрограммныйИнтерфейс

Процедура ПриОткрытии(Форма, ЭлементКоллекция, ОтключитьФильтр = Ложь) Экспорт
	
	ОбновитьЭлементыТолькоИзбранные(Форма, ЭлементКоллекция, ОтключитьФильтр);

КонецПроцедуры

Процедура ОбработкаКомандыТолькоИзбранные(Форма, ЭлементКоллекция) Экспорт
	
	ИмяТолькоИзбранные = ИТК_ИзбранноеКлиентСервер.ИмяРеквизитаТолькоИзбранные();
	
	Форма[ИмяТолькоИзбранные] = НЕ Форма[ИмяТолькоИзбранные];
	Форма.СохраняемыеВНастройкахДанныеМодифицированы = Истина;
	
	ОбновитьЭлементыТолькоИзбранные(Форма, ЭлементКоллекция);
	
КонецПроцедуры

Процедура ОбработкаКомандыДобавитьВИзбранное(ВидИнструмента, Форма, ИмяКоллекции, ИмяПоляКлюча) Экспорт
	
	УстановитьИзбранноеПоВыделеннымСтрокам(ВидИнструмента, Форма, ИмяКоллекции, ИмяПоляКлюча);	
	
КонецПроцедуры

Процедура ОбработкаКомандыУдалитьИзИзбранного(ВидИнструмента, Форма, ИмяКоллекции, ИмяПоляКлюча) Экспорт
	
	УстановитьИзбранноеПоВыделеннымСтрокам(ВидИнструмента, Форма, ИмяКоллекции, ИмяПоляКлюча, Ложь);	
	
КонецПроцедуры

Функция ОбработкаВыборВКоллекции(ВидИнструмента, Форма, ИмяКоллекции, Поле, Строка, ИмяКлюча) Экспорт
	
	Обработано = Ложь;
	Если Поле = Форма.Элементы[ИмяКоллекции + "ИзбранноеКартинка"] Тогда
		
		Обработано = Истина;
		
		Строка["Избранное"] = НЕ Строка["Избранное"]; 
		Строка["ИзбранноеКартинка"] = ИТК_ОбщийКлиентСерверПовтИсп.КартинкаИзбранное(Строка["Избранное"]);
		
		ИТК_ИзбранноеВызовСервера.ЗаписатьВИзбранное(ВидИнструмента,
									Строка[ИмяКлюча], Строка["Избранное"]);
									
	КонецЕсли;
	
	Возврат Обработано	
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура УстановитьИзбранноеПоВыделеннымСтрокам(ВидИнструмента, Форма, ИмяКоллекции, ИмяПоляКлюча, Избранное = Истина)
	
	ЭлементКоллекция = Форма.Элементы[ИмяКоллекции]; 
	
	КлючиПользователей = Новый Массив;
	Для Каждого ИдентификаторВыделеннойСтроки Из ЭлементКоллекция.ВыделенныеСтроки Цикл
		
		ВыделеннаяСтрока = Форма[ИмяКоллекции].НайтиПоИдентификатору(ИдентификаторВыделеннойСтроки);
		Если ВыделеннаяСтрока["Избранное"] = Избранное Тогда 
			Продолжить;
		КонецЕсли;
		
		ВыделеннаяСтрока["Избранное"] = Избранное; 
		ВыделеннаяСтрока["ИзбранноеКартинка"] = ИТК_ОбщийКлиентСерверПовтИсп.КартинкаИзбранное(Избранное);
		
		КлючиПользователей.Добавить(ВыделеннаяСтрока[ИмяПоляКлюча]);
		
	КонецЦикла;
	
	ИТК_ИзбранноеВызовСервера.ЗаписатьВИзбранное(ВидИнструмента, КлючиПользователей, Избранное);

КонецПроцедуры

Процедура ОбновитьЭлементыТолькоИзбранные(Форма, ЭлементКоллекция, ОтключитьФильтр = Ложь)
	
	ИмяТолькоИзбранные = ИТК_ИзбранноеКлиентСервер.ИмяРеквизитаТолькоИзбранные();
	
	Если ОтключитьФильтр Тогда
		Форма[ИмяТолькоИзбранные] = Ложь;
	КонецЕсли;
	
	Форма.Элементы[ИмяТолькоИзбранные].Пометка = Форма[ИмяТолькоИзбранные];
	
	ОтборИспользуется = Форма[ИмяТолькоИзбранные];
	ИТК_ФормаКлиент.ДополнитьОтборСтрок(ЭлементКоллекция, ОтборИспользуется, "Избранное", Истина);	
	
КонецПроцедуры

#КонецОбласти
