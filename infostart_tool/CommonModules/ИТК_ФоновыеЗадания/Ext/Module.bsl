#Область ПрограммныйИнтерфейс

Процедура Данные(Параметры, АдресРезультата) Экспорт
	
	Результат = Новый ТаблицаЗначений;
	
	Колонки = Результат.Колонки;
	Колонки.Добавить("Идентификатор", ИТК_ТипыКлиентСервер.ОписаниеУникальныйИдентификатор());
	Колонки.Добавить("Представление", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	
	Колонки.Добавить("Состояние", ИТК_ТипыКлиентСервер.ОписаниеСтрока(50));
	
	Колонки.Добавить("ДатаНачала", ИТК_ТипыКлиентСервер.ОписаниеДата());
	Колонки.Добавить("ДатаОкончания", ИТК_ТипыКлиентСервер.ОписаниеДата());
	Колонки.Добавить("Длительность", ИТК_ТипыКлиентСервер.ОписаниеСтрока(20));
	
	Колонки.Добавить("Ключ", ИТК_ТипыКлиентСервер.ОписаниеСтрока(100));
	
	// Сбор информации по всем заданиям с учетов вручную заполненных
	ВсеФоновыеЗадания = Новый Массив;
	Отбор = Параметры.Отбор;
	
	ОтборАвтоматическиеФоновыеЗадания = Отбор(Отбор);
	АвтоматическиеФоновыеЗадания = ФоновыеЗадания.ПолучитьФоновыеЗадания(ОтборАвтоматическиеФоновыеЗадания);
	ИТК_ОбщийКлиентСервер.ДополнитьМассив(ВсеФоновыеЗадания, АвтоматическиеФоновыеЗадания);
	
	РегламентноеЗадание = ИТК_ОбщийКлиентСервер.Свойство(Отбор, "РегламентноеЗадание");
	Если ЗначениеЗаполнено(РегламентноеЗадание) Тогда
		
		ОтборФоновыеЗаданияЗапущенныеВручную = Отбор(Отбор, Истина);
		ФоновыеЗаданияЗапущенныеВручную = ФоновыеЗадания.ПолучитьФоновыеЗадания(ОтборФоновыеЗаданияЗапущенныеВручную);
		ИТК_ОбщийКлиентСервер.ДополнитьМассив(ВсеФоновыеЗадания, ФоновыеЗаданияЗапущенныеВручную);
		
	КонецЕсли;
	
	// Обход и добавление данных фоновых заданий
	Количество = 0;
	Для Каждого ФоновоеЗадание Из ВсеФоновыеЗадания Цикл 
		
		НоваяСтрока = Результат.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ФоновоеЗадание);
		
		НоваяСтрока.Идентификатор = ФоновоеЗадание.УникальныйИдентификатор;
		НоваяСтрока.Представление = Представление(ФоновоеЗадание);
		
		Состояние = ФоновоеЗадание.Состояние;
		ДатаНачала = ФоновоеЗадание.Начало;
		ДатаОкончания = ФоновоеЗадание.Конец;
		
		Если ДатаОкончания = Неопределено Тогда
			
			Длительность = ИТК_Строки.ТекстНеопределено();
			
		Иначе
			
			ДлительностьСекунд = ДатаОкончания - ДатаНачала;
			Длительность = Формат(ИТК_ОбщийКлиентСервер.ПустаяДата() + ДлительностьСекунд, "ДЛФ=T");
			
		КонецЕсли;
		
		НоваяСтрока.Состояние = Состояние;
		
		НоваяСтрока.ДатаНачала = ДатаНачала;
		НоваяСтрока.ДатаОкончания = ДатаОкончания;
		НоваяСтрока.Длительность = Длительность;
		
		Количество = Количество + 1;
		Если ЗначениеЗаполнено(Отбор.Показывать) 
				И Количество >= Отбор.Показывать Тогда 
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(Результат, АдресРезультата);
	
КонецПроцедуры

Функция Получить(Знач Задание) Экспорт
	
	Если ТипЗнч(Задание) = Тип("Строка") Тогда
		
		Идентификатор = Новый УникальныйИдентификатор(Задание);
		
	Иначе
		
		Идентификатор = Задание;
		
	КонецЕсли;
	
	Результат = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(Идентификатор);
	
	Если Результат = Неопределено Тогда
		ВызватьИсключение(НСтр("ru = 'Фоновое задание не найдено'"));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СообщенияИОписанияОшибок(Знач Задание) Экспорт
	
	Ошибка = "";
	Сообщения = Новый Массив;
	
	Если Задание <> Неопределено Тогда
		
		УстановитьПривилегированныйРежим(Истина);
		
		ИнформацияОбОшибке = Задание.ИнформацияОбОшибке;
		Если ИнформацияОбОшибке <> Неопределено Тогда
			Ошибка = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		КонецЕсли;
		
		СообщенияПользователю = Задание.ПолучитьСообщенияПользователю();
		Для Каждого Сообщение Из СообщенияПользователю Цикл
			Сообщения.Добавить(Сообщение.Текст);
		КонецЦикла;
		
		УстановитьПривилегированныйРежим(Ложь);
		
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибка", Ошибка);
	Результат.Вставить("Сообщения", Сообщения);
	
	Возврат Результат;
	
КонецФункции

Функция Отменить(Идентификатор) Экспорт
	
	Отбор = Новый Структура;
	Отбор.Вставить("УникальныйИдентификатор", Идентификатор);
	
	УстановитьПривилегированныйРежим(Истина);

	НайденныеФоновыеЗадания = ФоновыеЗадания.ПолучитьФоновыеЗадания(Отбор);
	Если НЕ ЗначениеЗаполнено(НайденныеФоновыеЗадания) Тогда
		Возврат Ложь;
	КонецЕсли;
		
	ФоновоеЗадание = НайденныеФоновыеЗадания[0];
	ЗаданиеАктивно = (ФоновоеЗадание.Состояние = СостояниеФоновогоЗадания.Активно);
	
	Если ЗаданиеАктивно Тогда
		ФоновоеЗадание.Отменить();
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ЗаданиеАктивно;
	
КонецФункции

Функция Последнее(РегламентноеЗадание) Экспорт
	
	ВсеФоновыеЗаданияПоРегламентному = Новый Массив;
	Если РегламентноеЗадание.ПоследнееЗадание <> Неопределено Тогда
		ВсеФоновыеЗаданияПоРегламентному.Добавить(РегламентноеЗадание.ПоследнееЗадание);
	КонецЕсли;
	
	// Задания запущенные вручную
	Отбор = Новый Структура("Ключ", РегламентноеЗадание.УникальныйИдентификатор);
	ФоновыеЗаданияЗапущенныеВручную = ФоновыеЗадания.ПолучитьФоновыеЗадания(Отбор);
	
	ИТК_ОбщийКлиентСервер.ДополнитьМассив(ВсеФоновыеЗаданияПоРегламентному, ФоновыеЗаданияЗапущенныеВручную);
	
	// Автоматические задания
	Отбор = Новый Структура("РегламентноеЗадание", РегламентноеЗадание);
	АвтоматическиеФоновыеЗадания = ФоновыеЗадания.ПолучитьФоновыеЗадания(Отбор);

	ИТК_ОбщийКлиентСервер.ДополнитьМассив(ВсеФоновыеЗаданияПоРегламентному, АвтоматическиеФоновыеЗадания);
	
	Если НЕ ЗначениеЗаполнено(ВсеФоновыеЗаданияПоРегламентному) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПоследнееЗадание = ВсеФоновыеЗаданияПоРегламентному[0];
	Для Индекс = 1 По ВсеФоновыеЗаданияПоРегламентному.ВГраница() Цикл 
		
		ФоновоеЗадание = ВсеФоновыеЗаданияПоРегламентному[Индекс];
		
		Если ЗначениеЗаполнено(ПоследнееЗадание.Конец) Тогда
			
			Если НЕ ЗначениеЗаполнено(ФоновоеЗадание.Конец)
			 		ИЛИ ПоследнееЗадание.Конец < ФоновоеЗадание.Конец Тогда
					
				ПоследнееЗадание = ФоновоеЗадание;
				
			КонецЕсли;
			
		Иначе
			
			Если НЕ ЗначениеЗаполнено(ФоновоеЗадание.Конец)
			   		И ПоследнееЗадание.Начало < ФоновоеЗадание.Начало Тогда
					
				ПоследнееЗадание = ФоновоеЗадание;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ПоследнееЗадание;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция Представление(Задание)
	
	Результат = Задание.Наименование;
	Если ЗначениеЗаполнено(Результат) Тогда
		Возврат Результат;
	КонецЕсли;
	
	РегламентноеЗадание = Задание.РегламентноеЗадание;
	Если РегламентноеЗадание = Неопределено Тогда
		Возврат НСтр("ru = '<пусто>';
					|en = '<empty>'");
	КонецЕсли;

	Возврат РегламентноеЗадание.Метаданные.Представление();
	
КонецФункции

Функция Отбор(Отбор, ЗапущенныеВручную = Ложь)
	
	Результат = Новый Структура;
	
	// СОСТОЯНИЕ ----------------------------------------------------------------------
	ОтборПоСостояниюЗавершено = Отбор.СостояниеЗавершено;
	ОтборПоСостояниюЗавершеноАварийно = Отбор.СостояниеЗавершеноАварийно;
	ОтборПоСостояниюОтменено = Отбор.СостояниеОтменено;
	ОтборПоСостояниюАктивно = Отбор.СостояниеАктивно;
	
	ТребуетсяОтборПоСостоянию = НЕ (ОтборПоСостояниюЗавершено
									И ОтборПоСостояниюЗавершеноАварийно
									И ОтборПоСостояниюОтменено
									И ОтборПоСостояниюАктивно);
									
	Если ТребуетсяОтборПоСостоянию Тогда
		
		ОтборСостояние = Новый Массив;
		
		Если ОтборПоСостояниюЗавершено Тогда
			ОтборСостояние.Добавить(СостояниеФоновогоЗадания.Завершено);
		КонецЕсли;
		Если ОтборПоСостояниюЗавершеноАварийно Тогда
			ОтборСостояние.Добавить(СостояниеФоновогоЗадания.ЗавершеноАварийно);
		КонецЕсли;
		Если ОтборПоСостояниюОтменено Тогда
			ОтборСостояние.Добавить(СостояниеФоновогоЗадания.Отменено);
		КонецЕсли;
		Если ОтборПоСостояниюАктивно Тогда
			ОтборСостояние.Добавить(СостояниеФоновогоЗадания.Активно);
		КонецЕсли;
		
		Результат.Вставить("Состояние", ОтборСостояние);
		
	КонецЕсли;
	
	// ПЕРИОД
	ТекущаяДатаСеанса = ТекущаяДатаСеанса();
	
	Период = Отбор.Период;
	Если Период = ИТК_Перечисления.ВидПериодаПолученияФоновыхЗаданийВсеВремя() Тогда
		
		ОтборПериодС  = Неопределено;
		ОтборПериодПо = Неопределено;
		
	ИначеЕсли Период = ИТК_Перечисления.ВидПериодаПолученияФоновыхЗаданийСегодня() Тогда
		
		ОтборПериодС  = НачалоДня(ТекущаяДатаСеанса);
		ОтборПериодПо = КонецДня(ТекущаяДатаСеанса);
		
	ИначеЕсли Период = ИТК_Перечисления.ВидПериодаПолученияФоновыхЗаданийПрошлаяНочь() Тогда
		
		ОтборПериодС  = НачалоДня(ТекущаяДатаСеанса) - 3*3600;
		ОтборПериодПо = НачалоДня(ТекущаяДатаСеанса) + 9*3600;
		
	ИначеЕсли Период = ИТК_Перечисления.ВидПериодаПолученияФоновыхЗаданийВчера() Тогда
		
		ВчерашнийДень = ТекущаяДатаСеанса - ИТК_ОбщийКлиентСервер.КоличествоСекундВДне();
		
		ОтборПериодС  = НачалоДня(ВчерашнийДень);
		ОтборПериодПо = КонецДня(ВчерашнийДень);
		
	ИначеЕсли Период = ИТК_Перечисления.ВидПериодаПолученияФоновыхЗаданийПроизвольный() Тогда
		
		ОтборПериодС  = Отбор.ПериодС;
		ОтборПериодПо = Отбор.ПериодПо;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОтборПериодС) Тогда
		Результат.Вставить("Начало", ОтборПериодС);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОтборПериодПо) Тогда
		Результат.Вставить("Конец", ОтборПериодПо);
	КонецЕсли;
	
	// РЕГЛАМЕНТНОЕ ЗАДАНИЕ
	ИдентификаторРегламентногоЗадания = Отбор.РегламентноеЗадание;
	Если ЗначениеЗаполнено(ИдентификаторРегламентногоЗадания) Тогда 
		
		Если ЗапущенныеВручную Тогда
			Результат.Вставить("Ключ", ИдентификаторРегламентногоЗадания);
		Иначе
			РегламентноеЗадание = ИТК_РегламентныеЗадания.Получить(ИдентификаторРегламентногоЗадания);
			Результат.Вставить("РегламентноеЗадание", РегламентноеЗадание);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
