#Область ПрограммныйИнтерфейс

Функция ОтключитьОбработчик(Форма, ИмяОбработчика) Экспорт
	
	Попытка 
		
		Форма.ОтключитьОбработчикОжидания(ИмяОбработчика);
		Результат = Истина;
		
	Исключение
		
		Результат = Ложь;
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция ОтключитьГлобальныйОбработчик(ИмяОбработчика) Экспорт
	
	Попытка 
		
		ОтключитьОбработчикОжидания(ИмяОбработчика);
		Результат = Истина;
		
	Исключение
		
		Результат = Ложь;
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

