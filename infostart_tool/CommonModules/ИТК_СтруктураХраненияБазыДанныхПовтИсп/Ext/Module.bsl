#Область ПрограммныйИнтерфейс

Функция ОписанияХранения() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ПоляТаблицы", ПоляТаблицы());
	Результат.Вставить("ПоляПоля", ПоляПоля());
	Результат.Вставить("ПоляИндекса", ПоляИндекса());
	
	Возврат Результат;
	
КонецФункции

Функция НазначениеТаблицы(Назначение) Экспорт
	
	Если ИТК_ОбщийПовтИсп.ВариантВстроенногоЯзыкаРусский() Тогда
		Возврат Назначение;
	КонецЕсли;
	
	СоответствиеНазначений = СоответствиеНазначений();
	Результат = СоответствиеНазначений.Получить(Назначение);
	
	Если Результат = Неопределено Тогда
		Возврат Назначение;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СоответствиеНазначений() Экспорт
	
	Результат = Новый Соответствие;
	Результат.Вставить("Основная", "Main");
	Результат.Вставить("Константа", "Constant");
	Результат.Вставить("ТабличнаяЧасть", "TabularSection");
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПоляТаблицы() Экспорт
	
	ПолеНазначение = "Назначение";
	ПолеМетаданные = "Метаданные";
	ПолеПоля = "Поля";
	ПолеИндексы = "Индексы";
	ПолеИмяТаблицы = "ИмяТаблицы";
	ПолеИмяТаблицыХранения = "ИмяТаблицыХранения";
	
	Если ИТК_ОбщийПовтИсп.ВариантВстроенногоЯзыкаАнглийский() Тогда
		
		ПолеНазначение = "Purpose";
		ПолеМетаданные = "Metadata";
		ПолеПоля = "Fields";
		ПолеИндексы = "Indexes";
		ПолеИмяТаблицы = "TableName";
		ПолеИмяТаблицыХранения = "StorageTableName";
		
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Назначение", ПолеНазначение);
	Результат.Вставить("Метаданные", ПолеМетаданные);
	Результат.Вставить("Поля", ПолеПоля);
	Результат.Вставить("Индексы", ПолеИндексы);
	Результат.Вставить("ИмяТаблицы", ПолеИмяТаблицы);
	Результат.Вставить("ИмяТаблицыХранения", ПолеИмяТаблицыХранения);
	
	Возврат Результат;
	
КонецФункции

Функция ПоляПоля() Экспорт
	
	ПолеМетаданные = "Метаданные";
	ПолеИмяПоля = "ИмяПоля";
	ПолеИмяПоляХранения = "ИмяПоляХранения";
	
	Если ИТК_ОбщийПовтИсп.ВариантВстроенногоЯзыкаАнглийский() Тогда
		
		ПолеМетаданные = "Metadata";
		ПолеИмяПоля = "FieldName";
		ПолеИмяПоляХранения = "StorageFieldName";
		
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Метаданные", ПолеМетаданные);
	Результат.Вставить("ИмяПоля", ПолеИмяПоля);
	Результат.Вставить("ИмяПоляХранения", ПолеИмяПоляХранения);
	
	Возврат Результат;
	
КонецФункции

Функция ПоляИндекса() Экспорт
	
	ПолеПоля = "Поля";
	ПолеИмяИндексаХранения = "ИмяИндексаХранения";
	
	Если ИТК_ОбщийПовтИсп.ВариантВстроенногоЯзыкаАнглийский() Тогда
		
		ПолеПоля = "Fields";
		ПолеИмяИндексаХранения = "StorageIndexName";
		
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Поля", ПолеПоля);
	Результат.Вставить("ИмяИндексаХранения", ПолеИмяИндексаХранения);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
