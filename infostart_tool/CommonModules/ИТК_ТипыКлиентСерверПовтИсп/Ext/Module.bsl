#Область ПрограммныйИнтерфейс

Функция ОписаниеТиповЛюбаяСсылка() Экспорт
	
	XMLТекстЛюбаяСсылка = "<TypeDescription xmlns=""http://v8.1c.ru/8.1/data/core"" xmlns:xs=""http://www.w3.org/2001/XMLSchema"" xmlns:xsi=""http://www.w3.org/2001/XMLSchema-instance"" xsi:type=""TypeDescription"">
	|<TypeSet xmlns:d2p1=""http://v8.1c.ru/8.1/data/enterprise/current-config"">d2p1:AnyRef</TypeSet>
	|</TypeDescription>";
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(XMLТекстЛюбаяСсылка);
	Результат = СериализаторXDTO.ПрочитатьXML(ЧтениеXML);
	
	Если НЕ ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.20") Тогда
		
		ОписаниеТиповЛюбаяСсылкаРасширения = ИТК_ТипыВызовСервера.ОписаниеТиповЛюбаяСсылкаРасширения();
		Результат = ИТК_ТипыКлиентСервер.СложитьОписания(Результат, ОписаниеТиповЛюбаяСсылкаРасширения);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

