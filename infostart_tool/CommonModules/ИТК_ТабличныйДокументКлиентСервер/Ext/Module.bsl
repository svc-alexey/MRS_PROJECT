#Область ПрограммныйИнтерфейс

// Устанавливает фиксацию шапки табличного документа
// Параметры:
//   ТабличныйДокумент - ТабличныйДокумент - Табличный документ
//   Зафиксировать - Булево - Признак фиксации
Процедура ЗафиксироватьШапку(ТабличныйДокумент, Зафиксировать = Истина) Экспорт
	
	Если Зафиксировать Тогда
		
		ТабличныйДокумент.ФиксацияСлева = 1;
		ТабличныйДокумент.ФиксацияСверху = 3;
		
	Иначе
		
		ТабличныйДокумент.ФиксацияСлева = 0;
		ТабличныйДокумент.ФиксацияСверху = 0;
		
	КонецЕсли;
	
КонецПроцедуры

// Выделить ячейки табличного документа
//
// Параметры:
//	ТабличныйДокумент - ТабличныйДокумент - Табличный документ
//	ВыделеннаяОбласть - Структура - Выделенная область
//
Процедура ВыделитьЯчейки(ТабличныйДокумент, ВыделеннаяОбласть) Экспорт
	
	ПерваяСтрока 		= ВыделеннаяОбласть.Верх;
	ПерваяКолонка 		= ВыделеннаяОбласть.Лево;
	ПоследняяСтрока 	= ВыделеннаяОбласть.Низ;
	ПоследняяКолонка 	= ВыделеннаяОбласть.Право;
	
	ЭталоннаяОбласть = ТабличныйДокумент.Область(ПерваяСтрока, ПерваяКолонка, ПерваяСтрока, ПерваяКолонка);
	ШрифтЭталоннойОбласти = ЭталоннаяОбласть.Шрифт;
	Если ШрифтЭталоннойОбласти = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ОбластьВыделяется = НЕ ШрифтЭталоннойОбласти.Жирный;
	Для НомерСтроки = ПерваяСтрока По ПоследняяСтрока Цикл
		
		Для НомерКолонки = ПерваяКолонка По ПоследняяКолонка Цикл 
			
			ТекущаяОбластьРезультата = ТабличныйДокумент.Область(НомерСтроки, НомерКолонки, НомерСтроки, НомерКолонки);
			ТекущийШрифт = ТекущаяОбластьРезультата.Шрифт;
			Если ТекущийШрифт <> Неопределено Тогда 
				
				Если ОбластьВыделяется Тогда
					РазмерШрифта = 10;
				Иначе
					РазмерШрифта = 8;
				КонецЕсли;
				ТекущаяОбластьРезультата.Шрифт = Новый Шрифт(ТекущийШрифт, , РазмерШрифта, ОбластьВыделяется);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

// Обновляем подменю уровень результата в табличном документе
//
// Параметры:
//  Элемент  - Элемент - Элемент
//  Форма  - Форма - Форма
//  ТабличныйДокумент  - ТабличныйДокумент - ТабличныйДокумент
//
Процедура ОбновитьЭлементыПодменюУровеньГруппировок(Элемент, ТабличныйДокумент) Экспорт
	
	КоличествоУровнейГруппировокСтрок = ТабличныйДокумент.КоличествоУровнейГруппировокСтрок();
	
	Уровень = 1;
	Для Каждого ЭлементМеню Из Элемент.ПодчиненныеЭлементы Цикл 
		
		ЭлементМеню.Видимость = (Уровень <= КоличествоУровнейГруппировокСтрок);
		
		ЗаголовокЭлемента = СтрШаблон(НСтр("ru = 'Уровень %1';
											|en = 'Level %1'"), Уровень);
		Если Уровень = 1 Тогда
			Картинка = БиблиотекаКартинок.СвернутьВсе;
			ЗаголовокЭлемента = СтрШаблон(НСтр("ru = '%1 (свернуть все)';
												|en = '%1 (collapse all)'"), ЗаголовокЭлемента);
		ИначеЕсли Уровень = КоличествоУровнейГруппировокСтрок Тогда
			Картинка = БиблиотекаКартинок.РазвернутьВсе;
			ЗаголовокЭлемента = СтрШаблон(НСтр("ru = '%1 (развернуть все)';
												|en = '%1 (expand all)'"), ЗаголовокЭлемента);
		Иначе
			Картинка = Новый Картинка
		КонецЕсли;
		
		ЭлементМеню.Заголовок = ЗаголовокЭлемента;
		ЭлементМеню.Картинка = Картинка;
		
		Уровень = Уровень + 1;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти
