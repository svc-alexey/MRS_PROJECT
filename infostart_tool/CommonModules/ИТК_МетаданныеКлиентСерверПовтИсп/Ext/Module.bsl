Функция СтандартноеИмяПоляОбъекта(Имя) Экспорт
	
	Результат = Имя;
	
	Если ИТК_ОбщийКлиентСерверПовтИсп.ВариантВстроенногоЯзыкаАнглийский() Тогда
		
		ИменаСтандартныхПолейОбъекта = СоответствиеИменаСтандартныхПолейОбъекта();
		Результат = ИменаСтандартныхПолейОбъекта.Получить(Имя);
		
		Если Результат = Неопределено Тогда
			ВызватьИсключение "Неизвестное стандартное имя поля объекта: " + Имя;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
