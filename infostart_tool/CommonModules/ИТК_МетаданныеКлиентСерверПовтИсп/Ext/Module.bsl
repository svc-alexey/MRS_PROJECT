#Область ПрограммныйИнтерфейс

Функция ПорядокОбъектаКоллекции(Имя) Экспорт
	
	ИмяКоллекции = ИмяКоллекции(Имя);
	Возврат ИТК_МетаданныеКлиентСерверПовтИсп.ПорядокКоллекции(ИмяКоллекции);

КонецФункции

Функция ПорядокКоллекции(Имя) Экспорт
	
	Описание = НайтиОписаниеКоллекции(Имя);
	Возврат Описание["Порядок"];
	
КонецФункции

Функция КартинкаКоллекции(Имя) Экспорт
	
	Описание = НайтиОписаниеКоллекции(Имя);
	Возврат Описание["Картинка"];
	
КонецФункции

Функция КартинкаОбъектаКоллекции(Имя) Экспорт
	
	ИмяКоллекции = ИмяКоллекции(Имя);
	Возврат ИТК_МетаданныеКлиентСерверПовтИсп.КартинкаКоллекции(ИмяКоллекции);
	
КонецФункции

Функция Право(Имя) Экспорт
	
	Описание = НайтиОписаниеКоллекции(Имя);
	Возврат Описание["Право"];
	
КонецФункции

Функция ДоступныеКоллекцииМетаданныхГруппыОбщие() Экспорт
	
	Результат = Новый СписокЗначений;
	
	Для Каждого КлючЗначение Из ИТК_МетаданныеКлиентСерверПовтИсп.СоответствиеОписаниеКоллекций() Цикл 
		
		Описание = КлючЗначение.Значение;
		Если Описание["Группа"] <> "Общие" Тогда
			Продолжить;
		КонецЕсли;
		
		Результат.Добавить(Описание["Порядок"], КлючЗначение.Ключ, , Описание["Картинка"]);
		
	КонецЦикла;
	Результат.СортироватьПоЗначению();
	
	Возврат Результат;
	
КонецФункции

