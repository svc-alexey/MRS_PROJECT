Функция ИмяКоллекции(Имя, Язык = Неопределено) Экспорт
	
	Если Язык = Неопределено Тогда
		Язык = ИТК_ОбщийКлиентСервер.КодТекущегоЯзыка();
	КонецЕсли;
	
	СоответствиеИмяОбъектаИмяКоллекции = ИТК_МетаданныеКлиентСерверПовтИсп.СоответствиеИмяОбъектаИмяКоллекции();
	ИмяКоллекции = СоответствиеИмяОбъектаИмяКоллекции.Получить(Имя);
	Описание = НайтиОписаниеКоллекции(ИмяКоллекции);
	
	Если Язык = ИТК_ОбщийКлиентСервер.КодЯзыкаРусский() Тогда
		Результат = ИмяКоллекции;
	Иначе
		Результат = Описание["ИмяНаАнглийском"];
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

