Функция НайтиОписаниеКоллекции(Имя)
	
	ОписаниеКоллекций = ИТК_МетаданныеКлиентСерверПовтИсп.СоответствиеОписаниеКоллекций();
	
	Описание = ОписаниеКоллекций.Получить(Имя);
	Если ЗначениеЗаполнено(Описание) Тогда
		Возврат Описание;
	КонецЕсли;
	
	СоответствиеАнглийскогоИРусскогоИмени = СоответствиеАнглийскогоИРусскогоИмениКоллекции();
	ИмяНаРусском = СоответствиеАнглийскогоИРусскогоИмени.Получить(Имя);
	Описание = ОписаниеКоллекций.Получить(ИмяНаРусском);
	
	Если Описание = Неопределено Тогда
		ВызватьИсключение СтрШаблон("Неподдерживаемый тип объекта/коллекции метаданных: %1", Имя);
	КонецЕсли;
	
	Возврат Описание;
	
КонецФункции

Функция ЭтоОбъектКоллекция(Имя, Коллекция)
	
	Описание = НайтиОписаниеКоллекции(Коллекция);
	
	Возврат (Имя = Коллекция
				ИЛИ Имя = Описание["ИмяНаАнглийском"]
				ИЛИ Имя = Описание["ИмяЭлемента"]
				ИЛИ Имя = Описание["ИмяЭлементаНаАнглийском"]);
	
КонецФункции

Функция ОписаниеКоллекции()
	
	Результат = Новый Структура;
	
	Результат.Вставить("ИмяНаАнглийском");
	
	Результат.Вставить("ИмяЭлемента");
	Результат.Вставить("ИмяЭлементаНаАнглийском");
	
	Результат.Вставить("Картинка");
	Результат.Вставить("КартинкаЭлемента");
	
	Результат.Вставить("Группа", "");
	Результат.Вставить("Порядок", 0);
	
	Результат.Вставить("Право", "");
	
	Возврат Результат;
	
КонецФункции

