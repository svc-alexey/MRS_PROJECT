#Область ПрограммныйИнтерфейс

Процедура ОткрытьВПроводнике(ПолноеИмя) Экспорт

	Файл = Новый Файл(ПолноеИмя);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Путь", Файл.Путь);
	ДополнительныеПараметры.Вставить("ПолноеИмя", ПолноеИмя);
	ОписаниеОповещения = Новый ОписаниеОповещения("ЗавершенаПроверкаЭтоФайл", ЭтотОбъект, ДополнительныеПараметры);
	
	Файл.НачатьПроверкуЭтоФайл(ОписаниеОповещения);
	
КонецПроцедуры

Процедура ЗавершенаПроверкаЭтоФайл(ЭтоФайл, ДополнительныеПараметры) Экспорт
	
	Шаблон = "file:///%1";
	Параметр = ДополнительныеПараметры.ПолноеИмя;
	
	Если ЭтоФайл Тогда
		
		Если ИТК_ОбщийКлиент.ЭтоWindowsКлиент() Тогда
			
			Шаблон = "explorer.exe /select, ""%1""";
			
		Иначе // Это Linux или macOS
			
			Параметр = ДополнительныеПараметры.Путь;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Результат = СтрШаблон(Шаблон, Параметр);
	
	НачатьЗапускПриложения(ИТК_ОбщийКлиент.ПустойОбработчикОповещений(), Результат);
	
КонецПроцедуры

Функция КаталогДанныхПриложений() Экспорт
	
	WScriptShell = Новый COMОбъект("WScript.Shell");
	Возврат WScriptShell.ExpandEnvironmentStrings("%APPDATA%");

КонецФункции

Процедура СоздатьНесуществующиеКаталоги(ПолноеИмяФайла) Экспорт
	
	РазделительПути = ПолучитьРазделительПути();
	
	ЧастиПолногоИмениФайла = СтрРазделить(ПолноеИмяФайла, РазделительПути, Ложь);
	Для Индекс1 = 1 По ЧастиПолногоИмениФайла.Количество() - 2 Цикл
		
		ЧастьПутиКФайлу = "";
		Для Индекс2 = 0 По Индекс1 Цикл  
			ЧастьПутиКФайлу = ЧастьПутиКФайлу + ЧастиПолногоИмениФайла[Индекс2] + РазделительПути;
		КонецЦикла;
		
		Если ЗначениеЗаполнено(ЧастьПутиКФайлу) Тогда
			СоздатьКаталог(ЧастьПутиКФайлу);
		КонецЕсли;

	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти