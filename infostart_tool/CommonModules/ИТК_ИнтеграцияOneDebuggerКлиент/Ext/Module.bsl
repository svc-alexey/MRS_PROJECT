Процедура СохранитьСостояниеОтладчика(Форма, ЭлементТекст, ИзменяемыеПоля) Экспорт

	СостояниеОтладчика = ПолучитьСостояниеОтладчика(Форма, ЭлементТекст);
	
	Если СостояниеОтладчика <> Неопределено Тогда
		ИзменяемыеПоля.Вставить("СостояниеОтладчика", СостояниеОтладчика);	
	КонецЕсли;

КонецПроцедуры

Процедура УстановитьСостояниеОтладчика(Форма, Элемент, ДанныеСтроки) Экспорт
	
	Если НЕ ИТК_РедакторКодаКлиентСервер.ЭтоРедакторКодаMonaco(Элемент) Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ИТК_ИнтеграцияOneDebuggerКлиентСервер.ИспользуетсяOneDebugger(Форма, Элемент.Имя) Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ДанныеСтроки.Свойство("СостояниеОтладчика") Тогда
		Возврат;
	КонецЕсли;
	
	СостояниеОтладчика = ДанныеСтроки["СостояниеОтладчика"];
	
	ОбщийМодуль = Вычислить("dbgИнтерфейсКлиент");
	ОбщийМодуль.УстановитьСостояниеОтладчика(Форма, СостояниеОтладчика); 	
		
КонецПроцедуры

Процедура ОчиститьСостояниеОтладчика(НачальныеДанные) Экспорт

	Если НачальныеДанные.Свойство("СостояниеОтладчика") Тогда
		НачальныеДанные.СостояниеОтладчика = Неопределено;	
	КонецЕсли;
		
КонецПроцедуры

Процедура ОбработатьСобытиеИзмененияСодержимогоРедактора(Форма, ДанныеСобытия, Имя) Экспорт
	
	Если Не ИТК_ИнтеграцияOneDebuggerКлиентСервер.ИспользуетсяOneDebugger(Форма, Имя) Тогда
		Возврат;
	КонецЕсли;
		
	Событие = ДанныеСобытия.Event.eventData1C;
	
	Если Событие = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	ИмяСобытия = Событие.event;
	
	Если ИмяСобытия = "EVENT_CONTENT_CHANGED" Тогда	
		ОбщийМодуль = Вычислить("dbgИнтерфейсКлиент");
		ОбщийМодуль.ПриИзмененииСодержимогоРедактора(Форма);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПолучитьСостояниеОтладчика(Форма, Элемент)
	
	Если НЕ ИТК_РедакторКодаКлиентСервер.ЭтоРедакторКодаMonaco(Элемент) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если Не ИТК_ИнтеграцияOneDebuggerКлиентСервер.ИспользуетсяOneDebugger(Форма, Элемент.Имя) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ОбщийМодуль = Вычислить("dbgИнтерфейсКлиент");
	Результат   = ОбщийМодуль.ПолучитьСостояниеОтладчика(Форма); 	
	
	Возврат Результат;
	
КонецФункции  

#КонецОбласти
