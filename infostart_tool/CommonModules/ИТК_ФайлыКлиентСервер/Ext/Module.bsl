#Область ПрограммныйИнтерфейс

// Получает первый файл из каталога по маске
//
// Параметры:
//	Путь - Строка - Путь
//	Маска - Строка - Маска файлов
//
// Возвращаемое значение:
//   Строка - Полное имя файла 
//
Функция ПервыйИзКаталога(Путь, Маска = "*.*") Экспорт
	
	НайденныеФайлы = НайтиФайлы(Путь, Маска);
	Если ЗначениеЗаполнено(НайденныеФайлы) Тогда
		Результат = НайденныеФайлы[0].ПолноеИмя;
	Иначе
		Результат = Неопределено;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Переименовывает каталог
//
// Параметры:
//	СтароеИмя - Строка - Старое имя
//	НовоеИмя - Строка - Новое имя
//
Процедура ПереименоватьКаталог(СтароеИмя, НовоеИмя) Экспорт 
	
	FSO = Новый COMОбъект("Scripting.FileSystemObject"); 
	FSO.MoveFolder(СтароеИмя, НовоеИмя); 
	
КонецПроцедуры

// Получает полное имя дополняя путь именем
//
// Параметры:
//	Путь - Строка - Путь
//	Имя - Строка - Имя файла
//
// Возвращаемое значение:
//   Строка - Полное имя файла 
//
Функция ПолноеИмя(Путь, Имя, Расширение = Неопределено) Экспорт
	
	РазделительПути = ПолучитьРазделительПути();
	
	Результат = Путь;
	Если НЕ СтрЗаканчиваетсяНа(Путь, РазделительПути) Тогда
		Результат = Результат + РазделительПути;
	КонецЕсли;
	
	Результат = Результат + Имя;
	
	Если ЗначениеЗаполнено(Расширение) Тогда
		Результат = Результат + "." + Расширение;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Читает текст из файла
//
// Параметры:
//	Объект - Строка,Поток - Объект чтения
//
// Возвращаемое значение:
//   Строка - Прочитанный текст
//
Функция ПрочитатьТекст(ПолноеИмяФайла) Экспорт

	#Если Сервер Тогда
	
	Файл = Новый Файл(ПолноеИмяФайла);

	Если Не Файл.Существует() Тогда
		Возврат Неопределено;
	КонецЕсли;

	#КонецЕсли

	ТекстовыйДокумент = Новый ТекстовыйДокумент;
	ТекстовыйДокумент.Прочитать(ПолноеИмяФайла, КодировкаТекста.UTF8);
	Результат = ТекстовыйДокумент.ПолучитьТекст();

	Возврат Результат;
	
КонецФункции

// Записывает текст в файл
//
// Параметры:
//	ПолноеИмяФайла - Строка - Полное имя файла
//	Текст - Строка - Текст
//
Процедура ЗаписатьТекст(ПолноеИмяФайла, Текст) Экспорт
	
	ТекстовыйДокумент = Новый ТекстовыйДокумент;
	ТекстовыйДокумент.УстановитьТекст(Текст);
	ТекстовыйДокумент.Записать(ПолноеИмяФайла, КодировкаТекста.UTF8);
	
КонецПроцедуры

// Получает короткое представление полного имени файла
//
// Параметры:
//   ПолноеИмяФайла - Строка - Полное имя файла
//
// Возвращаемое значение:
//   Строка - короткое представление имени файла
Функция ПолноеИмяФайлаКратко(ПолноеИмяФайла) Экспорт
	
	ПозицияСимвола = СтрНайти(ПолноеИмяФайла, ПолучитьРазделительПути(), НаправлениеПоиска.СКонца);
	ПутьКФайлу = Лев(ПолноеИмяФайла, ПозицияСимвола - 1);
	ИмяФайла = Сред(ПолноеИмяФайла, ПозицияСимвола + 1);
	
	КраткоеПолноеИмяФайла = "";
	Если СтрДлина(ПутьКФайлу) > 7 Тогда
		ПутьКФайлу = Лев(ПутьКФайлу, 7) + "...";
		КраткоеПолноеИмяФайла = ПутьКФайлу + ПолучитьРазделительПути() + ИмяФайла;
	Иначе 
		КраткоеПолноеИмяФайла = ПолноеИмяФайла;
	КонецЕсли;	
	
	Возврат КраткоеПолноеИмяФайла;
	
КонецФункции

Функция СтрокаФильтраФайлов(Представление, Расширение) Экспорт
	
	Возврат СтрШаблон("%1 (%2)|%2", Представление, Расширение);
	
КонецФункции

#КонецОбласти

