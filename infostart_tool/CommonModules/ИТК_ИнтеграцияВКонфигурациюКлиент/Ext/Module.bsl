Процедура МенеджерФормы(Ссылка, ПараметрыВыполнения) Экспорт
	
	АктивноеОкно = АктивноеОкно();
	ОсновнаяФорма = АктивноеОкно.Содержимое[0];
	
	ИТК_ТуллкитКлиент.ОткрытьИнструмент(
		ИТК_Перечисления.ИнструментМенеджерФормы(), ОсновнаяФорма.УникальныйИдентификатор);
	
КонецПроцедуры

