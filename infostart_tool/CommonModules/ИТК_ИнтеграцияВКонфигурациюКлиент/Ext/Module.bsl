Процедура ЖурналРегистрации(Ссылки, ПараметрыВыполнения) Экспорт
	
	Параметры = Новый Структура;
	
	Если ТипЗнч(Ссылки) = Тип("Массив") Тогда
		
		Данные = Новый СписокЗначений;
		Данные.ЗагрузитьЗначения(Ссылки);
		
	Иначе
		Данные = Ссылки;
	КонецЕсли;
	Параметры.Вставить("Данные", Данные);
	
	ИТК_ФормаКлиент.ОткрытьЖурналРегистрации(Параметры);
	
КонецПроцедуры

