#Область ПрограммныйИнтерфейс

Процедура СвойстваОбъекта(Параметры, АдресРезультата) Экспорт
	
	ПолноеИмя = Параметры.ПолноеИмя;
	ТолькоВажныеСвойства = Параметры.ТолькоВажныеСвойства;
	
	Результат = Новый ДеревоЗначений;
	Результат.Колонки.Добавить("Имя", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	Результат.Колонки.Добавить("Значение");
	Результат.Колонки.Добавить("Представление", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	Результат.Колонки.Добавить("Картинка", ИТК_ТипыКлиентСервер.ОписаниеКартинка());
	Результат.Колонки.Добавить("ЭтоГруппа", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	Результат.Колонки.Добавить("Комментарий", ИТК_ТипыКлиентСервер.ОписаниеСтрока());

	Результат.Колонки.Добавить("Тип", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	Результат.Колонки.Добавить("КартинкаТипа", ИТК_ТипыКлиентСервер.ОписаниеКартинка());
	Результат.Колонки.Добавить("ДоступнаФормаСписка", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	Результат.Колонки.Добавить("ПредставлениеГиперссылки");
	Результат.Колонки.Добавить("ДанныеГиперссылки");
	
	Результат.Колонки.Добавить("Индексирование", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	Результат.Колонки.Добавить("Расширение", ИТК_ТипыКлиентСервер.ОписаниеСтрока());

	ИмяКоллекции = ИТК_Метаданные.ИмяКоллекции(ПолноеИмя);
	ОбъектМетаданных = Метаданные.НайтиПоПолномуИмени(ПолноеИмя);
	
	// Корень
	СтрокаКорень = Результат.Строки.Добавить();
	СтрокаКорень.Имя = ОбъектМетаданных.Имя;
	СтрокаКорень.ЭтоГруппа = Истина;
	СтрокаКорень.Представление = ОбъектМетаданных.Представление();
	СтрокаКорень.Комментарий = ОбъектМетаданных.Комментарий;
	СтрокаКорень.Картинка = ИТК_МетаданныеКлиентСерверПовтИсп.КартинкаКоллекции(ИмяКоллекции);
	СтрокаКорень.Тип = ПолноеИмя;
	СтрокаКорень.Расширение = ИТК_Метаданные.ИмяРасширения(ОбъектМетаданных);

	// Добавление свойств
	ДобавлениеСвойствПоОбъекту(СтрокаКорень, ОбъектМетаданных, ТолькоВажныеСвойства);
	
	// Типы
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ИмеетТипЗначения(ИмяКоллекции) Тогда
		
		ОписаниеТипов = ОбъектМетаданных.Тип;
		КоличествоТипов = ИТК_ТипыКлиентСервер.Количество(ОписаниеТипов);
		Если КоличествоТипов > 1 Тогда
			
			ДобавитьКоллекциюОписанияТипов(СтрокаКорень, ОписаниеТипов, НСтр("ru = 'Типы'; en = 'Types'"), БиблиотекаКартинок.ИТК_ТипОписаниеТипов);
			
		КонецЕсли;
		
	КонецЕсли;

	КонтекстОбъекта = Новый Структура;
	КонтекстОбъекта.Вставить("ИмяКоллекцииОбъекта", ИмяКоллекции);
	КонтекстОбъекта.Вставить("ОбъектМетаданных", ОбъектМетаданных);
	
	ДобавитьКоллекциюСвойств(КонтекстОбъекта, СтрокаКорень, "ЗначенияПеречисления");
	ДобавитьКоллекциюСвойств(КонтекстОбъекта, СтрокаКорень, "Владельцы", НСтр("ru = 'Владельцы'; en = 'Owners'"));
	ДобавитьКоллекциюСвойств(КонтекстОбъекта, СтрокаКорень, "Графы",  НСтр("ru = 'Графы'; en = 'Columns'"));
	
	ДобавитьГруппуСвойствВсеРеквизиты(КонтекстОбъекта, СтрокаКорень);
	
	// Табличные части
	ДобавитьКоллекциюТЧСвойств(КонтекстОбъекта, СтрокаКорень, "СтандартныеТабличныеЧасти", НСтр("ru = 'Стандартные табличные части'; en = 'Standard table parts'"));
	ДобавитьКоллекциюТЧСвойств(КонтекстОбъекта, СтрокаКорень, "ТабличныеЧасти", НСтр("ru = 'Табличные части'; en = 'Table parts'"));
	
	ДобавитьКоллекциюСвойств(КонтекстОбъекта, СтрокаКорень, "Измерения", НСтр("ru = 'Измерения'; en = 'Dimensions'"));
	ДобавитьКоллекциюСвойств(КонтекстОбъекта, СтрокаКорень, "Ресурсы", НСтр("ru = 'Ресурсы'; en = 'Resources'"));
	ДобавитьКоллекциюСвойств(КонтекстОбъекта, СтрокаКорень, "РегистрируемыеДокументы", НСтр("ru = 'Регистрируемые документы'; en = 'Registered documents'"));
	ДобавитьКоллекциюСвойств(КонтекстОбъекта, СтрокаКорень, "Движения", НСтр("ru = 'Движения'; en = 'RegisterRecords'"));
	ДобавитьКоллекциюСвойств(КонтекстОбъекта, СтрокаКорень, "Состав", НСтр("ru = 'Состав'; en = 'Content'"));
	ДобавитьКоллекциюСвойств(КонтекстОбъекта, СтрокаКорень, "Использование", НСтр("ru = 'Использование'; en = 'Use'"));

	// Источник
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПодпискаНаСобытие(ИмяКоллекции) Тогда
		
		ОписаниеТипов = ОбъектМетаданных.Источник;
		КоличествоТипов = ИТК_ТипыКлиентСервер.Количество(ОписаниеТипов);
		ДобавитьКоллекциюОписанияТипов(СтрокаКорень, ОписаниеТипов, НСтр("ru = 'Источник'; en = 'Source'"), БиблиотекаКартинок.ИТК_ТипОписаниеТипов);
		
	КонецЕсли;
	
	ДобавитьКоллекциюСвойств(КонтекстОбъекта, СтрокаКорень, "ПризнакиУчета", НСтр("ru = 'Признаки учета'; en = 'Accounting flags'"));
	ДобавитьКоллекциюСвойств(КонтекстОбъекта, СтрокаКорень, "ПризнакиУчетаСубконто", НСтр("ru = 'Признаки учета субконто'; en = 'Ext dimension accounting flags'"));
	
	// Предопределенные
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ОбъектCПредопределенными(ИмяКоллекции, Ложь) Тогда
		
		ДеревоПредопределенных = ИТК_Метаданные.ДеревоПредопределенных(ОбъектМетаданных);
		Если ИТК_Общий.ЗаполненоДерево(ДеревоПредопределенных) Тогда

			КоличествоСтрок = ИТК_Общий.КоличествоСтрокВДеревеЗначений(ДеревоПредопределенных);
			СтрокаГруппа = ДобавитьГруппуСвойств(СтрокаКорень, НСтр("ru = 'Предопределенные'; en = 'Predefined'"), , КоличествоСтрок);
			
			ДобавлениеПредопределенных(СтрокаГруппа, ДеревоПредопределенных, ИмяКоллекции);
			
		КонецЕсли;
		
	КонецЕсли;
	
	// Подсистемы
	ДеревоПодсистем = ИТК_Метаданные.ДеревоПодсистемОбъекта(ОбъектМетаданных);
	
	КоличествоСтрок = ИТК_Общий.КоличествоСтрокВДеревеЗначений(ДеревоПодсистем);
	СтрокаГруппа = ДобавитьГруппуСвойств(СтрокаКорень, НСтр("ru = 'Подсистемы'; en = 'Subsystems'"), БиблиотекаКартинок.ИТК_МетаданныеПодсистема, КоличествоСтрок);
	
	Если ИТК_Общий.ЗаполненоДерево(ДеревоПодсистем) Тогда
		ДобавлениеПодсистем(СтрокаГруппа, ДеревоПодсистем);
	КонецЕсли;

	// Регистраторы
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоРегистр(ИмяКоллекции) Тогда
		
		ОписаниеТиповРегистратор = Неопределено;
		Для Каждого ОписаниеРеквизита Из ОбъектМетаданных.СтандартныеРеквизиты Цикл 
			
			Если ОписаниеРеквизита.Имя = "Регистратор"
					ИЛИ ОписаниеРеквизита.Имя = "Recorder" Тогда
					
				ОписаниеТиповРегистратор = ОписаниеРеквизита.Тип;
				Прервать;
					
			КонецЕсли;

		КонецЦикла;
		
		Если ЗначениеЗаполнено(ОписаниеТиповРегистратор) Тогда
			
			ДобавитьКоллекциюОписанияТипов(СтрокаКорень, ОписаниеТиповРегистратор, НСтр("ru = 'Регистраторы'; en = 'Recorders'"));
			
		КонецЕсли;
		
	КонецЕсли;
	
	ДобавитьКоллекциюСвойств(КонтекстОбъекта, СтрокаКорень, "Команды",  НСтр("ru = 'Команды'; en = 'Commands'"));
	
	// Ввод на основании
	ДобавитьКоллекциюСвойств(КонтекстОбъекта, СтрокаКорень, "ВводитсяНаОсновании",  НСтр("ru = 'Вводится на основании'; en = 'Entered on the basis'"));
	
	// Является основанием для
	ДобавитьГруппуЯвляетсяОснованиемДля(СтрокаКорень, ОбъектМетаданных);
	
	// Роли
	ДобавитьГруппуРоли(СтрокаКорень, ОбъектМетаданных); 
	
	// Функциональные опции
	ДобавитьГруппуФункциональныеОпции(СтрокаКорень, ОбъектМетаданных); 
	
	// Подписки на события
	ДобавитьГруппуПодпискиНаСобытия(СтрокаКорень, ОбъектМетаданных); 
	
	ПоместитьВоВременноеХранилище(Результат, АдресРезультата);
	
КонецПроцедуры

Процедура СтруктураХранения(Параметры, АдресРезультата) Экспорт
	
	ПолноеИмя = Параметры.ПолноеИмя;
	ИменаВБазеДанныхВТерминах = Параметры.ИменаВБазеДанныхВТерминах;
	
	Результат = Новый ДеревоЗначений;
	Результат.Колонки.Добавить("Поле", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	Результат.Колонки.Добавить("ПолеХранения", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	Результат.Колонки.Добавить("Картинка", ИТК_ТипыКлиентСервер.ОписаниеКартинка());
	Результат.Колонки.Добавить("ЭтоГруппа", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	Результат.Колонки.Добавить("Метаданные", ИТК_ТипыКлиентСервер.ОписаниеКоллекцияИИмяМетаданных());
	
	// Получение данных структуру хранения
	ОбъектМетаданных = Метаданные.НайтиПоПолномуИмени(ПолноеИмя);	
	ОбъектыМетаданных = Новый Массив;
	ОбъектыМетаданных.Добавить(ОбъектМетаданных);
	
	ИменаВТерминахСУБД = (ИменаВБазеДанныхВТерминах = "SDBL");
	СтруктураХранения = ПолучитьСтруктуруХраненияБазыДанных(ОбъектыМетаданных, ИменаВТерминахСУБД);
	
	// Дополнительная обработка таблицы
	СтруктураХранения.Колонки.Добавить("Порядок", ИТК_ТипыКлиентСервер.ОписаниеЧисло());
	
	ОписанияХранения = ИТК_СтруктураХраненияБазыДанныхПовтИсп.ОписанияХранения();
	ПоляТаблицыХранения = ОписанияХранения.ПоляТаблицы;
	
	Для Каждого Строка Из СтруктураХранения Цикл 
		
		Назначение = Строка[ПоляТаблицыХранения.Назначение];
		Если Назначение = ИТК_СтруктураХраненияБазыДанныхПовтИсп.НазначениеТаблицы("Основная")
				ИЛИ Назначение = ИТК_СтруктураХраненияБазыДанныхПовтИсп.НазначениеТаблицы("Константа") Тогда
			Порядок = 0;
		ИначеЕсли Назначение = ИТК_СтруктураХраненияБазыДанныхПовтИсп.НазначениеТаблицы("ТабличнаяЧасть") Тогда
			Порядок = 10;
		Иначе	
			Порядок = 100;
		КонецЕсли;
		
		Строка.Порядок = Порядок;

	КонецЦикла;
	
	СтруктураХранения.Сортировать("Порядок, " + ПоляТаблицыХранения.ИмяТаблицы);
	
	// Подготовка отображения
	ПерваяСтрока = Истина;
	СтрокаТабличныеЧасти = Неопределено;
	КартинкаТабличнаяЧасть = БиблиотекаКартинок.ВложеннаяТаблица;
	
	Для Каждого Строка Из СтруктураХранения Цикл 
		
		Назначение = Строка[ПоляТаблицыХранения.Назначение];
		ИмяТаблицыХранения = Строка[ПоляТаблицыХранения.ИмяТаблицыХранения];
		
		Если ПерваяСтрока Тогда
			
			ИмяОбъектаКоллекции = ИТК_Метаданные.ИмяОбъектаКоллекции(ОбъектМетаданных);
			Картинка = ИТК_МетаданныеКлиентСерверПовтИсп.КартинкаОбъектаКоллекции(ИмяОбъектаКоллекции);
			КорневаяСтрока = ДобавитьГруппуСтруктурыХранения(Результат, ОбъектМетаданных.Имя, Картинка, ИмяТаблицыХранения, ПоляТаблицыХранения.Метаданные);
			ДобавитьПоляИндексыСтруктурыХранения(КорневаяСтрока, Строка, ОписанияХранения);
			
			ПерваяСтрока = Ложь;
			Продолжить;
			
		КонецЕсли;
		
		Если Назначение = ИТК_СтруктураХраненияБазыДанныхПовтИсп.НазначениеТаблицы("ТабличнаяЧасть") Тогда
			
			Если СтрокаТабличныеЧасти = Неопределено Тогда
				СтрокаТабличныеЧасти = ДобавитьГруппуСтруктурыХранения(КорневаяСтрока, НСтр("ru = 'Табличные части'; en = 'Tabular parts'"), КартинкаТабличнаяЧасть);
			КонецЕсли;
			
			ИмяТаблицы = ИмяОбъектаСтруктурыХранения(Строка[ПоляТаблицыХранения.ИмяТаблицы]);
			СтрокаТабличнаяЧасть = ДобавитьГруппуСтруктурыХранения(СтрокаТабличныеЧасти, ИмяТаблицы, КартинкаТабличнаяЧасть, ИмяТаблицыХранения, ПоляТаблицыХранения.Метаданные);
			ДобавитьПоляИндексыСтруктурыХранения(СтрокаТабличнаяЧасть, Строка, ОписанияХранения);
			
		Иначе
			
			ПрочаяСтрока = ДобавитьГруппуСтруктурыХранения(КорневаяСтрока, Назначение, , ИмяТаблицыХранения);
			ДобавитьПоляИндексыСтруктурыХранения(ПрочаяСтрока, Строка, ОписанияХранения);
			
		КонецЕсли;
		
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(Результат, АдресРезультата);
	
КонецПроцедуры

Процедура СсылкиНаОбъект(Параметры, АдресРезультата) Экспорт
	
	ПолноеИмя = Параметры.ПолноеИмя;
	
	Результат = Новый ДеревоЗначений;
	Результат.Колонки.Добавить("Имя", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	Результат.Колонки.Добавить("Картинка", ИТК_ТипыКлиентСервер.ОписаниеКартинка());
	Результат.Колонки.Добавить("ЭтоГруппа", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	Результат.Колонки.Добавить("Представление", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	Результат.Колонки.Добавить("Метаданные", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	Результат.Колонки.Добавить("Расширение", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	
	ИскомыйОбъектМетаданных = Метаданные.НайтиПоПолномуИмени(ПолноеИмя);
	
	ИмяОбъектаКоллекции = ИТК_Метаданные.ИмяОбъектаКоллекции(ИскомыйОбъектМетаданных);
	ИмяТипаСсылка = ИТК_МетаданныеКлиентСервер.ПолноеИмяТипаСсылка(ИмяОбъектаКоллекции, ИскомыйОбъектМетаданных.Имя);
	
	// Поиск ссылок на объект
	КоллекцииСсылокНаОбъект = Новый Соответствие;
	
	МестаПоиска = МестаПоискаСсылкиНаОбъект();
	Для Каждого МестоПоиска Из МестаПоиска Цикл 
		
		Если МестоПоиска.Поиск = "Тип" Тогда
			
			Если ЗначениеЗаполнено(ИмяТипаСсылка) Тогда
				ИскомыйТипСсылка = Тип(ИмяТипаСсылка);
			Иначе
				Продолжить;
			КонецЕсли;
			
		КонецЕсли;
		
		ОбъектыПоля = СтрРазделить(МестоПоиска.ОбъектыПоля, ".");
		
		ПростоеПоле = (ОбъектыПоля.Количество() = 2);
		ВложенноеПоле = (ОбъектыПоля.Количество() = 3);
		ТабличноеПоле = (ОбъектыПоля.Количество() = 4);
		
		ИмяКоллекции = ОбъектыПоля[0];
		
		ОбъектыКоллекции = ИТК_Метаданные.ОбъектыКоллекцииБезИерархии(ИмяКоллекции);
		Для Каждого ОбъектПоиска Из ОбъектыКоллекции Цикл 
			
			Если ПростоеПоле Тогда
				
				ИмяПоля = ОбъектыПоля[1];
				ПроверяемоеЗначение = ОбъектПоиска[ИмяПоля];
				
				Если СсылкиНаОбъектНайтиИспользование(ПроверяемоеЗначение, ИскомыйОбъектМетаданных, ИскомыйТипСсылка) Тогда
					
					ОписаниеОбъекта = СсылкиНаОбъектДобавитьОбъект(КоллекцииСсылокНаОбъект, ИмяКоллекции, ОбъектПоиска);
					СсылкиНаОбъектДобавитьПоле(ОписаниеОбъекта, "Поля", ИмяПоля, ОбъектПоиска, , ИмяПоля);
					
				КонецЕсли;
				
			Иначе
				
				ИмяПоляКоллекции = ОбъектыПоля[1];

				Если ИмяПоляКоллекции = "Реквизиты" Тогда
					КартинкаЭлементаКоллекции = ИТК_ОбщийКлиентСерверПовтИсп.БиблиотекаКартинок("Реквизит");
				ИначеЕсли ИмяПоляКоллекции = "Измерения" Тогда
					КартинкаЭлементаКоллекции = ИТК_ОбщийКлиентСерверПовтИсп.БиблиотекаКартинок("ИТК_МетаданныеИзмерения");
				ИначеЕсли ИмяПоляКоллекции = "Ресурсы" Тогда
					КартинкаЭлементаКоллекции = ИТК_ОбщийКлиентСерверПовтИсп.БиблиотекаКартинок("ИТК_МетаданныеРесурсы");
				КонецЕсли;
				
				Для Каждого ОбъектЭлементКоллекции Из ОбъектПоиска[ИмяПоляКоллекции] Цикл 
					
					Если ВложенноеПоле Тогда
						
						ИмяПоля = ОбъектыПоля[2];
						ПроверяемоеЗначение = ОбъектЭлементКоллекции[ИмяПоля];
						
						Если СсылкиНаОбъектНайтиИспользование(ПроверяемоеЗначение, ИскомыйОбъектМетаданных, ИскомыйТипСсылка) Тогда
							
							ОписаниеОбъекта = СсылкиНаОбъектДобавитьОбъект(КоллекцииСсылокНаОбъект, ИмяКоллекции, ОбъектПоиска);
							СсылкиНаОбъектДобавитьПоле(ОписаниеОбъекта, "ЭлементыКоллекций", ОбъектЭлементКоллекции.Имя, ОбъектЭлементКоллекции, КартинкаЭлементаКоллекции);
							
						КонецЕсли;
						
					Иначе
						
						КартинкаРеквизит = ИТК_ОбщийКлиентСерверПовтИсп.БиблиотекаКартинок("Реквизит");
						
						ОбъектТабличнаяЧасть = ОбъектЭлементКоллекции;
						Для Каждого ОбъектРеквизит Из ОбъектТабличнаяЧасть.Реквизиты Цикл 
							
							ПроверяемоеЗначение = ОбъектРеквизит.Тип;
							
							Если СсылкиНаОбъектНайтиИспользование(ПроверяемоеЗначение, ИскомыйОбъектМетаданных, ИскомыйТипСсылка) Тогда
								
								ОписаниеОбъекта = СсылкиНаОбъектДобавитьОбъект(КоллекцииСсылокНаОбъект, ИмяКоллекции, ОбъектПоиска);
								ОписаниеТабличнойЧасти = СсылкиНаОбъектДобавитьТабличнуюЧасть(ОписаниеОбъекта, ОбъектТабличнаяЧасть);
								
								СсылкиНаОбъектДобавитьПоле(ОписаниеТабличнойЧасти, "Реквизиты", ОбъектРеквизит.Имя, ОбъектРеквизит, КартинкаРеквизит);
								
							КонецЕсли;
							
						КонецЦикла;
						
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;

	КонецЦикла;
	
	// Сортировка результатов
	Для Каждого КоллекцияСсылокНаОбъект Из КоллекцииСсылокНаОбъект Цикл 
		
		СписокОбъектов = ИТК_ОбщийКлиентСервер.СоответствиеВСписокЗначений(КоллекцияСсылокНаОбъект.Значение);
		СписокОбъектов.СортироватьПоПредставлению();
		
		КоллекцииСсылокНаОбъект.Вставить(КоллекцияСсылокНаОбъект.Ключ, СписокОбъектов);
		
		Для Каждого ОбъектКоллекции Из КоллекцияСсылокНаОбъект.Значение Цикл 
			
			ОписаниеОбъекта = ОбъектКоллекции.Значение;
			
			ОписаниеОбъекта.Поля.СортироватьПоПредставлению();
			ОписаниеОбъекта.ЭлементыКоллекций.СортироватьПоПредставлению();
			ОписаниеОбъекта.ТабличныеЧасти.СортироватьПоПредставлению();
			
		КонецЦикла;
		
	КонецЦикла;
	
	// Вывод в дерево
	ВсеКоллекцииПоПорядку = ИТК_МетаданныеПовтИсп.ВсеКоллекцииПоПорядку();
	Для Каждого ИмяКоллекции Из ВсеКоллекцииПоПорядку Цикл 
		
		СписокОбъектов = КоллекцииСсылокНаОбъект.Получить(ИмяКоллекции);
		Если СписокОбъектов = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		КартинкаКоллекции = ИТК_МетаданныеКлиентСерверПовтИсп.КартинкаКоллекции(ИмяКоллекции);
		СтрокаГруппа = ДобавитьСтрокуГруппуСсылкиНаОбъект(Результат, ИмяКоллекции, КартинкаКоллекции, СписокОбъектов.Количество());
		
		Для Каждого ЭлементОбъектКоллекции Из СписокОбъектов Цикл 
			
			ИмяОбъекта = ЭлементОбъектКоллекции.Представление;
			ОбъектКоллекцииЗначение = ЭлементОбъектКоллекции.Значение;
			
			СтрокаОбъектКоллекции = ДобавитьСтрокуСсылкиНаОбъект(СтрокаГруппа, ИмяОбъекта, ОбъектКоллекцииЗначение.Представление, ОбъектКоллекцииЗначение.Метаданные,
													КартинкаКоллекции, ОбъектКоллекцииЗначение.Расширение);
			
			Для Каждого ЭлементПоле Из ОбъектКоллекцииЗначение.Поля Цикл 
					
				ОписаниеПоля = ЭлементПоле.Значение;

				ДобавитьСтрокуСсылкиНаОбъект(СтрокаОбъектКоллекции, ЭлементПоле.Представление, ОписаниеПоля.Представление,
												ОписаниеПоля.Метаданные, , ОписаниеПоля.Расширение);
																
			КонецЦикла;

			Для Каждого ЭлементРеквизит Из ОбъектКоллекцииЗначение.ЭлементыКоллекций Цикл 
				
				ОписаниеРеквизита = ЭлементРеквизит.Значение;

				ДобавитьСтрокуСсылкиНаОбъект(СтрокаОбъектКоллекции, ЭлементРеквизит.Представление, ОписаниеРеквизита.Представление, ОписаниеРеквизита.Метаданные,
															ЭлементРеквизит.Картинка, ОписаниеРеквизита.Расширение);
															
			КонецЦикла;
			
			Для Каждого ЭлементТабличнаяЧасть Из ОбъектКоллекцииЗначение.ТабличныеЧасти Цикл 
				
				ОписаниеТабличнойЧасти = ЭлементТабличнаяЧасть.Значение;
				
				КартинкаТабличнаяЧасть = ИТК_ОбщийКлиентСерверПовтИсп.БиблиотекаКартинок("ВложеннаяТаблица");
				СтрокаТабличнаяЧасть = ДобавитьСтрокуСсылкиНаОбъект(СтрокаОбъектКоллекции, ЭлементТабличнаяЧасть.Представление, ОписаниеТабличнойЧасти.Представление, ОписаниеТабличнойЧасти.Метаданные,
				КартинкаТабличнаяЧасть, ОписаниеТабличнойЧасти.Расширение);
				
				Для Каждого ЭлементРеквизит Из ОписаниеТабличнойЧасти.Реквизиты Цикл 
					
					ОписаниеРеквизита = ЭлементРеквизит.Значение;
					
					КартинкаРеквизит = ИТК_ОбщийКлиентСерверПовтИсп.БиблиотекаКартинок("Реквизит");
					ДобавитьСтрокуСсылкиНаОбъект(СтрокаТабличнаяЧасть, ЭлементРеквизит.Представление, ОписаниеРеквизита.Представление, ОписаниеРеквизита.Метаданные,
															КартинкаРеквизит, ОписаниеРеквизита.Расширение);
					
				КонецЦикла;
				
			КонецЦикла;

		КонецЦикла;

	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(Результат, АдресРезультата);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ДобавлениеСвойствПоОбъекту(Родитель, ОбъектМетаданных, ТолькоВажные);
	
	ПараметрыФункции = Новый Структура;
	ПараметрыФункции.Вставить("ПолноеИмя", ОбъектМетаданных.ПолноеИмя());
	ПараметрыФункции.Вставить("СортироватьПоАлфавиту", Истина);
	ПараметрыФункции.Вставить("ТолькоВажные", ТолькоВажные);
	ПараметрыФункции.Вставить("БазовыеСвойства", Ложь);
	
	ЗначенияСвойств = ИТК_ИнструментМетаданные.ЗначенияСвойств(ПараметрыФункции);

	Если ИТК_Общий.ЗаполненоДерево(ЗначенияСвойств) Тогда
		СтрокаГруппаСвойства = ДобавитьГруппуСвойств(Родитель, НСтр("ru = 'Свойства'; en = 'Properties'"));
	КонецЕсли;

	Для Каждого СтрокаСвойство Из ЗначенияСвойств.Строки Цикл 
		
		НоваяСтрока = СтрокаГруппаСвойства.Строки.Добавить();
		НоваяСтрока.Имя = СтрокаСвойство.Представление;
		НоваяСтрока.Представление = СтрокаСвойство.ПредставлениеЗначения;
		НоваяСтрока.Картинка = СтрокаСвойство.Картинка;
		
		НоваяСтрока.Значение = СтрокаСвойство.Значение;
		НоваяСтрока.ДанныеГиперссылки = СтрокаСвойство.ДанныеГиперссылки; 
		НоваяСтрока.ПредставлениеГиперссылки = СтрокаСвойство.ПредставлениеГиперссылки;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ДобавитьГруппуСвойств(Родитель, Представление, Картинка = Неопределено, Количество = Неопределено, Значение = Неопределено)
	
	Результат = Родитель.Строки.Добавить();
	
	Если Количество = Неопределено Тогда
		Результат.Имя = Представление;
	Иначе
		
		ДополненноеПредставление = ИТК_ФормаКлиентСервер.ЗаголовокСКоличеством(Представление, Количество);
		Результат.Имя = ДополненноеПредставление;
		
	КонецЕсли;

	Результат.ЭтоГруппа = Истина;
	Результат.Значение = Значение;
	
	Если Картинка = Неопределено Тогда
		Картинка = Новый Картинка;
	КонецЕсли;
	Результат.Картинка = Картинка;
	
	Возврат Результат;
	
КонецФункции

Процедура ДобавитьКоллекциюСвойств(КонтекстОбъекта, Родитель, ИмяКоллекции, Представление = Неопределено)
	
	// Проверка вывода
	ИмяКоллекцииМетаданных = КонтекстОбъекта.ИмяКоллекцииОбъекта;
	Если ИмяКоллекции = "Измерения" Тогда
		
		ПрошлаПроверка = ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоРегистр(ИмяКоллекцииМетаданных)
							ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПоследовательность(ИмяКоллекцииМетаданных);
								
	ИначеЕсли ИмяКоллекции = "Ресурсы" Тогда
		
		ПрошлаПроверка = ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоРегистр(ИмяКоллекцииМетаданных);
								
	ИначеЕсли ИмяКоллекции = "Графы" Тогда
		
		ПрошлаПроверка = ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоЖурналДокументов(ИмяКоллекцииМетаданных);
		
	ИначеЕсли ИмяКоллекции = "Владельцы" Тогда
		
		ПрошлаПроверка = ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоСправочник(ИмяКоллекцииМетаданных);
		
	ИначеЕсли ИмяКоллекции = "Движения" Тогда
		
		ПрошлаПроверка = ИТК_МетаданныеКлиентСерверПовтИсп.ИмеетДвижения(ИмяКоллекцииМетаданных);
		
	ИначеЕсли ИмяКоллекции = "РегистрируемыеДокументы" Тогда
		
		ПрошлаПроверка = ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоЖурналДокументов(ИмяКоллекцииМетаданных);
		
	ИначеЕсли ИмяКоллекции = "ЗначенияПеречисления" Тогда
		
		ПрошлаПроверка = ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПеречисление(ИмяКоллекцииМетаданных);
		
	ИначеЕсли ИмяКоллекции = "Команды" Тогда
		
		ПрошлаПроверка = ИТК_МетаданныеКлиентСерверПовтИсп.ИмеетКоманды(ИмяКоллекцииМетаданных);
		
	ИначеЕсли ИмяКоллекции = "Использование" Тогда
		
		ПрошлаПроверка = ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПараметрФункциональнойОпции(ИмяКоллекцииМетаданных);
		
	ИначеЕсли ИмяКоллекции = "ВводитсяНаОсновании" Тогда
		
		ПрошлаПроверка = ИТК_МетаданныеКлиентСерверПовтИсп.ВозможенВводНаОсновании(ИмяКоллекцииМетаданных);
			
	ИначеЕсли ИмяКоллекции = "ПризнакиУчета"
				ИЛИ ИмяКоллекции = "ПризнакиУчетаСубконто" Тогда
		
		ПрошлаПроверка = ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПланСчетов(ИмяКоллекцииМетаданных);
		
	ИначеЕсли ИмяКоллекции = "Состав" Тогда
		
		ПрошлаПроверка = ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоКритерийОтбора(ИмяКоллекцииМетаданных)
							ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПланОбмена(ИмяКоллекцииМетаданных)
							ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПодсистема(ИмяКоллекцииМетаданных)
							ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоОбщийРеквизит(ИмяКоллекцииМетаданных)
							ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоФункциональнаяОпция(ИмяКоллекцииМетаданных);
		
	КонецЕсли;
	
	Если НЕ ПрошлаПроверка Тогда
		Возврат;
	КонецЕсли;
	
	ОбъектКоллекция = КонтекстОбъекта.ОбъектМетаданных[ИмяКоллекции];
	Если ИмяКоллекции = "Состав"
			И ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоОбщийРеквизит(ИмяКоллекцииМетаданных) Тогда
		
		ОбъектКоллекцияСостав = Новый Массив;
		Для Каждого ЭлементКоллекции Из ОбъектКоллекция Цикл 
			
			Если ЭлементКоллекции.Использование <> Метаданные.СвойстваОбъектов.ИспользованиеОбщегоРеквизита.Использовать Тогда
				Продолжить;
			КонецЕсли;
				
			ОбъектКоллекцияСостав.Добавить(ЭлементКоллекции.Метаданные)
			
		КонецЦикла;
		
		ОбъектКоллекция = ОбъектКоллекцияСостав;
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ОбъектКоллекция) Тогда
		Возврат;
	КонецЕсли;
	
	// Картинки
	Если ИмяКоллекции = "Измерения" Тогда
		
		КартинкаГруппы = БиблиотекаКартинок.ИТК_МетаданныеИзмерения;
		КартинкаЭлементов = БиблиотекаКартинок.ИТК_МетаданныеИзмерения;
								
	ИначеЕсли ИмяКоллекции = "Ресурсы" Тогда
		
		КартинкаГруппы = БиблиотекаКартинок.ИТК_МетаданныеРесурсы;
		КартинкаЭлементов = БиблиотекаКартинок.ИТК_МетаданныеРесурсы;
								
	ИначеЕсли ИмяКоллекции = "Графы" Тогда
		
		КартинкаГруппы = БиблиотекаКартинок.ИТК_МетаданныеГрафы;
		КартинкаЭлементов = БиблиотекаКартинок.ИТК_МетаданныеГрафы;
								
	ИначеЕсли ИмяКоллекции = "ЗначенияПеречисления" Тогда
		
		КартинкаГруппы = БиблиотекаКартинок.ИТК_МетаданныеЗначениеПеречисления;
		КартинкаЭлементов = БиблиотекаКартинок.ИТК_МетаданныеЗначениеПеречисления;
								
	ИначеЕсли ИмяКоллекции = "Команды" Тогда
		
		КартинкаГруппы = БиблиотекаКартинок.ИТК_МетаданныеКоманды;
		КартинкаЭлементов = БиблиотекаКартинок.ИТК_МетаданныеКоманды;
	
	ИначеЕсли ИмяКоллекции = "ВводитсяНаОсновании" Тогда
		
		КартинкаГруппы = БиблиотекаКартинок.ВводНаОсновании;
		КартинкаЭлементов = Новый Картинка;
	
	Иначе
		
		КартинкаГруппы = Новый Картинка;
		КартинкаЭлементов = Новый Картинка;
		
	КонецЕсли;
	
	// Добавление группы
	Если ЗначениеЗаполнено(Представление) Тогда
		
		Количество = ОбъектКоллекция.Количество();
		СтрокаПриемник = ДобавитьГруппуСвойств(Родитель, Представление, КартинкаГруппы, Количество);
		
	Иначе
		СтрокаПриемник = Родитель;
	КонецЕсли;
	
	// Добавление элементов
	Если ИмяКоллекции = "ЗначенияПеречисления" Тогда
		ЦиклОбработки = "Базовый";
	ИначеЕсли ИмяКоллекции = "Движения"
				ИЛИ ИмяКоллекции = "Состав"
				ИЛИ ИмяКоллекции = "Владельцы"
				ИЛИ ИмяКоллекции = "Использование"
				ИЛИ ИмяКоллекции = "ВводитсяНаОсновании"
				ИЛИ ИмяКоллекции = "РегистрируемыеДокументы"
				Тогда
		ЦиклОбработки = "ТипПоОбъектуМетаданных";
	ИначеЕсли ИмяКоллекции = "Команды" Тогда
		ЦиклОбработки = "Команды";
	Иначе
		ЦиклОбработки = "Реквизиты";
	КонецЕсли;

	Если ЦиклОбработки = "Базовый" Тогда
		
		Для Каждого ОбъектКоллекции Из ОбъектКоллекция Цикл 
			
			НоваяСтрока = СтрокаПриемник.Строки.Добавить();
			НоваяСтрока.Имя = ОбъектКоллекции.Имя;
			НоваяСтрока.Представление = ОбъектКоллекции.Представление();
			НоваяСтрока.Комментарий = ОбъектКоллекции.Комментарий;
			НоваяСтрока.Картинка = КартинкаЭлементов;
			НоваяСтрока.Расширение = ИТК_Метаданные.ИмяРасширения(ОбъектКоллекции);
			
		КонецЦикла;
		
	ИначеЕсли ЦиклОбработки = "Команды" Тогда
		
		ВыгруженныеФайлыКонфигурации = ИТК_ФайлыКонфигурации.ПутьКФайлам();

		Для Каждого ОбъектКоллекции Из ОбъектКоллекция Цикл 
			
			НоваяСтрока = СтрокаПриемник.Строки.Добавить();
			НоваяСтрока.Имя = ОбъектКоллекции.Имя;
			НоваяСтрока.Представление = ОбъектКоллекции.Представление();
			НоваяСтрока.Комментарий = ОбъектКоллекции.Комментарий;
			НоваяСтрока.Картинка = КартинкаЭлементов;
			НоваяСтрока.Расширение = ИТК_Метаданные.ИмяРасширения(ОбъектКоллекции);
			
			// Модуль команды
			ПолноеИмяМодуля = СтрШаблон("%1.МодульКоманды", ОбъектКоллекции.ПолноеИмя());
			ОписаниеМодуля = ИТК_ФайлыКонфигурацииКлиентСервер.ОписаниеМодуляПерейтиКОпределению(ПолноеИмяМодуля);
				
			Если ИТК_ФайлыКонфигурации.ИспользуетсяМодуль(ВыгруженныеФайлыКонфигурации, ОписаниеМодуля) Тогда
				
				НоваяСтрока.ДанныеГиперссылки = Новый Структура("Модуль", ПолноеИмяМодуля);
				НоваяСтрока.ПредставлениеГиперссылки = НСтр("ru = 'Перейти к модулю'; en = 'Go to module'");
				
			КонецЕсли;
			
		КонецЦикла;
		
	ИначеЕсли ЦиклОбработки = "ТипПоОбъектуМетаданных" Тогда
		
		Для Каждого ЭлементКоллекции Из ОбъектКоллекция Цикл 
			
			Если ТипЗнч(ЭлементКоллекции) = Тип("ЭлементСоставаПланаОбмена") Тогда
				ОбъектКоллекции = ЭлементКоллекции.Метаданные;
			ИначеЕсли ТипЗнч(ЭлементКоллекции) = Тип("ЭлементСоставаФункциональнойОпции") Тогда
				ОбъектКоллекции = ЭлементКоллекции.Объект;
			Иначе
				ОбъектКоллекции = ЭлементКоллекции;
			КонецЕсли;
			
			Если ОбъектКоллекции = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ПолноеИмяОбъекта = ОбъектКоллекции.ПолноеИмя();
			
			НоваяСтрока = СтрокаПриемник.Строки.Добавить();
			НоваяСтрока.Имя = ПолноеИмяОбъекта;
			НоваяСтрока.Представление = ОбъектКоллекции.Представление();
			НоваяСтрока.Комментарий = ОбъектКоллекции.Комментарий;
			НоваяСтрока.Тип = НоваяСтрока.Имя;
			НоваяСтрока.Расширение = ИТК_Метаданные.ИмяРасширения(ОбъектКоллекции);
			
			НоваяСтрока.ДанныеГиперссылки = Новый Структура("ОбъектМетаданных");
			НоваяСтрока.Значение = ПолноеИмяОбъекта;
			НоваяСтрока.ПредставлениеГиперссылки = ПолноеИмяОбъекта;
			
			ИмяОбъектаКоллекции = ИТК_Метаданные.ИмяОбъектаКоллекции(ОбъектКоллекции);
			НоваяСтрока.КартинкаТипа = ИТК_МетаданныеКлиентСерверПовтИсп.КартинкаОбъектаКоллекции(ИмяОбъектаКоллекции);
			
		КонецЦикла;
		
	Иначе
		
		СписокЭлементов = Новый СписокЗначений;
		Для Каждого ОписаниеПоля Из ОбъектКоллекция Цикл 
			СписокЭлементов.Добавить(ОписаниеПоля, , , КартинкаЭлементов);
		КонецЦикла;
		
		ДобавитьЭлементыКоллекцииСвойств(СтрокаПриемник, СписокЭлементов, ИмяКоллекции, ИмяКоллекцииМетаданных)
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьКоллекциюОписанияТипов(Родитель, ОписаниеТипов, Представление, Картинка = Неопределено)

	КоличествоТипов = ИТК_ТипыКлиентСервер.Количество(ОписаниеТипов);
	СтрокаГруппа = ДобавитьГруппуСвойств(Родитель, Представление, Картинка, КоличествоТипов);
	
	Для Каждого Тип Из ОписаниеТипов.Типы() Цикл 
		
		НоваяСтрока = СтрокаГруппа.Строки.Добавить();
		НоваяСтрока.Имя = ИТК_Типы.ПредставлениеТипа(Тип, ОписаниеТипов);
		НоваяСтрока.Представление = ИТК_Типы.ПользовательскоеПредставлениеТипа(Тип, ОписаниеТипов);
		НоваяСтрока.Тип = НоваяСтрока.Имя;
		НоваяСтрока.КартинкаТипа = ИТК_Типы.Картинка(Тип, ОписаниеТипов);
		НоваяСтрока.Расширение = ИТК_Метаданные.ИмяРасширения(Тип);
		
		Если ИТК_ТипыКлиентСервер.ЭтоСсылочный(Тип) Тогда
			
			Значение = Новый СписокЗначений;
			
			XMLИмяТипа = ИТК_XML.ИмяТипа(Тип);
			Значение.Добавить(XMLИмяТипа);
			
			НоваяСтрока.Значение = Значение;
			НоваяСтрока.ДанныеГиперссылки = Новый Структура("ОписаниеТипов");
			НоваяСтрока.ПредставлениеГиперссылки = ИТК_Типы.ПредставлениеТипа(Тип, ОписаниеТипов);
			
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

Процедура ДобавитьКоллекциюТЧСвойств(КонтекстОбъекта, Родитель, ИмяКоллекции, Представление)

	// Проверка вывода
	ИмяКоллекцииОбъекта = КонтекстОбъекта.ИмяКоллекцииОбъекта;
	Если ИмяКоллекции = "СтандартныеТабличныеЧасти" Тогда
		
		ПрошлаПроверка = ИТК_МетаданныеКлиентСерверПовтИсп.ИмеетСтандартныеТабличныеЧасти(ИмяКоллекцииОбъекта);
		
	ИначеЕсли ИмяКоллекции = "ТабличныеЧасти" Тогда
		
		ПрошлаПроверка = ИТК_МетаданныеКлиентСерверПовтИсп.ИмеетТабличныеЧасти(ИмяКоллекцииОбъекта);
								
	КонецЕсли;
	
	Если НЕ ПрошлаПроверка Тогда
		Возврат;
	КонецЕсли;
	
	ОбъектКоллекция = КонтекстОбъекта.ОбъектМетаданных[ИмяКоллекции];
	Если НЕ ЗначениеЗаполнено(ОбъектКоллекция) Тогда
		Возврат;
	КонецЕсли;
	
	КартинкаТЧ = БиблиотекаКартинок.ВнешнийИсточникДанныхТаблица;
	КартинкаРеквизит = БиблиотекаКартинок.Реквизит;
	КартинкаСтандартныйРеквизит = БиблиотекаКартинок.ИТК_МетаданныеСтандартныйРеквизит;
	
	// Добавление группы
	КоличествоТЧ = Неопределено;
	Если ИмяКоллекции = "ТабличныеЧасти" Тогда
		КоличествоТЧ = ОбъектКоллекция.Количество();
	КонецЕсли;
	СтрокаГруппаТЧ = ДобавитьГруппуСвойств(Родитель, Представление, КартинкаТЧ, КоличествоТЧ, "ТабличныеЧасти");
	
	// Добавление элементов
	Для Каждого ОписаниеТЧ Из ОбъектКоллекция Цикл 
		
		КоллекцияТЧ = ОбъектКоллекция[ОписаниеТЧ.Имя];
		
		РеквизитыТЧ = Новый СписокЗначений;
		Для Каждого Реквизит Из КоллекцияТЧ.СтандартныеРеквизиты Цикл
			
			Если Реквизит.Имя = "НомерСтроки" Тогда
				Продолжить;
			КонецЕсли;
			
			РеквизитыТЧ.Добавить(Реквизит, Реквизит.Имя, , КартинкаСтандартныйРеквизит);
			
		КонецЦикла;
		
		Если ИмяКоллекции = "ТабличныеЧасти" Тогда
			Для Каждого Реквизит Из КоллекцияТЧ.Реквизиты Цикл
				РеквизитыТЧ.Добавить(Реквизит, Реквизит.Имя, , КартинкаРеквизит);
			КонецЦикла;
		КонецЕсли;
		
		РеквизитыТЧ.СортироватьПоПредставлению();
		
		СтрокаТЧ = ДобавитьГруппуСвойств(СтрокаГруппаТЧ, ОписаниеТЧ.Представление(), КартинкаТЧ, РеквизитыТЧ.Количество(), ОписаниеТЧ.Имя);
		ДобавитьЭлементыКоллекцииСвойств(СтрокаТЧ, РеквизитыТЧ);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьГруппуСвойствВсеРеквизиты(КонтекстОбъекта, Родитель)
	
	ИмяКоллекцииОбъекта = КонтекстОбъекта.ИмяКоллекцииОбъекта;
	ОбъектМетаданных = КонтекстОбъекта.ОбъектМетаданных;
	
	ВсеРеквизиты = Новый СписокЗначений;
	
	// СтандартныеРеквизиты
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ИмеетСтандартныеРеквизиты(ИмяКоллекцииОбъекта) Тогда 
		
		КартинкаСтандартныйРеквизит = БиблиотекаКартинок.ИТК_МетаданныеСтандартныйРеквизит;
		Для Каждого Реквизит Из ОбъектМетаданных.СтандартныеРеквизиты Цикл 
			
			Если Реквизит.Имя = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Ссылка")
					ИЛИ (ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПеречисление(ИмяКоллекцииОбъекта)
							И Реквизит.Имя = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Порядок"))Тогда
				Продолжить;
			КонецЕсли;
			
			ВсеРеквизиты.Добавить(Реквизит, Реквизит.Имя, , КартинкаСтандартныйРеквизит);
			
		КонецЦикла;
		
	КонецЕсли;
	
	// РеквизитыАдресации
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоЗадача(ИмяКоллекцииОбъекта) Тогда
		
		КартинкаРеквизитАдресации = БиблиотекаКартинок.ИТК_МетаданныеРеквизитАдресации;		
		Для Каждого Реквизит Из ОбъектМетаданных.РеквизитыАдресации Цикл 
			ВсеРеквизиты.Добавить(Реквизит, Реквизит.Имя, , КартинкаРеквизитАдресации);
		КонецЦикла;
		
	КонецЕсли;	
	
	// Реквизиты, общие
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ИмеетРеквизиты(ИмяКоллекцииОбъекта) Тогда 
		
		КартинкаРеквизит = БиблиотекаКартинок.Реквизит;
		Для Каждого Реквизит Из ОбъектМетаданных.Реквизиты Цикл 
			ВсеРеквизиты.Добавить(Реквизит, Реквизит.Имя, , КартинкаРеквизит);
		КонецЦикла;
		
		КартинкаОбщийРеквизит = БиблиотекаКартинок.ИТК_МетаданныеОбщийРеквизит;	
		Для Каждого Реквизит Из Метаданные.ОбщиеРеквизиты Цикл 
			
			Если НЕ ИТК_Метаданные.ОбщийРеквизитИспользуетсяВОбъекте(Реквизит, ОбъектМетаданных) Тогда
				Продолжить;
			КонецЕсли;
			
			ВсеРеквизиты.Добавить(Реквизит, Реквизит.Имя, , КартинкаОбщийРеквизит);
			
		КонецЦикла;
		
	КонецЕсли;
	
	ВсеРеквизиты.СортироватьПоПредставлению();
	
	Если НЕ ЗначениеЗаполнено(ВсеРеквизиты) Тогда
		Возврат;
	КонецЕсли;
	
	НоваяСтрокаГруппа = ДобавитьГруппуСвойств(Родитель, НСтр("ru = 'Все реквизиты'; en = 'All details'"), БиблиотекаКартинок.ИТК_ВсеРеквизиты, ВсеРеквизиты.Количество(), "Реквизиты");
	ДобавитьЭлементыКоллекцииСвойств(НоваяСтрокаГруппа, ВсеРеквизиты, , ИмяКоллекцииОбъекта);
	
КонецПроцедуры

Процедура ДобавитьЭлементыКоллекцииСвойств(Родитель, СписокЭлементов, ИмяКоллекцииСвойств = Неопределено, ИмяКоллекцииМетаданных = Неопределено)
	
	Если ИмяКоллекцииСвойств = "Ресурсы" Тогда
		ЗаполнятьИндексирование = ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоРегистрСведений(ИмяКоллекцииМетаданных);
	ИначеЕсли ИмяКоллекцииСвойств = "ПризнакиУчета"
				ИЛИ ИмяКоллекцииСвойств = "ПризнакиУчетаСубконто" Тогда
		ЗаполнятьИндексирование = Ложь;
	ИначеЕсли ИмяКоллекцииСвойств = "Измерения" Тогда
		ЗаполнятьИндексирование = ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоРегистр(ИмяКоллекцииМетаданных);
	Иначе
		
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоОтчет(ИмяКоллекцииМетаданных)
				ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоОбработка(ИмяКоллекцииМетаданных) Тогда
			ЗаполнятьИндексирование = Ложь;
		Иначе
			ЗаполнятьИндексирование = Истина;
		КонецЕсли;
		
	КонецЕсли;

	Для Каждого ЭлементСписка Из СписокЭлементов Цикл 
		
		ОписаниеПоля = ЭлементСписка.Значение;
		КартинкаПоля = ЭлементСписка.Картинка;
		
		Если ИмяКоллекцииСвойств = "Графы" Тогда
			
			ОписаниеТипов = Новый ОписаниеТипов;
			Для Каждого ОбъектСсылка Из ОписаниеПоля.Ссылки Цикл 
				ОписаниеТипов = ИТК_ТипыКлиентСервер.СложитьОписания(ОписаниеТипов, ОбъектСсылка.Тип);
			КонецЦикла;
			
		Иначе
			ОписаниеТипов = ОписаниеПоля.Тип;
		КонецЕсли;
		
		НоваяСтрока = Родитель.Строки.Добавить();
		НоваяСтрока.Картинка = КартинкаПоля;
		НоваяСтрока.Имя = ОписаниеПоля.Имя;
		НоваяСтрока.Представление = ОписаниеПоля.Представление();
		НоваяСтрока.Комментарий = ОписаниеПоля.Комментарий;
		НоваяСтрока.Тип = ИТК_Типы.ПредставлениеОписания(ОписаниеТипов, , , 30);
		НоваяСтрока.КартинкаТипа = ИТК_Типы.КартинкаОписания(ОписаниеТипов);
		Если ТипЗнч(ОписаниеПоля) = Тип("ОбъектМетаданных") Тогда
			НоваяСтрока.Расширение = ИТК_Метаданные.ИмяРасширения(ОписаниеПоля);
		КонецЕсли;
		
		Если ИТК_ТипыКлиентСервер.ЕстьСсылочныеТипы(ОписаниеТипов) Тогда
			
			НоваяСтрока.ДоступнаФормаСписка = Истина;
			
			НоваяСтрока.Значение = ОписаниеТипов;
			НоваяСтрока.ДанныеГиперссылки = Новый Структура("ОписаниеТипов");
			НоваяСтрока.ПредставлениеГиперссылки = ИТК_Типы.ПредставлениеОписания(ОписаниеТипов, , , 30);
			
		КонецЕсли;
		
		ЗаполнитьИндексированиеПоля(НоваяСтрока, ОписаниеПоля, ЗаполнятьИндексирование);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьИндексированиеПоля(Строка, ОписаниеПоля, ЗаполнятьИндексирование)
	
	Если ТипЗнч(ОписаниеПоля) = Тип("ОписаниеСтандартногоРеквизита") Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗаполнятьИндексирование Тогда
		Возврат;
	КонецЕсли;
	
	Строка.Индексирование = ИТК_Общий.ПредставлениеИндексирования(ОписаниеПоля.Индексирование);
	
КонецПроцедуры

Процедура ДобавлениеПредопределенных(Родитель, НаборСтрок, ИмяКоллекции)
	
	Для Каждого Строка Из НаборСтрок.Строки Цикл 
		
		НоваяСтрока = Родитель.Строки.Добавить();
		НоваяСтрока.Имя = Строка.Имя;
		
		Если Строка.ЭтоГруппа = Истина Тогда
			НоваяСтрока.Картинка = ИТК_ОбщийКлиентСерверПовтИсп.БиблиотекаКартинок("ИТК_Папка");
		Иначе
			
			Если ЗначениеЗаполнено(Строка.ТипЗначения) Тогда
				НоваяСтрока.Тип = Строка.ТипЗначения;
				НоваяСтрока.КартинкаТипа = ИТК_Типы.КартинкаОписания(Строка.ТипЗначения);
			КонецЕсли;
			
		КонецЕсли;
		
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПланСчетов(ИмяКоллекции) Тогда
			
			Представление = Строка.Код;
			ДополнениеПредставления = Строка.Наименование;
			
		Иначе
			
			Представление = Строка.Наименование;
			ДополнениеПредставления = Строка.Код;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДополнениеПредставления) Тогда
			Представление = Представление + Символы.НПП + "(" + ДополнениеПредставления + ")";
		КонецЕсли;
		
		НоваяСтрока.Представление = Представление;
		
		НоваяСтрока.Значение = Строка.Ссылка;
		НоваяСтрока.ДанныеГиперссылки = Новый Структура("Ссылка");
		НоваяСтрока.ПредставлениеГиперссылки = Строка.Представление;
		
		ДобавлениеПредопределенных(НоваяСтрока, Строка, ИмяКоллекции);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавлениеПодсистем(Родитель, НаборСтрок)
	
	Для Каждого Строка Из НаборСтрок.Строки Цикл 
		
		ПолноеИмяМетаданных = Строка.ПолноеИмя;
		
		НоваяСтрока = Родитель.Строки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
		НоваяСтрока.Тип = ПолноеИмяМетаданных;

		НоваяСтрока.ДанныеГиперссылки = Новый Структура("ОбъектМетаданных");
		НоваяСтрока.Значение = ПолноеИмяМетаданных;
		НоваяСтрока.ПредставлениеГиперссылки = ПолноеИмяМетаданных;

		ДобавлениеПодсистем(НоваяСтрока, Строка);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьГруппуФункциональныеОпции(Родитель, ОбъектМетаданныхВладелец)
	
	ФункциональныеОпцииОбъекта = ИТК_Метаданные.ФункциональныеОпцииОбъекта(ОбъектМетаданныхВладелец);
	ФункциональныеОпцииОбъекта.Свернуть("Имя, ОбъектМетаданных");
	
	КоличествоСтрок = ФункциональныеОпцииОбъекта.Количество();
	СтрокаГруппа = ДобавитьГруппуСвойств(Родитель, НСтр("ru = 'Функциональные опции'; en = 'Functional options'"), БиблиотекаКартинок.ИТК_МетаданныеФункциональныеОпции, КоличествоСтрок);
	
	Для Каждого СтрокаФункциональнаяОпция Из ФункциональныеОпцииОбъекта Цикл 
		
		ОбъектМетаданных = СтрокаФункциональнаяОпция.ОбъектМетаданных;
		ПолноеИмя = ОбъектМетаданных.ПолноеИмя();
		
		НоваяСтрока = СтрокаГруппа.Строки.Добавить();
		НоваяСтрока.Имя = СтрокаФункциональнаяОпция.Имя;
		НоваяСтрока.Представление = ОбъектМетаданных.Представление();
		НоваяСтрока.Комментарий = ОбъектМетаданных.Комментарий;
		НоваяСтрока.Тип = ПолноеИмя;
		НоваяСтрока.Расширение = ИТК_Метаданные.ИмяРасширения(ОбъектМетаданных);
		
		НоваяСтрока.ДанныеГиперссылки = Новый Структура("ОбъектМетаданных");
		НоваяСтрока.Значение = ПолноеИмя;
		НоваяСтрока.ПредставлениеГиперссылки = ПолноеИмя;
		
		ИмяОбъектаКоллекции = ИТК_Метаданные.ИмяОбъектаКоллекции(ОбъектМетаданных);
		НоваяСтрока.КартинкаТипа = ИТК_МетаданныеКлиентСерверПовтИсп.КартинкаОбъектаКоллекции(ИмяОбъектаКоллекции);
		
	КонецЦикла;

КонецПроцедуры

Процедура ДобавитьГруппуРоли(Родитель, Знач ОбъектМетаданных)
	
	ИмяКоллекции = ИТК_Метаданные.ИмяКоллекции(ОбъектМетаданных);
	ПраваДоступа = ИТК_АнализПравДоступаПовтИсп.МинимальныеПраваДоступа(ИмяКоллекции);
	
	Если НЕ ЗначениеЗаполнено(ПраваДоступа) Тогда
		Возврат;
	КонецЕсли;
	
	ИспользуемыеРоли = Новый СписокЗначений;
	Для Каждого Роль Из Метаданные.Роли Цикл 
		
		ДобавитьРоль = Ложь;
		Для Каждого ПравоДоступа Из ПраваДоступа Цикл 
			
			Если ПравоДоступа(ПравоДоступа, ОбъектМетаданных, Роль) Тогда
				
				ДобавитьРоль = Истина;
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если ДобавитьРоль Тогда
			
			ИспользуемыеРоли.Добавить(Роль, Роль.Имя);
			
		КонецЕсли;
		
	КонецЦикла;
	
	КоличествоСтрок = ИспользуемыеРоли.Количество();
	СтрокаГруппа = ДобавитьГруппуСвойств(Родитель, НСтр("ru = 'Роли'; en = 'Roles'"), БиблиотекаКартинок.ИТК_МетаданныеРоль, КоличествоСтрок);
	
	Для Каждого ЭлементСпискаРоль Из ИспользуемыеРоли Цикл 
		
		ОбъектМетаданных = ЭлементСпискаРоль.Значение;
		ПолноеИмя = ОбъектМетаданных.ПолноеИмя();
		
		НоваяСтрока = СтрокаГруппа.Строки.Добавить();
		НоваяСтрока.Имя = ОбъектМетаданных.Имя;
		НоваяСтрока.Представление = ОбъектМетаданных.Представление();
		НоваяСтрока.Комментарий = ОбъектМетаданных.Комментарий;
		НоваяСтрока.Тип = ПолноеИмя;
		НоваяСтрока.Расширение = ИТК_Метаданные.ИмяРасширения(ОбъектМетаданных);
		
		НоваяСтрока.ДанныеГиперссылки = Новый Структура("ОбъектМетаданных");
		НоваяСтрока.Значение = ПолноеИмя;
		НоваяСтрока.ПредставлениеГиперссылки = ПолноеИмя;
		
		ИмяОбъектаКоллекции = ИТК_Метаданные.ИмяОбъектаКоллекции(ОбъектМетаданных);
		НоваяСтрока.КартинкаТипа = ИТК_МетаданныеКлиентСерверПовтИсп.КартинкаОбъектаКоллекции(ИмяОбъектаКоллекции);
		
	КонецЦикла;

КонецПроцедуры

Функция ДобавитьГруппуСтруктурыХранения(Родитель, Поле, Картинка = Неопределено, ПолеХранения = Неопределено, Метаданные = Неопределено)
	
	Возврат ДобавитьСтрокуСтруктурыХранения(Родитель, Поле, ПолеХранения, Метаданные, Картинка, Истина);
	
КонецФункции

Функция ДобавитьПолеСтруктурыХранения(Родитель, Поле, ПолеХранения, Метаданные, Картинка = Неопределено)
	
	Возврат ДобавитьСтрокуСтруктурыХранения(Родитель, Поле, ПолеХранения, Метаданные, Картинка);
	
КонецФункции

Функция ДобавитьСтрокуСтруктурыХранения(Родитель, Поле, ПолеХранения, Метаданные, Картинка, ЭтоГруппа = Ложь)
	
	НоваяСтрока = Родитель.Строки.Добавить();
	НоваяСтрока.ЭтоГруппа = ЭтоГруппа;
	НоваяСтрока.Поле = Поле;
	НоваяСтрока.ПолеХранения = ПолеХранения;
	НоваяСтрока.Метаданные = Метаданные;
	
	Если Картинка = Неопределено Тогда
		Картинка = Новый Картинка;
	КонецЕсли;
	НоваяСтрока.Картинка = Картинка;
	
	Возврат НоваяСтрока;
	
КонецФункции

Процедура ДобавитьПоляИндексыСтруктурыХранения(Родитель, Строка, ОписанияХранения)
	
	ПоляТаблицыХранения = ОписанияХранения.ПоляТаблицы;
	ПоляПоля = ОписанияХранения.ПоляПоля;
	ПоляИндекса = ОписанияХранения.ПоляИндекса;
	
	ПоляИндексы = Строка[ПоляТаблицыХранения.Индексы];
	
	// Поля
	Если ЗначениеЗаполнено(ПоляИндексы) Тогда
		ГруппаПоля = ДобавитьГруппуСтруктурыХранения(Родитель, НСтр("ru = 'Поля'; en = 'Filds'"), БиблиотекаКартинок.ИТК_ВсеРеквизиты);
	Иначе 
		ГруппаПоля = Родитель;
	КонецЕсли;
	
	Для Каждого СтрокаПоле Из Строка[ПоляТаблицыХранения.Поля] Цикл 
		ДобавитьПолеСтруктурыХранения(ГруппаПоля, СтрокаПоле[ПоляПоля.ИмяПоля], СтрокаПоле[ПоляПоля.ИмяПоляХранения], СтрокаПоле[ПоляПоля.Метаданные]);
	КонецЦикла;

	// Индексы
	Если ЗначениеЗаполнено(ПоляИндексы) Тогда
		ГруппаИндексы = ДобавитьГруппуСтруктурыХранения(Родитель, НСтр("ru = 'Индексы'; en = 'Indexes'"), БиблиотекаКартинок.ИТК_Индексы);
	КонецЕсли;
	
	Для Каждого СтрокаИндекс Из ПоляИндексы Цикл 
		
		ГруппаИндекса = ДобавитьГруппуСтруктурыХранения(ГруппаИндексы, СтрокаИндекс[ПоляИндекса.ИмяИндексаХранения], БиблиотекаКартинок.ИТК_Индексы);
		
		Для Каждого СтрокаПолеИндекса Из СтрокаИндекс[ПоляИндекса.Поля] Цикл 
			ДобавитьПолеСтруктурыХранения(ГруппаИндекса, СтрокаПолеИндекса[ПоляПоля.ИмяПоля], СтрокаПолеИндекса[ПоляПоля.ИмяПоляХранения], СтрокаПолеИндекса[ПоляПоля.Метаданные]);
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ИмяОбъектаСтруктурыХранения(ПолноеИмяТаблицы)
	
	ЧастиПолногоИмени = СтрРазделить(ПолноеИмяТаблицы, ".");
	Возврат ЧастиПолногоИмени[ЧастиПолногоИмени.ВГраница()];
	
КонецФункции

Функция МестаПоискаСсылкиНаОбъект()
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("ОбъектыПоля", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	Результат.Колонки.Добавить("Поиск", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	
	// Описание полей
	ПолеТип = "Тип";
	ПолеКоллекцииСостав = "Состав";
	ПолеКоллекцииИзмерения = "Измерения";
	ПолеКоллекцииРесурсы = "Ресурсы";
	ПолеКоллекцииРеквизиты = "Реквизиты";
	ПолеКоллекцииТабличныеЧасти = "ТабличныеЧасти";
	
	Если ИТК_ОбщийПовтИсп.ВариантВстроенногоЯзыкаАнглийский() Тогда
		
		ПолеТип = "Type";
		ПолеКоллекцииСостав = "Content";
		ПолеКоллекцииИзмерения = "Dimensions";
		ПолеКоллекцииРесурсы = "Resources";
		ПолеКоллекцииРеквизиты = "Attributes";
		ПолеКоллекцииТабличныеЧасти = "TabularSections";
		
	КонецЕсли;
	
	Для Каждого ИмяКоллекции Из ИТК_МетаданныеКлиентСерверПовтИсп.КоллекцииСПолемСостав() Цикл 
		ДобавитьМестоПоискаСсылкиНаОбъект(Результат, ИмяКоллекции + "." + ПолеКоллекцииСостав, "Метаданные");
	КонецЦикла;
	
	Для Каждого ИмяКоллекции Из ИТК_МетаданныеКлиентСерверПовтИсп.КоллекцииСПолемТип() Цикл 
		ДобавитьМестоПоискаСсылкиНаОбъект(Результат, ИмяКоллекции + "." + ПолеТип);
	КонецЦикла;

	Для Каждого ИмяКоллекции Из ИТК_МетаданныеКлиентСерверПовтИсп.КоллекцииСИзмерениями() Цикл 
		ДобавитьМестоПоискаСсылкиНаОбъект(Результат, ИмяКоллекции + "." + ПолеКоллекцииИзмерения + "." + ПолеТип);
	КонецЦикла;
	
	Для Каждого ИмяКоллекции Из ИТК_МетаданныеКлиентСерверПовтИсп.КоллекцииСРесурсами() Цикл 
		ДобавитьМестоПоискаСсылкиНаОбъект(Результат, ИмяКоллекции + "." + ПолеКоллекцииРесурсы + "." + ПолеТип);
	КонецЦикла;
	
	Для Каждого ИмяКоллекции Из ИТК_МетаданныеКлиентСерверПовтИсп.КоллекцииСРеквизитами() Цикл 
		ДобавитьМестоПоискаСсылкиНаОбъект(Результат, ИмяКоллекции + "." + ПолеКоллекцииРеквизиты + "." + ПолеТип);
	КонецЦикла;

	Для Каждого ИмяКоллекции Из ИТК_МетаданныеКлиентСерверПовтИсп.КоллекцииСТабличнымиЧастями() Цикл 
		ДобавитьМестоПоискаСсылкиНаОбъект(Результат, ИмяКоллекции + "." + ПолеКоллекцииТабличныеЧасти + "." + ПолеКоллекцииРеквизиты + "." + ПолеТип);
	КонецЦикла;

	Возврат Результат;
	
КонецФункции

Процедура ДобавитьМестоПоискаСсылкиНаОбъект(МестаПоиска, ОбъектыПоля, Поиск = "Тип")
	
	НоваяСтрока = МестаПоиска.Добавить();
	НоваяСтрока.ОбъектыПоля = ОбъектыПоля;
	НоваяСтрока.Поиск = Поиск;
	
КонецПроцедуры

Функция ДобавитьСтрокуГруппуСсылкиНаОбъект(Родитель, Имя, Картинка, Количество)
	
	НоваяСтрока = Родитель.Строки.Добавить();
	НоваяСтрока.Имя = ИТК_ФормаКлиентСервер.ЗаголовокСКоличеством(Имя, Количество);
	НоваяСтрока.Картинка = Картинка;
	НоваяСтрока.ЭтоГруппа = Истина;
	
	Возврат НоваяСтрока;
	
КонецФункции

Функция ДобавитьСтрокуСсылкиНаОбъект(Родитель, Имя, Представление, Метаданные, Картинка, Расширение)
	
	НоваяСтрока = Родитель.Строки.Добавить();
	НоваяСтрока.Имя = Имя;
	НоваяСтрока.Представление = Представление;
	НоваяСтрока.Метаданные = Метаданные;
	НоваяСтрока.Расширение = Расширение;
	НоваяСтрока.Картинка = Картинка;
	
	Возврат НоваяСтрока;
	
КонецФункции

Функция СсылкиНаОбъектНайтиИспользование(ПроверяемоеЗначение, ИскомыйОбъектМетаданных, ИскомыйТипСсылка)
	
	Если ТипЗнч(ПроверяемоеЗначение) = Тип("ОписаниеТипов") Тогда
		
		Результат = ПроверяемоеЗначение.СодержитТип(ИскомыйТипСсылка);
		
	Иначе
		
		Результат = ПроверяемоеЗначение.Содержит(ИскомыйОбъектМетаданных);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СсылкиНаОбъектДобавитьОбъект(КоллекцииСсылок, ИмяКоллекции, ОбъектМетаданных)

	ОбъектыКоллекции = КоллекцииСсылок.Получить(ИмяКоллекции);
	Если ОбъектыКоллекции = Неопределено Тогда
		
		ОбъектыКоллекции = Новый Соответствие;
		КоллекцииСсылок.Вставить(ИмяКоллекции, ОбъектыКоллекции);
		
	КонецЕсли;
						
	Результат = ОбъектыКоллекции.Получить(ОбъектМетаданных.Имя);
	Если Результат = Неопределено Тогда
		
		Результат = Новый Структура;
		Результат.Вставить("Представление", ОбъектМетаданных.Представление());
		Результат.Вставить("Расширение", ИТК_Метаданные.ИмяРасширения(ОбъектМетаданных));
		Результат.Вставить("Метаданные", ОбъектМетаданных.ПолноеИмя());
		
		Результат.Вставить("Поля", Новый СписокЗначений);
		Результат.Вставить("ТабличныеЧасти", Новый СписокЗначений);
		Результат.Вставить("ЭлементыКоллекций", Новый СписокЗначений);
		
		ОбъектыКоллекции.Вставить(ОбъектМетаданных.Имя, Результат);
		
	КонецЕсли;

	Возврат Результат;

КонецФункции

Процедура СсылкиНаОбъектДобавитьПоле(ОписаниеОбъекта, ИмяКоллекцииПолей, ИмяПоля, ОбъектМетаданных, Картинка = Неопределено, ПолеМетаданных = Неопределено)
	
	ОписаниеПоля = Новый Структура;
	ОписаниеПоля.Вставить("Представление", ОбъектМетаданных.Представление());
	ОписаниеПоля.Вставить("Расширение", ИТК_Метаданные.ИмяРасширения(ОбъектМетаданных));
	
	МетаданныеПолноеИмя = ОбъектМетаданных.ПолноеИмя();
	Если ЗначениеЗаполнено(ПолеМетаданных) Тогда
		МетаданныеПолноеИмя = МетаданныеПолноеИмя + "." + ПолеМетаданных;
	КонецЕсли;
	ОписаниеПоля.Вставить("Метаданные", МетаданныеПолноеИмя);
	
	ОписаниеОбъекта[ИмяКоллекцииПолей].Добавить(ОписаниеПоля, ИмяПоля, , Картинка);
	
КонецПроцедуры

Функция СсылкиНаОбъектДобавитьТабличнуюЧасть(ОписаниеОбъекта, ОбъектМетаданных)

	ЭлементОписаниеТабличнойЧасти = ИТК_ОбщийКлиентСервер.СписокЗначенийНайтиПоПредставлению(ОписаниеОбъекта.ТабличныеЧасти, ОбъектМетаданных.Имя); 
	Если ЭлементОписаниеТабличнойЧасти = Неопределено Тогда
		
		Результат = Новый Структура;
		Результат.Вставить("Представление", ОбъектМетаданных.Представление());
		Результат.Вставить("Расширение", ИТК_Метаданные.ИмяРасширения(ОбъектМетаданных));
		Результат.Вставить("Метаданные", ОбъектМетаданных.ПолноеИмя());
		Результат.Вставить("Реквизиты", Новый СписокЗначений);
		
		ОписаниеОбъекта.ТабличныеЧасти.Добавить(Результат, ОбъектМетаданных.Имя);
		
	Иначе
		
		Результат = ЭлементОписаниеТабличнойЧасти.Значение;
		
	КонецЕсли;

	Возврат Результат;

КонецФункции

Процедура ДобавитьГруппуПодпискиНаСобытия(Родитель, ОбъектМетаданныхВладелец)
	
	ПодпискиНаСобытияОбъекта = ИТК_Метаданные.ПодпискиНаСобытияОбъекта(ОбъектМетаданныхВладелец);
	
	СтрокаГруппа = ДобавитьГруппуСвойств(Родитель, НСтр("ru = 'Подписки на события'; en = 'Event subscriptions'"),
						БиблиотекаКартинок.ИТК_МетаданныеПодпискаНаСобытие, ПодпискиНаСобытияОбъекта.Количество());
	
	Для Каждого ОбъектМетаданных Из ПодпискиНаСобытияОбъекта Цикл 
		
		ПолноеИмя = ОбъектМетаданных.ПолноеИмя();
		
		НоваяСтрока = СтрокаГруппа.Строки.Добавить();
		НоваяСтрока.Имя = ОбъектМетаданных.Имя;
		НоваяСтрока.Представление = ОбъектМетаданных.Представление();
		НоваяСтрока.Комментарий = ОбъектМетаданных.Комментарий;
		НоваяСтрока.Тип = ПолноеИмя;
		НоваяСтрока.Расширение = ИТК_Метаданные.ИмяРасширения(ОбъектМетаданных);
		
		НоваяСтрока.ДанныеГиперссылки = Новый Структура("ОбъектМетаданных");
		НоваяСтрока.Значение = ПолноеИмя;
		НоваяСтрока.ПредставлениеГиперссылки = ПолноеИмя;
		
		ИмяОбъектаКоллекции = ИТК_Метаданные.ИмяОбъектаКоллекции(ОбъектМетаданных);
		НоваяСтрока.КартинкаТипа = ИТК_МетаданныеКлиентСерверПовтИсп.КартинкаОбъектаКоллекции(ИмяОбъектаКоллекции);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьГруппуЯвляетсяОснованиемДля(Родитель, ОбъектМетаданныхВладелец)
	
	ЯвляетсяОснованиемДля = ИТК_Метаданные.ЯвляетсяОснованиемДля(ОбъектМетаданныхВладелец);
	
	Если НЕ ЗначениеЗаполнено(ЯвляетсяОснованиемДля) Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаГруппа = ДобавитьГруппуСвойств(Родитель, НСтр("ru = 'Является основанием для'; en = 'Is the basis for'"),
											БиблиотекаКартинок.ВводНаОсновании,	ЯвляетсяОснованиемДля.Количество());
	
	Для Каждого ОбъектМетаданных Из ЯвляетсяОснованиемДля Цикл 
		
		ПолноеИмя = ОбъектМетаданных.ПолноеИмя();
		
		НоваяСтрока = СтрокаГруппа.Строки.Добавить();
		НоваяСтрока.Имя = ОбъектМетаданных.Имя;
		НоваяСтрока.Представление = ОбъектМетаданных.Представление();
		НоваяСтрока.Комментарий = ОбъектМетаданных.Комментарий;
		НоваяСтрока.Тип = ПолноеИмя;
		НоваяСтрока.Расширение = ИТК_Метаданные.ИмяРасширения(ОбъектМетаданных);
		
		НоваяСтрока.ДанныеГиперссылки = Новый Структура("ОбъектМетаданных");
		НоваяСтрока.Значение = ПолноеИмя;
		НоваяСтрока.ПредставлениеГиперссылки = ПолноеИмя;
		
		ИмяОбъектаКоллекции = ИТК_Метаданные.ИмяОбъектаКоллекции(ОбъектМетаданных);
		НоваяСтрока.КартинкаТипа = ИТК_МетаданныеКлиентСерверПовтИсп.КартинкаОбъектаКоллекции(ИмяОбъектаКоллекции);
		
	КонецЦикла;
	
КонецПроцедуры

