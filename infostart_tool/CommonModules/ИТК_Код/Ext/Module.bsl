	Соответствие.Вставить(ТипКонтрольнойТочкиСхемыЗапроса.Иерархия, ВидЭлемента);
	
	ВидЭлемента = НСтр("ru = 'ТолькоИерархия';
						|en = 'HierarchyOnly'", Язык);
	Соответствие.Вставить(ТипКонтрольнойТочкиСхемыЗапроса.ТолькоИерархия, ВидЭлемента);
	
	Вид = Соответствие.Получить(Значение);
	Возврат СтрШаблон("%1.%2", ИТК_КодКлиентСервер.ИмяОбъектаТипКонтрольнойТочкиСхемыЗапроса(Язык), Вид);
	
