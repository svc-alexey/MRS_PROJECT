Функция ЗначениеСписокЗначений(Значение, ДополнительныеПараметры)
	
	Результат = Новый Массив;
	Результат.Добавить(НСтр("ru = '%1 = Новый СписокЗначений;';
							|en = '%1 = New ValueList;'", ДополнительныеПараметры.Язык));
	
	Для Каждого ЭлементСписка Из Значение Цикл
		
		ДополнениеРезультата = Неопределено;
		КодЗначенияЭлемента = Значение(ЭлементСписка.Значение, ДополнительныеПараметры, ДополнениеРезультата);
		
		Если ДополнительныеПараметры.ДобавлятьКомментарии И ЗначениеЗаполнено(ДополнениеРезультата.Комментарий) Тогда
			
			Комментарий = СтрШаблон("// %1", ДополнениеРезультата.Комментарий);
			
		Иначе
			
			Комментарий = "";
			
		КонецЕсли;
		
		Шаблон = НСтр("ru = 'Добавить(%1);%2';
						|en = 'Add(%1);%2'", ДополнительныеПараметры.Язык);
		Результат.Добавить("%1." + СтрШаблон(Шаблон, КодЗначенияЭлемента, Комментарий)); 
		
	КонецЦикла;
	
	Возврат СтрСоединить(Результат, Символы.ПС);
	
КонецФункции

Функция ЗначениеОписаниеТипов(Значение, ДополнительныеПараметры)
	
	Язык = ДополнительныеПараметры.Язык;
	
	КвалификаторыЧисла = "";
	Если Значение.СодержитТип(Тип("Число")) Тогда
		КвалификаторыЧисла = Значение(Значение.КвалификаторыЧисла, ДополнительныеПараметры);
	КонецЕсли;
	
	КвалификаторыСтроки = "";
	Если Значение.СодержитТип(Тип("Строка")) Тогда
		КвалификаторыСтроки = Значение(Значение.КвалификаторыСтроки, ДополнительныеПараметры);
	КонецЕсли;
	
	КвалификаторыДаты = "";
	Если Значение.СодержитТип(Тип("Дата")) Тогда
		КвалификаторыДаты = Значение(Значение.КвалификаторыДаты, ДополнительныеПараметры);
	КонецЕсли;
	
	СписокТипов = СтрСоединить(СписокИменТипов(Значение.Типы(), ДополнительныеПараметры), ",");
	
	Шаблон = НСтр("ru = 'Новый ОписаниеТипов(""%1"", %2, %3, %4)';
					|en = 'New TypeDescription(""%1"", %2, %3, %4)'", Язык);
	Возврат СтрШаблон(Шаблон, СписокТипов, КвалификаторыЧисла, КвалификаторыСтроки, КвалификаторыДаты);
	
КонецФункции

Функция ЗначениеТаблицаЗначений(Значение, ДополнительныеПараметры)
	
	Язык = ДополнительныеПараметры.Язык;
	ДобавлятьКомментарии = ДополнительныеПараметры.ДобавлятьКомментарии;
	
	Результат = Новый Массив;
	Результат.Добавить(НСтр("ru = '%1 = Новый ТаблицаЗначений;';
							|en = '%1 = New ValueTable;'", Язык));
	
	// Добавляем код колонок
	Колонки = Значение.Колонки;
	Если ЗначениеЗаполнено(Колонки) Тогда
		
		Результат.Добавить("");
		
		Если ДобавлятьКомментарии Тогда
			
			Результат.Добавить(НСтр("ru = '// Добавляем колонки';
									|en = '// Add columns'", Язык));
			
		КонецЕсли;
		
		Для Каждого Колонка Из Колонки Цикл 
			
			Шаблон = НСтр("ru = 'Колонки.Добавить(%1, %2);';
							|en = 'Columns.Add(%1, %2);'", Язык);
			КодДобавлениеКолонки = СтрШаблон(Шаблон, Значение(Колонка.Имя), Значение(Колонка.ТипЗначения, ДополнительныеПараметры));
			Результат.Добавить("%1." + КодДобавлениеКолонки);
			
		КонецЦикла;
		
	КонецЕсли;
	
	// Индексы колонок
	Индексы = Значение.Индексы;
	Если ЗначениеЗаполнено(Индексы) Тогда
		
		Если ДобавлятьКомментарии Тогда
			
			Результат.Добавить(НСтр("ru = '// Добавляем индексы';
									|en = '// Add indexes'", Язык));
			
		КонецЕсли;
		
		Для Каждого Индекс Из Индексы Цикл 
			
			Шаблон = НСтр("ru = 'Индексы.Добавить(%1);';
							|en = 'Indexes.Add(%1);'", Язык);
			КодДобавленияИндекса = СтрШаблон(Шаблон, Значение(Строка(Индекс)));
			Результат.Добавить("%1." + КодДобавленияИндекса);
			
		КонецЦикла;
		
	КонецЕсли;
	
	// Добавляем код строк
	Если ЗначениеЗаполнено(Значение) Тогда

		Результат.Добавить("");
		
		Если ДобавлятьКомментарии Тогда
			
			Результат.Добавить(НСтр("ru = '// Добавляем строки';
									|en = '// Add rows'", Язык));
			
		КонецЕсли;
		
		Для Каждого СтрокаТЗ Из Значение Цикл 
			
			Результат.Добавить(НСтр("ru = 'НоваяСтрока = %1.Добавить();';
									|en = 'NewRow = %1.Add();'", Язык));
			
			Для Каждого Колонка Из Колонки Цикл 
				
				Шаблон = НСтр("ru = 'НоваяСтрока[""%1""] = %2;';
								|en = 'NewRow[""%1""] = %2;'", Язык);
				Результат.Добавить(СтрШаблон(Шаблон, Колонка.Имя, Значение(СтрокаТЗ[Колонка.Имя], ДополнительныеПараметры, , Истина)));
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат СтрСоединить(Результат, Символы.ПС);
	
КонецФункции

Функция ЗначениеПрочие(Значение, ДополнительныеПараметры, Комментарий)
	
	ТипЗначения = ТипЗнч(Значение);
	ОбъектМетаданных = Метаданные.НайтиПоТипу(ТипЗначения);
	
	Если ОбъектМетаданных = Неопределено Тогда
		
		Результат = Значение(Неопределено, ДополнительныеПараметры);
		
	Иначе
		
		Результат = ЗначениеСсылка(Значение, ДополнительныеПараметры, Комментарий);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЗначениеСсылка(Значение, ДополнительныеПараметры, Комментарий)
	
	Язык = ДополнительныеПараметры.Язык;
	
	ТипЗначения = ТипЗнч(Значение);
	ОбъектМетаданных = Метаданные.НайтиПоТипу(ТипЗначения);
	ИмяОбъектаМетаданных = ОбъектМетаданных.Имя;
	
	ИмяКоллекцииМетаданных = ИТК_Метаданные.ИмяКоллекции(ОбъектМетаданных, Язык);
	ИмяОбъектаКоллекции = ИТК_Метаданные.ИмяОбъектаКоллекции(ОбъектМетаданных, Язык);
	
	Если ИТК_Метаданные.ЭтоТипТочкаМаршрутаБизнесПроцесса(ТипЗначения) Тогда
		
		ИмяТочки = "";
		ТочкиМаршрута = БизнесПроцессы[ИмяОбъектаМетаданных].ТочкиМаршрута;
		Для Каждого ТочкаМаршрута Из ТочкиМаршрута Цикл 
			
			Если ТочкаМаршрута = Значение Тогда
				
				ИмяТочки = ТочкаМаршрута.Имя;
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Результат = СтрШаблон("БизнесПроцессы.%1.ТочкиМаршрута.%2", ИмяОбъектаМетаданных, ИмяТочки);
		
	ИначеЕсли Значение.Пустая() Тогда
		
		Шаблон = НСтр("ru = '%1.%2.ПустаяСсылка()';
						|en = '%1.%2.EmptyRef()'", Язык);
		Результат = СтрШаблон(Шаблон, ИмяКоллекцииМетаданных, ИмяОбъектаМетаданных);
		
	ИначеЕсли ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПеречисление(ИмяОбъектаКоллекции) Тогда
		
		Результат = СтрШаблон("%1.%2.%3", ИмяКоллекцииМетаданных, ИмяОбъектаМетаданных, XMLСтрока(Значение));
		
	Иначе
		
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ОбъектCПредопределенными(ИмяОбъектаКоллекции) 
				И Значение.Предопределенный Тогда
			
			Результат = СтрШаблон("%1.%2.%3", ИмяКоллекцииМетаданных, ИмяОбъектаМетаданных, Значение.ИмяПредопределенныхДанных);
			
		Иначе
			
			Шаблон = НСтр("ru = '%1.%2.ПолучитьСсылку(%3)';
							|en = '%1.%2.GetRef(%3)'", Язык);
			Результат = СтрШаблон(Шаблон, ИмяКоллекцииМетаданных, ИмяОбъектаМетаданных, Значение(Значение.УникальныйИдентификатор(), ДополнительныеПараметры));
			Комментарий = СтрШаблон("%1 (%2.%3)", Строка(Значение), ИмяКоллекцииМетаданных, ИмяОбъектаМетаданных);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ГенерироватьКодУстановкиПараметров(Данные, Строки, ДополнительныеПараметры)
	
	Язык = ДополнительныеПараметры.Язык;
	ДобавлятьКомментарии = ДополнительныеПараметры.ДобавлятьКомментарии;
	
	ЗначенияПараметров = ИТК_Запрос.ЗначенияПараметров(Данные, Ложь);
	Если Не ЗначениеЗаполнено(ЗначенияПараметров) Тогда 
		Возврат;
	КонецЕсли;
	
	Строки.Добавить("");
	Если ДобавлятьКомментарии Тогда
		
		Строки.Добавить(НСтр("ru = '// Установка значений параметров';
							|en = '// Setting parameter values'", Язык));
		
	КонецЕсли;
	
	Для Каждого ОписаниеПараметра Из ЗначенияПараметров Цикл
		
		ИмяПараметра = ОписаниеПараметра.Ключ; 
		ЗначениеПараметра = ОписаниеПараметра.Значение;
		
		СложныйПараметр = Ложь;
		ВидПараметра = "";
		КодИнициализацииПараметра = "";
		КомментарийПараметра = "";
		
		Если ТипЗнч(ЗначениеПараметра) = Тип("Структура") И ЗначениеПараметра.Вид = ИТК_Перечисления.СложныйПараметрЗапросаВыражение() Тогда
			
			СложныйПараметр = Истина;
			ВидПараметра = НСтр("ru = 'Выражение';
								|en = 'Expression'");
			КодИнициализацииПараметра = ЗначениеПараметра.Значение;
			КодЗначенияПараметра = ИТК_РедакторКодаКлиентСервер.ИмяПеременнойВозвратаРезультата(Язык);
			
		Иначе 		
			
			Если ТипЗнч(ЗначениеПараметра) = Тип("Структура") Тогда
				
				Если ЗначениеПараметра.Вид = ИТК_Перечисления.СложныйПараметрЗапросаТаблицаЗначений() Тогда
					
					СложныйПараметр = Истина;
					ВидПараметра = НСтр("ru = 'Таблица значений';
										|en = 'Table of values'");
					ЗначениеПараметра = ПолучитьИзВременногоХранилища(ЗначениеПараметра.Значение);
					
				ИначеЕсли ЗначениеПараметра.Вид = ИТК_Перечисления.СложныйПараметрЗапросаГраница() Тогда
					
					ОписаниеГраницы = ЗначениеПараметра.Значение;
					ЗначениеПараметра = ИТК_Запрос.ГраницаИзОписания(ОписаниеГраницы);
					
				КонецЕсли;
				
			ИначеЕсли ТипЗнч(ЗначениеПараметра) = Тип("СписокЗначений") Тогда 
				
				СложныйПараметр = Истина;
				ВидПараметра = НСтр("ru = 'Список значений';
									|en = 'List of values'");
				
			КонецЕсли;
			
			ДополнениеРезультата = Неопределено;
			КодЗначенияПараметра = Значение(ЗначениеПараметра, ДополнительныеПараметры, ДополнениеРезультата);
			
			Если ЗначениеЗаполнено(ДополнениеРезультата.Комментарий) Тогда
				КомментарийПараметра = ДополнениеРезультата.Комментарий;
			КонецЕсли;
			
			Если ДополнениеРезультата.ТребуетсяИнициализация Тогда
				
				ИмяЗначенияПараметра = НСтр("ru = 'Параметр'; en = 'Parametr'", Язык);
				КодИнициализацииПараметра = СтрШаблон(КодЗначенияПараметра, ИмяЗначенияПараметра);
				КодЗначенияПараметра = ИмяЗначенияПараметра;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если СложныйПараметр Тогда
			
			Если ДобавлятьКомментарии Тогда
				Строки.Добавить(СтрШаблон(НСтр("ru = '// Параметр ""%1"" (%2)';
												|en = '// Parametr ""%1"" (%2)'", Язык), ИмяПараметра, ВидПараметра));
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(КодИнициализацииПараметра) Тогда
			Строки.Добавить(КодИнициализацииПараметра);
		КонецЕсли;
		
		// Строка установки значения параметра
		Шаблон = НСтр("ru = 'Запрос.УстановитьПараметр(""%1"", %2);';
						|en = 'Query.SetParameter(""%1"", %2);'", Язык);
		КодУстановкиЗначенияПараметра = СтрШаблон(Шаблон, ИмяПараметра, КодЗначенияПараметра);
		
		Если ЗначениеЗаполнено(КомментарийПараметра) Тогда
			КодУстановкиЗначенияПараметра = КодУстановкиЗначенияПараметра + "// " + КомментарийПараметра;
		КонецЕсли;
		
		Строки.Добавить(КодУстановкиЗначенияПараметра);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ГенерироватьКодДобавитьТекстВСтроки(Текст, Строки)
	
	Для НомерСтроки = 1 По СтрЧислоСтрок(Текст) Цикл 
		
		Строка = СтрПолучитьСтроку(Текст, НомерСтроки);
		Строки.Добавить(Строка);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ГенерироватьКодВыборкиЗапроса(СхемаЗапроса, Строки, Настройки, Язык)
	
	Строки.Добавить("");
	
	Если Настройки.ДобавлятьКомментарии Тогда
		Строки.Добавить(НСтр("ru = '// Выборка';
							|en = '// Selection'"));
	КонецЕсли;
	
	ИмяНачальнойВыборки = НСтр("ru = 'РезультатЗапроса';
								|en = 'ResultQuery'");
	
	Если Настройки.ВыборкаПоГруппировкам Тогда
		
		ЗапросСхемы = ИТК_Запрос.ПервыйЗапросСхемыСРезультатом(СхемаЗапроса);
		
		Если ЗапросСхемы.ОбщиеИтоги Тогда
			
			Строки.Добавить(НСтр("ru = 'ВыборкаОбщийИтог = РезультатЗапроса.Выбрать();';
								|en = 'SelectionCommon = ResultQuery.Select();'", Язык));
			Строки.Добавить(НСтр("ru = 'ВыборкаОбщийИтог.Следующий();';
								|en = 'SelectionCommon.Next();'", Язык));
			Строки.Добавить("");
			
			ИмяНачальнойВыборки = НСтр("ru = 'ВыборкаОбщийИтог';
										|en = 'SelectionCommon'");
			
		КонецЕсли;
		
		ШаблонВыборки = "";
		
		ИмяВыборки = ИмяНачальнойВыборки;
		Для Каждого ЭлементИтог Из ЗапросСхемы.КонтрольныеТочкиИтогов Цикл
			
			Если ЭлементИтог.ТипКонтрольнойТочки = ТипКонтрольнойТочкиСхемыЗапроса.Элементы Тогда
				ТипВыборки = НСтр("ru = 'ОбходРезультатаЗапроса.ПоГруппировкам';
									|en = 'QueryResultIteration.ByGroups'");
			Иначе 
				ТипВыборки = НСтр("ru = 'ОбходРезультатаЗапроса.ПоГруппировкамСИерархией';
									|en = 'QueryResultIteration.ByGroupsWithHierarchy'");
			КонецЕсли;
			
			ШаблонИмени = НСтр("ru = 'Выборка%1';
								|en = 'Selection%1'", Язык);
			ИмяНовойВыборки = СтрШаблон(ШаблонИмени, ЭлементИтог.ИмяКолонки);
			Шаблон = КодШаблонаЭлементаВыборкиЗапроса(ИмяНовойВыборки, ИмяВыборки, Язык, ТипВыборки);
			ИмяВыборки = ИмяНовойВыборки;
			Если ЗначениеЗаполнено(ШаблонВыборки) Тогда
				ШаблонВыборки = СтрШаблон(ШаблонВыборки, ИТК_Строки.ДобавитьТабВМногострочныйТекст(Шаблон, Ложь));
			Иначе
				ШаблонВыборки = Шаблон;
			КонецЕсли;
			
		КонецЦикла;
		
	Иначе
		
		ШаблонВыборки = КодШаблонаЭлементаВыборкиЗапроса(НСтр("ru = 'Выборка';
																|en = 'Selection'", Язык), ИмяНачальнойВыборки, Язык);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ШаблонВыборки) Тогда
		
		ТекстВыборки = СтрШаблон(ШаблонВыборки, НСтр("ru = '// Код';
													|en = '// Code'", Язык));
		ГенерироватьКодДобавитьТекстВСтроки(ТекстВыборки, Строки)
		
	КонецЕсли;
		
КонецПроцедуры

Функция КодШаблонаЭлементаВыборкиЗапроса(Имя, ИмяНачала, Язык, Тип = "")
	
	Шаблон = НСтр("ru = '%1 = %2.Выбрать(%3);
	|Пока %1.Следующий() Цикл
	|	%%1
	|КонецЦикла;';
	|en = '%1 = %2.Select(%3);
	|While %1.Next() Do
	|	%%1
	|EndDo;'", Язык);
	
	Возврат СтрШаблон(Шаблон, Имя, ИмяНачала, Тип);
	
КонецФункции

Процедура СхемаЗапроса_ДобавитьЗаполнениеСвойствЗапроса(ОписаниеЗапроса, Настройки, Строки)
	
	ЗапросСхемы = ОписаниеЗапроса.Объект;
	ИмяЗапросаПакета = ОписаниеЗапроса.Имя;
	
	ЗначениеСвойстваПоУмолчанию = Ложь;
	ИмяСвойства = НСтр("ru = 'ВыбиратьРазрешенные'; en = 'SelectAllowed'", Настройки.Язык);
	СхемаЗапроса_ДобавитьЗаполнениеСвойства(ЗапросСхемы, ИмяЗапросаПакета, ИмяСвойства, ЗначениеСвойстваПоУмолчанию, Настройки, Строки);
	
	ЗначениеСвойстваПоУмолчанию = Ложь;
	ИмяСвойства = НСтр("ru = 'Автопорядок'; en = 'AutoOrder'", Настройки.Язык);
	СхемаЗапроса_ДобавитьЗаполнениеСвойства(ЗапросСхемы, ИмяЗапросаПакета, ИмяСвойства, ЗначениеСвойстваПоУмолчанию, Настройки, Строки);
	
	ЗначениеСвойстваПоУмолчанию = Ложь;
	ИмяСвойства = НСтр("ru = 'ОбщиеИтоги'; en = 'Overall'", Настройки.Язык);
	СхемаЗапроса_ДобавитьЗаполнениеСвойства(ЗапросСхемы, ИмяЗапросаПакета, ИмяСвойства, ЗначениеСвойстваПоУмолчанию, Настройки, Строки);
	
	ЗначениеСвойстваПоУмолчанию = "";
	ИмяСвойства = НСтр("ru = 'ТаблицаДляПомещения'; en = 'PlacementTable'", Настройки.Язык);
	СхемаЗапроса_ДобавитьЗаполнениеСвойства(ЗапросСхемы, ИмяЗапросаПакета, ИмяСвойства, ЗначениеСвойстваПоУмолчанию, Настройки, Строки);
	
	Если ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.25") Тогда
		
		ЗначениеСвойстваПоУмолчанию = "";
		ИмяСвойства = НСтр("ru = 'ТаблицаДляДобавления'; en = 'TableToAdd'", Настройки.Язык);
		СхемаЗапроса_ДобавитьЗаполнениеСвойства(ЗапросСхемы, ИмяЗапросаПакета, ИмяСвойства, ЗначениеСвойстваПоУмолчанию, Настройки, Строки);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура СхемаЗапроса_ДобавитьЗаполнениеСвойства(Объект, ИмяОбъекта, ИмяСвойства, ЗначениеПоУмолчанию, Настройки, Строки)
	
	ЗначениеСвойства = Объект[ИмяСвойства];
	Если НЕ Настройки.ДобавлятьЗначенияСвойствПоУмолчанию
			И ЗначениеСвойства = ЗначениеПоУмолчанию Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Язык", Настройки.Язык);
	КодЗначения = Значение(ЗначениеСвойства, ДополнительныеПараметры);
	
	ТекстСтроки = СтрШаблон("%1.%2 = %3;", ИмяОбъекта, ИмяСвойства, КодЗначения);
	Строки.Добавить(ТекстСтроки);
	
КонецПроцедуры

Процедура СхемаЗапроса_ДобавитьЗапрос(ОписаниеЗапроса, Настройки, СтрокиКода)
	
	Язык = Настройки.Язык;
	ЗапросСхемы = ОписаниеЗапроса.Объект;
	
	Если ТипЗнч(ЗапросСхемы) = Тип("ЗапросУничтоженияТаблицыСхемыЗапроса") Тогда
		
		ЗначениеИмяТаблицы = Значение(ЗапросСхемы.ИмяТаблицы);
		ШаблонСтрокиКода = НСтр("ru = '%1.ИмяТаблицы = %2;'; en = '%1.TableName = %2;'", Язык);
		СтрокиКода.Добавить(СтрШаблон(ШаблонСтрокиКода, ОписаниеЗапроса.Имя, ЗначениеИмяТаблицы));
		Возврат;
		
	КонецЕсли;
	
	СхемаЗапроса_ДобавитьЗаполнениеСвойствЗапроса(ОписаниеЗапроса, Настройки, СтрокиКода);
	
	Для Каждого ОператорСхемыЗапроса Из ЗапросСхемы.Операторы Цикл
		
		ИндексОператора = ЗапросСхемы.Операторы.Индекс(ОператорСхемыЗапроса);
		НомерОператора = ИндексОператора + 1;
		
		ОписаниеОператораСхемыЗапроса = Новый Структура;
		ОписаниеОператораСхемыЗапроса.Вставить("Индекс", ИндексОператора);
		ОписаниеОператораСхемыЗапроса.Вставить("Объект", ОператорСхемыЗапроса);
		
		ШаблонИмени = НСтр("ru = 'Оператор%1'; |en = 'Operator%1'", Язык);
		ОписаниеОператораСхемыЗапроса.Вставить("Имя", СтрШаблон(ШаблонИмени, НомерОператора));
		
		ПредставлениеОператора = СтрШаблон(НСтр("ru = 'Оператор №%1'; en = 'Operator №%1'", Язык), НомерОператора);
		ОписаниеОператораСхемыЗапроса.Вставить("Представление", ПредставлениеОператора);
		
		СхемаЗапроса_ДобавитьОператорСхемыЗапроса(ОписаниеЗапроса, ОписаниеОператораСхемыЗапроса, Настройки, СтрокиКода);
		
	КонецЦикла;
	
	СхемаЗапроса_ДобавитьПсевдонимыПолейЗапросаПакета(ОписаниеЗапроса, Настройки, СтрокиКода);
	СхемаЗапроса_ДобавитьИндексыЗапросаПакета(ОписаниеЗапроса, Настройки, СтрокиКода);
	СхемаЗапроса_ДобавитьПорядокЗапросаПакета(ОписаниеЗапроса, Настройки, СтрокиКода);
	СхемаЗапроса_ДобавитьКонтрольныеТочкиИтоговЗапросаПакета(ОписаниеЗапроса, Настройки, СтрокиКода);
	СхемаЗапроса_ДобавитьВыраженияИтоговЗапросаПакета(ОписаниеЗапроса, Настройки, СтрокиКода);
	
КонецПроцедуры

Процедура СхемаЗапроса_ДобавитьПсевдонимыПолейЗапросаПакета(ОписаниеЗапросаПакета, Настройки, Строки)
	
	ЗапросПакета = ОписаниеЗапросаПакета.Объект;
	ИмяЗапросаПакета = ОписаниеЗапросаПакета.Имя;
	
	Язык = Настройки.Язык;
	Если Настройки.ДобавлятьКомментарии Тогда
		
		Строки.Добавить("");
		
		ШаблонСтрокиКода = НСтр("ru = '// %1 - Псевдонимы';
								|en = '// %1 - Alias'", Язык);
		СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ОписаниеЗапросаПакета.Представление);
		Строки.Добавить(СтрокаКода);
		
	КонецЕсли;
	
	АнализируемаяКоллекция = ЗапросПакета.Колонки;
	Для Каждого Колонка Из АнализируемаяКоллекция Цикл 
		
		ИндексКолонки = АнализируемаяКоллекция.Индекс(Колонка);
		
		Для Каждого ПолеКолонки Из Колонка.Поля Цикл 
			
			ИндексПоляКолонки = Колонка.Поля.Индекс(ПолеКолонки);
			
			Если ПолеКолонки = Неопределено Тогда
				ВыражениеПоляКолонки = Значение(ПолеКолонки);
			Иначе
				
				ШаблонСтрокиКода = НСтр("ru = '%1.Операторы[%2].ВыбираемыеПоля[%3]'; en = '%1.Operators[%2].SelectedFields[%3]'", Язык);
				ОписаниеВыбираемогоПоля = СхемаЗапроса_НайтиВыбираемоеПолеОператор(ЗапросПакета.Операторы, ПолеКолонки);
				ВыражениеПоляКолонки = СтрШаблон(ШаблонСтрокиКода, ИмяЗапросаПакета, ОписаниеВыбираемогоПоля.ИндексОператора, ОписаниеВыбираемогоПоля.ИндексПоля);
				
			КонецЕсли;
			
			ШаблонСтрокиКода = НСтр("ru = '%1.Колонки[%2].Поля.Установить(%3, %4);'; en = '%1.Columns[%2].Fields.Set(%3, %4);'", Язык);
			СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяЗапросаПакета, ИндексКолонки, ИндексКолонки, ВыражениеПоляКолонки);
			Строки.Добавить(СтрокаКода);
			
		КонецЦикла;
		
		Если ТипЗнч(Колонка) = Тип("КолонкаСхемыЗапроса") Тогда
			
			ШаблонСтрокиКода = НСтр("ru = '%1.Колонки[%2].Псевдоним = %3;'; en = '%1.Columns[%2].Alias = %3;'", Язык);
			СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяЗапросаПакета, ИндексКолонки, Значение(Колонка.Псевдоним));
			Строки.Добавить(СтрокаКода);
			
		ИначеЕсли ТипЗнч(Колонка) = Тип("КолонкаВложеннаяТаблицаСхемыЗапроса") Тогда
			
			ШаблонСтрокиКода = НСтр("ru = '%1.Колонки[%2].Псевдоним = %3;'; en = '%1.Columns[%2].Alias = %3;'", Язык);
			СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяЗапросаПакета, ИндексКолонки, Значение(Колонка.Псевдоним));
			Строки.Добавить(СтрокаКода);
			
			Для Каждого ВложеннаяКолонка Из Колонка.Колонки Цикл 
				
				ИндексВложеннойКолонки = Колонка.Колонки.Индекс(ВложеннаяКолонка);
				
				ШаблонСтрокиКода = НСтр("ru = '%1.Колонки[%2].Колонки[%3].Псевдоним = %4;'; en = '%1.Columns[%2].Columns[%3].Alias = %4;'", Язык);
				СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяЗапросаПакета, ИндексКолонки, ИндексВложеннойКолонки, Значение(ВложеннаяКолонка.Псевдоним));
				Строки.Добавить(СтрокаКода);
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура СхемаЗапроса_ДобавитьПорядокЗапросаПакета(ОписаниеЗапросаПакета, Настройки, Строки)
	
	ЗапросПакета = ОписаниеЗапросаПакета.Объект;
	ИмяЗапросаПакета = ОписаниеЗапросаПакета.Имя;
	АнализируемаяКоллекция = ЗапросПакета.Порядок;
	
	Если НЕ ЗначениеЗаполнено(АнализируемаяКоллекция) Тогда
		Возврат;
	КонецЕсли;
	
	Язык = Настройки.Язык;
	Если Настройки.ДобавлятьКомментарии Тогда
		
		Строки.Добавить("");
		
		ШаблонСтрокиКода = НСтр("ru = '// %1 - Порядок';
								|en = '// %1 - Order'", Язык);
		СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ОписаниеЗапросаПакета.Представление);
		Строки.Добавить(СтрокаКода);
		
	КонецЕсли;
	
	Для Каждого ВыражениеПорядка Из АнализируемаяКоллекция Цикл 
		
		ИндексВыраженияПорядка = АнализируемаяКоллекция.Индекс(ВыражениеПорядка);
		ШаблонИмениВыражениеПорядка = НСтр("ru = 'ВыражениеПорядка%1';
								|en = 'OrderExpressions%1'", Язык);
		ИмяОбъектаВыражениеПорядка = СтрШаблон(ШаблонИмениВыражениеПорядка, ИндексВыраженияПорядка + 1);
		
		// Оступ
		Если ИндексВыраженияПорядка > 0 Тогда
			Строки.Добавить("");
		КонецЕсли;
		
		// Элемент выражение порядка
		Если ТипЗнч(ВыражениеПорядка.Элемент) = Тип("КолонкаСхемыЗапроса") Тогда
			
			ШаблонСтрокиКода = НСтр("ru = 'КолонкаСхемыЗапроса = %1.Колонки.Найти(""%2"");';
									|en = 'QuerySchemaColumn = %2.Columns.Find(""%2"");'", Язык);
			СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяЗапросаПакета, ВыражениеПорядка.Элемент.Псевдоним);
			Строки.Добавить(СтрокаКода);
			
			ПолеВыраженияПорядка = НСтр("ru = 'КолонкаСхемыЗапроса';
										|en = 'QuerySchemaColumn'", Язык);
			
		ИначеЕсли ТипЗнч(ВыражениеПорядка.Элемент) = Тип("ВыражениеСхемыЗапроса") Тогда
			
			ШаблонСтрокиКода = НСтр("ru = 'ВыражениеСхемыЗапроса = Новый ВыражениеСхемыЗапроса(""%1"");';
									|en = 'QuerySchemaExpression = New QuerySchemaExpression(""%1"");'", Язык);
			СтрокаКода = СтрШаблон(ШаблонСтрокиКода, Строка(ВыражениеПорядка.Элемент));
			Строки.Добавить(СтрокаКода);
			
			ПолеВыраженияПорядка = НСтр("ru = 'ВыражениеСхемыЗапроса';
										|en = 'QuerySchemaExpression'", Язык);
			
		КонецЕсли;
		
		ШаблонСтрокиКода = НСтр("ru = '%1 = %2.Порядок.Добавить(%3);'; en = '%1 = %2.Order.Add(%3);'", Язык);
		СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяОбъектаВыражениеПорядка, ИмяЗапросаПакета, ПолеВыраженияПорядка);
		Строки.Добавить(СтрокаКода);
		
		ЗначениеСвойстваПоУмолчанию = НаправлениеПорядкаСхемыЗапроса.ПоВозрастанию;
		ИмяСвойства = НСтр("ru = 'Направление'; en = 'Direction'", Настройки.Язык);
		СхемаЗапроса_ДобавитьЗаполнениеСвойства(ВыражениеПорядка, ИмяОбъектаВыражениеПорядка, "Направление", ЗначениеСвойстваПоУмолчанию, Настройки, Строки);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура СхемаЗапроса_ДобавитьКонтрольныеТочкиИтоговЗапросаПакета(ОписаниеЗапросаПакета, Настройки, Строки)
	
	ЗапросПакета = ОписаниеЗапросаПакета.Объект;
	ИмяЗапросаПакета = ОписаниеЗапросаПакета.Имя;
	АнализируемаяКоллекция = ЗапросПакета.КонтрольныеТочкиИтогов;
	
	Если НЕ ЗначениеЗаполнено(АнализируемаяКоллекция) Тогда
		Возврат;
	КонецЕсли;
	
	Язык = Настройки.Язык;
	Если Настройки.ДобавлятьКомментарии Тогда
		
		Строки.Добавить("");
		
		ШаблонСтрокиКода = НСтр("ru = '// %1 - Итоги (поля)';
								|en = '// %1 - Totals (fields)'", Язык);
		СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ОписаниеЗапросаПакета.Представление);
		Строки.Добавить(СтрокаКода);
		
	КонецЕсли;
	
	Для Каждого КонтрольнаяТочкаИтогов Из АнализируемаяКоллекция Цикл 
		
		ИндексКонтрольнойТочкиИтогов = АнализируемаяКоллекция.Индекс(КонтрольнаяТочкаИтогов);
		ШаблонИмениКонтрольнойТочкиИтогов = НСтр("ru = 'КонтрольнаяТочкаИтогов%1';
												|en = 'TotalCalculationField%1'", Язык);
		ИмяОбъектаКонтрольнаяТочкаИтогов = СтрШаблон(ШаблонИмениКонтрольнойТочкиИтогов, ИндексКонтрольнойТочкиИтогов + 1);
		
		// Оступ
		Если ИндексКонтрольнойТочкиИтогов > 0 Тогда
			Строки.Добавить("");
		КонецЕсли;
		
		// Элемент контрольная точка итогов
		Если ТипЗнч(КонтрольнаяТочкаИтогов.Выражение) = Тип("КолонкаСхемыЗапроса") Тогда
			
			ШаблонСтрокиКода = НСтр("ru = 'КолонкаСхемыЗапроса = %1.Колонки.Найти(""%2"");';
									|en = 'QuerySchemaColumn = %2.Columns.Find(""%2"");'", Язык);
			СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяЗапросаПакета, КонтрольнаяТочкаИтогов.Выражение.Псевдоним);
			Строки.Добавить(СтрокаКода);
			
			ПолеВыраженияКонтрольнойТочки = НСтр("ru = 'КолонкаСхемыЗапроса';
										|en = 'QuerySchemaColumn'", Язык);
			
		ИначеЕсли ТипЗнч(КонтрольнаяТочкаИтогов.Выражение) = Тип("ВыражениеСхемыЗапроса") Тогда
			
			ШаблонСтрокиКода = НСтр("ru = 'ВыражениеСхемыЗапроса = Новый ВыражениеСхемыЗапроса(""%1"");';
									|en = 'QuerySchemaExpression = New QuerySchemaExpression(""%1"");'", Язык);
			СтрокаКода = СтрШаблон(ШаблонСтрокиКода, Строка(КонтрольнаяТочкаИтогов.Выражение));
			Строки.Добавить(СтрокаКода);
			
			ПолеВыраженияКонтрольнойТочки = НСтр("ru = 'ВыражениеСхемыЗапроса';
										|en = 'QuerySchemaExpression'", Язык);
			
		КонецЕсли;
		
		ШаблонСтрокиКода = НСтр("ru = '%1 = %2.КонтрольныеТочкиИтогов.Добавить(%3);'; en = '%1 = %2.TotalCalculationFields.Add(%3);'", Язык);
		СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяОбъектаКонтрольнаяТочкаИтогов, ИмяЗапросаПакета, ПолеВыраженияКонтрольнойТочки);
		Строки.Добавить(СтрокаКода);
		
		ЗначениеСвойстваПоУмолчанию = "";
		ИмяСвойства = НСтр("ru = 'ИмяКолонки'; en = 'ColumnName'", Язык);
		СхемаЗапроса_ДобавитьЗаполнениеСвойства(КонтрольнаяТочкаИтогов, ИмяОбъектаКонтрольнаяТочкаИтогов, ИмяСвойства, ЗначениеСвойстваПоУмолчанию, Настройки, Строки);
		
		ЗначениеСвойстваПоУмолчанию = ТипКонтрольнойТочкиСхемыЗапроса.Элементы;
		ИмяСвойства = НСтр("ru = 'ТипКонтрольнойТочки'; en = 'TotalCalculationFieldType'", Язык);
		СхемаЗапроса_ДобавитьЗаполнениеСвойства(КонтрольнаяТочкаИтогов, ИмяОбъектаКонтрольнаяТочкаИтогов, ИмяСвойства,
			ЗначениеСвойстваПоУмолчанию, Настройки, Строки);
		
		ЗначениеСвойстваПоУмолчанию = ТипДополненияПериодамиСхемыЗапроса.БезДополнения;
		ИмяСвойства = НСтр("ru = 'ТипДополненияПериодами'; en = 'PeriodAdditionType'", Язык);
		СхемаЗапроса_ДобавитьЗаполнениеСвойства(КонтрольнаяТочкаИтогов, ИмяОбъектаКонтрольнаяТочкаИтогов, ИмяСвойства,
			ЗначениеСвойстваПоУмолчанию, Настройки, Строки);
			
		ЗначениеСвойстваПоУмолчанию = "";
		ИмяСвойства = НСтр("ru = 'НачалоПериодаДополнения'; en = 'PeriodAdditionBegin'", Язык);
		СхемаЗапроса_ДобавитьЗаполнениеСвойства(КонтрольнаяТочкаИтогов, ИмяОбъектаКонтрольнаяТочкаИтогов, ИмяСвойства, ЗначениеСвойстваПоУмолчанию, Настройки, Строки);
		
		ЗначениеСвойстваПоУмолчанию = "";
		ИмяСвойства = НСтр("ru = 'КонецПериодаДополнения'; en = 'PeriodAdditionEnd'", Язык);
		СхемаЗапроса_ДобавитьЗаполнениеСвойства(КонтрольнаяТочкаИтогов, ИмяОбъектаКонтрольнаяТочкаИтогов, ИмяСвойства, ЗначениеСвойстваПоУмолчанию, Настройки, Строки);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура СхемаЗапроса_ДобавитьВыраженияИтоговЗапросаПакета(ОписаниеЗапросаПакета, Настройки, Строки)
	
	ЗапросПакета = ОписаниеЗапросаПакета.Объект;
	ИмяЗапросаПакета = ОписаниеЗапросаПакета.Имя;
	АнализируемаяКоллекция = ЗапросПакета.ВыраженияИтогов;
	
	Если НЕ ЗначениеЗаполнено(АнализируемаяКоллекция) Тогда
		Возврат;
	КонецЕсли;
	
	Язык = Настройки.Язык;
	Если Настройки.ДобавлятьКомментарии Тогда
		
		Строки.Добавить("");
		
		ШаблонСтрокиКода = НСтр("ru = '// %1 - Итоги (выражения)';
								|en = '// %1 - Totals (expressions)'", Язык);
		СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ОписаниеЗапросаПакета.Представление);
		Строки.Добавить(СтрокаКода);
		
	КонецЕсли;
	
	Для Каждого ВыражениеИтогов Из АнализируемаяКоллекция Цикл 
		
		ИндексВыраженияИтогов = АнализируемаяКоллекция.Индекс(ВыражениеИтогов);
		ШаблонИмениВыраженияИтогов = НСтр("ru = 'ВыражениеИтогов%1';
												|en = 'TotalExpression%1'", Язык);
		ИмяОбъектаВыраженияИтогов = СтрШаблон(ШаблонИмениВыраженияИтогов, ИндексВыраженияИтогов + 1);
		
		// Оступ
		Если ИндексВыраженияИтогов > 0 Тогда
			Строки.Добавить("");
		КонецЕсли;
		
		// Элемент выражение итогов
		ШаблонСтрокиКода = НСтр("ru = 'ВыражениеСхемыЗапроса = Новый ВыражениеСхемыЗапроса(""%1"");';
								|en = 'QuerySchemaExpression = New QuerySchemaExpression(""%1"");'", Язык);
		СтрокаКода = СтрШаблон(ШаблонСтрокиКода, Строка(ВыражениеИтогов.Выражение));
		Строки.Добавить(СтрокаКода);
		
		ПолеВыражения = НСтр("ru = 'ВыражениеСхемыЗапроса';
							|en = 'QuerySchemaExpression'", Язык);
		
		ШаблонСтрокиКода = НСтр("ru = '%1 = %2.ВыраженияИтогов.Добавить(%3);'; en = '%1 = %2.TotalExpressions.Add(%3);'", Язык);
		СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяОбъектаВыраженияИтогов, ИмяЗапросаПакета, ПолеВыражения);
		Строки.Добавить(СтрокаКода);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура СхемаЗапроса_ДобавитьИндексыЗапросаПакета(ОписаниеЗапросаПакета, Настройки, Строки)
	
	Если НЕ ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.25") Тогда
		Возврат;
	КонецЕсли;
	
	ЗапросПакета = ОписаниеЗапросаПакета.Объект;
	ИмяЗапросаПакета = ОписаниеЗапросаПакета.Имя;
	АнализируемаяКоллекция = ЗапросПакета.Индексы;
	
	Если АнализируемаяКоллекция.Количество() = 1
			И НЕ ЗначениеЗаполнено(АнализируемаяКоллекция[0].ВыраженияИндекса) Тогда
		Возврат;
	КонецЕсли;
	
	Язык = Настройки.Язык;
	Если Настройки.ДобавлятьКомментарии Тогда
		
		Строки.Добавить("");
		
		ШаблонСтрокиКода = НСтр("ru = '// %1 - Индексы';
								|en = '// %1 - Indexes'", Язык);
		СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ОписаниеЗапросаПакета.Представление);
		Строки.Добавить(СтрокаКода);
		
	КонецЕсли;
	
	Для Каждого Индекс Из АнализируемаяКоллекция Цикл 
		
		ИндексИндекса = АнализируемаяКоллекция.Индекс(Индекс);
		ШаблонИмениИндекса = НСтр("ru = 'Индекс%1';
								|en = 'Index%1'", Язык);
		ИмяОбъектаИндекса = СтрШаблон(ШаблонИмениИндекса, ИндексИндекса + 1);
		
		// Оступ
		Если ИндексИндекса > 0 Тогда
			Строки.Добавить("");
		КонецЕсли;
		
		ШаблонСтрокиКода = НСтр("ru = '%1 = %2.Индексы.Добавить();'; en = '%1 = %2.Indexes.Add();'", Язык);
		СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяОбъектаИндекса, ИмяЗапросаПакета);
		Строки.Добавить(СтрокаКода);
		
		ЗначениеСвойстваПоУмолчанию = Ложь;
		ИмяСвойства = НСтр("ru = 'Уникальный'; en = 'Unique'", Язык);
		СхемаЗапроса_ДобавитьЗаполнениеСвойства(Индекс, ИмяОбъектаИндекса, ИмяСвойства, ЗначениеСвойстваПоУмолчанию, Настройки, Строки);
		
		Для Каждого ВыраженияИндекса Из Индекс.ВыраженияИндекса Цикл 
			
			Строки.Добавить("");
			
			Если ТипЗнч(ВыраженияИндекса.Выражение) = Тип("КолонкаСхемыЗапроса") Тогда
				
				ШаблонСтрокиКода = НСтр("ru = 'КолонкаСхемыЗапроса = %1.Колонки.Найти(""%2"");';
										|en = 'QuerySchemaColumn = %2.Columns.Find(""%2"");'", Язык);
				СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяЗапросаПакета, ВыраженияИндекса.Выражение.Псевдоним);
				Строки.Добавить(СтрокаКода);
				
				ПолеВыраженияИндекса = НСтр("ru = 'КолонкаСхемыЗапроса';
											|en = 'QuerySchemaColumn'", Язык);
				
			ИначеЕсли ТипЗнч(Индекс.ВыраженияИндекса) = Тип("ВыражениеСхемыЗапроса") Тогда
				
				ШаблонСтрокиКода = НСтр("ru = 'ВыражениеСхемыЗапроса = Новый ВыражениеСхемыЗапроса(""%1"");';
										|en = 'QuerySchemaExpression = New QuerySchemaExpression(""%1"");'", Язык);
				СтрокаКода = СтрШаблон(ШаблонСтрокиКода, Строка(Индекс.Выражение));
				Строки.Добавить(СтрокаКода);
				
				ПолеВыраженияИндекса = НСтр("ru = 'ВыражениеСхемыЗапроса';
											|en = 'QuerySchemaExpression'", Язык);
				
			КонецЕсли;
			
			ШаблонСтрокиКода = НСтр("ru = '%1.ВыраженияИндекса.Добавить(%2);'; en = '%1.IndexExpressions.Add(%2);'", Язык);
			СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяОбъектаИндекса, ПолеВыраженияИндекса);
			Строки.Добавить(СтрокаКода);
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура СхемаЗапроса_ДобавитьОператорСхемыЗапроса(ОписаниеЗапросПакета, ОписаниеОператора, Настройки, Строки)
	
	ЗапросПакета = ОписаниеЗапросПакета.Объект;
	ИмяЗапросаПакета = ОписаниеЗапросПакета.Имя;
	ПредставлениеЗапросПакета = ОписаниеЗапросПакета.Представление;
	
	ОператорЗапроса = ОписаниеОператора.Объект;
	ИмяОператора = ОписаниеОператора.Имя;
	ПредставлениеОператора = ОписаниеОператора.Представление;
	
	Язык = Настройки.Язык;
	Если Настройки.ДобавлятьКомментарии Тогда
		
		Строки.Добавить("");
		
		СтрокаКода = СтрШаблон("// %1 - %2 --------------------------------------------------------", ПредставлениеЗапросПакета, ПредставлениеОператора);
		Строки.Добавить(СтрокаКода);
		
	КонецЕсли;
	
	Если ОписаниеОператора.Индекс = 0 Тогда
		ШаблонОператора = НСтр("ru = '%1 = %2.Операторы[0];'; en = '%1 = %2.Operators[0];'", Язык);
	Иначе
		ШаблонОператора = НСтр("ru = '%1 = %2.Операторы.Добавить();'; en = '%1 = %2.Operators.Add();'", Язык);
	КонецЕсли;
	
	СтрокаКода = СтрШаблон(ШаблонОператора, ИмяОператора, ИмяЗапросаПакета);
	Строки.Добавить(СтрокаКода);
	
	ЗначениеСвойстваПоУмолчанию = ТипОбъединенияСхемыЗапроса.ОбъединитьВсе;
	ИмяСвойства = НСтр("ru = 'ТипОбъединения'; en = 'UnionType'", Настройки.Язык);
	СхемаЗапроса_ДобавитьЗаполнениеСвойства(ОператорЗапроса, ИмяОператора, ИмяСвойства, ЗначениеСвойстваПоУмолчанию, Настройки, Строки);
	
	ЗначениеСвойстваПоУмолчанию = Ложь;
	ИмяСвойства = НСтр("ru = 'ВыбиратьРазличные'; en = 'SelectDistinct'", Настройки.Язык);
	СхемаЗапроса_ДобавитьЗаполнениеСвойства(ОператорЗапроса, ИмяОператора, ИмяСвойства, ЗначениеСвойстваПоУмолчанию, Настройки, Строки);
	
	ЗначениеСвойстваПоУмолчанию = Неопределено;
	ИмяСвойства = НСтр("ru = 'КоличествоПолучаемыхЗаписей'; en = 'RetrievedRecordsCount'", Настройки.Язык);
	СхемаЗапроса_ДобавитьЗаполнениеСвойства(ОператорЗапроса, ИмяОператора, ИмяСвойства, ЗначениеСвойстваПоУмолчанию, Настройки, Строки);
	
	СхемаЗапроса_ДобавитьИсточникиОператораСхемыЗапроса(ОписаниеЗапросПакета, ОписаниеОператора, Настройки, Строки);
	СхемаЗапроса_ДобавитьПоляОператораСхемыЗапроса(ОписаниеЗапросПакета, ОписаниеОператора, Настройки, Строки);
	
	Если ОператорЗапроса.ВыбиратьДляИзменения Тогда
		
		Строки.Добавить("");
		
		ЗначениеСвойстваПоУмолчанию = Ложь;
		ИмяСвойства = НСтр("ru = 'ВыбиратьДляИзменения'; en = 'SelectForUpdate'", Настройки.Язык);
		СхемаЗапроса_ДобавитьЗаполнениеСвойства(ОператорЗапроса, ИмяОператора, ИмяСвойства, ЗначениеСвойстваПоУмолчанию, Настройки, Строки);
		
		Для Каждого ТаблицаДляИзменения из ОператорЗапроса.ТаблицыДляИзменения Цикл
			
			ШаблонСтрокиКода = НСтр("ru = '%1.ТаблицыДляИзменения.Добавить(%2);';
									|en = '%1.TablesForUpdate.Add(%2);'", Язык);
			СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяОператора, Значение(ТаблицаДляИзменения.ИмяТаблицы));
			Строки.Добавить(СтрокаКода);
			
		КонецЦикла;
		
	КонецЕсли;
	
	//НовыйПакет.Колонки[0].Поля.Установить(0, НовыйПакет.Операторы[0].ВыбираемыеПоля[0]);
	//НовыйПакет.Колонки[0].Поля.Установить(1, Неопределено);
	//НовыйПакет.Колонки[0].Поля.Установить(2, Неопределено);
	
	СхемаЗапроса_ДобавитьГруппировкиОператораСхемыЗапроса(ОписаниеЗапросПакета, ОписаниеОператора, Настройки, Строки);
	СхемаЗапроса_ДобавитьОтборОператораСхемыЗапроса(ОписаниеЗапросПакета, ОписаниеОператора, Настройки, Строки);
	
КонецПроцедуры

Процедура СхемаЗапроса_ДобавитьПоляОператораСхемыЗапроса(ОписаниеЗапросПакета, ОписаниеОператора, Настройки, Строки)
	
	ОператорЗапроса = ОписаниеОператора.Объект;
	ИмяОператора = ОписаниеОператора.Имя;
	
	Язык = Настройки.Язык;
	Если Настройки.ДобавлятьКомментарии Тогда
		
		Строки.Добавить("");
		
		ШаблонСтрокиКода = НСтр("ru = '// %1 - %2 - Поля'; en = '// %1 - %2 - Fields'", Язык);
		СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ОписаниеЗапросПакета.Представление, ОписаниеОператора.Представление);
		Строки.Добавить(СтрокаКода);
		
	КонецЕсли;
	
	Для Каждого Поле Из ОператорЗапроса.ВыбираемыеПоля Цикл 
		
		Если ТипЗнч(Поле) = Тип("ВыражениеСхемыЗапроса") Тогда
			
			ШаблонСтрокиКода = НСтр("ru = '%1.ВыбираемыеПоля.Добавить(%2);';
									|en = '%1.SelectedFields.Add(%2);'", Язык);
			СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяОператора, Значение(Строка(Поле)));
			Строки.Добавить(СтрокаКода);
			
		ИначеЕсли ТипЗнч(Поле) = Тип("ВложеннаяТаблицаСхемыЗапроса") Тогда
			
			Для Каждого ВложенноеПоле Из Поле.Поля Цикл 
				
				ШаблонСтрокиКода = НСтр("ru = '%1.ВыбираемыеПоля.Добавить(%2);';
										|en = '%1.SelectedFields.Add(%2);'", Язык);
				СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяОператора, Значение(Строка(ВложенноеПоле)));
				Строки.Добавить(СтрокаКода);
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура СхемаЗапроса_ДобавитьИсточникиОператораСхемыЗапроса(ОписаниеЗапросПакета, ОписаниеОператора, Настройки, Строки)
	
	ОператорЗапроса = ОписаниеОператора.Объект;
	ИмяОператора = ОписаниеОператора.Имя;
	
	АнализируемаяКоллекция = ОператорЗапроса.Источники;
	Если НЕ ЗначениеЗаполнено(АнализируемаяКоллекция) Тогда
		Возврат;
	КонецЕсли;
	
	Язык = Настройки.Язык;
	Если Настройки.ДобавлятьКомментарии Тогда
		
		Строки.Добавить("");
		
		ШаблонСтрокиКода = НСтр("ru = '// %1 - %2 - Источники'; en = '// %1 - %2 - Sources'", Язык);
		СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ОписаниеЗапросПакета.Представление, ОписаниеОператора.Представление);
		Строки.Добавить(СтрокаКода);
		
	КонецЕсли;
	
	Для Каждого Источник Из АнализируемаяКоллекция Цикл 
		
		ИндексИсточника = АнализируемаяКоллекция.Индекс(Источник);
		НомерИсточника = ИндексИсточника + 1;
		ИмяИсточника = СтрШаблон(НСтр("ru = 'Источник%1'; en = 'Source%1'", Язык), НомерИсточника);
		ПредставлениеИсточника = СтрШаблон(НСтр("ru = 'Источник №%1'; en = 'Source #%1'", Язык), НомерИсточника);
		
		Если ИндексИсточника > 0 Тогда
			Строки.Добавить("");
		КонецЕсли;
		
		Если ТипЗнч(Источник.Источник) = Тип("ТаблицаСхемыЗапроса") Тогда
			
			ШаблонСтрокиКода = НСтр("ru = '%1 = %2.Источники.Добавить(%3, %4);'; en = '%1 = %2.Sources.Add(%3, %4);'", Язык);
			СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяИсточника, ИмяОператора,
							Значение(Источник.Источник.ИмяТаблицы), Значение(Источник.Источник.Псевдоним));
			Строки.Добавить(СтрокаКода);
			
		ИначеЕсли ТипЗнч(Источник.Источник) = Тип("ОписаниеВременнойТаблицыСхемыЗапроса") Тогда
			
			ШаблонСтрокиКода = НСтр("ru = '%1 = %2.Источники.Добавить(Тип(""ОписаниеВременнойТаблицыСхемыЗапроса""), %3, %4);';
									|en = '%1 = %2.Sources.Add(Type(""QuerySchemaTempTableDescription""), %3, %4);'", Язык);
			СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяИсточника, ИмяОператора,
							Значение(Источник.Источник.ИмяТаблицы), Значение(Источник.Источник.Псевдоним));
			Строки.Добавить(СтрокаКода);
			
			Для Каждого ДоступноеПоле Из Источник.Источник.ДоступныеПоля Цикл 
				
				ШаблонСтрокиКода = НСтр("ru = '%1.Источник.ДоступныеПоля.Добавить(%2);'; en = '%1.Source.AvailableFields.Add(%2);'", Язык);
				СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяИсточника, Значение(ДоступноеПоле.Имя));
				Строки.Добавить(СтрокаКода);
				
			КонецЦикла;
			
		ИначеЕсли ТипЗнч(Источник.Источник) = Тип("ВложенныйЗапросСхемыЗапроса") Тогда
			
			ШаблонСтрокиКода = НСтр("ru = '%1 = %2.Источники.Добавить(Тип(""ВложенныйЗапросСхемыЗапроса""), ""%3"");';
									|en = '%1 = %2.Sources.Add(Type(""QuerySchemaNestedQuery""), ""%3"");'", Язык);
			СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяИсточника, ИмяОператора, Источник.Источник.Псевдоним);
			Строки.Добавить(СтрокаКода);
			
		КонецЕсли;
		
		// Соединения
		ШаблонСтрокиКода = НСтр("ru = '%1.Соединения.Очистить();'; en = '%1.Joins.Clear();'", Язык);
		СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяИсточника);
		Строки.Добавить(СтрокаКода);
		
		Если ТипЗнч(Источник.Источник) = Тип("ВложенныйЗапросСхемыЗапроса") Тогда
			
			ИмяВложенногоЗапроса = НСтр("ru = 'ВложенныйЗапрос'; en = 'NestedQuery'", Язык);
			ПредставлениеВложенногоЗапроса = НСтр("ru = 'Вложенный запрос'; en = 'Nested query'", Язык);
			
			ШаблонСтрокиКода = НСтр("ru = '%1 = %2.Источник.Запрос;'; en = '%1 = %2.Source.Query;'", Язык);
			СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяВложенногоЗапроса, ИмяИсточника);
			Строки.Добавить(СтрокаКода);
			
			ОписаниеВложенногоЗапроса = Новый Структура;
			ОписаниеВложенногоЗапроса.Вставить("Объект", Источник.Источник.Запрос);
			ОписаниеВложенногоЗапроса.Вставить("Имя", ИмяВложенногоЗапроса);
			ОписаниеВложенногоЗапроса.Вставить("Представление", ИмяВложенногоЗапроса);
			
			СхемаЗапроса_ДобавитьЗапрос(ОписаниеВложенногоЗапроса, Настройки, Строки);
			
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Источник.Соединения) Тогда
			Продолжить;
		КонецЕсли;
		
		Строки.Добавить("");
		
		Если Настройки.ДобавлятьКомментарии Тогда
			
			ШаблонСтрокиКода = НСтр("ru = '// %1 - %2 - %3 - Соединения'; en = '// %1 - %2 - %3 - Joins'", Язык);
			СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ОписаниеЗапросПакета.Представление, ОписаниеОператора.Представление, ПредставлениеИсточника);
			Строки.Добавить(СтрокаКода);
			
		КонецЕсли;
		
		Для Каждого Соединение Из Источник.Соединения Цикл 
			
			ИндексИсточникаСоединения = Источник.Соединения.Индекс(Соединение);
			ПсевдонимИсточникаСоединения = Соединение.Источник.Источник.Псевдоним;
			
			ШаблонСтрокиКода = НСтр("ru = '%1.Источник.Соединения.Добавить(%2, %3);'; en = '%1.Source.Joins.Add(%2, %3);'", Язык);
			СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяИсточника, Значение(ПсевдонимИсточникаСоединения), Значение(Строка(Соединение.Условие)));
			Строки.Добавить(СтрокаКода);
			
			ШаблонИмяОбъектаСоединение = НСтр("ru = '%1.Источник.Соединения[%2]'; en = '%1.Source.Joins[%2]'", Язык);
			ИмяОбъектаСоединение = СтрШаблон(ШаблонИмяОбъектаСоединение, ИмяИсточника, ИндексИсточникаСоединения);
			
			ЗначениеСвойстваПоУмолчанию = Неопределено;
			ИмяСвойства = НСтр("ru = 'ТипСоединения'; en = 'JoinType'", Язык);
			СхемаЗапроса_ДобавитьЗаполнениеСвойства(Соединение, ИмяОбъектаСоединение, ИмяСвойства, ЗначениеСвойстваПоУмолчанию, Настройки, Строки);
			
			Если ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.14") Тогда
				
				ЗначениеСвойстваПоУмолчанию = Истина;
				ИмяСвойства = НСтр("ru = 'ОбязательноеСоединение'; en = 'RequiredJoin'", Язык);
				СхемаЗапроса_ДобавитьЗаполнениеСвойства(Соединение, ИмяОбъектаСоединение, ИмяСвойства, ЗначениеСвойстваПоУмолчанию, Настройки, Строки);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура СхемаЗапроса_ДобавитьОтборОператораСхемыЗапроса(ОписаниеЗапросПакета, ОписаниеОператора, Настройки, Строки)
	
	ОператорЗапроса = ОписаниеОператора.Объект;
	ИмяОператора = ОписаниеОператора.Имя;
	
	АнализируемаяКоллекция = ОператорЗапроса.Отбор;
	Если НЕ ЗначениеЗаполнено(АнализируемаяКоллекция) Тогда
		Возврат;
	КонецЕсли;
	
	Язык = Настройки.Язык;
	Если Настройки.ДобавлятьКомментарии Тогда
		
		Строки.Добавить("");
		
		ШаблонСтрокиКода = НСтр("ru = '// %1 - %2 - Условия'; en = '// %1 - %2 - Conditions'", Язык);
		СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ОписаниеЗапросПакета.Представление, ОписаниеОператора.Представление);
		Строки.Добавить(СтрокаКода);
		
	КонецЕсли;
	
	Для Каждого Поле Из АнализируемаяКоллекция Цикл 
		
		ШаблонСтрокиКода = НСтр("ru = '%1.Отбор.Добавить(%2);';
								|en = '%1.Filter.Add(%2);'", Язык);
		СтрокаКода = СтрШаблон(ШаблонСтрокиКода, ИмяОператора, Значение(Строка(Поле)));
		Строки.Добавить(СтрокаКода);
		
	КонецЦикла;
	
КонецПроцедуры

