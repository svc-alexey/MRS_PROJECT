Функция СхемаЗапроса_НайтиВыбираемоеПолеОператор(Операторы, ИскомоеПоле)
	
	ИндексОператора = Неопределено;
	ИндексПоля = Неопределено;
	
	Для Каждого ОператорЗапроса Из Операторы Цикл 
		
		Для Каждого ВыбираемоеПоле Из ОператорЗапроса.ВыбираемыеПоля Цикл 
			
			Если ВыбираемоеПоле = ИскомоеПоле Тогда
				
				ИндексОператора = Операторы.Индекс(ОператорЗапроса);
				ИндексПоля = ОператорЗапроса.ВыбираемыеПоля.Индекс(ВыбираемоеПоле);
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Результат = Новый Структура;
	Результат.Вставить("ИндексОператора", ИндексОператора);
	Результат.Вставить("ИндексПоля", ИндексПоля);
	Возврат Результат;
	
КонецФункции

#КонецОбласти