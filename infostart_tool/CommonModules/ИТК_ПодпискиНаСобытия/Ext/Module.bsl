#Область ПрограммныйИнтерфейс

Процедура ДанныеПодписок(Параметры, АдресРезультата) Экспорт

	Подписка = Параметры.Подписка;
	ОтборПоМетаданным = Параметры.ОтборПоМетаданным;
	Если ЗначениеЗаполнено(Подписка) Тогда
		
		Подписки = Новый Массив;
		Подписки.Добавить(Метаданные.ПодпискиНаСобытия[Подписка]);
		
	Иначе
		
		Подписки = Получить(Параметры.Событие, ОтборПоМетаданным, Параметры.ОтборПоПодписке);
		
	КонецЕсли;
	
	// Возврат результата
	Результат = Новый Структура;
	
	Источники = ИсточникиПодписок(Подписки, ОтборПоМетаданным);
	Результат.Вставить("Источники", Источники);
	
	Обработчики = ОбработчикиПодписок(Подписки);
	Результат.Вставить("Обработчики", Обработчики);
	
	ПоместитьВоВременноеХранилище(Результат, АдресРезультата);
	
КонецПроцедуры

Функция Получить(Событие = Неопределено, ОтборПоМетаданным = Неопределено, ОтборПоПодписке = Неопределено) Экспорт
	
	Результат = Новый Массив;
	
	ЧастиПоиска = ИТК_Строки.ЧастиПоискаПоПодобию(ОтборПоПодписке);
	Для Каждого ОписаниеПодписки Из Метаданные.ПодпискиНаСобытия Цикл 
		
		Если ЗначениеЗаполнено(Событие) 
				И Строка(ОписаниеПодписки.Событие) <> Событие Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ОтборПоМетаданным) 
				И НЕ ИТК_Метаданные.ОписаниеТиповСоответствуютОтбору(ОписаниеПодписки.Источник, ОтборПоМетаданным) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ОтборПоПодписке) Тогда
			
			АнализируемаяСтрокаИмя = ИТК_Строки.АнализируемаяСтрокаПоискаПоПодобию(ОписаниеПодписки.Имя);
			АнализируемаяСтрокаСиноним = ИТК_Строки.АнализируемаяСтрокаПоискаПоПодобию(ОписаниеПодписки.Синоним);
			Если НЕ (ИТК_Строки.НайденоПоПодобию(АнализируемаяСтрокаИмя, ЧастиПоиска)
						ИЛИ ИТК_Строки.НайденоПоПодобию(АнализируемаяСтрокаСиноним, ЧастиПоиска)) Тогда
						
				Продолжить;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Результат.Добавить(ОписаниеПодписки);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПредставлениеСобытия(ИмяСобытия) Экспорт 
	
	Если ИТК_ОбщийПовтИсп.ВариантВстроенногоЯзыкаРусский() Тогда
		Возврат ИмяСобытия;
	КонецЕсли;
	
	СоответсвиеИмен = ИТК_ПодпискиНаСобытияПовтИсп.СоответствиеПредставленийИменСобытий();
	Результат = СоответсвиеИмен.Получить(Строка(ИмяСобытия));
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОбработчикиПодписок(Подписки)
	
	Результат = Новый ДеревоЗначений;
	Результат.Колонки.Добавить("Картинка", ИТК_ТипыКлиентСервер.ОписаниеКартинка());
	Результат.Колонки.Добавить("Представление", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	
	// Собираем все обработчики, группируем
	Обработчики = Новый Соответствие;
	Для Каждого ОписаниеПодписки Из Подписки Цикл 
		
		Обработчики.Вставить(ОписаниеПодписки.Обработчик);
		
	КонецЦикла;
	
	// Получаем дерево Модуль - Процедура
	СтрокиМодулей = Новый Соответствие;
	Для Каждого Обработчик Из Обработчики Цикл 
		
		Обработчик = СтрРазделить(Обработчик.Ключ, ".");
		ИмяМодуля = Обработчик[0];
		ИмяПроцедуры = Обработчик[1];
		
		СтрокаМодуль = СтрокиМодулей.Получить(ИмяМодуля);
		Если СтрокаМодуль = Неопределено Тогда
			
			СтрокаМодуль = Результат.Строки.Добавить();
			СтрокаМодуль.Картинка = ИТК_ОбщийКлиентСерверПовтИсп.БиблиотекаКартинок("ИТК_МетаданныеОбщийМодуль");
			СтрокаМодуль.Представление = ИмяМодуля;
			
			СтрокиМодулей.Вставить(ИмяМодуля, СтрокаМодуль);
			
		КонецЕсли;
		
		СтрокаПроцедура = СтрокаМодуль.Строки.Добавить();
		СтрокаПроцедура.Картинка = БиблиотекаКартинок.ИТК_Процедура;
		СтрокаПроцедура.Представление = ИмяПроцедуры;
		
	КонецЦикла;
	
	// Сортируем по представлению
	Результат.Строки.Сортировать("Представление", Истина);
	
	Возврат Результат;
	
КонецФункции

Функция ИсточникиПодписок(Подписки, ОтборПоМетаданным)
	
	Результат = Новый ДеревоЗначений;
	Результат.Колонки.Добавить("Картинка", ИТК_ТипыКлиентСервер.ОписаниеКартинка());
	Результат.Колонки.Добавить("Представление", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	Результат.Колонки.Добавить("Порядок", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10));
	Результат.Колонки.Добавить("Выделить", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	
	// Собираем все обработчики, группируем
	Источники = Новый Соответствие;
	Для Каждого ОписаниеПодписки Из Подписки Цикл 
		
		Для Каждого ТипИсточника Из ОписаниеПодписки.Источник.Типы() Цикл
			
			Источники.Вставить(ТипИсточника, Строка(ОписаниеПодписки.Событие));
			
		КонецЦикла;
		
	КонецЦикла;
	
	// Получаем дерево Коллекция метаданных - объект метаданных
	СтрокиКоллекций = Новый Соответствие;
	Для Каждого Источник Из Источники Цикл 
		
		ОбъектаМетаданных = Метаданные.НайтиПоТипу(Источник.Ключ);
		ИмяКоллекции = ИТК_Метаданные.ИмяКоллекции(ОбъектаМетаданных);
		ИмяОбъектаКоллекции = ИТК_Метаданные.ИмяОбъектаКоллекции(ОбъектаМетаданных);
		ИмяОбъектаМетаданных = ОбъектаМетаданных.Имя;
		Событие = Источник.Значение;
		
		СтрокаКоллекция = СтрокиКоллекций.Получить(ИмяКоллекции);
		Если СтрокаКоллекция = Неопределено Тогда

			СтрокаКоллекция = Результат.Строки.Добавить();
			СтрокаКоллекция.Картинка = ИТК_МетаданныеКлиентСерверПовтИсп.КартинкаОбъектаКоллекции(ИмяОбъектаКоллекции);
			СтрокаКоллекция.Представление = ИмяКоллекции;
			СтрокаКоллекция.Порядок = ИТК_МетаданныеКлиентСерверПовтИсп.ПорядокОбъектаКоллекции(ИмяОбъектаКоллекции);
			
			СтрокиКоллекций.Вставить(ИмяКоллекции, СтрокаКоллекция);
			
		КонецЕсли;
		
		СтрокаОбъект = СтрокаКоллекция.Строки.Добавить();
		СтрокаОбъект.Картинка = СтрокаКоллекция.Картинка;
		СтрокаОбъект.Представление = ИТК_МетаданныеКлиентСервер.ПредставлениеОбъектаИсточникаПодписки(Событие, ИмяОбъектаКоллекции, ИмяОбъектаМетаданных);
		
		// Заполнение выделения объектов по отбору
		Если ЗначениеЗаполнено(ОтборПоМетаданным) Тогда
			
			Выделить = ИТК_Метаданные.СоответствуютОтбору(ИмяОбъектаКоллекции, ИмяОбъектаМетаданных, ОтборПоМетаданным);
			СтрокаОбъект.Выделить = Выделить;
			Если Выделить Тогда
				СтрокаКоллекция.Выделить = Истина;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	// Сортируем по порядку, представлению
	Результат.Строки.Сортировать("Порядок,Представление", Истина);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
