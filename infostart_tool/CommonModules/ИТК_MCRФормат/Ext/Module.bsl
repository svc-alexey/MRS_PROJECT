#Область ПрограммныйИнтерфейс

// Читает данные файла MCR из временного хранилища и помещает в иерархический массив структур
//
// Параметры:
//   ЧитаемыеДанные - Строка - Адрес временного хранилища содержащего данные 
//   				- ДвоичныеДанные - Двоичные данные 
//   УникальныйИдентификатор - УникальныйИдентификатор - Уникальный идентификатор
//
// Возвращаемое значение:
//   Массив	- Массив (иерархический) содержит структуры
//
Функция Прочитать(ЧитаемыеДанные, УникальныйИдентификатор) Экспорт
	
	Если ЭтоАдресВременногоХранилища(ЧитаемыеДанные) Тогда
		ФайлZipДвоичныеДанные = ПолучитьИзВременногоХранилища(ЧитаемыеДанные);
	Иначе
		ФайлZipДвоичныеДанные = ЧитаемыеДанные;
	КонецЕсли;
	
	ЧтениеZipФайла = Новый ЧтениеZipФайла(ФайлZipДвоичныеДанные.ОткрытьПотокДляЧтения());
	КаталогДляРаспаковки = ПолучитьИмяВременногоФайла();
	
	ЭлементZip = ЧтениеZipФайла.Элементы[0]; // берем первый файл (всегда один)
	ЧтениеZipФайла.Извлечь(ЭлементZip, КаталогДляРаспаковки);
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.ОткрытьФайл(КаталогДляРаспаковки + ПолучитьРазделительПути() + ЭлементZip.Имя);
	
	НовоеДеревоДанных = ИТК_XML.ПрочитатьВДерево(ЧтениеXML);
	
	ЧтениеXML.Закрыть();
	
	// Удалим временные файлы
	УдалитьФайлы(КаталогДляРаспаковки);
	
	КорневойЭлемент = НовоеДеревоДанных.Строки[0];
	ВерсияДанныхФайла = КорневойЭлемент.Значение.Version;
	
	Если ВерсияДанныхФайла > ИТК_ОбщийКлиентСервер.MCRПоддерживаемаяВерсия() Тогда
		
		Шаблон = НСтр("ru = 'Неподдерживаемая версия данных %1, требуется обновление.';
						|en = 'Unsupported version of data %1, update required.'");
		ВызватьИсключение СтрШаблон(Шаблон, ВерсияДанныхФайла);
		
	КонецЕсли;
	
	Данные = ПрочитатьЭлемент(КорневойЭлемент);
	ИТК_MCRФормат.ДополнительнаяОбработкаДанныхПослеЗагрузки(Данные, УникальныйИдентификатор);
	
	Возврат Данные;
	
КонецФункции

// Производит чтение данных из строки (MCR формат)
//
// Параметры:
//  Строка  - Строка - Имя Type
//
// Возвращаемое значение:
//   Перечисления.ИТК_ЭлементыДанных - Перечисление Type
//
Функция ЧтениеType(Строка) Экспорт

	Возврат ИТК_MCRФорматПовтИсп.ПреобразованиеПеречисленияЭлементДанных(Строка, Истина);

КонецФункции

// Производит обработку загруженных данных дополняя
//
// Параметры:
//  Данные  - Данные - Данные
//  УникальныйИдентификатор  - УникальныйИдентификатор - Уникальный идентификатор
//
Процедура ДополнительнаяОбработкаДанныхПослеЗагрузки(Данные, УникальныйИдентификатор) Экспорт
	
	Для Каждого ЭлементДанных Из Данные Цикл 
		
		ЭлементДанных.Вставить("UID", Новый УникальныйИдентификатор);
		ЭлементДанных.Type = ЧтениеType(ЭлементДанных.Type);
		
		Если ЭлементДанных.Type = ИТК_Перечисления.ЭлементДанныхЗапрос() Тогда 
			
			// Проверим запрос
			Результат = ИТК_Запрос.ПроверитьТекст(ЭлементДанных.Text);
			ЭлементДанных.Вставить("ТребуетсяПроверка", Ложь);
			ЭлементДанных.Вставить("Параметры", Результат.Параметры);
			ЭлементДанных.Вставить("ВременныеТаблицы", Результат.ВременныеТаблицы);
			ЭлементДанных.Вставить("Ошибка", ИТК_ЗапросКлиентСервер.ИнформацияООшибке(Результат.ТекстОшибки));
			
			// Обработка ТЗ в параметрах и временных таблицах
			Если ЭлементДанных.Свойство("Parameters") Тогда
				
				Для Каждого Параметр Из ЭлементДанных.Parameters Цикл 
					
					ЗначениеПараметра = Параметр.Значение;
					
					Если ТипЗнч(ЗначениеПараметра) = Тип("Массив") Тогда
						
						СписокЗначений = Новый СписокЗначений;
						Для Каждого ЭлементСписка Из ЗначениеПараметра Цикл 
							СписокЗначений.Добавить(ЭлементСписка);
						КонецЦикла;
						
						ЭлементДанных.Parameters.Вставить(Параметр.Ключ, СписокЗначений);
						
					ИначеЕсли ТипЗнч(ЗначениеПараметра) = Тип("ТаблицаЗначений") Тогда
						
						АдресЗначения = ПоместитьВоВременноеХранилище(ЗначениеПараметра, УникальныйИдентификатор);
						Значение = ИТК_ЗапросКлиентСервер.ЗначениеСложногоПараметра(ИТК_Перечисления.СложныйПараметрЗапросаТаблицаЗначений(), АдресЗначения);
						ЭлементДанных.Parameters.Вставить(Параметр.Ключ, Значение);
						
					КонецЕсли;
					
				КонецЦикла;
			КонецЕсли;
			
		ИначеЕсли ЭлементДанных.Type = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных() Тогда 
			
			// Проверим схему компоновки данных
			Результат = ИТК_СКД.ПроверитьТекст(ЭлементДанных.Text);
			ЭлементДанных.Вставить("ТребуетсяПроверка", Ложь);
			ЭлементДанных.Вставить("Ошибка", ИТК_СКДКлиентСервер.ИнформацияООшибке(Результат.ТекстОшибки));
			
		КонецЕсли;
		
		Если ЭлементДанных.Свойство("ExternalSources") Тогда
			
			Для Каждого ВременнаТаблица Из ЭлементДанных.ExternalSources Цикл 
				
				ОписаниеВнешнегоИсточника = ВременнаТаблица.Значение;
				Если ТипЗнч(ОписаниеВнешнегоИсточника.Значение) = Тип("ТаблицаЗначений") Тогда
					ОписаниеВнешнегоИсточника.Значение = ПоместитьВоВременноеХранилище(ОписаниеВнешнегоИсточника.Значение, УникальныйИдентификатор);
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
		Если ЭлементДанных.Свойство("TTMTables") Тогда
			
			Для Каждого ВременнаТаблица Из ЭлементДанных.TTMTables Цикл 
				
				ОписаниеТаблицыМВТ = ВременнаТаблица.Значение;
				Если ТипЗнч(ОписаниеТаблицыМВТ.Значение) = Тип("ТаблицаЗначений") Тогда
					ОписаниеТаблицыМВТ.Значение = ПоместитьВоВременноеХранилище(ОписаниеТаблицыМВТ.Значение, УникальныйИдентификатор);
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
		Если ЭлементДанных.Свойство("Elements") Тогда
			ДополнительнаяОбработкаДанныхПослеЗагрузки(ЭлементДанных.Elements, УникальныйИдентификатор);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Записывает данные в файл
//
// Параметры:
//  Данные  - Данные - Полное имя Zip файла
//  ИмяФайла  - Строка - Полное имя файла
//
Процедура ЗаписатьДанныеВФайл(Данные, ИмяФайла) Экспорт 
	
	ДвоичныеДанные = ДвоичныеДанныеMCR(Данные);
	ДвоичныеДанные.Записать(ИмяФайла);
	
КонецПроцедуры

// Формирует файл формата MCR и помещает во временное хранилище 
//
// Параметры:
//  Данные  - Массив - Дерево данных в виде массива структур
//
// Возвращаемое значение:
//   Строка	- Адрес двоичных данных файла во временном хранилище
//
Функция ПоместитьДанныеВоВременноеХранилище(Данные) Экспорт
	
	Возврат ПоместитьВоВременноеХранилище(ДвоичныеДанныеMCR(Данные));
	
КонецФункции

// Получает двоичиные данные MCR
//
// Параметры:
//  Данные  - Данные - Полное имя Zip файла
//
// Возвращаемое значение:
//   ДвоичныеДанные - Двоичиные данные MCR
//
Функция ДвоичныеДанныеMCR(Данные) Экспорт 
	
	ИмяФайлаXML = ПолучитьИмяВременногоФайла("xml");
	ДвоичныеДанныеXML = ДвоичныеДанныеXML(Данные);
	ДвоичныеДанныеXML.Записать(ИмяФайлаXML);
	
	ПотокЗаписи = Новый ПотокВПамяти;
	
	ЗаписьZipФайла = Новый ЗаписьZipФайла(ПотокЗаписи);
	ЗаписьZipФайла.Добавить(ИмяФайлаXML);
	ЗаписьZipФайла.Записать();
	
	// Удалим временные файлы
	УдалитьФайлы(ИмяФайлаXML);
	
	Возврат ПотокЗаписи.ЗакрытьИПолучитьДвоичныеДанные();
	
КонецФункции

// Сохраняет данные объекта в настройки
//
// Параметры:
//  Тип  - Перечисления.ИТК_ЭлементыДанных - Тип элементы данных
//
// Возвращаемое значение:
//   Строка - Представление Type
//
Функция ЗначениеTypeВXML(Тип) Экспорт
	
	Возврат ИТК_MCRФорматПовтИсп.ПреобразованиеПеречисленияЭлементДанных(Тип);

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ЧтениеПараметровЗапроса(СтрокаДерева)
	
	ЗначенияПараметров = Новый Соответствие;
	
	Для Каждого Строка Из СтрокаДерева.Строки Цикл 
		
		ДанныеПараметра = Строка.Значение;
		
		ЗначениеПараметра = ЧтениеЗначенияПараметраЗапроса(Строка);
		
		Если ЗначениеПараметра <> Неопределено Тогда 
			ЗначенияПараметров.Вставить(ДанныеПараметра.Name, ЗначениеПараметра);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ЗначенияПараметров;
	
КонецФункции

Функция ЧтениеВнешнихИсточников(СтрокаДерева)
	
	ВнешниеИсточники = Новый Соответствие;
	
	Для Каждого Строка Из СтрокаДерева.Строки Цикл 
		
		Данные = Строка.Значение;
		
		Type = ИТК_ОбщийКлиентСервер.Свойство(Данные, "Type", ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаЗначение());
		Если Type = "Expression" Тогда
			
			Type = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаВыражение();
			Значение = ИТК_ОбщийКлиентСервер.Свойство(Данные, "Value", "");
			
		Иначе
			
			Значение = ЧтениеЗначенияТаблицыЗначений(Строка);
			
		КонецЕсли;
		
		ОписаниеВнешнегоИсточника = ИТК_КонсольРазработчикаДанныеКлиентСервер.НовыйВнешнийИсточник(Данные.Name, Type, Значение);
		ВнешниеИсточники.Вставить(Новый УникальныйИдентификатор, ОписаниеВнешнегоИсточника);
		
	КонецЦикла;
	
	Возврат ВнешниеИсточники;
	
КонецФункции

Функция ЧтениеТаблицМВТ(СтрокаДерева)
	
	ТаблицыМВТ = Новый Соответствие;
	
	Для Каждого Строка Из СтрокаДерева.Строки Цикл 
		
		Данные = Строка.Значение;
		
		Type = ИТК_ОбщийКлиентСервер.Свойство(Данные, "Type", ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаЗначение());
		Если Type = "Expression" Тогда
			
			Type = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаВыражение();
			Значение = ИТК_ОбщийКлиентСервер.Свойство(Данные, "Value", "");
			
		Иначе
			
			Значение = ЧтениеЗначенияТаблицыЗначений(Строка);
			
		КонецЕсли;
		
		ОписаниеВнешнегоИсточника = ИТК_КонсольРазработчикаДанныеКлиентСервер.НоваяТаблицаМВТ(Данные.Name, Type, Значение);
		ТаблицыМВТ.Вставить(Новый УникальныйИдентификатор, ОписаниеВнешнегоИсточника);
		
	КонецЦикла;
	
	Возврат ТаблицыМВТ;
	
КонецФункции

Функция ЧтениеАлгоритмовОбработки(СтрокаДерева)
	
	АлгоритмыОбработки = Новый СписокЗначений;
	
	Для Каждого Строка Из СтрокаДерева.Строки Цикл 
		
		Данные = Строка.Значение;
		
		Код = ИТК_ОбщийКлиентСервер.Свойство(Данные, "Code", "");
		КодПеред = ИТК_ОбщийКлиентСервер.Свойство(Данные, "CodeBefore", "");
		КодПосле = ИТК_ОбщийКлиентСервер.Свойство(Данные, "CodeAfter", "");
		
		ПрерыватьПриОшибке = Ложь;
		Если Данные.Свойство("AbortOnError") Тогда
			ПрерыватьПриОшибке = XMLЗначение(Тип("Булево"), Данные.AbortOnError);
		КонецЕсли;
		
		ТранзакцияСтрока = ИТК_ОбщийКлиентСервер.Свойство(Данные, "Transaction", "");
		Если ЗначениеЗаполнено(ТранзакцияСтрока) Тогда
			
			Транзакция = ИТК_MCRФорматПовтИсп.ПреобразованиеПеречисленияТипТранзакцииОбработкиРезультата(ТранзакцияСтрока, Истина);
			
		Иначе
			
			Транзакция = ИТК_MCRФорматКлиентСервер.ТипТранзакцииОбработкиРезультатаПоУмолчанию();
			
		КонецЕсли;
		
		Параметры = Новый Структура;
		Параметры.Вставить("Код", Код);
		Параметры.Вставить("КодПеред", КодПеред);
		Параметры.Вставить("КодПосле", КодПосле);
		Параметры.Вставить("ПрерыватьПриОшибке", ПрерыватьПриОшибке);
		Параметры.Вставить("Транзакция", Транзакция);
		ОписаниеАлгоритмаОбработки = ИТК_MCRФорматКлиентСервер.ОписаниеАлгоритмаОбработки(Параметры);

		АлгоритмыОбработки.Добавить(ОписаниеАлгоритмаОбработки, Данные.Presentation);
		
	КонецЦикла;
	
	Возврат АлгоритмыОбработки;
	
КонецФункции

Функция ЧтениеНастроекВыводаПакета(СтрокаДерева)
	
	Результат = Новый Соответствие;
	
	Для Каждого Строка Из СтрокаДерева.Строки Цикл 
		
		Данные = Строка.Значение;
		
		Имя = ИТК_ОбщийКлиентСервер.Свойство(Данные, "Name", "");
		Вывод = ЗначениеВыводТаблицы(ИТК_ОбщийКлиентСервер.Свойство(Данные, "Output"));
		
		ОписаниеНастройкиВыводаТаблицы = ИТК_КонсольРазработчикаДанныеКлиентСервер.ОписаниеНастройкиВыводаТаблицы(Вывод);
		Результат.Вставить(Имя, ОписаниеНастройкиВыводаТаблицы);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ЧтениеЗначенияПараметраЗапроса(СтрокаДерева)
	
	ДанныеПараметра = СтрокаДерева.Значение;
	ТипПараметра = ИТК_ОбщийКлиентСервер.Свойство(ДанныеПараметра, "Type");
	
	ЗначениеПараметра = Неопределено;
	Если ТипПараметра = "Expression" Тогда
		
		ЗначениеПараметра = ИТК_ЗапросКлиентСервер.ЗначениеСложногоПараметра(ИТК_Перечисления.СложныйПараметрЗапросаВыражение(),
													ИТК_ОбщийКлиентСервер.Свойство(ДанныеПараметра, "Value", ""));
		
	ИначеЕсли ТипПараметра = "Table" Тогда	// Таблица значений
		
		ЗначениеПараметра = ЧтениеЗначенияТаблицыЗначений(СтрокаДерева);
		
	ИначеЕсли ТипПараметра = "PointInTime"
			ИЛИ ТипПараметра = "PointOfTime" Тогда // Момент времени
			// PointOfTime - устаревающий (для совместимости со старыми форматами)
			
		ЗначениеПараметра = ЧтениеМоментаВремени(ДанныеПараметра);
		
	ИначеЕсли ТипПараметра = "Boundary" Тогда // Граница
		
		Вид = ВидГраницы.Включая;
		Если ДанныеПараметра.Свойство("BoundaryType") И ДанныеПараметра.BoundaryType = "Excluding" Тогда
			Вид = ВидГраницы.Исключая;
		КонецЕсли;
		
		Значение = Неопределено;
		Если ДанныеПараметра.Свойство("ValueType") Тогда
			
			Если ДанныеПараметра.ValueType = "PointInTime" Тогда // Момент времени
				
				Значение = ЧтениеМоментаВремени(ДанныеПараметра);
				
			Иначе
				
				Значение = XMLЗначение(Тип(ДанныеПараметра.ValueType), ДанныеПараметра.Value);
				
			КонецЕсли;
			
		КонецЕсли;
		
		ОписаниеГраницы = ИТК_Запрос.ОписаниеИзГраницы(Новый Граница(Значение, Вид));
		ЗначениеПараметра = ИТК_ЗапросКлиентСервер.ЗначениеСложногоПараметра(ИТК_Перечисления.СложныйПараметрЗапросаГраница(), ОписаниеГраницы);
		
	ИначеЕсли ТипПараметра = "ValueList" Тогда // Список значений
		
		ЗначениеПараметра = Новый СписокЗначений;
		Для Каждого СтрокаПараметр Из СтрокаДерева.Строки Цикл // Блок Items
			
			ЗначениеПараметра.Добавить(ЧтениеЗначенияПараметраЗапроса(СтрокаПараметр));
			
		КонецЦикла;
		
	ИначеЕсли ТипПараметра = "Type" Тогда
		
		ЗначениеПараметра = Тип(ДанныеПараметра.Value);
		
	Иначе
		
		ЗначениеПараметра = ЧтениеЗначенияСТипом(ДанныеПараметра);
		
	КонецЕсли;
	
	Возврат ЗначениеПараметра;
	
КонецФункции

Функция ЧтениеЗначенияОписанияТипов(ДанныеОписания)
	
	Если ДанныеОписания.Свойство("Types") Тогда
		Типы = СтрРазделить(ДанныеОписания.Types, ",");
		СписокТипов = ДанныеОписания.Types;
	Иначе 
		Типы = Новый Массив;
		СписокТипов = "";
	КонецЕсли;
	
	КвалификаторыЧисла = Неопределено;
	Если Типы.Найти(ИТК_XML.ИмяТипа(Тип("Число"))) <> Неопределено Тогда
		
		Разрядность = ИТК_ОбщийКлиентСервер.Свойство(ДанныеОписания, "Digits", 0);
		РазрядностьДробнойЧасти = ИТК_ОбщийКлиентСервер.Свойство(ДанныеОписания, "FractionDigits", 0);
		ДопустимыйЗнакСтрока = ИТК_ОбщийКлиентСервер.Свойство(ДанныеОписания, "AllowedSign", "Any");
		
		КвалификаторыЧисла = Новый КвалификаторыЧисла(Разрядность, РазрядностьДробнойЧасти, ДопустимыйЗнак[ДопустимыйЗнакСтрока]);
		
	КонецЕсли;
	
	КвалификаторыСтроки = Неопределено;
	Если Типы.Найти(ИТК_XML.ИмяТипа(Тип("Строка"))) <> Неопределено Тогда
		
		ДлинаСтроки = ИТК_ОбщийКлиентСервер.Свойство(ДанныеОписания, "Length", 0);
		ДопустимаяДлинаСтрока = ИТК_ОбщийКлиентСервер.Свойство(ДанныеОписания, "AllowedLength", "Variable");
		
		КвалификаторыСтроки = Новый КвалификаторыСтроки(ДлинаСтроки, ДопустимаяДлина[ДопустимаяДлинаСтрока]);
		
	КонецЕсли;
	
	КвалификаторыДаты = Неопределено;
	Если Типы.Найти(ИТК_XML.ИмяТипа(Тип("Дата"))) <> Неопределено Тогда
		
		ЧастиДатыСтрока = ИТК_ОбщийКлиентСервер.Свойство(ДанныеОписания, "DateFractions", "DateTime");
		КвалификаторыДаты = Новый КвалификаторыДаты(ЧастиДаты[ЧастиДатыСтрока]);
		
	КонецЕсли;
	
	Попытка 
		
		Результат = Новый ОписаниеТипов(СписокТипов, КвалификаторыЧисла, КвалификаторыСтроки, КвалификаторыДаты);
		
	Исключение
		
		Результат = Новый ОписаниеТипов;
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция ЧтениеЗначенияТаблицыЗначений(СтрокаДерева)
	
	Value = ИТК_ОбщийКлиентСервер.Свойство(СтрокаДерева.Значение, "Value");
	Если ЗначениеЗаполнено(Value) Тогда // Таблица значений в Base64(СтрокаВнутр)
		
		СтрокаВнутр = ПолучитьСтрокуИзДвоичныхДанных(Base64Значение(Value));
		Результат = ЗначениеИзСтрокиВнутр(СтрокаВнутр);
		
	Иначе // Старый формат до 2.1
		
		Результат = Новый ТаблицаЗначений;
		СтрокаValue = СтрокаДерева.Строки.Найти("Value", "Имя");
		
		Если СтрокаValue <> Неопределено Тогда 
			
			Для Каждого СтрокаЗначенияValue Из СтрокаValue.Строки Цикл 
				
				ИмяДанных = СтрокаЗначенияValue.Имя;
				ДанныеКолонки = СтрокаЗначенияValue.Значение;
				
				Если ИмяДанных = "Column" Тогда // Колонка
					
					Результат.Колонки.Добавить(ДанныеКолонки.Name, ЧтениеЗначенияОписанияТипов(ДанныеКолонки));
					КолонкаИндексируется = ИТК_ОбщийКлиентСервер.Свойство(ДанныеКолонки, "Index", Ложь);
					Если КолонкаИндексируется Тогда
						Результат.Индексы.Добавить(ДанныеКолонки.Name);
					КонецЕсли;
					
				ИначеЕсли ИмяДанных = "Row" Тогда // Строка
					
					НоваяСтрока = Результат.Добавить();
					Индекс = 0;
					Для Каждого СтрокаЗначениеКолонкиСтроки Из СтрокаЗначенияValue.Строки Цикл 
						
						ЗначениеКолонкиСтроки = СтрокаЗначениеКолонкиСтроки.Значение;
						Если ЗначениеКолонкиСтроки.Свойство("Name") Тогда // Формат по старому до формата 1.3 
							
							НоваяСтрока[ЗначениеКолонкиСтроки.Name] = ЧтениеЗначенияСТипом(ЗначениеКолонкиСтроки);
							
						Иначе
							
							Колонка = Результат.Колонки[Индекс];
							
							Если  Колонка.ТипЗначения.Типы().Количество() > 1 Тогда
								ОписаниеТипов = Неопределено;
							Иначе 
								ОписаниеТипов = Колонка.ТипЗначения;
							КонецЕсли;
							
							НоваяСтрока[Колонка.Имя] = ЧтениеЗначенияСТипом(ЗначениеКолонкиСтроки, ОписаниеТипов);
							
						КонецЕсли;
						
						Индекс = Индекс + 1;
						
					КонецЦикла;
					
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЧтениеЗначенияСТипом(ДанныеЗначения, ОписаниеТипов = Неопределено)
	
	Попытка
		
		Если ОписаниеТипов = Неопределено Тогда
			
			Типы = ДанныеЗначения.Type;
			Тип = Тип(ДанныеЗначения.Type);
			
		Иначе
			
			Типы = Новый Массив;
			Если ЗначениеЗаполнено(ОписаниеТипов) Тогда
				Тип = ОписаниеТипов.Типы()[0];
				Типы.Добавить(Тип);
			КонецЕсли;
			
		КонецЕсли;
		
		Значение = Неопределено;
		ОписаниеТипов = Новый ОписаниеТипов(Типы);
	
		Если ДанныеЗначения.Свойство("Value") Тогда
			
			Если Тип = Тип("Тип") Тогда
				Значение = Тип(ДанныеЗначения.Value);
			Иначе
				Значение = XMLЗначение(Тип, ДанныеЗначения.Value);
			КонецЕсли;
			
		КонецЕсли;
		
		Если ДанныеЗначения.Свойство("Type") 
				И ДанныеЗначения.Type = "TypeDescription" Тогда
				
			Результат = Новый ОписаниеТипов(ДанныеЗначения.Types);
			
		Иначе
			
			Результат = ОписаниеТипов.ПривестиЗначение(Значение);
			
		КонецЕсли;
		
	Исключение
		
		Результат = Неопределено;
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция ЧтениеМоментаВремени(Данные)
	
	Если Данные.Свойство("Date") Тогда 
		
		Результат = XMLЗначение(Тип("Дата"), Данные.Date);
	Иначе
		
		Результат = ИТК_ОбщийКлиентСервер.ПустаяДата();
		
	КонецЕсли;
	
	Ссылка = Неопределено;
	Если Данные.Свойство("ValueRef") Тогда
		
		Ссылка = XMLЗначение(Тип(Данные.TypeRef), Данные.ValueRef);
		
	КонецЕсли;
	
	Возврат Новый МоментВремени(Результат, Ссылка);
	
КонецФункции

Функция ДвоичныеДанныеXML(Данные)
	
	ПотокЗаписи = Новый ПотокВПамяти;
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.ОткрытьПоток(ПотокЗаписи);
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("Data"); // <Data>
	
	ЗаписатьПолеВXML(ЗаписьXML, "Version", ИТК_ОбщийКлиентСервер.MCRПоддерживаемаяВерсия());
	ЗаписатьПолеВXML(ЗаписьXML, "Comment", ИТК_ТуллкитКлиентСервер.ПолноеПредставление());
	ЗаписатьДанныеВXML(ЗаписьXML, Данные);
	
	ЗаписьXML.ЗаписатьКонецЭлемента(); // </Data>
	ЗаписьXML.Закрыть();
	
	Возврат ПотокЗаписи.ЗакрытьИПолучитьДвоичныеДанные();
	
КонецФункции

Процедура ЗаписатьДанныеВXML(ЗаписьXML, Данные)
	
	Для Каждого ЭлементДанных Из Данные Цикл
		
		ЗаписьXML.ЗаписатьНачалоЭлемента(ЗначениеTypeВXML(ЭлементДанных.Type));
		
		Для Каждого ПолеДанных Из ЭлементДанных Цикл
			
			ИмяПоля = ПолеДанных.Ключ;
			ЗначениеПоля = ПолеДанных.Значение;
			
			Если ИмяПоля = "Elements" Тогда
				
				ЗаписатьДанныеВXML(ЗаписьXML, ЭлементДанных.Elements);
				
			ИначеЕсли ИмяПоля = "Type" Тогда
				
				Продолжить;
				
			ИначеЕсли ИмяПоля = "Parameters" Тогда
				
				Если ЗначениеЗаполнено(ЗначениеПоля) Тогда
					
					ЗаписьXML.ЗаписатьНачалоЭлемента("Parameters"); // <Parameters>
					
					Для Каждого Параметр Из ЗначениеПоля Цикл 
						
						ЗаписатьПараметрЗапросаВXML(ЗаписьXML, Параметр.Ключ, Параметр.Значение);
						
					КонецЦикла;
					
					ЗаписьXML.ЗаписатьКонецЭлемента(); // </Parameters>
					
				КонецЕсли;
				
			ИначеЕсли ИмяПоля = "ExternalSources" Тогда
				
				Если ЗначениеЗаполнено(ЗначениеПоля) Тогда
					
					ЗаписьXML.ЗаписатьНачалоЭлемента("ExternalSources"); // <ExternalSources>
					
					Для Каждого ВнешнийИсточник Из ЗначениеПоля Цикл 
						ЗаписатьВнешнийИсточникВXML(ЗаписьXML, ВнешнийИсточник.Значение);
					КонецЦикла;
					
					ЗаписьXML.ЗаписатьКонецЭлемента(); // </ExternalSources>
					
				КонецЕсли;
				
			ИначеЕсли ИмяПоля = "TTMTables" Тогда
				
				Если ЗначениеЗаполнено(ЗначениеПоля) Тогда
					
					ЗаписьXML.ЗаписатьНачалоЭлемента("TTMTables"); // <TTMTables>
					
					Для Каждого ТаблицаМВТ Из ЗначениеПоля Цикл 
						ЗаписатьТаблицуМВТВXML(ЗаписьXML, ТаблицаМВТ.Значение);
					КонецЦикла;
					
					ЗаписьXML.ЗаписатьКонецЭлемента(); // </TTMTables>
					
				КонецЕсли;
				
			ИначеЕсли ИмяПоля = "ProcessingAlgorithms" Тогда
				
				Если ЗначениеЗаполнено(ЗначениеПоля) Тогда
					
					ЗаписьXML.ЗаписатьНачалоЭлемента("ProcessingAlgorithms"); // <ProcessingAlgorithms>
					
					Для Каждого АлгоритмОбработки Из ЗначениеПоля Цикл 
						ЗаписатьАлгоритмОбработкиВXML(ЗаписьXML, АлгоритмОбработки);
					КонецЦикла;
					
					ЗаписьXML.ЗаписатьКонецЭлемента(); // </ProcessingAlgorithms>
					
				КонецЕсли;
				
			ИначеЕсли ИмяПоля = "SettingsOutputTables" Тогда
				
				Если ЗначениеЗаполнено(ЗначениеПоля) Тогда
					
					ЗаписьXML.ЗаписатьНачалоЭлемента("SettingsOutputTables"); // <SettingsOutputTables>
					
					Для Каждого НастройкаВыводаТаблицыПакета Из ЗначениеПоля Цикл 
						ЗаписатьНастройкуВыводаТаблицыПакетаВXML(ЗаписьXML, НастройкаВыводаТаблицыПакета);
					КонецЦикла;
					
					ЗаписьXML.ЗаписатьКонецЭлемента(); // </SettingsOutputTables>
					
				КонецЕсли;
				
			ИначеЕсли ИмяПоля = "Text" И ЭлементДанных.Type = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных() Тогда
				
				Продолжить;
				
			Иначе
				
				ЗначениеПоУмолчанию = ИТК_MCRФорматПовтИсп.ЗначениеПоляДанныхПоУмолчанию(ИмяПоля);
				ЗаписатьПолеВXML(ЗаписьXML, ИмяПоля, ЗначениеПоля, ЗначениеПоУмолчанию);
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если ЭлементДанных.Type = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных() Тогда
			ЗаписатьЭлементТекст(ЗаписьXML, "Text", ЭлементДанных.Text);
		КонецЕсли;
		
		ЗаписьXML.ЗаписатьКонецЭлемента(); 
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьПараметрЗапросаВXML(ЗаписьXML, Имя, Значение)
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("Parameter"); // <Parameter>
	ЗаписатьПолеВXML(ЗаписьXML, "Name", Имя);
	
	Если ТипЗнч(Значение) = Тип("Структура") Тогда
		
		Если Значение.Вид = ИТК_Перечисления.СложныйПараметрЗапросаВыражение() Тогда
			
			ЗаписатьПолеВXML(ЗаписьXML, "Type", "Expression");
			ЗаписатьПолеВXML(ЗаписьXML, "Value", Значение.Значение);
			
		ИначеЕсли Значение.Вид = ИТК_Перечисления.СложныйПараметрЗапросаТаблицаЗначений() Тогда
			
			ЗаписатьПолеВXML(ЗаписьXML, "Type", "Table");
			ТаблицаЗначений = ПолучитьИзВременногоХранилища(Значение.Значение);
			ЗаписатьТаблицуЗначенийВXML(ЗаписьXML, ТаблицаЗначений);
			
		ИначеЕсли Значение.Вид = ИТК_Перечисления.СложныйПараметрЗапросаГраница() Тогда
			
			ЗаписатьПолеВXML(ЗаписьXML, "Type", "Boundary");
			ЗаписатьГраницуВXML(ЗаписьXML, ИТК_Запрос.ГраницаИзОписания(Значение.Значение));
			
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(Значение) = Тип("ТаблицаЗначений") Тогда
		
		ЗаписатьПолеВXML(ЗаписьXML, "Type", "Table");
		ЗаписатьТаблицуЗначенийВXML(ЗаписьXML, Значение);
		
	ИначеЕсли ТипЗнч(Значение) = Тип("СписокЗначений")
		ИЛИ ТипЗнч(Значение) = Тип("Массив")
		ИЛИ ТипЗнч(Значение) = Тип("ФиксированныйМассив") Тогда
		
		ЗаписатьПолеВXML(ЗаписьXML, "Type", "ValueList");	
		
		Для Каждого ЭлементСписка Из Значение Цикл
			
			Если ТипЗнч(Значение) = Тип("СписокЗначений") Тогда
				
				ЗначениеЭлементаСписка	= ЭлементСписка.Значение;
				
			ИначеЕсли ТипЗнч(Значение) = Тип("Массив")
					ИЛИ ТипЗнч(Значение) = Тип("ФиксированныйМассив") Тогда
					
				ЗначениеЭлементаСписка	= ЭлементСписка;
					
			КонецЕсли;
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("Item"); // <Item>
			ЗаписатьЗначениеВXML(ЗаписьXML, ЗначениеЭлементаСписка);
			ЗаписьXML.ЗаписатьКонецЭлемента(); // </Item>
			
		КонецЦикла;
		
	Иначе
		
		ЗаписатьЗначениеВXML(ЗаписьXML, Значение);
		
	КонецЕсли;
	
	ЗаписьXML.ЗаписатьКонецЭлемента(); // </Parameter>
	
КонецПроцедуры

Процедура ЗаписатьВнешнийИсточникВXML(ЗаписьXML, ОписаниеВнешнегоИсточника)
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("ExternalSource"); // <ExternalSource>
	
	ЗаписатьПолеВXML(ЗаписьXML, "Name", ОписаниеВнешнегоИсточника.Имя);
	
	Если ОписаниеВнешнегоИсточника.Тип = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаВыражение() Тогда
		
		ЗаписатьПолеВXML(ЗаписьXML, "Type", "Expression");
		ЗаписатьПолеВXML(ЗаписьXML, "Value", ОписаниеВнешнегоИсточника.Значение);
		
	ИначеЕсли ОписаниеВнешнегоИсточника.Тип = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаЗначение() Тогда
		
		Если ТипЗнч(ОписаниеВнешнегоИсточника.Значение) = Тип("ТаблицаЗначений") Тогда
			ТаблицаЗначений = ОписаниеВнешнегоИсточника.Значение;
		Иначе 
			Если ЭтоАдресВременногоХранилища(ОписаниеВнешнегоИсточника.Значение) Тогда
				ТаблицаЗначений = ПолучитьИзВременногоХранилища(ОписаниеВнешнегоИсточника.Значение);
			Иначе
				ТаблицаЗначений = Новый ТаблицаЗначений;
			КонецЕсли;
		КонецЕсли;
		
		ЗаписатьТаблицуЗначенийВXML(ЗаписьXML, ТаблицаЗначений);
		
	КонецЕсли;
	
	ЗаписьXML.ЗаписатьКонецЭлемента(); // </ExternalSource>
	
КонецПроцедуры

Процедура ЗаписатьТаблицуМВТВXML(ЗаписьXML, ОписаниеТаблицыМВТ)
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("TTMTable"); // <TTMTable>
	
	ЗаписатьПолеВXML(ЗаписьXML, "Name", ОписаниеТаблицыМВТ.Имя);
	
	Если ОписаниеТаблицыМВТ.Тип = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаВыражение() Тогда
		
		ЗаписатьПолеВXML(ЗаписьXML, "Type", "Expression");
		ЗаписатьПолеВXML(ЗаписьXML, "Value", ОписаниеТаблицыМВТ.Значение);
		
	ИначеЕсли ОписаниеТаблицыМВТ.Тип = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаЗначение() Тогда
		
		Если ТипЗнч(ОписаниеТаблицыМВТ.Значение) = Тип("ТаблицаЗначений") Тогда
			ТаблицаЗначений = ОписаниеТаблицыМВТ.Значение;
		Иначе 
			Если ЭтоАдресВременногоХранилища(ОписаниеТаблицыМВТ.Значение) Тогда
				ТаблицаЗначений = ПолучитьИзВременногоХранилища(ОписаниеТаблицыМВТ.Значение);
			Иначе
				ТаблицаЗначений = Новый ТаблицаЗначений;
			КонецЕсли;
		КонецЕсли;
		
		ЗаписатьТаблицуЗначенийВXML(ЗаписьXML, ТаблицаЗначений);
		
	КонецЕсли;
	
	ЗаписьXML.ЗаписатьКонецЭлемента(); // </TTMTable>
	
КонецПроцедуры

Процедура ЗаписатьАлгоритмОбработкиВXML(ЗаписьXML, АлгоритмОбработки)
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("ProcessingAlgorithm"); // <ProcessingAlgorithm>
	
	ОписаниеАлгоритмаОбработки = АлгоритмОбработки.Значение;
	ЗаписатьПолеВXML(ЗаписьXML, "Presentation", АлгоритмОбработки.Представление);
	
	Если ОписаниеАлгоритмаОбработки.ПрерыватьПриОшибке Тогда
		
		ЗаписатьПолеВXML(ЗаписьXML, "AbortOnError", Истина);
		
	КонецЕсли;
	
	Если ОписаниеАлгоритмаОбработки.Транзакция <> ИТК_MCRФорматКлиентСервер.ТипТранзакцииОбработкиРезультатаПоУмолчанию() Тогда
		
		Транзакция = ИТК_MCRФорматПовтИсп.ПреобразованиеПеречисленияТипТранзакцииОбработкиРезультата(ОписаниеАлгоритмаОбработки.Транзакция);
		ЗаписатьПолеВXML(ЗаписьXML, "Transaction", Транзакция);
		
	КонецЕсли;
	
	ЗаписатьЭлементТекст(ЗаписьXML, "Code", ОписаниеАлгоритмаОбработки.Код);
	ЗаписатьЭлементТекст(ЗаписьXML, "CodeBefore", ОписаниеАлгоритмаОбработки.КодПеред);
	ЗаписатьЭлементТекст(ЗаписьXML, "CodeAfter", ОписаниеАлгоритмаОбработки.КодПосле);
	
	ЗаписьXML.ЗаписатьКонецЭлемента(); // </ProcessingAlgorithm>
	
КонецПроцедуры

Процедура ЗаписатьНастройкуВыводаТаблицыПакетаВXML(ЗаписьXML, НастройкаВыводаТаблицы)
	
	ОписаниеНастройкиВыводаТаблицы = НастройкаВыводаТаблицы.Значение;
	
	Если ОписаниеНастройкиВыводаТаблицы.Вывод = ИТК_MCRФорматКлиентСервер.ВыводТаблицыЗначениеПоУмолчанию() Тогда
		Возврат;
	КонецЕсли;
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("Table"); // <Table>
	
	ЗаписатьПолеВXML(ЗаписьXML, "Name", НастройкаВыводаТаблицы.Ключ);
	ЗаписатьПолеВXML(ЗаписьXML, "Output", ВыводТаблицыXML(ОписаниеНастройкиВыводаТаблицы.Вывод));

	ЗаписьXML.ЗаписатьКонецЭлемента(); // </Table>
	
КонецПроцедуры

Процедура ЗаписатьПолеВXML(ЗаписьXML, Имя, Значение, ЗначениеПоУмолчанию = Неопределено)
	
	// Значение по умолчанию и пустые значения не записываем
	Если Значение = ЗначениеПоУмолчанию
			ИЛИ (ЗначениеПоУмолчанию = Неопределено И Не ЗначениеЗаполнено(Значение)) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	XMLСтрока = XMLСтрока(Значение);
	
	Если ЗначениеЗаполнено(XMLСтрока) Тогда
		
		// Многострочный текст записываем как элемент (нельзя записывать как атрибут)
		Если ИТК_Строки.МногострочнаяСтрока(XMLСтрока) Тогда 
			
			ЗаписатьЭлементТекст(ЗаписьXML, Имя, XMLСтрока);
			
		Иначе
			
			ЗаписьXML.ЗаписатьАтрибут(Имя, XMLСтрока);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаписатьТаблицуЗначенийВXML(ЗаписьXML, ТаблицаЗначений)
	
	Если ТаблицаЗначений.Колонки.Количество() > 0 Тогда
		
		ДвоичныеДанные = ПолучитьДвоичныеДанныеИзСтроки(ЗначениеВСтрокуВнутр(ТаблицаЗначений));
		ЗаписатьЗначениеВXML(ЗаписьXML, Base64Строка(ДвоичныеДанные), Ложь);
		
	КонецЕсли;
	
КонецПроцедуры	

Процедура ЗаписатьОписаниеТиповВXML(ЗаписьXML, ОписаниеТипа)
	
	ЗаписатьПолеВXML(ЗаписьXML, "Types", ИТК_XML.СписокИменТипов(ОписаниеТипа));
	
	Если ОписаниеТипа.СодержитТип(Тип("Число")) Тогда
		
		КвалификаторыЧисла = ОписаниеТипа.КвалификаторыЧисла;
		
		ЗаписатьПолеВXML(ЗаписьXML, "Digits", КвалификаторыЧисла.Разрядность);
		ЗаписатьПолеВXML(ЗаписьXML, "FractionDigits", КвалификаторыЧисла.РазрядностьДробнойЧасти);
		ЗаписатьПолеВXML(ЗаписьXML, "AllowedSign", КвалификаторыЧисла.ДопустимыйЗнак, ДопустимыйЗнак.Любой);
		
	КонецЕсли;
	
	Если ОписаниеТипа.СодержитТип(Тип("Строка")) Тогда
		
		КвалификаторыСтроки = ОписаниеТипа.КвалификаторыСтроки;
		
		ЗаписатьПолеВXML(ЗаписьXML, "Length", КвалификаторыСтроки.Длина);
		ЗаписатьПолеВXML(ЗаписьXML, "AllowedLength", КвалификаторыСтроки.ДопустимаяДлина, ДопустимаяДлина.Переменная);
		
	КонецЕсли;
	
	Если ОписаниеТипа.СодержитТип(Тип("Дата")) Тогда
		
		КвалификаторыДаты = ОписаниеТипа.КвалификаторыДаты;
		ЗаписатьПолеВXML(ЗаписьXML, "DateFractions", КвалификаторыДаты.ЧастиДаты, ЧастиДаты.ДатаВремя);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаписатьЗначениеВXML(ЗаписьXML, Значение, ЗаписыватьТип = Истина)
	
	ТипЗначения = ТипЗнч(Значение);
	Если ТипЗначения = Тип("Тип") Тогда
		
		ИмяТипа = "Type";
		
	Иначе
		
		ИмяТипа = ИТК_XML.ИмяТипа(Значение);
		
	КонецЕсли;
	
	Если ЗаписыватьТип Тогда
		
		ЗаписатьПолеВXML(ЗаписьXML, "Type", ИмяТипа);
		
	КонецЕсли;
	
	Если ТипЗначения = Тип("МоментВремени") Тогда
		
		ЗаписатьМоментВремениВXML(ЗаписьXML, Значение);
		
	ИначеЕсли ТипЗначения = Тип("ОписаниеТипов") Тогда
		
		ЗаписатьОписаниеТиповВXML(ЗаписьXML, Значение);
		
	ИначеЕсли ТипЗначения = Тип("Тип") Тогда
		
		ЗаписатьПолеВXML(ЗаписьXML, "Value", ИТК_XML.ИмяТипа(Значение));
		
	Иначе
		
		ЗаписатьПолеВXML(ЗаписьXML, "Value", Значение);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаписатьМоментВремениВXML(ЗаписьXML, Значение)
	
	ЗаписатьПолеВXML(ЗаписьXML, "Date", Значение.Дата);
	
	Ссылка = Значение.Ссылка;
	Если Ссылка <> Неопределено Тогда
		ЗаписатьПолеВXML(ЗаписьXML, "TypeRef", ИТК_XML.ИмяТипа(Ссылка));
		ЗаписатьПолеВXML(ЗаписьXML, "ValueRef", Ссылка);
	КонецЕсли;
	
КонецПроцедуры	

Процедура ЗаписатьГраницуВXML(ЗаписьXML, Граница)
	
	Если Граница.ВидГраницы = ВидГраницы.Исключая Тогда
		ЗаписатьПолеВXML(ЗаписьXML, "BoundaryType", "Excluding");
	КонецЕсли;
	
	Если Граница.Значение = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗаписатьПолеВXML(ЗаписьXML, "ValueType", ИТК_XML.ИмяТипа(Граница.Значение));
	Если ТипЗнч(Граница.Значение) = Тип("МоментВремени") Тогда
		ЗаписатьМоментВремениВXML(ЗаписьXML, Граница.Значение);
	Иначе
		ЗаписатьПолеВXML(ЗаписьXML, "Value", Граница.Значение);
	КонецЕсли;
	
КонецПроцедуры	

Процедура ЗаписатьЭлементТекст(ЗаписьXML, Имя, Текст)
	
	Если ЗначениеЗаполнено(Текст) Тогда
	
		ЗаписьXML.ЗаписатьНачалоЭлемента(Имя);
		ЗаписьXML.ЗаписатьТекст(Текст);
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПрочитатьЭлемент(СтрокаДерева, ДанныеЭлемента = Неопределено)
	
	Данные = Новый Массив;
	
	Для Каждого Строка Из СтрокаДерева.Строки Цикл 
		
		Если Строка.Имя = "Parameters" Тогда
			
			ДанныеЭлемента.Вставить("Parameters", ЧтениеПараметровЗапроса(Строка));
			
		ИначеЕсли Строка.Имя = "TemporaryTables"
			ИЛИ Строка.Имя = "ExternalSources" Тогда
			
			ДанныеЭлемента.Вставить("ExternalSources", ЧтениеВнешнихИсточников(Строка));
			
		ИначеЕсли Строка.Имя = "TTMTables" Тогда
			
			ДанныеЭлемента.Вставить("TTMTables", ЧтениеТаблицМВТ(Строка));
			
		ИначеЕсли Строка.Имя = "ProcessingAlgorithms" Тогда
			
			ДанныеЭлемента.Вставить("ProcessingAlgorithms", ЧтениеАлгоритмовОбработки(Строка));
			
		ИначеЕсли Строка.Имя = "OutputTemporaryTables"
					ИЛИ Строка.Имя = "SettingsOutputTables" Тогда
			
			ДанныеЭлемента.Вставить("SettingsOutputTables", ЧтениеНастроекВыводаПакета(Строка));
			
		Иначе
			
			ДанныеНовогоЭлемента = Новый Структура;
			ДанныеНовогоЭлемента.Вставить("Type", Строка(Строка.Имя));
			ДанныеНовогоЭлемента.Вставить("Name", "");
			ДанныеНовогоЭлемента.Вставить("Text", "");
			
			Если ТипЗнч(Строка.Значение) = Тип("Структура") Тогда
				
				Для Каждого Поле Из Строка.Значение Цикл 
					
					ТипПоля = ИТК_MCRФорматПовтИсп.ТипЗначенияПоляДанных(Поле.Ключ);
					ДанныеНовогоЭлемента.Вставить(Поле.Ключ, XMLЗначение(ТипПоля, Поле.Значение));
					
				КонецЦикла;
				
			КонецЕсли;
			
			ДанныеНовогоЭлемента.Вставить("Elements", ПрочитатьЭлемент(Строка, ДанныеНовогоЭлемента));
			
			Данные.Добавить(ДанныеНовогоЭлемента);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Данные;
	
КонецФункции

Функция ЗначениеВыводТаблицы(Строка)
	
	Если Строка = "No" Тогда
		
		Результат = ИТК_Перечисления.ВидВыводаТаблицыНеВыводить();
		
	ИначеЕсли Строка = "Minimized" Тогда
		
		Результат = ИТК_Перечисления.ВидВыводаТаблицыСвернуто();
		
	Иначе
		
		Результат = ИТК_MCRФорматКлиентСервер.ВыводТаблицыЗначениеПоУмолчанию();
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ВыводТаблицыXML(Вывод)
	
	Если Вывод = ИТК_Перечисления.ВидВыводаТаблицыНеВыводить() Тогда
		
		Результат = "No";
		
	ИначеЕсли Вывод = ИТК_Перечисления.ВидВыводаТаблицыСвернуто() Тогда
		
		Результат = "Minimized";
		
	Иначе
		
		Результат = "";
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
