Функция НовыеДанныеСтрокиДереваДанных(Тип, Сохранение = Ложь) Экспорт
	
	Результат = Новый Структура;

	Если Сохранение Тогда
		
		Результат.Вставить("Представление", Неопределено);
		Результат.Вставить("Выделение", Ложь);
		Результат.Вставить("Тип", Тип);
		Результат.Вставить("Развернуто", Ложь);
		
	Иначе
		
		Результат.Вставить("Страница", Неопределено);
		
	КонецЕсли;
	
	Если Тип = ИТК_Перечисления.ЭлементДанныхКод() Тогда
		
		Результат.Вставить("Контекст", ИТК_КонсольКодаКлиентСервер.КонтекстСервер());
		Результат.Вставить("Параметры", Новый Структура);
		Результат.Вставить("СостояниеОтладчика", Неопределено);
		
		Если Не Сохранение Тогда
			
			Результат.Вставить("ВремяВыполнения", Неопределено);
			Результат.Вставить("Ошибка", Неопределено);
			Результат.Вставить("Страница", "Код");
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЭтоТипСтрокиДереваДанныхСИспользованиемТекста(Тип) Тогда
		
		Результат.Вставить("Текст", "");
		
		Если НЕ Сохранение Тогда
			
			Результат.Вставить("Закладки", Новый Массив);
			Результат.Вставить("СостояниеРедактора", Неопределено);
			
			ГраницыВыделения = ИТК_РедакторКодаКлиентСервер.ПустойГраницыВыделения();
			Результат.Вставить("ГраницыВыделенияТекста", ГраницыВыделения);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЭтоТипСтрокиДереваДанныхСИспользованиемОригинальногоТекста(Тип) Тогда
		
		Если НЕ Сохранение Тогда
			Результат.Вставить("ОригинальныйТекст", "");
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ДанныеМодифицированы(Форма, АвтоСохранение = Истина) Экспорт
	
	УстановитьМодифицированностьДанных(Форма, Истина, АвтоСохранение);
	
КонецПроцедуры

Процедура СброситьМодифицированностьДанных(Форма, АвтоСохранение = Истина) Экспорт
	
	УстановитьМодифицированностьДанных(Форма, Ложь, АвтоСохранение);
	
КонецПроцедуры

Процедура УстановитьМодифицированностьДанных(Форма, Модифицированность = Истина, АвтоСохранение = Истина) Экспорт
	
	Форма.Модифицированность = Модифицированность;
	
	Если АвтоСохранение Тогда
		Форма["МодифицированностьАвтоСохранение"] = Модифицированность;
	КонецЕсли;
	
КонецПроцедуры

Процедура СброситьОригинальныйТекстДанныхДереваДанных(Данные) Экспорт
	
	Данные["ОригинальныйТекст"] = Данные["Текст"];
	
КонецПроцедуры

Функция РаботаСДаннымиДанныеСтроки(Строка) Экспорт
	
	Если Строка = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат Строка.Данные;
	
КонецФункции

Функция КартинкаСтрокиДереваДанных(Тип) Экспорт
	
	СоответствиеЭлементДанныхКартинка = ИТК_КонсолиКлиентСерверПовтИсп.СоответствиеЭлементДанныхКартинка();
	Возврат СоответствиеЭлементДанныхКартинка.Получить(Тип);
	
КонецФункции

Процедура ЗаполнениеСтрокиДереваДанных(Строка, Тип, Представление, ДополнительныеПараметры) Экспорт
	
	Строка.Тип = Тип;
	Строка.Представление = Представление;
	Строка.Развернуто = Истина;
	
	УникальныйИдентификатор = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "УникальныйИдентификатор", Новый УникальныйИдентификатор);
	Строка.УникальныйИдентификатор = УникальныйИдентификатор;
	
	Строка.Картинка = КартинкаСтрокиДереваДанных(Тип);
	
	НачальныеДанные = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "НачальныеДанные");
	Если НачальныеДанные = Неопределено Тогда
		НачальныеДанные = НовыеДанныеСтрокиДереваДанных(Тип);
	КонецЕсли;
	
	Строка.Данные = НачальныеДанные;
	
КонецПроцедуры

