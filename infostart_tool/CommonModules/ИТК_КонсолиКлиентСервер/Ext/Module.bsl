	ИначеЕсли Инструмент = ИТК_Перечисления.ИнструментКонсольСхемКомпоновкиДанных() Тогда
		Результат = НСтр("ru = 'Схема компоновки данных'; en = 'Data composition schema'");
	ИначеЕсли Инструмент = ИТК_Перечисления.ИнструментКонсольСхемКомпоновкиДанных() Тогда
		Результат = НСтр("ru = 'Запрос'; en = 'Query'");
	Иначе
		Результат = Неопределено;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает строку фильтра для диалога выбора файла
//
// Параметры:
//   ВключатьИмпортируемыеФорматы - Булево - Включать импортируемые форматы
//
// Возвращаемое значение:
//   Строку - Фильтр для диалога выбора файла
//
Функция ФильтрФайловДанных(Инструмент, ВключатьИмпортируемыеФорматы = Ложь) Экспорт
	
	ПоддерживаемыеФорматы = Новый СписокЗначений;
	
	ОсновноеРасширение = ОсновноеРасширениеФайловДанных(Инструмент);
	ПоддерживаемыеФорматы.Добавить(СтрШаблон("*.%1", ОсновноеРасширение), НСтр("ru = 'Файлы данных';
																				|en = 'Data files'"));
	//Если ВключатьИмпортируемыеФорматы Тогда
	//	ПоддерживаемыеФорматы.Добавить("*.q1c", НСтр("ru = 'Файлы запросов от 1С';
	//												|en = 'Query files from 1C'"));
	//	ПоддерживаемыеФорматы.Добавить("*.dcr", НСтр("ru = 'Файлы СКД от 1С';
	//												|en = 'DCS files from 1C'"));
	//	ПоддерживаемыеФорматы.Добавить("*.erf", НСтр("ru = 'Файлы внешних отчетов (СКД)';
	//												|en = 'External report files (DCS)'"));
	//КонецЕсли;
	
	Возврат ФильтрФайлов(ПоддерживаемыеФорматы);
	
КонецФункции

