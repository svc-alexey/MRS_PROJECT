КонецПроцедуры

Функция КартинкаКнопкиСохранить(Форма) Экспорт
	
	РабочиеДанные = Форма["РабочиеДанные"];
	Если РабочиеДанные.Тип = Неопределено Тогда
		
		ИмяНастройкиСохранятьДанныеПоУмолчаниюВ = ИТК_НастройкиКлиентСерверПовтИсп.ИмяНастройкиСохранятьДанныеПоУмолчаниюВ();
		СохранятьДанныеПоУмолчаниюВ = ИТК_Настройки.Значение(ИТК_Перечисления.ГруппаИнструментовКонсоли(), ИмяНастройкиСохранятьДанныеПоУмолчаниюВ);
		
	Иначе
		СохранятьДанныеПоУмолчаниюВ = РабочиеДанные.Тип;
	КонецЕсли;
	
	ИмяКартинки = "Записать";
	Если СохранятьДанныеПоУмолчаниюВ = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда
		ИмяКартинки = "ИТК_ЗаписатьВНастройки";
	КонецЕсли;
	
	Возврат ИТК_ОбщийКлиентСерверПовтИсп.БиблиотекаКартинок(ИмяКартинки);
	
КонецФункции

