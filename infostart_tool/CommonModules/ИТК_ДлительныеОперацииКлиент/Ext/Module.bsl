#Область ПрограммныйИнтерфейс

Процедура НачатьОперацию(Форма, Оповещение, ОписаниеОперации = Неопределено) Экспорт
	
	ВыполнитьОбработкуОповещения(Оповещение, ОписаниеОперации);
	ОтменитьОперацию(Форма);
	
КонецПроцедуры

Процедура СкрытьПрогресс(Форма) Экспорт
	
	Элементы = Форма.Элементы;
	ИмяГруппы = "ГруппаПрогрессДлительнойОперации";
	Если Элементы.Найти(ИмяГруппы) = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Элементы[ИмяГруппы].Видимость = Ложь;
	
КонецПроцедуры

Процедура ПоказатьПрогресс(Форма, ВозможностьОтменить = Истина) Экспорт
	
	Элементы = Форма.Элементы;
	Элементы.ГруппаПрогрессДлительнойОперации.Видимость = Истина;
	Элементы.ОтменитьДлительнуюОперацию.Видимость = ВозможностьОтменить;
	
	Имя = "ГруппаИнформацияОПоследнейОбработке";
	Если Элементы.Найти(Имя) <> Неопределено Тогда
		Элементы[Имя].Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОтменитьОперацию(Форма, ОписаниеОперации = Неопределено) Экспорт
	
	ЗаполнитьОписаниеОперацииПоУмолчанию(Форма, ОписаниеОперации);
	ИТК_ДлительныеОперации.Отменить(ОписаниеОперации);
	
	СкрытьПрогресс(Форма);
	
КонецПроцедуры

Процедура ЗаполнитьОписаниеОперации(ДлительнаяОперация, ОписаниеОперации) Экспорт
	
	Для Каждого ЭлементОписанияОперации Из ОписаниеОперации Цикл 
		ДлительнаяОперация.Вставить(ЭлементОписанияОперации.Ключ, ЭлементОписанияОперации.Значение);
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьОповещениеПользователя(Форма, ПараметрыОжидания, ОписаниеОперации = Неопределено) Экспорт 
	
	Если НЕ ИТК_НастройкиКлиент.ЗначениеОбщейНастройки(Форма, "УведомлениеОЗавершенииДлительныхОпераций") Тогда
		Возврат;
	КонецЕсли;
		
	Если ИТК_БСПКлиентСервер.ИспользуетсяБСП()
			И ИТК_БСПКлиентСерверПовтИсп.АнглийскаяБСП() Тогда
			
		ПолеОповещениеПользователя = "UserNotification"; 
		ПолеПоказатьОповещениеПользователя = "Show"; 
		ПолеТекстОповещениеПользователя = "Text"; 
		ПолеПояснениеОповещениеПользователя = "Explanation"; 
		ПолеНавигационнаяСсылкаОповещенияПользователя = "URL"; 
		
	Иначе
		
		ПолеОповещениеПользователя = "ОповещениеПользователя"; 
		ПолеПоказатьОповещениеПользователя = "Показать"; 
		ПолеТекстОповещениеПользователя = "Текст"; 
		ПолеПояснениеОповещениеПользователя = "Пояснение"; 
		ПолеНавигационнаяСсылкаОповещенияПользователя = "НавигационнаяСсылка"; 
		
	КонецЕсли;
	
	ОповещениеПользователя = ПараметрыОжидания[ПолеОповещениеПользователя];
	ОповещениеПользователя[ПолеПоказатьОповещениеПользователя] = Истина;
	
	НавигационнаяСсылка = Неопределено;
	Окно = Форма.Окно;
	Если Окно <> Неопределено Тогда
		НавигационнаяСсылка = Окно.ПолучитьНавигационнуюСсылку();
	КонецЕсли;
	ОповещениеПользователя[ПолеНавигационнаяСсылкаОповещенияПользователя] = НавигационнаяСсылка;
	
	ЗаполнитьОписаниеОперацииПоУмолчанию(Форма, ОписаниеОперации);
	
	ОповещениеПользователя[ПолеТекстОповещениеПользователя] = ИТК_Перечисления.Представление(ОписаниеОперации.Источник);
	ОповещениеПользователя[ПолеПояснениеОповещениеПользователя] = СтрШаблон(НСтр("ru = 'Завершен(а): %1';
																				|en = 'Completed: %1'"), ОписаниеОперации.Наименование);
	
КонецПроцедуры

Процедура СледующийШагИнтервалаОжидания(Интервал) Экспорт
	
	ПараметрыОжидания = Неопределено;
	ИнициализироватьПараметрыОбработчикаОжидания(ПараметрыОжидания);
	
	Интервал = Мин(Интервал * ПараметрыОжидания.КоэффициентУвеличенияИнтервала, ПараметрыОжидания.МаксимальныйИнтервал);
	
КонецПроцедуры

Процедура ИнициализироватьПараметрыОбработчикаОжидания(ПараметрыОбработчикаОжидания) Экспорт
	
	Если ИТК_БСПКлиентСервер.ИспользуетсяБСП() Тогда
		
		ПараметрыПроцедуры = Новый Массив;
		ПараметрыПроцедуры.Добавить(ПараметрыОбработчикаОжидания);
		
		ИТК_БСПКлиентСервер.ВыполнитьПроцедуру("ДлительныеОперацииКлиент.ИнициализироватьПараметрыОбработчикаОжидания", ПараметрыПроцедуры);
		ПараметрыОбработчикаОжидания = ПараметрыПроцедуры[0];
		
		Возврат;
		
	КонецЕсли;
		
	// Скопировано содержимое функции ДлительныеОперацииКлиент.ИнициализироватьПараметрыОбработчикаОжидания
	ПараметрыОбработчикаОжидания = Новый Структура;
	ПараметрыОбработчикаОжидания.Вставить("МинимальныйИнтервал", 1);
	ПараметрыОбработчикаОжидания.Вставить("МаксимальныйИнтервал", 15);
	ПараметрыОбработчикаОжидания.Вставить("ТекущийИнтервал", 1);
	ПараметрыОбработчикаОжидания.Вставить("КоэффициентУвеличенияИнтервала", 1.4);
	
КонецПроцедуры

Функция ПараметрыОжидания(ФормаВладелец, ОповещениеОПрогрессеВыполнения = Неопределено) Экспорт
	
	ОтслеживаетсяПрогрессВыполнения = (ОповещениеОПрогрессеВыполнения <> Неопределено);
	Если ИТК_БСПКлиентСервер.ИспользуетсяБСП() Тогда
		
		ПараметрыФункции = Новый Массив;
		ПараметрыФункции.Добавить(ФормаВладелец);
		
		Результат = ИТК_БСПКлиентСервер.ВыполнитьФункцию("ДлительныеОперацииКлиент.ПараметрыОжидания", ПараметрыФункции);
		
		Если ИТК_БСПКлиентСерверПовтИсп.АнглийскаяБСП() Тогда
			
			ПолеВыводитьОкноОжидания = "OutputIdleWindow";
			ПолеВыводитьПрогрессВыполнения = "OutputProgressBar";
			ПолеВыводитьСообщения = "OutputMessages";
			ПолеОповещениеОПрогрессеВыполнения = "ExecutionProgressNotification";
			
		Иначе
			
			ПолеВыводитьОкноОжидания = "ВыводитьОкноОжидания";
			ПолеВыводитьПрогрессВыполнения = "ВыводитьПрогрессВыполнения";
			ПолеВыводитьСообщения = "ВыводитьСообщения";
			ПолеОповещениеОПрогрессеВыполнения = "ОповещениеОПрогрессеВыполнения";
			
		КонецЕсли;
		
		Результат[ПолеВыводитьОкноОжидания] = Ложь;
		
		Если ОтслеживаетсяПрогрессВыполнения Тогда
			
			Результат[ПолеВыводитьПрогрессВыполнения] = Истина;
			Результат[ПолеВыводитьСообщения] = Истина;
			Результат[ПолеОповещениеОПрогрессеВыполнения] = ОповещениеОПрогрессеВыполнения;
			
		КонецЕсли;
		
		Возврат Результат;
		
	КонецЕсли;
		
	// Скопировано из функции ДлительныеОперацииКлиент.ПараметрыОжидания
	// убрано много кода - работа без фонового выполнения
	Результат = Новый Структура;
	Результат.Вставить("ФормаВладелец", ФормаВладелец);
	Результат.Вставить("ТекстСообщения", "");
	Результат.Вставить("ВыводитьОкноОжидания", Ложь);
	Результат.Вставить("ВыводитьПрогрессВыполнения", Ложь);
	Результат.Вставить("ОповещениеОПрогрессеВыполнения", Неопределено);
	Результат.Вставить("ВыводитьСообщения", ОтслеживаетсяПрогрессВыполнения);
	Результат.Вставить("Интервал", 0);
	Результат.Вставить("ПолучатьРезультат", Ложь);
	
	ОповещениеПользователя = Новый Структура;
	ОповещениеПользователя.Вставить("Показать", Ложь);
	ОповещениеПользователя.Вставить("Текст", Неопределено);
	ОповещениеПользователя.Вставить("НавигационнаяСсылка", Неопределено);
	ОповещениеПользователя.Вставить("Пояснение", Неопределено);
	Результат.Вставить("ОповещениеПользователя", ОповещениеПользователя);
	
	Возврат Результат;
	
КонецФункции

// Скопировано из функции ДлительныеОперацииКлиент.ОжидатьЗавершение
Процедура ОжидатьЗавершение(Знач ДлительнаяОперация, Знач ОповещениеОЗавершении = Неопределено, Знач ПараметрыОжидания = Неопределено) Экспорт
	
	Если ИТК_БСПКлиентСервер.ИспользуетсяБСП() Тогда
		
		ПараметрыПроцедуры = Новый Массив;
		ПараметрыПроцедуры.Добавить(ДлительнаяОперация);
		ПараметрыПроцедуры.Добавить(ОповещениеОЗавершении);
		ПараметрыПроцедуры.Добавить(ПараметрыОжидания);
		
		ИТК_БСПКлиентСервер.ВыполнитьПроцедуру("ДлительныеОперацииКлиент.ОжидатьЗавершение", ПараметрыПроцедуры);
		
		Возврат;
		
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Статус", ДлительнаяОперация.Статус);
	Результат.Вставить("АдресРезультата", ДлительнаяОперация.АдресРезультата);
	Результат.Вставить("АдресДополнительногоРезультата", ДлительнаяОперация.АдресДополнительногоРезультата);
	Результат.Вставить("КраткоеПредставлениеОшибки", ДлительнаяОперация.КраткоеПредставлениеОшибки);
	Результат.Вставить("ПодробноеПредставлениеОшибки", ДлительнаяОперация.ПодробноеПредставлениеОшибки);
	
	Сообщения = Неопределено;
	Если ПараметрыОжидания.ВыводитьСообщения  Тогда
		Сообщения = ДлительнаяОперация.Сообщения;
	КонецЕсли;
	Результат.Вставить("Сообщения", Сообщения); 
	
	Если ДлительнаяОперация.Статус = "Выполнено" И ПараметрыОжидания <> Неопределено Тогда
		ПоказатьОповещение(ПараметрыОжидания);
	КонецЕсли;
	
	ВыполнитьОбработкуОповещения(ОповещениеОЗавершении, Результат);
	
КонецПроцедуры

Процедура ПодготовитьРезультатВыполнения(Результат) Экспорт 
	
	Если Результат = Неопределено
			ИЛИ НЕ ИТК_БСПКлиентСерверПовтИсп.АнглийскаяБСП() Тогда
		Возврат;
	КонецЕсли;
	
	ПереводПолей = Новый Соответствие;
	ПереводПолей.Вставить("Status", "Статус");
	ПереводПолей.Вставить("ResultAddress", "АдресРезультата");
	ПереводПолей.Вставить("DetailErrorDescription", "АдресДополнительногоРезультата");
	
	ПереводПолей.Вставить("BriefErrorDescription", "КраткоеПредставлениеОшибки");
	ПереводПолей.Вставить("BriefErrorPresentation", "КраткоеПредставлениеОшибки");
	
	ПереводПолей.Вставить("DetailErrorDescription", "ПодробноеПредставлениеОшибки");
	ПереводПолей.Вставить("DetailedErrorPresentation", "ПодробноеПредставлениеОшибки");
	ПереводПолей.Вставить("Messages", "Сообщения");
	
	ПереводПоляСтатус = Новый Соответствие;
	ПереводПоляСтатус.Вставить("Done", "Выполнено");
	ПереводПоляСтатус.Вставить("Running", "Выполняется");
	ПереводПоляСтатус.Вставить("Error", "Ошибка");
	ПереводПоляСтатус.Вставить("Canceled", "Отменено");
	
	Для Каждого ПолеПеревода Из ПереводПолей Цикл 
		
		ИмяПоля = ПолеПеревода.Ключ;
		ИмяПоляНаРусском = ПолеПеревода.Значение;
		
		Если НЕ Результат.Свойство(ИмяПоля) Тогда
			Продолжить;
		КонецЕсли;
		
		ЗначениеПоля = Результат[ИмяПоля];
		Если ИмяПоляНаРусском = "Статус" Тогда
			ЗначениеПоляНаРусском = СтатусЗадания(ЗначениеПоля);
		Иначе
			ЗначениеПоляНаРусском = ЗначениеПоля;
		КонецЕсли;
		
		Результат.Вставить(ИмяПоляНаРусском, ЗначениеПоляНаРусском);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ПодготовитьПрогрессВыполнения(Результат) Экспорт 
	
	Если Результат = Неопределено
			ИЛИ НЕ ИТК_БСПКлиентСерверПовтИсп.АнглийскаяБСП() Тогда
		Возврат;
	КонецЕсли;
	
	ПереводПолей = Новый Соответствие;
	ПереводПолей.Вставить("Status", "Статус");
	ПереводПолей.Вставить("JobID", "ИдентификаторЗадания");
	ПереводПолей.Вставить("Messages", "Сообщения");
	ПереводПолей.Вставить("Progress", "Прогресс");
	
	Для Каждого ПолеПеревода Из ПереводПолей Цикл 
		
		ИмяПоля = ПолеПеревода.Ключ;
		ИмяПоляНаРусском = ПолеПеревода.Значение;
		
		ЗначениеПоля = Результат[ИмяПоля];
		Если ИмяПоляНаРусском = "Статус" Тогда
			
			ЗначениеПоляНаРусском = СтатусЗадания(ЗначениеПоля);
			
		ИначеЕсли ИмяПоляНаРусском = "Прогресс" Тогда
			
			Если ЗначениеЗаполнено(ЗначениеПоля) Тогда
				
				ЗначениеПоляНаРусском = Новый Структура;
				ЗначениеПоляНаРусском.Вставить("Процент", ЗначениеПоля["Percent"]);
				ЗначениеПоляНаРусском.Вставить("Текст", ЗначениеПоля["Text"]);
				
			КонецЕсли;
			
		Иначе
			
			ЗначениеПоляНаРусском = ЗначениеПоля;
			
		КонецЕсли;
		
		Результат.Вставить(ИмяПоляНаРусском, ЗначениеПоляНаРусском);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбновитьЭлементыОтображенияСостояния(ОписаниеОперации, ЭлементРезультат, ЭлементСостояние, ТекстСостоянияИдетВыполнение) Экспорт
	
	ИдетВыполнение = ОперацияВыполняется(ОписаниеОперации);
	ТекстОшибкиВыполнения = ОшибкаВыполнения(ОписаниеОперации);
	ОтображатьСостояние = ИдетВыполнение ИЛИ ЗначениеЗаполнено(ТекстОшибкиВыполнения);
	
	ЭлементСостояние.Видимость = ОтображатьСостояние;
	
	// Обновление элементов результата
	Если ТипЗнч(ЭлементРезультат) = Тип("Массив") Тогда
		ЭлементыРезультата = ЭлементРезультат;
	Иначе
		ЭлементыРезультата = Новый Массив;
		ЭлементыРезультата.Добавить(ЭлементРезультат);
	КонецЕсли;
	
	Для Каждого Элемент Из ЭлементыРезультата Цикл 
		Элемент.Видимость = НЕ ОтображатьСостояние;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ТекстОшибкиВыполнения) Тогда
		
		КартинкаСостояния = БиблиотекаКартинок.ИТК_Ошибка32;
		ТекстСостояния = ТекстОшибкиВыполнения;
		
	Иначе
		
		КартинкаСостояния = Неопределено;
		ТекстСостояния = ТекстСостоянияИдетВыполнение;
		
	КонецЕсли;
	
	ИТК_ФормаКлиентСервер.ОтображениеСостоянияТабличногоДокумента(ЭлементСостояние, ТекстСостояния, КартинкаСостояния);
	
КонецПроцедуры

Функция ОперацияВыполняется(ОписаниеОперации) Экспорт
	
	Если ОписаниеОперации = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат (ОписаниеОперации.Статус = "Выполняется");
	
КонецФункции

Функция ОшибкаВыполнения(ОписаниеОперации) Экспорт
	
	Если ОписаниеОперации = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ИТК_ОбщийКлиентСервер.Свойство(ОписаниеОперации, "ПодробноеПредставлениеОшибки");
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаполнитьОписаниеОперацииПоУмолчанию(Форма, ОписаниеОперации)
	
	Если ОписаниеОперации = Неопределено Тогда
		ОписаниеОперации = Форма.ДлительнаяОперация;
	КонецЕсли;
	
КонецПроцедуры

// Скопировано из функции ДлительныеОперацииКлиент.ПоказатьОповещение
Процедура ПоказатьОповещение(ДлительнаяОперация)
	
	Оповещение = ДлительнаяОперация.ОповещениеПользователя;
	Если Не Оповещение.Показать Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Оповещение.Текст) Тогда
		
		ПоказатьОповещениеПользователя(Оповещение.Текст, Оповещение.НавигационнаяСсылка, Оповещение.Пояснение);
		
	КонецЕсли;

КонецПроцедуры

Функция СтатусЗадания(Статус)
	
	Результат = Статус;
	Если ИТК_БСПКлиентСерверПовтИсп.АнглийскаяБСП() Тогда
		
		Соответствие = Новый Соответствие;
		Соответствие.Вставить("Done", "Выполнено");
		Соответствие.Вставить("Completed", "Выполнено");
		Соответствие.Вставить("Completed2", "Выполнено");
		Соответствие.Вставить("Running", "Выполняется");
		Соответствие.Вставить("Error", "Ошибка");
		Соответствие.Вставить("Canceled", "Отменено");
		
		Результат = Соответствие.Получить(Статус);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти