#Область ПрограммныйИнтерфейс

Процедура Заменить(Параметры, АдресРезультата = Неопределено) Экспорт
	
	Найденные = Параметры.Найденные;
	ОбрабатываемыеОбъекты = Параметры.Обрабатываемые;
	ПакетОбъектов = Параметры.ПакетОбъектов;
	Заменяемые = Параметры.Заменяемые;
	ПараметрыЗаписи = Параметры.ПараметрыЗаписи;
	
	Если ПакетОбъектов = Неопределено Тогда
		
		Индекс = 0;
		Для Каждого Ссылка Из ОбрабатываемыеОбъекты Цикл 
			
			ТранзакцияЗаменаСсылкиВОбъекте(Найденные, Заменяемые, ПараметрыЗаписи, Ссылка, Индекс);
			Индекс = Индекс + 1;
			
		КонецЦикла;
		
	Иначе
		
		Для Каждого Индекс Из ПакетОбъектов Цикл 
			
			Ссылка = ОбрабатываемыеОбъекты[Индекс];
			ТранзакцияЗаменаСсылкиВОбъекте(Найденные, Заменяемые, ПараметрыЗаписи, Ссылка, Индекс);
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ТранзакцияЗаменаСсылкиВОбъекте(Найденные, Заменяемые, ПараметрыЗаписи, Ссылка, Индекс)
	
	Ошибка = "";
	ИТК_ДлительныеОперацииКлиентСервер.СообщениеНачалоОбработкиОбъекта(Индекс);
	
	НачатьТранзакцию();
	
	Попытка
		
		ЗаменитьСсылкиВОбъекте(Найденные, Заменяемые, ПараметрыЗаписи, Ссылка, Индекс);
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		Ошибка = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		
	КонецПопытки;
	
	ИТК_ДлительныеОперацииКлиентСервер.СообщениеКонецОбработкиОбъекта(Ошибка);
	
КонецПроцедуры

Процедура ЗаменитьСсылкиВОбъекте(Найденные, Заменяемые, ПараметрыЗаписи, Ссылка, Индекс)

	ЭтоКлючЗаписиРегистраСведений = ИТК_МетаданныеКлиентСервер.ЭтоТипКлючЗаписиРегистраСведений(ТипЗнч(Ссылка));
	Если ЭтоКлючЗаписиРегистраСведений Тогда
		
		НаборЗаписей = ИТК_Метаданные.НаборЗаписейПоКлючу(Ссылка);
		НаборЗаписей.Прочитать();
		
		Объект = НаборЗаписей;
		
	Иначе
		
		Объект = Ссылка.ПолучитьОбъект();
		
	КонецЕсли;
	
	ОбъектВXML = ИТК_XML.ВыгрузкаОбъектаВСтроку(Объект);
	
	Если ЭтоКлючЗаписиРегистраСведений Тогда
		
		// Очищаем старые записи
		Объект.Очистить();
		ИТК_ОбработкаОбъектов.УстановкаПараметровЗаписи(Объект, Истина, ПараметрыЗаписи.ДополнительныеСвойства);
		Объект.Записать();
		
	КонецЕсли;
	
	СсылкиПоОбъекту = Найденные.НайтиСтроки(Новый Структура("Данные", Ссылка));
	ЗаменитьСсылкиВТексте(ОбъектВXML, Заменяемые, СсылкиПоОбъекту);
	
	Если ИТК_Метаданные.ЭтоДокумент(Ссылка.Метаданные()) Тогда
		
		ЗаменитьДвиженияДокумента(Объект.Движения, ПараметрыЗаписи, Заменяемые, СсылкиПоОбъекту);
		
	КонецЕсли;
	
	Объект = ИТК_XML.ЗагрузитьОбъектИзСтроки(ОбъектВXML);
	ИТК_ОбработкаОбъектов.УстановкаПараметровЗаписи(Объект, Истина, ПараметрыЗаписи.ДополнительныеСвойства);
	
	Объект.Записать();
	
КонецПроцедуры

Процедура ЗаменитьДвиженияДокумента(Движения, ПараметрыЗаписи, Заменяемые, СсылкиПоОбъекту)
	
	Для Каждого НаборЗаписей Из Движения Цикл 
		
		НаборЗаписей.Прочитать();
		Записывать = ЗначениеЗаполнено(НаборЗаписей);
		
		Если Записывать Тогда
			
			ОбъектВXML = ИТК_XML.ВыгрузкаОбъектаВСтроку(НаборЗаписей);
			ЗаменитьСсылкиВТексте(ОбъектВXML, Заменяемые, СсылкиПоОбъекту);
			НаборЗаписей = ИТК_XML.ЗагрузитьОбъектИзСтроки(ОбъектВXML);
			
			ИТК_ОбработкаОбъектов.УстановкаПараметровЗаписи(НаборЗаписей, Истина, ПараметрыЗаписи.ДополнительныеСвойства);
			НаборЗаписей.Записать();
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаменитьСсылкиВТексте(Текст, Заменяемые, СсылкиПоОбъекту)
	
	Для Каждого Строка Из СсылкиПоОбъекту Цикл 
		
		ОписаниеЗаменяемойСсылки = Заменяемые.Получить(Строка.Ссылка);
		Текст = СтрЗаменить(Текст, ОписаниеЗаменяемойСсылки.GUID, ОписаниеЗаменяемойСсылки.НовыйGUID);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти
