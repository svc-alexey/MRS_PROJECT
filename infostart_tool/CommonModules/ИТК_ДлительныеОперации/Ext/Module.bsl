#Область ПрограммныйИнтерфейс

Функция ЗаданиеВыполнено(Идентификатор) Экспорт
	
	Попытка 
		
		ПараметрыФункции = Новый Массив;
		ПараметрыФункции.Добавить(Идентификатор);
		
		Результат = ИТК_БСПКлиентСервер.ВыполнитьФункцию("ДлительныеОперации.ЗаданиеВыполнено", ПараметрыФункции);
		
	Исключение
		
		Результат = Истина;
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Процедура Отменить(ОписаниеОперации) Экспорт
	
	Если НЕ ИТК_БСППовтИсп.ИспользуетсяБСП() Тогда
		Возврат;
	КонецЕсли;
	
	ПолеИдентификаторЗадания = "ИдентификаторЗадания";
	Если ИТК_БСППовтИсп.АнглийскаяБСП() Тогда
		ПолеИдентификаторЗадания = "JobID";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОписаниеОперации)
			И ЗначениеЗаполнено(ОписаниеОперации[ПолеИдентификаторЗадания]) Тогда
		
		ИдентификаторЗадания = ОписаниеОперации[ПолеИдентификаторЗадания];
		
		ПараметрыПроцедуры = Новый Массив;
		ПараметрыПроцедуры.Добавить(ИдентификаторЗадания);
		
		ИТК_БСПКлиентСервер.ВыполнитьПроцедуру("ДлительныеОперации.ОтменитьВыполнениеЗадания", ПараметрыПроцедуры);
		
		Пока НЕ ИТК_ДлительныеОперации.ЗаданиеВыполнено(ИдентификаторЗадания) Цикл 
			ИТК_ОбщийКлиентСервер.Подождать(0.1);
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура СообщитьПрогресс(Знач Текст = Неопределено, Знач Процент = Неопределено, Знач ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ИТК_БСППовтИсп.ИспользуетсяБСП() Тогда
		
		ПараметрыФункции = Новый Массив;
		ПараметрыФункции.Добавить(Процент);
		ПараметрыФункции.Добавить(Текст);
		ПараметрыФункции.Добавить(ДополнительныеПараметры);
		
		ИТК_БСПКлиентСервер.ВыполнитьПроцедуру("ДлительныеОперации.СообщитьПрогресс", ПараметрыФункции);
		Возврат;
		
	КонецЕсли;
	
	// Скопировано из функции ДлительныеОперации.СообщитьПрогресс
	ПередаваемоеЗначение = Новый Структура;
	Если Процент <> Неопределено Тогда
		ПередаваемоеЗначение.Вставить("Процент", Процент);
	КонецЕсли;
	Если Текст <> Неопределено Тогда
		ПередаваемоеЗначение.Вставить("Текст", Текст);
	КонецЕсли;
	Если ДополнительныеПараметры <> Неопределено Тогда
		ПередаваемоеЗначение.Вставить("ДополнительныеПараметры", ДополнительныеПараметры);
	КонецЕсли;
	
	// Подготовка значения - преобразование в XML
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку();
	СериализаторXDTO.ЗаписатьXML(ЗаписьXML, ПередаваемоеЗначение, НазначениеТипаXML.Явное);
	
	Текст = "{" + СообщениеПрогресса() + "}" + ЗаписьXML.Закрыть();
	Сообщить(Текст);
	
КонецПроцедуры

Функция ПараметрыВыполненияВФоне(Знач ИдентификаторФормы, ЗапуститьВФоне = Истина, НаименованиеФоновогоЗадания = "") Экспорт
	
	Если ИТК_БСППовтИсп.ИспользуетсяБСП() Тогда
		
		ПараметрыФункции = Новый Массив;
		ПараметрыФункции.Добавить(ИдентификаторФормы);
		
		Результат = ИТК_БСПКлиентСервер.ВыполнитьФункцию("ДлительныеОперации.ПараметрыВыполненияВФоне", ПараметрыФункции);
		
		ПолеЗапуститьВФоне = "ЗапуститьВФоне";
		ПолеЗапуститьНеВФоне = "ЗапуститьНеВФоне";
		ПолеНаименованиеФоновогоЗадания = "НаименованиеФоновогоЗадания";
		Если ИТК_БСППовтИсп.АнглийскаяБСП() Тогда
			
			ПолеЗапуститьВФоне = "RunInBackground";
			ПолеНаименованиеФоновогоЗадания = "BackgroundJobDescription";
			Если Результат.Свойство("RunNotInBackground1") Тогда
				ПолеЗапуститьНеВФоне = "RunNotInBackground1";
			Иначе
				ПолеЗапуститьНеВФоне = "RunNotInBackground";
			КонецЕсли;
			
		КонецЕсли;
		
		Результат[ПолеЗапуститьВФоне] = ЗапуститьВФоне;
		Результат[ПолеЗапуститьНеВФоне] = НЕ ЗапуститьВФоне;
		
		Результат[ПолеНаименованиеФоновогоЗадания] = НаименованиеФоновогоЗадания;
		
		Возврат Результат;
		
	КонецЕсли;
	
	// Скопировано из функции ДлительныеОперации.ПараметрыВыполненияВФоне
	Результат = Новый Структура;
	Результат.Вставить("ИдентификаторФормы", ИдентификаторФормы); 
	Результат.Вставить("ДополнительныйРезультат", Ложь);
	Результат.Вставить("ОжидатьЗавершение", ?(ПолучитьСкоростьКлиентскогоСоединения() = СкоростьКлиентскогоСоединения.Низкая, 4, 0.8));
	Результат.Вставить("НаименованиеФоновогоЗадания", "");
	Результат.Вставить("КлючФоновогоЗадания", "");
	Результат.Вставить("АдресРезультата", Неопределено);
	Результат.Вставить("ЗапуститьНеВФоне", Ложь);
	Результат.Вставить("ЗапуститьВФоне", Ложь);
	
	Возврат Результат;
	
КонецФункции

Функция ВыполнитьВФоне(Знач ИмяПроцедуры, Знач ПараметрыПроцедуры, Знач ПараметрыВыполнения) Экспорт
	
	Если ИТК_БСППовтИсп.ИспользуетсяБСП() Тогда
		
		ПараметрыФункции = Новый Массив;
		ПараметрыФункции.Добавить(ИмяПроцедуры);
		ПараметрыФункции.Добавить(ПараметрыПроцедуры);
		ПараметрыФункции.Добавить(ПараметрыВыполнения);
		
		Возврат ИТК_БСПКлиентСервер.ВыполнитьФункцию("ДлительныеОперации.ВыполнитьВФоне", ПараметрыФункции);
		
	КонецЕсли;
	
	// Скопировано из функции ДлительныеОперации.ВыполнитьВФоне
	АдресРезультата = ?(ПараметрыВыполнения.АдресРезультата <> Неопределено, 
	    ПараметрыВыполнения.АдресРезультата,
		ПоместитьВоВременноеХранилище(Неопределено, ПараметрыВыполнения.ИдентификаторФормы));
	
	Результат = Новый Структура;
	Результат.Вставить("Статус",    "Выполняется");
	Результат.Вставить("ИдентификаторЗадания", Неопределено);
	Результат.Вставить("АдресРезультата", АдресРезультата);
	Результат.Вставить("АдресДополнительногоРезультата", "");
	Результат.Вставить("КраткоеПредставлениеОшибки", "");
	Результат.Вставить("ПодробноеПредставлениеОшибки", "");
	Результат.Вставить("Сообщения", Новый ФиксированныйМассив(Новый Массив));
	
	ПараметрыЭкспортнойПроцедуры = Новый Массив;
	ПараметрыЭкспортнойПроцедуры.Добавить(ПараметрыПроцедуры);
	ПараметрыЭкспортнойПроцедуры.Добавить(АдресРезультата);
	
	Если ПараметрыВыполнения.ДополнительныйРезультат Тогда
		Результат.АдресДополнительногоРезультата = ПоместитьВоВременноеХранилище(Неопределено, ПараметрыВыполнения.ИдентификаторФормы);
		ПараметрыЭкспортнойПроцедуры.Добавить(Результат.АдресДополнительногоРезультата);
	КонецЕсли;
	
	// Выполнить в основном потоке.
	Попытка
		
		ИТК_Общий.ВыполнитьПроцедуру(ИмяПроцедуры, ПараметрыЭкспортнойПроцедуры, Ложь);
		Результат.Статус = "Выполнено";
		
	Исключение
		
		Результат.Статус = "Ошибка";
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		Результат.КраткоеПредставлениеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке);
		Результат.ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		
		ЗаписьЖурналаРегистрации(НСтр("ru = 'Ошибка выполнения';
										|en = 'Runtime error'"), УровеньЖурналаРегистрации.Ошибка, , , Результат.ПодробноеПредставлениеОшибки);
		
	КонецПопытки;
	
	Сообщения = ПолучитьСообщенияПользователю(Истина);
	Результат.Вставить("Сообщения", Сообщения);
	
	Возврат Результат;
	
КонецФункции

// Скопировано из функции ДлительныеОперации.СообщениеПрогресса
Функция СообщениеПрогресса() Экспорт
	
	Возврат "СтандартныеПодсистемы.ДлительныеОперации";
	
КонецФункции

Функция ЕстьАктивныеФоновыеЗадания() Экспорт
	
	ЗапущеноЗаданий = ФоновыеЗадания.ПолучитьФоновыеЗадания(Новый Структура("Состояние", СостояниеФоновогоЗадания.Активно)).Количество();
	Возврат (ЗапущеноЗаданий > 0);
	
КонецФункции

Функция Результат(Результат, АдресРезультата) Экспорт 
	
	Если ЗначениеЗаполнено(АдресРезультата) Тогда
		ПоместитьВоВременноеХранилище(Результат, АдресРезультата);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
