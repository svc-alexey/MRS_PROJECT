#Область ПрограммныйИнтерфейс

Функция Значения(Форма) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Привилегированный", Форма[ИмяПараметраПривилегированный()]);
	
	ИмяПараметраБезПроверок = ИмяПараметраБезПроверок();
	Если Форма.Элементы.Найти(ИмяПараметраБезПроверок) <> Неопределено Тогда
		Результат.Вставить("БезПроверок", Форма[ИмяПараметраБезПроверок]);
	КонецЕсли;
	
	ДополнительныеСвойства = Новый Структура;
	
	ОтключитьМеханизмРегистрации = Форма[ИмяПараметраОтключитьМеханизмРегистрацииВФорме()];
	Если ОтключитьМеханизмРегистрации Тогда
		ДополнительныеСвойства.Вставить("ОтключитьМеханизмРегистрацииОбъектов", ОтключитьМеханизмРегистрации);
	КонецЕсли;
	
	ПропуститьПроверкуЗапретаИзменения = Форма[ИмяПараметраПропуститьПроверкуЗапретаИзмененияВФорме()];
	Если ПропуститьПроверкуЗапретаИзменения Тогда
		ДополнительныеСвойства.Вставить("ПропуститьПроверкуЗапретаИзменения", ПропуститьПроверкуЗапретаИзменения);
	КонецЕсли;
	
	Для Каждого ДополнительноеСвойство Из Форма[ИмяПараметраДополнительныйСвойства()] Цикл 
		ДополнительныеСвойства.Вставить(ДополнительноеСвойство.Представление, ДополнительноеСвойство.Значение);
	КонецЦикла;

	Результат.Вставить("ДополнительныеСвойства", ДополнительныеСвойства);
	
	Возврат Результат;
	
КонецФункции

Функция ИмяПараметраДополнительныйСвойства() Экспорт
	
	Возврат ПрефиксПараметров() + "ДополнительныйСвойства";
	
КонецФункции

Функция ИмяПараметраПривилегированный() Экспорт
	
	Возврат ПрефиксПараметров() + "Привилегированный";
	
КонецФункции

Функция ИмяПараметраБезПроверок() Экспорт
	
	Возврат ПрефиксПараметров() + "БезПроверок";
	
КонецФункции

Функция ИмяПараметраОтключитьМеханизмРегистрации() Экспорт
	
	Возврат ИТК_БСПКлиентСервер.ИмяДополнительногоСвойстваОтключитьМеханизмРегистрации();
	
КонецФункции

Функция ИмяПараметраПропуститьПроверкуЗапретаИзменения() Экспорт
	
	Возврат ИТК_БСПКлиентСервер.ИмяДополнительногоСвойстваПропуститьПроверкуЗапретаИзменения();
	
КонецФункции

Функция ИмяПараметраОтключитьМеханизмРегистрацииВФорме() Экспорт
	
	Возврат ПрефиксПараметров() + ИмяПараметраОтключитьМеханизмРегистрации();
	
КонецФункции

Функция ИмяПараметраПропуститьПроверкуЗапретаИзмененияВФорме() Экспорт
	
	Возврат ПрефиксПараметров() + ИмяПараметраПропуститьПроверкуЗапретаИзменения();
	
КонецФункции

Функция ИмяОбработчикаКоманд() Экспорт 
	
	Возврат "ПодключаемыйОбработчикКоманд";
	
КонецФункции

Функция УстанавливаемыеДополнительныеСвойства() Экспорт
	
	Результат = Новый Массив;
	Результат.Добавить(ИмяПараметраОтключитьМеханизмРегистрации());
	Результат.Добавить(ИмяПараметраПропуститьПроверкуЗапретаИзменения());
	
	Возврат Результат;
	
КонецФункции



#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПрефиксПараметров()
	
	Возврат "ПараметрыЗаписи";
	
КонецФункции

#КонецОбласти

