#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СформироватьПриОткрытии = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "СформироватьПриОткрытии");
	
	Ссылки = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "Ссылки", Новый Массив);
	ЗаполнитьСравниваемыеОбъекты(Ссылки);
	
	Элементы.ФормаНастройки.Пометка = Истина;
	
	ИТК_ТабличныйДокумент.ДобавитьГруппуИнструментыВКонтекстноеМеню(ЭтотОбъект, Элементы.ТабличныйДокументРезультат.КонтекстноеМеню);
	ИТК_Форма.ОшибкиНастроекОтчетаИнициализировать(ЭтотОбъект, Элементы.ГруппаОшибкиНастроек);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИТК_ОбщийКлиент.ОбработчикПриОткрытии(Отказ);
	
	Если СформироватьПриОткрытии Тогда
		ОбновитьОтчет();
	КонецЕсли;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранныеЗначения, ИсточникВыбора)

	ДобавленныеЗначения = Новый Массив;
	Для Каждого ВыбранноеЗначение Из ВыбранныеЗначения Цикл 
		
		НайденныеСтроки = Объекты.НайтиСтроки(Новый Структура("Объект", ВыбранноеЗначение));
		Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
			Продолжить;
		КонецЕсли;

		НоваяСтрока = Объекты.Добавить();
		НоваяСтрока.Пометка = Истина;
		НоваяСтрока.Объект = ВыбранноеЗначение;
		
		ДобавленныеЗначения.Добавить(ВыбранноеЗначение);
		
	КонецЦикла;
	
	ИТК_ФормаКлиент.ВыводОповещенийПодбора(ДобавленныеЗначения);
	
	ОбновитьЭлементыФормы();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ТабличныйДокументРезультатПриАктивизацииОбласти(Элемент)
	
	ИТК_ТабличныйДокументКлиент.ОбработчикПриАктивизацииОбласти(ЭтотОбъект, Элемент, ТабличныйДокументРезультат);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыОбъекты

&НаКлиенте
Процедура ОбъектыПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	КоличествоОбъектов = Объекты.Количество();
	Если КоличествоОбъектов = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПоследнийОбъект = Объекты[КоличествоОбъектов -1].Объект;
	
	ОписаниеТипов = ИТК_ТипыКлиентСервер.ОписаниеТиповПоТипу(ТипЗнч(ПоследнийОбъект));
	ОграничитьТипЭлемента(Элементы.ОбъектыОбъект, ОписаниеТипов, Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если НоваяСтрока Тогда
		ТекущиеДанные.Пометка = Истина;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбъектыОбъектНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Если Элемент.ВыбиратьТип Тогда
		
		ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("ВыборТипаОбъектаЗавершен", ЭтотОбъект, Новый Структура);
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Исключаемые", "ПростыеТипы,Перечисления");
		ИТК_ФормаКлиент.ОткрытьРедактированиеТипаЗначения(Элемент, НСтр("ru = 'Объект';
																		|en = 'Object'"), ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборТипа(),
															Элемент.ДоступныеТипы, ОписаниеОповещенияЗавершение, СтандартнаяОбработка, ДополнительныеПараметры);
		
	КонецЕсли;
														
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыОбъектОчистка(Элемент, СтандартнаяОбработка)
	
	ОграничитьТипЭлемента(Элементы.ОбъектыОбъект, Новый ОписаниеТипов, Истина);

КонецПроцедуры

&НаКлиенте
Процедура ОбъектыПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Сравнить(Команда)
	
	ОбновитьОтчет();
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#Область ПодключаемыеКоманды

&НаКлиенте
Процедура Настройки(Команда)
	
	Элемент = Элементы.ФормаНастройки;
	Элемент.Пометка = НЕ Элемент.Пометка;
	
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаКлиенте
Процедура Подбор(Команда)
	
	ОписаниеОповещенияОЗавершении = Новый ОписаниеОповещения("ПослеВыбораТипаДляПодбора", ЭтотОбъект, Новый Структура);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Исключаемые", "ПростыеТипы,Перечисления");
	ИТК_ФормаКлиент.ОткрытьРедактированиеТипаЗначения(ЭтотОбъект, "Заголовок", ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборТипа(),
													Новый ОписаниеТипов, ОписаниеОповещенияОЗавершении, , ДополнительныеПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемаяКомандаРезультатВТабличномДокументе(Команда)

	ИТК_ТабличныйДокументКлиент.ОбработкаКомандыРезультатВТабличномДокументе(ЭтотОбъект, Команда, ТабличныйДокументРезультат);

КонецПроцедуры

&НаКлиенте
Процедура ОткрытьНовоеОкно(Команда)
	
	ИТК_ФормаКлиент.ОткрытьНовую(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	ИТК_ДлительныеОперацииКлиент.ОбновитьЭлементыОтображенияСостояния(ДлительнаяОперация,
		Элементы.ТабличныйДокументРезультат, Элементы.ИдетФормированиеОтчетаТабличныйДокумент,
		НСтр("ru = 'Формирование отчета...';
			|en = 'Report generation...'"));
	
	Элементы.ГруппаНастройки.Видимость = Элементы.ФормаНастройки.Пометка;
	
	КоличествоОтмеченных = ИТК_ФормаКлиент.КоличествоПомеченныхВКоллекции(Объекты);
	Элементы.ОбъектыОбъект.Заголовок = ИТК_ФормаКлиентСервер.ЗаголовокСКоличеством(НСтр("ru = 'Объекты';
																						|en = 'Objects'"), КоличествоОтмеченных);
	
	ЗаполнитьОшибкиНастроекОтчета();	
	
	ОшибкиНастроекОтчета = ИТК_ФормаКлиент.ОшибкиНастроекОтчетаСписок(ЭтотОбъект);
	КоличествоВажныхОшибок = ИТК_ФормаКлиент.КоличествоПомеченныхВКоллекции(ОшибкиНастроекОтчета);
	Элементы.ФормаСравнить.Доступность = (КоличествоВажныхОшибок = 0);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОтчет()
	
	ПараметрыОперации = Новый Структура;
	ПараметрыОперации.Вставить("Объекты", СравниваемыеОбъекты());
	ДлительнаяОперация = ОбновитьОтчетНаСервере(ПараметрыОперации, УникальныйИдентификатор);
	
	ПараметрыОжидания = ИТК_ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершеноОбновлениеОтчета", ЭтотОбъект);
	ИТК_ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ОбновитьОтчетНаСервере(ПараметрыОперации, УникальныйИдентификатор)
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_СравнениеОбъектов.ДанныеОтчета", ПараметрыОперации, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ЗавершеноОбновлениеОтчета(Результат, ДополнительныеПараметры) Экспорт
	
	ДлительнаяОперация = Результат;
	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		Элементы.ФормаНастройки.Пометка = Ложь;
		ОбновитьДанныеОтчетаСервер(Результат.АдресРезультата);
		
	КонецЕсли;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьДанныеОтчетаСервер(АдресРезультата)
	
	Результат = ПолучитьИзВременногоХранилища(АдресРезультата);
	ТабличныйДокументРезультат = Результат;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборТипаОбъектаЗавершен(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОграничитьТипЭлемента(Элементы.ОбъектыОбъект, Результат, Ложь);
	
	ТекущиеДанные = Элементы.Объекты.ТекущиеДанные;
	ТекущиеДанные.Объект = Результат.ПривестиЗначение(Неопределено);
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОграничитьТипЭлемента(Элемент, ОписаниеТипов, ВыбиратьТип)
	
	Элемент.ДоступныеТипы = ОписаниеТипов;
	Элемент.ОграничениеТипа = ОписаниеТипов;
	Элемент.ВыбиратьТип = ВыбиратьТип;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСравниваемыеОбъекты(Ссылки)
	
	Для Каждого Ссылка Из Ссылки Цикл 
		
		НоваяСтрока = Объекты.Добавить();
		НоваяСтрока.Пометка = Истина;
		НоваяСтрока.Объект = Ссылка;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Функция СравниваемыеОбъекты()
	
	Результат = Новый Массив;
	Для Каждого СтрокаОбъект Из Объекты Цикл 
		
		Если СтрокаОбъект.Пометка Тогда
			Результат.Добавить(СтрокаОбъект.Объект);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьОшибкиНастроекОтчета()
	
	ИТК_ФормаКлиент.ОшибкиНастроекОтчетаОчистить(ЭтотОбъект);
	
	КоличествоОтмеченных = ИТК_ФормаКлиент.КоличествоПомеченныхВКоллекции(Объекты);
	Если КоличествоОтмеченных < 2 Тогда
		
		ТекстОшибки = НСтр("ru = 'Недостаточно выбранных объектов для сравнения';
							|en = 'Not enough selected objects to compare'");
		ИТК_ФормаКлиент.ОшибкиНастроекОтчетаДобавить(ЭтотОбъект, ТекстОшибки, БиблиотекаКартинок.ИТК_ПредупреждениеВажное, Истина);
		
	КонецЕсли;
	
	ИТК_ФормаКлиент.ОшибкиНастроекОтчетаОбновитьОтображение(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораТипаДляПодбора(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИТК_ФормаКлиент.ОткрытьФормуВыбора(Результат, ЭтотОбъект, Ложь);

КонецПроцедуры

#КонецОбласти
