#Область ОписаниеПеременных

&НаКлиенте
Перем ПоследнееВыделение;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОтборМетаданных = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "ОтборМетаданных");
	ГруппироватьМетаданныеПоКоллекциям = Истина;
	ОтборИсключитьНедоступныхПользователей = Истина;
	
	Если Параметры.Свойство("ОтборПравДоступа") Тогда
		ОтборПравДоступа = Параметры.ОтборПравДоступа;
	Иначе
		ОтборПравДоступа = ИТК_АнализПравДоступаПовтИсп.ВсеПраваДоступаКромеИсторииДанных();
	КонецЕсли;
	
	СформироватьПриОткрытии = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "СформироватьПриОткрытии");
	
	ОбновитьЭлементыФормыПриСозданииНаСервере();
	
	НачальныеНастройки = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "НачальныеНастройки");
	Если ЗначениеЗаполнено(НачальныеНастройки) Тогда
		
		ОтборИсключитьНедоступныхПользователей = Ложь;
		
		// Группировки
		ГруппировкиСтрок.ЗаполнитьПометки(Ложь);
		
		НачальныеГруппировки = СтрРазделить(НачальныеНастройки.Группировки, ",");
		
		Для ИндексГруппировки = 0 По НачальныеГруппировки.ВГраница() Цикл 
			
			ГруппировкаСтрок = НачальныеГруппировки[ИндексГруппировки];
			
			ЭлементГруппировки = ГруппировкиСтрок.НайтиПоЗначению(ГруппировкаСтрок);
			ЭлементГруппировки.Пометка = Истина;
			
			Смещение = ИндексГруппировки - ГруппировкиСтрок.Индекс(ЭлементГруппировки);
			ГруппировкиСтрок.Сдвинуть(ЭлементГруппировки, Смещение);
			
		КонецЦикла;
		
		ПолеКолонок = Неопределено;
		
		// Отбор
		Для Каждого ОписаниеОтбора Из НачальныеНастройки.Отбор Цикл 
			
			Если ОписаниеОтбора.Ключ = "Пользователь" Тогда
				
				ОтборПользователей.Очистить();
				
				ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(ОписаниеОтбора.Значение);
				ОтборПользователей.Добавить(ОписаниеОтбора.Значение, ПользовательИБ.ПолноеИмя);
				
			ИначеЕсли ОписаниеОтбора.Ключ = "ГруппаДоступа" Тогда
				
				ОтборГруппДоступа.Очистить();
				ОтборГруппДоступа.Добавить(ОписаниеОтбора.Значение);
				
			ИначеЕсли ОписаниеОтбора.Ключ = "ПрофильГруппДоступа" Тогда
				
				ОтборПрофилиГруппДоступа.Очистить();
				ОтборПрофилиГруппДоступа.Добавить(ОписаниеОтбора.Значение);
				
			ИначеЕсли ОписаниеОтбора.Ключ = "Роль" Тогда
				
				ОтборРолей.Очистить();
				
				ОбъектМетаданных = Метаданные.НайтиПоПолномуИмени("Роль." + ОписаниеОтбора.Значение);
				ОтборРолей.Добавить(ОписаниеОтбора.Значение, ОбъектМетаданных.Представление());
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	ИТК_Настройки.ИнициализироватьФорму(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИТК_ОбщийКлиент.ОбработчикПриОткрытии(Отказ);
	
	Если СформироватьПриОткрытии Тогда
		ОбновитьОтчет();
	КонецЕсли;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	ИТК_НастройкиКлиент.ОбработкаОповещения(ЭтотОбъект, ИмяСобытия);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ТабличныйДокументРезультатПриАктивизацииОбласти(Элемент)
	
	ОформитьАктивнуюОбластьВРезультате(Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура ТабличныйДокументРезультатОбработкаРасшифровки(Элемент, Расшифровка, СтандартнаяОбработка, ДополнительныеПараметры)
	
	СтандартнаяОбработка = Ложь;
	
	МенюРасшифровки = МенюРасшифровки(АдресДанныхРасшифровки, Расшифровка);
	Если ЗначениеЗаполнено(МенюРасшифровки) Тогда
		
		Оповещение = Новый ОписаниеОповещения("ЗавершениеВыбораМенюРасшифровки", ЭтотОбъект);
		ПоказатьВыборИзМеню(Оповещение, МенюРасшифровки, Элемент);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборМетаданныхПредставлениеНажатие(Элемент, СтандартнаяОбработка)
	
	ДополнительныеПараметрыОповещения = Новый Структура;
	ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("НастройкаОтбораМетаданныхЗавершена", ЭтотОбъект, ДополнительныеПараметрыОповещения);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Исключаемые", "Перечисления,Последовательности,ХранилищаНастроек");
	
	ИТК_ФормаКлиент.ОткрытьРедактированиеТипаЗначения(ЭтотОбъект, Неопределено, ИТК_Перечисления.РежимРедактированияТипаЗначенияОтборМетаданных(),
														ОтборМетаданных, ОписаниеОповещенияЗавершение, СтандартнаяОбработка, ДополнительныеПараметры);
														
КонецПроцедуры

&НаКлиенте
Процедура ОтборРолиПредставлениеНажатие(Элемент, СтандартнаяОбработка)
	
	ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("ВыборРолейЗавершен", ЭтотОбъект);
	ИТК_ФормаКлиент.ОткрытьВыборРолей(ЭтотОбъект, ОтборРолей, ОписаниеОповещенияЗавершение, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборПользователейПредставлениеНажатие(Элемент, СтандартнаяОбработка)
	
	ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("ВыборПользователейЗавершен", ЭтотОбъект);
	ИТК_ФормаКлиент.ОткрытьВыборПользователей(ЭтотОбъект, ОтборПользователей, ОписаниеОповещенияЗавершение, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборПравДоступаПредставлениеНажатие(Элемент, СтандартнаяОбработка)
	
	ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("ВыборПравДоступаЗавершен", ЭтотОбъект);
	ИТК_ФормаКлиент.ОткрытьВыборПравДоступа(ЭтотОбъект, ОтборПравДоступа, ОписаниеОповещенияЗавершение, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборПрофилиГруппДоступаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ОписаниеТипов = ИТК_БСПКлиентСервер.ОписаниеТиповПрофилиГруппДоступа();
	ОписаниеОповещения = Новый ОписаниеОповещения("РедактированиеСпискаПрофилиГруппДоступаЗавершено", ЭтотОбъект);
	ИТК_ФормаКлиент.ОткрытьСписокЗначений(ЭтотОбъект, ИТК_Перечисления.ВариантФормыСписокЗначенийРедактирование(),
												ОтборПрофилиГруппДоступа, ОписаниеТипов, ОписаниеОповещения,
												СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборПрофилиГруппДоступаОчистка(Элемент, СтандартнаяОбработка)

	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаКлиенте
Процедура ОтборГруппДоступаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ОписаниеТипов = ИТК_БСПКлиентСервер.ОписаниеТиповГруппыДоступа();
	ОписаниеОповещения = Новый ОписаниеОповещения("РедактированиеСпискаГруппДоступаЗавершено", ЭтотОбъект);
	ИТК_ФормаКлиент.ОткрытьСписокЗначений(ЭтотОбъект, ИТК_Перечисления.ВариантФормыСписокЗначенийРедактирование(),
												ОтборГруппДоступа, ОписаниеТипов, ОписаниеОповещения,
												СтандартнаяОбработка);
												
КонецПроцедуры

&НаКлиенте
Процедура ОтборГруппДоступаОчистка(Элемент, СтандартнаяОбработка)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПолеКолонокПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПолеКолонкиОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыГруппировкиСтрок

&НаКлиенте
Процедура ГруппировкиСтрокПометкаПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ГруппировкиСтрок.ТекущиеДанные;
	
	Если ТекущиеДанные.Пометка = Ложь
			И ИТК_ФормаКлиент.КоличествоПомеченныхВКоллекции(ГруппировкиСтрок) = 0 Тогда
			
		ТекущийЭлементСписка = ГруппировкиСтрок.НайтиПоЗначению(ТекущиеДанные.Значение);
		ТекущийЭлементСписка.Пометка = Истина;
		
	КонецЕсли;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ГруппировкиСтрокПроверкаПеретаскивания(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Поле)
	
	Если Строка = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ГруппировкиСтрокПеретаскивание(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Поле)
	
	СтрокаПриемник = ГруппировкиСтрок.НайтиПоИдентификатору(Строка);
	СтрокаИсточник = ГруппировкиСтрок.НайтиПоИдентификатору(ПараметрыПеретаскивания.Значение);
	
	ИндексПриемника = ГруппировкиСтрок.Индекс(СтрокаПриемник);
	ИндексИсточника = ГруппировкиСтрок.Индекс(СтрокаИсточник);
	
	ГруппировкиСтрок.Сдвинуть(СтрокаИсточник, ИндексПриемника - ИндексИсточника);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Сформировать(Команда)
	
	ОбновитьОтчет();
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура Настройки(Команда)
	
	Элемент = Элементы.ФормаНастройки;
	Элемент.Пометка = НЕ Элемент.Пометка;
	
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаКлиенте
Процедура ОтключитьОтборМетаданных(Команда)
	
	ОтборМетаданных = Неопределено;
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтключитьОтборРолей(Команда)
	
	ОтборРолей = Неопределено;
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтключитьОтборПользователей(Команда)
	
	ОтборПользователей = Неопределено;
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтключитьОтборПравДоступа(Команда)
	
	ОтборПравДоступа = Неопределено;
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ГруппировкиСтрокПереместитьВверх(Команда)
	
	СдвинутьЭлементСписка("ГруппировкиСтрок", -1);
	
КонецПроцедуры

&НаКлиенте
Процедура ГруппировкиСтрокПереместитьВниз(Команда)
	
	СдвинутьЭлементСписка("ГруппировкиСтрок", +1);

КонецПроцедуры

&НаКлиенте
Процедура ОткрытьНовоеОкно(Команда)
	
	ИТК_ФормаКлиент.ОткрытьНовую(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	ИТК_ДлительныеОперацииКлиент.ОбновитьЭлементыОтображенияСостояния(ДлительнаяОперация, Элементы.ТабличныйДокументРезультат,
		Элементы.ИдетФормированиеОтчетаТабличныйДокумент, ТекстСтатусаФормирования);
	
	Элементы.ГруппаНастройки.Видимость = Элементы.ФормаНастройки.Пометка;
	
	ОбновитьОтображениеОтбора("ОтборМетаданных", "Метаданные");
	Элементы.ГруппироватьМетаданныеПоКоллекциям.Доступность = ПолеИспользуетсяВОтчете("Метаданные");
	
	ОбновитьОтображениеОтбора("ОтборРолей", "Роль");
	ОбновитьОтображениеОтбора("ОтборПользователей", "Пользователь");
	
	ОбновитьОтображениеОтбора("ОтборПравДоступа", "ПравоДоступа");
	Элементы.ОтображатьНеустановленныеПраваДоступа.Доступность = ПолеИспользуетсяВОтчете("ПравоДоступа");
	
	ВыделитьШрифтомЗаголовкаВключенныйОтбор(Элементы.ОтборПрофилиГруппДоступа, ОтборПрофилиГруппДоступа);
	ВыделитьШрифтомЗаголовкаВключенныйОтбор(Элементы.ОтборГруппДоступа, ОтборГруппДоступа);
	
	ИспользуетсяБСП = ИТК_БСПКлиентСервер.ИспользуетсяБСП();
	Элементы.ГруппаОтборПрофили.Видимость = ИспользуетсяБСП;
	Элементы.ГруппаОтборГруппДоступа.Видимость = ИспользуетсяБСП;
	
	ЗаполнитьОшибкиНастроекОтчета();
	
	ОшибкиНастроекОтчета = ИТК_ФормаКлиент.ОшибкиНастроекОтчетаСписок(ЭтотОбъект);
	КоличествоВажныхОшибок = ИТК_ФормаКлиент.КоличествоПомеченныхВКоллекции(ОшибкиНастроекОтчета);
	Элементы.ФормаСформировать.Доступность = (КоличествоВажныхОшибок = 0);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьЭлементыФормыПриСозданииНаСервере()
	
	Элементы.ФормаНастройки.Пометка = Истина;
	ИТК_Форма.ОшибкиНастроекОтчетаИнициализировать(ЭтотОбъект, Элементы.ГруппаОшибкиНастроек);
	
	ЗаполнениеДоступныхГруппировокИПолейОтчета();
	ПолеКолонок = "ПравоДоступа";

КонецПроцедуры

&НаСервере
Процедура ЗаполнениеДоступныхГруппировокИПолейОтчета()
	
	ПоляОтчета = Новый ТаблицаЗначений;
	ПоляОтчета.Колонки.Добавить("Имя", ИТК_ТипыКлиентСервер.ОписаниеИмяМетаданных());
	ПоляОтчета.Колонки.Добавить("Группировка", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	ПоляОтчета.Колонки.Добавить("ГруппировкаПорядок", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10));
	ПоляОтчета.Колонки.Добавить("ПолеКолонок", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	ПоляОтчета.Колонки.Добавить("ПолеКолонокПорядок", ИТК_ТипыКлиентСервер.ОписаниеЧисло(10));
	ПоляОтчета.Колонки.Добавить("ИспользуетсяПоУмолчанию", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	ПоляОтчета.Колонки.Добавить("ИспользуетсяВБСП", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	
	НовоеПоле = ПоляОтчета.Добавить();
	НовоеПоле.Имя = "";
	НовоеПоле.ПолеКолонок = Истина;
	НовоеПоле.ПолеКолонокПорядок = 0;
	
	НовоеПоле = ПоляОтчета.Добавить();
	НовоеПоле.Имя = "Метаданные";
	НовоеПоле.Группировка = Истина;
	НовоеПоле.ГруппировкаПорядок = 10;
	НовоеПоле.ИспользуетсяПоУмолчанию = Истина;
	
	НовоеПоле = ПоляОтчета.Добавить();
	НовоеПоле.Имя = "ПрофильГруппДоступа";
	НовоеПоле.ИспользуетсяВБСП = Истина;
	НовоеПоле.Группировка = Истина;
	НовоеПоле.ГруппировкаПорядок = 20;
	НовоеПоле.ПолеКолонок = Истина;
	НовоеПоле.ПолеКолонокПорядок = 20;
	
	НовоеПоле = ПоляОтчета.Добавить();
	НовоеПоле.Имя = "ГруппаДоступа";
	НовоеПоле.ИспользуетсяВБСП = Истина;
	НовоеПоле.Группировка = Истина;
	НовоеПоле.ГруппировкаПорядок = 25;
	НовоеПоле.ПолеКолонок = Истина;
	НовоеПоле.ПолеКолонокПорядок = 25;

	НовоеПоле = ПоляОтчета.Добавить();
	НовоеПоле.Имя = "Роль";
	НовоеПоле.Группировка = Истина;
	НовоеПоле.ГруппировкаПорядок = 30;
	НовоеПоле.ПолеКолонок = Истина;
	НовоеПоле.ПолеКолонокПорядок = 30;
	НовоеПоле.ИспользуетсяПоУмолчанию = Истина;
	
	НовоеПоле = ПоляОтчета.Добавить();
	НовоеПоле.Имя = "Пользователь";
	НовоеПоле.Группировка = Истина;
	НовоеПоле.ГруппировкаПорядок = 60;
	НовоеПоле.ПолеКолонок = Истина;
	НовоеПоле.ПолеКолонокПорядок = 60;
	
	НовоеПоле = ПоляОтчета.Добавить();
	НовоеПоле.Имя = "ПравоДоступа";
	НовоеПоле.Группировка = Истина;
	НовоеПоле.ГруппировкаПорядок = 70;
	НовоеПоле.ПолеКолонок = Истина;
	НовоеПоле.ПолеКолонокПорядок = 10;
	
	ДобавитьДоступныеПоляОтчетаВСписок(ПоляОтчета, ГруппировкиСтрок, "Группировка");
	ДобавитьДоступныеПоляОтчетаВСписок(ПоляОтчета, Элементы.ПолеКолонок.СписокВыбора, "ПолеКолонок");
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьДоступныеПоляОтчетаВСписок(ПоляОтчета, Список, ПолеПризнак)
	
	ПоляОтчета.Сортировать(ПолеПризнак + "Порядок");
	
	Для Каждого Поле Из ПоляОтчета Цикл 
		
		Если НЕ Поле[ПолеПризнак]
				ИЛИ (Поле["ИспользуетсяВБСП"] 
						И НЕ ИТК_БСПКлиентСервер.ИспользуетсяБСП()) Тогда
			Продолжить;
		КонецЕсли;		
		
		ИмяПоля = Поле.Имя;
		ПредставлениеПоля = ИТК_АнализПравДоступаКлиентСервер.ПредставлениеПоляОтчета(ИмяПоля);
		Список.Добавить(ИмяПоля, ПредставлениеПоля, Поле.ИспользуетсяПоУмолчанию); 
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаОтбораМетаданныхЗавершена(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОтборМетаданных = Результат;
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборРолейЗавершен(Результат, ДополнительныеПараметры) Экспорт
	
