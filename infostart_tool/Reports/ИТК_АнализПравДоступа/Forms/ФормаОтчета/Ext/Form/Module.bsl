КонецПроцедуры

&НаКлиенте
Процедура СдвинутьЭлементСписка(ИмяСписка, Смещение)
	
	Список = ЭтотОбъект[ИмяСписка];
	ИдентификаторТекущейСтроки = Элементы[ИмяСписка].ТекущаяСтрока;

	ЭлементСписка = Список.НайтиПоИдентификатору(ИдентификаторТекущейСтроки);
	
	Если Смещение = -1 Тогда
		Граница = 0;
	Иначе 
		Граница = Список.Количество() - 1;
	КонецЕсли;
	
	Если Список.Индекс(ЭлементСписка) = Граница Тогда
		Возврат;
	КонецЕсли;
	
	Список.Сдвинуть(ЭлементСписка, Смещение);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОтчет()
	
	ПоследнееВыделение = Неопределено;
	ТекстСтатусаФормирования = НСтр("ru = 'Формирование отчета...'; |en = 'Report generation...'");
	
	ПараметрыОперации = Новый Структура;
	ПараметрыОперации.Вставить("ОтборМетаданных", ОтборМетаданных);
	ПараметрыОперации.Вставить("ОтборРолей", ОтборРолей);
	ПараметрыОперации.Вставить("ОтборПользователей", ОтборПользователей);
	ПараметрыОперации.Вставить("ОтборПользователейИсключитьНедоступных", ОтборИсключитьНедоступныхПользователей);
	ПараметрыОперации.Вставить("ОтборПравДоступа", ОтборПравДоступа);
	
	ПараметрыОперации.Вставить("ОтборГруппДоступа", ОтборГруппДоступа);
	ПараметрыОперации.Вставить("ОтборПрофилейГруппДоступа", ОтборПрофилиГруппДоступа);
	
	ПараметрыОперации.Вставить("ПолеКолонок", ПолеКолонок);
	
	ИспользуемыеГруппировкиСтрок = Новый СписокЗначений;
	Для Каждого ЭлементСпискГруппировка Из ГруппировкиСтрок Цикл 
		
		Если НЕ ЭлементСпискГруппировка.Пометка Тогда
			Продолжить;
		КонецЕсли;
		
		ИспользуемыеГруппировкиСтрок.Добавить(ЭлементСпискГруппировка.Значение, ЭлементСпискГруппировка.Представление);
		
	КонецЦикла;
	ПараметрыОперации.Вставить("ГруппировкиСтрок", ИспользуемыеГруппировкиСтрок);
	ПараметрыОперации.Вставить("ГруппироватьМетаданныеПоКоллекциям", ГруппироватьМетаданныеПоКоллекциям);
	
	ПараметрыОперации.Вставить("ОтображатьНеустановленныеПраваДоступа", ОтображатьНеустановленныеПраваДоступа);
	ПараметрыОперации.Вставить("РасширенноеПредставлениеРолей", РасширенноеПредставлениеРолей);
	
	ДлительнаяОперация = ОбновитьОтчетНаСервере(ПараметрыОперации, УникальныйИдентификатор);
	
	ОписаниеОперации = Новый Структура;
	ОписаниеОперации.Вставить("Источник", ИТК_Перечисления.ИнструментАнализПравДоступа());
	ОписаниеОперации.Вставить("Наименование", НСтр("ru = 'Анализ прав доступа';
													|en = 'Access rights analysis'"));
	
	ОповещениеОПрогрессеВыполнения = Новый ОписаниеОповещения("ОбработкаПрогрессаВыполнения", ЭтотОбъект);
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершеноОбновлениеОтчета", ЭтотОбъект);
	ИТК_ОбработкаОбъектовКлиент.ИнициализацияДлительнойОперации(ЭтотОбъект, ДлительнаяОперация, ОписаниеОперации, ОповещениеОПрогрессеВыполнения, ОповещениеОЗавершении);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ОбновитьОтчетНаСервере(ПараметрыОперации, УникальныйИдентификатор)
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_АнализПравДоступа.ДанныеОтчета", ПараметрыОперации, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ОбработкаПрогрессаВыполнения(Результат, ДополнительныеПараметры) Экспорт
	
	ДлительнаяОперация = Результат;
	ИТК_ДлительныеОперацииКлиент.ПодготовитьПрогрессВыполнения(Результат);
	Если НЕ ЗначениеЗаполнено(Результат) Тогда
		Возврат;
	КонецЕсли;
	
	Прогресс = Результат.Прогресс;
	Если НЕ ЗначениеЗаполнено(Прогресс) Тогда
		Возврат;
	КонецЕсли;
	
	ТекстСтатусаФормирования = СтрШаблон("%1%% %2", Прогресс.Процент, Прогресс.Текст);
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершеноОбновлениеОтчета(Результат, ДополнительныеПараметры) Экспорт
	
	ДлительнаяОперация = Результат;
	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		Элементы.ФормаНастройки.Пометка = Ложь;
		ОбновитьДанныеОтчетаСервер(Результат.АдресРезультата);
		
		ОформитьАктивнуюОбластьВРезультате(Элементы.ТабличныйДокументРезультат);
		
	КонецЕсли;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьДанныеОтчетаСервер(АдресРезультата)
	
	РезультатВыполнения = ПолучитьИзВременногоХранилища(АдресРезультата);
	
	ТабличныйДокументРезультат = РезультатВыполнения.ДокументРезультат;
	АдресДанныхРасшифровки = ИТК_ВременноеХранилище.Поместить(РезультатВыполнения.ДанныеРасшифровки, АдресДанныхРасшифровки, УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОтображениеОтбора(ИмяЗначенияОтбора, ПолеОтбора)
	
	Отбор = ЭтотОбъект[ИмяЗначенияОтбора];
	ИмяОтборПредставление = ИмяЗначенияОтбора + "Представление";
	
	ЭлементОтборПредставление = Элементы[ИмяОтборПредставление];
	ВыделитьШрифтомЗаголовкаВключенныйОтбор(ЭлементОтборПредставление, Отбор);
	
	Если ПолеОтбора = "ПравоДоступа" Тогда
		ПредставлениеОтбора = ИТК_АнализПравДоступаКлиентСервер.ПредставлениеВыбранныхПравДоступа(Отбор);
	Иначе
		ПредставлениеОтбора = ИТК_ФормаКлиентСервер.ПредставлениеСписка(Отбор, 80);
	КонецЕсли;	
	ЭтотОбъект[ИмяОтборПредставление] = ПредставлениеОтбора;
	
	Элементы["Отключить" + ИмяЗначенияОтбора].Видимость = ЗначениеЗаполнено(Отбор);	
	
КонецПроцедуры

&НаКлиенте
Процедура ВыделитьШрифтомЗаголовкаВключенныйОтбор(Элемент, Отбор)
	
	ШрифтЗаголовка = Новый Шрифт;
	Если ЗначениеЗаполнено(Отбор) Тогда
		ШрифтЗаголовка = ИТК_ОбщийКлиентСервер.ШрифтЖирный();
	КонецЕсли;
	Элемент.ШрифтЗаголовка = ШрифтЗаголовка;
	
КонецПроцедуры

&НаКлиенте
Функция ПолеИспользуетсяВОтчете(Поле)
	
	Если ПолеКолонок = Поле Тогда
		Возврат Истина;
	КонецЕсли;
	
	ЭлементГруппировки = ГруппировкиСтрок.НайтиПоЗначению(Поле);
	Если ЭлементГруппировки <> Неопределено Тогда

		Если ЭлементГруппировки.Пометка Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат НЕ НесколькоЗначенийВОтборе(Поле);
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьОшибкиНастроекОтчета()
	
	ИТК_ФормаКлиент.ОшибкиНастроекОтчетаОчистить(ЭтотОбъект);
	
	НайденныйЭлементГруппировкиСтрок = ГруппировкиСтрок.НайтиПоЗначению(ПолеКолонок);
	Если НайденныйЭлементГруппировкиСтрок <> Неопределено
			И НайденныйЭлементГруппировкиСтрок.Пометка Тогда
			
		ШаблонОшибки = НСтр("ru = 'Поле %1 дублируется в строках и колонках';
							|en = 'Field %1 is duplicated in rows and columns'");
		ТекстОшибки = СтрШаблон(ШаблонОшибки, ПолеКолонок);
		ИТК_ФормаКлиент.ОшибкиНастроекОтчетаДобавить(ЭтотОбъект, ТекстОшибки, БиблиотекаКартинок.ИТК_ПредупреждениеВажное, Истина);
		
	КонецЕсли;
	
	Для Каждого ЭлементГруппировка Из ГруппировкиСтрок Цикл 
		
		Поле = ЭлементГруппировка.Значение;
		ПредставлениеПоля = ЭлементГруппировка.Представление;
		
		ОшибкаИспользованияГруппировки = НЕ ПолеИспользуетсяВОтчете(Поле)
			И ЗаданыЗначенияОтбора(Поле)
			И НесколькоЗначенийВОтборе(Поле);
		Если ОшибкаИспользованияГруппировки И Поле = "ПравоДоступа" Тогда
			ОшибкаИспользованияГруппировки = ПолеИспользуетсяВОтчете("Метаданные")
				И (ПолеИспользуетсяВОтчете("Роль")
					ИЛИ ПолеИспользуетсяВОтчете("Пользователь"));
		КонецЕсли;

		Если ОшибкаИспользованияГруппировки Тогда
				
			ШаблонТекстаОшибки = НСтр("ru = 'Выбрано несколько значений отбора, необходимо включить использование группировки %1';
										|en = 'Multiple filter values selected, use grouping %1 must be enabled'");
			ТекстОшибки = СтрШаблон(ШаблонТекстаОшибки, ПредставлениеПоля);
			ИТК_ФормаКлиент.ОшибкиНастроекОтчетаДобавить(ЭтотОбъект, ТекстОшибки, БиблиотекаКартинок.ИТК_ПредупреждениеВажное, Истина);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ПолеИспользуетсяВОтчете("Метаданные")
			ИЛИ ПолеИспользуетсяВОтчете("ПравоДоступа") Тогда
			
		Если НЕ (ПолеИспользуетсяВОтчете("Метаданные")
				И ПолеИспользуетсяВОтчете("ПравоДоступа")
				И (ПолеИспользуетсяВОтчете("Роль")
					ИЛИ ПолеИспользуетсяВОтчете("Пользователь"))) Тогда
				
			ТекстОшибки = НСтр("ru = 'Для построения отчета по метаданнным требуются поля Метаданные, Право доступа и Роль / Пользователь';
								|en = 'To build a report on metadata, the fields Metadata, Access right and Role / User are required'");
			ИТК_ФормаКлиент.ОшибкиНастроекОтчетаДобавить(ЭтотОбъект, ТекстОшибки, БиблиотекаКартинок.ИТК_ПредупреждениеВажное, Истина);
			
		КонецЕсли;
		
	КонецЕсли;

	Если ПолеИспользуетсяВОтчете("Метаданные")
			И НЕ ЗначениеЗаполнено(ОтборМетаданных) Тогда
			
		ТекстОшибки = НСтр("ru = 'Отбор метаданных не установлен формирование отчета может занять много времени';
							|en = 'The selection of metadata is not set. Generation of the report can take a long time'");
		ИТК_ФормаКлиент.ОшибкиНастроекОтчетаДобавить(ЭтотОбъект, ТекстОшибки, БиблиотекаКартинок.ИТК_Предупреждение);
		
	КонецЕсли;
	
	ИТК_ФормаКлиент.ОшибкиНастроекОтчетаОбновитьОтображение(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Функция НесколькоЗначенийВОтборе(Поле)
	
	ОтборПоля = ЗначениеОтбораПоля(Поле);
	
	Если ТипЗнч(ОтборПоля) = Тип("СписокЗначений") Тогда
		ОдноЗначениеВОтборе = (ОтборПоля.Количество() = 1);
	Иначе
		
		ЭлементыОтбора = СтрРазделить(ОтборПоля, ", ");
		
		ОдноЗначениеВОтборе = (ЭлементыОтбора.Количество() = 1)
						И СтрНайти(ЭлементыОтбора[0], ".");
		
	КонецЕсли;
	
	Возврат НЕ ОдноЗначениеВОтборе;
	
КонецФункции

&НаКлиенте
Функция ЗначениеОтбораПоля(Поле)
	
	Если Поле = "Метаданные" Тогда
		ОтборПоля = ОтборМетаданных;
	ИначеЕсли Поле = "Роль" Тогда
		ОтборПоля = ОтборРолей;
	ИначеЕсли Поле = "Пользователь" Тогда
		ОтборПоля = ОтборПользователей;
	ИначеЕсли Поле = "ПравоДоступа" Тогда
		ОтборПоля = ОтборПравДоступа;
	Иначе
		ОтборПоля = Неопределено;
	КонецЕсли;
	
	Возврат ОтборПоля;
	
КонецФункции

&НаКлиенте
Функция ЗаданыЗначенияОтбора(Поле)
	
	ОтборПоля = ЗначениеОтбораПоля(Поле);
	Возврат ЗначениеЗаполнено(ОтборПоля);
	
КонецФункции

&НаКлиенте
Процедура ОформитьАктивнуюОбластьВРезультате(Элемент)
	
	ВосстановитьФонПредудущихОбластей();
	
	// Вычисление строки с которой начинается таблица
	СтрокаНачалаТаблицы = 0;
	Для НомерСтроки = 1 По ТабличныйДокументРезультат.ВысотаТаблицы Цикл
		
		Если ТабличныйДокументРезультат.Область(НомерСтроки, 1).ГраницаСверху.ТипЛинии = ТипЛинииЯчейкиТабличногоДокумента.Сплошная Тогда
			
			СтрокаНачалаТаблицы = НомерСтроки;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если СтрокаНачалаТаблицы = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// Оформление и запоминание новой области
	ТекущаяОбласть = Элемент.ТекущаяОбласть;
	ОформлятьСтроку = (ТекущаяОбласть.Низ = ТекущаяОбласть.Верх)
						И ТекущаяОбласть.Низ > СтрокаНачалаТаблицы;
	ОформлятьСтолбец = (ТекущаяОбласть.Лево = ТекущаяОбласть.Право)
						И ТекущаяОбласть.Лево > 1
						И ТекущаяОбласть.Низ > СтрокаНачалаТаблицы;
						
	ЦветФона = WebЦвета.СветлоЗолотистый;

	ТекущаяСтрока = ТекущаяОбласть.Низ;
	ТекущаяКолонка = ТекущаяОбласть.Лево;
	
	ПоследнееВыделение = Новый Соответствие;
	
	// Строка
	Если ОформлятьСтроку Тогда
		
		Для НомерКолонки = 1 По ТабличныйДокументРезультат.ШиринаТаблицы Цикл 
			ЗапомнитьФонОбласти(ТекущаяСтрока, НомерКолонки, ЦветФона);
		КонецЦикла;
		
		Область = ТабличныйДокументРезультат.Область(ТекущаяСтрока, 1, ТекущаяСтрока, ТабличныйДокументРезультат.ШиринаТаблицы);
		Область.ЦветФона = ЦветФона;
		
	КонецЕсли;
	
	// Столбец
	Если ОформлятьСтолбец Тогда
		
		Для НомерСтроки = СтрокаНачалаТаблицы По ТабличныйДокументРезультат.ВысотаТаблицы Цикл
			ЗапомнитьФонОбласти(НомерСтроки, ТекущаяКолонка, ЦветФона);
		КонецЦикла;
		
		Область = ТабличныйДокументРезультат.Область(СтрокаНачалаТаблицы, ТекущаяКолонка, ТабличныйДокументРезультат.ВысотаТаблицы, ТекущаяКолонка);
		Область.ЦветФона = ЦветФона;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВосстановитьФонПредудущихОбластей()

	Если ПоследнееВыделение = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ИмяОбластиЦвет Из ПоследнееВыделение Цикл 
		
		Область = ТабличныйДокументРезультат.Область(ИмяОбластиЦвет.Ключ);
		Область.ЦветФона = ИмяОбластиЦвет.Значение;
		
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ЗапомнитьФонОбласти(НомерСтроки, НомерКолонки, ЦветФона)

	Область = ТабличныйДокументРезультат.Область(НомерСтроки, НомерКолонки);
	Если ПоследнееВыделение.Получить(Область.Имя) = Неопределено Тогда
		ПоследнееВыделение.Вставить(Область.Имя, Область.ЦветФона);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура РедактированиеСпискаПрофилиГруппДоступаЗавершено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОтборПрофилиГруппДоступа = Результат;
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаКлиенте
Процедура РедактированиеСпискаГруппДоступаЗавершено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОтборГруппДоступа = Результат;
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаСервереБезКонтекста
Функция МенюРасшифровки(АдресДанныхРасшифровки, Расшифровка) 
	
	ДанныеРасшифровки = ПолучитьИзВременногоХранилища(АдресДанныхРасшифровки);
	ПоляРасшифровки = ДанныеРасшифровки.Элементы[Расшифровка].ПолучитьПоля();
	
	Если НЕ ЗначениеЗаполнено(ПоляРасшифровки) Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ПолеРасшифровки = ПоляРасшифровки[0].Поле;
	ЗначениеРасшифровки = ПоляРасшифровки[0].Значение;
	
	// Заполнение меню расшифроки
	Результат = Новый СписокЗначений;
	Если ПолеРасшифровки = "Метаданные" Тогда
		ДобавитьИнструментВМенюРасшифровки(Результат, ИТК_Перечисления.ИнструментМетаданные(), ЗначениеРасшифровки);
	ИначеЕсли ПолеРасшифровки = "Пользователь" Тогда
		
		Если ИТК_БСППовтИсп.ИспользуетсяБСП() Тогда
			
			ПользовательБСП = ИТК_БСППовтИсп.НайтиПользователяПоУникальномуИдентификатору(Строка(ЗначениеРасшифровки));
			Если ЗначениеЗаполнено(ПользовательБСП) Тогда
				
				ДобавитьСтрокуВМенюРасшифровки(Результат, НСтр("ru = 'Открыть пользователя (БСП)'; en = 'Open user (SSL)'"),
												ПользовательБСП, БиблиотекаКартинок.Пользователь);
			КонецЕсли;
										
		КонецЕсли;
		
		ДобавитьИнструментВМенюРасшифровки(Результат, ИТК_Перечисления.ИнструментРедактированиеПользователяИБ(), ЗначениеРасшифровки);
		
		Если ИТК_БСППовтИсп.ИспользуетсяБСП() Тогда
			
			ОтборОтчета = Новый Структура;
			ОтборОтчета.Вставить("Пользователь", ЗначениеРасшифровки);
			НастройкиОтчетаРасшифровки = НастройкиОтчетаРасшифровки("ПрофильГруппДоступа,ГруппаДоступа,Роль", ОтборОтчета);
			
			ДобавитьИнструментВМенюРасшифровки(Результат, ИТК_Перечисления.ИнструментАнализПравДоступа(), НастройкиОтчетаРасшифровки,
												НСтр("ru = 'Профили/Группы/Роли по пользователю'; en = 'Profiles/Groups/Roles by user'"));
		
		КонецЕсли;
											
	ИначеЕсли ПолеРасшифровки = "ГруппаДоступа" Тогда
		
		ДобавитьСтрокуВМенюРасшифровки(Результат, НСтр("ru = 'Открыть '; en = 'Open'"),	ЗначениеРасшифровки);
		
		ОтборОтчета = Новый Структура;
		ОтборОтчета.Вставить("ГруппаДоступа", ЗначениеРасшифровки);
		НастройкиОтчетаРасшифровки = НастройкиОтчетаРасшифровки("ГруппаДоступа,Пользователь", ОтборОтчета);
		
		ДобавитьИнструментВМенюРасшифровки(Результат, ИТК_Перечисления.ИнструментАнализПравДоступа(), НастройкиОтчетаРасшифровки,
											НСтр("ru = 'Пользователи по группе'; en = 'Users by group'"));

		ОтборОтчета = Новый Структура;
		ОтборОтчета.Вставить("ГруппаДоступа", ЗначениеРасшифровки);
		НастройкиОтчетаРасшифровки = НастройкиОтчетаРасшифровки("ПрофильГруппДоступа,Роль", ОтборОтчета);
		
		ДобавитьИнструментВМенюРасшифровки(Результат, ИТК_Перечисления.ИнструментАнализПравДоступа(), НастройкиОтчетаРасшифровки,
											НСтр("ru = 'Роли по группе'; en = 'Roles by group'"));
		
	ИначеЕсли ПолеРасшифровки = "ПрофильГруппДоступа" Тогда
		
		ДобавитьСтрокуВМенюРасшифровки(Результат, НСтр("ru = 'Открыть '; en = 'Open'"),	ЗначениеРасшифровки);
		
		ОтборОтчета = Новый Структура;
		ОтборОтчета.Вставить("ПрофильГруппДоступа", ЗначениеРасшифровки);
		НастройкиОтчетаРасшифровки = НастройкиОтчетаРасшифровки("ГруппаДоступа,Пользователь", ОтборОтчета);
		
		ДобавитьИнструментВМенюРасшифровки(Результат, ИТК_Перечисления.ИнструментАнализПравДоступа(), НастройкиОтчетаРасшифровки,
											НСтр("ru = 'Пользователи по профилю'; en = 'Users by profile'"));

		ОтборОтчета = Новый Структура;
		ОтборОтчета.Вставить("ПрофильГруппДоступа", ЗначениеРасшифровки);
		НастройкиОтчетаРасшифровки = НастройкиОтчетаРасшифровки("ПрофильГруппДоступа,Роль", ОтборОтчета);
		
		ДобавитьИнструментВМенюРасшифровки(Результат, ИТК_Перечисления.ИнструментАнализПравДоступа(), НастройкиОтчетаРасшифровки,
											НСтр("ru = 'Роли по профилю'; en = 'Roles by profile'"));
		
	ИначеЕсли ПолеРасшифровки = "Роль" Тогда

		ПолноеИмяМетаданных = "Роль." + ЗначениеРасшифровки;
		ДобавитьИнструментВМенюРасшифровки(Результат, ИТК_Перечисления.ИнструментМетаданные(), ПолноеИмяМетаданных);
											
		ОтборОтчета = Новый Структура;
		ОтборОтчета.Вставить("Роль", ЗначениеРасшифровки);
		НастройкиОтчетаРасшифровки = НастройкиОтчетаРасшифровки("ПрофильГруппДоступа,ГруппаДоступа,Пользователь", ОтборОтчета);
		
		ДобавитьИнструментВМенюРасшифровки(Результат, ИТК_Перечисления.ИнструментАнализПравДоступа(), НастройкиОтчетаРасшифровки,
											НСтр("ru = 'Профили/Группы/Пользователи по роли'; en = 'Profiles/Groups/Users by role'"));
											
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ЗавершениеВыбораМенюРасшифровки(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйЭлемент = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ВыбранноеЗначение = ВыбранныйЭлемент.Значение;
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") Тогда
		ИТК_ТуллкитКлиент.ОткрытьИнструмент(ВыбранноеЗначение["Инструмент"], ВыбранноеЗначение["Параметр"]);
	Иначе
		ПоказатьЗначение(, ВыбранноеЗначение);
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДобавитьИнструментВМенюРасшифровки(Меню, Инструмент, Параметр, Представление = Неопределено)
	
	ОписаниеИнструмента = ИТК_ТуллкитКлиентСервер.ОписаниеИнструмента(Инструмент);

	ОписаниеЗначенияСтроки = Новый Структура;
	ОписаниеЗначенияСтроки.Вставить("Инструмент", Инструмент);
	ОписаниеЗначенияСтроки.Вставить("Параметр", Параметр);
	
	Если Представление = Неопределено Тогда 
		Представление = ОписаниеИнструмента.Представление;
	КонецЕсли;
	
	Меню.Добавить(ОписаниеЗначенияСтроки, Представление, , ОписаниеИнструмента.Картинка);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДобавитьСтрокуВМенюРасшифровки(Меню, Заголовок, Значение, Картинка = Неопределено)
	
	Если Картинка = Неопределено Тогда
		Картинка = Новый Картинка;
	КонецЕсли;
	
	Меню.Добавить(Значение, Заголовок, , Картинка);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НастройкиОтчетаРасшифровки(Группировки, Отбор)
	
	Результат = Новый Структура;
	Результат.Вставить("Группировки", Группировки);
	Результат.Вставить("Отбор", Отбор);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
