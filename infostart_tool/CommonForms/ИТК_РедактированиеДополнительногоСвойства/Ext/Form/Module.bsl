#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Изменение Тогда
		
		Заголовок = НСтр("ru = 'Добавление дополнительного свойства';
						|en = 'Adding an additional property'");
		
	Иначе		
		
		Заголовок = НСтр("ru = 'Редактирование дополнительного свойства';
						|en = 'Editing an additional property'");
		
	КонецЕсли;

	ИТК_ПроверкаОшибокВФорме.Инициализировать(ЭтотОбъект);

	Имя = Параметры.Имя;
	Значение = Параметры.Значение;
	
	ЗанятыеИдентификаторы.ЗагрузитьЗначения(Параметры.ЗанятыеИдентификаторы);
	ИТК_ПодключаемыеКоманды.ИнструментыКПолю(ЭтотОбъект, "Значение", Истина, Истина);	
	
	// Загружаем используемые дополнительные свойства
	ОбщиеНастройки = ИТК_Настройки.Загрузить();
	ИспользуемыеДополнительныеСвойства = ОбщиеНастройки["ИспользуемыеДополнительныеСвойства"];
	Элементы.Имя.СписокВыбора.ЗагрузитьЗначения(ИспользуемыеДополнительныеСвойства);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИТК_ФормаКлиент.АктивизацияЗначенияВФорме(Элементы.Значение, Значение);
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ИдентификаторПриИзменении(Элемент)
	
	ПодключитьОбработчикОжидания("ПриИзмененииДанныхПослеОжидания", 0.1, Истина);	
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначениеПриИзменении(Элемент)
	
	ПодключитьОбработчикОжидания("ПриИзмененииДанныхПослеОжидания", 0.1, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.НачалоВыбораЗначенияВФорме(ЭтотОбъект, "Значение", НСтр("ru = 'Значение';
																			|en = 'Value'"), СтандартнаяОбработка, , , "");
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначениеОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Значение = Неопределено;
	
	ЗначениеПриИзменении(Элемент);
	ИТК_ФормаКлиент.АктивизацияЗначенияВФорме(Элемент, Значение);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначениеОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.ОбработкаВыбораЗначенияВФорме(Элемент, ВыбранноеЗначение, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначениеАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.АвтоПодборЗначенияВФорме(Текст, Элемент, ДанныеВыбора, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОшибкиОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	ИТК_ПроверкаОшибокВФормеКлиент.ОбработкаНавигационнойСсылки(ЭтотОбъект, Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОК(Команда)
	
	ОшибкиЗаполнения = ПроверкаЗаполнения();
	
	Если ЗначениеЗаполнено(ОшибкиЗаполнения) Тогда
		
		ИТК_ПроверкаОшибокВФормеКлиент.ТекущийЭлементПоПервой(ЭтотОбъект, ОшибкиЗаполнения);
		
	Иначе
		
		Результат = Новый Структура;
		Результат.Вставить("Имя", Имя);
		Результат.Вставить("Значение", Значение);
		
		Закрыть(Результат);
		
	КонецЕсли;
	
КонецПроцедуры

#Область ПодключаемыеКоманды

&НаКлиенте
Процедура ПодключаемаяКоманда(Команда)
	
	ИТК_ПоискСсылокКлиент.ОбработатьПодключеннуюКоманду(ЭтотОбъект, Команда.Имя);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	ИТК_ПроверкаОшибокВФормеКлиент.Обновить(ЭтотОбъект, ПроверкаЗаполнения());
	ИТК_ПодключаемыеКомандыКлиент.ОбновитьЭлементы(ЭтотОбъект, Элементы.Значение);
	
КонецПроцедуры
	
&НаКлиенте
Процедура ПриИзмененииДанныхПослеОжидания()

	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаКлиенте
Функция ПроверкаЗаполнения()
	
	Результат = Новый СписокЗначений;
	
	ОшибкиИмени = ИТК_Строки.ПроверкаИдентификатора(Имя, ЗанятыеИдентификаторы.ВыгрузитьЗначения(), "_");	
	
	Для Каждого Ошибка Из ОшибкиИмени Цикл
		Результат.Добавить("Имя", Ошибка);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти