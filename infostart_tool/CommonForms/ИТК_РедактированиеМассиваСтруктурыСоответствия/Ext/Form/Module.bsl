#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	НачальноеЗначение = Параметры.НачальноеЗначение.Получить();
	
	ТипЗначения = ТипЗнч(НачальноеЗначение);
	Заголовок = СтрШаблон(НСтр("ru = 'Редактирование значения: %1'; en = 'Editing value: %1'"), ТипЗначения);
	
	ЭтоМассив = (ТипЗначения = Тип("Массив") ИЛИ ТипЗначения = Тип("ФиксированныйМассив"));
	ЭтоСтруктура = (ТипЗначения = Тип("Структура") ИЛИ ТипЗначения = Тип("ФиксированнаяСтруктура"));
	ЭтоСоответствие = (ТипЗначения = Тип("Соответствие") ИЛИ ТипЗначения = Тип("ФиксированноеСоответствие"));
	
	// Инициализация значения
	Если ЭтоМассив Тогда
		
		Для Каждого ЭлементЗначение Из НачальноеЗначение Цикл 
			
			НоваяСтрока = ТаблицаЗначения.Добавить();
			НоваяСтрока.Значение = ЭлементЗначение;
			ЗаполнитьПредставленияСтроки(НоваяСтрока);
			
		КонецЦикла;
		
	Иначе
		
		Для Каждого КлючИЗначение Из НачальноеЗначение Цикл 
			
			НоваяСтрока = ТаблицаЗначения.Добавить();
			НоваяСтрока.Ключ = КлючИЗначение.Ключ;
			НоваяСтрока.Значение = КлючИЗначение.Значение;
			ЗаполнитьПредставленияСтроки(НоваяСтрока);
			
		КонецЦикла;
		
	КонецЕсли;
	
	// Инициализация элементов
	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.ТаблицаЗначения);
	Если ЭтоСтруктура Тогда
		Элементы.ТаблицаЗначенияКлючПредставление.ОграничениеТипа = ИТК_ТипыКлиентСервер.ОписаниеСтрока();
	КонецЕсли;
	Элементы.ТаблицаЗначенияКлючПредставление.Видимость =  ЭтоСтруктура ИЛИ ЭтоСоответствие;
	
	Элементы.ТаблицаЗначения.ИзменятьПорядокСтрок = ЭтоМассив;
	Элементы.ТаблицаЗначенияПорядок.Видимость = ЭтоМассив;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТаблицаЗначения

&НаКлиенте
Процедура ТаблицаЗначенияПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущиеДанные.Значение = Неопределено Тогда
		ТекущиеДанные.Значение = ИТК_ПроизвольноеЗначениеВызовСервера.ЗначениеНеопределено();
	КонецЕсли;
	ИТК_ПроизвольноеЗначениеКлиент.АктивизацияЗначенияВФорме(Элементы.ТаблицаЗначенияЗначениеПредставление, ТекущиеДанные.Значение);
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаЗначенияПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	Если Копирование Тогда
		
		ТекущиеДанные = Элемент.ТекущиеДанные;
		ИТК_ПроизвольноеЗначениеКлиент.АктивизацияЗначенияВФорме(Элементы.ТаблицаЗначенияЗначениеПредставление, ТекущиеДанные.Значение);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаЗначенияПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	
	Если ОтменаРедактирования Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Ошибки = Новый Массив;
	Если ЭтоСтруктура Тогда
		
		Если ЗначениеЗаполнено(ТекущиеДанные.КлючПредставление) Тогда
			
			Если ИТК_Строки.НекорректныйИдентификатор(ТекущиеДанные.КлючПредставление) Тогда
				Ошибки.Добавить(НСтр("ru = 'Некорректный ключ'; en = 'Incorrect key'"));
			КонецЕсли;
			
		Иначе
			Ошибки.Добавить(НСтр("ru = 'Не заполнен ключ'; en = 'Key is not filled'"));
		КонецЕсли;
		
	КонецЕсли;
	
	// Проверка дублирования ключа
	Если ЭтоСтруктура ИЛИ ЭтоСоответствие Тогда
		
		Для Каждого Строка Из ТаблицаЗначения Цикл 
			
			Если Строка.ПолучитьИдентификатор() = ТекущиеДанные.ПолучитьИдентификатор() Тогда
				Продолжить;
			КонецЕсли;
			
			Если Строка.Ключ = ТекущиеДанные.Ключ Тогда
				
				Ошибки.Добавить(НСтр("ru = 'Ключ не уникален'; en = 'Кey is not unique'"));
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Ошибки) Тогда
		
		ПоказатьПредупреждение( , СтрСоединить(Ошибки, Символы.ПС));
		Отказ = Истина;
		Возврат;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаЗначенияКлючПредставлениеПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ТаблицаЗначения.ТекущиеДанные;
	ТекущиеДанные.Ключ = ТекущиеДанные.КлючПредставление;
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаЗначенияКлючПредставлениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("ВводКлючаЗавершен", ЭтотОбъект, Новый Структура);
	
	ИТК_ПроизвольноеЗначениеКлиент.ОбработкаНачалоВыбора(Элемент, Элементы.ТаблицаЗначения.ТекущиеДанные.Ключ,
		ОписаниеОповещенияЗавершение, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаЗначенияЗначениеПредставлениеПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ТаблицаЗначения.ТекущиеДанные;
	ТекущиеДанные.Значение = ТекущиеДанные.ЗначениеПредставление;
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаЗначенияЗначениеПредставлениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("ВводЗначенияЗавершен", ЭтотОбъект, Новый Структура);
	
	ИТК_ПроизвольноеЗначениеКлиент.ОбработкаНачалоВыбора(Элемент, Элементы.ТаблицаЗначения.ТекущиеДанные.Значение,
		ОписаниеОповещенияЗавершение, СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Сохранить(Команда)
	Закрыть(ЗначениеРезультат());
КонецПроцедуры

&НаКлиенте
Процедура Отмена(Команда)
	Закрыть();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьПредставленияСтроки(Строка)
	
	ОписаниеЗначенияКлюч = ИТК_ПроизвольноеЗначение.ОписаниеЗначения(Строка.Ключ);
	Строка.КлючПредставление = ОписаниеЗначенияКлюч.Значение;
	
	ОписаниеЗначенияЗначение = ИТК_ПроизвольноеЗначение.ОписаниеЗначения(Строка.Значение);
	Строка.ЗначениеПредставление = ОписаниеЗначенияЗначение.Значение;
	
КонецПроцедуры

&НаСервере
Функция ЗначениеРезультат()
	
	Если ЭтоСтруктура Тогда
		Результат = Новый Структура;
	ИначеЕсли ЭтоСоответствие Тогда
		Результат = Новый Соответствие;
	Иначе
		Результат = Новый Массив;
	КонецЕсли;
	
	Для Каждого Строка Из ТаблицаЗначения Цикл
		
		Если ЭтоМассив Тогда
			Результат.Добавить(Строка.Значение);
		Иначе
			
			Значение = ИТК_ПроизвольноеЗначение.ОписаниеЗначения(Строка.Значение).Значение;
			Ключ = ИТК_ПроизвольноеЗначение.ОписаниеЗначения(Строка.Ключ).Значение;
			Результат.Вставить(Ключ, Значение);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ТипЗначения = Тип("ФиксированнаяСтруктура") Тогда
		Результат = Новый ФиксированнаяСтруктура(Результат);
	ИначеЕсли ТипЗначения = Тип("ФиксированноеСоответствие") Тогда
		Результат = Новый ФиксированноеСоответствие(Результат);
	ИначеЕсли ТипЗначения = Тип("ФиксированныйМассив") Тогда
		Результат = Новый ФиксированныйМассив(Результат);
	КонецЕсли;
	
	Возврат Новый ХранилищеЗначения(Результат);
	
КонецФункции

&НаКлиенте
Процедура ВводЗначенияЗавершен(НовоеЗначение, ДополнительныеПараметры) Экспорт
	
	Если НовоеЗначение = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элементы.ТаблицаЗначения.ТекущиеДанные;
	
	ВыборТипа = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "ВыборТипа", Ложь);
	Если ВыборТипа Тогда 
		ОбновитьЗначениеСтрокиПоТипуНаСервере(ТекущиеДанные.ПолучитьИдентификатор(), НовоеЗначение);
	Иначе
		ОбновитьЗначениеНаСервере(ТекущиеДанные.ПолучитьИдентификатор(), НовоеЗначение);
	КонецЕсли;
	
	ИТК_ПроизвольноеЗначениеКлиент.АктивизацияЗначенияВФорме(Элементы.ТаблицаЗначенияЗначениеПредставление, ТекущиеДанные.Значение);
	
КонецПроцедуры

&НаКлиенте
Процедура ВводКлючаЗавершен(НовыйКлюч, ДополнительныеПараметры) Экспорт
	
	Если НовыйКлюч = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элементы.ТаблицаЗначения.ТекущиеДанные;
	
	ВыборТипа = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "ВыборТипа", Ложь);
	Если ВыборТипа Тогда 
		ОбновитьКлючСтрокиПоТипуНаСервере(ТекущиеДанные.ПолучитьИдентификатор(), НовыйКлюч);
	Иначе
		ОбновитьКлючНаСервере(ТекущиеДанные.ПолучитьИдентификатор(), НовыйКлюч);
	КонецЕсли;
	
	ИТК_ПроизвольноеЗначениеКлиент.АктивизацияЗначенияВФорме(Элементы.ТаблицаЗначенияКлючПредставление, ТекущиеДанные.Значение);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьКлючСтрокиПоТипуНаСервере(ИдентификаторСтроки, ТипЗначенияВКонтейнере)
	
	НовоеЗначение = ТипЗначенияВКонтейнере.Получить().ПривестиЗначение(Неопределено);
	ОбновитьКлючНаСервере(ИдентификаторСтроки, НовоеЗначение);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьКлючНаСервере(ИдентификаторСтроки, НовоеЗначение)
	
	ОписаниеЗначенияКлюча = ИТК_ПроизвольноеЗначение.ОписаниеЗначения(НовоеЗначение);
	
	Строка = ТаблицаЗначения.НайтиПоИдентификатору(ИдентификаторСтроки);
	Если ОписаниеЗначенияКлюча.РедактируетсяВПоле Тогда
		Строка.Ключ = НовоеЗначение;
	Иначе
		
		Если ТипЗнч(НовоеЗначение) = Тип("ХранилищеЗначения") Тогда
			Строка.Ключ = НовоеЗначение;
		Иначе
			Строка.Ключ = Новый ХранилищеЗначения(НовоеЗначение);
		КонецЕсли;
		
	КонецЕсли;
	
	Строка.КлючПредставление = ОписаниеЗначенияКлюча.Значение;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьЗначениеСтрокиПоТипуНаСервере(ИдентификаторСтроки, ТипЗначенияВКонтейнере)
	
	НовоеЗначение = ТипЗначенияВКонтейнере.Получить().ПривестиЗначение(Неопределено);
	ОбновитьЗначениеНаСервере(ИдентификаторСтроки, НовоеЗначение);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьЗначениеНаСервере(ИдентификаторСтроки, НовоеЗначение)
	
	ОписаниеЗначения = ИТК_ПроизвольноеЗначение.ОписаниеЗначения(НовоеЗначение);
	
	Строка = ТаблицаЗначения.НайтиПоИдентификатору(ИдентификаторСтроки);
	Если ОписаниеЗначения.РедактируетсяВПоле Тогда
		Строка.Значение = НовоеЗначение;
	Иначе
		
		Если ТипЗнч(НовоеЗначение) = Тип("ХранилищеЗначения") Тогда
			Строка.Значение = НовоеЗначение;
		Иначе
			Строка.Значение = Новый ХранилищеЗначения(НовоеЗначение);
		КонецЕсли;
		
	КонецЕсли;
	
	Строка.ЗначениеПредставление = ОписаниеЗначения.Значение;
	
КонецПроцедуры

#КонецОбласти