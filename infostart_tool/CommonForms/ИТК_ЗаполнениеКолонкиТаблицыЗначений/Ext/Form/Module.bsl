
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТипЗаполнения = "Выделенные";
	Заголовок = СтрШаблон(НСтр("ru = 'Заполнение колонки %1';
								|en = 'Column fill %1'"), Параметры.Имя);
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Параметры, "ДопустимыеТипы, Имя, Значение");
	
	Элементы.Значение.ОграничениеТипа = ДопустимыеТипы;
	
	ТекущийЭлемент = Элементы.Значение;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаОК(Команда)
	
	Результат = Новый Структура;
	
	Если ТипЗаполнения = "Все" Тогда
		Результат.Вставить("ЗаполнятьВсе");
	КонецЕсли;
	
	Результат.Вставить("Имя", Имя);
	Результат.Вставить("Значение", Значение);
	
	Закрыть(Результат);
	
КонецПроцедуры

#КонецОбласти
