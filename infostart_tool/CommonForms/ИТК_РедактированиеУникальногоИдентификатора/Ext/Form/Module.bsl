#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Значение = Параметры.Значение;
	
	ШаблонЗаголовка = НСтр("ru = 'Редактирование уникального идентификатора %1';
							|en = 'Editing a unique identifier %1'");
	Заголовок = СтрШаблон(ШаблонЗаголовка, Параметры.Заголовок);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ЗначениеПриИзменении(Элемент)
	
	Если ПустаяСтрока(Значение) Тогда
		Значение = ИТК_Строки.ПустойУникальныйИдентификатор();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РедактируемоеЗначениеОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Значение = ИТК_Строки.ПустойУникальныйИдентификатор();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СохранитьИЗакрыть(Команда)
	
	Закрыть(Новый УникальныйИдентификатор(Значение));
	
КонецПроцедуры

&НаКлиенте
Процедура Сгенерировать(Команда)
	
	Значение = Новый УникальныйИдентификатор;
	Модифицированность = Истина;
	
КонецПроцедуры

#КонецОбласти
