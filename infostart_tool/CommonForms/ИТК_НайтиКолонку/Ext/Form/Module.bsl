#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.Колонки, ПоложениеСтрокиПоиска.ЗаголовокФормы);
	
	// Заполнение списка колонок
	Для Каждого ЭлементКолонка Из Параметры.Колонки Цикл 
		
		НоваяСтрока = Колонки.Добавить();
		НоваяСтрока.Имя = ЭлементКолонка.Значение;
		НоваяСтрока.Представление = ЭлементКолонка.Представление;
		НоваяСтрока.Картинка = ЭлементКолонка.Картинка;
		
	КонецЦикла;
	
	// Утсановка текущей строки
	Отбор = Новый Структура("Имя", Параметры.Имя);
	НайденныеСтроки = Колонки.НайтиСтроки(Отбор);
	Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
		Элементы.Колонки.ТекущаяСтрока = НайденныеСтроки[0].ПолучитьИдентификатор();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыКолонки

&НаКлиенте
Процедура КолонкиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Выбрать();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Выбрать(Команда = Неопределено)
	
	ТекущиеДанные = Элементы.Колонки.ТекущиеДанные;
	Закрыть(ТекущиеДанные.Имя);
	
КонецПроцедуры

#КонецОбласти
