#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Добавление Тогда
		
		Заголовок = НСтр("ru = 'Добавление подключения к кластеру';
						|en = 'Adding a connection to the cluster'");
		
	Иначе
		
		Заголовок = НСтр("ru = 'Редактирование подключения к кластеру';
						|en = 'Editing the connection to the cluster'");
		
	КонецЕсли;
	
	ОписаниеПодключения = Параметры.ОписаниеПодключения;
	Если ЗначениеЗаполнено(ОписаниеПодключения) Тогда 
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ОписаниеПодключения);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ПроверитьПодключение();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПодключениеОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура СерверПриИзменении(Элемент)
	
	ТребуетсяПроверкаСоединения();
	
КонецПроцедуры

&НаКлиенте
Процедура АдминистраторПриИзменении(Элемент)
	
	ТребуетсяПроверкаСоединения();
	
КонецПроцедуры

&НаКлиенте
Процедура ПарольПриИзменении(Элемент)
	
	ТребуетсяПроверкаСоединения();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Сохранить(Команда)
	
	ОписаниеПодключения = ИТК_ПодключениеКСерверамКлиентСервер.ОписаниеПодключения();
	ЗаполнитьЗначенияСвойств(ОписаниеПодключения, ЭтотОбъект);
	
	Закрыть(ОписаниеПодключения);

КонецПроцедуры

&НаКлиенте
Процедура ПроверитьПодключение(Команда = Неопределено)
	
	СостояниеПроверкиПодключения(НСтр("ru = 'Проверка подключения';
										|en = 'Checking the connection'"), БиблиотекаКартинок.ИТК_ДлительнаяОперацияАнимация16);
	
	ПараметрыПодключения = Новый Структура;
	ПараметрыПодключения.Вставить("Подключение", Подключение);
	ПараметрыПодключения.Вставить("Сервер", Сервер);
	ПараметрыПодключения.Вставить("Администратор", Администратор);
	ПараметрыПодключения.Вставить("Пароль", Пароль);
	ДлительнаяОперацияПроверкаПодключения = ПроверитьПодключениеНаСервере(УникальныйИдентификатор, ПараметрыПодключения);
	
	ПараметрыОжидания = ИТК_ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершенаПроверкаПодключения", ЭтотОбъект);
	ИТК_ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперацияПроверкаПодключения, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
Функция ПроверитьПодключениеНаСервере(УникальныйИдентификатор, ПараметрыПодключения)
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_ПодключениеКСерверам.Проверка", ПараметрыПодключения, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ЗавершенаПроверкаПодключения(Результат, ДополнительныеПараметры) Экспорт
	
	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		РезультатПроверки = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		
		Если РезультатПроверки = Неопределено Тогда
			
			СостояниеПроверкиПодключения(НСтр("ru = 'Проверено';
												|en = 'Verified'"), БиблиотекаКартинок.ИТК_УспешноПроверено);
			
		Иначе
			
			СостояниеПроверкиПодключения(РезультатПроверки, БиблиотекаКартинок.ИТК_ПредупреждениеВажное);
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура СостояниеПроверкиПодключения(Состояние, Картинка = Неопределено)
	
	Элементы.РезультатПроверкиСообщение.Заголовок = Состояние;
	Элементы.РезультатПроверкиКартинка.Картинка = Картинка;
	
КонецПроцедуры

&НаКлиенте
Процедура ТребуетсяПроверкаСоединения()
	
	СостояниеПроверкиПодключения(НСтр("ru = 'Не проверено (настройки изменены)';
										|en = 'Not tested (settings changed)'"), БиблиотекаКартинок.ИТК_Информация);
	
КонецПроцедуры

#КонецОбласти
