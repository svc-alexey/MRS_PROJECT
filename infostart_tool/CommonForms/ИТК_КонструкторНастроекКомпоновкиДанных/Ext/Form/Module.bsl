#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Инициализация всмомогательных компоновщиков
	ИнициализироватьКомпоновщикНастроек("КомпоновщикНастроек1");
	ИнициализироватьКомпоновщикНастроек("КомпоновщикНастроек2");

	// Определение типа отчета, начальная инициализация
	ИнициализироватьКомпоновщикНастроек("КомпоновщикНастроек");

	НастройкиВарианта = ПолучитьИзВременногоХранилища(Параметры.АдресНастроек);
	ИТК_СКД.СкопироватьЭлементы(КомпоновщикНастроек.Настройки.Порядок, НастройкиВарианта.Порядок);
	
	ТипОтчета = Неопределено;
	ОсновнаяГруппировка = ОсновнаяГруппировкаКомпоновщика(ЭтотОбъект);
	
	РодительСтруктура = НастройкиВарианта.Структура;
	Пока ЗначениеЗаполнено(РодительСтруктура) Цикл 
		
		ЭлементСтруктуры = РодительСтруктура[0];
		
		Если ТипЗнч(ЭлементСтруктуры) = Тип("ГруппировкаКомпоновкиДанных")
				И ЗначениеЗаполнено(ЭлементСтруктуры.ПоляГруппировки.Элементы) Тогда
				
			НовоеПолеГруппировки = ОсновнаяГруппировка.ПоляГруппировки.Элементы.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
			ПервоеПолеГруппировки = ЭлементСтруктуры.ПоляГруппировки.Элементы[0];
			ЗаполнитьЗначенияСвойств(НовоеПолеГруппировки, ПервоеПолеГруппировки);
			
		ИначеЕсли ТипЗнч(ЭлементСтруктуры) = Тип("ТаблицаКомпоновкиДанных") Тогда
			
			ТипОтчета = "Таблица";
			ЗаполнитьГруппировкиКомпоновщикаПоКоллекции("КомпоновщикНастроек1", ЭлементСтруктуры.Строки);
			ЗаполнитьГруппировкиКомпоновщикаПоКоллекции("КомпоновщикНастроек2", ЭлементСтруктуры.Колонки);
			Прервать;
			
		ИначеЕсли ТипЗнч(ЭлементСтруктуры) = Тип("ДиаграммаКомпоновкиДанных") Тогда
			
			ТипОтчета = "Диаграмма";
			ЗаполнитьГруппировкиКомпоновщикаПоКоллекции("КомпоновщикНастроек1", ЭлементСтруктуры.Серии);
			ЗаполнитьГруппировкиКомпоновщикаПоКоллекции("КомпоновщикНастроек2", ЭлементСтруктуры.Точки);
			
			ТипДиаграммыВарианта = ЭлементСтруктуры.ПараметрыВывода.НайтиЗначениеПараметра(ПараметрыВыводаТипДиаграммы()).Значение;
			Диаграмма.ТипДиаграммы = ТипДиаграммыВарианта;
			КомпоновщикНастроек.Настройки.ПараметрыВывода.УстановитьЗначениеПараметра(ПараметрыВыводаТипДиаграммы(), ТипДиаграммыВарианта);
			
			Прервать;

		КонецЕсли;
		
		РодительСтруктура = ЭлементСтруктуры.Структура;
		
	КонецЦикла;
	
	Если НЕ ЗначениеЗаполнено(ТипОтчета) Тогда
		ТипОтчета = "Список";
	КонецЕсли;
	
	// Добавление поля тип диаграммы
	ЭлементТипДиаграммы = Элементы.Вставить("ТипДиаграммы", Тип("ПолеФормы"), Элементы.СтраницаТипДиаграммы, Элементы.Диаграмма);
	ЭлементТипДиаграммы.Вид = ВидПоляФормы.ПолеВвода;
	ЭлементТипДиаграммы.Заголовок = НСтр("ru = 'Тип диаграммы'; en = 'Chart type'");
	ЭлементТипДиаграммы.Ширина = 100;
	
	ИнициализацияДанныхДиаграммы();
	
	ПараметрыВывода = КомпоновщикНастроек.Настройки.ПараметрыВывода;
	ПараметрВывода = ПараметрыВывода.НайтиЗначениеПараметра(ПараметрыВыводаТипДиаграммы());
	ИндексПараметраВывода = ПараметрыВывода.Элементы.Индекс(ПараметрВывода);
	
	ЭлементТипДиаграммы.ПутьКДанным = СтрШаблон("КомпоновщикНастроек.Настройки.ПараметрыВывода[%1].Значение", ИндексПараметраВывода);
	ЭлементТипДиаграммы.УстановитьДействие("ПриИзменении", "ПодключаемыйТипДиаграммыПриИзменении");
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ТипОтчетаПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйТипДиаграммыПриИзменении(Элемент)
	
	ПолеТипДиаграммы = КомпоновщикНастроек.Настройки.ПараметрыВывода.НайтиЗначениеПараметра(ПараметрыВыводаТипДиаграммы()).Значение;
	Диаграмма.ТипДиаграммы = ПолеТипДиаграммы;
	
	Модифицированность = Истина;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыКомпоновщикНастроекНастройкиВыборДоступныеПоляВыбора

&НаКлиенте
Процедура КомпоновщикНастроекНастройкиВыборДоступныеПоляВыбораВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Модифицированность = Истина;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыКомпоновщикНастроекНастройкиПорядокДоступныеПоляПорядка

&НаКлиенте
Процедура КомпоновщикНастроекНастройкиПорядокДоступныеПоляПорядкаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Модифицированность = Истина;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыКомпоновщикНастроекНастройкиЭлементПоляГруппировкиДоступныеПоляПолейГруппировокВыбор

&НаКлиенте
Процедура КомпоновщикНастроекНастройкиЭлементПоляГруппировкиДоступныеПоляПолейГруппировокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Модифицированность = Истина;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыКомпоновщикНастроекНастройкиЭлементПоляГруппировкиРасширенныеДоступныеПоляПолейГруппировок

&НаКлиенте
Процедура КомпоновщикНастроекНастройкиЭлементПоляГруппировкиРасширенныеДоступныеПоляПолейГруппировокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Далее(Команда)
	
	Если ТипОтчета = "Диаграмма"
			И Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаВыбранныеПоля Тогда
		
		КоличествоРесурсовВВыбранныхПолях = 0;
		Для Каждого ВыбранноеПоле Из КомпоновщикНастроек.Настройки.Выбор.Элементы Цикл 
			
			ДоступноеПоле = КомпоновщикНастроек.Настройки.ДоступныеПоляВыбора.НайтиПоле(ВыбранноеПоле.Поле);
			Если ДоступноеПоле.Ресурс Тогда
				КоличествоРесурсовВВыбранныхПолях = КоличествоРесурсовВВыбранныхПолях + 1;
			КонецЕсли;

		КонецЦикла;
		
		Если КоличествоРесурсовВВыбранныхПолях <> 1 Тогда
			
			ПоказатьПредупреждение( , НСтр("ru = 'Выбранные поля диграммы должны содержать только один ресурс.';
											|en = 'The selected chart fields must contain only one resource.'"));
			Возврат;
			
		КонецЕсли;
		
	КонецЕсли;
	//
	
	Элементы.Страницы.ТекущаяСтраница = СледующаяСтраница();
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура Назад(Команда)
	
	Элементы.Страницы.ТекущаяСтраница = СледующаяСтраница(-1);
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаОК(Команда)
	
	Результат = РезультатНастройкиКомпоновкиДанных();
	Закрыть(Результат);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбранныеПоляУдалить(Команда)
	
	УдалитьВыделенныеПоляКоллекции("Выбор", Элементы.КомпоновщикНастроекНастройкиВыбор);
		
КонецПроцедуры

&НаКлиенте
Процедура ЭлементПоляГруппировкиУдалить(Команда)
	
	УдалитьВыделенныеПоляГруппировок("КомпоновщикНастроек", Элементы.КомпоновщикНастроекНастройкиЭлементПоляГруппировки);
	
КонецПроцедуры

&НаКлиенте
Процедура ПорядокПолейУдалить(Команда)
	
	УдалитьВыделенныеПоляКоллекции("Порядок", Элементы.КомпоновщикНастроекНастройкиПорядок);
		
КонецПроцедуры

&НаКлиенте
Процедура УдалитьВсеВыбранныеПоля(Команда)
	
	ВыбранныеПоля = КомпоновщикНастроек.Настройки.Выбор.Элементы;
	Если ЗначениеЗаполнено(ВыбранныеПоля) Тогда 
		
		Модифицированность = Истина;
		ВыбранныеПоля.Очистить();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьВсеПорядокПолей(Команда)
	
	ПоляУпорядочивания = КомпоновщикНастроек.Настройки.Порядок.Элементы;
	Если ЗначениеЗаполнено(ПоляУпорядочивания) Тогда 
		
		Модифицированность = Истина;
		ПоляУпорядочивания.Очистить();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьВсеГруппировки(Команда)
	
	ОсновнаяГруппировка = ОсновнаяГруппировкаКомпоновщика(ЭтотОбъект);
	
	Если ЗначениеЗаполнено(ОсновнаяГруппировка.ПоляГруппировки.Элементы) Тогда 
		
		Модифицированность = Истина;
		ОсновнаяГруппировка.ПоляГруппировок.Элементы.Очистить();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоляГруппировокРасширенныеДобавить(Команда)
	
	ДобавитьВыделенныеПоляВГруппировки("КомпоновщикНастроек", Элементы.КомпоновщикНастроекНастройкиЭлементПоляГруппировкиРасширенныеДоступныеПоляПолейГруппировок);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоляГруппировокРасширенныеУдалить(Команда)
	
	УдалитьВыделенныеПоляГруппировок("КомпоновщикНастроек", Элементы.КомпоновщикНастроекНастройкиЭлементПоляГруппировкиРасширенные);

КонецПроцедуры

&НаКлиенте
Процедура ПоляГруппировокРасширенныеСтрокиСерииДобавить(Команда)
	
	ДобавитьВыделенныеПоляВГруппировки("КомпоновщикНастроек1", Элементы.КомпоновщикНастроекНастройкиЭлементПоляГруппировкиРасширенныеДоступныеПоляПолейГруппировок);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоляГруппировокРасширенныеСтрокиСерииУдалить(Команда)
	
	УдалитьВыделенныеПоляГруппировок("КомпоновщикНастроек1", Элементы.КомпоновщикНастроек1НастройкиЭлементПоляГруппировкиРасширенные);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоляГруппировокРасширенныеКолонкиТочкиДобавить(Команда)
	
	ДобавитьВыделенныеПоляВГруппировки("КомпоновщикНастроек2", Элементы.КомпоновщикНастроекНастройкиЭлементПоляГруппировкиРасширенныеДоступныеПоляПолейГруппировок);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоляГруппировокРасширенныеКолонкиТочкиУдалить(Команда)
	
	УдалитьВыделенныеПоляГруппировок("КомпоновщикНастроек2", Элементы.КомпоновщикНастроек2НастройкиЭлементПоляГруппировкиРасширенные);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	Элементы.СтраницаГруппировки.Видимость = (ТипОтчета = "Список");
	Элементы.СтраницаГруппировкиРасширенные.Видимость = (ТипОтчета = "Таблица") ИЛИ (ТипОтчета = "Диаграмма");
	Элементы.СтраницаТипДиаграммы.Видимость = (ТипОтчета = "Диаграмма");
	
	Если ТипОтчета = "Таблица" Тогда
		
		ЗаголовокСтрокиСерии = НСтр("ru = 'Строки'; en = 'Rows'");
		ЗаголовокКолонкиТочки = НСтр("ru = 'Колонки'; en = 'Columns'");
		ЗаголовокТаблицыДиаграммы = НСтр("ru = 'Таблицы'; en = 'Tables'");
		
	Иначе 
		
		ЗаголовокСтрокиСерии = НСтр("ru = 'Серии'; en = 'Series'");
		ЗаголовокКолонкиТочки = НСтр("ru = 'Точки'; en = 'Points'");
		ЗаголовокТаблицыДиаграммы = НСтр("ru = 'Диаграммы'; en = 'Diagrams'");
		
	КонецЕсли;
	
	Элементы.КомпоновщикНастроек1НастройкиЭлементПоляГруппировкиРасширенные.Заголовок = ЗаголовокСтрокиСерии;
	Элементы.КомпоновщикНастроек2НастройкиЭлементПоляГруппировкиРасширенные.Заголовок = ЗаголовокКолонкиТочки;
	Элементы.КомпоновщикНастроекНастройкиЭлементПоляГруппировкиРасширенные.Заголовок = ЗаголовокТаблицыДиаграммы;
	
	Элементы.ФормаНазад.Доступность = НЕ ПерваяСтраница();
	Элементы.ФормаДалее.Доступность = НЕ ПоследняяСтраница();
	
КонецПроцедуры

&НаКлиенте
Функция ПоследняяСтраница()
	
	ВидимыеСтраницы = ВидимыеСтраницы();
	ПоследняяСтраница = ВидимыеСтраницы[ВидимыеСтраницы.ВГраница()];
	Возврат (Элементы.Страницы.ТекущаяСтраница = ПоследняяСтраница)
	
КонецФункции

&НаКлиенте
Функция ПерваяСтраница()
	
	ВидимыеСтраницы = ВидимыеСтраницы();
	ПерваяСтраница = ВидимыеСтраницы[0];
	Возврат (Элементы.Страницы.ТекущаяСтраница = ПерваяСтраница)
	
КонецФункции

&НаКлиенте
Функция СледующаяСтраница(Сдвиг = 1)
	
	ВидимыеСтраницы = ВидимыеСтраницы();
	Индекс = ВидимыеСтраницы.Найти(Элементы.Страницы.ТекущаяСтраница);
	
	Возврат ВидимыеСтраницы[Индекс + Сдвиг];
	
КонецФункции

&НаКлиенте
Функция ВидимыеСтраницы()
	
	Результат = Новый Массив;
	Для Каждого Страница Из Элементы.Страницы.ПодчиненныеЭлементы Цикл 
		
		Если НЕ Страница.Видимость Тогда
			Продолжить;
		КонецЕсли;
		
		Если Страница = Элементы.СтраницаСлужебная Тогда
			Продолжить;
		КонецЕсли;
		
		Результат.Добавить(Страница);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция РезультатНастройкиКомпоновкиДанных()
	
	РезультатКомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	РезультатКомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСхемыКомпоновкиДанных));
	
	ИТК_СКД.СкопироватьЭлементы(РезультатКомпоновщикНастроек.Настройки.Выбор, КомпоновщикНастроек.Настройки.Выбор);
	ИТК_СКД.СкопироватьЭлементы(РезультатКомпоновщикНастроек.Настройки.Порядок, КомпоновщикНастроек.Настройки.Порядок);
	
	// Добавление группировок
	РодительСтруктура = РезультатКомпоновщикНастроек.Настройки.Структура; 
	ОсновнаяГруппировка = ОсновнаяГруппировкаКомпоновщика(ЭтотОбъект);
		
	Для Каждого ЭлементПолеГруппировки Из ОсновнаяГруппировка.ПоляГруппировки.Элементы Цикл 
			
		ЭлементГруппировка = ДобавитьГрупиировкуАвтоПолеКомпоновкиДанных(РодительСтруктура);
		
		ОсновноеПолеГруппировки = ЭлементГруппировка.ПоляГруппировки.Элементы.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
		ЗаполнитьЗначенияСвойств(ОсновноеПолеГруппировки, ЭлементПолеГруппировки);
			
		РодительСтруктура = ЭлементГруппировка.Структура;
			
	КонецЦикла;
	
	Если ТипОтчета = "Список" Тогда
		
		// Детальные записи
		ЭлементДетальныеЗаписи = ДобавитьГрупиировкуАвтоПолеКомпоновкиДанных(РодительСтруктура);

	ИначеЕсли ТипОтчета = "Таблица" Тогда
		
		ЭлементТаблица = РодительСтруктура.Добавить(Тип("ТаблицаКомпоновкиДанных"));
		ЗаполнитьКоллекцииПоГруппировкеКомпоновщика(ЭлементТаблица.Строки, "КомпоновщикНастроек1", Истина);
		ЗаполнитьКоллекцииПоГруппировкеКомпоновщика(ЭлементТаблица.Колонки, "КомпоновщикНастроек2");
		
	ИначеЕсли ТипОтчета = "Диаграмма" Тогда
		
		ЭлементДиаграмма = РодительСтруктура.Добавить(Тип("ДиаграммаКомпоновкиДанных"));
		ЗаполнитьКоллекцииПоГруппировкеКомпоновщика(ЭлементДиаграмма.Серии, "КомпоновщикНастроек1");
		ЗаполнитьКоллекцииПоГруппировкеКомпоновщика(ЭлементДиаграмма.Точки, "КомпоновщикНастроек2");
		
		ТипДиаграммыВарианта = КомпоновщикНастроек.Настройки.ПараметрыВывода.НайтиЗначениеПараметра(ПараметрыВыводаТипДиаграммы()).Значение;
		ЭлементДиаграмма.ПараметрыВывода.УстановитьЗначениеПараметра(ПараметрыВыводаТипДиаграммы(), ТипДиаграммыВарианта);
		
	КонецЕсли;
	
	Возврат РезультатКомпоновщикНастроек.Настройки;
	
КонецФункции

&НаСервереБезКонтекста
Функция ДобавитьГрупиировкуАвтоПолеКомпоновкиДанных(Родитель)
	
	Если ТипЗнч(Родитель) = Тип("КоллекцияЭлементовСтруктурыТаблицыКомпоновкиДанных") Тогда
		НовыйЭлемент = Родитель.Добавить();
	Иначе
		НовыйЭлемент = Родитель.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
	КонецЕсли;
	
	НовыйЭлемент.Выбор.Элементы.Добавить(Тип("АвтоВыбранноеПолеКомпоновкиДанных"));
	НовыйЭлемент.Порядок.Элементы.Добавить(Тип("АвтоЭлементПорядкаКомпоновкиДанных"));
	
	Возврат НовыйЭлемент;
	
КонецФункции

&НаСервере
Процедура ИнициализироватьКомпоновщикНастроек(Имя)
	
	КомпоновщикНастроекЭлемент = Элементы[Имя + "Настройки"];
	КомпоновщикНастроекПриемник = ЭтотОбъект[Имя];
	
	АдресСхемыКомпоновкиДанных = Параметры.АдресСхемыКомпоновкиДанных;
	КомпоновщикНастроекПриемник.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСхемыКомпоновкиДанных));
	
	НастройкиВарианта = ПолучитьИзВременногоХранилища(Параметры.АдресНастроек);
	ИТК_СКД.СкопироватьЭлементы(КомпоновщикНастроекПриемник.Настройки.Выбор, НастройкиВарианта.Выбор);

	СтруктураНастроек = КомпоновщикНастроекПриемник.Настройки.Структура;
	ОсновнаяГруппировка = СтруктураНастроек.Добавить(Тип("ГруппировкаКомпоновкиДанных"));

	КомпоновщикНастроекЭлемент.ТекущаяСтрока = КомпоновщикНастроекПриемник.Настройки.ПолучитьИдентификаторПоОбъекту(ОсновнаяГруппировка);	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьГруппировкиКомпоновщикаПоКоллекции(Имя, Коллекция)
	
	ОсновнаяГруппировка = ОсновнаяГруппировкаКомпоновщика(ЭтотОбъект, Имя);

	РодительскаяКоллекция = Коллекция;
	Пока ЗначениеЗаполнено(РодительскаяКоллекция) Цикл 
		
		ЭлементКоллекции = РодительскаяКоллекция[0];
		
		Если ЗначениеЗаполнено(ЭлементКоллекции.ПоляГруппировки) Тогда
			
			НовоеПолеГруппировки = ОсновнаяГруппировка.ПоляГруппировки.Элементы.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
			ПервоеПолеГруппировки = ЭлементКоллекции.ПоляГруппировки.Элементы[0];
			ЗаполнитьЗначенияСвойств(НовоеПолеГруппировки, ПервоеПолеГруппировки);
			
		КонецЕсли;
		
		РодительскаяКоллекция = ЭлементКоллекции.Структура;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьКоллекцииПоГруппировкеКомпоновщика(Коллекция, Имя, ДетальныеЗаписи = Ложь)
	
	ОсновнаяГруппировка = ОсновнаяГруппировкаКомпоновщика(ЭтотОбъект, Имя);

	РодительГруппировки = Коллекция;
	Для Каждого ПолеГруппировки Из ОсновнаяГруппировка.ПоляГруппировки.Элементы Цикл 
		
		НоваяГруппировка = РодительГруппировки.Добавить();

		НовоеПолеГруппировки = НоваяГруппировка.ПоляГруппировки.Элементы.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
		ЗаполнитьЗначенияСвойств(НовоеПолеГруппировки, ПолеГруппировки);
		
		РодительГруппировки = НоваяГруппировка.Структура;
		
	КонецЦикла;
	
	Если ДетальныеЗаписи Тогда 
		ДобавитьГрупиировкуАвтоПолеКомпоновкиДанных(РодительГруппировки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ОсновнаяГруппировкаКомпоновщика(Форма, Имя = "КомпоновщикНастроек") 
	
	ЭлементКомпоновщикНастроек = Форма.Элементы[Имя + "Настройки"];
	Возврат Форма[Имя].Настройки.ПолучитьОбъектПоИдентификатору(ЭлементКомпоновщикНастроек.ТекущаяСтрока);
	
КонецФункции

&НаКлиенте
Процедура УдалитьВыделенныеПоляГруппировок(ИмяКомпоновщикаНастроек, ИзменяемыйЭлемент)
	
	ОсновнаяГруппировка = ОсновнаяГруппировкаКомпоновщика(ЭтотОбъект, ИмяКомпоновщикаНастроек);
	
	УдаляемыеПоля = Новый Массив;
	Для Каждого ИдентификаторПоля Из ИзменяемыйЭлемент.ВыделенныеСтроки Цикл 
		
		ПолеГруппировки = ОсновнаяГруппировка.ПоляГруппировки.ПолучитьОбъектПоИдентификатору(ИдентификаторПоля);
		УдаляемыеПоля.Добавить(ПолеГруппировки);

	КонецЦикла;
	
	Для Каждого УдаляемоеПоле Из УдаляемыеПоля Цикл 
		ОсновнаяГруппировка.ПоляГруппировки.Элементы.Удалить(УдаляемоеПоле);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьВыделенныеПоляКоллекции(Коллекция, ИзменяемыйЭлемент)
	
	ОсновнаяКоллекция = КомпоновщикНастроек.Настройки[Коллекция];
	
	УдаляемыеПоля = Новый Массив;
	Для Каждого ИдентификаторПоля Из ИзменяемыйЭлемент.ВыделенныеСтроки Цикл 
		
		Поле = ОсновнаяКоллекция.ПолучитьОбъектПоИдентификатору(ИдентификаторПоля);
		УдаляемыеПоля.Добавить(Поле);

	КонецЦикла;
	
	Для Каждого УдаляемоеПоле Из УдаляемыеПоля Цикл 
		ОсновнаяКоллекция.Элементы.Удалить(УдаляемоеПоле);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьВыделенныеПоляВГруппировки(ИмяКомпоновщикаНастроек, ЭлементИсточник)
	
	ОсновнаяГруппировка = ОсновнаяГруппировкаКомпоновщика(ЭтотОбъект, ИмяКомпоновщикаНастроек);
	
	Для Каждого ИдентификаторДоступногоПоля Из ЭлементИсточник.ВыделенныеСтроки Цикл 
		
		ДоступноеПоле = ОсновнаяГруппировка.ПоляГруппировки.ДоступныеПоляПолейГруппировок.ПолучитьОбъектПоИдентификатору(ИдентификаторДоступногоПоля);
		
		НовоеПолеГруппировки = ОсновнаяГруппировка.ПоляГруппировки.Элементы.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
		НовоеПолеГруппировки.Поле = ДоступноеПоле.Поле;

	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПараметрыВыводаТипДиаграммы()
	
	Возврат Новый ПараметрКомпоновкиДанных("ТипДиаграммы");
	
КонецФункции

&НаСервере
Процедура ИнициализацияДанныхДиаграммы()
	
	ГенераторСлучайныхЧисел = Новый ГенераторСлучайныхЧисел;
	Для НомерТочки = 1 По 4 Цикл 
		
		ПредставлениеТочки = СтрШаблон(НСтр("ru = 'Точка %1'; en = 'Point %1'"), НомерТочки);
		Точка = Диаграмма.УстановитьТочку(ПредставлениеТочки);
		
		Для НомерСерии = 1 По 4 Цикл 
			
			ПредставлениеСерии = СтрШаблон(НСтр("ru = 'Серия %1'; en = 'Series %1'"), НомерСерии);
			Серия = Диаграмма.УстановитьСерию(ПредставлениеСерии);
			
			Диаграмма.УстановитьЗначение(Точка, Серия, ГенераторСлучайныхЧисел.СлучайноеЧисло(1, 20));
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти
