#Область ОписаниеПеременных

&НаКлиенте
Перем ИдентификаторПоследнейВыделеннойСтроки Экспорт;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УстанавливаемыеДополнительныеСвойства  = ИТК_ПараметрыЗаписиКлиентСервер.УстанавливаемыеДополнительныеСвойства();
	Для Каждого ОписаниеДополнительногоСвойства Из Параметры.Значение Цикл 
		
		НоваяСтрока = Значение.Добавить();
		НоваяСтрока.Имя = ОписаниеДополнительногоСвойства.Ключ;
		НоваяСтрока.Значение = ОписаниеДополнительногоСвойства.Значение;
		НоваяСтрока.Предопределенный = (УстанавливаемыеДополнительныеСвойства.Найти(ОписаниеДополнительногоСвойства.Ключ) <> Неопределено);
		
	КонецЦикла;
	Значение.Сортировать("Предопределенный Убыв");
	
	Заголовок = НСтр("ru = 'Редактирование дополнительных свойств';
					|en = 'Editing advanced properties'");
	УстановитьУсловноеОформление();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыЗначение

&НаКлиенте
Процедура ЗначениеПриАктивизацииСтроки(Элемент)
	
	ИдентификаторТекущейСтроки = Элементы.Значение.ТекущаяСтрока;
	
	Если ИдентификаторПоследнейВыделеннойСтроки <> ИдентификаторТекущейСтроки Тогда 
		
		ИдентификаторПоследнейВыделеннойСтроки = ИдентификаторТекущейСтроки;
		ОбновитьЭлементыФормы();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначениеПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)

	ОткрытьФормуРедактированияСвойства(Отказ, Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначениеПередНачаломИзменения(Элемент, Отказ)
	
	Если Элемент.ТекущиеДанные.Предопределенный Тогда
		
		Отказ = Истина;
		Возврат;
		
	КонецЕсли;
	
	ОткрытьФормуРедактированияСвойства(Отказ);

КонецПроцедуры

&НаКлиенте
Процедура ЗначениеПередУдалением(Элемент, Отказ)
	
	Если Элемент.ТекущиеДанные.Предопределенный Тогда
		
		Отказ = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СохранитьИЗакрыть(Команда)
	
	Результат = Новый Структура;
	
	Для Каждого СтрокаДополнительноеСвойство Из Значение Цикл 
		
		Если СтрокаДополнительноеСвойство.Предопределенный Тогда
			Продолжить;
		КонецЕсли;
		
		Результат.Вставить(СтрокаДополнительноеСвойство.Имя, СтрокаДополнительноеСвойство.Значение);
		
	КонецЦикла;
	
	Закрыть(Результат);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "Значение", Новый Структура("Шрифт", ИТК_ОбщийКлиентСервер.ШрифтЖирный()), "Значение.Предопределенный", Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	ТекущиеДанные = Элементы.Значение.ТекущиеДанные;
	ЭтоСтрока = (ТекущиеДанные <> Неопределено);
	
	ДоступноУдаление = ЭтоСтрока И Не ТекущиеДанные.Предопределенный;

	Элементы.ЗначениеУдалить.Доступность = ДоступноУдаление;
	Элементы.ЗначениеКонтекстноеМенюУдалить.Доступность = ДоступноУдаление;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуРедактированияСвойства(Отказ, Изменение = Истина)
	
	Отказ = Истина;
	
	ТекущиеДанные = Элементы.Значение.ТекущиеДанные;
	Если Изменение Тогда
		ИмяСвойства = ТекущиеДанные.Имя;
		ЗначениеСвойства = ТекущиеДанные.Значение;
	Иначе
		ИмяСвойства = "";
		ЗначениеСвойства = Неопределено;
	КонецЕсли;
	
	ИспользуемыеИдентификаторы = ИТК_ФормаКлиент.ВыгрузитьКолонкуКоллекции(Значение, "Имя", ИмяСвойства);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Изменение", Изменение);
	ОписаниеОповещения = Новый ОписаниеОповещения("РедактированиеСвойстваЗакончена", ЭтотОбъект, ДополнительныеПараметры);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Изменение", Изменение);
	ПараметрыФормы.Вставить("ЗанятыеИдентификаторы", ИспользуемыеИдентификаторы);
	ПараметрыФормы.Вставить("Имя", ИмяСвойства);
	ПараметрыФормы.Вставить("Значение", ЗначениеСвойства);
	
	ОткрытьФорму("ОбщаяФорма.ИТК_РедактированиеДополнительногоСвойства", ПараметрыФормы, ЭтотОбъект, , , , ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

&НаКлиенте
Процедура РедактированиеСвойстваЗакончена(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеПараметры.Изменение Тогда
		СтрокаСвойство = Элементы.Значение.ТекущиеДанные;
	Иначе
		СтрокаСвойство = Значение.Добавить();
	КонецЕсли;
	ЗаполнитьЗначенияСвойств(СтрокаСвойство, Результат);
	
	ДобавитьИмяДополнительногоСвойстваВИспользуемые(Результат.Имя);
	
	Модифицированность = Истина;
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДобавитьИмяДополнительногоСвойстваВИспользуемые(Имя)
	
	ОбщиеНастройки = ИТК_Настройки.Загрузить();
	
	ИспользуемыеДополнительныеСвойства = ОбщиеНастройки["ИспользуемыеДополнительныеСвойства"];
	Если ИспользуемыеДополнительныеСвойства.Найти(Имя) <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИспользуемыеДополнительныеСвойства.Добавить(Имя);
	ИТК_Настройки.Сохранить(ОбщиеНастройки);
	
КонецПроцедуры

#КонецОбласти
