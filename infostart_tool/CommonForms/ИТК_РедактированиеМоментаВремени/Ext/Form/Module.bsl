#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	МоментВремени = Параметры.Значение;
	Дата = МоментВремени.Дата;
	ОбновитьСписокВыбораДаты();
	
	Ссылка = МоментВремени.Ссылка;
	Элементы.Ссылка.ДоступныеТипы = Новый ОписаниеТипов(ИТК_Метаданные.ТипВсеСсылкиКоллекции("Документы"));
	
	Заголовок = СтрШаблон(НСтр("ru = 'Редактирование момента времени %1';
								|en = 'Editing point in time %1'"), Параметры.Заголовок);
	ИТК_ПодключаемыеКоманды.ИнструментыКПолю(ЭтотОбъект, "Ссылка", Истина, Истина);	
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИТК_ФормаКлиент.АктивизацияЗначенияВФорме(Элементы.Ссылка, Ссылка);
	
	ОбновитьЭлементыФормы();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СсылкаПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
	Если ЗначениеЗаполнено(Ссылка) Тогда
		СсылкаПриИзмененииНаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СсылкаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.НачалоВыбораЗначенияВФорме(ЭтотОбъект, "Ссылка", НСтр("ru = 'Объект';
																			|en = 'Object'"), СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура СсылкаОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Ссылка = Неопределено;
	
	СсылкаПриИзменении(Элемент);
	ИТК_ФормаКлиент.АктивизацияЗначенияВФорме(Элемент, Ссылка);
	
КонецПроцедуры

&НаКлиенте
Процедура СсылкаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.ОбработкаВыбораЗначенияВФорме(Элемент, ВыбранноеЗначение, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура СсылкаАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.АвтоПодборЗначенияВФорме(Текст, Элемент, ДанныеВыбора, СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СохранитьИЗакрыть(Команда)
	
	Результат = ИТК_ОбщийВызовСервера.НовыйМоментВремени(Дата, Ссылка);
	
	Закрыть(Результат);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура СсылкаПриИзмененииНаСервере()
	
	ПолеДата = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Дата");
	Дата = ИТК_Общий.ЗначениеРеквизитаОбъекта(Ссылка, ПолеДата);
	
	ОбновитьСписокВыбораДаты();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСписокВыбораДаты()
	
	СписокВыбора = Элементы.Дата.СписокВыбора;
	СписокВыбора.Очистить();
	СписокВыбора.Добавить(Дата, СтрШаблон(НСтр("ru = 'Документ: %1';
												|en = 'Document: %1'"), Дата));
	
	Если Ссылка = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Даты движений
	ОбъектМетаданных = Ссылка.Метаданные();
	Запросы = Новый Массив;
	Для Каждого ОбъектДвижений Из ОбъектМетаданных.Движения Цикл 
		
		ЕстьРеквизитПериод = Ложь;
		Для Каждого ОписаниеСтандартногоРеквизита Из ОбъектДвижений.СтандартныеРеквизиты Цикл 
			
			Если ОписаниеСтандартногоРеквизита.Имя = "Период" Тогда
				ЕстьРеквизитПериод = Истина;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если ЕстьРеквизитПериод Тогда
			
			ТекстЗапроса = "ВЫБРАТЬ
			|	Таблица.Период КАК Дата
			|ИЗ
			|	&ИмяТаблицы КАК Таблица
			|ГДЕ
			|	Таблица.Регистратор = &Регистратор
			|	И Таблица.Период <> &Дата";
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ИмяТаблицы", ОбъектДвижений.ПолноеИмя());
			Запросы.Добавить(ТекстЗапроса);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Запросы) Тогда
		
		ТекстЗапроса = СтрШаблон("ВЫБРАТЬ ВложенныйЗапрос.Дата ИЗ (%1) КАК ВложенныйЗапрос СГРУППИРОВАТЬ ПО ВложенныйЗапрос.Дата", СтрСоединить(Запросы, " ОБЪЕДИНИТЬ ВСЕ "));
		
		Запрос = Новый Запрос(ТекстЗапроса);
		Запрос.УстановитьПараметр("Регистратор", Ссылка);
		Запрос.УстановитьПараметр("Дата", Дата);
		Результат = Запрос.Выполнить();
		
		Выборка = Результат.Выбрать();
		Пока Выборка.Следующий() Цикл
			
			Пояснение = СтрШаблон(НСтр("ru = 'Из движений: %1';
										|en = 'From the movements: %1'"), Выборка.Дата);
			СписокВыбора.Добавить(Выборка.Дата, Пояснение);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Элементы.Дата.КнопкаВыпадающегоСписка = ЗначениеЗаполнено(СписокВыбора);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	ИТК_ПодключаемыеКомандыКлиент.ОбновитьЭлементы(ЭтотОбъект, Элементы.Ссылка);
	
КонецПроцедуры

#Область ПодключаемыеКоманды

&НаКлиенте
Процедура ПодключаемаяКоманда(Команда)
	
	ИТК_ПоискСсылокКлиент.ОбработатьПодключеннуюКоманду(ЭтотОбъект, Команда.Имя);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти