#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОтборРолей = "Установленные";
	
	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.Роли);
	
	УникальныйИдентификаторПользователя = Параметры.Пользователь;
	Если ИТК_БСПКлиентСервер.ЭтоСсылкаНаСправочникПользователи(Параметры.Пользователь) Тогда
		УникальныйИдентификаторПользователя = ИТК_БСП.ИдентификаторПользователяИБИзСсылкиСправочникаПользователи(Параметры.Пользователь);
	КонецЕсли;
	Пользователь = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(УникальныйИдентификаторПользователя);
	
	ПоляИсключения = Новый Массив;
	ПоляИсключения.Добавить("Пароль");
	ПоляИсключения.Добавить("УникальныйИдентификатор");
	ПоляИсключения.Добавить("ЗащитаОтОпасныхДействий");
	ПоляИсключения.Добавить("Роли");
	ПоляИсключения.Добавить("Язык");
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Пользователь, , СтрСоединить(ПоляИсключения, ","));
	УИД = Пользователь.УникальныйИдентификатор;
	
	Пароль = Пользователь.СохраняемоеЗначениеПароля;
	ПарольПодтверждение = Пользователь.СохраняемоеЗначениеПароля;
	ЗащитаОтОпасныхДействий = Пользователь.ЗащитаОтОпасныхДействий.ПредупреждатьОбОпасныхДействиях;
	
	Если Пользователь.Язык <> Неопределено Тогда
		Язык = Пользователь.Язык.Имя;
	КонецЕсли;
	
	// Заполнение ролей
	ДоступныеРоли = Новый Соответствие;
	Для Каждого ОписаниеРоли Из Пользователь.Роли Цикл 
		ДоступныеРоли.Вставить(ОписаниеРоли.Имя, Истина);
	КонецЦикла;
	
	ВсеРоли = Новый ТаблицаЗначений;
	ВсеРоли.Колонки.Добавить("Имя", ИТК_ТипыКлиентСервер.ОписаниеИмяМетаданных());
	ВсеРоли.Колонки.Добавить("Представление", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	ВсеРоли.Колонки.Добавить("Комментарий", ИТК_ТипыКлиентСервер.ОписаниеСтрока());
	ВсеРоли.Колонки.Добавить("Пометка", ИТК_ТипыКлиентСервер.ОписаниеБулево());
	
	Для Каждого Роль Из Метаданные.Роли Цикл 
		
		НоваяСтрока = ВсеРоли.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Роль, "Имя, Комментарий");
		
		НоваяСтрока.Представление = Роль.Представление();
		НоваяСтрока.Пометка = (ДоступныеРоли.Получить(Роль.Имя) <> Неопределено);
		
	КонецЦикла;
	
	ВсеРоли.Сортировать("Представление");
	Роли.Загрузить(ВсеРоли);
	
	ВидИнструмента = ИТК_Перечисления.ИнструментПользователи();
	Избранное = ИТК_Избранное.ОбъектВИзбранном(ВидИнструмента, Пользователь.УникальныйИдентификатор);

	ОбновитьЭлементыФормыПриСозданииНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновитьЭлементыФормы();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура АутентификацияОСПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборРолейПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура РежимЗапускаОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ПарольПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПарольПодтверждениеПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОткрытьПользователяБСП(Команда)
	
	ИТК_БСПКлиент.ОткрытьПользователяБСП(УИД);
	
КонецПроцедуры

&НаКлиенте
Процедура РолиУстановитьВсе(Команда)
	
	Модифицированность = Истина;
	ИТК_ФормаКлиент.УстановитьПометки(Роли);

КонецПроцедуры

&НаКлиенте
Процедура РолиСнятьВсе(Команда)
	
	Модифицированность = Истина;
	ИТК_ФормаКлиент.УстановитьПометки(Роли, Ложь);

КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьИЗакрыть(Команда)
	
	Если Пароль <> ПарольПодтверждение Тогда
		
		ПоказатьПредупреждение( , НСтр("ru = 'Пароль и подтверждение пароля не совпадают'; en = 'Password and confirmation password do not match'"));
		Возврат;
		
	КонецЕсли;
	
	ЗаписатьДанныеПользователяИБ();
	Оповестить("ИТК_ПользовательИБ_Записан");
	Закрыть();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ОбновитьЭлементыФормыПриСозданииНаСервере()
	
	Элементы.ГруппаРедактированиеРекомендуетсяЧерезБСП.Видимость = ИТК_БСПКлиентСервер.ИспользуетсяБСП();
	
	Элементы.АдресЭлектроннойПочты.Видимость = ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.15");
	Элементы.ЗапрещеноВосстанавливатьПароль.Видимость = ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.15");
	
	Элементы.АутентификацияOpenIDConnect.Видимость = ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.19");
	Элементы.АутентификацияТокеномДоступа.Видимость = ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.21");
	
	// Заполнение списка языков
	Для Каждого ОбъектМетаданныхЯзык Из Метаданные.Языки Цикл 
		Элементы.Язык.СписокВыбора.Добавить(ОбъектМетаданныхЯзык.Имя, ОбъектМетаданныхЯзык.Представление());
	КонецЦикла;
	
	// Заполнение режима запуска
	СписокВыбора = Элементы.РежимЗапуска.СписокВыбора;
	СписокВыбора.Добавить(РежимЗапускаКлиентскогоПриложения.Авто);
	СписокВыбора.Добавить(РежимЗапускаКлиентскогоПриложения.ОбычноеПриложение);
	СписокВыбора.Добавить(РежимЗапускаКлиентскогоПриложения.УправляемоеПриложение);
	
	Элементы.ФормаОткрытьПользователяБСП.Видимость = ЗначениеЗаполнено(УИД)
														И ИТК_БСПКлиентСервер.ИспользуетсяБСП();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	Элементы.ПользовательОС.Доступность = АутентификацияОС;
	
	
	Если Пароль = ПарольПодтверждение Тогда
		
		Если ЗначениеЗаполнено(Пароль) Тогда
			ПаролиСовпадают = НСтр("ru = 'совпадают'; en = 'match'");
		Иначе
			ПаролиСовпадают = Неопределено;
		КонецЕсли;
		
	Иначе
		ПаролиСовпадают = НСтр("ru = 'не совпадают'; en = 'do not match'");
	КонецЕсли;
	
	ОбновитьОтборСтрокРолей();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОтборСтрокРолей()
	
	Если ОтборРолей = "Неустановленные" Тогда
		Пометка = Ложь;
	ИначеЕсли ОтборРолей = "Установленные" Тогда
		Пометка = Истина;
	Иначе
		Пометка = Неопределено;
	КонецЕсли;
	
	Если Пометка = Неопределено Тогда
		ОтборСтрок = Неопределено;
	Иначе
		ОтборСтрок = Новый ФиксированнаяСтруктура("Пометка", Пометка);
	КонецЕсли;
		
	Элементы.Роли.ОтборСтрок = ОтборСтрок
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьДанныеПользователяИБ()
	
	// Просто заполняемые поля
	ЗаполняемыеПоля = Новый Массив;
	ЗаполняемыеПоля.Добавить("Имя");
	ЗаполняемыеПоля.Добавить("ПолноеИмя");
	
	ЗаполняемыеПоля.Добавить("АутентификацияОС");
	ЗаполняемыеПоля.Добавить("ПользовательОС");
	
	ЗаполняемыеПоля.Добавить("ПоказыватьВСпискеВыбора");
	ЗаполняемыеПоля.Добавить("АутентификацияOpenID");
	ЗаполняемыеПоля.Добавить("АутентификацияСтандартная");
	ЗаполняемыеПоля.Добавить("ЗапрещеноИзменятьПароль");
	
	Если ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.15") Тогда
		
		ЗаполняемыеПоля.Добавить("ЗапрещеноВосстанавливатьПароль");
		ЗаполняемыеПоля.Добавить("АдресЭлектроннойПочты");
		
	КонецЕсли;
	
	Если ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.19") Тогда
		ЗаполняемыеПоля.Добавить("АутентификацияOpenIDConnect");
	КонецЕсли;
	
	УникальныйИдентификаторПользователя = Новый УникальныйИдентификатор(УИД);
	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(УникальныйИдентификаторПользователя);
	ЗаполнитьЗначенияСвойств(ПользовательИБ, ЭтотОбъект, СтрСоединить(ЗаполняемыеПоля, ","));
	
	ПользовательИБ.ЗащитаОтОпасныхДействий.ПредупреждатьОбОпасныхДействиях = ЗащитаОтОпасныхДействий;
	ПользовательИБ.Пароль = Пароль;
	
	// Заполнение ролей
	ПользовательИБ.Роли.Очистить();
	
	ОтборСтрок = Новый Структура("Пометка", Истина);
	УстановленныеРоли = Роли.НайтиСтроки(ОтборСтрок);
	
	Для Каждого СтрокаРоль Из УстановленныеРоли Цикл 
		
		ОбъектМетаданныхРоль = Метаданные.Роли[СтрокаРоль.Имя];
		ПользовательИБ.Роли.Добавить(ОбъектМетаданныхРоль);
		
	КонецЦикла;
	
	ПользовательИБ.РежимЗапуска = РежимЗапуска;
	
	ЯзыкПользователя = Неопределено;
	Если ЗначениеЗаполнено(Язык) Тогда 
		ЯзыкПользователя = Метаданные.Языки[Язык];
	КонецЕсли;
	ПользовательИБ.Язык = ЯзыкПользователя;
	
	ПользовательИБ.Записать();
	
	ВидИнструмента = ИТК_Перечисления.ИнструментПользователи();
	ИТК_Избранное.ЗаписатьВИзбранное(ВидИнструмента, УникальныйИдентификаторПользователя, Избранное);

КонецПроцедуры

#КонецОбласти