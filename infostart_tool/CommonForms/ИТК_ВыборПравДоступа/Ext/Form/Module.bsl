
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.ДеревоПравДоступа);
	
	ЗаполнениеДерева();
		
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДеревоПравДоступа

&НаКлиенте
Процедура ДеревоПравДоступаПометкаПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Выбрать(Команда)
	
	КоличествоВыбранных = ИТК_ФормаКлиент.КоличествоПомеченныхВКоллекции(ДеревоПравДоступа);
	Если КоличествоВыбранных = 0 Тогда
			
		ПоказатьПредупреждение( , НСтр("ru = 'Необходимо выбрать права доступа';
										|en = 'You need to select permissions'"));
		Возврат;	
			
	КонецЕсли;
	
	Результат = Новый СписокЗначений;
	Для Каждого СтрокаПравоДоступа Из ДеревоПравДоступа.ПолучитьЭлементы() Цикл 
		
		Если НЕ СтрокаПравоДоступа.Пометка Тогда
			Продолжить;
		КонецЕсли;
		
		Результат.Добавить(СтрокаПравоДоступа.Значение, СтрокаПравоДоступа.Представление);
		
	КонецЦикла;
	
	Закрыть(Результат);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтметитьВсе(Команда)
	
	ИТК_ФормаКлиент.УстановитьПометки(ДеревоПравДоступа);
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура СнятьВсеПометки(Команда)
	
	ИТК_ФормаКлиент.УстановитьПометки(ДеревоПравДоступа, Ложь);
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	ЗаголовокКнопки = НСтр("ru = 'Выбрать';
							|en = 'Select'");
	КоличествоВыбранных = ИТК_ФормаКлиент.КоличествоПомеченныхВКоллекции(ДеревоПравДоступа);
	Элементы.ФормаВыбрать.Заголовок = ИТК_ФормаКлиентСервер.ЗаголовокСКоличеством(ЗаголовокКнопки, КоличествоВыбранных);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнениеДерева()
	
	ВыбранныеПрава = Параметры.ВыбранныеПрава;
	
	ВсеПраваДоступа = ИТК_АнализПравДоступаПовтИсп.ВсеПраваДоступа();
	Для Каждого ЭлементПравоДоступа Из ВсеПраваДоступа Цикл 
		
		ПравоДоступа = ЭлементПравоДоступа.Значение;
		
		НоваяСтрока = ДеревоПравДоступа.ПолучитьЭлементы().Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементПравоДоступа, "Значение, Представление");
		
		ОписаниеПраваДоступа = ИТК_МетаданныеКлиентСервер.ОписаниеПраваДоступа(ПравоДоступа);
		Коллекции = СтрРазделить(ОписаниеПраваДоступа.Коллекции, ",");
		НоваяСтрока.Использование = СтрСоединить(Коллекции, ", ");
		
		Если ЗначениеЗаполнено(ВыбранныеПрава) Тогда
			Пометка = (ВыбранныеПрава.НайтиПоЗначению(ПравоДоступа) <> Неопределено);
		Иначе
			Пометка = Истина;
		КонецЕсли;
		НоваяСтрока.Пометка = Пометка;
		
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ПравоДоступаИсторииДанных(ПравоДоступа) Тогда
			Картинка = ИТК_ОбщийКлиентСерверПовтИсп.БиблиотекаКартинок("ИсторияДанных");
		ИначеЕсли Коллекции.Количество() = 1 Тогда
			
			ПерваяКоллекция = Коллекции[0];
			Картинка = ИТК_МетаданныеКлиентСерверПовтИсп.КартинкаКоллекции(ПерваяКоллекция);
			
		Иначе
			Картинка = Новый Картинка;
		КонецЕсли;
		НоваяСтрока.Картинка = Картинка;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти
