#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Заголовок = НСтр("ru = 'Строки на различных языках';
					|en = 'Strings in different languages'");
	
	Представления = ИТК_Строки.ЛокализированнаяСтрокаЗначениеИзНСтр(Параметры.НачальноеЗначение);
	
	// Добавим языки конфигурации
	Для Каждого Язык Из Метаданные.Языки Цикл 
		
		КодЯзыка = Язык.КодЯзыка;
		Если Представления.НайтиПоЗначению(КодЯзыка) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Представления.Добавить(КодЯзыка);
		
	КонецЦикла;
	
	// Создаем элементы
	Для Индекс = 0 По Представления.Количество() - 1 Цикл 
		
		ЭлементПредставления = Представления[Индекс];
		КодЯзыка = ЭлементПредставления.Значение;
		
		Свойства = Новый Структура;
		Свойства.Вставить("Заголовок", ИТК_ОбщийКлиентСервер.ПредставлениеЯзыка(КодЯзыка));
		
		ПутьКДанным = СтрШаблон("Представления[%1].Представление", Индекс);
		Свойства.Вставить("ПутьКДанным", ПутьКДанным);
		
		Свойства.Вставить("МногострочныйРежим", Истина);
		Свойства.Вставить("РасширенноеРедактирование", Истина);
		Свойства.Вставить("Высота", 3);
		Свойства.Вставить("АвтоМаксимальнаяШирина", Ложь);
		
		ИТК_Форма.ДобавитьЭлемент(ЭтотОбъект, "Представление" + КодЯзыка, "ПолеВвода", Свойства, Элементы.ГруппаПредставления);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаОК(Команда)
	
	Результат = ИТК_Строки.ЛокализированнаяСтрокаНСтрИзЗначения(Представления);
	Закрыть(Результат);
	
КонецПроцедуры

#КонецОбласти
