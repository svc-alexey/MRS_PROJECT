#Область ОписаниеПеременных

&НаКлиенте
Перем ЗакрытиеРазрешено;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Параметры, "Заголовок, Редактирование, ПерейтиК");

	ДополнительныеСвойства = Новый Структура;
	
	НачальныйКод = Параметры.Код;
	ДополнительныеСвойства.Вставить("Текст", НачальныйКод);
	ДополнительныеСвойства.Вставить("ТолькоПросмотр", НЕ Редактирование);
	
	Если Редактирование Тогда
		
		ИТК_Настройки.ИнициализироватьФорму(ЭтотОбъект); 
		ЯзыкПрограммирования = ИТК_Настройки.ЗначениеОбщейНастройки(ЭтотОбъект, "ЯзыкПрограммирования");
		ИмяПеременной = ИТК_РедакторКодаКлиентСервер.ИмяПеременнойВозвратаРезультата(ЯзыкПрограммирования);
		ДополнительныеСвойства.Вставить("Подсказка", СтрШаблон(НСтр("ru = 'Возврат результата производится через переменную ""%1""';
																	|en = 'The result is returned through the variable ""%1""'"), ИмяПеременной));
		
	Иначе
		
		ПоложениеКоманднойПанели = ПоложениеКоманднойПанелиФормы.Нет;	
		
	КонецЕсли;
	
	ИТК_РедакторКода.Инициализация(ЭтотОбъект, "Код", ДополнительныеСвойства);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИТК_РедакторКодаКлиент.Инициализация(ЭтотОбъект, "Код");
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	ИТК_РедакторКодаКлиент.ОбработкаОповещения(ЭтотОбъект, ИмяСобытия, Параметр, Источник);
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если Не ЗавершениеРаботы 
		И ЗакрытиеРазрешено = Неопределено Тогда
		
		Если Модифицированность Тогда
			
			Отказ = Истина;
			
			ОписаниеОповещенияОЗавершении = Новый ОписаниеОповещения("ВопросСохраненияЗавершение", ЭтотОбъект);
			ТекстВопроса = НСтр("ru = 'Имеются несохраненные данные при закрытии они будут потеряны. Сохранить?';
								|en = 'If you have unsaved data when you close it, it will be lost. Save?'");
			ЗаголовокВопроса = НСтр("ru = 'Редактирование выражения';
									|en = 'Editing an expression'");

			КнопкаПоУмолчанию = Истина;
			
			КнопкиВопроса = Новый СписокЗначений;
			КнопкиВопроса.Добавить(Истина, НСтр("ru = 'Сохранить и закрыть';
												|en = 'Save and close'"));
			КнопкиВопроса.Добавить(Ложь, НСтр("ru = 'Не сохранять';
												|en = 'Do not save'"));
			КнопкиВопроса.Добавить(Неопределено, НСтр("ru = 'Отмена';
														|en = 'Cancel'"));
			
			ИТК_ФормаКлиент.ЗадатьВопрос(ОписаниеОповещенияОЗавершении, ТекстВопроса, КнопкиВопроса, КнопкаПоУмолчанию, ЗаголовокВопроса, ЭтотОбъект);
								
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ИТК_ПодключаемыйДокументСформирован(Элемент)
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Текст", НачальныйКод);
	
	Если Редактирование Тогда
		
		ПользовательскиеОбъекты = ИТК_РедакторКодаВызовСервера.ПользовательскиеОбъектыРезультат();
		ДополнительныеПараметры.Вставить("ПользовательскиеОбъекты", ПользовательскиеОбъекты);
		
	КонецЕсли;
	
	ИТК_РедакторКодаКлиент.ДополнительнаяИнициализация(ЭтотОбъект, Элемент, ДополнительныеПараметры);
	
	Если ЗначениеЗаполнено(ПерейтиК) Тогда
		
		Если ТипЗнч(ПерейтиК) = Тип("Число") Тогда
			ПодключитьОбработчикОжидания("ПодключаемыйПерейтиНомеруСтрокиВКоде", 0.1, Истина);
		Иначе
			ПодключитьОбработчикОжидания("ПодключаемыйПерейтиКМетодуВКоде", 0.1, Истина);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИТК_ПодключаемыйПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	ИТК_РедакторКодаКлиент.ОбработкаСобытий(ЭтотОбъект, Элемент, ДанныеСобытия, СтандартнаяОбработка);
	
	Если ИТК_РедакторКодаКлиент.ЭтоСобытиеНажатиеКлавишиEscape(ЭтотОбъект, ДанныеСобытия) Тогда
		
		Если НЕ Редактирование Тогда
			Закрыть();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СохранитьИЗакрыть(Команда)
	
	ЗакрытиеРазрешено = Истина;

	Текст = ИТК_РедакторКодаКлиент.Текст(ЭтотОбъект, "Код");
	Закрыть(Текст);
	
КонецПроцедуры

#Область ПодключаемыеКоманды

&НаКлиенте
Процедура ИТК_ПодключаемаяКомандаРедакторКодаОбработчик(Команда)
	
	ИТК_РедакторКодаКлиент.ПодключаемыйОбработчикКоманд(ЭтотОбъект, Команда.Имя);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ИТК_ПодключаемыйВосстановлениеФокусаРедактора() Экспорт 
	
	ИТК_РедакторКодаКлиент.ВосстановлениеФокусаРедактора(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйПерейтиКМетодуВКоде() Экспорт 
	
	ИТК_РедакторКодаКлиент.ПерейтиКОпределениюВМодуле(ЭтотОбъект, ПерейтиК);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйПерейтиНомеруСтрокиВКоде() Экспорт 
	
	ИТК_РедакторКодаКлиент.ПоказатьОшибку(Элементы.Код, ПерейтиК)
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросСохраненияЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если Результат Тогда
		
		ПараметрЗакрытия = ИТК_РедакторКодаКлиент.Текст(ЭтотОбъект, "Код");
		
	Иначе
		
		ПараметрЗакрытия = Неопределено;
		
	КонецЕсли;
	
	ЗакрытиеРазрешено = Истина;
	Закрыть(ПараметрЗакрытия);

КонецПроцедуры

#КонецОбласти
