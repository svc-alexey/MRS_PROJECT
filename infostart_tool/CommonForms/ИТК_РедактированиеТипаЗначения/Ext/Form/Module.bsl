#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("Значение") Тогда
		ТекущееЗначение = Параметры.Значение;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Параметры, "Режим, ЗакрыватьПриВыборе, ДополнятьДату, Системные, ТипыКод, ДоступныеОбъекты");
	
	УстановитьЗаголовок();
	
	ДополнительныйТекст = НСтр("ru = 'В результат поиска выводится не более 50 найденных.'; en = 'The search result displays no more than 50 found.'");
	ИТК_ФормаКлиентСервер.ОформитьСтрокуПоискаПоПодобию(Элементы.Поиск, ДополнительныйТекст);
	
	КодЯзыка = ИТК_ОбщийКлиентСервер.КодТекущегоЯзыка();
	ПервоначальноеЗаполнениеДерева();
	
	Если Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияРедактированиеОписанияТипов() Тогда
		
		СписокВыбораДатаСостав = Элементы.ДатаСостав.СписокВыбора;
		СписокВыбораДатаСостав.Добавить(ЧастиДаты.ДатаВремя, НСтр("ru = 'Дата время';
																	|en = 'Date time'"));
		СписокВыбораДатаСостав.Добавить(ЧастиДаты.Дата, НСтр("ru = 'Дата';
															|en = 'Date'"));
		СписокВыбораДатаСостав.Добавить(ЧастиДаты.Время, НСтр("ru = 'Время';
																|en = 'Time'"));
		
		СписокВыбораСтрокаТип = Элементы.СтрокаТип.СписокВыбора;
		СписокВыбораСтрокаТип.Добавить(ДопустимаяДлина.Переменная, НСтр("ru = 'Переменная';
																		|en = 'Variable'"));
		СписокВыбораСтрокаТип.Добавить(ДопустимаяДлина.Фиксированная, НСтр("ru = 'Фиксированная';
																			|en = 'Fixed'"));
		
		Составной = (ТекущееЗначение.Типы().Количество() > 1);
		
		ДатаСостав = ТекущееЗначение.КвалификаторыДаты.ЧастиДаты;
		
		СтрокаТип = ТекущееЗначение.КвалификаторыСтроки.ДопустимаяДлина;
		СтрокаДлина = ТекущееЗначение.КвалификаторыСтроки.Длина;
		СтрокаНеограниченная = (СтрокаДлина = 0);
		
		ЧислоДлина = ТекущееЗначение.КвалификаторыЧисла.Разрядность;
		ЧислоТочность = ТекущееЗначение.КвалификаторыЧисла.РазрядностьДробнойЧасти;
		ЧислоНеотрицательное = (ТекущееЗначение.КвалификаторыЧисла.ДопустимыйЗнак = ДопустимыйЗнак.Неотрицательный);

	КонецЕсли;
	
	УстановитьТекущееЗначение();
	УстановитьУсловноеОформление();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	РедактированиеОписанияТипов = (Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияРедактированиеОписанияТипов());
	ОтборМетаданных = (Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияОтборМетаданных());
	
	УстановитьМаксимальнуюДлинуСтроки();
	Если РедактированиеОписанияТипов ИЛИ ОтборМетаданных Тогда
		ЗаполнитьПометкиДерева(Дерево);
	КонецЕсли;
	
	// Разворачивание небольшого числа объектов
	Если ЗначениеЗаполнено(ДоступныеОбъекты) 
			И ДоступныеОбъекты.Количество() < 15 Тогда
		ИТК_ФормаКлиент.РазвернутьДерево(Элементы.Дерево, Дерево);
	КонецЕсли;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПоискПриИзменении(Элемент)
	
	Список.Очистить();
	Если ЗначениеЗаполнено(Поиск) Тогда
		
		ОбновитьСписокСервер();
		ПодключитьОбработчикОжидания("ПодключаемыйТекущийЭлементСтрокаПоискаПослеОжидания", 0.2, Истина);
		
	КонецЕсли;
	
	ОбновлениеЭлементовФормыПослеОжидания();
	
КонецПроцедуры

&НаКлиенте
Процедура СоставнойПриИзменении(Элемент)
	
	УстановитьУсловноеОформление();

	Если Не Составной Тогда
		
		Идентификатор = ИдентификаторПервойОтмеченнойСтроки();
		СнятьВсеОтмеченныеДобавитьОдну(Идентификатор);
			
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЧислоДлинаПриИзменении(Элемент)
	
	Если ЧислоТочность > ЧислоДлина Тогда
		
		ЧислоТочность = ЧислоДлина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЧислоТочностьПриИзменении(Элемент)
	
	Если ЧислоДлина < ЧислоТочность Тогда
		ЧислоДлина = ЧислоТочность;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СтрокаНеограниченнаяПриИзменении(Элемент)
	
	СтрокаТип = ДопустимаяДлина.Переменная;
	
	Если СтрокаНеограниченная Тогда
		СтрокаДлина = 0;
	Иначе
		СтрокаДлина = 10;
	КонецЕсли;
	
	ОбновлениеЭлементовФормыПослеОжидания();
	
КонецПроцедуры

&НаКлиенте
Процедура СтрокаТипПриИзменении(Элемент)
	
	УстановитьМаксимальнуюДлинуСтроки();
	
КонецПроцедуры

&НаКлиенте
Процедура СтрокаДлинаПриИзменении(Элемент)
	
	СтрокаНеограниченная = (СтрокаДлина = 0);
	
	Если СтрокаНеограниченная Тогда
		
		СтрокаТип = ДопустимаяДлина.Переменная;

	КонецЕсли;
	
	УстановитьМаксимальнуюДлинуСтроки();
	ОбновлениеЭлементовФормыПослеОжидания();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДерево

&НаКлиенте
Процедура ДеревоПриАктивизацииСтроки(Элемент)
	
	ОбновлениеЭлементовФормыПослеОжидания();
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоВыбораВыборЗначения(Элемент, Значение, СтандартнаяОбработка)
	
	ВыбраноЗначение(Элемент.ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоВыбораПередРазворачиванием(Элемент, Строка, Отказ)
	
	РазворачиваемаяСтрока = Дерево.НайтиПоИдентификатору(Строка);
	
	Если ИТК_ФормаКлиентСервер.НеобходимоРазвернутьСтроку(РазворачиваемаяСтрока) Тогда
		
		РазвернутьСтрокуКоллекции(Строка);
				
		Идентификатор = ИдентификаторСтроки(РазворачиваемаяСтрока);
		УстановкаСнятиеПометки(РазворачиваемаяСтрока, Идентификатор, РазворачиваемаяСтрока.Пометка);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоПометкаПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Дерево.ТекущиеДанные;
	
	Идентификатор = ИдентификаторСтроки(ТекущиеДанные);
	УстановкаСнятиеПометки(ТекущиеДанные, Идентификатор);
	
	ОбновлениеЭлементовФормыПослеОжидания();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписок

&НаКлиенте
Процедура СписокПриАктивизацииСтроки(Элемент)
	
	ОбновлениеЭлементовФормыПослеОжидания();
	
КонецПроцедуры

&НаКлиенте
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Идентификатор = Элементы.Список.ТекущиеДанные.Значение;
	Строка = НайтиСтрокуПоИдентификатору(Идентификатор);
	
	ВыбраноЗначение(Строка);

КонецПроцедуры

&НаКлиенте
Процедура СписокПометкаПриИзменении(Элемент)

	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	
	Идентификатор = ТекущиеДанные.Значение;
	Строка = НайтиСтрокуПоИдентификатору(ТекущиеДанные.Значение);
	УстановкаСнятиеПометки(Строка, Идентификатор, ТекущиеДанные.Пометка);
	
	ОбновлениеЭлементовФормыПослеОжидания();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаОК(Команда)
	
	ТекущаяСтрока = НайтиСтрокуПоИдентификатору(ИдентификаторТекущейСтроки());
	ВыбраноЗначение(ТекущаяСтрока, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВсе(Команда)
	
	УстановитьПометкиСписка(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура СнятьВсе(Команда)
	
	УстановитьПометкиСписка(Ложь);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПервоначальноеЗаполнениеДерева()
	
	ВыборТипа = (Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборТипа());
	ВыборПроизвольногоТипа = (Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборПроизвольногоТипа());
	РедактированиеТипа = (Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияРедактированиеТипа());
	РедактированиеОписанияТипов = (Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияРедактированиеОписанияТипов());
	ОтборМетаданных = (Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияОтборМетаданных());
	ВыборОбъектаМетаданных = (Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборОбъектаМетаданных());
	
	ИспользуемыеПростыеТипы = Новый Соответствие;
	ИспользуемыеСсылочныеТипы = Новый Соответствие;
	
	Если ВыборОбъектаМетаданных И ЗначениеЗаполнено(ДоступныеОбъекты) Тогда
		
		Для Каждого ДоступныйОбъект Из ДоступныеОбъекты Цикл 
			
			ТипОбъекта = Тип(ДоступныйОбъект.Значение);
			ОбъектМетаданных = Метаданные.НайтиПоТипу(ТипОбъекта);
			
			Если ОбъектМетаданных <> Неопределено Тогда
				
				ИмяОбъектаКоллекции = ИТК_Метаданные.ИмяОбъектаКоллекции(ОбъектМетаданных, , ТипОбъекта);
				
				ТипыКоллекции = ИспользуемыеСсылочныеТипы.Получить(ИмяОбъектаКоллекции);
				Если ТипыКоллекции = Неопределено Тогда
					
					ТипыКоллекции = Новый СписокЗначений;
					
				КонецЕсли;
				
				ТипыКоллекции.Добавить(ТипОбъекта);
				ИспользуемыеСсылочныеТипы.Вставить(ИмяОбъектаКоллекции, ТипыКоллекции);
				
			КонецЕсли;
			
		КонецЦикла;
		
		ОтображатьВсеДоступныеТипы = Ложь;
		
	Иначе
		
		ОтображатьВсеДоступныеТипы = ОтборМетаданных
										ИЛИ ВыборОбъектаМетаданных
										ИЛИ НЕ (ВыборТипа
													И ЗначениеЗаполнено(ТекущееЗначение.Типы()));
		Если НЕ ОтображатьВсеДоступныеТипы Тогда
			
			Для Каждого Тип Из ТекущееЗначение.Типы() Цикл 
				
				ОбъектМетаданных = Метаданные.НайтиПоТипу(Тип);
				Если ОбъектМетаданных = Неопределено Тогда
					ИспользуемыеПростыеТипы.Вставить(Тип, Истина);
				Иначе
					
					ИмяОбъектаКоллекции = ИТК_Метаданные.ИмяОбъектаКоллекции(ОбъектМетаданных, , Тип);
					
					ТипыКоллекции = ИспользуемыеСсылочныеТипы.Получить(ИмяОбъектаКоллекции);
					Если ТипыКоллекции = Неопределено Тогда
						ТипыКоллекции = Новый СписокЗначений;
					КонецЕсли;
					
					ТипыКоллекции.Добавить(Тип);
					ИспользуемыеСсылочныеТипы.Вставить(ИмяОбъектаКоллекции, ТипыКоллекции);
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЕсли;
	
	// Добавление простых типов
	Исключаемые = СтрРазделить(Параметры.Исключаемые, ",", Ложь);
	Если ОтборМетаданных
			ИЛИ ВыборОбъектаМетаданных Тогда
			
		Исключаемые.Добавить("ПростыеТипы");
		
	КонецЕсли;
	
	Если Исключаемые.Найти("ПростыеТипы") = Неопределено Тогда
		
		ПростыеТипы = СписокПростыхТипов(КодЯзыка, РедактированиеТипа);
		Для Каждого ОписаниеТипа Из ПростыеТипы Цикл 
			
			Тип = Тип(ОписаниеТипа.Значение);
			Если ОтображатьВсеДоступныеТипы ИЛИ ИспользуемыеПростыеТипы.Получить(Тип) <> Неопределено Тогда
				
				ДобавитьСтрокуДерева(Дерево, ОписаниеТипа.Значение, ОписаниеТипа.Представление, ИТК_Типы.Картинка(Тип));
				
				ДополнятьГраницейИМоментомВремени = (Тип = Тип("Дата"))
														И ДополнятьДату 
														И Не РедактированиеОписанияТипов;
				Если ДополнятьГраницейИМоментомВремени Тогда
					
					
					ТипСтрока = "МоментВремени";
					ПредставлениеТипа = НСтр("ru = 'МоментВремени';
											|en = 'PointInTime'", КодЯзыка);
					Если Исключаемые.Найти(ТипСтрока) = Неопределено Тогда
						ДобавитьСтрокуДерева(Дерево, ТипСтрока, ПредставлениеТипа, ИТК_Типы.Картинка(Тип(ТипСтрока)));
					КонецЕсли;
					
					ТипСтрока = "Граница";
					ПредставлениеТипа = НСтр("ru = 'Граница';
											|en = 'Boundary'", КодЯзыка);
					Если Исключаемые.Найти(ТипСтрока) = Неопределено Тогда
						ДобавитьСтрокуДерева(Дерево, ТипСтрока, ПредставлениеТипа, ИТК_Типы.Картинка(Тип(ТипСтрока)));
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	// Добавление системных типов используемых в коде
	Если ТипыКод Тогда
		
		ТипСтрока = "Массив";
		ПредставлениеТипа = НСтр("ru = 'Массив';
								|en = 'Array'", КодЯзыка);
		ДобавитьСтрокуДерева(Дерево, ТипСтрока, ПредставлениеТипа, ИТК_Типы.Картинка(Тип(ТипСтрока)));
		
	КонецЕсли;
	
	Если ВыборПроизвольногоТипа Тогда
		
		ТипСтрока = "Массив";
		ПредставлениеТипа = НСтр("ru = 'Массив';
								|en = 'Array'", КодЯзыка);
		ДобавитьСтрокуДерева(Дерево, ТипСтрока, ПредставлениеТипа, ИТК_Типы.Картинка(Тип(ТипСтрока)));
		
		ТипСтрока = "ФиксированныйМассив";
		ПредставлениеТипа = НСтр("ru = 'ФиксированныйМассив';
								|en = 'FixedArray'", КодЯзыка);
		ДобавитьСтрокуДерева(Дерево, ТипСтрока, ПредставлениеТипа, ИТК_Типы.Картинка(Тип(ТипСтрока)));
		
		ТипСтрока = "Структура";
		ПредставлениеТипа = НСтр("ru = 'Структура';
								|en = 'Structure'", КодЯзыка);
		ДобавитьСтрокуДерева(Дерево, ТипСтрока, ПредставлениеТипа, ИТК_Типы.Картинка(Тип(ТипСтрока)));
		
		ТипСтрока = "ФиксированнаяСтруктура";
		ПредставлениеТипа = НСтр("ru = 'ФиксированнаяСтруктура';
								|en = 'FixedStructure'", КодЯзыка);
		ДобавитьСтрокуДерева(Дерево, ТипСтрока, ПредставлениеТипа, ИТК_Типы.Картинка(Тип(ТипСтрока)));
		
		ТипСтрока = "Соответствие";
		ПредставлениеТипа = НСтр("ru = 'Соответствие';
								|en = 'Map'", КодЯзыка);
		ДобавитьСтрокуДерева(Дерево, ТипСтрока, ПредставлениеТипа, ИТК_Типы.Картинка(Тип(ТипСтрока)));
		
		ТипСтрока = "ФиксированноеСоответствие";
		ПредставлениеТипа = НСтр("ru = 'ФиксированноеСоответствие';
								|en = 'FixedMap'", КодЯзыка);
		ДобавитьСтрокуДерева(Дерево, ТипСтрока, ПредставлениеТипа, ИТК_Типы.Картинка(Тип(ТипСтрока)));
		
		ТипСтрока = "СписокЗначений";
		ПредставлениеТипа = НСтр("ru = 'СписокЗначений';
								|en = 'ValueList'", КодЯзыка);
		ДобавитьСтрокуДерева(Дерево, ТипСтрока, ПредставлениеТипа, ИТК_Типы.Картинка(Тип(ТипСтрока)));
		
		ТипСтрока = "ДвоичныеДанные";
		ПредставлениеТипа = НСтр("ru = 'ДвоичныеДанные';
								|en = 'ДвоичныеДанные'", КодЯзыка);
		ДобавитьСтрокуДерева(Дерево, ТипСтрока, ПредставлениеТипа, ИТК_Типы.Картинка(Тип(ТипСтрока)));
		
	КонецЕсли;
	
	// Добавление типов объектов
	Если ОтборМетаданных Тогда
		ТипыОбъектов = ИТК_МетаданныеКлиентСерверПовтИсп.ДоступныеОбъектыОтбораМетаданных(КодЯзыка);
	ИначеЕсли ВыборОбъектаМетаданных Тогда
		
		Если ЗначениеЗаполнено(ДоступныеОбъекты) Тогда
			ТипыОбъектов = ИТК_МетаданныеКлиентСерверПовтИсп.ДоступныеОбъектыМетаданных(КодЯзыка);
		Иначе
			ТипыОбъектов = ИТК_МетаданныеКлиентСерверПовтИсп.ДоступныеОбъектыОсновнойТаблицыДинамическогоСписка(КодЯзыка);
		КонецЕсли;
		
	Иначе 
		ТипыОбъектов = ИТК_МетаданныеКлиентСерверПовтИсп.ДоступныеТипыОбъекта(КодЯзыка);
	КонецЕсли;
	
	Если ОтображатьВсеДоступныеТипы Тогда
		
		Для Каждого ТипОбъекта Из ТипыОбъектов Цикл 
			
			ИмяКоллекцииМетаданных = ИТК_МетаданныеКлиентСерверПовтИсп.ИмяКоллекции(ТипОбъекта, КодЯзыка);
			Если Исключаемые.Найти(ИмяКоллекцииМетаданных) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
				
			КоллекцияМетаданных = ИТК_МетаданныеПовтИсп.КоллекцияМетаданныхПоИмени(ИмяКоллекцииМетаданных);
			Если НЕ ЗначениеЗаполнено(КоллекцияМетаданных) Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаКоллекция = ДобавитьСтрокуДерева(Дерево, ИмяКоллекцииМетаданных, , ИТК_МетаданныеКлиентСерверПовтИсп.КартинкаОбъектаКоллекции(ТипОбъекта), Ложь);
			ДобавитьСтрокуДерева(СтрокаКоллекция);
			
		КонецЦикла;
		
	Иначе
		
		Для Каждого ИспользуемыйСсылочныйТип Из ИспользуемыеСсылочныеТипы Цикл 
			ИспользуемыйСсылочныйТип.Значение.СортироватьПоПредставлению();
		КонецЦикла;
		
		Для Каждого ТипОбъекта Из ТипыОбъектов Цикл 
			
			ОписаниеТиповКоллекции = ИспользуемыеСсылочныеТипы.Получить(ТипОбъекта);
			Если ОписаниеТиповКоллекции = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			КартинкаКоллекции = ИТК_МетаданныеКлиентСерверПовтИсп.КартинкаОбъектаКоллекции(ТипОбъекта);
			ИмяКоллекцииМетаданных = ИТК_МетаданныеКлиентСерверПовтИсп.ИмяКоллекции(ТипОбъекта, КодЯзыка);
			СтрокаКоллекция = ДобавитьСтрокуДерева(Дерево, ИмяКоллекцииМетаданных, , КартинкаКоллекции);
			
			Для Каждого ОписаниеТипа Из ОписаниеТиповКоллекции Цикл
				
				ОбъектМетаданных = Метаданные.НайтиПоТипу(ОписаниеТипа.Значение);
				ДобавитьСтрокуДерева(СтрокаКоллекция, ОбъектМетаданных.Имя, , КартинкаКоллекции);
				
			КонецЦикла; 
			
		КонецЦикла;
		
	КонецЕсли;
	
	// Добавление системных типов
	Если Системные Тогда
		
		ТипСтрока = "СтандартныйПериод";
		ПредставлениеТипа = НСтр("ru = 'СтандартныйПериод';
								|en = 'StandardPeriod'", КодЯзыка);
		ДобавитьСтрокуДерева(Дерево, ТипСтрока, ПредставлениеТипа, ИТК_Типы.Картинка(Тип(ТипСтрока)));
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ТипСтрокой(Тип) 
	
	ПростыеТипы = Новый Соответствие;
	ПростыеТипы.Вставить(Тип("Число"), "Число");
	ПростыеТипы.Вставить(Тип("Строка"), "Строка");
	ПростыеТипы.Вставить(Тип("Булево"), "Булево");
	ПростыеТипы.Вставить(Тип("Дата"), "Дата");
	ПростыеТипы.Вставить(Тип("УникальныйИдентификатор"), "УникальныйИдентификатор");
	ПростыеТипы.Вставить(Тип("ХранилищеЗначения"), "ХранилищеЗначения");
	ПростыеТипы.Вставить(Тип("Неопределено"), "Неопределено");
	ПростыеТипы.Вставить(Тип("Null"), "Null");
	ПростыеТипы.Вставить(Тип("МоментВремени"), "МоментВремени");
	ПростыеТипы.Вставить(Тип("СтандартныйПериод"), "СтандартныйПериод");
	
	Результат = ПростыеТипы.Получить(Тип);
	Если Результат = Неопределено Тогда
		
		ОбъектМетаданных = Метаданные.НайтиПоТипу(Тип);
		Если ОбъектМетаданных = Неопределено Тогда
			
			ВызватьИсключение СтрШаблон("Нет строкового значения для данного типа: %1", Тип);
			
		Иначе 
			
			Результат = Новый Структура;
			
			Коллекция = ИТК_Метаданные.ИмяКоллекции(ОбъектМетаданных);
			Результат.Вставить("Коллекция", Коллекция);
			Результат.Вставить("Имя", ОбъектМетаданных.Имя);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура УстановитьТекущееЗначение()
	
	Если НЕ ЗначениеЗаполнено(ТекущееЗначение) Тогда
		Возврат;
	КонецЕсли;
	
	Если Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияРедактированиеОписанияТипов() Тогда 
		
		ПерваяСтрока = Неопределено;
		Для Каждого ВыбранныйТип Из ТекущееЗначение.Типы() Цикл 
			
			НайденнаяСтрока = НайтиСтрокуТипа(Дерево, ТипСтрокой(ВыбранныйТип));
			НайденнаяСтрока.Пометка = Истина;
			
			Если ПерваяСтрока = Неопределено Тогда
				ПерваяСтрока = НайденнаяСтрока;
			КонецЕсли;
			
		КонецЦикла;
		
		Если ПерваяСтрока <> Неопределено Тогда
			Элементы.Дерево.ТекущаяСтрока = ПерваяСтрока.ПолучитьИдентификатор();
		КонецЕсли;
		
	ИначеЕсли Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборТипа()
			ИЛИ Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборПроизвольногоТипа() Тогда 
		
		Если ТекущееЗначениеОписаниеТипов().Типы().Количество() <= КоличествоТиповОтображаемыхСразу()
				ИЛИ Дерево.ПолучитьЭлементы().Количество() = 1 Тогда
			Элементы.Дерево.НачальноеОтображениеДерева = НачальноеОтображениеДерева.РаскрыватьВсеУровни;
		КонецЕсли;
		
	ИначеЕсли Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияОтборМетаданных() Тогда 
		
		ОтмеченныеМетаданные = СтрРазделить(ТекущееЗначение, ", ", Ложь);
		Для Каждого Идентификатор Из ОтмеченныеМетаданные Цикл 
			
			НайденнаяСтрока = НайтиСтрокуПоПолномуЗначению(Дерево, Идентификатор);
			НайденнаяСтрока.Пометка = Истина;
			
		КонецЦикла;
		
	ИначеЕсли Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборОбъектаМетаданных() Тогда 
		
		НайденнаяСтрока = НайтиСтрокуПоПолномуЗначению(Дерево, ТекущееЗначение);
		Элементы.Дерево.ТекущаяСтрока = НайденнаяСтрока.ПолучитьИдентификатор();
		
	Иначе
		
		НайденнаяСтрока = НайтиСтрокуТипа(Дерево, ТипСтрокой(ТекущееЗначение));
		Элементы.Дерево.ТекущаяСтрока = НайденнаяСтрока.ПолучитьИдентификатор();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция НайтиСтрокуТипа(КоллекцияСтрок, ОписаниеТипа)
	
	Если ТипЗнч(ОписаниеТипа) = Тип("Структура") Тогда
		
		Для Каждого Строка Из КоллекцияСтрок.ПолучитьЭлементы() Цикл 
			
			Если ЗначениеПоСтроке(Строка) = ОписаниеТипа.Коллекция Тогда
				
				Если ИТК_ФормаКлиентСервер.НеобходимоРазвернутьСтроку(Строка) Тогда
					
					РазвернутьСтрокуКоллекции(Строка.ПолучитьИдентификатор());
					
				КонецЕсли;
				
				Результат = НайтиСтрокуТипа(Строка, ОписаниеТипа.Имя);
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
	Иначе
		
		Для Каждого Строка Из КоллекцияСтрок.ПолучитьЭлементы() Цикл 
			
			Если ЗначениеПоСтроке(Строка) = ОписаниеТипа Тогда
				Результат = Строка;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция НайтиСтрокуПоПолномуЗначению(КоллекцияСтрок, Идентификатор)
	
	Если НЕ СтрНайти(Идентификатор, ".") Тогда
		Возврат НайтиСтрокуПоЗначению(КоллекцияСтрок, Идентификатор);
	КонецЕсли;
	
	ЧастиИдентификатора = СтрРазделить(Идентификатор, ".");
	ИмяОбъектаКоллекции = ЧастиИдентификатора[0];
	ИмяКоллекции = ИТК_МетаданныеКлиентСерверПовтИсп.ИмяКоллекции(ИмяОбъектаКоллекции);
	ИмяОбъекта = ЧастиИдентификатора[1];
	
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПодсистема(ИмяКоллекции) Тогда
		Возврат НайтиСтрокуПодсистемы(Идентификатор);
	КонецЕсли;
	
	ИмяЭлемента = Неопределено;
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоВнешнийИсточникДанных(ИмяКоллекции) Тогда
		ИмяЭлемента = ЧастиИдентификатора[2] + "." + ЧастиИдентификатора[3];
	КонецЕсли;
	
	Для Каждого СтрокаКоллекция Из КоллекцияСтрок.ПолучитьЭлементы() Цикл 
		
		Если ЗначениеПоСтроке(СтрокаКоллекция) <> ИмяКоллекции Тогда
			Продолжить;
		КонецЕсли;
			
		Если ИТК_ФормаКлиентСервер.НеобходимоРазвернутьСтроку(СтрокаКоллекция) Тогда
			РазвернутьСтрокуКоллекции(СтрокаКоллекция.ПолучитьИдентификатор());
		КонецЕсли;
		
		Результат = НайтиСтрокуПоЗначению(СтрокаКоллекция, ИмяОбъекта);
		Если ЗначениеЗаполнено(ИмяЭлемента) Тогда
			Результат = НайтиСтрокуПоЗначению(Результат, ИмяЭлемента);
		КонецЕсли;
		
		Прервать;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция НайтиСтрокуПоЗначению(Родитель, Значение)
	
	Результат = Неопределено;
	Для Каждого Строка Из Родитель.ПолучитьЭлементы() Цикл 
		
		Если ЗначениеПоСтроке(Строка) = Значение Тогда
			
			Результат = Строка;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ДобавитьСтрокуДерева(Родитель, Значение = Неопределено, Представление = "", Картинка = Неопределено, Выбирается = Истина)

	НоваяСтрока = Родитель.ПолучитьЭлементы().Добавить();
	НоваяСтрока.Картинка = Картинка;
	НоваяСтрока.Выбирается = Выбирается;
	
	Если ПустаяСтрока(Представление) Тогда
		
		Представление = Значение;
		
	КонецЕсли;
	НоваяСтрока.Представление = Представление;
	
	Если Представление <> Значение Тогда
		
		НоваяСтрока.Значение = Значение;
		
	КонецЕсли;
	
	Если ТипЗнч(Родитель) <> Тип("ДанныеФормыДерево") Тогда
		
		НоваяСтрока.Пометка = Родитель.Пометка;
		
	КонецЕсли;
	
    Возврат НоваяСтрока;
	
КонецФункции

&НаСервере
Процедура РазвернутьСтрокуКоллекции(ИдентификаторСтроки)
	
	РазворачиваемаяСтрока = Дерево.НайтиПоИдентификатору(ИдентификаторСтроки);
	РазворачиваемаяСтрока.ПолучитьЭлементы().Очистить();
	
	ИмяКоллекции = РазворачиваемаяСтрока.Представление;
	
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПодсистема(ИмяКоллекции) Тогда
		
		РазвернутьСтрокуПодсистемы(РазворачиваемаяСтрока, Метаданные);
		Возврат;
		
	Иначе
		
		СписокИменКоллекции = ИТК_МетаданныеПовтИсп.КэшИменКоллекции(ИмяКоллекции);
		
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоВнешнийИсточникДанных(ИмяКоллекции) Тогда
			
			Для Каждого ЭлементСписка Из СписокИменКоллекции Цикл 
				
				ИмяОбъектаКоллекции = ЭлементСписка.Представление;
				СтрокаВнешнийИсточник = ДобавитьСтрокуДерева(РазворачиваемаяСтрока, , ИмяОбъектаКоллекции, РазворачиваемаяСтрока.Картинка, Ложь);
				
				Для Каждого ТаблицаВнешнегоИсточника Из Метаданные[ИмяКоллекции][ИмяОбъектаКоллекции].Таблицы Цикл 
					
					ДобавитьСтрокуДерева(СтрокаВнешнийИсточник, "Таблица." + ТаблицаВнешнегоИсточника.Имя, ТаблицаВнешнегоИсточника.Имя, ИТК_ОбщийКлиентСерверПовтИсп.БиблиотекаКартинок("ВнешнийИсточникДанныхТаблица"));
					
				КонецЦикла;
				
			КонецЦикла;
			
		Иначе
			
			Для Каждого ЭлементСписка Из СписокИменКоллекции Цикл 
				
				ИмяОбъектаКоллекции = ЭлементСписка.Представление;
				ДобавитьСтрокуДерева(РазворачиваемаяСтрока, ИмяОбъектаКоллекции, , РазворачиваемаяСтрока.Картинка);
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура РазвернутьСтрокуПодсистемы(Строка, КоллекцияМетаданных)
	
	СписокЗначений = Новый СписокЗначений;
	
	Для Каждого ОбъектМетаданных Из КоллекцияМетаданных.Подсистемы Цикл 
		СписокЗначений.Добавить(ОбъектМетаданных, ОбъектМетаданных.Имя);
	КонецЦикла;
	
	СписокЗначений.СортироватьПоПредставлению();
	
	Для Каждого ЭлементСписка Из СписокЗначений Цикл 
		
		ИмяОбъектаКоллекции = ЭлементСписка.Представление;
		ОбъектКоллекция = ЭлементСписка.Значение;
		
		Если ТипЗнч(КоллекцияМетаданных) = Тип("ОбъектМетаданныхКонфигурация") Тогда
			ЗначениеСтроки = ИмяОбъектаКоллекции;
		Иначе
			ЗначениеСтроки = "Подсистема." + ИмяОбъектаКоллекции;
		КонецЕсли;
		
		НоваяСтрока = ДобавитьСтрокуДерева(Строка, ЗначениеСтроки, ИмяОбъектаКоллекции, Строка.Картинка);
		РазвернутьСтрокуПодсистемы(НоваяСтрока, ОбъектКоллекция);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция НайтиСтрокуПодсистемы(Идентификатор)
	
	ЧастиИдентификатора = СтрРазделить(Идентификатор, ".");
	
	// Найдем строку коллекцию "Подсистемы"
	СтрокаКоллекцияПодсистемы = Неопределено;
	Для Каждого СтрокаКоллекция Из Дерево.ПолучитьЭлементы() Цикл 
		
		ИмяКоллекции = ЗначениеПоСтроке(СтрокаКоллекция);
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПодсистема(ИмяКоллекции) Тогда
			СтрокаКоллекцияПодсистемы = СтрокаКоллекция;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ИТК_ФормаКлиентСервер.НеобходимоРазвернутьСтроку(СтрокаКоллекцияПодсистемы) Тогда
		
		ИдентификаторСтроки = СтрокаКоллекцияПодсистемы.ПолучитьИдентификатор();
		РазвернутьСтрокуКоллекции(ИдентификаторСтроки)
		
	КонецЕсли;
	
	// Найдем строку подсистемы
	ИндексПодсистемы = 1;
	СтрокаРодитель = СтрокаКоллекцияПодсистемы;
	Пока ИндексПодсистемы <= ЧастиИдентификатора.ВГраница() Цикл
		
		Если ИндексПодсистемы = 1 Тогда
			ИмяПодсистемы = ЧастиИдентификатора[ИндексПодсистемы];
		Иначе
			ИмяПодсистемы = ЧастиИдентификатора[ИндексПодсистемы - 1] + "." + ЧастиИдентификатора[ИндексПодсистемы];
		КонецЕсли;
		СтрокаРодитель = НайтиСтрокуПоЗначению(СтрокаРодитель, ИмяПодсистемы);
		
		ИндексПодсистемы = ИндексПодсистемы + 2;
		
	КонецЦикла;
	
	Возврат СтрокаРодитель;
	
КонецФункции

&НаСервере
Функция СписокПростыхТипов(КодЯзыкаПрограммирования, РедактированиеТипа = Истина)
	
	Результат = Новый СписокЗначений;
	
	Результат.Добавить(ТипСтрокой(Тип("Число")), НСтр("ru = 'Число';
														|en = 'Number'", КодЯзыкаПрограммирования));
	Результат.Добавить(ТипСтрокой(Тип("Строка")), НСтр("ru = 'Строка';
														|en = 'String'", КодЯзыкаПрограммирования));
	Результат.Добавить(ТипСтрокой(Тип("Булево")), НСтр("ru = 'Булево';
														|en = 'Boolean'", КодЯзыкаПрограммирования));
	Результат.Добавить(ТипСтрокой(Тип("Дата")), НСтр("ru = 'Дата';
													|en = 'Date'", КодЯзыкаПрограммирования));
	Результат.Добавить(ТипСтрокой(Тип("УникальныйИдентификатор")), НСтр("ru = 'УникальныйИдентификатор';
																		|en = 'UUID'", КодЯзыкаПрограммирования));
	
	Тип = Тип("ХранилищеЗначения");
	Если РедактированиеТипа 
			ИЛИ ТекущееЗначениеОписаниеТипов().СодержитТип(Тип) Тогда 
		Результат.Добавить(ТипСтрокой(Тип), НСтр("ru = 'ХранилищеЗначения';
												|en = 'ValueStorage'", КодЯзыкаПрограммирования));
	КонецЕсли;
	
	Тип = Тип("Неопределено");
	Если РедактированиеТипа 
			ИЛИ ТекущееЗначениеОписаниеТипов().СодержитТип(Тип) Тогда 
		Результат.Добавить(ТипСтрокой(Тип), НСтр("ru = 'Неопределено';
												|en = 'Undefined'", КодЯзыкаПрограммирования));
	КонецЕсли;
	
	Тип = Тип("Null");
	Если РедактированиеТипа 
			ИЛИ ТекущееЗначениеОписаниеТипов().СодержитТип(Тип) Тогда 
		Результат.Добавить(ТипСтрокой(Тип));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	ПоискЗаполнен = ЗначениеЗаполнено(Поиск);
	РежимРедактированиеОписанияТипов = (Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияРедактированиеОписанияТипов());
	РежимОтборМетаданных = (Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияОтборМетаданных());
	ОтображатьПометку = РежимРедактированиеОписанияТипов ИЛИ РежимОтборМетаданных;
	
	Идентификатор = ИдентификаторТекущейСтроки();
	
	Элементы.Дерево.Видимость = Не ПоискЗаполнен;
	Элементы.Список.Видимость = ПоискЗаполнен;
	
	Элементы.Поиск.Видимость = ПоискДоступен(ТекущееЗначение, Режим);
	Элементы.Составной.Видимость = РежимРедактированиеОписанияТипов;
	Элементы.ДеревоПометка.Видимость = ОтображатьПометку;
	Элементы.СписокПометка.Видимость = ОтображатьПометку;
	
	Элементы.СписокКонтекстноеМенюУстановитьВсе.Видимость = РежимОтборМетаданных;
	Элементы.СписокКонтекстноеМенюСнятьВсе.Видимость = РежимОтборМетаданных;
	
	Если РежимРедактированиеОписанияТипов Тогда
		
		ТипСтрокой = ""; 
		ПометкаСтроки = Ложь;
		Если Идентификатор <> Неопределено Тогда
			
			НайденнаяСтрока = НайтиСтрокуПоИдентификатору(Идентификатор);
			ТипСтрокой = ЗначениеПоСтроке(НайденнаяСтрока);
			ПометкаСтроки = НайденнаяСтрока.Пометка;
			
		КонецЕсли;
		
		ТипСтрокиДата = (ТипСтрокой = "Дата");
		ТипСтрокиЧисло = (ТипСтрокой = "Число");
		ТипСтрокиСтрока = (ТипСтрокой = "Строка");
		
		Элементы.ГруппаДата.Видимость = ТипСтрокиДата;
		Элементы.ГруппаДата.Доступность = ТипСтрокиДата И ПометкаСтроки;
		Элементы.ГруппаЧисло.Видимость = ТипСтрокиЧисло;
		Элементы.ГруппаЧисло.Доступность = ТипСтрокиЧисло И ПометкаСтроки;
		Элементы.ГруппаСтрока.Видимость = ТипСтрокиСтрока;
		Элементы.ГруппаСтрока.Доступность = ТипСтрокиСтрока И ПометкаСтроки;
		Элементы.СтрокаТип.Доступность = СтрокаДлина < ИТК_МетаданныеКлиентСерверПовтИсп.МаксимальнаяДлинаФиксированнойСтроки() И Не СтрокаНеограниченная;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновлениеЭлементовФормыПослеОжидания()
	
	ПодключитьОбработчикОжидания("ПодключаемыйОбновлениеЭлементовФормыПослеОжидания", 0.1, Истина);	
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйОбновлениеЭлементовФормыПослеОжидания()

	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
	НесколькоПомеченных = НесколькоПомеченных(Составной, Режим);
	Оформление = Новый Структура("Отображать", НесколькоПомеченных);
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "ДеревоПометка", Оформление, "Дерево.Выбирается", Ложь);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСписокСервер()
	
	// Получим все строки коллекций
	Для Каждого Строка Из Дерево.ПолучитьЭлементы() Цикл 
		
		Если ИТК_ФормаКлиентСервер.НеобходимоРазвернутьСтроку(Строка) Тогда
			РазвернутьСтрокуКоллекции(Строка.ПолучитьИдентификатор());
		КонецЕсли;
		
	КонецЦикла;
	
	ПараметрыПоиска = ИТК_Строки.ПараметрыПоискаПоПодобию(Поиск);
	ДобавитьВСписок(Дерево, ПараметрыПоиска);
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьВСписок(КоллекцияСтрок, ПараметрыПоиска)
	
	Для Каждого Строка Из КоллекцияСтрок.ПолучитьЭлементы() Цикл 
		
		ЭтоГруппа = ЗначениеЗаполнено(Строка.ПолучитьЭлементы());
		
		Если ЭтоГруппа Тогда
			
			Если ЗначениеЗаполнено(ПараметрыПоиска.Коллекция)
					И НЕ СтрНайти(НРег(Строка.Представление), ПараметрыПоиска.Коллекция) Тогда 
				Продолжить;
			КонецЕсли;
			
			ДобавитьВСписок(Строка, ПараметрыПоиска);
			
		Иначе
			
			АнализируемаяСтрока = НРег(Строка.Представление);
			Если НЕ ИТК_Строки.ПоискПоПодобиюНайденыСовпадения(АнализируемаяСтрока, ПараметрыПоиска) Тогда
				Продолжить;
			КонецЕсли;
				
			Идентификатор = ИдентификаторСтроки(Строка);
			Список.Добавить(Идентификатор, Строка.Представление, Строка.Пометка, Строка.Картинка);
			
		КонецЕсли;
		
		Если Список.Количество() = 50 Тогда
			Возврат;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбраноЗначение(Строка, Завершается = Ложь)
	
	РежимВыбораТипа = (Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборТипа());
	РежимВыбораПроизвольногоТипа = (Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборПроизвольногоТипа());
	РежимОтборМетаданных = (Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияОтборМетаданных());
	РежимВыборОбъектаМетаданных = (Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборОбъектаМетаданных());
	РежимРедактированиеОписанияТипов = (Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияРедактированиеОписанияТипов());
	
	Если Не Завершается 
			И (РежимРедактированиеОписанияТипов 
					ИЛИ РежимОтборМетаданных) Тогда
		Возврат;
		
	КонецЕсли;
	
	Если РежимРедактированиеОписанияТипов Тогда
		
		Результат = ВыбраноЗначениеОписанияТипов();
		
	ИначеЕсли РежимОтборМетаданных Тогда
		
		Результат = ВыбраноЗначениеОтбораМетаданных();
		
	ИначеЕсли РежимВыборОбъектаМетаданных Тогда
		
		Если Не Строка.Выбирается Тогда
			Возврат;
		КонецЕсли;
		
		Результат = ПолноеИмяСтроки(Строка);
		
	Иначе
		
		Если НЕ Строка.Выбирается Тогда
			Возврат;
		КонецЕсли;
		
		ПолноеИмяТипа = ПолноеИмяТипаСтроки(Строка);
		Если РежимВыбораПроизвольногоТипа Тогда
			Результат = РезультатВХранилище(ПолноеИмяТипа);
		ИначеЕсли РежимВыбораТипа Тогда
			
			Тип = Тип(ПолноеИмяТипа);
			Результат = ИТК_ТипыКлиентСервер.ОписаниеТиповПоТипу(Тип);
			
		Иначе
			Результат = Тип(ПолноеИмяТипа);
		КонецЕсли;
		
	КонецЕсли;
	
	// Возвращаем значение
	Если ЗакрыватьПриВыборе Тогда
		Закрыть(Результат);
	Иначе
		ОповеститьОВыборе(Результат);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ВыбраноЗначениеОписанияТипов()
	
	ВыбранныеТипы = Новый Массив;
	СобратьЗначениеОписанияТипов(Дерево, ВыбранныеТипы);
	СписокТипов = СтрСоединить(ВыбранныеТипы, ",");
	
	Если ЧислоНеотрицательное Тогда
		ЗначениеДопустимыйЗнак = ДопустимыйЗнак.Неотрицательный;
	Иначе
		ЗначениеДопустимыйЗнак = ДопустимыйЗнак.Любой;
	КонецЕсли;
	КвалификаторЧисла = Новый КвалификаторыЧисла(ЧислоДлина, ЧислоТочность, ЗначениеДопустимыйЗнак);
	
	КвалификаторСтроки = Новый КвалификаторыСтроки(СтрокаДлина, СтрокаТип);
	КвалификаторДаты = Новый КвалификаторыДаты(ДатаСостав);
	
	Результат = Новый ОписаниеТипов(СписокТипов, КвалификаторЧисла, КвалификаторСтроки, КвалификаторДаты);
	
	Возврат Результат;
		
КонецФункции

&НаСервере
Процедура СобратьЗначениеОписанияТипов(Родитель, ВыбранныеТипы)
	
	Для Каждого Строка Из Родитель.ПолучитьЭлементы() Цикл 
		
		Если Не Строка.Пометка Тогда
			Продолжить;
		КонецЕсли;
		
		Если Строка.Выбирается Тогда
			
			ПолноеИмяТипа = ПолноеИмяТипаСтроки(Строка);
			ВыбранныеТипы.Добавить(ПолноеИмяТипа);
			
		Иначе
			
			Если Строка.Пометка = 1 Тогда
				
				Коллекция = ЗначениеПоСтроке(Строка);
				ИмяОбъектаКоллекции = ИТК_Метаданные.ИмяОбъектаКоллекции(Коллекция);

				Для Каждого ОбъектМетаданных Из Метаданные[Коллекция] Цикл 
					
					ПолноеИмяТипа = ИТК_МетаданныеКлиентСервер.ПолноеИмяТипаСсылка(ИмяОбъектаКоллекции, ОбъектМетаданных.Имя);
					ВыбранныеТипы.Добавить(ПолноеИмяТипа);

				КонецЦикла;
				
			ИначеЕсли Строка.Пометка = 2 Тогда
				
				СобратьЗначениеОписанияТипов(Строка, ВыбранныеТипы);
				
			КонецЕсли;
			
		КонецЕсли;
			
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ВыбраноЗначениеОтбораМетаданных()
	
	Результат = Новый Массив;
	СобратьЗначениеОтбораМетаданных(Дерево, Результат);
	
	Возврат СтрСоединить(Результат, ", ");
		
КонецФункции

&НаСервере
Процедура СобратьЗначениеОтбораМетаданных(Родитель, Выбранные)
	
	Для Каждого Строка Из Родитель.ПолучитьЭлементы() Цикл 
		
		Если Строка.Пометка = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если Строка.Пометка = 1 Тогда
			
			Если Строка.Выбирается Тогда
				
				ПолноеИмя = ПолноеИмяСтроки(Строка);
				Выбранные.Добавить(ПолноеИмя);
				
			Иначе
				
				Коллекция = ЗначениеПоСтроке(Строка);
				Выбранные.Добавить(Коллекция);
				Продолжить;
				
			КонецЕсли;
			
		КонецЕсли;
		СобратьЗначениеОтбораМетаданных(Строка, Выбранные);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ИдентификаторСтроки(Строка)
	
	Если Строка = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ЧастиИдентификатора = Новый Массив;
	ЧастиИдентификатора.Добавить(ЗначениеПоСтроке(Строка));
	
	Родитель = Строка.ПолучитьРодителя();
	Пока Родитель <> Неопределено Цикл 
		
		ЧастиИдентификатора.Вставить(0, ЗначениеПоСтроке(Родитель));
		Родитель = Родитель.ПолучитьРодителя();
		
	КонецЦикла;
	
	Возврат СтрСоединить(ЧастиИдентификатора, ".");
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПолноеИмяТипаСтроки(Строка)
	
	Если Строка = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Родитель = Строка.ПолучитьРодителя();
	Если Родитель = Неопределено Тогда
		Результат = ЗначениеПоСтроке(Строка);
	Иначе
		
		ИмяКоллекции = ЗначениеПоСтроке(Родитель);
		ИмяОбъектаКоллекции = ИТК_МетаданныеКлиентСерверПовтИсп.ИмяОбъектаКоллекции(ИмяКоллекции);
		
		Результат = ИТК_МетаданныеКлиентСервер.ПолноеИмяТипаСсылка(ИмяОбъектаКоллекции, ЗначениеПоСтроке(Строка));
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПолноеИмяСтроки(Строка)
	
	Родитель = Строка.ПолучитьРодителя();
	РодительРодителя = Родитель.ПолучитьРодителя();
	
	ЧастиРезультата = Новый Массив;
	
	Если РодительРодителя = Неопределено Тогда
		СтрокаКоллекция = Родитель;
	Иначе
		СтрокаКоллекция = РодительРодителя;
	КонецЕсли;
	
	ИмяКоллекции = ЗначениеПоСтроке(СтрокаКоллекция);
	ИмяОбъектаКоллекции = ИТК_МетаданныеКлиентСерверПовтИсп.ИмяОбъектаКоллекции(ИмяКоллекции);
	ЧастиРезультата.Добавить(ИмяОбъектаКоллекции);
	
	Если РодительРодителя <> Неопределено Тогда
		
		ИмяРодителяОбъектаКоллекции = ЗначениеПоСтроке(Родитель);
		ЧастиРезультата.Добавить(ИмяРодителяОбъектаКоллекции);
		
	КонецЕсли;
	
	ЧастиРезультата.Добавить(ЗначениеПоСтроке(Строка));
	
	Возврат СтрСоединить(ЧастиРезультата, ".");
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЗначениеПоСтроке(Строка)
	
	Если ПустаяСтрока(Строка.Значение) Тогда
		
		Результат = Строка.Представление;
		
	Иначе
		
		Результат = Строка.Значение;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьПометкиДерева(Родитель)
	
	Для Каждого Строка Из Родитель.ПолучитьЭлементы() Цикл 
		
		Если ИТК_ФормаКлиентСервер.НеобходимоРазвернутьСтроку(Строка) Тогда
			Продолжить;
		КонецЕсли;
		
		ПодчиненныеСтроки = Строка.ПолучитьЭлементы();
		Если ПодчиненныеСтроки.Количество() = 0 Тогда 
			Продолжить;
		КонецЕсли;
		
		ПодчиненнаяСтрока = ПодчиненныеСтроки[0];
		ИТК_ФормаКлиент.ДеревоОпределитьПометкуРодителя(ПодчиненнаяСтрока, ПодчиненнаяСтрока.Пометка);
			
		Если Строка.Пометка = 2 Тогда
			
			Идентификатор = Строка.ПолучитьИдентификатор();
			Элементы.Дерево.Развернуть(Идентификатор);
			
		КонецЕсли;
		ЗаполнитьПометкиДерева(Строка);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановкаСнятиеПометки(Строка, Идентификатор, Пометка = Неопределено)
	
	Если Пометка = Неопределено Тогда
		Пометка = ИТК_ФормаКлиент.ОпределитьПометкуТриСостояния(Строка);
	КонецЕсли;
	
	// Установка пометки подчиненным
	ИТК_ФормаКлиент.ДеревоУстановитьПодчиненнымПометку(Строка, Пометка);
	
	Если НЕ Строка.Выбирается Тогда
		Возврат;
	КонецЕсли;
	
	НесколькоПомеченных = НесколькоПомеченных(Составной, Режим);
	Если НесколькоПомеченных Тогда
		ОтметитьСтрокуВЭлементах(Идентификатор, Пометка);
	Иначе
		
		Если Пометка Тогда
			СнятьВсеОтмеченныеДобавитьОдну(Идентификатор);
		КонецЕсли;
		
	КонецЕсли;
	
	ИТК_ФормаКлиент.ДеревоОпределитьПометкуРодителя(Строка, Пометка);
	
КонецПроцедуры

&НаКлиенте
Процедура СнятьВсеОтмеченныеДобавитьОдну(Идентификатор)
	
	ИТК_ФормаКлиент.ДеревоУстановитьПодчиненнымПометку(Дерево, Ложь);
	
	// Снять все пометки списка
	Для Каждого ЭлементСписка Из Список Цикл 
		ЭлементСписка.Пометка = Ложь;
	КонецЦикла;
	
	// Установить новую пометку
	Если ЗначениеЗаполнено(Идентификатор) Тогда
		
		ОтметитьСтрокуВЭлементах(Идентификатор, Истина);
		
		НайденнаяСтрока = НайтиСтрокуПоИдентификатору(Идентификатор);
		ИТК_ФормаКлиент.ДеревоОпределитьПометкуРодителя(НайденнаяСтрока, НайденнаяСтрока.Пометка);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтметитьСтрокуВЭлементах(Идентификатор, Пометка)
	
	// Пометки в дереве
	НайденнаяСтрока = НайтиСтрокуПоИдентификатору(Идентификатор);
	НайденнаяСтрока.Пометка = Пометка;
	
	// Пометки в списке
	НайденныйЭлемент = Список.НайтиПоЗначению(Идентификатор);
	Если НайденныйЭлемент <> Неопределено Тогда
		НайденныйЭлемент.Пометка = Пометка;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьМаксимальнуюДлинуСтроки()
	
	Если СтрокаТип = ДопустимаяДлина.Переменная Тогда
		
		Максимум = ИТК_МетаданныеКлиентСерверПовтИсп.МаксимальнаяДлинаСтроки();
		
	Иначе
		
		Максимум = ИТК_МетаданныеКлиентСерверПовтИсп.МаксимальнаяДлинаФиксированнойСтроки();
		
	КонецЕсли;
	
	Элементы.СтрокаДлина.МаксимальноеЗначение = Максимум;
	
КонецПроцедуры

&НаКлиенте
Функция НайтиСтрокуПоИдентификатору(Идентификатор)
	
	ЧастиИдентификатора = СтрРазделить(Идентификатор, ".");
	
	ИмяКоллекции = ЧастиИдентификатора[0];
	Для Каждого СтрокаКоллекция Из Дерево.ПолучитьЭлементы() Цикл 
		
		Если ЗначениеПоСтроке(СтрокаКоллекция) <> ИмяКоллекции Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЧастиИдентификатора.Количество() = 1 Тогда
			Возврат СтрокаКоллекция;
		КонецЕсли;
		
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПодсистема(ИмяКоллекции) Тогда
			
			ИндексУровня = 1;
			Возврат НайтиСтрокуПодстему(СтрокаКоллекция, ЧастиИдентификатора, ИндексУровня);
			
		Иначе
			
			Для Каждого СтрокаОбъектМетаданных Из СтрокаКоллекция.ПолучитьЭлементы() Цикл 
				
				Если ЗначениеПоСтроке(СтрокаОбъектМетаданных) <> ЧастиИдентификатора[1] Тогда
					Продолжить;
				КонецЕсли;
				
				Если ЧастиИдентификатора.Количество() = 2 Тогда
					Возврат СтрокаОбъектМетаданных;
				КонецЕсли;
				
				Для Каждого СтрокаЭлементОбъектМетаданных Из СтрокаОбъектМетаданных.ПолучитьЭлементы() Цикл 
					
					Если ЗначениеПоСтроке(СтрокаЭлементОбъектМетаданных) <> "Таблица." + ЧастиИдентификатора[2] Тогда
						Продолжить;
					КонецЕсли;
					
					Возврат СтрокаЭлементОбъектМетаданных;
					
				КонецЦикла
				
			КонецЦикла
			
		КонецЕсли;
		
	КонецЦикла;

	Возврат Неопределено;
	
КонецФункции

&НаКлиенте
Функция НайтиСтрокуПодстему(СтрокаРодитель, ЧастиИдентификатора, ИндексУровня)
	
	Для Каждого СтрокаОбъектМетаданных Из СтрокаРодитель.ПолучитьЭлементы() Цикл 
		
		Если ИндексУровня = 1 Тогда
			ИскомыйИдентификатор = ЧастиИдентификатора[ИндексУровня];
		Иначе 
			ИскомыйИдентификатор = ЧастиИдентификатора[ИндексУровня - 1] + "." + ЧастиИдентификатора[ИндексУровня];
		КонецЕсли;
		
		Если ЗначениеПоСтроке(СтрокаОбъектМетаданных) <> ИскомыйИдентификатор Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЧастиИдентификатора.ВГраница() = ИндексУровня Тогда
			Возврат СтрокаОбъектМетаданных;
		КонецЕсли;
		
		ИндексУровня = ИндексУровня + 2;
		Возврат НайтиСтрокуПодстему(СтрокаОбъектМетаданных, ЧастиИдентификатора, ИндексУровня);
		
	КонецЦикла;
	
	Возврат Неопределено;

КонецФункции

&НаКлиенте
Функция ИдентификаторТекущейСтроки()
	
	Результат = Неопределено;
	Если ЗначениеЗаполнено(Поиск) Тогда
		
		СписокТекущиеДанные = Элементы.Список.ТекущиеДанные;
		Если СписокТекущиеДанные <> Неопределено Тогда
			Результат = СписокТекущиеДанные.Значение;
		КонецЕсли;
		
	Иначе
		
		Результат = ИдентификаторСтроки(Элементы.Дерево.ТекущиеДанные);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ИдентификаторПервойОтмеченнойСтроки()
	
	Результат = Неопределено;
	
	Для Каждого Строка Из Дерево.ПолучитьЭлементы() Цикл 
		
		Если Строка.Пометка Тогда
			
			Если Строка.Выбирается Тогда
				
				Результат = ИдентификаторСтроки(Строка);
				Прервать;
				
			КонецЕсли;
			
			Для Каждого ПодчиненнаяСтрока Из Строка.ПолучитьЭлементы() Цикл
				
				Если ПодчиненнаяСтрока.Пометка И ПодчиненнаяСтрока.Выбирается Тогда
					
					Результат = ИдентификаторСтроки(ПодчиненнаяСтрока);
					Возврат Результат;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция КоличествоТиповОтображаемыхСразу()
	
	Возврат 20;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПоискДоступен(Значение, Режим)
	
	Если ТипЗнч(Значение) = Тип("ОписаниеТипов")
			И Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборТипа() Тогда

		МинимальноеЧислоТипов = 7;
		КоличествоТипов = Значение.Типы().Количество();
		Результат = (КоличествоТипов = 0 ИЛИ КоличествоТипов > МинимальноеЧислоТипов);
		
	Иначе
		
		Результат = Истина;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура УстановитьЗаголовок()
	
	Если Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборТипа() Тогда
		
		Заголовок = НСтр("ru = 'Выбор типа';
						|en = 'Type selection'");
		
	ИначеЕсли Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияОтборМетаданных() Тогда
		
		Заголовок = НСтр("ru = 'Отбор метаданных';
						|en = 'Selection of metadata'");
		
	ИначеЕсли Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборОбъектаМетаданных() Тогда
		
		Заголовок = НСтр("ru = 'Выбор объекта метаданных';
						|en = 'Selecting a metadata object'");
		
	Иначе 
		
		ШаблонЗаголовка = НСтр("ru = 'Редактирование типа (%1)';
								|en = 'Edit type (%1)'");
		Заголовок = СтрШаблон(ШаблонЗаголовка, Параметры.Заголовок);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция НесколькоПомеченных(Составной, Режим)
	
	Возврат (Составной 
				ИЛИ Режим = ИТК_Перечисления.РежимРедактированияТипаЗначенияОтборМетаданных());
	
КонецФункции

&НаКлиенте
Процедура УстановитьПометкиСписка(Пометка = Истина)
	
	Для Каждого ЭлементСписка Из Список Цикл 
		
		ЭлементСписка.Пометка = Пометка;
		НайденнаяСтрока = НайтиСтрокуПоИдентификатору(ЭлементСписка.Значение);
		
		НайденнаяСтрока.Пометка = Пометка;
		ИТК_ФормаКлиент.ДеревоОпределитьПометкуРодителя(НайденнаяСтрока, НайденнаяСтрока.Пометка);
		
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйТекущийЭлементСтрокаПоискаПослеОжидания()

	ТекущийЭлемент = Элементы.Поиск;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция РезультатВХранилище(ПолноеИмяТипа)
	
	ОписаниеТипов = ИТК_ТипыКлиентСервер.ОписаниеТиповПоТипу(Тип(ПолноеИмяТипа));
	Возврат Новый ХранилищеЗначения(ОписаниеТипов);
	
КонецФункции

&НаСервере
Функция ТекущееЗначениеОписаниеТипов()
	Если ТипЗнч(ТекущееЗначение) = Тип("ХранилищеЗначения") Тогда
		Результат = ТекущееЗначение.Получить();
	Иначе
		Результат = ТекущееЗначение;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти