#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Значение = Параметры.НачальноеЗначение;
	
	ОписаниеЗначения = ИТК_ПроизвольноеЗначение.ОписаниеЗначения(Значение);
	ПредставлениеЗначения = ОписаниеЗначения.Значение;
	Тип = ОписаниеЗначения.ТипЗначенияВКонтейнере;
	
	Элементы.ПредставлениеЗначения.РедактированиеТекста = ОписаниеЗначения.РедактируетсяВПоле;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИТК_ПроизвольноеЗначениеКлиент.АктивизацияЗначенияВФорме(Элементы.ПредставлениеЗначения, Значение);
	ОбновитьПредставленияЗначенийНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПредставлениеЗначенияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("ВводЗначенияЗавершен", ЭтотОбъект, Новый Структура);
	ИТК_ПроизвольноеЗначениеКлиент.ОбработкаНачалоВыбора(Элемент, Значение, ОписаниеОповещенияЗавершение, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПредставлениеЗначенияПриИзменении(Элемент)
	ОбновитьЗначениеНаСервере(ПредставлениеЗначения);
КонецПроцедуры

&НаКлиенте
Процедура ПредставлениеЗначенияОчистка(Элемент, СтандартнаяОбработка)
	
	ИТК_ПроизвольноеЗначениеКлиент.ОбработкаОчистка(Элемент, СтандартнаяОбработка, Значение);
	ОбновитьПредставленияЗначенийНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Сохранить(Команда)
	Закрыть(Значение);
КонецПроцедуры

&НаКлиенте
Процедура Отмена(Команда)
	Закрыть();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ВводЗначенияЗавершен(НовоеЗначение, ДополнительныеПараметры) Экспорт
	
	Если НовоеЗначение = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВыборТипа = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "ВыборТипа", Ложь);
	Если ВыборТипа Тогда 
		ОбновитьЗначениеПоТипуНаСервере(НовоеЗначение);
	Иначе
		ОбновитьЗначениеНаСервере(НовоеЗначение)
	КонецЕсли;
	ИТК_ПроизвольноеЗначениеКлиент.АктивизацияЗначенияВФорме(Элементы.ПредставлениеЗначения, Значение);
	
	ОбновитьПредставленияЗначенийНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьЗначениеНаСервере(НовоеЗначение)
	
	Если ТипЗнч(НовоеЗначение) = Тип("ХранилищеЗначения") Тогда
		Значение = НовоеЗначение;
	Иначе
		Значение = Новый ХранилищеЗначения(НовоеЗначение);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьЗначениеПоТипуНаСервере(ТипЗначенияВКонтейнере)
	
	ТипЗначения = ТипЗначенияВКонтейнере.Получить();
	НовоеЗначение = ТипЗначения.ПривестиЗначение(Неопределено);
	ОбновитьЗначениеНаСервере(НовоеЗначение);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьПредставленияЗначенийНаСервере()
	
	ОписаниеЗначения = ИТК_ПроизвольноеЗначение.ОписаниеЗначения(Значение);
	
	ПредставлениеЗначения = ОписаниеЗначения.Значение;
	ТипПредставление = ИТК_Типы.ПредставлениеОписания(ОписаниеЗначения.ТипЗначения);
	
КонецПроцедуры

#КонецОбласти