#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	АдресСхемыЗапроса = Параметры.АдресСхемыЗапроса;
	ИндексЗапросаПакета = Параметры.ИндексЗапросаПакета;
	
	ДополнительныйТекст = НСтр("ru = 'В результат поиска выводится не более 50 найденных.'; en = 'The search result displays no more than 50 found.'");
	ИТК_ФормаКлиентСервер.ОформитьСтрокуПоискаПоПодобию(Элементы.СтрокаПоиска, ДополнительныйТекст);
	
	ДоступныТаблицыИзменений = Параметры.ДоступныТаблицыИзменений;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СтрокаПоискаПриИзменении(Элемент)
	
	ОбновитьРезультатПоиска();
	ПодключитьОбработчикОжидания("ПодключаемыйТекущийЭлементСтрокаПоискаПослеОжидания", 0.2, Истина);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыНайденные

&НаКлиенте
Процедура НайденныеВыбор(Элемент, ИдентификаторВыбраннойСтроки, Поле, СтандартнаяОбработка)
	
	ВыбраннаяСтрока = Найденные.НайтиПоИдентификатору(ИдентификаторВыбраннойСтроки);
	Закрыть(ВыбраннаяСтрока.Значение);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьРезультатПоиска()
	
	ОбновитьРезультатПоискаНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьРезультатПоискаНаСервере()
	
	Найденные.Очистить();
	МаксимальноеКоличествоНайденных = 50;
	
	Если НЕ ЗначениеЗаполнено(АдресКэшаПоиска) Тогда
		ИнициализироватьКэшПоиска();
	КонецЕсли;
	КэшПоиска = ПолучитьИзВременногоХранилища(АдресКэшаПоиска);
	
	ПараметрыПоиска = ИТК_Строки.ПараметрыПоискаПоПодобию(СтрокаПоиска);
	Для Каждого ЭлементДоступныхТаблиц Из КэшПоиска Цикл 
		
		ОписаниеКоллекции = ЭлементДоступныхТаблиц.Значение;
		Если ЗначениеЗаполнено(ПараметрыПоиска.Коллекция)
				И НЕ СтрНайти(НРег(ОписаниеКоллекции.ИмяКоллекции), ПараметрыПоиска.Коллекция) Тогда
			Продолжить;
		КонецЕсли;
		
		КартинкаКоллекции = ЭлементДоступныхТаблиц.Картинка;
		
		Для Каждого ОписаниеТаблицы Из ОписаниеКоллекции.Состав Цикл 
			
			Если НЕ ИТК_Строки.ПоискПоПодобиюНайденыСовпадения(ОписаниеТаблицы.ИмяНРег, ПараметрыПоиска) Тогда
				Продолжить;
			КонецЕсли;
			
			ОписаниеТаблицы.Вставить("ИмяРодительскойСтроки", ОписаниеКоллекции.ИмяРодительскойСтроки);
			Найденные.Добавить(ОписаниеТаблицы, ОписаниеТаблицы.Представление, , ОписаниеКоллекции.Картинка);
			
			Если Найденные.Количество() = МаксимальноеКоличествоНайденных Тогда
				Возврат;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьКэшПоиска()
	
	КэшПоиска = Новый СписокЗначений;
	
	КартинкиКоллекций = ИТК_КонструкторЗапросовПовтИсп.СоответствиеКартинокКоллекцийДоступныхТаблиц();
	
	СхемаЗапроса = ПолучитьИзВременногоХранилища(АдресСхемыЗапроса);
	ДоступныеТаблицы = СхемаЗапроса.ПакетЗапросов[ИндексЗапросаПакета].ДоступныеТаблицы;
	Для Каждого ЭлементДоступныхТаблицСхемыЗапроса Из ДоступныеТаблицы Цикл 
		
		Если ТипЗнч(ЭлементДоступныхТаблицСхемыЗапроса) = Тип("ДоступнаяТаблицаСхемыЗапроса") Тогда
			Продолжить;
		КонецЕсли;
		
		ОписаниеКоллекции = Новый Структура;
		ИмяКоллекции = ЭлементДоступныхТаблицСхемыЗапроса.Представление;
		Если СтрНачинаетсяС(ЭлементДоступныхТаблицСхемыЗапроса.Состав[0].Имя, "ВнешнийИсточникДанных") Тогда
			ИмяКоллекции = "ВнешниеИсточникиДанных";
		КонецЕсли;
		ОписаниеКоллекции.Вставить("ИмяКоллекции", ИмяКоллекции);
		ОписаниеКоллекции.Вставить("ИмяРодительскойСтроки", ЭлементДоступныхТаблицСхемыЗапроса.Представление);
		ОписаниеКоллекции.Вставить("Картинка", КартинкиКоллекций.Получить(ИмяКоллекции));
		
		СоставКоллекции = Новый Массив;
		Для Каждого ЭлементТаблица Из ЭлементДоступныхТаблицСхемыЗапроса.Состав Цикл 
			
			ПолноеИмяТаблицы = ЭлементТаблица.Имя;
			ЧастиИмени = СтрРазделить(ПолноеИмяТаблицы, ".");
			
			ВариантТаблицы = Неопределено;
			Если СтрНачинаетсяС(ПолноеИмяТаблицы, "ВнешнийИсточникДанных") Тогда
				
				ВариантТаблицы = ЧастиИмени[1];
				ИмяТаблицы = ЧастиИмени[3];
				
			Иначе
				
				ИмяТаблицы = ЧастиИмени[0];
				Если ЧастиИмени.Количество() > 1 Тогда
					ИмяТаблицы = ЧастиИмени[1];
				КонецЕсли;
				
				Если ЧастиИмени.Количество() > 2 Тогда
					ВариантТаблицы = ЧастиИмени[2];
				КонецЕсли;
				
				Если НЕ ДоступныТаблицыИзменений
						И (ВариантТаблицы = "Изменения"
							ИЛИ ВариантТаблицы = "Changes") Тогда
					Продолжить;
				КонецЕсли;
				
			КонецЕсли;
			
			ОписаниеТаблицы = Новый Структура;
			ОписаниеТаблицы.Вставить("ИмяНРег", НРег(ИмяТаблицы));
			ОписаниеТаблицы.Вставить("ПолноеИмя", ПолноеИмяТаблицы);
			
			Если ЗначениеЗаполнено(ВариантТаблицы) Тогда 
				ПредставлениеТаблицы = СтрШаблон("%1 (%2)", ИмяТаблицы, ВариантТаблицы);
			Иначе
				ПредставлениеТаблицы = ИмяТаблицы;
			КонецЕсли;
			ОписаниеТаблицы.Вставить("Представление", ПредставлениеТаблицы);
			
			СоставКоллекции.Добавить(ОписаниеТаблицы);
			
		КонецЦикла;
		
		ОписаниеКоллекции.Вставить("Состав", СоставКоллекции);
		КэшПоиска.Добавить(ОписаниеКоллекции);
		
	КонецЦикла;
	
	АдресКэшаПоиска = ПоместитьВоВременноеХранилище(КэшПоиска, УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйТекущийЭлементСтрокаПоискаПослеОжидания()
	
	ТекущийЭлемент = Элементы.СтрокаПоиска;
	
КонецПроцедуры

#КонецОбласти
