
#Область ОписаниеПеременных

&НаКлиенте
Перем ЗакрытиеРазрешено;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Редактирование = Параметры.Редактирование;
	Источник = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "Источник");
	
	ИТК_ФормаКлиентСервер.ПоказатьГруппу(Элементы.ГруппаКолонки);
	
	Если Параметры.Свойство("ДополнениеЗаголовка") Тогда
		ДополнениеЗаголовка = Параметры.ДополнениеЗаголовка;
	КонецЕсли;
	
	// Заполнение данных
	Если ЭтоАдресВременногоХранилища(Параметры.Адрес) Тогда
		
		// Заполнение данных таблицы значений
		Адрес = Параметры.Адрес;
		ВходнаяТаблицаЗначений = ПолучитьИзВременногоХранилища(Адрес);
		
	Иначе
		
		ВходнаяТаблицаЗначений = Новый ТаблицаЗначений;
		
	КонецЕсли;
	
	Если Параметры.Свойство("ДобавляемыеКолонки") Тогда
		
		Для Каждого ДобавляемаяКолонка Из Параметры.ДобавляемыеКолонки Цикл 
			
			ИмяКолонки = ДобавляемаяКолонка.Представление;
			Если ВходнаяТаблицаЗначений.Колонки.Найти(ИмяКолонки) = Неопределено Тогда
				
				Модифицированность = Истина;
				ВходнаяТаблицаЗначений.Колонки.Добавить(ИмяКолонки, ДобавляемаяКолонка.Значение);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	ОбновитьДанныеТаблицыЗначений(ВходнаяТаблицаЗначений);
	
	ИТК_ПодключаемыеКоманды.ДополнительныеКТаблицеЗначений(ЭтотОбъект, "ТаблицаЗначений", Редактирование);
	ИТК_ПодключаемыеКоманды.ИнструментыКТаблицеЗначений(ЭтотОбъект, "ТаблицаЗначений");
	
	// Изменение элементов управления 
	
	// ТаблицаЗначений
	Элементы.ТаблицаЗначений.ИзменятьПорядокСтрок = Редактирование;
	Элементы.ТаблицаЗначений.ИзменятьСоставСтрок = Редактирование;
	Элементы.ТаблицаЗначений.ТолькоПросмотр = Не Редактирование;
	
	// Колонки
	Элементы.КолонкиИндексировать.Видимость = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "НастройкаИндексацииКолонок", Ложь);
	
	// Форма
	КоманднаяПанель.Видимость = Редактирование;
	Элементы.ЗагрузкаПодменю.Видимость = Редактирование;
	Элементы.СохранениеПодменю.Видимость = Редактирование;
	Элементы.СохранитьИЗакрыть.Видимость = Редактирование;

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновитьЭлементыУправления();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если Не ЗавершениеРаботы 
		И ЗакрытиеРазрешено = Неопределено Тогда
		
		Если Модифицированность Тогда
			
			Отказ = Истина;
			
			ОписаниеОповещенияОЗавершении = Новый ОписаниеОповещения("ВопросСохраненияЗавершение", ЭтотОбъект);
			ТекстВопроса = НСтр("ru = 'Имеются несохраненные данные при закрытии они будут потеряны. Сохранить?';
								|en = 'If you have unsaved data when you close it, it will be lost. Save?'");
			ЗаголовокВопроса = НСтр("ru = 'Редактирование таблицы значений';
									|en = 'Editing the table of values'");

			КнопкаПоУмолчанию = Истина;
			
			КнопкиВопроса = Новый СписокЗначений;
			КнопкиВопроса.Добавить(Истина, НСтр("ru = 'Сохранить и закрыть';
												|en = 'Save and close'"));
			КнопкиВопроса.Добавить(Ложь, НСтр("ru = 'Не сохранять';
												|en = 'Do not save'"));
			КнопкиВопроса.Добавить(Неопределено, НСтр("ru = 'Отмена';
														|en = 'Cancel'"));
			
			ИТК_ФормаКлиент.ЗадатьВопрос(ОписаниеОповещенияОЗавершении, ТекстВопроса, КнопкиВопроса, КнопкаПоУмолчанию, ЗаголовокВопроса, ЭтотОбъект);
								
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыКолонки

&НаКлиенте
Процедура КолонкиПриИзменении(Элемент)
	
	Модифицированность = Истина;
	ОбновитьЭлементыУправления();
	
КонецПроцедуры

&НаКлиенте
Процедура КолонкиПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	Отказ = Истина;
	ДобавитьКолонку();
	
КонецПроцедуры

&НаКлиенте
Процедура КолонкиПередНачаломИзменения(Элемент, Отказ)
	
	Если Элемент.ТекущийЭлемент = Элементы.КолонкиИндексировать Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Отказ = Истина;
	
	КолонкиТекущиеДанные = Элементы.Колонки.ТекущиеДанные;
	ИспользуемыеИдентификаторы = ИТК_ФормаКлиент.ВыгрузитьКолонкуКоллекции(Колонки, "Имя", КолонкиТекущиеДанные.Имя);
	ОписаниеОповещения = Новый ОписаниеОповещения("РедактированиеКолонкиЗакончено", ЭтотОбъект);
	
	ИТК_ФормаКлиент.ОткрытьРедактированиеКолонкиТаблицыЗначений(ИТК_Перечисления.РежимРедактированияКолонкиТаблицыЗначенийИзменение(),
												КолонкиТекущиеДанные.Имя, КолонкиТекущиеДанные.Тип, КолонкиТекущиеДанные.Индексировать, ИспользуемыеИдентификаторы, ЭтотОбъект, ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура КолонкиПередУдалением(Элемент, Отказ)
	
	УдалитьКолонкуСервер(Элемент.ТекущиеДанные.Имя);
	ОбновитьЭлементыУправления();
	
КонецПроцедуры

&НаКлиенте
Процедура КолонкиПриАктивизацииСтроки(Элемент)
	
	ОбновитьЭлементыУправления();
	
КонецПроцедуры

#КонецОбласти

