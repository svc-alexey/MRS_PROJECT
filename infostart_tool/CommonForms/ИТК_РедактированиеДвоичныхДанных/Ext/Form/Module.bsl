#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Значение = Параметры.НачальноеЗначение;
	ОбновитьДанныеЗначения();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СохранитьИЗакрыть(Команда)
	Закрыть(Значение);
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИзФайла(Команда)
	
	ДиалогВыбораФайла =  Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ЗавершенВыборЗагружаемогоФайла", ЭтотОбъект);
	ДиалогВыбораФайла.Показать(ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьВФайл(Команда)
	
	ПолучитьФайл(АдресДвоичныхДанных());
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ОбновитьДанныеЗначения()
	
	ДвоичныеДанные = Значение.Получить();
	РазмерВБайтах = ДвоичныеДанные.Размер();
	
КонецПроцедуры

&НаСервере
Процедура ИзменитьЗначениеНаСервере(ДвоичныеДанные)
	
	Модифицированность = Истина;
	Значение = Новый ХранилищеЗначения(ДвоичныеДанные);
	ОбновитьДанныеЗначения();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершенВыборЗагружаемогоФайла(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныеФайлы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПолноеИмяФайла = ВыбранныеФайлы[0];
	
	ДвоичныеДанные = Новый ДвоичныеДанные(ПолноеИмяФайла);
	ИзменитьЗначениеНаСервере(ДвоичныеДанные);
	
КонецПроцедуры

Функция АдресДвоичныхДанных()
	Возврат ПоместитьВоВременноеХранилище(Значение.Получить());
КонецФункции

#КонецОбласти
