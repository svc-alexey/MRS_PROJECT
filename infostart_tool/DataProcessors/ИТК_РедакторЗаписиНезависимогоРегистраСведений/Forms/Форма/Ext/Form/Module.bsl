#Область ОписаниеПеременных

&НаКлиенте
Перем ЗакрытиеРазрешено;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.ПоляЗаписи);
	ИТК_ПараметрыЗаписи.СоздатьЭлементыИРеквизиты(ЭтотОбъект, Элементы.ГруппаПараметрыЗаписиОбъекта);
	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.ПоляЗаписи);
	ИТК_ПодключаемыеКоманды.ИнструментыКТаблицеЗначений(ЭтотОбъект, "ПоляЗаписи");
	
	Если Параметры.Свойство("КлючЗаписи") Тогда
		
		КлючЗаписи = Параметры.КлючЗаписи;
		ИмяВыбранногоОбъекта = Метаданные.НайтиПоТипу(ТипЗнч(КлючЗаписи)).Имя;
		
		ОбновитьДанныеКлючаЗаписи();
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИТК_ОбщийКлиент.ОбработчикПриОткрытии(Отказ);
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПредставлениеВыбранногоОбъектаНажатие(Элемент, СтандартнаяОбработка)
	
	ВыбратьОбъектаКлюча(СтандартнаяОбработка, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПредставлениеКлючаЗаписиОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Неопределено;
	
	КлючЗаписи = Неопределено;
	ИмяВыбранногоОбъекта = Неопределено;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПредставлениеКлючаЗаписиНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ВыбратьОбъектаКлюча(СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПредставлениеКлючаЗаписиОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ВыбранТипОбъекта(ВыбранноеЗначение);

КонецПроцедуры

&НаКлиенте
Процедура ПредставлениеКлючаЗаписиАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Если НЕ ЗначениеЗаполнено(Текст) Тогда
		Возврат;
	КонецЕсли;
	
	ПоискПоНезависимымРегистрамСведений(Текст, ДанныеВыбора);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПоляЗаписи

&НаКлиенте
Процедура ПоляЗаписиПриИзменении(Элемент)
	
	Модифицированность = Истина;
	ИТК_ПодключаемыеКомандыКлиент.ОбновитьЭлементы(ЭтотОбъект, Элементы.ПоляЗаписи);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоляЗаписиПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	ИТК_ФормаКлиент.АктивизацияЗначенияВФорме(Элементы.ПоляЗаписиЗначение, ТекущиеДанные.Значение, ТекущиеДанные.Тип);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоляЗаписиПриАктивизацииЯчейки(Элемент)
	
	ИТК_ПодключаемыеКомандыКлиент.ОбновитьЭлементы(ЭтотОбъект, Элемент, "Значение");
	
КонецПроцедуры

&НаКлиенте
Процедура ПоляЗаписиПередНачаломИзменения(Элемент, Отказ)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Элемент.ТекущийЭлемент.ОграничениеТипа = ТекущиеДанные.Тип;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоляЗаписиЗначениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ПоляЗаписи.ТекущиеДанные;
	
	Имя = ТекущиеДанные.Имя;
	ЗаголовокФормы = СтрШаблон(НСтр("ru = 'Поле ""%1""';
									|en = 'Field ""%1""'"), Имя);

	ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("ВводЗначенияПоляЗавершен", ЭтотОбъект, Новый Структура);
	Если ТекущиеДанные.Тип.СодержитТип(Тип("ОписаниеТипов")) Тогда
		
		ИТК_ФормаКлиент.ОткрытьРедактированиеТипаЗначения(Элемент, ЗаголовокФормы, ИТК_Перечисления.РежимРедактированияТипаЗначенияРедактированиеОписанияТипов(),
																	ТекущиеДанные.Значение, ОписаниеОповещенияЗавершение, СтандартнаяОбработка);
	Иначе
		ИТК_ФормаКлиент.ВводЗначенияСтрокиВФорме(ЗаголовокФормы, Элемент, ТекущиеДанные.Значение, ТекущиеДанные.Тип, СтандартнаяОбработка, ОписаниеОповещенияЗавершение);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоляЗаписиЗначениеОчистка(Элемент, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.ОчисткаЗначенияСтрокиВФорме(Элемент, СтандартнаяОбработка);
	
	СтрокаПоля = Элементы.ПоляЗаписи.ТекущиеДанные;
	СтрокаПоля.Значение = СтрокаПоля.Тип.ПривестиЗначение(Неопределено);
	
	ОбновитьДанныеСтроки(СтрокаПоля);
	
	ИТК_ФормаКлиент.АктивизацияЗначенияВФорме(Элемент, Неопределено, СтрокаПоля.Тип);
	
	ПоляЗаписиПриИзменении(Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоляЗаписиЗначениеОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.ОбработкаВыбораЗначенияВФорме(Элемент, ВыбранноеЗначение, СтандартнаяОбработка);
	ОбновитьДанныеСтроки(Элементы.ПоляЗаписи.ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоляЗаписиЗначениеАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)

	ИТК_ФормаКлиент.АвтоПодборЗначенияВФорме(Текст, Элемент, ДанныеВыбора, СтандартнаяОбработка);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОткрытьНовоеОкно(Команда)
	
	ИТК_ФормаКлиент.ОткрытьНовую(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьДанные(Команда)

	ЗаголовокВопроса = НСтр("ru = 'Записать?';
					|en = 'Write?'");

	ТекстВопроса = СтрШаблон(НСтр("ru = 'Объект: %1';
								|en = 'Object: %1'"), ПредставлениеКлючаЗаписи);
	Если ИзмененыКлючиОбъекта() Тогда
			
		ТекстВопроса = ТекстВопроса + Символы.ПС + НСтр("ru = 'Изменены ключевые поля объекта. Запись будет перенесена.';
														|en = 'The key fields of the object have been changed. The recording will be rescheduled.'");
		Если ЗаписьСТакимиКлючомСуществует() Тогда
			
			ТекстВопроса = ТекстВопроса + Символы.ПС + НСтр("ru = 'Существует запись с такими ключевыми полями. Она будет замещена (удалена).';
															|en = 'There is a record with these key fields. It will be replaced (deleted).'");
			
		КонецЕсли;
							
	КонецЕсли;
	
	ОписаниеОЗавершении = Новый ОписаниеОповещения("ЗавершенВопросДействия", ЭтотОбъект);
	ПоказатьВопрос(ОписаниеОЗавершении, ТекстВопроса, РежимДиалогаВопрос.ДаНет, 60, КодВозвратаДиалога.Нет, ЗаголовокВопроса, КодВозвратаДиалога.Нет);
	
КонецПроцедуры

#Область ПодключаемыеКоманды

&НаКлиенте
Процедура ПодключаемаяКоманда(Команда)
	
	ИТК_ПодключаемыеКомандыКлиент.ОбработатьКоманду(ЭтотОбъект, Команда.Имя);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемаяКомандаРаботаСТаблицейЗначений(Команда)
	
	ИТК_ПодключаемыеКомандыКлиент.ОбработатьКомандуРаботыСТаблицейЗначений(ЭтотОбъект, Команда.Имя, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйОбработчикКоманд(Команда)
	
	ИТК_ПараметрыЗаписиКлиент.ОбработатьКоманду(ЭтотОбъект, Команда.Имя);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	ВыбранОбъект = ЗначениеЗаполнено(ИмяВыбранногоОбъекта);
	
	ПредставлениеВыбранногоОбъекта = НСтр("ru = 'РегистрСведений'; en = 'InformationRegister'");
	Если ЗначениеЗаполнено(ИмяВыбранногоОбъекта) Тогда
		ПредставлениеВыбранногоОбъекта = ПредставлениеВыбранногоОбъекта + "." + ИмяВыбранногоОбъекта;
	КонецЕсли;
	
	Элементы.ПредставлениеКлючаЗаписи.РедактированиеТекста = НЕ ВыбранОбъект;
	Элементы.ПредставлениеКлючаЗаписи.КнопкаОчистки = ВыбранОбъект И ЗначениеЗаполнено(КлючЗаписи);
	ОбновитьПредставлениеКлючаЗаписи();
	
	ИТК_ПараметрыЗаписиКлиент.ОбновитьЭлементы(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьОбъектаКлюча(СтандартнаяОбработка = Неопределено, ПеревыбратьОбъект = Ложь)
	
	Перем ОписаниеОповещенияОЗакрытии;
	
	СтандартнаяОбработка = Ложь;
	
	Если ПеревыбратьОбъект
			ИЛИ НЕ ЗначениеЗаполнено(ИмяВыбранногоОбъекта) Тогда
		
		ОписаниеОповещенияОЗакрытии = Новый ОписаниеОповещения("ЗавершенВыборОбъекта", ЭтотОбъект);
		ОткрытьФорму("Обработка.ИТК_РедакторЗаписиНезависимогоРегистраСведений.Форма.ВыборОбъекта", , ЭтотОбъект,
							, , , ОписаниеОповещенияОЗакрытии, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	Иначе
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("РежимВыбора", Истина);
		ДополнительныеПараметры.Вставить("ЗакрыватьПриВыборе", Истина);
		
		ОписаниеОповещенияОЗакрытии = Новый ОписаниеОповещения("ЗавершенВыборКлючаЗаписи", ЭтотОбъект);
		ДополнительныеПараметры.Вставить("ОписаниеОповещенияОЗакрытии", ОписаниеОповещенияОЗакрытии);
		
		ДополнительныеПараметры.Вставить("Ключ", КлючЗаписи);

		ИТК_ФормаКлиент.ОткрытьУниверсальнуюФормуСписка("РегистрСведений." + ИмяВыбранногоОбъекта, ЭтотОбъект, ДополнительныеПараметры);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершенВыборОбъекта(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВыбранТипОбъекта(Результат);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбранТипОбъекта(ИмяОбъекта)
	
	ИмяВыбранногоОбъекта = ИмяОбъекта;
	КлючЗаписи = Неопределено;
	
	ОбновитьЭлементыФормы();
	
	ВыбратьОбъектаКлюча();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершенВыборКлючаЗаписи(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	КлючЗаписи = Результат;
	ОбновитьЭлементыФормы();
	
	ОбновитьДанныеКлючаЗаписи();
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПоискПоНезависимымРегистрамСведений(СтрокаПоиска, ДанныеВыбора)
	
	ДанныеВыбора = Новый СписокЗначений;
	ПараметрыПоиска = ИТК_Строки.ПараметрыПоискаПоПодобию(СтрокаПоиска);
	Картинка = БиблиотекаКартинок.РегистрСведений;
	
	КоличествоДобавленных = 0;
	Для Каждого РегистрСведений Из Метаданные.РегистрыСведений Цикл 
		
		Если РегистрСведений.РежимЗаписи = Метаданные.СвойстваОбъектов.РежимЗаписиРегистра.ПодчинениеРегистратору Тогда
			Продолжить;
		КонецЕсли;
		
		АнализируемаяСтрока = НРег(РегистрСведений.Имя + " " + РегистрСведений.Синоним);
		Если НЕ ИТК_Строки.ПоискПоПодобиюНайденыСовпадения(АнализируемаяСтрока, ПараметрыПоиска) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(РегистрСведений.Синоним) Тогда 
			Представление = СтрШаблон("%1 (%2)", РегистрСведений.Имя, РегистрСведений.Синоним);
		Иначе
			Представление = РегистрСведений.Имя;
		КонецЕсли;
		
		ФорматированноеПредставление = ИТК_Строки.НайтиИВыделитьОформлением(Представление, СтрокаПоиска);
		ДанныеВыбора.Добавить(РегистрСведений.Имя, ФорматированноеПредставление, , Картинка);
		КоличествоДобавленных = КоличествоДобавленных + 1;
		
		Если КоличествоДобавленных = 30 Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПредставлениеКлючаЗаписи()
	
	Если КлючЗаписи = Неопределено Тогда
		ПредставлениеКлючаЗаписи = Неопределено;
	Иначе
		ПредставлениеКлючаЗаписи = ИТК_Метаданные.ПредставлениеКлючаЗаписейРегистраСведений(КлючЗаписи, Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьДанныеКлючаЗаписи()
	
	Модифицированность = Ложь;

	МенеджерЗаписи = РегистрыСведений[ИмяВыбранногоОбъекта].СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(МенеджерЗаписи, КлючЗаписи);
	МенеджерЗаписи.Прочитать();
	
	ОбъектМетаданных = Метаданные.РегистрыСведений[ИмяВыбранногоОбъекта];
	
	Поля = Новый ТаблицаЗначений;
	Поля.Колонки.Добавить("Имя", ИТК_ТипыКлиентСервер.ОписаниеИмяМетаданных());
	Поля.Колонки.Добавить("Синоним", ИТК_ТипыКлиентСервер.ОписаниеСинонимМетаданных());
	Поля.Колонки.Добавить("Картинка", ИТК_ТипыКлиентСервер.ОписаниеКартинка());
	Поля.Колонки.Добавить("Тип");
	Поля.Колонки.Добавить("Значение");
	
	ЧитаемыеКоллекции = Новый СписокЗначений;
	ЧитаемыеКоллекции.Добавить("СтандартныеРеквизиты", , , БиблиотекаКартинок.Измерение);
	ЧитаемыеКоллекции.Добавить("Измерения", , , БиблиотекаКартинок.Измерение);
	ЧитаемыеКоллекции.Добавить("Реквизиты", , , БиблиотекаКартинок.Реквизит);
	ЧитаемыеКоллекции.Добавить("Ресурсы", , , БиблиотекаКартинок.Ресурс);
	
	Для Каждого ЧитаемаяКоллекция Из ЧитаемыеКоллекции Цикл 
		
		ПоляКоллекции = Новый СписокЗначений;
		Для Каждого ОбъектПоле Из ОбъектМетаданных[ЧитаемаяКоллекция.Значение] Цикл 
			ПоляКоллекции.Добавить(ОбъектПоле, ОбъектПоле.Имя, , ЧитаемаяКоллекция.Картинка);
		КонецЦикла;
		ПоляКоллекции.СортироватьПоПредставлению();
		
		Для Каждого ПолеКоллекции Из ПоляКоллекции Цикл 
			
			ОбъектПоле = ПолеКоллекции.Значение;
			ИмяПоля = ПолеКоллекции.Представление;
			
			НоваяСтрока = Поля.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ОбъектПоле);
			НоваяСтрока.Картинка = ПолеКоллекции.Картинка;
			НоваяСтрока.Значение = МенеджерЗаписи[ИмяПоля];
		
		КонецЦикла;
	
	КонецЦикла;
	
	ПоляЗаписи.Очистить();
	Для Каждого Поле Из Поля Цикл 
		
		Если НЕ ИТК_Типы.РедактируетсяВТаблицеЗначений(Поле.Тип) Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = ПоляЗаписи.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Поле);
		
		НоваяСтрока.Значение = Поле.Тип.ПривестиЗначение(Поле.Значение);
		
		НоваяСтрока.КартинкаТип = ИТК_Типы.КартинкаОписания(Поле.Тип);
		НоваяСтрока.ТипПредставление = ИТК_Типы.ПредставлениеОписания(Поле.Тип);
		НоваяСтрока.ЗначениеКартинка = ИТК_Типы.КартинкаЗначения(Поле.Значение, Поле.Тип);
		
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ВводЗначенияПоляЗавершен(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элементы.ПоляЗаписи.ТекущиеДанные;
	
	ИТК_ФормаКлиент.ОбработкаЗавершенВводЗначенияВФорме(Элементы.ПоляЗаписиЗначение, Результат, ДополнительныеПараметры,
																ТекущиеДанные.Значение, ТекущиеДанные.Тип, Модифицированность); 
	ОбновитьДанныеСтроки(ТекущиеДанные);

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанныеСтроки(Строка)
	
	Строка.ЗначениеКартинка = ИТК_Типы.КартинкаЗначения(Строка.Значение, Строка.Тип);

КонецПроцедуры

&НаСервере
Функция ИзмененыКлючиОбъекта()
	
	ИзмененыКлючиОбъекта = Ложь;
	
	ОбъектМетаданных = Метаданные.РегистрыСведений[ИмяВыбранногоОбъекта];
	Для Каждого ПолеКлюч Из ИТК_Метаданные.КлючиРегистраСведений(ОбъектМетаданных) Цикл 
		
		Отбор = Новый Структура;
		Отбор.Вставить("Имя", ПолеКлюч);
		НайденныеСтроки = ПоляЗаписи.НайтиСтроки(Отбор);
		НайденнаяСтрока = НайденныеСтроки[0];
		
		Если КлючЗаписи[ПолеКлюч] <> НайденнаяСтрока.Значение Тогда
			
			ИзмененыКлючиОбъекта = Истина;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ИзмененыКлючиОбъекта;
	
КонецФункции

&НаСервере
Функция ЗаписьСТакимиКлючомСуществует()
	
	НаборЗаписей = ИТК_Метаданные.НаборЗаписейПоКлючу(НовыйКлючЗаписи());
	НаборЗаписей.Прочитать();
	
	Возврат ЗначениеЗаполнено(НаборЗаписей);
	
КонецФункции

&НаСервере
Функция НовыйКлючЗаписи()
	
	ЗначенияКлюча = Новый Структура;
	
	ОбъектМетаданных = Метаданные.РегистрыСведений[ИмяВыбранногоОбъекта];
	Для Каждого ПолеКлюч Из ИТК_Метаданные.КлючиРегистраСведений(ОбъектМетаданных) Цикл 
		
		Отбор = Новый Структура;
		Отбор.Вставить("Имя", ПолеКлюч);
		НайденныеСтроки = ПоляЗаписи.НайтиСтроки(Отбор);
		
		ЗначенияКлюча.Вставить(ПолеКлюч, НайденныеСтроки[0].Значение);
		
	КонецЦикла;
	
	Возврат РегистрыСведений[ИмяВыбранногоОбъекта].СоздатьКлючЗаписи(ЗначенияКлюча);
	
КонецФункции

&НаКлиенте
Процедура ЗавершенВопросДействия(Результат, ДополнительныеПараметры) Экспорт 
	
	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ЗаписатьДанныеКлючаЗаписи();
	ОбновитьДанныеКлючаЗаписи();
	
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаСервере
Процедура ЗаписатьДанныеКлючаЗаписи()
	
	ПараметрыЗаписи = ИТК_ПараметрыЗаписиКлиентСервер.Значения(ЭтотОбъект);
	Если ПараметрыЗаписи.Привилегированный Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Если ИзмененыКлючиОбъекта() Тогда
		
		НачатьТранзакцию();
		Попытка
			
			// Удаление старой записи
			Если ИзмененыКлючиОбъекта() Тогда
				
				НаборЗаписей = ИТК_Метаданные.НаборЗаписейПоКлючу(КлючЗаписи);
				ИТК_ПараметрыЗаписи.Установка(НаборЗаписей, ПараметрыЗаписи.БезПроверок, ПараметрыЗаписи.ДополнительныеСвойства);
				НаборЗаписей.Записать();
				
			КонецЕсли;
			
			// Запись новой/существующей записи
			НаборЗаписей = ИТК_Метаданные.НаборЗаписейПоКлючу(НовыйКлючЗаписи());
			НаборЗаписей.Прочитать();
			
			Если ЗначениеЗаполнено(НаборЗаписей) Тогда
				Запись = НаборЗаписей[0];
			Иначе
				
				Запись = НаборЗаписей.Добавить();
				НаборЗаписей.Заполнить(Неопределено);
				
			КонецЕсли;
			ЗаполнениеЗаписиПоДаннымФормы(Запись);
			
			ИТК_ПараметрыЗаписи.Установка(НаборЗаписей, ПараметрыЗаписи.БезПроверок, ПараметрыЗаписи.ДополнительныеСвойства);
			НаборЗаписей.Записать();
			
			ЗафиксироватьТранзакцию();
			
			КлючЗаписи = НовыйКлючЗаписи();
			
		Исключение
			ОтменитьТранзакцию();
		КонецПопытки;
		
	Иначе
		
		// Изменение существующей записи
		НаборЗаписей = ИТК_Метаданные.НаборЗаписейПоКлючу(КлючЗаписи);
		НаборЗаписей.Прочитать();
		
		Запись = НаборЗаписей[0];
		ЗаполнениеЗаписиПоДаннымФормы(Запись);
		
		ИТК_ПараметрыЗаписи.Установка(НаборЗаписей, ПараметрыЗаписи.БезПроверок, ПараметрыЗаписи.ДополнительныеСвойства);
		НаборЗаписей.Записать();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнениеЗаписиПоДаннымФормы(Запись)
	
	Для Каждого ПолеЗаписи Из ПоляЗаписи Цикл 
		Запись[ПолеЗаписи.Имя] = ПолеЗаписи.Значение;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти