#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	КодЯзыкаПрограммирования = ИТК_Общий.КодЯзыкаПрограммирования();
	ИТК_ФормаКлиентСервер.Заголовок(ЭтотОбъект, НСтр("ru = 'Конструктор строки сохранения данных из отладки';
													|en = 'Designer lines store data from debug'"));
	
	ИТК_Перечисления.ЗаполнитьСписок(Элементы.Тип, ИТК_Перечисления.ЭлементыДанных());
	
	ИмяСхемыСписокВыбора = Элементы.ИмяСхемы.СписокВыбора;
	
	ИмяСхемы = НСтр("ru = 'СхемаКомпоновкиДанных';
					|en = 'DataCompositionSchema'", КодЯзыкаПрограммирования);
	ИмяСхемыСписокВыбора.Добавить(ИмяСхемы);
	
	ИмяСхемыДинамическогоСписка = НСтр("ru = 'Элементы.Список.ПолучитьИсполняемуюСхемуКомпоновкиДанных()';
					|en = 'Items.List.GetPerformingDataCompositionScheme()'", КодЯзыкаПрограммирования);
	ИмяСхемыСписокВыбора.Добавить(ИмяСхемыДинамическогоСписка);
	
	// НастройкиКомпоновкиДанных
	ИмяНастроекСписокВыбора = Элементы.ИмяНастроек.СписокВыбора;
	
	ИмяНастроекДинамическогоСписка = НСтр("ru = 'КомпоновщикНастроек.Настройки';
					|en = 'SettingsComposer.Settings'", КодЯзыкаПрограммирования);
	ИмяНастроекСписокВыбора.Добавить(ИмяНастроекДинамическогоСписка);
	
	ИмяНастроекДинамическогоСписка = НСтр("ru = 'КомпоновщикНастроек.ПолучитьНастройки()';
					|en = 'SettingsComposer.GetSettings()'", КодЯзыкаПрограммирования);
	ИмяНастроекСписокВыбора.Добавить(ИмяНастроекДинамическогоСписка);
	
	ИмяНастроек = НСтр("ru = 'НастройкиКомпоновкиДанных';
						|en = 'DataCompositionSettings'", КодЯзыкаПрограммирования);
	ИмяНастроекСписокВыбора.Добавить(ИмяНастроек);
	
	ИмяНастроекДинамическогоСписка = НСтр("ru = 'Элементы.Список.ПолучитьИсполняемыеНастройкиКомпоновкиДанных()';
					|en = 'Items.List.GetPerformingDataCompositionSettings()'", КодЯзыкаПрограммирования);
	ИмяНастроекСписокВыбора.Добавить(ИмяНастроекДинамическогоСписка);
	
	ИмяНастроекДинамическогоСписка = НСтр("ru = 'Настройки';
					|en = 'Settings'", КодЯзыкаПрограммирования);
	ИмяНастроекСписокВыбора.Добавить(ИмяНастроекДинамическогоСписка);
	
	ИмяНастроекДинамическогоСписка = НСтр("ru = 'НастройкиОтчета';
					|en = 'ReportSettings'", КодЯзыкаПрограммирования);
	ИмяНастроекСписокВыбора.Добавить(ИмяНастроекДинамическогоСписка);
	
	// ВнешниеНаборыДанных
	ИмяВнешнихНаборовДанныхСписокВыбора = Элементы.ИмяВнешнихНаборовДанных.СписокВыбора;
	ИмяВнешнихНаборовДанных = НСтр("ru = 'ВнешниеНаборыДанных';
									|en = 'ExternalDataSets'", КодЯзыкаПрограммирования);
	ИмяВнешнихНаборовДанныхСписокВыбора.Добавить(ИмяВнешнихНаборовДанных);
	
	ИмяВнешнихНаборовДанных = НСтр("ru = 'ВнешниеИсточникиДанных';
									|en = 'ExternalDataSources'", КодЯзыкаПрограммирования);
	ИмяВнешнихНаборовДанныхСписокВыбора.Добавить(ИмяВнешнихНаборовДанных);
	
	// МенеджерВременныхТаблиц
	ИмяМенеджераВременныхТаблицСписокВыбора = Элементы.ИмяМенеджераВременныхТаблиц.СписокВыбора;
	
	ТекстИмяМенеджераВременныхТаблиц = НСтр("ru = 'МенеджерВременныхТаблиц';
											|en = 'TempTablesManager'", КодЯзыкаПрограммирования);
	ИмяМенеджераВременныхТаблицСписокВыбора.Добавить(ТекстИмяМенеджераВременныхТаблиц);
	
	ТекстИмяМенеджераВременныхТаблиц = НСтр("ru = 'МВТ';
											|en = 'TTM'", КодЯзыкаПрограммирования);
	ИмяМенеджераВременныхТаблицСписокВыбора.Добавить(ТекстИмяМенеджераВременныхТаблиц);
	
	Элементы.ИмяМенеджераВременныхТаблиц.Видимость = ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.17");
	
	Тип = ИТК_Перечисления.ЭлементДанныхЗапрос();
	СохранятьВ = ИТК_Перечисления.ТипХраненияДанныхНастройка();
	
	ИмяОбъектаЗапрос = "Запрос";
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ТипПриИзменении(Элемент)
	
	Если Тип = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных()
			И СохранятьВ = ЗначениеСохранятьВ_БСПXML() Тогда
		СохранятьВ = ИТК_Перечисления.ТипХраненияДанныхНастройка();
	КонецЕсли;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура СохранятьВПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ИмяОбъектаЗапросПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПутьПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаКлиенте
Процедура ИмяПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаКлиенте
Процедура ПутьНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ДиалогВыборКаталога = Новый ДиалогВыбораФайла (РежимДиалогаВыбораФайла.ВыборКаталога);
	ДиалогВыборКаталога.Каталог = Путь;
	ДиалогВыборКаталога.Заголовок = НСтр("ru = 'Выбор каталога';
										|en = 'Select catalog'");
	
	ДиалогВыборКаталога.Показать(Новый ОписаниеОповещения("ВыборКаталогаЗакончен", ЭтотОбъект));
	
КонецПроцедуры

&НаКлиенте
Процедура ИмяСхемыПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ИмяНастроекПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ИмяВнешнихНаборовДанныхПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ИмяМенеджераВременныхТаблицПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КопироватьИЗакрыть(Команда)
	
	ИТК_БуферОбменаКлиент.Копировать(Результат);
	Закрыть();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	СохранятьВФайл = (СохранятьВ = ИТК_Перечисления.ТипХраненияДанныхФайл());
	СохранятьВНастройки = (СохранятьВ = ИТК_Перечисления.ТипХраненияДанныхНастройка());
	СохранятьВБСП_XML = (СохранятьВ = ЗначениеСохранятьВ_БСПXML());
	ЭтоТипЗапрос = (Тип = ИТК_Перечисления.ЭлементДанныхЗапрос());
	ЭтоТипСхемаКомпоновкиДанных = (Тип = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных());
	
	ЗаполнитьСписокСохранитьВ();
	ЗаполнитьСписокИмяОбъектаЗапрос();
	
	Элементы.Путь.Видимость = СохранятьВФайл;
	Элементы.Имя.Видимость = СохранятьВФайл ИЛИ СохранятьВНастройки;
	Элементы.Имя.ПодсказкаВвода = СтрШаблон(НСтр("ru = 'По умолчанию: %1';
												|en = 'Default: %1'"), ИТК_ОтладкаКлиентСервер.ИмяДанныхПоУмолчанию(Тип));
	Элементы.ГруппаЗапрос.Видимость = ЭтоТипЗапрос;
	Элементы.ГруппаПояснениеСохранитьВ_БСП_XML.Видимость = СохранятьВБСП_XML;
	
	Элементы.ГруппаСхемаКомпоновкиДанных.Видимость = ЭтоТипСхемаКомпоновкиДанных;
	
	// Генерируем строку для отладки
	ПараметрыФункции = Новый Массив;
	
	Если ЭтоТипЗапрос Тогда
		ИмяОсновногоОбъекта = ИмяОбъектаЗапрос;
	ИначеЕсли ЭтоТипСхемаКомпоновкиДанных Тогда
		ИмяОсновногоОбъекта = ИмяСхемы;
	КонецЕсли;
	ПараметрыФункции.Добавить(ИмяОсновногоОбъекта);
		
	Если СохранятьВФайл Тогда
		ПараметрыФункции.Добавить(ИТК_Код.Значение(Путь));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Имя) Тогда
		ПараметрИмя = ИТК_Код.Значение(Имя);
	Иначе
		ПараметрИмя = "";
	КонецЕсли;
	ПараметрыФункции.Добавить(ПараметрИмя);
	
	Если ЭтоТипСхемаКомпоновкиДанных Тогда
		
		ПараметрыФункции.Добавить(ИмяНастроек);
		ПараметрыФункции.Добавить(ИмяВнешнихНаборовДанных);
		ПараметрыФункции.Добавить(ИмяМенеджераВременныхТаблиц);
		
	КонецЕсли;
	
	// Удалим последние параметры по умолчанию
	Пока ПустаяСтрока(ПараметрыФункции[ПараметрыФункции.ВГраница()]) Цикл 
		ПараметрыФункции.Удалить(ПараметрыФункции.ВГраница());
	КонецЦикла;
	
	Если СохранятьВ = ЗначениеСохранятьВ_БСПXML() Тогда
		
		ИмяМодуля = "ОбщегоНазначения";
		ИмяФункции = "ЗапросВСтрокуXML";
		РезультатПодсказка = Неопределено;
		
	Иначе
		
		ИмяМодуля = ИТК_ОтладкаКлиентСервер.ИмяМодуля();
		ИмяФункции = ИТК_ОтладкаКлиентСервер.ИмяФункции(СохранятьВ);
		РезультатПодсказка = ИТК_ОтладкаКлиентСервер.ПодсказкаОписаниеВызова(Тип, СохранятьВ);
		
	КонецЕсли;
	
	Результат = СтрШаблон("%1.%2(%3)", ИмяМодуля, ИмяФункции, СтрСоединить(ПараметрыФункции, ", "));
	Элементы.Результат.Подсказка = РезультатПодсказка;
	Элементы.Результат.ЦветФона = ИТК_ОбщийКлиентСервер.ЦветФонаЭлементРедактируется(Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСписокСохранитьВ()
	
	ИТК_Перечисления.ЗаполнитьСписок(Элементы.СохранятьВ, ИТК_Перечисления.ТипыХраненияДанных());
	Если Тип = ИТК_Перечисления.ЭлементДанныхЗапрос() Тогда
		Элементы.СохранятьВ.СписокВыбора.Добавить(ЗначениеСохранятьВ_БСПXML(), НСтр("ru = 'БСП (XML)'; en = 'SSL (XML)'"));
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСписокИмяОбъектаЗапрос()
	
	СписокВыбора = Элементы.ИмяОбъектаЗапрос.СписокВыбора;
	СписокВыбора.Очистить();
	
	СписокВыбора.Добавить("Запрос", НСтр("ru = 'Запрос'; en = 'Query'", КодЯзыкаПрограммирования));
	Если СохранятьВ = ИТК_Перечисления.ТипХраненияДанныхФайл()
			ИЛИ СохранятьВ = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда
		
		СписокВыбора.Добавить(НСтр("ru = 'Список'; en = 'List'", КодЯзыкаПрограммирования));
		СписокВыбора.Добавить(НСтр("ru = 'ПостроительЗапроса'; en = 'QueryBuilder'", КодЯзыкаПрограммирования));
		СписокВыбора.Добавить(НСтр("ru = 'ПостроительОтчета'; en = 'ReportBuilder'", КодЯзыкаПрограммирования));
		СписокВыбора.Добавить(НСтр("ru = 'МакетКомпоновкиДанных'; en = 'DataCompositionTemplate'", КодЯзыкаПрограммирования));
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ЗначениеСохранятьВ_БСПXML()
	Возврат "БСП_XML";
КонецФункции

&НаКлиенте
Процедура ВыборКаталогаЗакончен(ВыбранныеКаталоги, ДополнительныеПараметры) Экспорт 
	
	Если ЗначениеЗаполнено(ВыбранныеКаталоги) Тогда
		Путь = ВыбранныеКаталоги[0];
		ОбновитьЭлементыФормы();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
