#Область ОписаниеПеременных

&НаКлиенте
Перем НайденныеСсылкиОтбор Экспорт;

&НаКлиенте
Перем НайденныеСсылкиПометки Экспорт;

&НаКлиенте
Перем ПрерванаОперацияЗамены Экспорт;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Ссылки = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "Ссылки");
	Если ЗначениеЗаполнено(Ссылки) Тогда
		
		// Необходимо сворачивать, ссылки могут повторяться
		СсылкиСвернуто = ИТК_ОбщийКлиентСервер.СвернутьМассив(Ссылки);
		Для Каждого Ссылка Из СсылкиСвернуто Цикл 
			
			НоваяСтрока = ЗаменяемыеЗначения.Добавить();
			НоваяСтрока.Пометка = Истина;
			НоваяСтрока.Ссылка = Ссылка;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Шаг = 1;
	
	ИТК_Настройки.ИнициализироватьФорму(ЭтотОбъект);
	ИТК_ОбработкаОбъектов.СоздатьЭлементыИРеквизиты(ЭтотОбъект, Элементы.ГруппаРезультат, Элементы.ГруппаИнформацияООбработкеОбъектов);
	ИТК_ПараметрыЗаписи.СоздатьЭлементыИРеквизиты(ЭтотОбъект, Элементы.ГруппаПараметрыЗаписиОбъекта, Ложь);
	
	ИТК_Перечисления.ЗаполнитьСписок(Элементы.ДействияСЗаменяемымиСсылки, ИТК_Перечисления.ДействияСЗаменяемымиСсылками());
	ДействияСЗаменяемымиСсылки = ИТК_Перечисления.ДействиеСЗаменяемойСсылкойНеУдалять();
	
	УстановитьУсловноеОформление();
	
	ИТК_ПоискСсылок.ПодключитьКоманды(ЭтотОбъект, Истина);
	ИТК_ФормаКлиентСервер.ОтображениеСостоянияТабличногоДокумента(Элементы.ИдетПоискСсылокТабличныйДокумент, НСтр("ru = 'Поиск ссылок...';
																													|en = 'Search links...'"));
	
КонецПроцедуры

&НаСервере
Процедура ПередЗагрузкойДанныхИзНастроекНаСервере(Настройки)
	
	Если ЗначениеЗаполнено(ЗаменяемыеЗначения) Тогда
		Настройки.Удалить("ЗаменяемыеЗначения");
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИТК_ОбщийКлиент.ОбработчикПриОткрытии(Отказ);
	
	НайденныеСсылкиОтбор = Новый Соответствие;	
	НайденныеСсылкиПометки = Новый Соответствие;	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	ИТК_НастройкиКлиент.ОбработкаОповещения(ЭтотОбъект, ИмяСобытия);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыЗаменяемыеЗначения

&НаКлиенте
Процедура ЗаменяемыеЗначенияПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущиеДанные.Ссылка <> Неопределено Тогда
		
		Тип = ТипЗнч(ТекущиеДанные.Ссылка);
		ОписаниеТипов = ИТК_ТипыКлиентСервер.ОписаниеТиповПоТипу(Тип);
		
		ОграничитьТипЭлемента(Элементы.ЗаменяемыеЗначенияСсылка, ОписаниеТипов, Ложь);
		ПривестиСсылкуКЗаменитьНа();

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаменяемыеЗначенияСсылкаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Если Элемент.ВыбиратьТип Тогда
		
		ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("ВыборТипаСсылкиЗавершен", ЭтотОбъект, Новый Структура);
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Исключаемые", "ПростыеТипы");
		ИТК_ФормаКлиент.ОткрытьРедактированиеТипаЗначения(Элемент, НСтр("ru = 'Что заменять';
																		|en = 'What to replace'"), ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборТипа(),
															Элемент.ДоступныеТипы, ОписаниеОповещенияЗавершение, СтандартнаяОбработка, ДополнительныеПараметры);
		
	КонецЕсли;
														
КонецПроцедуры

&НаКлиенте
Процедура ЗаменяемыеЗначенияПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаменяемыеЗначенияПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаменяемыеЗначенияСсылкаПриИзменении(Элемент)

	ТекущиеДанные = Элементы.ЗаменяемыеЗначения.ТекущиеДанные;
	ТекущиеДанные.Пометка = Истина;

КонецПроцедуры

&НаКлиенте
Процедура ЗаменяемыеЗначенияЗаменитьНаПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ЗаменяемыеЗначения.ТекущиеДанные;
	ТекущиеДанные.Пометка = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаменяемыеЗначенияСсылкаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.ОбработкаВыбораЗначенияВФорме(Элемент, ВыбранноеЗначение, СтандартнаяОбработка);

КонецПроцедуры

&НаКлиенте
Процедура ЗаменяемыеЗначенияСсылкаАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.АвтоПодборЗначенияВФорме(Текст, Элемент, ДанныеВыбора, СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыНайденныеСсылки

&НаКлиенте
Процедура НайденныеСсылкиПриАктивизацииСтроки(Элемент)
	
	ИТК_ПодключаемыеКомандыКлиент.ОбновитьЭлементы(ЭтотОбъект, Элементы.НайденныеСсылки, "Данные");
	
	ТекущиеДанные = Элементы.НайденныеСсылки.ТекущиеДанные;
	Элементы.НайденныеСсылкиКонтекстноеМенюОтбор.Видимость = (ТекущиеДанные <> Неопределено) И ТекущиеДанные.ДоступенОтбор;
	
КонецПроцедуры

&НаКлиенте
Процедура НайденныеСсылкиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле = Элементы.НайденныеСсылкиПредставление Тогда
		
		ИТК_ПоискСсылокКлиент.НайденныеСсылкиВыбор(ЭтотОбъект, ВыбраннаяСтрока, СтандартнаяОбработка);
		
	ИначеЕсли Поле = Элементы.НайденныеСсылкиКартинкаОтбора Тогда
		
		ОткрытьНастройкиОтбора();
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ИспользуемыеТипы(Строка, ИспользуемыеТипы)
	
	Если ИТК_МетаданныеКлиентСервер.ЭтоПолноеИмяОбъекта(Строка.Метаданные) Тогда
		
		Если Строка.ДоступенОтбор Тогда
			ИспользуемыеТипы.Добавить(Строка.Метаданные);
		КонецЕсли;
		
		Возврат;
		
	КонецЕсли;
		
	Для Каждого ПодчиненнаяСтрока Из Строка.ПолучитьЭлементы() Цикл 
		
		ИспользуемыеТипы(ПодчиненнаяСтрока, ИспользуемыеТипы);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура НайденныеСсылкиПометкаПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.НайденныеСсылки.ТекущиеДанные;
	
	Пометка = ИТК_ФормаКлиент.ОпределитьПометкуТриСостояния(ТекущиеДанные);
	НайденныеСсылкиПометки.Вставить(ТекущиеДанные.Метаданные, Пометка);
	
	ИТК_ФормаКлиент.ДеревоУстановитьПодчиненнымПометку(ТекущиеДанные, Пометка);
	ИТК_ФормаКлиент.ДеревоОпределитьПометкуРодителя(ТекущиеДанные, Пометка);

КонецПроцедуры

&НаКлиенте
Процедура НайденныеСсылкиПередРазворачиванием(Элемент, Строка, Отказ)
	
	РазворачиваемаяСтрока = НайденныеСсылки.НайтиПоИдентификатору(Строка);
	
	Если ИТК_ФормаКлиентСервер.НеобходимоРазвернутьСтроку(РазворачиваемаяСтрока) Тогда
		
		РазвернутьСтроку(Строка);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НайденныеСсылкиПредставлениеОтбораНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

	ОткрытьНастройкиОтбора();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовЖурналРезультатовОбработки

&НаКлиенте
Процедура ПодключаемыйЖурналРезультатовОбработкаРасшифровки(Элемент, Расшифровка, СтандартнаяОбработка, ДополнительныеПараметры)
	
	СтандартнаяОбработка = Ложь;
	ИндексОбъекта = Расшифровка;
	
	Если ИТК_ОбработкаРезультатаКлиентСервер.ЭтоИндексОбъекта(ИндексОбъекта) Тогда
		
		ОбъектРасшифровки = ОбъектРасшифровки(ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаДанных()], ИндексОбъекта);
		ПоказатьЗначение( , ОбъектРасшифровки); 
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗаполнитьЗаменитьНа(Команда)
	
	ИмяКоллекции = "ЗаменяемыеЗначения";
	ЭлементТаблица = Элементы[ИмяКоллекции];
	ЭлементКолонка = ЭлементТаблица.ТекущийЭлемент;
	ВыделенныеСтроки = ЭлементТаблица.ВыделенныеСтроки;
	
	Если ЗначениеЗаполнено(ВыделенныеСтроки) Тогда
		
		ДопустимыеТипы = ЭлементКолонка.ДоступныеТипы;
		Значение = ЭлементТаблица.ТекущиеДанные.ЗаменитьНа;
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("ИмяКоллекции", ИмяКоллекции);
		ДополнительныеПараметры.Вставить("ДопустимыеТипы", ДопустимыеТипы);
		
		ОписаниеООповещенияОЗакрытии = Новый ОписаниеОповещения("ЗаполнитьЗаменитьНаЗавершено", ЭтотОбъект, ДополнительныеПараметры);
		ИТК_ФормаКлиент.ОткрытьЗаполнениеКолонкиТаблицыЗначений(ЭтотОбъект, Значение, ЭлементКолонка.Имя, ДопустимыеТипы, ОписаниеООповещенияОЗакрытии);

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Далее(Команда)
	
	Отказ = Ложь;
	Если Шаг = 1 Тогда
		
		Если ЗначениеЗаполнено(ЗаменяемыеСсылки()) Тогда
			Обновить();
		Иначе
			
			Отказ = Истина;
			ПоказатьПредупреждение(, НСтр("ru = 'Нет ссылок для поиска';
											|en = 'No search links'"), , ИТК_ПоискИЗаменаСсылокКлиентСервер.Представление());
			
		КонецЕсли;
		
	ИначеЕсли Шаг = 2 Тогда
		
		Если ЕстьСсылкиДляЗамены() Тогда 
			
			ОбновитьПредупреждения();
			ОчиститьЖурналаРезультата();
			
		Иначе
			
			Отказ = Истина;
			ПоказатьПредупреждение(, НСтр("ru = 'Нет ссылок для замены';
											|en = 'No replacement links'"), , ИТК_ПоискИЗаменаСсылокКлиентСервер.Представление());
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ Отказ Тогда
		
		Шаг = Шаг + 1;
		ОбновитьЭлементыФормы();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Назад(Команда)
	
	Отказ = Ложь;
	Если Шаг = 2 Тогда
		
		ИТК_ДлительныеОперации.Отменить(ДлительнаяОперация);
		
	ИначеЕсли Шаг = 3 Тогда
		
		ПрерванаОперацияЗамены = Истина;
		ИТК_ДлительныеОперации.Отменить(ДлительнаяОперация);
		ОбновитьНайденныеСсылки();
		
	КонецЕсли;
	
	Если Не Отказ Тогда
		
		Шаг = Шаг - 1;
		ОбновитьЭлементыФормы();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Обновить(Команда = Неопределено)
	
	ОбновитьНайденныеСсылки();
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура Заменить(Команда)
	
	ВариантыОтвета = Новый СписокЗначений;
	ВариантыОтвета.Добавить(КодВозвратаДиалога.Да,		НСтр("ru = 'Продолжить';
																|en = 'Continue'"));
	ВариантыОтвета.Добавить(КодВозвратаДиалога.Отмена,	НСтр("ru = 'Отмена';
																|en = 'Cancel'"));
	
	ПоказатьВопрос(Новый ОписаниеОповещения("ВопросЗаменитьЗавершение", ЭтотОбъект),
					НСтр("ru = 'Заменить значения. Данная операция не обратима. Продолжить?';
						|en = 'Replace values. This operation is not reversible. Proceed?'"),
					ВариантыОтвета, , КодВозвратаДиалога.Да, ИТК_ПоискИЗаменаСсылокКлиентСервер.Представление());
	
КонецПроцедуры

&НаКлиенте
Процедура СнятьВсе(Команда)
	
	ИТК_ФормаКлиент.УстановитьПометки(ЗаменяемыеЗначения, Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВсе(Команда)
	
	ИТК_ФормаКлиент.УстановитьПометки(ЗаменяемыеЗначения);
	
КонецПроцедуры

&НаКлиенте
Процедура Отбор(Команда)
	
	ОткрытьНастройкиОтбора();
	
КонецПроцедуры

#Область ПодключаемыеКоманды

&НаКлиенте
Процедура ПодключаемаяКоманда(Команда)
	
	Если СтрНайти(Команда.Имя, "РазвернутьВсе") Тогда
		
		НайденныеСсылкиРазвернутьВсе();
		
	КонецЕсли;
	
	ИТК_ПоискСсылокКлиент.ОбработатьПодключеннуюКоманду(ЭтотОбъект, Команда.Имя, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйОбработчикКоманд(Команда)
	
	ИТК_ПараметрыЗаписиКлиент.ОбработатьКоманду(ЭтотОбъект, Команда.Имя);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйОбработчикКомандОбработкаОбъектов(Команда)
	
	ИТК_ОбработкаОбъектовКлиент.ОбработатьКоманду(ЭтотОбъект, Команда.Имя);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьДлительнуюОперацию(Команда)
	
	ИТК_ДлительныеОперацииКлиент.ОтменитьОперацию(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	ШагВводЗначений = 1;
	ШагПоискСсылок = 2;
	ШагЗаменаСсылок = 3;
	КоличествоШагов = 3;
	
	ЗаменяемыеЗначенияТекущиеДанные = Элементы.ЗаменяемыеЗначения.ТекущиеДанные;
	КоличествоСсылок = ЗаменяемыеЗначения.Количество();
	
	Если ЗаменяемыеЗначенияТекущиеДанные <> Неопределено Тогда
		Элементы.ЗаменяемыеЗначенияЗаменитьНа.Доступность = (ЗаменяемыеЗначенияТекущиеДанные.Ссылка <> Неопределено);
	КонецЕсли;
	
	Элементы.ИдетПоискСсылокТабличныйДокумент.Видимость = ИдетПоискСсылок;
	Элементы.НайденныеСсылки.Видимость = Не ИдетПоискСсылок;
	
	Если Шаг = ШагВводЗначений Тогда
		
		ЗаголовокШага = НСтр("ru = 'Ввод значений';
							|en = 'Entering values'");
		ТекущаяСтраница = Элементы.СтраницаСсылки;
		
	ИначеЕсли Шаг = ШагПоискСсылок Тогда
		
		НесколькоЗаменяемыхЗначений = НесколькоЗаменяемыхЗначений();
		Элементы.НайденныеСсылкиСсылка.Видимость = НесколькоЗаменяемыхЗначений;
		
		ЗаголовокШага = НСтр("ru = 'Поиск ссылок, настройка областей замены';
							|en = 'Search links, configure replacement areas'");
		ТекущаяСтраница = Элементы.СтраницаНайденныеСсылки;
		
	ИначеЕсли Шаг = ШагЗаменаСсылок Тогда
		
		ЗаголовокШага = НСтр("ru = 'Окончательная настройка, замена, результат';
							|en = 'Final setup, replacement, result'");
		ТекущаяСтраница = Элементы.СтраницаЗаменаСсылок;
		
		Элементы.ФормаЗаменить.Доступность = Истина;
		
	КонецЕсли;
	
	Элементы.ДополнительныйЗаголовок.Заголовок = СтрШаблон(НСтр("ru = 'Шаг %1 из %2 - %3 ';
																|en = 'Step %1 from %2 - %3 '"), Шаг, КоличествоШагов, ЗаголовокШага);
	Элементы.Страницы.ТекущаяСтраница = ТекущаяСтраница;

	Элементы.ФормаНазад.Видимость = (Шаг > 1);
	
	ЕстьКнопкаДалее = (Шаг < КоличествоШагов И Не ИдетПоискСсылок);
	Элементы.ФормаДалее.Видимость = ЕстьКнопкаДалее;
	Элементы.ФормаДалее.КнопкаПоУмолчанию = ЕстьКнопкаДалее;
	
	ЕстьКнопкаЗаменить = (Шаг = КоличествоШагов);
	
	Элементы.ФормаЗаменить.Видимость = ЕстьКнопкаЗаменить;
	Элементы.ФормаЗаменить.КнопкаПоУмолчанию = ЕстьКнопкаЗаменить;
	
КонецПроцедуры

&НаКлиенте
Функция ЗаменяемыеСсылки()
	
	Результат = Новый Массив;
	
	Для Каждого ЗаменяемоеЗначение Из ЗаменяемыеЗначения Цикл
		
		Если ЗаменяемоеЗначение.Пометка
				И ЗначениеЗаполнено(ЗаменяемоеЗначение.Ссылка) Тогда
				
			Результат.Добавить(ЗаменяемоеЗначение.Ссылка);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
		
КонецФункции

&НаКлиенте
Функция НесколькоЗаменяемыхЗначений()

	Результат = Ложь;
	
	Количество = 0;
	Для Каждого ЗаменяемоеЗначение Из ЗаменяемыеЗначения Цикл
		
		Если ЗаменяемоеЗначение.Пометка
				И ЗначениеЗаполнено(ЗаменяемоеЗначение.Ссылка) Тогда
			
			Количество = Количество + 1;
			
			Если Количество > 1 Тогда
				
				Результат = Истина;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ОбновитьНайденныеСсылки()
	
	ИдетПоискСсылок = Истина;
	
	ДлительнаяОперация = НайтиСсылкиНаСервере(ЗаменяемыеСсылки(), УникальныйИдентификатор);
	
	ПараметрыОжидания = ИТК_ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершенПоискСсылок", ЭтотОбъект);
	ИТК_ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборТипаСсылкиЗавершен(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОграничитьТипЭлемента(Элементы.ЗаменяемыеЗначенияСсылка, Результат, Ложь);
	
	ТекущиеДанные = Элементы.ЗаменяемыеЗначения.ТекущиеДанные;
	ТекущиеДанные.Ссылка = Результат.ПривестиЗначение(Неопределено);
	
	ПривестиСсылкуКЗаменитьНа();
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаменяемыеЗначенияСсылкаОчистка(Элемент, СтандартнаяОбработка)
	
	ОграничитьТипЭлемента(Элементы.ЗаменяемыеЗначенияСсылка, Новый ОписаниеТипов, Истина);
	ПривестиСсылкуКЗаменитьНа();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаменяемыеЗначенияПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если НоваяСтрока
			И НЕ Копирование Тогда
		
		ТекущиеДанные.Пометка = Истина;
		ОграничитьТипЭлемента(Элементы.ЗаменяемыеЗначенияСсылка, Новый ОписаниеТипов, Истина);
		
	КонецЕсли;
	
	ПривестиСсылкуКЗаменитьНа();

КонецПроцедуры

&НаКлиенте
Процедура ПривестиСсылкуКЗаменитьНа()
	
	ЭлементСсылка = Элементы.ЗаменяемыеЗначенияСсылка;
	ЭлементЗаменитьНа = Элементы.ЗаменяемыеЗначенияЗаменитьНа;
	
	ЗаполнитьЗначенияСвойств(ЭлементЗаменитьНа, ЭлементСсылка, "ВыбиратьТип,ОграничениеТипа,ДоступныеТипы");

	ТекущиеДанные = Элементы.ЗаменяемыеЗначения.ТекущиеДанные;
	ТекущиеДанные.ЗаменитьНа = ЭлементСсылка.ОграничениеТипа.ПривестиЗначение(ТекущиеДанные.ЗаменитьНа);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьЗаменитьНаЗавершено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИмяКоллекции = ДополнительныеПараметры.ИмяКоллекции;
	ИзменяемаяТаблицаЗначений = ЭтотОбъект[ИмяКоллекции];
	
	Если Результат.Свойство("ЗаполнятьВсе") Тогда
		
		Для Каждого СтрокаТаблицы Из ИзменяемаяТаблицаЗначений Цикл 
			
			ЗаполнениеПоляСтрокиТаблицы(СтрокаТаблицы, "ЗаменитьНа", Результат.Значение, ТипЗнч(СтрокаТаблицы.Ссылка));
			
		КонецЦикла;
		
	Иначе
		
		Для Каждого ИдентификаторСтроки Из Элементы[ИмяКоллекции].ВыделенныеСтроки Цикл 
			
			СтрокаТаблицы = ИзменяемаяТаблицаЗначений.НайтиПоИдентификатору(ИдентификаторСтроки);
			ЗаполнениеПоляСтрокиТаблицы(СтрокаТаблицы, "ЗаменитьНа", Результат.Значение, ТипЗнч(СтрокаТаблицы.Ссылка));
			
		КонецЦикла;
		
	КонецЕсли;
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнениеПоляСтрокиТаблицы(Строка, Поле, Значение, Тип)
	
	Если Тип = ТипЗнч(Значение) Тогда
		
		Строка[Поле] = Значение;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОграничитьТипЭлемента(Элемент, ОписаниеТипов, ВыбиратьТип)
	
	Элемент.ДоступныеТипы = ОписаниеТипов;
	Элемент.ОграничениеТипа = ОписаниеТипов;
	Элемент.ВыбиратьТип = ВыбиратьТип;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НайтиСсылкиНаСервере(ЗаменяемыеСсылки, УникальныйИдентификатор)
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	
	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("Ссылки", ЗаменяемыеСсылки);
	ПараметрыПроцедуры.Вставить("ПоискИЗаменаСсылок", Истина);
	
	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_ПоискСсылок.НайтиСсылки", ПараметрыПроцедуры, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ЗавершенПоискСсылок(Результат, ДополнительныеПараметры) Экспорт
	
	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		ОбновитьНайденныеСсылкиСервер(Результат.АдресРезультата);
		НайденныеСсылкиОбновитьНастройкиДанных(НайденныеСсылки);
		ПодключитьОбработчикОжидания("ПодключаемыйРазвернутьНайденныеСсылки", 0.1, Истина);
		
		ИдетПоискСсылок = Ложь;
		ОбновитьЭлементыФормы();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьНайденныеСсылкиСервер(АдресРезультата)
	
	ИТК_ПоискСсылок.ОбновитьНайденныеСсылки(ЭтотОбъект, АдресРезультата, Истина);
	
КонецПроцедуры

&НаСервере
Процедура РазвернутьСтроку(Идентификатор)
	
	ИТК_ПоискСсылок.НайденныеСсылкиРазвернутьСтроку(ЭтотОбъект, Идентификатор, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйРазвернутьНайденныеСсылки() Экспорт
	
	ИТК_ПоискСсылокКлиент.РазвернутьНайденныеСсылки(ЭтотОбъект, Истина);
	
КонецПроцедуры

&НаКлиенте
Функция ЕстьСсылкиДляЗамены() Экспорт 
	
	Результат = Ложь;
	
	Для Каждого СтрокаОбъектКоллекции Из НайденныеСсылки.ПолучитьЭлементы() Цикл 
		
		Для Каждого СтрокаОбъектМетаданных Из СтрокаОбъектКоллекции.ПолучитьЭлементы() Цикл 
			
			Если СтрокаОбъектМетаданных.Пометка Тогда
				Результат = Истина;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ОбновитьПредупреждения()
	
	Предупреждения = Новый СписокЗначений;
	
	// Сбор предупреждений
	
	// Попытка замены на пустую ссылку
	КоличествоПустыхЗаменитьНа = 0;
	Для Каждого ЗаменяемоеЗначение Из ЗаменяемыеЗначения Цикл 
		
		Если ЗаменяемоеЗначение.Пометка 
				И Не ЗначениеЗаполнено(ЗаменяемоеЗначение.ЗаменитьНа) Тогда
				
			КоличествоПустыхЗаменитьНа = КоличествоПустыхЗаменитьНа + 1;
			
		КонецЕсли;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(КоличествоПустыхЗаменитьНа) Тогда
		Предупреждения.Добавить(, СтрШаблон(НСтр("ru = 'Замена на пустую ссылку (%1)';
												|en = 'Replacing an empty link (%1)'"), КоличествоПустыхЗаменитьНа), , БиблиотекаКартинок.ИТК_ПредупреждениеВажное);
	КонецЕсли;
	
	// Обновление предупреждений на форме
	ЭлементПредупреждения = Элементы.ГруппаЗаменаСсылокПредупреждения;
	ИТК_Форма.УдалитьПодчиненныеЭлементы(ЭтотОбъект, ЭлементПредупреждения);
	
	ИндексПредупреждения = 0;
	Для Каждого ОписаниеПредупреждения Из Предупреждения Цикл 
		
		Поля = Новый Структура;
		Поля.Вставить("ОтображатьЗаголовок", Ложь);
		Поля.Вставить("Группировка", ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная);
		Поля.Вставить("Заголовок", НСтр("ru = 'Предупреждение (группа)';
										|en = 'Warning (group)'"));
		
		ГруппаПредупреждение = ИТК_Форма.ДобавитьЭлемент(ЭтотОбъект, СтрШаблон("ГруппаПредупреждение%1", ИндексПредупреждения), "Группа", Поля, ЭлементПредупреждения);
		
		Если ЗначениеЗаполнено(ОписаниеПредупреждения.Картинка) Тогда
			
			Поля = Новый Структура;
			Поля.Вставить("Заголовок", НСтр("ru = 'Картинка';
											|en = 'Picture'"));
			Поля.Вставить("Картинка", ОписаниеПредупреждения.Картинка); 
			
			ИТК_Форма.ДобавитьЭлемент(ЭтотОбъект, СтрШаблон("ГруппаПредупреждениеКартинка%1", ИндексПредупреждения), "ДекорацияКартинка", Поля, ГруппаПредупреждение);
			
		КонецЕсли;
		
		Поля = Новый Структура;
		Поля.Вставить("Заголовок", ОписаниеПредупреждения.Представление);
		Поля.Вставить("Шрифт", ИТК_ОбщийКлиентСервер.ШрифтЖирный());
		ИТК_Форма.ДобавитьЭлемент(ЭтотОбъект, СтрШаблон("ГруппаПредупреждениеТекст%1", ИндексПредупреждения), "ДекорацияНадпись", Поля, ГруппаПредупреждение);
		
		ИндексПредупреждения = ИндексПредупреждения + 1;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросЗаменитьЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
		
	ВыполнитьЗаменуСсылок();

КонецПроцедуры

&НаКлиенте
Процедура СобратьНастройкиОтбораОбъектов(Строка, НастройкиОтбораОбъектов)
	
	Для Каждого ПодчиненнаяСтрока Из Строка.ПолучитьЭлементы() Цикл 
		
		Если ПодчиненнаяСтрока.Пометка Тогда
			
			Если ИТК_МетаданныеКлиентСервер.ЭтоПолноеИмяОбъекта(ПодчиненнаяСтрока.Метаданные) Тогда
				
				Если ПодчиненнаяСтрока.ДоступенОтбор Тогда
					Настройки = ИТК_НастройкиОтбораКлиент.НастройкиСУчетомНастроекРодителей(НайденныеСсылкиОтбор, ПодчиненнаяСтрока);
				Иначе
					Настройки = Неопределено;
				КонецЕсли;
				НастройкиОтбораОбъектов.Вставить(ПодчиненнаяСтрока.Метаданные, Настройки);
				
			Иначе
				
				СобратьНастройкиОтбораОбъектов(ПодчиненнаяСтрока, НастройкиОтбораОбъектов);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьНастройкиОтбора()
	
	ТекущиеДанные = Элементы.НайденныеСсылки.ТекущиеДанные;
	
	Если ТекущиеДанные.ДоступенОтбор Тогда

		ИспользуемыеТипы = Новый Массив;
		ИспользуемыеТипы(ТекущиеДанные, ИспользуемыеТипы);
		
		Если ЗначениеЗаполнено(ИспользуемыеТипы) Тогда
			
			ПараметрыФормы = Новый Структура;
			ПараметрыФормы.Вставить("ИспользуемыеТипы", ИспользуемыеТипы);
			ПараметрыФормы.Вставить("Настройки", ИТК_НастройкиОтбораКлиент.НастройкиСУчетомНастроекРодителей(НайденныеСсылкиОтбор, ТекущиеДанные));
			
			ОписаниеОповещения = Новый ОписаниеОповещения("НастройкаОтбораЗавершение", ЭтотОбъект);
			ОткрытьФорму("ОбщаяФорма.ИТК_НастройкаОтбора", ПараметрыФормы, ЭтотОбъект, , , , ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаОтбораЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ТекущиеДанные = Элементы.НайденныеСсылки.ТекущиеДанные;
	НайденныеСсылкиОтбор.Вставить(ТекущиеДанные.Метаданные, Результат);
	ЗаполнитьДанныеНастроекНайденныхСсылок(ТекущиеДанные);
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаКлиенте
Процедура НайденныеСсылкиОбновитьНастройкиДанных(Строка)
	
	Для Каждого ПодчиненнаяСтрока Из Строка.ПолучитьЭлементы() Цикл 
		
		Если ПодчиненнаяСтрока.ДоступенОтбор Тогда
			
			ЗаполнитьДанныеНастроекНайденныхСсылок(ПодчиненнаяСтрока);
			НайденныеСсылкиОбновитьНастройкиДанных(ПодчиненнаяСтрока);
			
		Иначе 
			
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДанныеНастроекНайденныхСсылок(Строка)
	
	Настройки = НайденныеСсылкиОтбор.Получить(Строка.Метаданные);
	Если ЗначениеЗаполнено(Настройки) 
			И ЗначениеЗаполнено(Настройки.Отбор.Элементы) Тогда
			
		Картинка = БиблиотекаКартинок.ИТК_ОтборУстановлен;
		Представление = ИТК_Строки.Сократить(Настройки.Отбор, 200);
		
	Иначе
		
		Картинка = БиблиотекаКартинок.ОтборКомпоновкиДанныхНедоступный;
		Представление = "";
		
	КонецЕсли;
	
	Строка.КартинкаОтбора = Картинка;
	Строка.ПредставлениеОтбора = Представление;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "НайденныеСсылкиПредставлениеОтбора", Новый Структура("Доступность", Ложь), "НайденныеСсылки.ДоступенОтбор", Ложь);
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "НайденныеСсылкиПометка", Новый Структура("Отображать", Ложь), "НайденныеСсылки.Ссылка", Истина, ВидСравненияКомпоновкиДанных.Заполнено);
	
КонецПроцедуры

&НаСервере
Процедура НайденныеСсылкиРазвернутьВсе()
	
	ИТК_ПоискСсылок.РазвернутьВсе(ЭтотОбъект, Истина);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДобавитьОбъектыСЗаменяемымиСсылками(Объекты, НайденныеСтроки)
	
	Для Каждого Строка Из НайденныеСтроки Цикл 
		
		НоваяСтрока = Объекты.Добавить();
		НоваяСтрока.Объект = Строка.Данные;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьЗаменуСсылок()

	НастройкиОтбораОбъектов = Новый Соответствие;
	СобратьНастройкиОтбораОбъектов(НайденныеСсылки, НастройкиОтбораОбъектов);
	
	ЗаменяемыеСсылкиАдрес = ПоместитьВоВременноеХранилище(ОписаниеЗаменяемыхСсылок(), УникальныйИдентификатор);
	
	ОбрабатываемыеОбъектыАдрес = ПоместитьВоВременноеХранилище(Неопределено, УникальныйИдентификатор);
	ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаДанных()] = ОбрабатываемыеОбъектыАдрес;
	ОбрабатываемыеОбъектыКоличество = ОбрабатываемыеОбъекты(НайденныеСсылкиАдресРезультата, НастройкиОтбораОбъектов, ОбрабатываемыеОбъектыАдрес);
	
	ПараметрыЗаписи = ИТК_ПараметрыЗаписиКлиентСервер.Значения(ЭтотОбъект);
	
	ПрерванаОперацияЗамены = Ложь;
	
	ОписаниеОперации = Новый Структура;
	ОписаниеОперации.Вставить("Источник", ИТК_Перечисления.ИнструментПоискИЗаменаСсылок());
	ОписаниеОперации.Вставить("Наименование", НСтр("ru = 'Поиск и замена ссылок';
													|en = 'Search and replace links'"));

	ОповещениеНачала = Новый ОписаниеОповещения("НачалоДлительнойОперации", ЭтотОбъект);
	ИТК_ОбработкаОбъектовКлиент.Инициализация(ЭтотОбъект, ОбрабатываемыеОбъектыКоличество, ОписаниеОперации, ОповещениеНачала);
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершенаОбработкаДанных", ЭтотОбъект);
	ФоновоеВыполнение = ИТК_БСПКлиентСервер.ВозможноВыполнениеВФоне();
	Если ФоновоеВыполнение Тогда
		
		ДлительнаяОперация = ЗапуститьОбработкуЗаменыСсылокНаСервере(ОбрабатываемыеОбъектыАдрес, НайденныеСсылкиАдресРезультата, ЗаменяемыеСсылкиАдрес, ПараметрыЗаписи, УникальныйИдентификатор, ФоновоеВыполнение);
		
		ОповещениеОПрогрессеВыполнения = Новый ОписаниеОповещения("ОбработкаПрогрессаВыполнения", ЭтотОбъект);
		ИТК_ОбработкаОбъектовКлиент.ИнициализацияДлительнойОперации(ЭтотОбъект, ДлительнаяОперация, ОписаниеОперации, ОповещениеОПрогрессеВыполнения, ОповещениеОЗавершении);
		
	Иначе
		
		ВыполнитьОбработкуЗаменыСсылок(ОбрабатываемыеОбъектыАдрес, ЗаменяемыеСсылкиАдрес, ПараметрыЗаписи);
		ВыполнитьОбработкуОповещения(ОповещениеОЗавершении);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НачалоДлительнойОперации(Результат, ДополнительныеПараметры) Экспорт
	
	Элементы.ФормаЗаменить.Доступность = Ложь;
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьЖурналаРезультата() Экспорт
	
	ИТК_ОбработкаОбъектов.ОчиститьЖурналаРезультата(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаПрогрессаВыполнения(Результат, ДополнительныеПараметры) Экспорт
	
	ИТК_ДлительныеОперацииКлиент.ПодготовитьПрогрессВыполнения(Результат);
	
	ОбработатьСообщенияПрогресса(Результат.Сообщения);
	ИТК_ДлительныеОперацииКлиент.ПоказатьПрогресс(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСообщенияПрогресса(Сообщения)
	
	Результат = ОбработатьСообщенияПрогрессаСервер(Сообщения);
	
	СостояниеОбработки = ИТК_ОбработкаОбъектовКлиент.СостояниеОбработки(ЭтотОбъект);
	СостояниеОбработки.Ошибок = СостояниеОбработки.Ошибок + Результат.Ошибок;
	СостояниеОбработки.Обработано = СостояниеОбработки.Обработано + Результат.Обработано;
	
	ФоновоеВыполнение = ИТК_БСПКлиентСервер.ВозможноВыполнениеВФоне();
	ИТК_ОбработкаОбъектовКлиент.ОбновитьПрогресс(ЭтотОбъект, ФоновоеВыполнение);
	
КонецПроцедуры

&НаСервере
Функция ОбработатьСообщенияПрогрессаСервер(Сообщения)
	
	АдресДанных = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаДанных()];
	АдресЖурнала = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаЖурналаРезультата()];
	АдресРезультатов = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаРезультатов()];
	ПоследниеСообщения = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторСообщенияОбработкиПоследнегоОбъекта()];
	ИндексПоследнегоОбрабатываемогоОбъекта = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторИндексПоследнегоОбрабатываемогоОбъекта()];
	
	Результат = ИТК_ОбработкаОбъектов.ОбработатьСообщенияПрогресса(АдресЖурнала, АдресРезультатов, ПоследниеСообщения, ИндексПоследнегоОбрабатываемогоОбъекта, Сообщения, АдресДанных);
	ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторИндексПоследнегоОбрабатываемогоОбъекта()] = ИндексПоследнегоОбрабатываемогоОбъекта;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ОписаниеЗаменяемыхСсылок()
	
	Результат = Новый Соответствие;
	
	Для Каждого СтрокаЗаменяемоеЗначение Из ЗаменяемыеЗначения Цикл
		
		ЗаменяемаяСсылка = СтрокаЗаменяемоеЗначение.Ссылка;
		ЗаменитьНа = СтрокаЗаменяемоеЗначение.ЗаменитьНа;
		Если СтрокаЗаменяемоеЗначение.Пометка
			И ЗначениеЗаполнено(ЗаменяемаяСсылка) Тогда
			
			ОписаниеЗамены = Новый Структура;
			ОписаниеЗамены.Вставить("GUID", Строка(ЗаменяемаяСсылка.УникальныйИдентификатор()));
			Если ЗначениеЗаполнено(ЗаменитьНа) Тогда
				НовыйGUID = Строка(СтрокаЗаменяемоеЗначение.ЗаменитьНа.УникальныйИдентификатор());
			Иначе
				НовыйGUID = ИТК_Строки.ПустойУникальныйИдентификатор();
			КонецЕсли;
			ОписаниеЗамены.Вставить("НовыйGUID", НовыйGUID);
			
			Результат.Вставить(ЗаменяемаяСсылка, ОписаниеЗамены);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция ОбрабатываемыеОбъекты(НайденныеСсылкиАдресРезультата, НастройкиОтбораОбъектов, ОбрабатываемыеОбъектыАдрес)
	
	Результат = ПолучитьИзВременногоХранилища(НайденныеСсылкиАдресРезультата);
	НайденныеСсылки = Результат.НайденныеСсылки;
	
	// Собираем данные для обработки (объект должен встречатся один раз даже если в нем несколько ссылок, )
	// Быстрее всего работает Свернуть() таблицы значений
	ОбрабатываемыеОбъекты = Новый ТаблицаЗначений;
	ОбрабатываемыеОбъекты.Колонки.Добавить("Объект");
	
	Для Каждого НастрокиОтбораОбъекта Из НастройкиОтбораОбъектов Цикл 
		
		Настройки = НастрокиОтбораОбъекта.Значение;
		ИмяОбъектаМетаданных = НастрокиОтбораОбъекта.Ключ;
		НайденныеСсылкиПоОбъектуМетаданных = НайденныеСсылки.НайтиСтроки(Новый Структура("Метаданные", ИмяОбъектаМетаданных));
		
		Если Настройки = Неопределено Тогда
			
			ДобавитьОбъектыСЗаменяемымиСсылками(ОбрабатываемыеОбъекты, НайденныеСсылкиПоОбъектуМетаданных);
			
		Иначе
			
			Ссылки = Новый Массив;
			Для Каждого СтрокаНайденнаяСсылка Из НайденныеСсылкиПоОбъектуМетаданных Цикл 
				Ссылки.Добавить(СтрокаНайденнаяСсылка.Данные);
			КонецЦикла;
			
			ОбрабатываемыеСсылки = ИТК_НастройкиОтбора.ОбрабатываемыеСсылки(ИмяОбъектаМетаданных, Настройки, Ссылки);
			Для Каждого ОбрабатываемаяСсылка Из ОбрабатываемыеСсылки Цикл 
				
				ОтборСтрок = Новый Структура;
				ОтборСтрок.Вставить("Метаданные", ИмяОбъектаМетаданных);
				ОтборСтрок.Вставить("Данные", ОбрабатываемаяСсылка);
				НайденныеСсылкиПоОбъектуМетаданныхИДанным = НайденныеСсылки.НайтиСтроки(ОтборСтрок);
				
				ДобавитьОбъектыСЗаменяемымиСсылками(ОбрабатываемыеОбъекты, НайденныеСсылкиПоОбъектуМетаданныхИДанным);
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ОбрабатываемыеОбъекты.Свернуть("Объект");
	Результат = ОбрабатываемыеОбъекты.ВыгрузитьКолонку("Объект");
	ПоместитьВоВременноеХранилище(Результат, ОбрабатываемыеОбъектыАдрес);
	
	Возврат Результат.Количество();
	
КонецФункции

&НаКлиенте
Процедура ВыполнитьОбработкуЗаменыСсылок(ОбрабатываемыеОбъектыАдрес, ЗаменяемыеСсылкиАдрес, ПараметрыЗаписи)
	
	// Обработка всех строк
	ИндексНачалаПакета = 0;
	КоличествоВПакете = 1;
	
	ИмяПроцедурыОбработкиПрерыванияПользователем = "ПодключаемыйОбработкаПрерыванияПользователем";
	ПодключитьОбработчикОжидания(ИмяПроцедурыОбработкиПрерыванияПользователем, 0.1, Истина);
	
	ИнтервалОбновления = 0.5; ПоказываетсяПрогресс = Ложь;
	
	СостояниеОбработки = ИТК_ОбработкаОбъектовКлиент.СостояниеОбработки(ЭтотОбъект);
	Пока СостояниеОбработки.Обработано < СостояниеОбработки.Обрабатывается  Цикл 
		
		// Подготавливаем пакет обрабатываемых объектов
		ПакетОбъектов = Новый Массив;
		Для ИндексСтроки = ИндексНачалаПакета По (ИндексНачалаПакета + КоличествоВПакете - 1) Цикл
			ПакетОбъектов.Добавить(ИндексСтроки);
		КонецЦикла;
		
		// Обрабатываем
		РезультатОбработки = ОбработатьОбновитьРезультатСервер(НайденныеСсылкиАдресРезультата, ОбрабатываемыеОбъектыАдрес, ПакетОбъектов, ЗаменяемыеСсылкиАдрес, ПараметрыЗаписи);
		ВремяОбработки = ИТК_ОбщийКлиентСервер.МиллисекВСек(РезультатОбработки.ВремяОбработки);
		
		ИТК_ОбработкаОбъектовКлиент.ПоказатьПрогрессНаФорме(ЭтотОбъект, ПоказываетсяПрогресс);
		ОбработатьСообщенияПрогресса(РезультатОбработки.Сообщения);
		СостояниеОбработки = ИТК_ОбработкаОбъектовКлиент.СостояниеОбработки(ЭтотОбъект);
		
		ИТК_ОбработкаОбъектовКлиент.ЗаполняемДанныеСледующегоПакета(СостояниеОбработки.Обрабатывается, ВремяОбработки, ИндексНачалаПакета, КоличествоВПакете, ИнтервалОбновления);
		
		ОбработкаПрерыванияПользователя();
		
	КонецЦикла;
	
	ОтключитьОбработчикОжидания(ИмяПроцедурыОбработкиПрерыванияПользователем);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйОбработкаПрерыванияПользователем() Экспорт
	
	ЗавершенаОбработкаДанных();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершенаОбработкаДанных(Результат = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт

	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	
	Если ЗначениеЗаполнено(Результат) Тогда
		ОбработатьСообщенияПрогресса(Результат.Сообщения);
	КонецЕсли;
	
	ИТК_ДлительныеОперацииКлиент.СкрытьПрогресс(ЭтотОбъект);
	ИТК_ОбработкаОбъектовКлиент.ПоказатьИнформациюОПоследнейОбработке(ЭтотОбъект);
	
	ИТК_ВременноеХранилище.Удалить(ЗаменяемыеСсылкиАдрес);
	
	Если Не ПрерванаОперацияЗамены Тогда
		ТекущийЭлемент = Элементы.ГруппаРезультат;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ОбработатьОбновитьРезультатСервер(АдресНайденныеСсылки, ОбрабатываемыеОбъектыАдрес, ПакетОбъектов, АдресЗаменяемыеСсылки, ПараметрыЗаписи)
	
	НачалоОбработки = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	ПараметрыПроцедуры = Новый Структура;
	
	ОписаниеНайденных = ПолучитьИзВременногоХранилища(АдресНайденныеСсылки);
	ПараметрыПроцедуры.Вставить("Найденные", ОписаниеНайденных.НайденныеСсылки);
	
	ПараметрыПроцедуры.Вставить("Обрабатываемые", ПолучитьИзВременногоХранилища(ОбрабатываемыеОбъектыАдрес));
	ПараметрыПроцедуры.Вставить("ПакетОбъектов", ПакетОбъектов);
	ПараметрыПроцедуры.Вставить("Заменяемые", ПолучитьИзВременногоХранилища(АдресЗаменяемыеСсылки));
	ПараметрыПроцедуры.Вставить("ПараметрыЗаписи", ПараметрыЗаписи);
	ИТК_ПоискИЗаменаСсылок.Заменить(ПараметрыПроцедуры);
	
	Возврат ИТК_ОбработкаОбъектов.ВернутьРезультат(НачалоОбработки);
	
КонецФункции

&НаСервереБезКонтекста
Функция ЗапуститьОбработкуЗаменыСсылокНаСервере(ОбрабатываемыеОбъектыАдрес, АдресНайденныхСсылок, АдресЗаменяемыеСсылки, ПараметрыЗаписи, УникальныйИдентификатор, ФоновоеВыполнение)

	ПараметрыПроцедуры = Новый Структура;
	
	РезультатПоиска = ПолучитьИзВременногоХранилища(АдресНайденныхСсылок);
	ПараметрыПроцедуры.Вставить("Найденные", РезультатПоиска.НайденныеСсылки);
	
	ПараметрыПроцедуры.Вставить("ПакетОбъектов", Неопределено);
	ПараметрыПроцедуры.Вставить("Обрабатываемые", ПолучитьИзВременногоХранилища(ОбрабатываемыеОбъектыАдрес));
	ПараметрыПроцедуры.Вставить("Заменяемые", ПолучитьИзВременногоХранилища(АдресЗаменяемыеСсылки));
	ПараметрыПроцедуры.Вставить("ПараметрыЗаписи", ПараметрыЗаписи);
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.ЗапуститьНеВФоне = НЕ ФоновоеВыполнение;
	
	Результат = ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_ПоискИЗаменаСсылок.Заменить", ПараметрыПроцедуры, ПараметрыВыполнения);
	
	Возврат Результат;

КонецФункции

&НаСервереБезКонтекста
Функция ОбъектРасшифровки(АдресОбрабатываемыхДанных, ИндексОбъекта)
	
	ОбрабатываемыеДанные = ПолучитьИзВременногоХранилища(АдресОбрабатываемыхДанных);
	Возврат ОбрабатываемыеДанные[ИндексОбъекта];
	
КонецФункции

#КонецОбласти
