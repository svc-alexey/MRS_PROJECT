
#Область ОписаниеПеременных

&НаКлиенте
Перем ЗакрытиеРазрешено;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ЭлементРодительКнопки", Элементы.ЗначенияПараметровСеансаГруппаПрочиеФильтры);
	ДополнительныеПараметры.Вставить("ГруппаКонтекстногоМеню", Элементы.ЗначенияПараметровСеансаКонтекстноеМенюГруппаИзбранное);
	ДополнительныеПараметры.Вставить("ЭлементВставкиКолонкиПеред", Элементы.ЗначенияПараметровСеансаГруппаЗначение);
	ИТК_Избранное.Инициализировать(ЭтотОбъект, "ЗначенияПараметровСеанса", ДополнительныеПараметры);
	
	УстановитьУсловноеОформление();
	
	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.ЗначенияПараметровСеанса);
	
	ВидИнструмента = ИТК_Перечисления.ИнструментРедакторПараметровСеанса();
	
	Если Параметры.Свойство("Имя") Тогда
		ЗначенияПараметровСеансаПоследнееВыделение = Новый Структура("Имя", Параметры.Имя);
	КонецЕсли;
	
	// Подключение команд
	ИТК_ПодключаемыеКоманды.ИнструментыКТаблицеЗначений(ЭтотОбъект, "ЗначенияПараметровСеанса");
	
	ОбновитьПараметрыСеансаНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИТК_ОбщийКлиент.ОбработчикПриОткрытии(Отказ);
	
	ОтключитьТолькоИзбранные = ЗначениеЗаполнено(ЗначенияПараметровСеансаПоследнееВыделение);
	ИТК_ИзбранноеКлиент.ПриОткрытии(ЭтотОбъект, Элементы.ЗначенияПараметровСеанса, ОтключитьТолькоИзбранные);
	
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаСервере
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	
	ИТК_Избранное.ПриЗагрузкеДанныхИзНастроекНаСервере(ЭтотОбъект, Настройки);
	
КонецПроцедуры

&НаСервере
Процедура ПриСохраненииДанныхВНастройкахНаСервере(Настройки)
	
	ИТК_Избранное.ПриСохраненииДанныхВНастройкахНаСервере(ЭтотОбъект, Настройки);
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы = Истина Тогда
		
		Если Модифицированность Тогда
			
			ТекстПредупреждения = НСтр("ru = 'Имеются несохраненные данные, они будут потеряны.
                                        |Для сохранения изменений нажмите ""Продолжить работу"", сохраните данные, а потом завершите работу.';
                                        |en = 'There is unsaved data, it will be lost.
                                        |To save changes, click Continue, save the data, and then exit.'");
			
			Отказ = Истина;
			
		КонецЕсли;
		
	Иначе
		
		Если ЗакрытиеРазрешено = Неопределено Тогда
			
			Отказ = Истина;
			ЗапуститьОбработчикСПроверкойНаСохранностьДанных(Новый ОписаниеОповещения("ОбработчикЗакрытиеРазрешеноЗакрыть", ЭтотОбъект));

		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Обновить(Команда)
	
	ОбновитьПараметрыСеанса();
	
КонецПроцедуры

&НаКлиенте
Процедура Записать(Команда)
	
	Если ОтсутствуетИзменения() Тогда
		
		ТекстПредупреждения = НСтр("ru = 'Нет изменений для записи';
									|en = 'No changes to record'");
		ПоказатьПредупреждение( , ТекстПредупреждения, , ИТК_РедакторПараметровСеансаКлиентСервер.Представление());
		
		Возврат;
		
	КонецЕсли;
	
	ОписаниеОЗавершении = Новый ОписаниеОповещения("ЗавершенВопросЗаписи", ЭтотОбъект);
	
	ЗаголовокВопроса = НСтр("ru = 'Записать?';
							|en = 'Write?'");
	ТекстВопроса = "";
	ПоказатьВопрос(ОписаниеОЗавершении, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет, ЗаголовокВопроса, КодВозвратаДиалога.Нет);
	
КонецПроцедуры

#Область ПодключаемыеКоманды

&НаКлиенте
Процедура ПодключаемаяКоманда(Команда)
	
	ИТК_ПодключаемыеКомандыКлиент.ОбработатьКоманду(ЭтотОбъект, Команда.Имя);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйОбработчикКоманд(Команда)
	
	ИТК_ПараметрыЗаписиКлиент.ОбработатьКоманду(ЭтотОбъект, Команда.Имя);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ТолькоИзбранные(Команда)
	
	ИТК_ИзбранноеКлиент.ОбработкаКомандыТолькоИзбранные(ЭтотОбъект, Элементы.ЗначенияПараметровСеанса);
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ДобавитьВИзбранное(Команда)
	
	ИТК_ИзбранноеКлиент.ОбработкаКомандыДобавитьВИзбранное(ВидИнструмента, ЭтотОбъект,
							"ЗначенияПараметровСеанса", "Имя");
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_УдалитьИзИзбранного(Команда)

	ИТК_ИзбранноеКлиент.ОбработкаКомандыУдалитьИзИзбранного(ВидИнструмента, ЭтотОбъект,
							"ЗначенияПараметровСеанса", "Имя");
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыЗначенияПараметровСеанса

&НаКлиенте
Процедура ЗначенияПараметровСеансаПриАктивизацииЯчейки(Элемент)
	
	ИТК_ПодключаемыеКомандыКлиент.ОбновитьЭлементы(ЭтотОбъект, Элемент, "Значение");
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияПараметровСеансаПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		
		ЗначенияПараметровСеансаПоследнееВыделение = Неопределено;
		Возврат;
		
	КонецЕсли;
	ЗначенияПараметровСеансаПоследнееВыделение = Новый Структура("Имя", ТекущиеДанные.Имя);
	
	ИТК_ФормаКлиент.АктивизацияЗначенияВФорме(Элементы.ЗначенияПараметровСеансаЗначение, ТекущиеДанные.Значение, ТекущиеДанные.Тип);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияПараметровСеансаПриИзменении(Элемент)
	
	Модифицированность = Истина;
	ИТК_ПодключаемыеКомандыКлиент.ОбновитьЭлементы(ЭтотОбъект, Элементы.ЗначенияПараметровСеанса);
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияПараметровСеансаПередНачаломИзменения(Элемент, Отказ)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Элемент.ТекущийЭлемент.ОграничениеТипа = ТекущиеДанные.Тип;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияПараметровСеансаЗначениеПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ЗначенияПараметровСеанса.ТекущиеДанные;
	ТекущиеДанные.Изменять = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияПараметровСеансаВыбор(Элемент, ИдентификаторВыбраннойСтроки, Поле, СтандартнаяОбработка)
	
	ВыбраннаяСтрока = ЗначенияПараметровСеанса.НайтиПоИдентификатору(ИдентификаторВыбраннойСтроки);
	
	Обработано = ИТК_ИзбранноеКлиент.ОбработкаВыборВКоллекции(ВидИнструмента, ЭтотОбъект,
						"ЗначенияПараметровСеанса", Поле, ВыбраннаяСтрока, "Имя");
	Если Обработано Тогда
		Возврат;
	КонецЕсли;
	
	Если Поле = Элементы.ЗначенияПараметровСеансаЗначениеГиперссылка Тогда
		
		Если ТипЗнч(ВыбраннаяСтрока.Значение) = Тип("ХранилищеЗначения") Тогда
			
			СтандартнаяОбработка = Ложь;
			ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("РедактированиеХранилищаЗначенийЗавершено", ЭтотОбъект);
			ИТК_ФормаКлиент.ОткрытьРедактированиеХранилищаЗначений(ВыбраннаяСтрока.Значение, ЭтотОбъект, ОписаниеОповещенияЗавершение);
			
		Иначе
			
			ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("РедактированиеПроизвольногоЗначенияЗавершено", ЭтотОбъект);
			ЗначениеХранилище = ИТК_ПроизвольноеЗначениеВызовСервера.ПоместитьЗначениеВХранилище(ВыбраннаяСтрока.Значение);
			ИТК_ПроизвольноеЗначениеКлиент.ОбработкаНачалоВыбора(Элемент, ЗначениеХранилище, ОписаниеОповещенияЗавершение, СтандартнаяОбработка);
			
		КонецЕсли;
		Возврат;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияПараметровСеансаЗначениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ЗначенияПараметровСеанса.ТекущиеДанные;
	
	Имя = ТекущиеДанные.Имя;
	ЗаголовокФормы = СтрШаблон(НСтр("ru = 'Параметр сеанса ""%1""';
									|en = 'Session parameter ""%1""'"), Имя);

	ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("ВводЗначенияПараметраСеансаЗавершен", ЭтотОбъект, Новый Структура);
	Если ТекущиеДанные.Тип.СодержитТип(Тип("ОписаниеТипов")) Тогда
		
		ИТК_ФормаКлиент.ОткрытьРедактированиеТипаЗначения(Элемент, ЗаголовокФормы, ИТК_Перечисления.РежимРедактированияТипаЗначенияРедактированиеОписанияТипов(),
																	ТекущиеДанные.Значение, ОписаниеОповещенияЗавершение, СтандартнаяОбработка);
	Иначе
		
		ИТК_ФормаКлиент.ВводЗначенияСтрокиВФорме(ЗаголовокФормы, Элемент, ТекущиеДанные.Значение, ТекущиеДанные.Тип, СтандартнаяОбработка, ОписаниеОповещенияЗавершение);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияПараметровСеансаЗначениеОчистка(Элемент, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.ОчисткаЗначенияСтрокиВФорме(Элемент, СтандартнаяОбработка);
	
	Строка = Элементы.ЗначенияПараметровСеанса.ТекущиеДанные;
	Строка.Изменять = Истина;
	Строка.Значение = Строка.Тип.ПривестиЗначение(Неопределено);
	
	ОбновитьДанныеСтроки(Строка);
	
	ИТК_ФормаКлиент.АктивизацияЗначенияВФорме(Элемент, Неопределено, Строка.Тип);
	
	ЗначенияПараметровСеансаПриИзменении(Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияПараметровСеансаЗначениеОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.ОбработкаВыбораЗначенияВФорме(Элемент, ВыбранноеЗначение, СтандартнаяОбработка);
	ОбновитьДанныеСтроки(Элементы.ЗначенияПараметровСеанса.ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗначенияПараметровСеансаЗначениеАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.АвтоПодборЗначенияВФорме(Текст, Элемент, ДанныеВыбора, СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьПараметрыСеанса()
	
	ОбновитьПараметрыСеансаНаСервере();
	ИТК_ФормаКлиент.ВосстановитьВыделениеТаблицы(ЭтотОбъект, "ЗначенияПараметровСеанса", ЗначенияПараметровСеансаПоследнееВыделение);

	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьПараметрыСеансаНаСервере()
	
	ЗначенияПараметровСеанса.Очистить();
	
	ИзбранныеОбъекты = ИТК_Избранное.КоллекцияИзбранныеОбъекты(ВидИнструмента);
	ТекущийПользователь = ПользователиИнформационнойБазы.ТекущийПользователь();
	Для Каждого ПараметрСеанса Из Метаданные.ПараметрыСеанса Цикл 
		
		Если НЕ ПравоДоступа("Получение", ПараметрСеанса, ТекущийПользователь) Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = ЗначенияПараметровСеанса.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ПараметрСеанса);
		
		НоваяСтрока.КартинкаТип = ИТК_Типы.КартинкаОписания(ПараметрСеанса.Тип);
		НоваяСтрока.ТипПредставление = ИТК_Типы.ПредставлениеОписания(ПараметрСеанса.Тип);
		
		Попытка
			Значение = ПараметрыСеанса[ПараметрСеанса.Имя];
		Исключение
			Значение = НСтр("ru = '<Не инициализирован>';
							|en = '<Not initialized>'");
		КонецПопытки; 
		НоваяСтрока.Значение = Значение;
		НоваяСтрока.ЗначениеКартинка = ИТК_Типы.КартинкаЗначения(Значение, ПараметрСеанса.Тип);
		Если ТипЗнч(Значение) = Тип("ХранилищеЗначения") Тогда
			НоваяСтрока.ЗначениеГиперссылка = ИТК_ПроизвольноеЗначение.ПредставлениеЗначения(Значение);
		ИначеЕсли ТипЗнч(Значение) = Тип("ФиксированныйМассив")
					ИЛИ ТипЗнч(Значение) = Тип("ФиксированнаяСтруктура")
					ИЛИ ТипЗнч(Значение) = Тип("ФиксированноеСоответствие") Тогда
			НоваяСтрока.ЗначениеГиперссылка = Значение
		Иначе
			НоваяСтрока.ЗначениеГиперссылка = Неопределено;
		КонецЕсли;
		
		ИТК_Избранное.ЗаполнитьСтрокуТаблицыЗначений(ИзбранныеОбъекты,
								НоваяСтрока, ПараметрСеанса.Имя);
								
	КонецЦикла;

	Модифицированность = Ложь;

КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	Оформление = Новый Структура("Шрифт", ИТК_ОбщийКлиентСервер.ШрифтЖирный());
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "ЗначенияПараметровСеансаИмя", Оформление,
		"ЗначенияПараметровСеанса.Изменять", Истина);
	
	Оформление = Новый Структура("Видимость", Ложь);
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "ЗначенияПараметровСеансаЗначение", Оформление,
		"ЗначенияПараметровСеанса.ЗначениеГиперссылка", , ВидСравненияКомпоновкиДанных.Заполнено);
	
	Оформление = Новый Структура("Видимость", Ложь);
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "ЗначенияПараметровСеансаЗначениеГиперссылка", Оформление,
		"ЗначенияПараметровСеанса.ЗначениеГиперссылка", , ВидСравненияКомпоновкиДанных.НеЗаполнено);
	
КонецПроцедуры

&НаКлиенте
Процедура ВводЗначенияПараметраСеансаЗавершен(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элементы.ЗначенияПараметровСеанса.ТекущиеДанные;
	ТекущиеДанные.Изменять = Истина;
	
	ИТК_ФормаКлиент.ОбработкаЗавершенВводЗначенияВФорме(Элементы.ЗначенияПараметровСеансаЗначение, Результат, ДополнительныеПараметры,
																ТекущиеДанные.Значение, ТекущиеДанные.Тип, Модифицированность); 
	ОбновитьДанныеСтроки(ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура РедактированиеХранилищаЗначенийЗавершено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элементы.ЗначенияПараметровСеанса.ТекущиеДанные;
	ТекущиеДанные.Изменять = Истина;
	
	ИТК_ФормаКлиент.ОбработкаЗавершенВводЗначенияВФорме(Элементы.ЗначенияПараметровСеансаЗначение, Результат, ДополнительныеПараметры,
																ТекущиеДанные.Значение, ТекущиеДанные.Тип, Модифицированность); 
	ОбновитьДанныеСтроки(ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура РедактированиеПроизвольногоЗначенияЗавершено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элементы.ЗначенияПараметровСеанса.ТекущиеДанные;
	ТекущиеДанные.Изменять = Истина;
	
	ТекущиеДанные.Значение = ИТК_ПроизвольноеЗначениеВызовСервера.ЗначениеВХранилище(Результат);
	ТекущиеДанные.ЗначениеГиперссылка = ИТК_ПроизвольноеЗначениеВызовСервера.ПредставлениеЗначения(Результат);
	
	ОбновитьДанныеСтроки(ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Функция ОтсутствуетИзменения()
	
	Отбор = Новый Структура("Изменять", Истина);
	ИзменяемыеПараметрыСеанса = ЗначенияПараметровСеанса.НайтиСтроки(Отбор);
	
	Возврат НЕ ЗначениеЗаполнено(ИзменяемыеПараметрыСеанса);
	
КонецФункции

&НаКлиенте
Процедура ЗавершенВопросЗаписи(Результат, ДополнительныеПараметры) Экспорт 
	
	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
		
	Ошибка = ЗаписатьЗначенияПараметровСеанса();
	Если ЗначениеЗаполнено(Ошибка) Тогда
		
		ПоказатьПредупреждение( , Ошибка, , ИТК_РедакторПараметровСеансаКлиентСервер.Представление());
		
	Иначе 
		
		Модифицированность = Ложь;
		ОбновитьПараметрыСеанса();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЗаписатьЗначенияПараметровСеанса()
	
	Попытка
		
		Для Каждого ЗначениеПараметраСеанса Из ЗначенияПараметровСеанса Цикл 
			
			Если Не ЗначениеПараметраСеанса.Изменять Тогда
				Продолжить;
			КонецЕсли;
			
			ПараметрыСеанса[ЗначениеПараметраСеанса.Имя] = ЗначениеПараметраСеанса.Значение;
			
		КонецЦикла;
		
		Результат = "";
		
	Исключение
		
		Результат = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		
	КонецПопытки;
	
	Возврат Результат;
		
КонецФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	Элементы.ФормаЗаписать.Заголовок = ИТК_ФормаКлиентСервер.ЗаголовокСКоличеством(НСтр("ru = 'Записать'; en = 'Write'"),
																	КоличествоИзменяемыхПараметровСеанса());
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанныеСтроки(Строка)
	
	Строка.ЗначениеКартинка = ИТК_Типы.КартинкаЗначения(Строка.Значение, Строка.Тип);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьОбработчикСПроверкойНаСохранностьДанных(ОписаниеОбработчика)
	
	Если Модифицированность Тогда
		
		// Список вариантов ответа
		ВариантыОтвета = Новый СписокЗначений;
		ВариантыОтвета.Добавить(КодВозвратаДиалога.Да,		НСтр("ru = 'Закрыть';
																	|en = 'Close'"));
		ВариантыОтвета.Добавить(КодВозвратаДиалога.Отмена,	НСтр("ru = 'Отмена';
																	|en = 'Cancel'"));
		
		ПоказатьВопрос(Новый ОписаниеОповещения("ВопросСохраненияЗавершение", ЭтотОбъект, ОписаниеОбработчика),
								НСтр("ru = 'При закрытии изменения будут потеряны';
									|en = 'Changes will be lost on close'"), ВариантыОтвета, , КодВозвратаДиалога.Отмена,
								ИТК_РедакторПараметровСеансаКлиентСервер.Представление());
		
	Иначе 
		
		ВыполнитьОбработкуОповещения(ОписаниеОбработчика);
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ВопросСохраненияЗавершение(Результат, ОписаниеОбработчика) Экспорт
	
	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ВыполнитьОбработкуОповещения(ОписаниеОбработчика);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработчикЗакрытиеРазрешеноЗакрыть(Результат, ДополнительныеПараметры) Экспорт
	
	ЗакрытиеРазрешено = Истина;
	Закрыть();
	
КонецПроцедуры

&НаКлиенте
Функция КоличествоИзменяемыхПараметровСеанса()
	
	Отбор = Новый Структура("Изменять", Истина);
	НайденныеСтроки = ЗначенияПараметровСеанса.НайтиСтроки(Отбор);
	
	Возврат НайденныеСтроки.Количество();
	
КонецФункции

#КонецОбласти
