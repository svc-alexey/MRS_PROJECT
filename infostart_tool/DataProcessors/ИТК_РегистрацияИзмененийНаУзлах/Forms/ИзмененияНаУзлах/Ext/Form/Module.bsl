#Область ОписаниеПеременных

&НаКлиенте
Перем ДлительнаяОперацияИдетВыполнение;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ПроверятьОграниченияМиграцииДанныхБСП = Истина;
	
	ВидИзменения = ВидИзмененияЗарегистрировать();
	Объекты.ЗагрузитьЗначения(Параметры.Ссылки);
	
	ИнициализацияДереваУзлов();
	
	ОбновитьЭлементыФормыПриСозданииНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ДлительнаяОперацияИдетВыполнение = Ложь;
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВидИзмененияПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДеревоУзлов

&НаКлиенте
Процедура ДеревоУзловПометкаПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ДеревоУзлов.ТекущиеДанные;
	
	Пометка = ИТК_ФормаКлиент.ОпределитьПометкуТриСостояния(ТекущиеДанные);
	
	ИТК_ФормаКлиент.ДеревоУстановитьПодчиненнымПометку(ТекущиеДанные, Пометка);
	ИТК_ФормаКлиент.ДеревоОпределитьПометкуРодителя(ТекущиеДанные, Пометка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Зарегистрировать(Команда)
	ВыполнитьИзменение();
КонецПроцедуры

&НаКлиенте
Процедура СнятьСРегистрации(Команда)
	ВыполнитьИзменение();
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьУдаление(Команда)
	ВыполнитьИзменение();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ОбновитьЭлементыФормыПриСозданииНаСервере()
	
	СписокВыбораВидаИзменения = Элементы.ВидИзменения.СписокВыбора;
	СписокВыбораВидаИзменения.Добавить(ВидИзмененияЗарегистрировать(), НСтр("ru = 'Зарегистрировать'; en = 'Register'"));
	СписокВыбораВидаИзменения.Добавить(ВидИзмененияСнятьСРегистрации(), НСтр("ru = 'Снять с регистрации'; en = 'Deregister'"));
	//СписокВыбораВидаИзменения.Добавить(ВидИзмененияУдаление(), НСтр("ru = 'Отправить удаление'; en = 'Submit delete'"));
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	КнопкиВидаИзменения = Новый Соответствие;
	КнопкиВидаИзменения.Вставить(ВидИзмененияЗарегистрировать(), Элементы.ФормаЗарегистрировать);
	КнопкиВидаИзменения.Вставить(ВидИзмененияСнятьСРегистрации(), Элементы.ФормаСнятьСРегистрации);
	КнопкиВидаИзменения.Вставить(ВидИзмененияУдаление(), Элементы.ФормаОтправитьУдаление);
	
	Для Каждого КлючИЗначение Из КнопкиВидаИзменения Цикл 
		
		ЭлементКнопка = КлючИЗначение.Значение;
		ЭлементКнопка.Видимость = (ВидИзменения = КлючИЗначение.Ключ);
		ЭлементКнопка.КнопкаПоУмолчанию = (ВидИзменения = КлючИЗначение.Ключ);
		
	КонецЦикла;
	
	Элементы.ПроверятьОграниченияМиграцииДанныхБСП.Видимость = (ИТК_БСПКлиентСервер.ИспользуетсяБСП()
																	И ВидИзменения = ВидИзмененияЗарегистрировать());
	
	Элементы.НастройкиОперации.Доступность = НЕ ДлительнаяОперацияИдетВыполнение;
	Элементы.ПрогрессОперации.Видимость = ДлительнаяОперацияИдетВыполнение;
	
КонецПроцедуры

&НаСервере
Процедура ИнициализацияДереваУзлов()
	
	ПроверяемыеМетаданные = Новый Соответствие;
	Для Каждого ЭлементОбъект Из Объекты Цикл 
		
		ОбъектКИзменению = ЭлементОбъект.Значение;
		ПроверяемыеМетаданные.Вставить(ОбъектКИзменению.Метаданные(), Истина);
		
	КонецЦикла;
	
	ДоступныеУзлы = ИТК_РегистрацияИзмененийНаУзлах.ДоступныеУзлыПлановОбмена(ПроверяемыеМетаданные);
	ИТК_РегистрацияИзмененийНаУзлах.ИнициализацияДереваУзловНаФорме(ЭтотОбъект, "ДеревоУзлов", ДоступныеУзлы);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьИзменение()
	
	ВыбранныеУзлы = ВыбранныеУзлы();
	Если НЕ ЗначениеЗаполнено(ВыбранныеУзлы) Тогда
		
		ПоказатьПредупреждение( , НСтр("ru = 'Не выбрано ни оного узла. Необходимо выбрать узел(ы)'; en = 'No nodes selected. You must select node(s)'"));
		ТекущийЭлемент = Элементы.ДеревоУзлов;
		Возврат;
		
	КонецЕсли;
	
	ПараметрыИзменения = Новый Структура;
	ПараметрыИзменения.Вставить("ВидИзменения", ВидИзменения);
	ПараметрыИзменения.Вставить("ВыбранныеУзлы", ВыбранныеУзлы);
	ПараметрыИзменения.Вставить("Объекты", Объекты);
	ПараметрыИзменения.Вставить("ПроверятьОграниченияМиграцииДанныхБСП", ПроверятьОграниченияМиграцииДанныхБСП);
	
	ДлительнаяОперация = ВыполнитьИзменениеНаСервере(ПараметрыИзменения, УникальныйИдентификатор);
	
	ДлительнаяОперацияИдетВыполнение = Истина;
	ОбновитьЭлементыФормы();

	ОповещениеОПрогрессеВыполнения = Новый ОписаниеОповещения("ОбработкаПрогрессаВыполнения", ЭтотОбъект);
	ПараметрыОжидания = ИТК_ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект, ОповещениеОПрогрессеВыполнения);
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершеноИзменение", ЭтотОбъект, );
	ИТК_ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ВыполнитьИзменениеНаСервере(ПараметрыИзменения, УникальныйИдентификатор)
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_РегистрацияИзмененийНаУзлах.ВыполнитьИзменениеРегистрации", ПараметрыИзменения, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ЗавершеноИзменение(Результат, ДополнительныеПараметры) Экспорт
	
	ДлительнаяОперацияИдетВыполнение = Ложь;
	ДлительнаяОперация = Результат;
	ОбновитьЭлементыФормы();
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		Оповестить("ИзменениеРегистрацииОбменаДаннымиОбъекта");
		Закрыть();
		
	КонецЕсли;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаПрогрессаВыполнения(Результат, ДополнительныеПараметры) Экспорт
	
	ИТК_ДлительныеОперацииКлиент.ПодготовитьПрогрессВыполнения(Результат);
	
	Прогресс = Результат.Прогресс;
	Если ЗначениеЗаполнено(Прогресс) Тогда
		
		ПрогрессСостояние = Прогресс.Текст;
		ПрогрессИндикатор = Прогресс.Процент;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ВыбранныеУзлы()
	
	ВыбранныеУзлы = Новый Массив;
	Для Каждого СтрокаПлан Из ДеревоУзлов.ПолучитьЭлементы() Цикл 
		
		Если СтрокаПлан.Пометка = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого СтрокаУзел Из СтрокаПлан.ПолучитьЭлементы() Цикл 
			
			Если СтрокаУзел.Пометка <> 0 Тогда
				ВыбранныеУзлы.Добавить(СтрокаУзел.Ссылка);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ВыбранныеУзлы;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ВидИзмененияЗарегистрировать()
	Возврат "Зарегистрировать";
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ВидИзмененияСнятьСРегистрации()
	Возврат "СнятьСРегистрации";
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ВидИзмененияУдаление()
	Возврат "Удаление";
КонецФункции

#КонецОбласти
