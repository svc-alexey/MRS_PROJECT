#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ЭлементРодительКнопки", Элементы.ПользователиИБГруппаОтбор);
	ДополнительныеПараметры.Вставить("ГруппаКонтекстногоМеню", Элементы.ПользователиИБКонтекстноеМенюГруппаИзбранное);
	ДополнительныеПараметры.Вставить("ЭлементВставкиКолонкиПеред", Элементы.ПользователиИБПользователь);
	ИТК_Избранное.Инициализировать(ЭтотОбъект, "ПользователиИБ", ДополнительныеПараметры);
	
	ОтображатьОтключенных = Истина;
	ОтображатьНедействительныхВнешнихПользователей = Истина;
	ВидИнструмента = ИТК_Перечисления.ИнструментПользователи();
	
	НачальнаяСтраница = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "НачальнаяСтраница");
	Если ЗначениеЗаполнено(НачальнаяСтраница) Тогда
		Элементы.Страницы.ТекущаяСтраница = Элементы["Страница" + НачальнаяСтраница];
	КонецЕсли;
	
	ОбновитьЭлементыФормыПриСозданииНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИТК_ОбщийКлиент.ОбработчикПриОткрытии(Отказ);
	
	ИТК_ИзбранноеКлиент.ПриОткрытии(ЭтотОбъект, Элементы.ПользователиИБ);
	
	ОбновитьПользователей();
	ОбновитьВнешнихПользователей();

	Если Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаАктивныеПользователи Тогда
		ОбновитьАктивныхПользователейИБ();
	КонецЕсли;
	
	ПодключитьОбработчикОжидания("ПодключаемыйОбновлениеПользователей", 60);
	ПодключитьОбработчикОжидания("ПодключаемыйОбновлениеВнешнихПользователей", 120);
	ПодключитьОбработчикОжидания("ПодключаемыйОбновлениеАктивныхПользователей", 60);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ИТК_ПользовательИБ_Записан" Тогда
		ОбновитьПользователей();
	ИначеЕсли ИмяСобытия = "Запись_ВнешниеПользователи" Тогда
		ОбновитьВнешнихПользователей();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	
	ИТК_Избранное.ПриЗагрузкеДанныхИзНастроекНаСервере(ЭтотОбъект, Настройки);
	
КонецПроцедуры

&НаСервере
Процедура ПриСохраненииДанныхВНастройкахНаСервере(Настройки)
	
	ИТК_Избранное.ПриСохраненииДанныхВНастройкахНаСервере(ЭтотОбъект, Настройки);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	Если Не ЗначениеЗаполнено(КоличествоАктивныхПользователей) Тогда
		ОбновитьАктивныхПользователейИБ();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПользователиИБ

&НаКлиенте
Процедура ПользователиИБПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элементы.ПользователиИБ.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		
		ПользователиПоследнееВыделение = Неопределено;
		Возврат;

	КонецЕсли;          	
	
	ПользователиПоследнееВыделение = Новый Структура("Пользователь", ТекущиеДанные.Пользователь);
	
КонецПроцедуры

&НаКлиенте
Процедура ПользователиИБВыбор(Элемент, ИдентификаторВыбраннойСтроки, Поле, СтандартнаяОбработка)

	ВыбраннаяСтрока = ПользователиИБ.НайтиПоИдентификатору(ИдентификаторВыбраннойСтроки);
	
	Обработано = ИТК_ИзбранноеКлиент.ОбработкаВыборВКоллекции(ВидИнструмента, ЭтотОбъект,
						"ПользователиИБ", Поле, ВыбраннаяСтрока, "УникальныйИдентификатор");
	Если Обработано Тогда
		Возврат;	
	КонецЕсли;
	
	ИТК_ТуллкитКлиент.ОткрытьИнструмент(ИТК_Перечисления.ИнструментРедактированиеПользователяИБ(),
												ВыбраннаяСтрока.УникальныйИдентификатор, ЭтотОбъект);

КонецПроцедуры

#КонецОбласти

