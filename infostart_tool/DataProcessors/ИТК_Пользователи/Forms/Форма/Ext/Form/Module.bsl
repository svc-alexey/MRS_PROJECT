&НаКлиенте
Процедура ОбновитьПользователей()
	
	ДлительнаяОперация = ОбновитьПользователейНаСервере(УникальныйИдентификатор);
	
	ПараметрыОжидания = ИТК_ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершеноОбновлениеПользователей", ЭтотОбъект);
	ИТК_ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ОбновитьПользователейНаСервере(УникальныйИдентификатор)
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыПроцедуры = Новый Структура;
	
	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_Пользователи.ДанныеПользователей", ПараметрыПроцедуры, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ЗавершеноОбновлениеПользователей(Результат, ДополнительныеПараметры) Экспорт
	
	ДлительнаяОперация = Результат;
	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		ОбновитьПользователейНаФорме(Результат.АдресРезультата);
		ИТК_ФормаКлиент.ВосстановитьВыделениеТаблицы(ЭтотОбъект, "ПользователиИБ", ПользователиПоследнееВыделение);
		
	КонецЕсли;
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьПользователейНаФорме(АдресРезультата)
	
	Результат = ПолучитьИзВременногоХранилища(АдресРезультата);
	ЗначениеВРеквизитФормы(Результат, "ПользователиИБ");
	КоличествоПользователей = ПользователиИБ.Количество();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ОбновитьВнешнихПользователейНаСервере(УникальныйИдентификатор)
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыПроцедуры = Новый Структура;
	
	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_Пользователи.ДанныеВнешнихПользователей", ПараметрыПроцедуры, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ЗавершеноОбновлениеВнешнихПользователей(Результат, ДополнительныеПараметры) Экспорт
	
	ДлительнаяОперацияВнешниеПользователи = Результат;
	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		ОбновитьВнешнихПользователейНаФорме(Результат.АдресРезультата);
		ИТК_ФормаКлиент.ВосстановитьВыделениеТаблицы(ЭтотОбъект, "ВнешниеПользователи", ВнешниеПользователиПоследнееВыделение);
		
	КонецЕсли;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьВнешнихПользователейНаФорме(АдресРезультата)
	
	Результат = ПолучитьИзВременногоХранилища(АдресРезультата);
	ЗначениеВРеквизитФормы(Результат, "ВнешниеПользователи");
	КоличествоВнешнихПользователей = ВнешниеПользователи.Количество();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьАктивныхПользователейИБ()
	
	ДлительнаяОперацияАктивныеПользователи = ОбновитьАктивныхПользователейНаСервере(УникальныйИдентификатор);
	
	ПараметрыОжидания = ИТК_ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершеноОбновлениеАктивныхПользователей", ЭтотОбъект);
	ИТК_ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперацияАктивныеПользователи, ОповещениеОЗавершении, ПараметрыОжидания);
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ОбновитьАктивныхПользователейНаСервере(УникальныйИдентификатор)
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыПроцедуры = Новый Структура;
	
	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_Пользователи.ДанныеАктивныхПользователей", ПараметрыПроцедуры, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ЗавершеноОбновлениеАктивныхПользователей(Результат, ДополнительныеПараметры) Экспорт
	
	ДлительнаяОперацияАктивныеПользователи = Результат;
	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		ОбновитьАктивныхПользователейНаФорме(Результат.АдресРезультата);
		ИТК_ФормаКлиент.ВосстановитьВыделениеТаблицы(ЭтотОбъект, "АктивныеПользователи", АктивныеПользователиПоследнееВыделение);
		
	КонецЕсли;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьАктивныхПользователейНаФорме(АдресРезультата)
	
	Результат = ПолучитьИзВременногоХранилища(АдресРезультата);
	ЗначениеВРеквизитФормы(Результат, "АктивныеПользователи");
	КоличествоАктивныхПользователей = АктивныеПользователи.Количество();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	Оформление = Новый Структура("ЦветТекста", ИТК_ОбщийКлиентСервер.ЦветТекстаНедоступно());
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "ПользователиИБ", Оформление, "ПользователиИБ.Отключен", Истина);
	
	Оформление = Новый Структура("ЦветТекста", ИТК_ОбщийКлиентСервер.ЦветТекстаНедоступно());
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "ВнешниеПользователи", Оформление, "ВнешниеПользователи.Недействителен", Истина);

	Оформление = Новый Структура("Шрифт", ИТК_ОбщийКлиентСервер.ШрифтЖирный());
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "АктивныеПользователи", Оформление, "АктивныеПользователи.Конфигуратор", Истина);

КонецПроцедуры

&НаСервере
Процедура ОбновитьЭлементыФормыПриСозданииНаСервере()
	
	УстановитьУсловноеОформление();
	
	ИспользуютсяВнешниеПользователи = ИТК_БСП.ИспользуютсяВнешниеПользователи();
	Элементы.ГруппаВнешниеПользователи.Видимость = ИспользуютсяВнешниеПользователи;
	
	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.ПользователиИБ);
	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.ВнешниеПользователи);
	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.АктивныеПользователи);
	
	Элементы.ПользователиИБАдресЭлектроннойПочты.Видимость = ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.15");
	Элементы.ПользователиИБЗапрещеноВосстанавливатьПароль.Видимость = ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.15");
	
	Элементы.ПользователиИБАутентификацияOpenIDConnect.Видимость = ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.19");
	Элементы.ПользователиИБАутентификацияТокеномДоступа.Видимость = ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.21");
	
	ИспользуетсяБСП = ИТК_БСПКлиентСервер.ИспользуетсяБСП();
	Элементы.ПользователиИБПользователи_ОткрытьПользователяБСП.Видимость = ИспользуетсяБСП;
	Элементы.ПользователиИБКонтекстноеМенюПользователи_ОткрытьПользователяБСП.Видимость = ИспользуетсяБСП;
	Элементы.АктивныеПользователи_ОткрытьПользователяБСП.Видимость = ИспользуетсяБСП;
	Элементы.АктивныеПользователиКонтекстноеМеню_ОткрытьПользователяБСП.Видимость = ИспользуетсяБСП;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	ИТК_ДлительныеОперацииКлиент.ОбновитьЭлементыОтображенияСостояния(ДлительнаяОперация,
		Элементы.ПользователиИБ, Элементы.ИдетПолучениеПользователейТабличныйДокумент,
		НСтр("ru = 'Получение списка пользователей...';
					|en = 'Getting a list of users...'"));
	
	Элементы.ПользователиИБОтображатьОтключенных.Пометка = ОтображатьОтключенных;
	ОтборИспользуется = НЕ ОтображатьОтключенных;
	ИТК_ФормаКлиент.ДополнитьОтборСтрок(Элементы.ПользователиИБ, ОтборИспользуется, "Отключен", Ложь);
	
	ИТК_ДлительныеОперацииКлиент.ОбновитьЭлементыОтображенияСостояния(ДлительнаяОперацияВнешниеПользователи,
		Элементы.ВнешниеПользователи, Элементы.ИдетПолучениеВнешнихПользователейТабличныйДокумент,
		НСтр("ru = 'Получение списка внешних пользователей...';
					|en = 'Getting a list of external users...'"));
	
	Элементы.ВнешниеПользователиОтображатьНедействительныхВнешнихПользователей.Пометка = ОтображатьНедействительныхВнешнихПользователей;
	ОтборИспользуется = НЕ ОтображатьНедействительныхВнешнихПользователей;
	ИТК_ФормаКлиент.ДополнитьОтборСтрок(Элементы.ВнешниеПользователи, ОтборИспользуется, "Недействителен", Ложь);
	
	#Если ВебКлиент Тогда
		ДоступенЗапускПодПользователем = Ложь;
	#Иначе
		ДоступенЗапускПодПользователем = Истина;
	#КонецЕсли
	Элементы.ПользователиИБЗапуститьПодПользователем.Видимость = ДоступенЗапускПодПользователем;
	
	ИТК_ДлительныеОперацииКлиент.ОбновитьЭлементыОтображенияСостояния(ДлительнаяОперация,
		Элементы.АктивныеПользователи, Элементы.ИдетПолучениеАктивныхПользователейТабличныйДокумент,
		НСтр("ru = 'Получение списка активных пользователей...';
					|en = 'Getting a list of active users...'"));
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьПодПользователемУниверсальная(ТаблицаФормы, ЗапуститьПриОткрытии = Истина)

	// [ⒼⓋ] g.o.vasilyev@gmail.com №1061 28.03.2025 ++
	ТекущиеДанные = ТаблицаФормы.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	Если ТаблицаФормы = Элементы.ВнешниеПользователи Тогда
		ИмяПользователя 					= ИмяПользователяИБПоУникальномуИдентификатору(ТекущиеДанные.ИдентификаторПользователяИБ);
		УникальныйИдентификаторПользователя = ТекущиеДанные.ИдентификаторПользователяИБ;
	Иначе
		ИмяПользователя 					= ТекущиеДанные.Пользователь;
		УникальныйИдентификаторПользователя	= ТекущиеДанные.УникальныйИдентификатор;
	КонецЕсли;
	
	ОткрытьЗапускПодПользователем(ИмяПользователя, УникальныйИдентификаторПользователя, ЗапуститьПриОткрытии);
	// [ⒼⓋ] g.o.vasilyev@gmail.com №1061 28.03.2025 —-
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьЗапускПодПользователем(ИмяПользователя, УникальныйИдентификаторПользователя, ЗапуститьПриОткрытии)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ИмяПользователя", ИмяПользователя);
	ПараметрыФормы.Вставить("УникальныйИдентификаторПользователя", УникальныйИдентификаторПользователя);
	// [ⒼⓋ] g.o.vasilyev@gmail.com №1061 28.03.2025 ++
	ПараметрыФормы.Вставить("ЗапуститьПриОткрытии", ЗапуститьПриОткрытии);
	// [ⒼⓋ] g.o.vasilyev@gmail.com №1061 28.03.2025 —-
	
	ОткрытьФорму("Обработка.ИТК_Пользователи.Форма.ЗапускПодПользователем", ПараметрыФормы, ЭтотОбъект, , , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйОбновлениеПользователей()
	ОбновитьПользователей();
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйОбновлениеВнешнихПользователей()
	ОбновитьВнешнихПользователей();
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйОбновлениеАктивныхПользователей()
	ОбновитьАктивныхПользователейИБ();
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИмяПользователяИБПоУникальномуИдентификатору(УникальныйИдентификатор)
	
	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(УникальныйИдентификатор);
	Возврат ПользовательИБ.Имя;
	
КонецФункции

