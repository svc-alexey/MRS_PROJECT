
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	РежимВыбора = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "РежимВыбора", Ложь);
	Элементы[ИмяДинамическогоСписка()].РежимВыбора = РежимВыбора;
	
	Если ЗначениеЗаполнено(Параметры.ЗакрыватьПриВыборе) Тогда
		ЗакрыватьПриВыборе = Параметры.ЗакрыватьПриВыборе;
	КонецЕсли;
	
	ПараметрОбъект = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "Объект", "");
	Если ТипЗнч(ПараметрОбъект) = Тип("Строка") Тогда
		
		Таблица = ПараметрОбъект;
		
		Если Параметры.Свойство("Ключ") Тогда
			ТекущееЗначение = Параметры.Ключ;
		КонецЕсли;
		
	Иначе
		
		ТекущееЗначение = ПараметрОбъект;
		
		ОбъектМетаданных = ПараметрОбъект.Метаданные();
		Таблица = ИТК_Метаданные.ПолноеИмя(ОбъектМетаданных);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Таблица) Тогда
		ТаблицаПредставление = Таблица;
	Иначе
		ТаблицаПредставление = НСтр("ru = 'Выбрать';
									|en = 'Select'"); 		 
	КонецЕсли;
	
	ОбновитьРеквизитыЭлементыДинамическогоСписка();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	ИТК_ОбщийКлиент.ОбработчикПриОткрытии(Отказ);
	
	ОбновитьЭлементыФормы();
	
	// Активизация текущего значения
	Если ЗначениеЗаполнено(ТекущееЗначение) Тогда
		Элементы[ИмяДинамическогоСписка()].ТекущаяСтрока = ТекущееЗначение;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ТаблицаПредставлениеНажатие(Элемент, СтандартнаяОбработка)
	
	ДополнительныеПараметрыОповещения = Новый Структура;
	ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("ВыборТаблицыМетаданныхЗавершен", ЭтотОбъект, ДополнительныеПараметрыОповещения);
	
	ИТК_ФормаКлиент.ОткрытьРедактированиеТипаЗначения(ЭтотОбъект, Неопределено, ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборОбъектаМетаданных(),
														Таблица, ОписаниеОповещенияЗавершение, СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДинамическийСписок

&НаСервереБезКонтекста
Процедура ДинамическийСписокПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	Для Каждого КлючИЗначение Из Строки Цикл 
		
		ДанныеСтроки = КлючИЗначение.Значение.Данные;
		
		Ссылка = ИТК_ОбщийКлиентСервер.Свойство(ДанныеСтроки, "Ссылка");
		Если НЕ ЗначениеЗаполнено(Ссылка) Тогда
			Возврат;
		КонецЕсли;
		
		ПолноеИмяОбъектаМетаданных = Ссылка.Метаданные().ПолноеИмя();
		Если НЕ ИТК_Метаданные.ЭтоПеречисление(ПолноеИмяОбъектаМетаданных) Тогда
			Возврат;
		КонецЕсли;
		
		ДанныеСтроки.Имя = XMLСтрока(Ссылка);
		
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОткрытьНовоеОкно(Команда)
	
	ИТК_ФормаКлиент.ОткрытьНовую(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура Инструменты(Команда)
	
	ИТК_ГлобальноеМенюКлиент.Открыть();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()

	Элементы.НеобходимоВыбратьТип.Видимость = Не ЗначениеЗаполнено(Таблица);
	Элементы.ОтсутствуютДанныеДляОтображения.Видимость = ОтсутствуютДанныеДляОтображения;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьРеквизитыЭлементыДинамическогоСписка()

	ИмяСписка = ИмяДинамическогоСписка();
	ЭлементСписок = Элементы[ИмяСписка];
	ОбъектСписок = ЭтотОбъект[ИмяСписка];
	
	ИТК_Форма.УдалитьПодчиненныеЭлементы(ЭтотОбъект, ЭлементСписок);
	
	Если НЕ ЗначениеЗаполнено(Таблица) Тогда
		Возврат;
	КонецЕсли;
	
	ОбъектМетаданных = Метаданные.НайтиПоПолномуИмени(Таблица);
	Если ИТК_Метаданные.ЭтоПеречисление(ОбъектМетаданных) Тогда
		
		ОбъектСписок.ОсновнаяТаблица = Неопределено;
		ОбъектСписок.ПроизвольныйЗапрос = Истина;
		
		ШаблонЗапроса =
		"ВЫБРАТЬ
		|	Таблица.%1 КАК Ссылка,
		|	Таблица.%2 КАК Порядок,
		|	ВЫРАЗИТЬ("""" КАК СТРОКА(80)) КАК Имя
		|ИЗ
		|	%3 КАК Таблица
		|УПОРЯДОЧИТЬ ПО
		|	Порядок";
		ПолеСсылка = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Ссылка");
		ПолеПорядок = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Порядок");
		
		ОбъектСписок.ТекстЗапроса = СтрШаблон(ШаблонЗапроса, ПолеСсылка, ПолеПорядок, Таблица);
		
		ПоляСписка = Новый Массив;
		
		ОписаниеПоля = Новый Структура;
		ОписаниеПоля.Вставить("Имя", "Ссылка");
		ОписаниеПоля.Вставить("Представление", НСтр("ru = 'Представление'; en = 'Presentation'"));
		ОписаниеПоля.Вставить("ТипЗначения", Новый ОписаниеТипов);
		ПоляСписка.Добавить(ОписаниеПоля);
		
		ОписаниеПоля = Новый Структура;
		ОписаниеПоля.Вставить("Имя", "Имя");
		ОписаниеПоля.Вставить("Представление", НСтр("ru = 'Имя'; en = 'Name'"));
		ОписаниеПоля.Вставить("ТипЗначения", Новый ОписаниеТипов);
		ПоляСписка.Добавить(ОписаниеПоля);
		
		ОписаниеПоля = Новый Структура;
		ОписаниеПоля.Вставить("Имя", "Порядок");
		ОписаниеПоля.Вставить("Представление", НСтр("ru = 'Порядок'; en = 'Order'"));
		ОписаниеПоля.Вставить("ТипЗначения", Новый ОписаниеТипов);
		ПоляСписка.Добавить(ОписаниеПоля);
		
	Иначе
		
		// Устанавливаем параметры
		ОбъектСписок.ОсновнаяТаблица = Таблица;
		ОбъектСписок.ПроизвольныйЗапрос = Ложь;
		ОбъектСписок.ДинамическоеСчитываниеДанных = Истина;
		
		ЭлементСписок.ПутьКДаннымКартинкиСтроки = ИмяСписка + ".СтандартнаяКартинка";
		
		ПоляСписка = ИТК_ФормаСпискаУниверсальная.ПоляОбъектаМетаданных(ОбъектМетаданных);
		
	КонецЕсли;
	
	// Добавление колонок динамического списка
	ОтсутствуютДанныеДляОтображения = НЕ ЗначениеЗаполнено(ПоляСписка);
	Для Каждого Поле Из ПоляСписка Цикл 
		
		ИмяПоля = Поле.Имя;
		ТипЗначенияПоля = Поле.ТипЗначения;
		Если НЕ ИТК_Типы.РедактируетсяВТаблицеЗначений(ТипЗначенияПоля) Тогда 
			Продолжить;
		КонецЕсли;
		
		Попытка
			
			НоваяКолонка = Элементы.Добавить(ИмяСписка + ИмяПоля, Тип("ПолеФормы"), ЭлементСписок);
			НоваяКолонка.ПутьКДанным = ИмяСписка + "." + ИмяПоля;
			
			Если ИТК_ТипыКлиентСервер.Количество(ТипЗначенияПоля) = 1
				И ТипЗначенияПоля.СодержитТип(Тип("Булево")) Тогда
				
				ВидПоля = ВидПоляФормы.ПолеФлажка;
				
			Иначе
				ВидПоля = ВидПоляФормы.ПолеВвода;
			КонецЕсли;
			НоваяКолонка.Вид = ВидПоля;
			
			
			НоваяКолонка.Заголовок = Поле.Представление;
			
			Если ЗначениеЗаполнено(ТипЗначенияПоля) Тогда
				
				НоваяКолонка.КартинкаШапки = ИТК_Типы.КартинкаОписания(ТипЗначенияПоля);
				НоваяКолонка.Подсказка = ИТК_Типы.ПодсказкаОписания(ИмяПоля, ТипЗначенияПоля)
				
			КонецЕсли;
			
		Исключение
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборТаблицыМетаданныхЗавершен(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Таблица = Результат;
	ТаблицаПредставление = Результат;
	
	ОбновитьРеквизитыЭлементыДинамическогоСписка();
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ИмяДинамическогоСписка()
	
	Возврат "ДинамическийСписок";
	
КонецФункции

&НаКлиенте
Процедура ДинамическийСписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)

	ЭлементСписок = Элементы[ИмяДинамическогоСписка()];
	Если ЭлементСписок.РежимВыбора Тогда
		
		СтандартнаяОбработка = Ложь;
		ОповеститьОВыборе(ЭлементСписок.ТекущаяСтрока);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
