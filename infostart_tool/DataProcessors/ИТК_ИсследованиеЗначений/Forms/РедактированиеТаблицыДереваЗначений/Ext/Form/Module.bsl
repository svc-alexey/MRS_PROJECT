#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЗаголовокФормы = Параметры.Заголовок;
	Если ЗначениеЗаполнено(ЗаголовокФормы) Тогда
		Заголовок = ЗаголовокФормы;
	КонецЕсли;
	
	Редактирование = Параметры.Редактирование;
	
	ПереданноеЗначение = ПолучитьИзВременногоХранилища(Параметры.Значение);
	Значение = ИТК_ИсследованиеЗначенийСервер.ИзвлечениеПереданногоЗначения(ПереданноеЗначение);
	
	ОбновитьДанныеКоллекцияЗначений(Значение);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ОбновитьДанныеКоллекцияЗначений(Коллекция)
	
	ЭтоКоллекцияТаблицаЗначений = (ТипЗнч(Коллекция) = Тип("ТаблицаЗначений"));
	
	// Добавление колонок
	Для Каждого Колонка Из Коллекция.Колонки Цикл 
		
		НоваяКолонка = Колонки.Добавить();
		НоваяКолонка.Имя = Колонка.Имя;
		НоваяКолонка.Тип = Колонка.ТипЗначения;
		
		Если ЭтоКоллекцияТаблицаЗначений Тогда
			НоваяКолонка.Индексировать = ИТК_ТаблицаЗначений.ИндексируетсяКолонка(Коллекция, Колонка.Имя);
		КонецЕсли;
		
		Если ЭтоКоллекцияТаблицаЗначений Тогда
			ИмяКоллекции = "ТаблицаЗначений";
		Иначе
			ИмяКоллекции = "ДеревоЗначений";
		КонецЕсли;
		ИТК_Форма.ДобавитьКолонкуВТаблицуЗначений(ЭтотОбъект, Колонка.Имя, Колонка.ТипЗначения, ИмяКоллекции);
		
	КонецЦикла;
	
	Если ЭтоКоллекцияТаблицаЗначений Тогда
		ТаблицаЗначений.Загрузить(Коллекция);
	Иначе
		ЗначениеВРеквизитФормы(Коллекция, "ДеревоЗначений");
	КонецЕсли;
	
	КоличествоКолонок = Коллекция.Колонки.Количество();
	
КонецПроцедуры

#КонецОбласти