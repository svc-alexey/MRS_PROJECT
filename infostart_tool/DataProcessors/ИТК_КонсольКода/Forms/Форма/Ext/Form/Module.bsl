&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИТК_ИсследованиеЗначенийСервер.УстановитьУсловноеОформление(ЭтотОбъект, "РезультатПеременные");
	
	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.ПараметрыКода);
	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.РезультатСообщения);
	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.РезультатПеременные);
	
	СписокВыбора = Элементы.Контекст.СписокВыбора;
	СписокВыбора.Добавить(ИТК_КонсольКодаКлиентСервер.КонтекстКлиент(), НСтр("ru = 'Клиент'; en = 'Client'"));
	СписокВыбора.Добавить(ИТК_КонсольКодаКлиентСервер.КонтекстСервер(), НСтр("ru = 'Сервер'; en = 'Server'"));
	
	ОтображатьДеревоДанных = Истина;
	
	ДополнительныеСвойства = Новый Структура;
	ШаблонПодсказки = НСтр("ru = '%1.<Имя> - Использование значений параметров (только чтение)';
							|en = '%1.<Name> - Using parameter values (read only)'");
	Подсказака = СтрШаблон(ШаблонПодсказки, ИТК_КонсольКодаКлиентСервер.ИдентификаторПараметры());
	ДополнительныеСвойства.Вставить("Подсказка", Подсказака);
	
	ИТК_РедакторКода.Инициализация(ЭтотОбъект, "Код", ДополнительныеСвойства);
	
	ИТК_Консоли.ПриСозданииНаСервере(ЭтотОбъект, ИТК_Перечисления.ИнструментКонсольКода());
	
	ИТК_ПодключаемыеКоманды.ИнструментыКТаблицеЗначений(ЭтотОбъект, "РезультатПеременные");
	
	ИТК_ИнтеграцияOneDebugger.ПриСозданииНаСервере(ЭтотОбъект, "Код");
	
КонецПроцедуры

