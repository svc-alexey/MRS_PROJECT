&НаКлиенте
Функция ИТК_ИсследованиеЗначений_Контекст() Экспорт
	
	Возврат ИТК_КонсолиКлиентСервер.ПолеРезультатаВыполнения(ЭтотОбъект, "Контекст");
	
КонецФункции

&НаСервере
Функция ИТК_ИсследованиеЗначенийОсновноеЗначение(Строка) Экспорт
	
	КонтекстРезультата = ИТК_КонсолиКлиентСервер.ПолеРезультатаВыполнения(ЭтотОбъект, "Контекст");
	РезультатДанные = ИТК_КонсолиКлиентСервер.ПолеРезультатаВыполнения(ЭтотОбъект, "Результат");
	
	ОписаниеПеременных = ПолучитьИзВременногоХранилища(РезультатДанные);
	КорневаяСтрока = ИТК_ФормаКлиентСервер.ОсновнойРодительСтрокиДерева(Строка);
	
	Результат = ЗначениеПеременнойОписания(ОписаниеПеременных, КорневаяСтрока.Имя);
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ИТК_ИсследованиеЗначенийОсновноеЗначениеКлиент(Строка) Экспорт
	
	КорневаяСтрока = ИТК_ФормаКлиентСервер.ОсновнойРодительСтрокиДерева(Строка);
	Возврат ЗначениеПеременнойОписания(РезультатВыполненияКлиент, КорневаяСтрока.Имя);
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЗначениеПеременнойОписания(ОписаниеПеременных, Имя)
	
	НайденныеЭлемент = ИТК_ОбщийКлиентСервер.СписокЗначенийНайтиПоПредставлению(ОписаниеПеременных, Имя);
	Возврат НайденныеЭлемент.Значение;
	
КонецФункции

&НаКлиенте
Процедура ИзмененКодВТекущейСтроке(НовыйКод) Экспорт
	
 	ИТК_КонсолиКлиент.РаботаСДаннымиИзменитьПоле(ЭтотОбъект, ДеревоДанныхТекущиеДанные, "Текст", НовыйКод);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьРезультатВыполнения(Результат)
	
	РезультатСообщения.Очистить();
	РезультатПеременные.ПолучитьЭлементы().Очистить();
	
	// Обновить результат выполнения
	Если ЭтоАдресВременногоХранилища(Результат) Тогда
		ДанныеРезультатата = ОбновитьРезультатВыполненияНаСервере(Результат);
	Иначе
		ДанныеРезультатата = ОбновитьРезультатВыполненияНаКлиенте(Результат);
	КонецЕсли;
	
	ВремяВыполнения = Результат.Время;
	
	// Очистка данных предыдущего результата
	Если ИТК_КонсолиКлиентСервер.ПолеРезультатаВыполнения(ЭтотОбъект, "Контекст") = ИТК_КонсольКодаКлиентСервер.КонтекстСервер() Тогда
		
		АдресПредыдущегоРезультата = ИТК_КонсолиКлиентСервер.ПолеРезультатаВыполнения(ЭтотОбъект, "Результат");
		ИТК_ВременноеХранилище.Удалить(АдресПредыдущегоРезультата);
		
	КонецЕсли;
	
	// Заполнение нового результата
	НовыйРезультатВыполнения = Новый Структура;
	НовыйРезультатВыполнения.Вставить("Строка", Результат.УникальныйИдентификатор);
	НовыйРезультатВыполнения.Вставить("Контекст", Результат.Контекст);
	
	Если Результат.Контекст = ИТК_КонсольКодаКлиентСервер.КонтекстКлиент() Тогда
		РезультатВыполненияКлиент = ДанныеРезультатата;
	Иначе
		НовыйРезультатВыполнения.Вставить("Результат", ДанныеРезультатата);
	КонецЕсли;
	ИТК_КонсолиКлиентСервер.УстановитьРезультатВыполнения(ЭтотОбъект, НовыйРезультатВыполнения);
	
	// Переменные
	ЗаголовокСтраницы = ИТК_ФормаКлиентСервер.ЗаголовокСКоличеством(НСтр("ru = 'Переменные'; en = 'Values'"), РезультатПеременные.ПолучитьЭлементы().Количество());
	Элементы.СтраницаРезультатПеременные.Заголовок = ЗаголовокСтраницы;
	
	// Сообщения
	ЗаголовокСтраницы = ИТК_ФормаКлиентСервер.ЗаголовокСКоличеством(НСтр("ru = 'Сообщения'; en = 'Messages'"), РезультатСообщения.Количество());
	Элементы.СтраницаРезультатСообщения.Заголовок = ЗаголовокСтраницы;
	
	// Активная страница результата выполенения
	ТекущаяСтраницаРезультат = Неопределено;
	Если ЗначениеЗаполнено(РезультатСообщения)
			И НЕ ЗначениеЗаполнено(РезультатПеременные.ПолучитьЭлементы()) Тогда
		ТекущаяСтраницаРезультат = Элементы.СтраницаРезультатСообщения;
	ИначеЕсли НЕ ЗначениеЗаполнено(РезультатСообщения) Тогда
		ТекущаяСтраницаРезультат = Элементы.СтраницаРезультатПеременные;
	КонецЕсли;
	
	Если ТекущаяСтраницаРезультат <> Неопределено Тогда
		Элементы.ПанельРезультатаСтраницы.ТекущаяСтраница = ТекущаяСтраницаРезультат;
	КонецЕсли;
	
	ЗаполнитьПоказатьОшибку(Результат);
	ОбновитьИспользуемыеПеременные();
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаСервере
Функция ОбновитьРезультатВыполненияНаСервере(Результат)
	
	Результат = ПолучитьИзВременногоХранилища(Результат);
	
	// Переменные
	Для Каждого Переменная Из Результат.Переменные Цикл 
		
		НоваяСтрока = РезультатПеременные.ПолучитьЭлементы().Добавить();
		ИТК_ИсследованиеЗначенийКлиентСервер.ЗаполнениеСтрокиНаФорме(НоваяСтрока, Переменная.Представление, Переменная.Значение)
		
	КонецЦикла;
	
	// Сообщения
	НомерСтроки = 1;
	Для Каждого СообщениеПользователю Из Результат.Сообщения Цикл 
		
		НоваяСтрока = РезультатСообщения.Добавить();
		НоваяСтрока.НомерСтроки = НомерСтроки;
		
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СообщениеПользователю);
		
		НомерСтроки = НомерСтроки + 1;
		
	КонецЦикла;
	
	ДанныеРезультата = ПоместитьВоВременноеХранилище(Результат.Переменные, УникальныйИдентификатор);
	
	Результат.Удалить("Сообщения");
	Результат.Удалить("Переменные");
	
	Возврат ДанныеРезультата;
	
КонецФункции

&НаКлиенте
Функция ОбновитьРезультатВыполненияНаКлиенте(Результат)
	
	// Переменные
	Для Каждого Переменная Из Результат.Переменные Цикл 
		
		НоваяСтрока = РезультатПеременные.ПолучитьЭлементы().Добавить();
		ИТК_ИсследованиеЗначенийКлиентСервер.ЗаполнениеСтрокиНаФорме(НоваяСтрока, Переменная.Представление, Переменная.Значение)
		
	КонецЦикла;
	
	Возврат Результат.Переменные;
	
КонецФункции

&НаКлиенте
Процедура ОбновитьИспользуемыеПеременные()
	
	УникальныйИдентификаторСтрокиДерева = Неопределено;
	Если ДеревоДанныхТекущиеДанные <> Неопределено Тогда
		УникальныйИдентификаторСтрокиДерева = ДеревоДанныхТекущиеДанные.УникальныйИдентификатор;
	КонецЕсли;
	
	ПодсказкиИспользуемыхПеременных = Новый Соответствие;
	Если ИТК_КонсолиКлиентСервер.ПолеРезультатаВыполнения(ЭтотОбъект, "Строка") = УникальныйИдентификаторСтрокиДерева Тогда 
		
		Для Каждого Переменная Из РезультатПеременные.ПолучитьЭлементы() Цикл 
			
			Представление = Переменная.Представление;
			Если ЗначениеЗаполнено(Переменная.ПредставлениеГиперссылки) Тогда
				Представление = Переменная.ПредставлениеГиперссылки;
			КонецЕсли;
			ПодсказкаПеременной = ИТК_РедакторКодаКлиентСервер.ПодсказкаИспользуемойПеременной(Переменная.Имя,
																Представление, Переменная.ПредставлениеТипа);
			ПодсказкиИспользуемыхПеременных.Вставить(Переменная.Имя, ПодсказкаПеременной);
			
		КонецЦикла;
		
	КонецЕсли;
	
	ИТК_РедакторКодаКлиент.ОбновитьПодсказкиИспользуемыхПеременных(Элементы.Код, ПодсказкиИспользуемыхПеременных);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоказатьОшибку(Результат)
	
	Строка = ИТК_КонсолиКлиент.НайтиСтрокуДереваДанных(ДеревоДанных, Результат.УникальныйИдентификатор);
	Если Строка = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеСтроки = ИТК_КонсолиКлиентСервер.РаботаСДаннымиДанныеСтроки(Строка);
	ДанныеСтроки.Ошибка = Результат.Ошибка;
	
	Если ЗначениеЗаполнено(Результат.Ошибка) Тогда
		ПоказатьОшибку();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЭлементыОшибки()
	
	Ошибка = ОшибкаПоСтроке(ДеревоДанныхТекущиеДанные);
	
	ПрисутствуютОшибки = (Ошибка <> Неопределено);
	Элементы.ГруппаОшибка.Видимость = ПрисутствуютОшибки;
	
	Если НЕ ПрисутствуютОшибки Тогда
		Возврат;
	КонецЕсли;
	
	Элементы.ПодробнееПоОшибке.Видимость = ЗначениеЗаполнено(Ошибка.СтекВызовов);
	Элементы.ОшибкаТекст.Заголовок = ИТК_КодКлиентСервер.ПредставлениеОшибки(Ошибка);
	
КонецПроцедуры

&НаКлиенте
Функция ОшибкаПоСтроке(Строка)
	
	Если Строка = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если Строка.Тип <> ИТК_Перечисления.ЭлементДанныхКод() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДанныеСтроки = ИТК_КонсолиКлиентСервер.РаботаСДаннымиДанныеСтроки(Строка);
	Возврат ДанныеСтроки.Ошибка;
	
КонецФункции

&НаКлиенте
Процедура ПоказатьОшибку(Нажатие = Ложь)
	
	ДанныеСтроки = ИТК_КонсолиКлиентСервер.РаботаСДаннымиДанныеСтроки(ДеревоДанныхТекущиеДанные);
	
	ЭлементТекст = Элементы.Код;
	Ошибка = ДанныеСтроки.Ошибка;

	ПоказатьОшибкуВКоде(ЭлементТекст, Ошибка, Нажатие);
	ТекущийЭлемент = ЭлементТекст;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьОшибкуПослеОжидания()
	
	ПодключитьОбработчикОжидания("ПодключаемыйПоказатьОшибку", 0.1, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйПоказатьОшибку()
	
	ПоказатьОшибку();
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьОшибкуВКоде(ЭлементТекст, Ошибка, Нажатие = Ложь)
	
	ОписаниеОшибки = Ошибка.ОписаниеОшибки;
	
	Если ЗначениеЗаполнено(ОписаниеОшибки.ИмяМодуля) Тогда
		
		ТекущийЭлемент = ЭлементТекст;
		
		Если Нажатие Тогда
			ИТК_РедакторКодаКлиент.ОткрытьКодМодуля(ОписаниеОшибки.ИмяМодуля, ОписаниеОшибки.НомерСтроки);
		КонецЕсли;
		
	Иначе
		
		ИТК_РедакторКодаКлиент.ПоказатьОшибку(ЭлементТекст, ОписаниеОшибки.НомерСтроки);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьВыполнениеНаСервере(Код, Параметры, Строка)
	
	ИдетВыполнение = Истина;
	
	ДлительнаяОперация = ВыполнениеНаСервере(УникальныйИдентификатор, Код, Параметры, Строка);
	
	ПараметрыОжидания = ИТК_ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершеноВыполнениеНаСервере", ЭтотОбъект);
	ИТК_ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаСервереБезКонтекста
Функция ВыполнениеНаСервере(УникальныйИдентификатор, Код, Параметры, Строка)
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор, Ложь);
	
	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("Код", Код);
	ПараметрыПроцедуры.Вставить("Параметры", Параметры);
	ПараметрыПроцедуры.Вставить("Строка", Строка);
	
	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_КонсольКода.Исполнить", ПараметрыПроцедуры, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ЗавершеноВыполнениеНаСервере(Результат, ДополнительныеПараметры) Экспорт
	
	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);

	Если Результат.Статус = "Выполнено" Тогда
		ОбновитьРезультатВыполнения(Результат.АдресРезультата);
	КонецЕсли;

	ИдетВыполнение = Ложь;
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаКлиенте
Процедура ВыборТипаПараметраЗавершен(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИТК_КонсолиКлиентСервер.УстановитьМодифицированностьДанных(ЭтотОбъект);
	
	Если Результат.СодержитТип(Тип("Массив")) Тогда
		Результат = ИТК_ТипыКлиентСервер.ОписаниеИзСтроки("СписокЗначений");
	КонецЕсли;
	
	УстановитьНовоеЗначениеИзмененногоПараметра(ДополнительныеПараметры.Имя, Результат.ПривестиЗначение(Неопределено));
	ПараметрыКодаПриАктивизацииСтроки(Элементы.ПараметрыКода);

КонецПроцедуры

&НаКлиенте
Процедура РедактированиеЗначенияПараметраСписокЗавершено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьНовоеЗначениеИзмененногоПараметра(ДополнительныеПараметры.Имя, Результат);
	ПараметрыКодаПриАктивизацииСтроки(Элементы.ПараметрыКода);

КонецПроцедуры

&НаКлиенте
Процедура УстановитьНовоеЗначениеИзмененногоПараметра(Имя, Значение)
	
	Модифицированность = Истина;
	
	ТекущиеДанные = Элементы.ПараметрыКода.ТекущиеДанные;
	ТекущиеДанные.Значение = Значение;
	
	ДанныеСтроки = ИТК_КонсолиКлиентСервер.РаботаСДаннымиДанныеСтроки(ДеревоДанныхТекущиеДанные);
	ДанныеСтроки.Параметры.Вставить(Имя, Значение);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьПользовательскиеОбъектыКода()

	Если ИТК_РедакторКодаКлиент.ТребуетсяИнициализация(Элементы.Код) Тогда
		Возврат;
	КонецЕсли;
	
	Если ДеревоДанныхТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеСтроки = ИТК_КонсолиКлиентСервер.РаботаСДаннымиДанныеСтроки(ДеревоДанныхТекущиеДанные);
	
	ПользовательскиеОбъекты = ПользовательскиеОбъектыРедактораКода(ДанныеСтроки.Параметры);
	ИТК_РедакторКодаКлиент.ЗагрузитьПользовательскиеОбъекты(Элементы.Код, ПользовательскиеОбъекты);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПользовательскиеОбъектыРедактораКода(Параметры)
	
	Результат = ИТК_РедакторКода.НовыеПользовательскиеОбъекты();
	Кэш = ИТК_РедакторКода.КэшТиповПользовательскихОбъектов();
	
	ПараметрыКода = Новый Структура;
	Для Каждого Параметр Из Параметры Цикл 
		
		ОписаниеТипов = ИТК_ТипыКлиентСервер.ОписаниеТиповПоТипу(ТипЗнч(Параметр.Значение));

		Если ОписаниеТипов.СодержитТип(Тип("СписокЗначений")) Тогда
			
			ОписаниеПараметра = Новый Структура;
			ОписаниеПараметра.Вставить("Тип", Новый ОписаниеТипов("Массив"));
			
			ТипыЭлементов = Новый Массив;
			Для Каждого ЭлементСписка Из Параметр.Значение Цикл 
				ТипыЭлементов.Добавить(ТипЗнч(ЭлементСписка.Значение));
			КонецЦикла;
			
			ОписаниеПараметра.Вставить("ТипЭлементов", Новый ОписаниеТипов(ТипыЭлементов));
			
		Иначе
			ОписаниеПараметра = ОписаниеТипов;
		КонецЕсли;
		
		ПараметрыКода.Вставить(Параметр.Ключ, ОписаниеПараметра);
		
	КонецЦикла;
	
	ОписаниеОбъектаПараметры = ИТК_РедакторКода.ОписаниеПользовательскогоОбъекта(Кэш, , ПараметрыКода);

	ИдентификаторПараметры = ИТК_КонсольКодаКлиентСервер.ИдентификаторПараметры();
	ИТК_РедакторКода.ДобавитьПользовательскийОбъект(Результат, ИдентификаторПараметры, ОписаниеОбъектаПараметры);
	
	ИдентификаторПараметрыEN = ИТК_КонсольКодаКлиентСервер.ИдентификаторПараметры("en");
	ИТК_РедакторКода.ДобавитьПользовательскийОбъект(Результат, ИдентификаторПараметрыEN, ОписаниеОбъектаПараметры);
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ОбновитьДанныеСтрокиНаФорме()
	
	ТекстКода = "";
	Если ДеревоДанныхТекущиеДанные <> Неопределено Тогда
		
		ДанныеСтроки = ИТК_КонсолиКлиентСервер.РаботаСДаннымиДанныеСтроки(ДеревоДанныхТекущиеДанные);
		Контекст = ИТК_ОбщийКлиентСервер.Свойство(ДанныеСтроки, "Контекст");

		Если ИТК_КонсолиКлиентСервер.ЭтоТипСтрокиДереваДанныхСИспользованиемТекста(ДеревоДанныхТекущиеДанные.Тип) Тогда
			ТекстКода = ДанныеСтроки.Текст;
		КонецЕсли;
		
		Если ДанныеСтроки.Свойство("Параметры") Тогда
			
			ПараметрыКода.ПолучитьЭлементы().Очистить();
			
			Для Каждого Параметр Из ДанныеСтроки.Параметры Цикл 
				
				НоваяСтрока = ПараметрыКода.ПолучитьЭлементы().Добавить();
				НоваяСтрока.Имя = Параметр.Ключ;
				НоваяСтрока.Значение = Параметр.Значение;
				
			КонецЦикла;
			
			ИТК_ФормаКлиент.СортироватьСтрокиДерева(ПараметрыКода.ПолучитьЭлементы(), "Имя");
			
			ЗагрузитьПользовательскиеОбъектыКода();
			
		КонецЕсли;

	КонецЕсли;
	
	ИТК_РедакторКодаКлиент.УстановитьТекст(ЭтотОбъект, Элементы.Код, ТекстКода);
	ОбновитьИспользуемыеПеременные();
	
КонецФункции

&НаКлиенте
Функция ЗавершениеСтандартногоОбрабочикаРаботыСДанными(Имя, ДополнительныеПараметры) Экспорт
	
	Если СтрНайти(Имя, "Новый") Тогда
		ТекущийЭлемент = Элементы.Код;
	КонецЕсли;

КонецФункции

&НаКлиенте
Функция ПроблемыСравнения(ВыделенныеСтроки)

	// Определим есть ли строки группы и не выделены разные типы строк
	ЕстьСтрокаГруппа = Ложь; НесовместимыеТипыСтрок = Ложь; ПоследнийТипСтроки = Неопределено;
	Для Каждого ИдентификаторВыделеннойСтроки Из ВыделенныеСтроки Цикл 
		
		ВыделеннаяСтрока = ДеревоДанных.НайтиПоИдентификатору(ИдентификаторВыделеннойСтроки);

		Если ВыделеннаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхГруппа() Тогда
			ЕстьСтрокаГруппа = Истина;
		КонецЕсли;
		
		Если ПоследнийТипСтроки <> Неопределено Тогда 
			
			Если ПоследнийТипСтроки <> ВыделеннаяСтрока.Тип	Тогда
				НесовместимыеТипыСтрок = Истина;
			КонецЕсли;
			
		КонецЕсли;
			
		ПоследнийТипСтроки = ВыделеннаяСтрока.Тип;
		
	КонецЦикла;
	
	Результат = Новый Массив;

	Если ЕстьСтрокаГруппа Тогда
		Результат.Добавить(НСтр("ru = 'Нельзя выбирать группы';
									|en = 'You cannot select groups'"));
	КонецЕсли;
	
	Если ВыделенныеСтроки.Количество() > 2 Тогда
		Результат.Добавить(НСтр("ru = 'Необходимо выделить не более 2-х строк';
									|en = 'It is necessary to select no more than 2 lines'"));
	КонецЕсли;
	
	Если НесовместимыеТипыСтрок Тогда
		Результат.Добавить(НСтр("ru = 'Несовместимые типы строк';
									|en = 'Incompatible string types'"));
	КонецЕсли;
	
	Если ВыделенныеСтроки.Количество() = 0 Тогда
		Результат.Добавить(НСтр("ru = 'Нет выделенных строк';
									|en = 'No rows selected'"));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ОткрытьФормуСравнения(СтрокаЭталон, ДополнительныеПараметры)

	Если Не ИТК_ФормаКлиент.ВозможенЗапускСравненияПредупреждение() Тогда
		Возврат;
	КонецЕсли;
	
	ТипОбъектов = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "ТипОбъектов", Неопределено);
	ТипСравнения = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "ТипСравнения", Неопределено);
	НеизменяемыеПоля = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "НеизменяемыеПоля", Новый Структура);
	СтрокаНовый = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "СтрокаНовый", Неопределено);
	
	ПараметрыФормы = Новый Структура;
	
	// Список элементов код
	СписокКод = Новый СписокЗначений;
	
	ТипыСтрокКода = Новый Массив;
	ТипыСтрокКода.Добавить(ИТК_Перечисления.ЭлементДанныхКод());
	
	ПодготовитьДанныеДляСравнения(ДеревоДанных, СписокКод, ТипыСтрокКода);
	ПараметрыФормы.Вставить("СписокКод", СписокКод);
	
	ПараметрыФормы.Вставить("СписокЗапросов", Новый СписокЗначений);
	ПараметрыФормы.Вставить("СписокСхемКомпоновкиДанных", Новый СписокЗначений);

	Если СтрокаЭталон <> Неопределено Тогда
		ПараметрыФормы.Вставить("ОбъектЭталон", СтрокаЭталон.УникальныйИдентификатор);
	КонецЕсли;
	Если СтрокаНовый <> Неопределено Тогда
		ПараметрыФормы.Вставить("ОбъектНовый", СтрокаНовый.УникальныйИдентификатор);
	КонецЕсли;

	НедостаточноДанных = Ложь;
	МинимальноеКоличествоОбъектовСравнения = 2;
	Если СписокКод.Количество() < МинимальноеКоличествоОбъектовСравнения Тогда
		НедостаточноДанных = Истина;
	КонецЕсли;
		
	ТипОбъектов = СтрокаЭталон.Тип;
	НеизменяемыеПоля.Вставить("ТипОбъектов");
	Если ТипОбъектов = ИТК_Перечисления.ЭлементДанныхКод() Тогда
		НеизменяемыеПоля.Вставить("ТипСравнения");
	КонецЕсли;

	ПараметрыФормы.Вставить("ТипОбъектов", ТипОбъектов);
	ПараметрыФормы.Вставить("ТипСравнения", ТипСравнения);
	ПараметрыФормы.Вставить("НеизменяемыеПоля", НеизменяемыеПоля);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("НастройкаСравненияЗавершена", ЭтотОбъект);
	ОткрытьФорму("Обработка.ИТК_КонсольРазработчика.Форма.НастройкаСравнения", ПараметрыФормы, ЭтотОбъект, , , , ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаСравненияЗавершена(ПараметрыСравнения, ДополнительныеПараметры) Экспорт
	
	Если ПараметрыСравнения = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ИТК_ФормаКлиент.ВозможенЗапускСравненияПредупреждение(ПараметрыСравнения.ТипСравнения) Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаЭталон = ИТК_КонсолиКлиент.НайтиСтрокуДереваДанных(ДеревоДанных, ПараметрыСравнения.ОбъектЭталон);
	ДанныеЭталон = ИТК_КонсолиКлиентСервер.РаботаСДаннымиДанныеСтроки(СтрокаЭталон);
	
	СтрокаНовый = ИТК_КонсолиКлиент.НайтиСтрокуДереваДанных(ДеревоДанных, ПараметрыСравнения.ОбъектНовый);
	ДанныеНовый = ИТК_КонсолиКлиентСервер.РаботаСДаннымиДанныеСтроки(СтрокаНовый);
	
	ТипЯзыка = ИТК_Перечисления.ТипЯзыкаРедактораВстроенный();
	ИТК_ФормаКлиент.ОткрытьСравнениеТекстов(ЭтотОбъект, ДанныеЭталон.Текст, ДанныеНовый.Текст, ТипЯзыка);
		
КонецПроцедуры

&НаКлиенте
Процедура ПодготовитьДанныеДляСравнения(СтрокаИсточник, СписокЗначений, ОбрабатываемыеТипы)
	
	Для Каждого Строка Из СтрокаИсточник.ПолучитьЭлементы() Цикл
		
		Если Строка.Тип = ИТК_Перечисления.ЭлементДанныхГруппа() Тогда
			
			ПодготовитьДанныеДляСравнения(Строка, СписокЗначений, ОбрабатываемыеТипы); 
			
		Иначе
			
			Если ОбрабатываемыеТипы.Найти(Строка.Тип) = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ПредставлениеСтроки = ПолноеИмяСтрокиДляСравнения(Строка);
			Если Строка.Выделение Тогда
				ПредставлениеСтроки = Новый ФорматированнаяСтрока(ПредставлениеСтроки, ИТК_ОбщийКлиентСервер.ШрифтЖирный());
			КонецЕсли;
					
			СписокЗначений.Добавить(Строка(Строка.УникальныйИдентификатор), ПредставлениеСтроки);
			
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Функция ПолноеИмяСтрокиДляСравнения(Строка)
	
	ПолноеИмя = Строка.Представление;
	
	РодительСтроки = Строка.ПолучитьРодителя();
	
	Если РодительСтроки <> Неопределено Тогда
		ПолноеИмя = РодительСтроки.Представление + " - " +ПолноеИмя;
		РодительСтроки = РодительСтроки.ПолучитьРодителя();
	КонецЕсли;

	Возврат ПолноеИмя;
	
КонецФункции

#КонецОбласти
