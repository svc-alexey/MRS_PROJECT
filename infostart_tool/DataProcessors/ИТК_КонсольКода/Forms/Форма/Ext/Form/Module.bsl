#Область ОбработчикиСобытийЭлементовТаблицыФормыПараметрыКода

&НаКлиенте
Процедура ПараметрыКодаПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗначениеПараметра = ТекущиеДанные.Значение;
	ВыбиратьТип = (ЗначениеПараметра = Неопределено);
	Элементы.ПараметрыКодаЗначение.ВыбиратьТип = ВыбиратьТип;
	
	Если ВыбиратьТип Тогда
		ОграничениеТипа = Элементы.ПараметрыКодаЗначение.ДоступныеТипы;
	Иначе
		ОграничениеТипа = ИТК_ТипыКлиентСервер.ОписаниеТиповПоТипу(ТипЗнч(ЗначениеПараметра));
	КонецЕсли;
	Элементы.ПараметрыКодаЗначение.ОграничениеТипа = ИТК_ТипыКлиентСервер.ОписаниеТиповПоТипу(ТипЗнч(ЗначениеПараметра));
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыКодаПриИзменении(Элемент)
	
	ИТК_КонсолиКлиентСервер.УстановитьМодифицированностьДанных(ЭтотОбъект);
	
	ПараметрыКодаКорректны = Истина;
	Для Каждого СтрокаПараметрКода Из ПараметрыКода.ПолучитьЭлементы() Цикл 
		
		Если ИТК_Строки.НекорректныйИдентификатор(СтрокаПараметрКода.Имя) Тогда 
			
			ПараметрыКодаКорректны = Ложь;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ПараметрыКодаКорректны Тогда 
	
	    ИТК_ФормаКлиент.СортироватьСтрокиДерева(ПараметрыКода.ПолучитьЭлементы(), "Имя");
		
		ДанныеСтроки = ИТК_КонсолиКлиентСервер.РаботаСДаннымиДанныеСтроки(ДеревоДанныхТекущиеДанные);
		ДанныеСтрокиПараметры = ДанныеСтроки.Параметры;
		ДанныеСтрокиПараметры.Очистить();
	
		Для Каждого СтрокаПараметрКода Из ПараметрыКода.ПолучитьЭлементы() Цикл 
			ДанныеСтрокиПараметры.Вставить(СтрокаПараметрКода.Имя, СтрокаПараметрКода.Значение);
		КонецЦикла;
		
		ЗагрузитьПользовательскиеОбъектыКода();
		ИТК_КонсолиКлиент.ОбновитьЭлементыФормы(ЭтотОбъект);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыКодаПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	
	Если ОтменаРедактирования Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если ИТК_Строки.НекорректныйИдентификатор(ТекущиеДанные.Имя) Тогда

		Отказ = Истина;
		
		ТекущийЭлемент = Элементы.ПараметрыКодаИмя;
		ПоказатьПредупреждение( , НСтр("ru = 'Некорректный идентификатор';
										|en = 'Invalid identifier'"));
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПараметрыКодаЗначениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ПараметрыКода.ТекущиеДанные;
	
	ДополнительныеПараметрыОповещения = Новый Структура;
	ДополнительныеПараметрыОповещения.Вставить("Имя", ТекущиеДанные.Имя);
	
	Если ТипЗнч(ТекущиеДанные.Значение) = Тип("СписокЗначений") Тогда 
		
		ЗаголовокФормы = НСтр("ru = 'Параметр'; en = 'Parametr'");
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("ДополнениеЗаголовка", ЗаголовокФормы);
		
		ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("РедактированиеЗначенияПараметраСписокЗавершено", ЭтотОбъект, ДополнительныеПараметрыОповещения);
		
		ИТК_ФормаКлиент.ОткрытьСписокЗначений(Элемент, ИТК_Перечисления.ВариантФормыСписокЗначенийРедактирование(),
												ТекущиеДанные.Значение, , ОписаниеОповещенияЗавершение,
												СтандартнаяОбработка, ДополнительныеПараметры);
		
	ИначеЕсли ТекущиеДанные.Значение = Неопределено Тогда
		
		ЗаголовокФормы = НСтр("ru = 'Тип параметра'; en = 'Type parametr'");
		ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("ВыборТипаПараметраЗавершен", ЭтотОбъект, ДополнительныеПараметрыОповещения);
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Исключаемые", "УникальныйИдентификатор");
		ДополнительныеПараметры.Вставить("ТипыКод", Истина);
		ИТК_ФормаКлиент.ОткрытьРедактированиеТипаЗначения(Элемент, Заголовок, ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборТипа(),
																Элемент.ДоступныеТипы, ОписаниеОповещенияЗавершение, СтандартнаяОбработка, ДополнительныеПараметры);
																
	КонецЕсли;

КонецПроцедуры

