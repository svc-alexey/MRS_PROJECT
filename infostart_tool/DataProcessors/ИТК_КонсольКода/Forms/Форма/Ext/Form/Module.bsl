&НаКлиенте
Процедура ОбновитьЭлементыФормы() Экспорт
	
	Элементы.ДеревоДанных.Видимость = ОтображатьДеревоДанных;
	Элементы.СкрытьПоказатьДеревоДанных.Пометка = ОтображатьДеревоДанных;
	Если НЕ ОтображатьДеревоДанных Тогда
		
		Если ДеревоДанныхТекущиеДанные = Неопределено
				И ЗначениеЗаполнено(ДеревоДанных.ПолучитьЭлементы()) Тогда
			
			ДеревоДанныхТекущиеДанные = ДеревоДанных.ПолучитьЭлементы()[0];
			ОбновитьДанныеСтрокиНаФорме();
			
		КонецЕсли;
		
	КонецЕсли;

	ТипСтрокиДереваДанных = Неопределено;
	Если ДеревоДанныхТекущиеДанные <> Неопределено Тогда
		ТипСтрокиДереваДанных = ДеревоДанныхТекущиеДанные.Тип;
	КонецЕсли;
	
	ДоступноИзменениеКода = ИТК_КонсолиКлиентСервер.ЭтоТипСтрокиДереваДанныхСИспользованиемТекста(ТипСтрокиДереваДанных);
	ТипСтрокиКод = (ТипСтрокиДереваДанных = ИТК_Перечисления.ЭлементДанныхКод());
	
	Элементы.ПанельНастроек.Доступность = ДоступноИзменениеКода;
	Элементы.ВыполнитьКод.Доступность = ТипСтрокиКод;
	
	Элементы.ФормаИдетВыполнениеПрервать.Видимость = ИдетВыполнение;
	
	// Оформление заголовка группы Параметры
	КоличествоПараметров = ИТК_ФормаКлиент.КоличествоСтрокВДереве(ПараметрыКода);
	Элементы.ПараметрыКода.Заголовок = ИТК_ФормаКлиентСервер.ЗаголовокСКоличеством(НСтр("ru = 'Параметры'; en = 'Parametrs'"), КоличествоПараметров);

	ОбновитьЭлементыОшибки();
	
КонецПроцедуры

