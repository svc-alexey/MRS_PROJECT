&НаСервере
Функция ПодготовитьДанныеДляСохранения(Знач СтрокаДерева)
	
	Массив = Новый Массив;
	СловарьПереводаИменПолей = ИТК_MCRФорматПовтИсп.СловарьПереводаИменПолей("ru");
	
	Для Каждого ЭлементДерева Из СтрокаДерева.ПолучитьЭлементы() Цикл
		
		ДанныеСтроки = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ЭлементДерева);
		
		ДанныеЗаписываемойСтроки = ИТК_КонсольРазработчикаДанныеКлиентСервер.НовыйЭлемент(ЭлементДерева.Тип, Истина);
		ЗаполнитьЗначенияСвойств(ДанныеЗаписываемойСтроки, ЭлементДерева);
		ЗаполнитьЗначенияСвойств(ДанныеЗаписываемойСтроки, ДанныеСтроки);
		Если ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоОдинИзТиповСтрокиСодержащийСохраняемыеСтроки(ЭлементДерева.Тип) Тогда
			
			Строки = ПодготовитьДанныеДляСохранения(ЭлементДерева);
			Если ЗначениеЗаполнено(Строки) Тогда
				ДанныеЗаписываемойСтроки.Вставить("Строки", Строки);
			КонецЕсли;
			
		ИначеЕсли ЭлементДерева.Тип = ИТК_Перечисления.ЭлементДанныхЗапрос() Тогда
			
			Если Не ДанныеСтроки.ТребуетсяПроверка И ДанныеСтроки.Ошибка = Неопределено Тогда
				
				// Записываем только те значения параметров которые есть в запросе
				ЗначенияПараметров = Новый Соответствие;
				Для Каждого ЗначениеПараметра Из ДанныеСтроки.ЗначенияПараметров Цикл 
					
					Если ДанныеСтроки.Параметры.Получить(ЗначениеПараметра.Ключ) <> Неопределено Тогда
						ЗначенияПараметров.Вставить(ЗначениеПараметра.Ключ, ЗначениеПараметра.Значение);
					КонецЕсли;
					
				КонецЦикла;
				ДанныеЗаписываемойСтроки.ЗначенияПараметров = ЗначенияПараметров;
				
				// Записываем только те настройки вывода таблиц, которые есть в запросе
				ЗаписываемыеНастройкиВыводаТаблиц = Новый Соответствие;
				Для Каждого НастройкаВыводаТаблицы Из ДанныеСтроки.НастройкиВыводаТаблиц Цикл 
					
					ИмяТаблицы = НастройкаВыводаТаблицы.Ключ;
					Если ДанныеСтроки.ВременныеТаблицы.Получить(ИмяТаблицы) <> Неопределено
							ИЛИ ИмяТаблицы = "" Тогда
						
						ОписаниеНастройкиВыводаТаблицы = НастройкаВыводаТаблицы.Значение;
						
						Если ОписаниеНастройкиВыводаТаблицы.Вывод <> ИТК_MCRФорматКлиентСервер.ВыводТаблицыЗначениеПоУмолчанию() Тогда
							ЗаписываемыеНастройкиВыводаТаблиц.Вставить(ИмяТаблицы, ОписаниеНастройкиВыводаТаблицы);
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЦикла;
				
				ДанныеЗаписываемойСтроки.НастройкиВыводаТаблиц = ЗаписываемыеНастройкиВыводаТаблиц;
				
			КонецЕсли;

		КонецЕсли;
		
		Для Каждого Поле Из ДанныеЗаписываемойСтроки Цикл 
			
			ДанныеЗаписываемойСтроки.Вставить(СловарьПереводаИменПолей[Поле.Ключ], Поле.Значение);
			ДанныеЗаписываемойСтроки.Удалить(Поле.Ключ);
			
		КонецЦикла;
		
		Массив.Добавить(ДанныеЗаписываемойСтроки);
		
	КонецЦикла;
	
	Возврат Массив;

КонецФункции

&НаКлиенте
Функция ДобавитьСтрокуВДеревоДанных(Тип, Имя = Неопределено, ДополнительныеПараметры = Неопределено)
	
	Родитель = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "Родитель");
	Активизировать = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "Активизировать", Истина);
	НачальныеДанные = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "НачальныеДанные");
	UID = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "UID");
	Картинка = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "Картинка");
	УстанавливатьМодифицированность = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "УстанавливатьМодифицированность", Истина);
	
	Если Родитель = Неопределено Тогда
		
		// Определим исходя из выделения куда добавляем
		Если ТекущаяСтрока = Неопределено Тогда
			Родитель = ДеревоДанных;
		ИначеЕсли ТекущаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхГруппа()
				ИЛИ (ТекущаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных()
						И (Тип = ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД()
							ИЛИ Тип = ИТК_Перечисления.ЭлементДанныхПользовательскаяНастройкаСКД()))
				ИЛИ (ТекущаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД()
						И Тип = ИТК_Перечисления.ЭлементДанныхПользовательскаяНастройкаСКД()) Тогда
					
			Родитель = ТекущаяСтрока;
			
		ИначеЕсли ТекущаяСтрока.ПолучитьРодителя() = Неопределено Тогда
			
			Родитель = ДеревоДанных;
			
		Иначе
			
			Родитель = ТекущаяСтрока.ПолучитьРодителя();
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Имя = Неопределено Тогда
		Имя = НовоеИмяСтрокиДереваДанных(Родитель, Тип);
	КонецЕсли;
	
	Если УстанавливатьМодифицированность Тогда
		Модифицированность = Истина;
	КонецЕсли;
	
	// Добавление новой строки
	НоваяСтрока = Родитель.ПолучитьЭлементы().Добавить();
	ИТК_КонсольРазработчикаКлиентСервер.ЗаполнениеДанныхСтроки(НоваяСтрока, Имя, Тип, UID, НачальныеДанные, Картинка);
	
	Если Активизировать Тогда
		Элементы.ДеревоДанных.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
	КонецЕсли;
	
	Возврат НоваяСтрока;
	
КонецФункции

&НаКлиенте
Функция НовоеИмяСтрокиДереваДанных(Родитель, Тип)
	
	МаксИндекс = МаксимальныйИндексСтрокДереваДанных(Родитель, Тип);
	Представление = ИТК_Перечисления.Представление(Тип);
	
	Возврат СтрШаблон("%1 №%2", Представление, МаксИндекс + 1);
	
КонецФункции

&НаКлиенте
Функция МаксимальныйИндексСтрокДереваДанных(Родитель, Тип)
	
	Результат = 0;
	Для Каждого Строка Из Родитель.ПолучитьЭлементы() Цикл 
		
		Если Строка.Тип <> Тип Тогда
			Продолжить;
		КонецЕсли;
		
		Значение = Строка["Имя"];
		Индекс = ИТК_Строки.ИндексИдентификатора(Значение);
		
		Если Индекс > Результат Тогда
			
			Результат = Индекс;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ДобавитьСтрокуВДеревоДанныхСервер(ИмяДанных, ТипСтроки, Родитель, ДополнительныеПараметры = Неопределено)
	
	НачальныеДанные = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "НачальныеДанные");
	UID = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "UID");
	Картинка = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "Картинка");
	
	// Добавление новой строки
	НоваяСтрока = Родитель.ПолучитьЭлементы().Добавить();
	ИТК_КонсольРазработчикаКлиентСервер.ЗаполнениеДанныхСтроки(НоваяСтрока, ИмяДанных, ТипСтроки, UID, НачальныеДанные, Картинка);
	
	Возврат НоваяСтрока;
	
КонецФункции

&НаСервере
Процедура ЗагрузитьДанные(Данные)
	
	Попытка
		
		МассивДанных = ИТК_MCRФормат.Прочитать(Данные.Получить(), УникальныйИдентификатор);
		ЗагрузитьДанныеПострочно(МассивДанных, ДеревоДанных);
		ОбновитьСтруктуруЗапросовСервер();
		
	Исключение

		Шаблон = НСтр("ru = 'Ошибка при загрузке данных: %1';
						|en = 'Error loading data: %1'");
		ПредставлениеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Сообщить(СтрШаблон(Шаблон, ПредставлениеОшибки));
		
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьДанныеПострочно(МассивДанных, СтрокаДерева)
	
	СловарьПереводаИменПолей = ИТК_MCRФорматПовтИсп.СловарьПереводаИменПолей("en");

	Для Каждого СтрокаСтруктура Из МассивДанных Цикл
		
		Для Каждого Поле Из СтрокаСтруктура Цикл 
			
			ПереводИмениПоля = СловарьПереводаИменПолей.Получить(Поле.Ключ);
			Если ЗначениеЗаполнено(ПереводИмениПоля) Тогда
				СтрокаСтруктура.Вставить(ПереводИмениПоля, Поле.Значение);
				СтрокаСтруктура.Удалить(Поле.Ключ);
			КонецЕсли;
			
		КонецЦикла;
		
		ТипСтроки = СтрокаСтруктура.Тип;
		НачальныеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.НовыйЭлемент(ТипСтроки);
		ЗаполнитьЗначенияСвойств(НачальныеДанные, СтрокаСтруктура);
		
		Если ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоТипСтрокиСИспользованиемОригинальногоТекста(ТипСтроки) Тогда
			ИТК_КонсольРазработчикаДанныеКлиентСервер.СброситьОригинальныйТекст(НачальныеДанные);
		КонецЕсли;
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("UID", СтрокаСтруктура.UID);
		ДополнительныеПараметры.Вставить("НачальныеДанные", НачальныеДанные);
		
		НоваяСтрока = ДобавитьСтрокуВДеревоДанныхСервер(СтрокаСтруктура.Имя, ТипСтроки, СтрокаДерева, ДополнительныеПараметры);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаСтруктура);
		
		// Обработаем вложенные строки
		Если СтрокаСтруктура.Свойство("Строки") Тогда
			ЗагрузитьДанныеПострочно(СтрокаСтруктура.Строки, НоваяСтрока); 
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСтруктуруЗапросовСервер()
	
	РазбиратьСтруктуру = ИТК_Настройки.ЗначениеНастройкиВФорме(ЭтотОбъект, "РазбиратьСтруктуруЗапроса");
	
	Для Каждого ОбрабатываемаяСтрока Из ИТК_КонсольРазработчикаКлиентСервер.СтрокиДереваДанных(ДеревоДанных, ИТК_Перечисления.ЭлементДанныхЗапрос()) Цикл 
		
		ОбрабатываемаяСтрока.ПолучитьЭлементы().Очистить();
		
		Если РазбиратьСтруктуру Тогда
			
			Данные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ОбрабатываемаяСтрока);
			Если Данные.ТребуетсяПроверка ИЛИ ЗначениеЗаполнено(Данные.Ошибка) Тогда
				Возврат;
			КонецЕсли;
			
			ОбновитьСтруктуруЗапросаСервер(ОбрабатываемаяСтрока, ИТК_АнализЗапроса.РазборСтруктуры(Данные.Текст));
			
		КонецЕсли;
		
	КонецЦикла;	
	
КонецПроцедуры	

&НаСервере
Процедура ОбновитьСтруктуруЗапросаСервер(Строка, Данные)
	
	Для Каждого Элемент Из Данные Цикл 
		
		НачальныеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.НовыйЭлемент(ИТК_Перечисления.ЭлементДанныхПодзапрос());
		НачальныеДанные.Вставить("ТекстИнициализации", Элемент.ТекстИнициализации);
		НачальныеДанные.Вставить("Текст", Элемент.Текст);
		НачальныеДанные.Вставить("Параметры", Элемент.Параметры);
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("НачальныеДанные", НачальныеДанные);
		ДополнительныеПараметры.Вставить("Картинка", Элемент.Картинка);
		
		НоваяСтрока = ДобавитьСтрокуВДеревоДанныхСервер(Элемент.Представление, ИТК_Перечисления.ЭлементДанныхПодзапрос(), Строка, ДополнительныеПараметры);
		
		ОбновитьСтруктуруЗапросаСервер(НоваяСтрока, Элемент.Элементы);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура РаскрытьВеткиДереваВСоответствииСДанными(ОбрабатываемаяСтрока)
	
	Для Каждого ЭлементДерева Из ОбрабатываемаяСтрока.ПолучитьЭлементы() Цикл
		
		Если ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоОдинИзТиповСтрокиСодержащийСохраняемыеСтроки(ЭлементДерева.Тип) Тогда
				
			Если ЭлементДерева.Развернуто Тогда
				Элементы.ДеревоДанных.Развернуть(ЭлементДерева.ПолучитьИдентификатор());
			КонецЕсли;
			
		КонецЕсли;
		
		РаскрытьВеткиДереваВСоответствииСДанными(ЭлементДерева);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Функция НайтиСтрокуПоUID(СтрокаИсточник, UID)
	
	Результат = Неопределено;
	
	Для Каждого Строка Из СтрокаИсточник.ПолучитьЭлементы() Цикл
		
		Если Строка.UID = UID Тогда
			Результат = Строка;
			Прервать;
		КонецЕсли;
		
		НайденнаяСтрока = НайтиСтрокуПоUID(Строка, UID);
		
		Если НайденнаяСтрока <> Неопределено Тогда
			Результат = НайденнаяСтрока; 
			Прервать;
		КонецЕсли;
			
	КонецЦикла;
		
	Возврат Результат;	

КонецФункции

&НаСервере
Процедура СохранитьДанныеВНастройкиСервер(Имя)
	
	ПодготовленныеДанные = ПодготовитьДанныеДляСохранения(ДеревоДанных);
	ИТК_КонсольРазработчика.СохранитьДанные(Имя, ПодготовленныеДанные);
	
	ТипХраненияДанных = ИТК_Перечисления.ТипХраненияДанныхНастройка();
	УстановитьРабочиеДанные(РабочиеДанные, ТипХраненияДанных, Имя);
	ОбновитьЭлементыПоследниеРабочиеДанные(ТипХраненияДанных, Имя);

КонецПроцедуры

&НаСервере
Процедура ЗагрузитьДанныеИзНастроекСервер(Имя, Пользователь = Неопределено, Объединение = Ложь)
	
	Попытка
		
		Данные = ИТК_КонсольРазработчика.ЗагрузитьДанныеИзНастроек(Имя, Пользователь);
		
	Исключение
		
		Возврат;
		
	КонецПопытки;
	
	Если Не Объединение Тогда
		
		ОчиститьДанныеСервер();
		
	КонецЕсли;
	
	ЗагрузитьДанные(Данные);
	
	Если Не Объединение 
			И Пользователь = Неопределено Тогда
			
		УстановитьРабочиеДанные(РабочиеДанные, ИТК_Перечисления.ТипХраненияДанныхНастройка(), Имя);
		ИТК_КонсольРазработчикаДанныеКлиентСервер.СброситьМодифицированность(ЭтотОбъект);
		
	Иначе
			
		ИТК_КонсольРазработчикаДанныеКлиентСервер.ДанныеМодифицированы(ЭтотОбъект);
		
	КонецЕсли;
	
	ОбновитьЭлементыПоследниеРабочиеДанные(ИТК_Перечисления.ТипХраненияДанныхНастройка(), Имя);
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьДанныеИзФайлаСервер(Адрес, ПолноеИмяФайла, Объединение)
	
	ИндексСимвола = СтрНайти(ПолноеИмяФайла, ".", НаправлениеПоиска.СКонца);
	Расширение = НРег(Сред(ПолноеИмяФайла, ИндексСимвола + 1));
	ОсновноеРасширение = (Расширение = ИТК_ОбщийКлиентСервер.ОсновноеРасширениеФайловДанных());
	
	Попытка
		
		Если ОсновноеРасширение Тогда
			
			МассивДанных = ИТК_MCRФормат.Прочитать(Адрес, УникальныйИдентификатор);
			
		Иначе
			
			Если Расширение = "dcr" Тогда
				
				МассивДанных = ИТК_КонсольРазработчикаЭкспортДанных.DCRИзВременногоХранилища(Адрес, УникальныйИдентификатор);
				
			ИначеЕсли Расширение = "q1c" Тогда
				
				МассивДанных = ИТК_КонсольРазработчикаЭкспортДанных.Q1CИзВременногоХранилища(Адрес, УникальныйИдентификатор);
				
			ИначеЕсли Расширение = "erf" Тогда
				
				МассивДанных = ИТК_КонсольРазработчикаЭкспортДанных.ERFИзВременногоХранилища(Адрес, УникальныйИдентификатор);
				
			КонецЕсли;
			
		КонецЕсли;
		
	Исключение
		
		Возврат;
		
	КонецПопытки;
	
	Если Объединение Тогда
		
		ИТК_КонсольРазработчикаДанныеКлиентСервер.ДанныеМодифицированы(ЭтотОбъект);
		
	Иначе
		
		Если ОсновноеРасширение Тогда
			
			УстановитьРабочиеДанные(РабочиеДанные, ИТК_Перечисления.ТипХраненияДанныхФайл(), ПолноеИмяФайла);
			
		Иначе
			
			УстановитьРабочиеДанные(РабочиеДанные, , , СтрШаблон(НСтр("ru = 'экспортирован из %1';
																		|en = 'exported from %1'"), Расширение));
			
		КонецЕсли;
		
		ОчиститьДанныеСервер();
		
	КонецЕсли;
	
	ЗагрузитьДанныеПострочно(МассивДанных, ДеревоДанных);
	
	ОбновитьСтруктуруЗапросовСервер();
	ОбновитьЭлементыПоследниеРабочиеДанные(ИТК_Перечисления.ТипХраненияДанныхФайл(), ПолноеИмяФайла);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьТекущейСтрокойДереваПервую()
	
	СтрокиДерева = ДеревоДанных.ПолучитьЭлементы();
	Если ЗначениеЗаполнено(СтрокиДерева) Тогда
		ТекущаяСтрока = СтрокиДерева[0];
		Элементы.ДеревоДанных.ТекущаяСтрока = ТекущаяСтрока;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОбработчикАвтоСохранения()
	
	ОтключитьОбработчикОжидания("ПодключаемыйАвтоСохранениеДанных");
	
	ПериодичностьАвтоСохранения = ИТК_НастройкиКлиент.ЗначениеНастройки(ЭтотОбъект, "ПериодичностьАвтоСохранения");
	Если ЗначениеЗаполнено(ПериодичностьАвтоСохранения) Тогда
		
		ПодключитьОбработчикОжидания("ПодключаемыйАвтоСохранениеДанных", ПериодичностьАвтоСохранения);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйАвтоСохранениеДанных()

	АвтосохранениеДанных();

КонецПроцедуры

&НаКлиенте
Процедура АвтоСохранениеДанных()

	Если МодифицированностьАвтосохранение Тогда
		
		Элементы.ФормаАвтоСохранение.Видимость = Истина;
		
		ДлительнаяОперацияАвтоматическоеСохранение = АвтоматическоеСохранениеНаСервере();
		ПараметрыОжидания = ИТК_ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		
		ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершениеАвтоматическогоСохранения", ЭтотОбъект);
		ИТК_ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперацияАвтоматическоеСохранение, ОповещениеОЗавершении, ПараметрыОжидания);
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция АвтоматическоеСохранениеНаСервере()
	
	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("Данные", ПодготовитьДанныеДляСохранения(ДеревоДанных));
	ПараметрыПроцедуры.Вставить("Тип", РабочиеДанные);
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	
	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_КонсольРазработчика.АвтоматическоеСохранение", ПараметрыПроцедуры, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ЗавершениеАвтоматическогоСохранения(Результат, ДополнительныеПараметры) Экспорт
	
	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;

	МодифицированностьАвтоСохранение = Ложь;
	Элементы.ФормаАвтоСохранение.Видимость = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура НачалоДлительнойОперации(ОписаниеОперации, ДополнительныеПараметры) Экспорт
	
	ПрогрессДлительнойОперации = ОписаниеОперации.Наименование;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаменаПараметраВТекстеНаЗначениеЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда 
		Возврат;
	КонецЕсли;
		
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	
	ГраницыВыделения = Неопределено;
	ТекстЗначенияПараметра = ИТК_Запрос.ЗначениеПараметраВТекст(ТекущиеДанные, ДополнительныеПараметры.Имя);
	НовыйТекст = ИТК_ЗапросКлиентСервер.ЗаменитьПараметрВТексте(ТекущиеДанные.Текст, ДополнительныеПараметры.Имя, ТекстЗначенияПараметра, ГраницыВыделения);
	
	ИзменяемыеПоля = Новый Структура;
	ИзменяемыеПоля.Вставить("ТребуетсяПроверка", Истина);
	ИзменяемыеПоля.Вставить("Текст", НовыйТекст);
	ИзменяемыеПоля.Вставить("ГраницыВыделенияТекста", ГраницыВыделения);
	ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоля(ЭтотОбъект, ТекущаяСтрока, ИзменяемыеПоля);
	
	Элементы.ПанельНастроек.ТекущаяСтраница = Элементы.СтраницаТекстЗапроса;
	ТекущийЭлемент = Элементы.ТекстЗапроса;
																							
	ПодключаемыйЗагрузитьСостояниеРедактораКода();
	
	ПроверитьПоказатьОшибку();
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗапуститьЗамераПакетногоЗапросаНаСервере(Знач Данные, УникальныйИдентификатор, ФоновоеВыполнение)

	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("Данные", ПодготовитьДанныеПередВыполнениемНаСервере(Данные));
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор, ФоновоеВыполнение);
	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_Запрос.ДетальныйЗамер", ПараметрыПроцедуры, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ЗавершениеЗамераПакетногоЗапроса(Результат, ДополнительныеПараметры) Экспорт
	
	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	ИТК_ДлительныеОперацииКлиент.СкрытьПрогресс(ЭтотОбъект);
	
	РезультатЗамера = РезультатЗамераПакетногоЗапроса(Результат, УникальныйИдентификатор);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("АдресДанных", РезультатЗамера.АдресРезультата);
	
	ПредставлениеЗапроса = Элементы.ДеревоДанных.ТекущиеДанные.Имя;
	ПараметрыФормы.Вставить("ДополнениеЗаголовка", ПредставлениеЗапроса);
	
	ОткрытьФорму("Обработка.ИТК_КонсольРазработчика.Форма.АнализПакетаЗапросов", ПараметрыФормы, , Истина);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция РезультатЗамераПакетногоЗапроса(Знач РезультатЗамера, УникальныйИдентификатор)
	
	РезультатЗамера = ПолучитьИзВременногоХранилища(РезультатЗамера.АдресРезультата);
	
	Результат = Новый Структура;
	Результат.Вставить("АдресРезультата", ИТК_ВременноеХранилище.Поместить(РезультатЗамера.Результат, , УникальныйИдентификатор));
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ЗавершенВопросПреобразоватьЗначениеПараметраВыражения(Результат, ДополнительныеПараметры) Экспорт
	
	СтрокаПараметр = Элементы.ПараметрыЗапроса.ТекущиеДанные;
	ИмяПараметра = СтрокаПараметр.Имя;
	
	Если ЗначениеЗаполнено(Результат) Тогда
		
		НовоеЗначение = ДополнительныеПараметры.НовоеЗначение;
		НовыйТип = ДополнительныеПараметры.Тип;
		
		ПоследнийТипПараметра = НовыйТип;

		ИТК_КонсольРазработчикаДанныеКлиент.ВставитьЗначениеПараметраЗапроса(ЭтотОбъект, ТекущаяСтрока, ИмяПараметра, НовоеЗначение);
		
	Иначе
		
		НовоеЗначение = ДополнительныеПараметры.Значение;
		
	КонецЕсли;
	
	ОбновитьСтрокуПараметра(СтрокаПараметр, ИмяПараметра, СтрокаПараметр.ТипЗначения, НовоеЗначение);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьЗаполняемыеПараметры(ДанныеЗаполнения, ИменаПараметров)
	
	Если ЗначениеЗаполнено(ДанныеЗаполнения) Тогда
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Имена", ИменаПараметров);
		ПараметрыФормы.Вставить("ДанныеЗаполнения", ДанныеЗаполнения);
		
		ДополнительныеПараметры = Новый Структура;
		Если ИменаПараметров.Количество() = 1 Тогда
			ДополнительныеПараметры.Вставить("Имя", ИменаПараметров[0]);
		КонецЕсли;
		Оповещение = Новый ОписаниеОповещения("ЗаполнениеПараметровЗакончено", ЭтотОбъект, ДополнительныеПараметры);
		
		ОткрытьФорму("Обработка.ИТК_КонсольРазработчика.Форма.ЗаполнениеПараметров", ПараметрыФормы, ЭтотОбъект, , , , Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	Иначе 
		
		ПоказатьПредупреждение(, НСтр("ru = 'Нет данных для заполнения параметров';
										|en = 'There is no data to populate parameters'"), , ИТК_КонсольРазработчикаКлиентСервер.Представление());
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция КолонкиВнешнегоИсточника(Описание)
	
	Если Описание.Тип = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаВыражение() Тогда
			
		Комментарий = СтрШаблон(НСтр("ru = 'Внешний источник: %1';
									|en = 'External source: %1'"), Описание.Имя);
		Значение = ИТК_ОбщийВызовСервера.ВычислитьВыражениеНаВстроенномЯзыке(Описание.Значение, Комментарий);
		
	Иначе 
		
		Значение = ПолучитьИзВременногоХранилища(Описание.Значение);
		
	КонецЕсли;
	
	Результат = Новый СписокЗначений;
	Если ТипЗнч(Значение) = Тип("ТаблицаЗначений") Тогда
		
		Для Каждого Колонка Из Значение.Колонки Цикл 
			
			Результат.Добавить(Колонка.ТипЗначения, Колонка.Имя, ИТК_ТаблицаЗначений.ИндексируетсяКолонка(Значение, Колонка.Имя));
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ОткрытьФормуАнализаИсполняемыхЗапросов(Адрес)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Адрес", Адрес);
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("АнализИсполняемыхЗапросовЗавершен", ЭтотОбъект);
	ОткрытьФорму("Обработка.ИТК_КонсольРазработчика.Форма.АнализИсполняемыхЗапросов", ПараметрыФормы, ЭтотОбъект, , , , ОповещениеОЗакрытии, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

&НаКлиенте
Процедура АнализИсполняемыхЗапросовЗавершен(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Добавляем строку запрос в данные для анализа
	Тип = ИТК_Перечисления.ЭлементДанныхЗапрос();
	
	ШаблонИмени = НСтр("ru = 'Запрос СКД (%1)';
						|en = 'Query DCS (%1)'");
	Имя = СтрШаблон(ШаблонИмени, Результат.Имя);
	
	ДополнительныеПараметры = Новый Структура;
	
	// Подготовка начальных данных
	НачальныеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.НовыйЭлемент(Тип);	
	ЗаполнитьЗначенияСвойств(НачальныеДанные, Результат, "Текст, ЗначенияПараметров");
	НачальныеДанные["Ошибка"] = Неопределено;
	НачальныеДанные["ТребуетсяПроверка"] = Истина;
	
	ДополнительныеПараметры.Вставить("НачальныеДанные", НачальныеДанные);
	
	// Определение родителя
	Родитель = ТекущаяСтрока.ПолучитьРодителя();
	Пока НЕ (Родитель = Неопределено 
			ИЛИ Родитель.Тип = ИТК_Перечисления.ЭлементДанныхГруппа()) Цикл 
			
		Родитель = Родитель.ПолучитьРодителя();

	КонецЦикла;
	Если Родитель = Неопределено Тогда
		Родитель = ДеревоДанных;
	КонецЕсли;
	
	ДополнительныеПараметры.Вставить("Родитель", Родитель);
	
	ДобавитьСтрокуВДеревоДанных(Тип, Имя, ДополнительныеПараметры);
	
КонецПроцедуры

&НаСервере
Процедура ИнициализацияРедактораКода()
	
	ЯзыкПрограммирования = ИТК_Настройки.ЗначениеОбщейНастройки(ЭтотОбъект, "ЯзыкПрограммирования");
	ИмяПеременной = ИТК_РедакторКодаКлиентСервер.ИмяПеременнойВозвратаРезультата(ЯзыкПрограммирования);
	
	ДополнительныеСвойства = Новый Структура;
	ДополнительныеСвойства.Вставить("Подсказка", СтрШаблон(НСтр("ru = 'Возврат результата производится через переменную ""%1""';
																|en = 'The result is returned through the variable ""%1""'"), ИмяПеременной));
	ИТК_РедакторКода.Инициализация(ЭтотОбъект, "Код", ДополнительныеСвойства);
	
КонецПроцедуры

