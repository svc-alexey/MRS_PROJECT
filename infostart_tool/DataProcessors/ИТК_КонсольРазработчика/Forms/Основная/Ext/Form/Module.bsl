КонецПроцедуры

&НаКлиенте
Процедура ДеревоДанныхПередУдалением(Элемент, Отказ)
	
	Отказ = Истина;
	
	ЗаголовокВопроса = НСтр("ru = 'Удаление строк';
							|en = 'Deleting rows'");
	ТекстВопроса = СтрШаблон(НСтр("ru = 'Выделено: %1
	|Данные будут потеряны. Продолжить?';
	|en = 'Lines selected: %1
	|Data will be lost. Continue?'"), Элемент.ВыделенныеСтроки.Количество());

	ОписаниеОповещенияОЗавершении = Новый ОписаниеОповещения("ВопросПередУдалениемСтрокДанныхЗавершение", ЭтотОбъект);
	КнопкиВопроса = ИТК_ФормаКлиент.КнопкиВопросаПродолжитьОтмена();
	
	ИТК_ФормаКлиент.ЗадатьВопрос(ОписаниеОповещенияОЗавершении, ТекстВопроса, КнопкиВопроса, Истина, ЗаголовокВопроса, ЭтотОбъект, "ПередУдалениемСтрокДанных");
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПараметрыЗапроса

&НаКлиенте
Процедура ПараметрыЗапросаПриИзменении(Элемент)
	
	СтрокаПараметр = Элемент.ТекущиеДанные;
	Если СтрокаПараметр = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИмяИзменяемойКолонки = Элемент.ТекущийЭлемент.Имя;
	ИмяПараметра = СтрокаПараметр.Имя;
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	
	ЗначениеПараметра = ИТК_КонсольРазработчикаДанныеКлиент.ЗначениеПараметраЗапроса(ТекущиеДанные, ИмяПараметра, СтрокаПараметр.ТипЗначения);
	ТипЗначения = ТекущиеДанные.Параметры[ИмяПараметра];
	НовыйТип = СтрокаПараметр.Тип;
	
	Если ИмяИзменяемойКолонки = "ПараметрыЗапросаТип" Тогда
		
		Если ПоследнийТипПараметра <> НовыйТип Тогда // Изменен тип
			
			ТекстОшибки = "";
			ПреобразованноеЗначение = ПреобразоватьЗначениеПараметраКТипу(ЗначениеПараметра, ТипЗначения, ПоследнийТипПараметра, НовыйТип, ТекстОшибки);
			
			ДополнительныеПараметры = Новый Структура;
			ДополнительныеПараметры.Вставить("Тип", НовыйТип);
			ДополнительныеПараметры.Вставить("Значение", ЗначениеПараметра);
			ДополнительныеПараметры.Вставить("НовоеЗначение", ПреобразованноеЗначение);
			
			ОписаниеОповещения = Новый ОписаниеОповещения("ЗавершенВопросПреобразоватьЗначениеПараметраВыражения", ЭтотОбъект, ДополнительныеПараметры);
			
			Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			
				ТекстВопроса = СтрШаблон(НСтр("ru = 'Ошибка при преобразовании значения: %1
	                                           |Значение будет потеряно. Продолжить?';
	                                           |en = 'Error converting value: %1
	                                           |The value will be lost. Proceed?'"), ТекстОшибки);
				
				ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, ИТК_ФормаКлиент.КнопкиВопросаПродолжитьОтмена(), , , ИТК_КонсольРазработчикаКлиентСервер.Представление()); 
				
			Иначе 
				
				ВыполнитьОбработкуОповещения(ОписаниеОповещения, Истина);
				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		НовоеЗначениеПараметра = СтрокаПараметр.ЗначениеПредставление;
		
		Если НовоеЗначениеПараметра <> ЗначениеПараметра Тогда 
			ИТК_КонсольРазработчикаДанныеКлиент.ВставитьЗначениеПараметраЗапроса(ЭтотОбъект, ТекущаяСтрока, ИмяПараметра, НовоеЗначениеПараметра);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыЗапросаПриАктивизацииСтроки(Элемент)
	
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущаяСтрока.Тип <> ИТК_Перечисления.ЭлементДанныхЗапрос() Тогда
		
		// Странно иногда активация строки параметра проиходит при обновлении страницы код
		// и решение проблемы https://github.com/infostart-hub/toolkit/issues/938
		Возврат;
		
	КонецЕсли;
	
	СтрокаПараметр = Элемент.ТекущиеДанные;
	
	Если СтрокаПараметр <> Неопределено Тогда 
		
		ПоследнийТипПараметра = СтрокаПараметр.Тип;
		
		ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
		ЗначениеПараметра = ИТК_КонсольРазработчикаДанныеКлиент.ЗначениеПараметраЗапроса(ТекущиеДанные, СтрокаПараметр.Имя, СтрокаПараметр.ТипЗначения);
		
		ИТК_ФормаКлиент.АктивизацияЗначенияВФорме(Элементы.ПараметрыЗапросаЗначениеПредставление, ЗначениеПараметра, СтрокаПараметр.ТипЗначения);
		
		ЭлементЗначение = Элементы.ПараметрыЗапросаЗначениеПредставление;
		
		Если ТипЗнч(ЗначениеПараметра) = Тип("СписокЗначений") Тогда
			
			ОписаниеТиповСтрока = ИТК_ТипыКлиентСервер.ОписаниеСтрока();
			Элементы.ПараметрыЗапросаЗначениеПредставление.ОграничениеТипа = ОписаниеТиповСтрока;
			ЭлементЗначение.РедактированиеТекста = Ложь;
			ЭлементЗначение.КнопкаВыпадающегоСписка = Ложь;
			ЭлементЗначение.КнопкаВыбора = Истина;
			
			СтрокаПараметр.ЗначениеПредставление = ОписаниеТиповСтрока.ПривестиЗначение(ЗначениеПараметра); 
			
		ИначеЕсли ТипЗнч(ЗначениеПараметра) = Тип("Структура") Тогда
			
			Элементы.ПараметрыЗапросаЗначениеПредставление.ОграничениеТипа = ИТК_ТипыКлиентСервер.ОписаниеСтрока();
			ЭлементЗначение.РедактированиеТекста = Ложь;				
			ЭлементЗначение.КнопкаОчистки = Ложь;
			ЭлементЗначение.КнопкаВыбора = Истина;
			ЭлементЗначение.КнопкаВыпадающегоСписка = Ложь;
			
			СтрокаПараметр.ЗначениеПредставление = ЗначениеПараметра.Представление;
			
		КонецЕсли;
		
		// Обновление списка выбора типа
		СписокДоступен = СписокДоступенДляПараметра(ЗначениеПараметра, ТекущиеДанные.Параметры[СтрокаПараметр.Имя]);
		ИТК_Перечисления.ЗаполнитьСписок(Элементы.ПараметрыЗапросаТип, ИТК_Перечисления.ТипыЗначенияПараметровЗапроса(), СписокДоступен);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыЗапросаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле = Элементы.ПараметрыЗапросаИмя
			И ТекущаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхЗапрос() Тогда
			
		ПереименоватьПараметр();
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыЗапросаТипОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыЗапросаЗначениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

	Перем ОписаниеОповещенияОЗакрытии;
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	
	СтрокаПараметр = Элементы.ПараметрыЗапроса.ТекущиеДанные;
	ИмяПараметра = СтрокаПараметр.Имя;
	
	ЗначениеПараметра = ИТК_КонсольРазработчикаДанныеКлиент.ЗначениеПараметраЗапроса(ТекущиеДанные, ИмяПараметра, СтрокаПараметр.ТипЗначения);
	ЗаголовокПараметр = СтрШаблон(НСтр("ru = 'Параметр ""%1""';
										|en = 'Parameter ""%1""'"), ИмяПараметра);

	ДополнительныеПараметры = Новый Структура;
	ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("ВводЗначенияПараметраЗавершен", ЭтотОбъект, ДополнительныеПараметры);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ДополнятьДату", Истина);
	ИТК_ФормаКлиент.ВводЗначенияСтрокиВФорме(ЗаголовокПараметр, Элемент, ЗначениеПараметра, СтрокаПараметр.ТипЗначения, СтандартнаяОбработка, ОписаниеОповещенияЗавершение, ДополнительныеПараметры);
	
	ДополнительныеПараметры = Новый Структура("Имя", ИмяПараметра);
	Если СтрокаПараметр.Тип = ИТК_Перечисления.ТипЗначенияПараметраЗапросаВыражение() Тогда
		
		СтандартнаяОбработка = Ложь;
		ДополнительныеПараметры.Вставить("ВидСложногоПараметра", ИТК_Перечисления.СложныйПараметрЗапросаВыражение());
		ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("РедактированиеСложногоПараметраЗавершено", ЭтотОбъект, ДополнительныеПараметры);
		
		ШаблонЗаголовка = НСтр("ru = 'Редактирование выражения (%1): %2';
								|en = 'Expression edit (%1):%2'");
		ЗаголовокФормы = СтрШаблон(ШаблонЗаголовка, ИТК_Строки.ТекстПараметр(), ИмяПараметра);
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Владелец", ЭтотОбъект);
		ДополнительныеПараметры.Вставить("ОписаниеОповещенияОЗакрытии", ОписаниеОповещенияЗавершение);
		
		ИТК_РедакторКодаКлиент.ОткрытьРедактированиеКодаВОтдельномОкне(ЗаголовокФормы, ЗначениеПараметра.Значение, ДополнительныеПараметры);
		
	ИначеЕсли ТипЗнч(ЗначениеПараметра) = Тип("Структура") Тогда
		
		СтандартнаяОбработка = Ложь;
		ДополнительныеПараметры.Вставить("ВидСложногоПараметра", ЗначениеПараметра.Вид);
 		ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("РедактированиеСложногоПараметраЗавершено", ЭтотОбъект, ДополнительныеПараметры);
		
		Если ЗначениеПараметра.Вид = ИТК_Перечисления.СложныйПараметрЗапросаТаблицаЗначений() Тогда
			
			ДополнительныеПараметрыОткрытия = Новый Структура;
			ДополнительныеПараметрыОткрытия.Вставить("ДополнениеЗаголовка", СтрШаблон("(%1): %2", ИТК_Строки.ТекстПараметр(), ИмяПараметра));
			ДополнительныеПараметрыОткрытия.Вставить("ОписаниеОповещенияОЗакрытии", ОписаниеОповещенияЗавершение);
			ДополнительныеПараметрыОткрытия.Вставить("Источник", СтрШаблон("&%1", ИмяПараметра));
			
			ИТК_ФормаКлиент.ОткрытьТаблицуЗначений(ЗначениеПараметра.Значение, ЭтотОбъект, , ДополнительныеПараметрыОткрытия);
			
		ИначеЕсли ЗначениеПараметра.Вид = ИТК_Перечисления.СложныйПараметрЗапросаГраница() Тогда
			
			ИТК_ФормаКлиент.ОткрытьРедактированиеГраницы(ЗаголовокПараметр, ЗначениеПараметра.Значение, ЭтотОбъект, ОписаниеОповещенияЗавершение);
			
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(ЗначениеПараметра) = Тип("МоментВремени") Тогда
		
		ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("РедактированиеЗначенияПараметраЗавершено", ЭтотОбъект, ДополнительныеПараметры);
		ИТК_ФормаКлиент.ОткрытьРедактированиеМоментаВремени(ЭтотОбъект, ЗначениеПараметра, СтандартнаяОбработка, ОписаниеОповещенияЗавершение, ЗаголовокПараметр);
		
	ИначеЕсли ТипЗнч(ЗначениеПараметра) = Тип("СписокЗначений") Тогда
		
		ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("РедактированиеЗначенияПараметраЗавершено", ЭтотОбъект, ДополнительныеПараметры);
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("ДополнениеЗаголовка", ЗаголовокПараметр);
		
		ИТК_ФормаКлиент.ОткрытьСписокЗначений(ЭтотОбъект, ИТК_Перечисления.ВариантФормыСписокЗначенийРедактирование(),
												ЗначениеПараметра, СтрокаПараметр.ТипЗначения, ОписаниеОповещенияЗавершение,
												СтандартнаяОбработка, ДополнительныеПараметры);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыЗапросаЗначениеОчистка(Элемент, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.ОчисткаЗначенияСтрокиВФорме(Элемент, СтандартнаяОбработка);
	
	СтрокаПараметр = Элементы.ПараметрыЗапроса.ТекущиеДанные;
	НовоеЗначение = СтрокаПараметр.ТипЗначения.ПривестиЗначение(Неопределено);
	
	Если СтрокаПараметр.Тип = ИТК_Перечисления.ТипЗначенияПараметраЗапросаСписок() Тогда
		НовоеЗначение = ИТК_ОбщийКлиентСервер.НовыйСписокЗначений(НовоеЗначение);
	КонецЕсли;
	
	ИТК_КонсольРазработчикаДанныеКлиент.ВставитьЗначениеПараметраЗапроса(ЭтотОбъект, ТекущаяСтрока, СтрокаПараметр.Имя, НовоеЗначение);
	ОбновитьСтрокуПараметра(СтрокаПараметр, СтрокаПараметр.Имя, СтрокаПараметр.ТипЗначения, НовоеЗначение);

КонецПроцедуры

&НаКлиенте
Процедура ПараметрыЗапросаЗначениеОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.ОбработкаВыбораЗначенияВФорме(Элемент, ВыбранноеЗначение, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыЗапросаЗначениеАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.АвтоПодборЗначенияВФорме(Текст, Элемент, ДанныеВыбора, СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыВнешниеИсточники

&НаКлиенте
Процедура ВнешниеИсточникиПриАктивизацииСтроки(Элемент)

	ВнешниеИсточникиТекущиеДанные = Элементы.ВнешниеИсточники.ТекущиеДанные;
	Элементы.ВнешниеИсточникиКонтекстноеМенюЗапросИсточника.Доступность = (ВнешниеИсточникиТекущиеДанные <> Неопределено);

	Если ВнешниеИсточникиТекущиеДанные = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВнешниеИсточникиТекущиеДанные.Тип) Тогда // Без этого условия при копировании заносит пустое значение и обновляет внешний источник пустым
		
		ПоследнийТипВнешнегоИсточника = ВнешниеИсточникиТекущиеДанные.Тип;
		
	КонецЕсли;
	
	ОбновитьСтрокуВнешнийИсточник(ВнешниеИсточникиТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ВнешниеИсточникиПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	Если Копирование Тогда
		
		КопируемыеДанныеВнешнихИсточников = Элемент.ТекущиеДанные;
		
	Иначе
		
		КопируемыеДанныеВнешнихИсточников = Неопределено;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВнешниеИсточникиПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	ВнешниеИсточникиТекущиеДанные = Элементы.ВнешниеИсточники.ТекущиеДанные;
	
	Если НоваяСтрока Тогда
		
		ИмяВнешнегоИсточника = ИТК_Строки.НовыйИдентификатор(НСтр("ru = 'Таблица';
																	|en = 'Table'"), ИТК_ФормаКлиент.ВыгрузитьКолонкуКоллекции(ВнешниеИсточники, "Имя"));
		ВнешниеИсточникиТекущиеДанные.Имя = ИмяВнешнегоИсточника;
		
		UIDВнешнегоИсточника = Новый УникальныйИдентификатор;
		ВнешниеИсточникиТекущиеДанные.UID = UIDВнешнегоИсточника;
		
		Если Копирование Тогда
			
			Тип = КопируемыеДанныеВнешнихИсточников.Тип;
			
			Если Тип = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаВыражение() Тогда
				
				ИТК_КонсольРазработчикаДанныеКлиент.СкопироватьВнешнийИсточник(ЭтотОбъект, ТекущаяСтрока, ИмяВнешнегоИсточника,
																		UIDВнешнегоИсточника, КопируемыеДанныеВнешнихИсточников.UID);
				
			КонецЕсли;
			
		Иначе
			
			Тип = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаЗначение();
			
		КонецЕсли;
		ВнешниеИсточникиТекущиеДанные.Тип = Тип;
		
		ПоследнийТипВнешнегоИсточника = Тип;
		
		ВнешниеИсточники.Сортировать("Имя");
		
		ОбновитьСтрокуВнешнийИсточник(ВнешниеИсточникиТекущиеДанные);
		ТекущийЭлемент = Элементы.ВнешниеИсточникиИмя;
		
	Иначе
		
		ТекущаяКолонка = Элемент.ТекущийЭлемент;
		ИмяВнешнегоИсточника = ВнешниеИсточникиТекущиеДанные.Имя;
		UIDВнешнегоИсточника = ВнешниеИсточникиТекущиеДанные.UID;
		
		Если СтрНайти(ТекущаяКолонка.Имя, "Имя") Тогда
			
			ЗанятыеИдентификаторы = ИТК_ФормаКлиент.ВыгрузитьКолонкуКоллекции(ВнешниеИсточники, "Имя", ИмяВнешнегоИсточника);
			ИТК_ФормаКлиент.ОткрытьРедактированиеИдентификатора(НСтр("ru = 'Имя внешнего источника';
																	|en = 'External source name'"),
																	ИТК_Перечисления.РежимРедактированияИдентификатораИдентификаторВременнойТаблицы(), ЭтотОбъект,
																	Новый ОписаниеОповещения("ВводИдентификатораВнешнегоИсточникаЗавершен", ЭтотОбъект),
																	ИмяВнешнегоИсточника, ЗанятыеИдентификаторы);
			
		ИначеЕсли СтрНайти(ТекущаяКолонка.Имя, "Представление") Тогда
			
			ДополнительныеПараметры = Новый Структура("UID", UIDВнешнегоИсточника);
			
			ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
			ОписаниеВнешнегоИсточника = ИТК_КонсольРазработчикаДанныеКлиент.ВнешнийИсточник(ТекущиеДанные, UIDВнешнегоИсточника);
			Если ОписаниеВнешнегоИсточника = Неопределено Тогда
				ЗначениеВнешнегоИсточника = Неопределено;
			Иначе
				ЗначениеВнешнегоИсточника = ОписаниеВнешнегоИсточника.Значение;
			КонецЕсли;
			ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("РедактированиеЗначенияВнешнегоИсточникаЗавершено", ЭтотОбъект, ДополнительныеПараметры);
			
			Если ВнешниеИсточникиТекущиеДанные.Тип = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаВыражение() Тогда
				
				ШаблонЗаголовка = НСтр("ru = 'Редактирование выражения (%1): %2';
										|en = 'Expression edit (%1):%2'");
				ЗаголовокФормы = СтрШаблон(ШаблонЗаголовка, ИТК_Строки.ИмяВнешнегоИсточника(), ИмяВнешнегоИсточника);
				
				ДополнительныеПараметры = Новый Структура;
				ДополнительныеПараметры.Вставить("Владелец", ЭтотОбъект);
				ДополнительныеПараметры.Вставить("ОписаниеОповещенияОЗакрытии", ОписаниеОповещенияЗавершение);
				
				ИТК_РедакторКодаКлиент.ОткрытьРедактированиеКодаВОтдельномОкне(ЗаголовокФормы, ЗначениеВнешнегоИсточника, ДополнительныеПараметры);
				
			ИначеЕсли ВнешниеИсточникиТекущиеДанные.Тип = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаЗначение() Тогда
				
				ДополнительныеПараметрыОткрытия = Новый Структура;
				ДополнительныеПараметрыОткрытия.Вставить("ДополнениеЗаголовка", СтрШаблон("(%1): %2", ИТК_Строки.ИмяВнешнегоИсточника(), ИмяВнешнегоИсточника));
				ДополнительныеПараметрыОткрытия.Вставить("НастройкаИндексацииКолонок", Истина);
				ДополнительныеПараметрыОткрытия.Вставить("ОписаниеОповещенияОЗакрытии", ОписаниеОповещенияЗавершение);
				ДополнительныеПараметрыОткрытия.Вставить("Источник", ИмяВнешнегоИсточника);
				
				ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
				ДополнительныеПараметрыОткрытия.Вставить("ДобавляемыеКолонки", ТекущиеДанные.ОписаниеВнешнихИсточников.Получить(ИмяВнешнегоИсточника));
				
				ИТК_ФормаКлиент.ОткрытьТаблицуЗначений(ЗначениеВнешнегоИсточника, ЭтотОбъект, , ДополнительныеПараметрыОткрытия);
				
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВнешниеИсточникиПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	
	Если ОтменаРедактирования Тогда
		Возврат;
	КонецЕсли;
	
	ВнешниеИсточникиТекущиеДанные = Элементы.ВнешниеИсточники.ТекущиеДанные;
	
	ИмяТаблицы = ВнешниеИсточникиТекущиеДанные.Имя;
	ТипТаблицы = ВнешниеИсточникиТекущиеДанные.Тип;
	UIDТаблицы = ВнешниеИсточникиТекущиеДанные.UID;
	
	Если КопируемыеДанныеВнешнихИсточников <> Неопределено
			И ТипТаблицы = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаЗначение() Тогда
		
		ИТК_КонсольРазработчикаДанныеКлиент.СкопироватьВнешнийИсточник(ЭтотОбъект, ТекущаяСтрока, ИмяТаблицы,
																UIDТаблицы, КопируемыеДанныеВнешнихИсточников.UID);
																
	КонецЕсли;
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	ОписаниеВнешнегоИсточника = ИТК_КонсольРазработчикаДанныеКлиент.ВнешнийИсточник(ТекущиеДанные, UIDТаблицы);
	Если ОписаниеВнешнегоИсточника = Неопределено Тогда
		ОписаниеВнешнегоИсточника = ИТК_КонсольРазработчикаДанныеКлиентСервер.НовыйВнешнийИсточник();
	КонецЕсли;
	ОписаниеВнешнегоИсточника.Имя = ИмяТаблицы;
	ОписаниеВнешнегоИсточника.Тип = ТипТаблицы;
	
	ИТК_КонсольРазработчикаДанныеКлиент.ВставитьВнешнийИсточник(ЭтотОбъект, ТекущаяСтрока, UIDТаблицы, ОписаниеВнешнегоИсточника);
	
КонецПроцедуры

&НаКлиенте
Процедура ВнешниеИсточникиПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	
	ВнешниеИсточникиТекущиеДанные = Элементы.ВнешниеИсточники.ТекущиеДанные;
	
	Если ВнешниеИсточникиТекущиеДанные <> Неопределено Тогда
		ПоследнийТипВнешнегоИсточника = ВнешниеИсточникиТекущиеДанные.Тип;
	КонецЕсли;
	
	ОбновитьКоличествоВнешнихИсточников();
	
КонецПроцедуры

&НаКлиенте
Процедура ВнешниеИсточникиПриИзменении(Элемент)
	
	Если Элемент.ТекущийЭлемент = Элементы.ВнешниеИсточникиТип Тогда
		
		ВнешниеИсточникиТекущиеДанные = Элементы.ВнешниеИсточники.ТекущиеДанные;
		НовыйТип = ВнешниеИсточникиТекущиеДанные.Тип;
		Если ЗначениеЗаполнено(НовыйТип) 
				И ПоследнийТипВнешнегоИсточника <> НовыйТип Тогда
			
			ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
			ОписаниеВнешнегоИсточника = ИТК_КонсольРазработчикаДанныеКлиент.ВнешнийИсточник(ТекущиеДанные, ВнешниеИсточникиТекущиеДанные.UID);
			Если ЗначениеЗаполнено(ОписаниеВнешнегоИсточника) Тогда
				
				НовоеЗначение = ОписаниеВнешнегоИсточника.Значение;
				
			Иначе
				
				ОписаниеВнешнегоИсточника = ИТК_КонсольРазработчикаДанныеКлиентСервер.НовыйВнешнийИсточник(ВнешниеИсточникиТекущиеДанные.Имя);
				НовоеЗначение = Неопределено;
				
			КонецЕсли;
			
			ОписаниеВнешнегоИсточника.Тип = НовыйТип;
			ОписаниеВнешнегоИсточника.Значение = ПреобразоватьЗначениеВнешнегоИсточникаКТипу(НовоеЗначение, ПоследнийТипВнешнегоИсточника, НовыйТип);
			ИТК_КонсольРазработчикаДанныеКлиент.ВставитьВнешнийИсточник(ЭтотОбъект, ТекущаяСтрока, ВнешниеИсточникиТекущиеДанные.UID, ОписаниеВнешнегоИсточника);
			
			ПоследнийТипВнешнегоИсточника = НовыйТип;
			ОбновитьСтрокуВнешнийИсточник(ВнешниеИсточникиТекущиеДанные);
			
		КонецЕсли;
		
	КонецЕсли;
	
	ИТК_КонсольРазработчикаДанныеКлиентСервер.ДанныеМодифицированы(ЭтотОбъект);
	ОбновитьКоличествоВнешнихИсточников();
	
КонецПроцедуры

&НаКлиенте
Процедура ВнешниеИсточникиПередУдалением(Элемент, Отказ)
	
	Отказ = Истина;
	
	ШаблонТекстаВопроса = НСтр("ru = 'Выделено : %1
							|Данные будут потеряны. Продолжить?';
							|en = 'Selected: %1
							|Data will be lost. Continue?'");
	ТекстВопроса = СтрШаблон(ШаблонТекстаВопроса, Элемент.ВыделенныеСтроки.Количество());
	
	ЗаголовокВопроса = НСтр("ru = 'Удаление внешних источников';
							|en = 'Deleting external sources'");
	КнопкиВопроса = ИТК_ФормаКлиент.КнопкиВопросаПродолжитьОтмена();
	ОписаниеОповещения = Новый ОписаниеОповещения("ВопросПередУдалениемВнешнегоИсточникаЗавершение", ЭтотОбъект);
	
	ИТК_ФормаКлиент.ЗадатьВопрос(ОписаниеОповещения, ТекстВопроса, КнопкиВопроса, Истина, ЗаголовокВопроса,	ЭтотОбъект, "ПередУдалениемВнешнихИсточников");
	
КонецПроцедуры

&НаКлиенте
Процедура ВнешниеИсточникиТипОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТаблицыМВТ

&НаКлиенте
Процедура ТаблицыМВТПриИзменении(Элемент)
	
	Если Элемент.ТекущийЭлемент = Элементы.ТаблицыМВТТип Тогда
		
		ТаблицыМВТТекущиеДанные = Элементы.ТаблицыМВТ.ТекущиеДанные;
		НовыйТип = ТаблицыМВТТекущиеДанные.Тип;
		Если ЗначениеЗаполнено(НовыйТип) 
				И ПоследнийТипТаблицыМВТ <> НовыйТип Тогда
			
			ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
			ОписаниеТаблицыМВТ = ИТК_КонсольРазработчикаДанныеКлиент.ТаблицаМВТ(ТекущиеДанные, ТаблицыМВТТекущиеДанные.UID);
			Если ЗначениеЗаполнено(ОписаниеТаблицыМВТ) Тогда
				НовоеЗначение = ОписаниеТаблицыМВТ.Значение;
			Иначе
				
				ОписаниеТаблицыМВТ = ИТК_КонсольРазработчикаДанныеКлиентСервер.НоваяТаблицаМВТ(ТаблицыМВТТекущиеДанные.Имя);
				НовоеЗначение = Неопределено;
				
			КонецЕсли;
			
			ОписаниеТаблицыМВТ.Тип = НовыйТип;
			ОписаниеТаблицыМВТ.Значение = ПреобразоватьЗначениеВнешнегоИсточникаКТипу(НовоеЗначение, ПоследнийТипТаблицыМВТ, НовыйТип);
			ИТК_КонсольРазработчикаДанныеКлиент.ВставитьТаблицуМВТ(ЭтотОбъект, ТекущаяСтрока, ТаблицыМВТТекущиеДанные.UID, ОписаниеТаблицыМВТ);
			
			ПоследнийТипТаблицыМВТ = НовыйТип;
			ОбновитьСтрокуТаблицыМВТ(ТаблицыМВТТекущиеДанные);
			
		КонецЕсли;
		
	КонецЕсли;
	
	ИТК_КонсольРазработчикаДанныеКлиентСервер.ДанныеМодифицированы(ЭтотОбъект);
	ОбновитьКоличествоТаблицМВТ();
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицыМВТПриАктивизацииСтроки(Элемент)
	
	ТаблицыМВТТекущиеДанные = Элементы.ТаблицыМВТ.ТекущиеДанные;
	
	Если ТаблицыМВТТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТаблицыМВТТекущиеДанные.Тип) Тогда // Без этого условия при копировании заносит пустое значение и обновляет внешний источник пустым
		ПоследнийТипТаблицыМВТ = ТаблицыМВТТекущиеДанные.Тип;
	КонецЕсли;
	
	ОбновитьСтрокуТаблицыМВТ(ТаблицыМВТТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицыМВТПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	Если Копирование Тогда
		КопируемыеДанныеТаблицМВТ = Элемент.ТекущиеДанные;
	Иначе
		КопируемыеДанныеТаблицМВТ = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицыМВТПередУдалением(Элемент, Отказ)
	
	Отказ = Истина;
	
	ШаблонТекстаВопроса = НСтр("ru = 'Выделено : %1
							|Данные будут потеряны. Продолжить?';
							|en = 'Selected: %1
							|Data will be lost. Continue?'");
	ТекстВопроса = СтрШаблон(ШаблонТекстаВопроса, Элемент.ВыделенныеСтроки.Количество());
	
	ЗаголовокВопроса = НСтр("ru = 'Удаление таблиц МВТ';
							|en = 'Removing TTM tables'");
	КнопкиВопроса = ИТК_ФормаКлиент.КнопкиВопросаПродолжитьОтмена();
	ОписаниеОповещения = Новый ОписаниеОповещения("ВопросПередУдалениемТаблицыМВТЗавершение", ЭтотОбъект);
	
	ИТК_ФормаКлиент.ЗадатьВопрос(ОписаниеОповещения, ТекстВопроса, КнопкиВопроса, Истина, ЗаголовокВопроса,	ЭтотОбъект, "ПередУдалениемВнешнихИсточников");
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицыМВТПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	
	Если ОтменаРедактирования Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицыМВТТекущиеДанные = Элементы.ТаблицыМВТ.ТекущиеДанные;
	
	ИмяТаблицы = ТаблицыМВТТекущиеДанные.Имя;
	ТипТаблицы = ТаблицыМВТТекущиеДанные.Тип;
	UIDТаблицы = ТаблицыМВТТекущиеДанные.UID;
	
	Если КопируемыеДанныеТаблицМВТ <> Неопределено
			И ТипТаблицы = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаЗначение() Тогда
		
		ИТК_КонсольРазработчикаДанныеКлиент.СкопироватьТаблицуМВТ(ЭтотОбъект, ТекущаяСтрока, ИмяТаблицы,
																UIDТаблицы, КопируемыеДанныеТаблицМВТ.UID);
																
	КонецЕсли;
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	ОписаниеТаблицыМВТ = ИТК_КонсольРазработчикаДанныеКлиент.ТаблицаМВТ(ТекущиеДанные, UIDТаблицы);
	Если ОписаниеТаблицыМВТ = Неопределено Тогда
		ОписаниеТаблицыМВТ = ИТК_КонсольРазработчикаДанныеКлиентСервер.НоваяТаблицаМВТ();
	КонецЕсли;
	ОписаниеТаблицыМВТ.Имя = ИмяТаблицы;
	ОписаниеТаблицыМВТ.Тип = ТипТаблицы;
	
	ИТК_КонсольРазработчикаДанныеКлиент.ВставитьТаблицуМВТ(ЭтотОбъект, ТекущаяСтрока, UIDТаблицы, ОписаниеТаблицыМВТ);
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицыМВТПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	
	ТаблицыМВТТекущиеДанные = Элементы.ТаблицыМВТ.ТекущиеДанные;
	
	Если ТаблицыМВТТекущиеДанные <> Неопределено Тогда
		ПоследнийТипТаблицыМВТ = ТаблицыМВТТекущиеДанные.Тип;
	КонецЕсли;
	
	ОбновитьКоличествоТаблицМВТ();
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицыМВТТипОчистка(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСтруктураСКД

&НаКлиенте
Процедура СтруктураСКДПриАктивизацииПоля(Элемент)
	
	ВыбраннаяСтраница = Неопределено;
	ИмяПоля = Элемент.ТекущийЭлемент.Имя;
	
	Если СтрНайти(ИмяПоля, "СтруктураНаличиеВыбора") Тогда
		ВыбраннаяСтраница = Элементы.СтраницаСКДПоляВыбора;
	ИначеЕсли СтрНайти(ИмяПоля, "СтруктураНаличиеОтбора") Тогда
		ВыбраннаяСтраница = Элементы.СтраницаСКДОтбор;
	ИначеЕсли СтрНайти(ИмяПоля, "СтруктураНаличиеПорядка") Тогда
		ВыбраннаяСтраница = Элементы.СтраницаСКДПорядок;
	ИначеЕсли СтрНайти(ИмяПоля, "СтруктураНаличиеУсловногоОформления") Тогда
		ВыбраннаяСтраница = Элементы.СтраницаСКДУсловноеОформление;
	ИначеЕсли СтрНайти(ИмяПоля, "СтруктураНаличиеПараметровВывода") Тогда
		ВыбраннаяСтраница = Элементы.СтраницаСКДПараметрыДанных;
	КонецЕсли;
	
	Если ВыбраннаяСтраница <> Неопределено Тогда
		ТекущийЭлемент = Элементы.СтраницыНастройкиСКД;
		Элементы.СтраницыНастройкиСКД.ТекущаяСтраница = ВыбраннаяСтраница;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СтруктураСКДПриАктивизацииСтроки(Элемент)
	
	ЭлементСтруктуры = КомпоновщикНастроек.Настройки.ПолучитьОбъектПоИдентификатору(Элементы.СКДСтруктура.ТекущаяСтрока);
	ТипЭлемента = ТипЗнч(ЭлементСтруктуры); 
	
	ЭтоКоллекция	= ТипЭлемента = Неопределено  
						ИЛИ ТипЭлемента = Тип("КоллекцияЭлементовСтруктурыДиаграммыКомпоновкиДанных") 
						ИЛИ ТипЭлемента = Тип("КоллекцияЭлементовСтруктурыТаблицыКомпоновкиДанных");
	ЭтоНастройка	= ТипЭлемента = Тип("НастройкиКомпоновкиДанных") 
						ИЛИ ТипЭлемента = Тип("НастройкиВложенногоОбъектаКомпоновкиДанных");
	ЭтоГруппировка	= ТипЭлемента = Тип("ГруппировкаКомпоновкиДанных") 
						ИЛИ ТипЭлемента = Тип("ГруппировкаТаблицыКомпоновкиДанных") 
						ИЛИ ТипЭлемента = Тип("ГруппировкаДиаграммыКомпоновкиДанных");								
	ЭтаТаблицаДиаграмма = ТипЭлемента = Тип("ТаблицаКомпоновкиДанных") 
						ИЛИ ТипЭлемента = Тип("ДиаграммаКомпоновкиДанных");
						
	// Поля группировки
	Если ЭтоГруппировка Тогда
		Элементы.СтраницыСКДПолейГруппировки.ТекущаяСтраница = Элементы.НастройкиСКДПолейГруппировки;
	КонецЕсли;
	
	// Выбранные поля
	НаличиеВыбораУЭлемента = КомпоновщикНастроек.Настройки.НаличиеВыбораУЭлемента(ЭлементСтруктуры)
								ИЛИ ЭтоНастройка;
	СКДЛокальныеВыбранныеПоля = НаличиеВыбораУЭлемента;
	Элементы.СКДЛокальныеВыбранныеПоля.ТолькоПросмотр = ЭтоКоллекция ИЛИ ЭтоНастройка;
	Если ЭтоКоллекция Тогда
		ТекущаяСтраницаПоляВыбора = Элементы.СКДНедоступныеНастройкиВыбранныхПолей;
	ИначеЕсли НаличиеВыбораУЭлемента Тогда
		ТекущаяСтраницаПоляВыбора = Элементы.СКДНастройкиВыбранныхПолей;
	Иначе
		ТекущаяСтраницаПоляВыбора = Элементы.СКДОтключенныеНастройкиВыбранныхПолей;
	КонецЕсли;
	Элементы.СтраницыСКДПоляВыбора.ТекущаяСтраница = ТекущаяСтраницаПоляВыбора;
	
	// Отбор
	НаличиеОтбораУЭлемента = КомпоновщикНастроек.Настройки.НаличиеОтбораУЭлемента(ЭлементСтруктуры)
								ИЛИ ЭтоНастройка;
	СКДЛокальныйОтбор = НаличиеОтбораУЭлемента;
	Элементы.СКДЛокальныйОтбор.ТолькоПросмотр = ЭтоНастройка ИЛИ ЭтаТаблицаДиаграмма;
	Если ЭтоКоллекция ИЛИ ЭтаТаблицаДиаграмма Тогда
		ТекущаяСтраницаОтбор = Элементы.СКДНедоступныеНастройкиОтбора;
	ИначеЕсли НаличиеОтбораУЭлемента Тогда
		ТекущаяСтраницаОтбор = Элементы.СКДНастройкиОтбора;
	Иначе	
		ТекущаяСтраницаОтбор = Элементы.СКДОтключенныеНастройкиОтбора;
	КонецЕсли;
	Элементы.СКДСтраницыОтбора.ТекущаяСтраница = ТекущаяСтраницаОтбор;
	
	// Порядок
	НаличиеПорядкаУЭлемента = КомпоновщикНастроек.Настройки.НаличиеПорядкаУЭлемента(ЭлементСтруктуры)
								ИЛИ ЭтоНастройка;
	СКДЛокальныйПорядок = НаличиеПорядкаУЭлемента;
	Элементы.СКДЛокальныйПорядок.ТолькоПросмотр = ЭтоНастройка ИЛИ ЭтаТаблицаДиаграмма;
	Если ЭтоКоллекция ИЛИ ЭтаТаблицаДиаграмма Тогда
		ТекущаяСтраницаПорядок = Элементы.СКДНедоступныеНастройкиПорядка;
	ИначеЕсли СКДЛокальныйПорядок Тогда
		ТекущаяСтраницаПорядок = Элементы.СКДНастройкиПорядка;
	Иначе
		ТекущаяСтраницаПорядок = Элементы.СКДОтключенныеНастройкиПорядка;
	КонецЕсли;
	Элементы.СтраницыСКДПорядок.ТекущаяСтраница = ТекущаяСтраницаПорядок;
	
	// Условное оформление
	НаличиеУсловногоОформленияУЭлемента = КомпоновщикНастроек.Настройки.НаличиеУсловногоОформленияУЭлемента(ЭлементСтруктуры);
	СКДЛокальноеУсловноеОформление = НаличиеУсловногоОформленияУЭлемента;
	Элементы.СКДЛокальноеУсловноеОформление.ТолькоПросмотр = ЭтоКоллекция;
	Если ЭтоКоллекция Тогда
		ТекущаяСтраницаУсловноеОформление = Элементы.СКДНедоступныеНастройкиУсловногоОформления;
	ИначеЕсли СКДЛокальноеУсловноеОформление Тогда
		ТекущаяСтраницаУсловноеОформление = Элементы.СКДНастройкиУсловногоОформления;
	Иначе
		ТекущаяСтраницаУсловноеОформление = Элементы.СКДОтключенныеНастройкиУсловногоОформления;
	КонецЕсли;
	Элементы.СтраницыСКДУсловногоОформления.ТекущаяСтраница = ТекущаяСтраницаУсловноеОформление;
	
	// Параметры вывода
	НаличиеПараметровВыводаУЭлемента = КомпоновщикНастроек.Настройки.НаличиеПараметровВыводаУЭлемента(ЭлементСтруктуры);
	СКДЛокальныеПараметрыВывода = НаличиеПараметровВыводаУЭлемента;
	Элементы.СКДЛокальныеПараметрыВывода.ТолькоПросмотр = ЭтоКоллекция;
	Если ЭтоКоллекция Тогда
		ТекущаяСтраницаПараметрыВывода = Элементы.СКДНедоступныеНастройкиПараметровВывода;
	ИначеЕсли НаличиеПараметровВыводаУЭлемента Тогда
		ТекущаяСтраницаПараметрыВывода = Элементы.СКДНастройкиПараметровВывода;
	Иначе
		ТекущаяСтраницаПараметрыВывода = Элементы.СКДОтключенныеНастройкиПараметровВывода;
	КонецЕсли;
	Элементы.СтраницыСКДПараметрыВывода.ТекущаяСтраница = ТекущаяСтраницаПараметрыВывода;
						
КонецПроцедуры

