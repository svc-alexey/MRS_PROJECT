КонецПроцедуры

&НаКлиенте
Процедура ЗамерПакетаЗапросов(Команда)
	
	Если ИТК_ТуллкитКлиент.ПоказатьПредупреждениеНедоступноВОграниченнойВерсии() Тогда
		Возврат;
	КонецЕсли;
	
	ОписаниеОперации = Новый Структура;
	ОписаниеОперации.Вставить("Источник", ИТК_Перечисления.ИнструментКонсольРазработчика());
	ОписаниеОперации.Вставить("Наименование", НСтр("ru = 'Получение результата для обработки';
													|en = 'Getting the result for processing'"));
	
	Если ЗапускНевозможенПроверкаОповещение(ОписаниеОперации.Наименование) Тогда
		Возврат;
	КонецЕсли;
	
	ИТК_ДлительныеОперацииКлиент.НачатьОперацию(ЭтотОбъект, Новый ОписаниеОповещения("НачалоДлительнойОперации", ЭтотОбъект), ОписаниеОперации);
	
	Данные = ПодготовитьДанныеПередВыполнением(ТекущаяСтрока);
	
	ФоновоеВыполнение = ИТК_БСПКлиентСервер.ВозможноВыполнениеВФоне();
	ДлительнаяОперация = ЗапуститьЗамераПакетногоЗапросаНаСервере(Данные, УникальныйИдентификатор, ФоновоеВыполнение);
	ИТК_ДлительныеОперацииКлиент.ЗаполнитьОписаниеОперации(ДлительнаяОперация, ОписаниеОперации);
	
	ОповещениеОПрогрессеВыполнения = Новый ОписаниеОповещения("ОбработкаПрогрессаВыполненияДлительнойОперации", ЭтотОбъект);
	ПараметрыОжидания = ИТК_ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект, ОповещениеОПрогрессеВыполнения);
	
	ИТК_ДлительныеОперацииКлиент.ДобавитьОповещениеПользователя(ЭтотОбъект, ПараметрыОжидания);
		
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершениеЗамераПакетногоЗапроса", ЭтотОбъект);
	ИТК_ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьКод(Команда)
	
	ДобавитьСтрокуВДеревоДанных(ИТК_Перечисления.ЭлементДанныхКод());
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапросВнешнегоИсточника(Команда)
	
	ВнешниеИсточникиТекущиеДанные = Элементы.ВнешниеИсточники.ТекущиеДанные;	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	
	ОписаниеИсточника = ИТК_КонсольРазработчикаДанныеКлиент.ВнешнийИсточник(ТекущиеДанные, ВнешниеИсточникиТекущиеДанные.UID);
	
	Если ОписаниеИсточника.Значение = Неопределено Тогда
		
		ТекстПредупреждения = НСтр("ru = 'Пустой внешний источник (нет колонок)';
									|en = 'Empty external source (no columns)'");
		ПоказатьПредупреждение( , ТекстПредупреждения, , ИТК_КонсольРазработчикаКлиентСервер.Представление());
		Возврат;
		
	КонецЕсли;
	
	КолонкиИсточника = КолонкиВнешнегоИсточника(ОписаниеИсточника);
	ИТК_ОбщийКлиент.ОткрытьЗапросИсточника(ЭтотОбъект, КолонкиИсточника, ОписаниеИсточника.Имя);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьДанныеОтладкиИзСтроки(Команда)
	
	Текст = ИТК_БуферОбменаКлиент.Текст();
	КорректныйТекст = СтрНачинаетсяС(Текст, "<Structure");
	
	Если НЕ КорректныйТекст Тогда
		
		ПоказатьПредупреждение( , НСтр("ru = 'Буфер обмена должен содержать XML текст вида: <Structure...
                                       |Полученный функцией БСП:  ОбщегоНазначения.ЗапросВСтрокуXML';
                                       |en = 'The clipboard must contain XML text of the form: <Structure ...
                                       |Received by function SSL: ОбщегоНазначения.ЗапросВСтрокуXML in XML String'"),
										, ИТК_КонсольРазработчикаКлиентСервер.Представление());
		Возврат;
		
	КонецЕсли;
	
	ОписаниеОповещения = ОповещениеЗагрузкиДанных("ОбработчикЗагрузитьДанныеОтладкиИзБуфераОбмена");
	ЗапуститьОбработчикСПроверкойНаСохранностьДанных(ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура СтекВызововПоОшибке(Команда)
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	
	СтекВызовов = ТекущиеДанные.ОшибкаПриВыполнении.СтекВызовов;
	ИТК_ФормаКлиент.ОткрытьСтекВызовов(ЭтотОбъект, СтекВызовов);
	
КонецПроцедуры

