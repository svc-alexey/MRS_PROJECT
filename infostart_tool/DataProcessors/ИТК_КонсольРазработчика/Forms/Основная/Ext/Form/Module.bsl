&НаКлиенте
Процедура СравнитьРезультаты(Команда)
	
	НеизменяемыеПоля = Новый Структура;
	НеизменяемыеПоля.Вставить("ОбъектЭталон");
	НеизменяемыеПоля.Вставить("ТипОбъектов");
	НеизменяемыеПоля.Вставить("ТипСравнения");
	
	ДополнительныеПараметры = Новый Структура;
	
	Строка = НайтиСтрокуПоUID(ДеревоДанных, ТекущийРезультат.АктуаленПоСтроке);
	ДополнительныеПараметры.Вставить("ТипОбъектов", Строка.Тип);
	ДополнительныеПараметры.Вставить("ТипСравнения", ИТК_Перечисления.ВариантСравненияДанныхРезультаты());
	ДополнительныеПараметры.Вставить("НеизменяемыеПоля", НеизменяемыеПоля);
	
	ОткрытьФормуСравнения(Строка, ДополнительныеПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура СравнитьСтроки(Команда)
	
	ВыделенныеСтроки = Элементы.ДеревоДанных.ВыделенныеСтроки;
	
	СписокОшибок = Новый Массив;
	
	// Определим есть ли строки группы и не выделены разные типы строк
	ЕстьСтрокаГруппа = Ложь; НесовместимыеТипыСтрок = Ложь; ПоследнийТипСтроки = Неопределено;
	Для Каждого ИдентификаторВыделеннойСтроки Из ВыделенныеСтроки Цикл 
		
		ВыделеннаяСтрока = ДеревоДанных.НайтиПоИдентификатору(ИдентификаторВыделеннойСтроки);

		Если ВыделеннаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхГруппа() Тогда
			ЕстьСтрокаГруппа = Истина;
		КонецЕсли;
		
		Если ПоследнийТипСтроки <> Неопределено Тогда 
			
			Если ПоследнийТипСтроки <> ВыделеннаяСтрока.Тип
					И Не (ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоОдинИзТиповСтрокиСКД(ПоследнийТипСтроки) 
							И ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоОдинИзТиповСтрокиСКД(ВыделеннаяСтрока.Тип))	Тогда
				НесовместимыеТипыСтрок = Истина;
			КонецЕсли;
			
		КонецЕсли;
			
		ПоследнийТипСтроки = ВыделеннаяСтрока.Тип;
		
	КонецЦикла;
	
	Если ЕстьСтрокаГруппа Тогда
		СписокОшибок.Добавить(НСтр("ru = 'Нельзя выбирать группы';
									|en = 'You cannot select groups'"));
	КонецЕсли;
	Если ВыделенныеСтроки.Количество() > 2 Тогда
		СписокОшибок.Добавить(НСтр("ru = 'Необходимо выделять не более 2-х строк';
									|en = 'It is necessary to select no more than 2 lines'"));
	КонецЕсли;
	Если НесовместимыеТипыСтрок Тогда
		СписокОшибок.Добавить(НСтр("ru = 'Несовместимые типы строк';
									|en = 'Incompatible string types'"));
	КонецЕсли;
	Если ВыделенныеСтроки.Количество() = 0 Тогда
		СписокОшибок.Добавить(НСтр("ru = 'Нет выделенных строк';
									|en = 'No rows selected'"));
	КонецЕсли;
	
	Если СписокОшибок.Количество() > 0 Тогда
		
		ТекстПредупреждения = СтрШаблон(НСтр("ru = 'Проблема сравнения: %1';
											|en = 'Comparison problem: %1'"), СтрСоединить(СписокОшибок, ", "));
		ПоказатьПредупреждение( , ТекстПредупреждения, , ИТК_КонсольРазработчикаКлиентСервер.Представление());
		Возврат;
		
	КонецЕсли;
	
	НеизменяемыеПоля = Новый Структура;
	НеизменяемыеПоля.Вставить("ОбъектЭталон");
	НеизменяемыеПоля.Вставить("ТипОбъектов");
	
	СтрокаЭталон = ДеревоДанных.НайтиПоИдентификатору(ВыделенныеСтроки[0]);
	СтрокаНовый = Неопределено;
	Если ВыделенныеСтроки.Количество() > 1 Тогда
		СтрокаНовый = ДеревоДанных.НайтиПоИдентификатору(ВыделенныеСтроки[1]);
		НеизменяемыеПоля.Вставить("ОбъектНовый");
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("СтрокаНовый", СтрокаНовый);
	ДополнительныеПараметры.Вставить("ТипОбъектов", СтрокаЭталон.Тип);
	ДополнительныеПараметры.Вставить("НеизменяемыеПоля", НеизменяемыеПоля);
	
	ОткрытьФормуСравнения(СтрокаЭталон, ДополнительныеПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьНастройку(Команда)
	
	ОписаниеОповещения = ОписаниеОбработчикаЗагрузкиНастройки();
	ЗапуститьОбработчикСПроверкойНаСохранностьДанных(ОписаниеОповещения);

КонецПроцедуры

&НаКлиенте
Процедура ОбъединитьСНастройкой(Команда)
	
	ОписаниеОповещения = ОписаниеОбработчикаЗагрузкиНастройки(Истина);
	ВыполнитьОбработкуОповещения(ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьКакНастройку(Команда = Неопределено)
	
	ТекущееИмяНастройки = Неопределено;
	Если РабочиеДанные.Тип = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда
		ТекущееИмяНастройки = РабочиеДанные.Имя;
	КонецЕсли;
	
	КлючНастроек = ИТК_КонсольРазработчикаДанныеКлиентСервер.КлючНастроек();
	ОписаниеОповещения = Новый ОписаниеОповещения("СохранениеНастройкиЗавершено", ЭтотОбъект);
	ИТК_ФормаКлиент.ОткрытьДиалогВыбораНастроекДанных(ЭтотОбъект, ИТК_Перечисления.РежимДиалогаУправлениеДаннымиВНастройкахСохранение(),
														КлючНастроек, ТекущееИмяНастройки, ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьРезультатВОтдельномОкне(Команда)
	
	Если Не ЗначениеЗаполнено(ТекущийРезультат.Адрес) Тогда
		ПоказатьПредупреждение( , НСтр("ru = 'Нет результата для просмотра в отдельном окне';
										|en = 'No result to view in separate window'"), , ИТК_КонсольРазработчикаКлиентСервер.Представление());
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Имя", ТекущаяСтрока.Имя);
	ПараметрыФормы.Вставить("АдресРезультата", ТекущийРезультат.Адрес);
	ПараметрыФормы.Вставить("АдресДанныхРасшифровки", ТекущийРезультат.АдресДанныхРасшифровки);
	ПараметрыФормы.Вставить("ФиксацияШапки", Элементы.КнопкаФиксацияШапки.Пометка);
	ПараметрыФормы.Вставить("ФиксацияШапкиДоступность", Элементы.КнопкаФиксацияШапки.Доступность);
	ПараметрыФормы.Вставить("ВсеСтрокиВыведены", ТекущийРезультат.ВсеСтрокиВыведены);
	
	Если ЗначениеЗаполнено(ТекущийРезультат.АдресСхемыКомпоновкиДанных) Тогда
		ПараметрыФормы.Вставить("АдресСхемыКомпоновкиДанных", ТекущийРезультат.АдресСхемыКомпоновкиДанных);
	КонецЕсли;

	ОткрытьФорму("Обработка.ИТК_КонсольРазработчика.Форма.РезультатВОтдельномОкне", ПараметрыФормы, , Новый УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПараметр(Команда)

	ТекущиеДанные = Элементы.ПараметрыЗапроса.ТекущиеДанные;
	
	ИменаПараметров = Новый Массив;
	ИменаПараметров.Добавить(ТекущиеДанные.Имя);
	
	ДанныеЗаполнения = ПодготовитьДанныеЗаполненияПараметров(ИменаПараметров, ДеревоДанных);
	
	ОбработатьЗаполняемыеПараметры(ДанныеЗаполнения, ИменаПараметров);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПараметры(Команда)
	
	ИменаПараметров = Новый Массив;
	Для Каждого СтрокаПараметрЗапроса Из ПараметрыЗапроса Цикл 
		ИменаПараметров.Добавить(СтрокаПараметрЗапроса.Имя);
	КонецЦикла;
	
	ДанныеЗаполнения = ПодготовитьДанныеЗаполненияПараметров(ИменаПараметров, ДеревоДанных);
	ОбработатьЗаполняемыеПараметры(ДанныеЗаполнения, ИменаПараметров);
	
КонецПроцедуры

&НаКлиенте
Процедура ПереименоватьПараметр(Команда = Неопределено)
	
	ПараметрЗапросаТекущиеДанные = Элементы.ПараметрыЗапроса.ТекущиеДанные;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Имя", ПараметрЗапросаТекущиеДанные.Имя);
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	ВсеПараметры = Новый СписокЗначений;
	Для Каждого Параметр Из ТекущиеДанные.Параметры Цикл 
		
		Если Параметр.Ключ = ПараметрЗапросаТекущиеДанные.Имя Тогда
			Продолжить;
		КонецЕсли;
		
		ВсеПараметры.Добавить(Параметр.Ключ);
		
	КонецЦикла;
	ПараметрыФормы.Вставить("ВсеПараметры", ВсеПараметры);
	
	ДополнительныеПараметры = Новый Структура("Имя", ПараметрЗапросаТекущиеДанные.Имя);
	ОписаниеОповещения = Новый ОписаниеОповещения("ПереименованиеПараметраЗавершено", ЭтотОбъект, ДополнительныеПараметры);
	ОткрытьФорму("Обработка.ИТК_КонсольРазработчика.Форма.ПереименованиеПараметра", ПараметрыФормы, ЭтотОбъект, , , , ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьТипПараметра(Команда)
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	
	ИменаПараметров = Новый Массив;
	ОписаниеТиповПараметров = Неопределено;
	Для Каждого ИдентификаторСтрокиПараметр Из Элементы.ПараметрыЗапроса.ВыделенныеСтроки Цикл 
		
		СтрокаПараметр = ПараметрыЗапроса.НайтиПоИдентификатору(ИдентификаторСтрокиПараметр);
		ИменаПараметров.Добавить(СтрокаПараметр.Имя);
		
		ОписаниеТиповПараметра = ТекущиеДанные.Параметры[СтрокаПараметр.Имя];
		
		Если ОписаниеТиповПараметров = Неопределено Тогда
			ОписаниеТиповПараметров = ОписаниеТиповПараметра;
		Иначе
			ОписаниеТиповПараметров = ИТК_ТипыКлиентСервер.СложитьОписания(ОписаниеТиповПараметров, ОписаниеТиповПараметра);
		КонецЕсли;
		
	КонецЦикла;
	
	ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("ПреобразованиеТипаЗначенияПараметраЗавершено", ЭтотОбъект, Новый Структура);

	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ДополнятьДату", Истина);
	
	ПредставлениеИменПараметров = СтрСоединить(ИменаПараметров, ", ");
	ИТК_ФормаКлиент.ОткрытьРедактированиеТипаЗначения(ЭтотОбъект, СтрШаблон(НСтр("ru = 'Параметр(ы) ""%1""';
																				|en = 'Parameter(s) ""%1""'"), ПредставлениеИменПараметров), 
									ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборТипа(), ОписаниеТиповПараметров,
									ОписаниеОповещенияЗавершение, , ДополнительныеПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаменитьПараметрВТекстеНаЗначение(Команда)
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	
	ПараметрЗапросаТекущиеДанные = Элементы.ПараметрыЗапроса.ТекущиеДанные;
	ИмяПараметра = ПараметрЗапросаТекущиеДанные.Имя;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Имя", ИмяПараметра);
	ОписаниеОповещенияОЗавершении = Новый ОписаниеОповещения("ЗаменаПараметраВТекстеНаЗначениеЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	
	Результат = ИТК_Запрос.АнализПреобразованияПараметраВЗначение(ТекущиеДанные, ИмяПараметра);
	Если Результат.Преобразуется = 0 Тогда
		
		ТекстПредупреждения = НСтр("ru = 'Невозможно преобразовать значение параметра в значение';
									|en = 'Cannot convert parameter value to value'");
		ПоказатьПредупреждение(, ТекстПредупреждения, ,	ИТК_КонсольРазработчикаКлиентСервер.Представление());
		
	ИначеЕсли ЗначениеЗаполнено(Результат.Потеряно) Тогда
		
		ЗаголовокВопроса = НСтр("ru = 'Замена значения параметра на ЗНАЧЕНИЕ';
								|en = 'Replacing a parameter value with VALUE'");
		ТекстВопроса = НСтр("ru = 'При замене часть значений будет потеряно. Продолжить?';
							|en = 'When replacing, part of the values will be lost. Proceed?'");
		КнопкиВопроса = ИТК_ФормаКлиент.КнопкиВопросаПродолжитьОтмена();

		ИТК_ФормаКлиент.ЗадатьВопрос(ОписаниеОповещенияОЗавершении, ТекстВопроса, КнопкиВопроса, Истина, ЗаголовокВопроса, ЭтотОбъект, "ПередЗаменойПараметраНаЗначение");
		
	Иначе
		
		ВыполнитьОбработкуОповещения(ОписаниеОповещенияОЗавершении, Истина);
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ФормаВыбораУниверсальнаяЗначениеПараметра(Команда)
	
	ПараметрыЗапросаТекущиеДанные = Элементы.ПараметрыЗапроса.ТекущиеДанные;
	Если ПараметрыЗапросаТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеПараметра = ДанныеПараметраЗапроса(ТекущаяСтрока, ПараметрыЗапросаТекущиеДанные.Имя);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("РежимВыбора", Истина);
	ДополнительныеПараметры.Вставить("ЗакрыватьПриВыборе", Истина);
		
	ОписаниеОповещенияОЗакрытии = Новый ОписаниеОповещения("ЗавершенВыборЗначенияПараметра", ЭтотОбъект);
	ДополнительныеПараметры.Вставить("ОписаниеОповещенияОЗакрытии", ОписаниеОповещенияОЗакрытии);
		
	ДополнительныеПараметры.Вставить("Ключ", ДанныеПараметра.Значение);

	ИТК_ФормаКлиент.ОткрытьУниверсальнуюФормуСписка(ДанныеПараметра.Значение, ЭтотОбъект, ДополнительныеПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаРезультата(Команда)
	
	ОписаниеОперации = Новый Структура;
	ОписаниеОперации.Вставить("Источник", ИТК_Перечисления.ИнструментКонсольРазработчика());
	ОписаниеОперации.Вставить("Наименование", НСтр("ru = 'Получение результата для обработки';
													|en = 'Getting the result for processing'"));
	
	Если ЗапускНевозможенПроверкаОповещение(ОписаниеОперации.Наименование) Тогда
		Возврат;
	КонецЕсли;
	
	ИТК_ДлительныеОперацииКлиент.НачатьОперацию(ЭтотОбъект, Новый ОписаниеОповещения("НачалоДлительнойОперации", ЭтотОбъект), ОписаниеОперации);
	
	Данные = ПодготовитьДанныеПередВыполнением(ТекущаяСтрока);
	
	ФоновоеВыполнение = ИТК_БСПКлиентСервер.ВозможноВыполнениеВФоне();
	ДлительнаяОперация = ЗапуститьПолучениеРезультатаДляОбработкиНаСервере(Данные, УникальныйИдентификатор, ФоновоеВыполнение);
	ИТК_ДлительныеОперацииКлиент.ЗаполнитьОписаниеОперации(ДлительнаяОперация, ОписаниеОперации);
	
	ОповещениеОПрогрессеВыполнения = Новый ОписаниеОповещения("ОбработкаПрогрессаВыполненияДлительнойОперации", ЭтотОбъект);
	ПараметрыОжидания = ИТК_ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект, ОповещениеОПрогрессеВыполнения);
	
	ИТК_ДлительныеОперацииКлиент.ДобавитьОповещениеПользователя(ЭтотОбъект, ПараметрыОжидания);
		
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("UID", ТекущаяСтрока.UID);
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершениеПолученияРезультатаДляОбработки", ЭтотОбъект, ДополнительныеПараметры);
	
	ИТК_ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаКлиенте
Процедура АнализироватьПланЗапроса(Команда)
	
	Если ИТК_ТуллкитКлиент.ПоказатьПредупреждениеНедоступноВОграниченнойВерсии() Тогда
		Возврат;
	КонецЕсли;
	
	// Необходимо подождать т.к. запись в файл технологического журнала иногда не успевает
	Пока ИТК_ОбщийВызовСервера.ТекущаяДатаСервера() < ТекущийРезультат.ОкончаниеВыполненияНаКлиенте + 3 Цикл // +3 секунды
	КонецЦикла;
	
	ПолноеИмяФайлаЖурнала = ИТК_АнализПланаЗапроса.ПолноеИмяLogФайлаТехнологическогоЖурнала(ТекущийРезультат.IDПроцесса, ТекущийРезультат.НачалоВыполнения);
	
	Если ПолноеИмяФайлаЖурнала = Неопределено Тогда
		
		ПоказатьПредупреждение(, НСтр("ru = 'Не удалось найти файл логов на сервере (возможно не включен технологический журнал)';
										|en = 'Log file could not be found on the server (technology log may not be enabled)'"), , ИТК_КонсольРазработчикаКлиентСервер.Представление());
		
	Иначе
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Имя", ТекущаяСтрока.Имя);
		ПараметрыФормы.Вставить("UID", ТекущийРезультат.UID);
		ПараметрыФормы.Вставить("ОписанияТиповПараметров", ТекущийРезультат.ОписанияТиповПараметров);
		ПараметрыФормы.Вставить("ИмяФайла", ПолноеИмяФайлаЖурнала);
		
		ОткрытьФорму("Обработка.ИТК_КонсольРазработчика.Форма.АнализПланаЗапроса", ПараметрыФормы, ЭтотОбъект, , , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура АнализИсполняемыхЗапросов(Команда)
	
	Если ИТК_ТуллкитКлиент.ПоказатьПредупреждениеНедоступноВОграниченнойВерсии() Тогда
		Возврат;
	КонецЕсли;
	
	ВыполнитьОперацию(ИТК_Перечисления.РежимВыполненияСКДПолучениеИсполняемыхЗапросов());

КонецПроцедуры

&НаКлиенте
Процедура ЭкспортВоВнешнийОтчет(Команда)
	
	Если ЗапускНевозможенПроверкаОповещение(НСтр("ru = 'Экспорт во внешний отчет (erf)';
												|en = 'Export to external report (erf)'")) Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Имя", ТекущаяСтрока.Имя);
	ПараметрыФормы.Вставить("Данные", ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока));

	ОткрытьФорму("Обработка.ИТК_КонсольРазработчика.Форма.ЭкспортВоВнешнийОтчет", ПараметрыФормы, ЭтотОбъект, , , , 
					Новый ОписаниеОповещения("ЭкспортВоВнешнийОтчетФайлаЗакончен", ЭтотОбъект),
					РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ВидНастройкиДанных(Команда)
	
	СохранитьИзмененныеДанныеСтроки();

	Элемент = Элементы.ФормаВидВидНастройкиДанных;
	Элемент.Пометка = Не Элемент.Пометка;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ВидДеревоДанных(Команда)
	
	Элемент = Элементы.ФормаВидВидДеревоДанных;
	Элемент.Пометка = Не Элемент.Пометка;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ВидРезультат(Команда)
	
	Если Элементы.ПанельРезультат.Скрыта() Тогда
		Элементы.ПанельРезультат.Показать();
	Иначе
		Элементы.ПанельРезультат.Скрыть();
	КонецЕсли;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкиВыводаТаблицыУстановитьВыводить(Команда)
	
	УстановитьНастройкиВыводаТаблицыПакета(ИТК_Перечисления.ВидВыводаТаблицыВыводить());

