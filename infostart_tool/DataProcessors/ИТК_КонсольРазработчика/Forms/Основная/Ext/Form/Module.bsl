КонецПроцедуры

&НаКлиенте
Функция КартинкаКнопкиСохранить()
	
	Если РабочиеДанные.Тип = Неопределено Тогда
		
		ИмяНастройкиСохранятьДанныеПоУмолчаниюВ = ИТК_НастройкиКлиентСерверПовтИсп.ИмяНастройкиСохранятьДанныеПоУмолчаниюВ();
		СохранятьДанныеПоУмолчаниюВ = ИТК_НастройкиКлиент.ЗначениеНастройки(ЭтотОбъект, ИмяНастройкиСохранятьДанныеПоУмолчаниюВ);
		
	Иначе
		
		СохранятьДанныеПоУмолчаниюВ = РабочиеДанные.Тип;
		
	КонецЕсли;
	
	Если СохранятьДанныеПоУмолчаниюВ = ИТК_Перечисления.ТипХраненияДанныхФайл() Тогда
		
		Результат = БиблиотекаКартинок.Записать;
		
	Иначе
		
		Результат = БиблиотекаКартинок.ИТК_ЗаписатьВНастройки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ОбработкаКомандыРедактораКодаЗавершена(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИТК_РедакторКодаКлиент.СтандартныйОбработчикЗавершенияКоманды(Результат, ДополнительныеПараметры);	
	
	НайденнаяСтрока = НайтиСтрокуПоUID(ДеревоДанных, ДополнительныеПараметры.UID);
	Если НайденнаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИзменяемыеПоля = Новый Структура;
	ИзменяемыеПоля.Вставить("Текст", Результат);
	ИзменяемыеПоля.Вставить("ТребуетсяПроверка", Истина);
	ИзменяемыеПоля.Вставить("Ошибка", Неопределено);
	
	ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоля(ЭтотОбъект, НайденнаяСтрока, ИзменяемыеПоля);
	
	ПодключаемыйЗагрузитьСостояниеРедактораКода();
	
	ОбновитьСтруктуруЗапросов(ТекущаяСтрока);
	ПроверитьПоказатьОшибку();
	
КонецПроцедуры

&НаКлиенте
Процедура РаботаКонструктораЗапросаЗавершена(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НайденнаяСтрока = НайтиСтрокуПоUID(ДеревоДанных, ДополнительныеПараметры.UID);
	Если НайденнаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИзменяемыеПоля = Новый Структура;
	ИзменяемыеПоля.Вставить("Текст", Результат);
	ИзменяемыеПоля.Вставить("ТребуетсяПроверка", Истина);
	ИзменяемыеПоля.Вставить("Ошибка", Неопределено);
	ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоля(ЭтотОбъект, НайденнаяСтрока, ИзменяемыеПоля);
	
	ПодключаемыйЗагрузитьСостояниеРедактораКода();

	ОбновитьСтруктуруЗапросов(НайденнаяСтрока);
	ПроверитьПоказатьОшибку();
	
КонецПроцедуры

&НаКлиенте
Функция ЭлементТекстПоТипуСтроки(Тип)
	
	Если ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоОдинИзТиповСтрокиЗапрос(Тип) Тогда
		
		Результат = Элементы.ТекстЗапроса;
		
	ИначеЕсли Тип = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных() Тогда
		
		Результат = Элементы.СхемаКомпоновкиДанныхXML;
		
	ИначеЕсли Тип = ИТК_Перечисления.ЭлементДанныхКод() Тогда
		
		Результат = Элементы.Код;
		
	Иначе
		
		Результат = Неопределено;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ПодключаемыйВосстановитьСостояниеСтрокиПослеОжидания()

	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПодключаемыйЗагрузитьСостояниеРедактораКода();
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	
	// Активация страница которая была последней
	Если ЗначениеЗаполнено(ТекущиеДанные.Страница) Тогда
		
		ЭлементСтраница = Элементы["Страница" + ТекущиеДанные.Страница];
		Элементы.ПанельНастроек.ТекущаяСтраница = ЭлементСтраница;
		
		Если ЭлементСтраница = Элементы.СтраницаТекстЗапроса Тогда
			
			ТекущийЭлемент = Элементы.ТекстЗапроса;
			
		ИначеЕсли ЭлементСтраница = Элементы.СтраницаСхемаКомпоновкиДанныхXML Тогда
			
			ТекущийЭлемент = Элементы.СхемаКомпоновкиДанныхXML;
			
		ИначеЕсли ЭлементСтраница = Элементы.СтраницаКод Тогда
			
			ТекущийЭлемент = Элементы.Код;
			
		ИначеЕсли ЭлементСтраница = Элементы.СтраницаПрочее Тогда
			
			ТекущийЭлемент = Элементы.Представление;
			
		КонецЕсли;
		
	Иначе
		
		ТекущийЭлемент = Элементы.Представление;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйЗагрузитьСостояниеРедактораКода()
	
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТипСтроки = ТекущаяСтрока.Тип;
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	ЭлементТекст = ЭлементТекстПоТипуСтроки(ТипСтроки);
	
	Если ЭлементТекст = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если НЕ ИТК_РедакторКодаКлиент.Инициализирован(ЭлементТекст) Тогда
		
		ПодключитьОбработчикОжидания("ПодключаемыйЗагрузитьСостояниеРедактораКода", 0.1, Истина);
		Возврат;
		
	КонецЕсли;
	
	Текст = ТекущиеДанные["Текст"];
	ДоступноРедактированиеТекста = ИТК_КонсольРазработчикаДанныеКлиентСервер.ДоступноРедактированиеТекстаДляСтроки(ТипСтроки);
	
	ИТК_РедакторКодаКлиент.УстановитьДоступностьРедактирования(ЭтотОбъект, ЭлементТекст, ДоступноРедактированиеТекста);
	ИТК_РедакторКодаКлиент.УстановитьТекст(ЭтотОбъект, ЭлементТекст, Текст);
	
	// Восстановление выделения
	ИТК_РедакторКодаКлиент.УстановитьВыделение(ЭлементТекст, ТекущиеДанные["ГраницыВыделенияТекста"]);
	Если ИТК_РедакторКодаКлиентСервер.ЭтоРедакторКодаMonaco(ЭлементТекст) Тогда
		
		// Восстановление закладок
		ИТК_РедакторКодаКлиент.УстановитьЗакладки(ЭлементТекст, ТекущиеДанные["Закладки"]);
		
		// Установим оригинальный текст
		Если ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоТипСтрокиСИспользованиемОригинальногоТекста(ТипСтроки) Тогда
			ИТК_РедакторКодаКлиент.УстановитьОригинальныйТекст(ЭлементТекст, ТекущиеДанные["ОригинальныйТекст"]);
		КонецЕсли;
		
		// Восстановление состояния редактора
		ИТК_РедакторКодаКлиент.УстановитьСостояниеРедактора(ЭлементТекст, ТекущиеДанные["СостояниеРедактора"]);
		
	КонецЕсли;
	
	ЗагрузитьПользовательскиеОбъектыПодсказки();
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьТребуетсяИнициализацияРедактора()
	
	Если Элементы.СтраницаКод.Видимость = Ложь Тогда
		
		Элемент = Элементы["Код"];
		ИТК_РедакторКодаКлиент.УстановитьТребуетсяДополнительнаяИнициализация(Элемент);
		
	КонецЕсли;
	
	Если Элементы.СтраницаТекстЗапроса.Видимость = Ложь Тогда
		
		Элемент = Элементы["ТекстЗапроса"];
		ИТК_РедакторКодаКлиент.УстановитьТребуетсяДополнительнаяИнициализация(Элемент);
		
	КонецЕсли;
	
	Если Элементы.СтраницаСхемаКомпоновкиДанныхXML.Видимость = Ложь Тогда
		
		Элемент = Элементы["СхемаКомпоновкиДанныхXML"];
		ИТК_РедакторКодаКлиент.УстановитьТребуетсяДополнительнаяИнициализация(Элемент);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьДанныеОтладкиИзБуфераОбмена(СтрокаXML)
	
	МассивДанных = ИТК_КонсольРазработчикаЭкспортДанных.ДанныеОтладкиИзСтрокиXML(СтрокаXML, УникальныйИдентификатор);
		
	УстановитьРабочиеДанные(РабочиеДанные, , , НСтр("ru = 'загружен из отладки';
													|en = 'loaded from debug'"));
	ОчиститьДанныеСервер();
	
	ЗагрузитьДанныеПострочно(МассивДанных, ДеревоДанных);
	
	ОбновитьСтруктуруЗапросовСервер();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработчикЗагрузитьДанныеОтладкиИзБуфераОбмена(Результат, ДополнительныеПараметры) Экспорт
	
	Текст = ИТК_БуферОбменаКлиент.Текст();
	
	Попытка
		
		ЗагрузитьДанныеОтладкиИзБуфераОбмена(Текст);
		ИТК_КонсольРазработчикаДанныеКлиентСервер.ДанныеМодифицированы(ЭтотОбъект);
		
	Исключение
		
		ПредставлениеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ПоказатьПредупреждение( , ПредставлениеОшибки, , ИТК_КонсольРазработчикаКлиентСервер.Представление());
		
	КонецПопытки;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьПользовательскиеОбъектыПодсказки()
	
	ТипСтроки = ТекущаяСтрока.Тип;
	
	ЭлементТекст = ЭлементТекстПоТипуСтроки(ТипСтроки);
	Если НЕ ИТК_РедакторКодаКлиентСервер.ЭтоРедакторКодаMonaco(ЭлементТекст) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипСтроки <> ИТК_Перечисления.ЭлементДанныхЗапрос() Тогда
		Возврат;
	КонецЕсли;
	
	ПользовательскиеОбъекты = ПользовательскиеОбъектыТекстЗапроса();
	ИТК_РедакторКодаКлиент.ЗагрузитьПользовательскиеОбъекты(ЭлементТекст, ПользовательскиеОбъекты);

КонецПроцедуры

&НаКлиенте
Функция ПользовательскиеОбъектыТекстЗапроса()
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	
	Результат = Новый Структура;
	
	Если ТекущаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхЗапрос()
			И ЗначениеЗаполнено(ТекущиеДанные.ВнешниеИсточники) Тогда
		
		Результат = ПользовательскиеОбъектыТекстЗапросаСервер(ТекущиеДанные);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ПользовательскиеОбъектыТекстЗапросаСервер(Данные)
	
	ЗначенияВнешнихИсточников = ИТК_КонсольРазработчика.ЗначенияВнешнихИсточников(Данные);
	Возврат ИТК_РедакторКода.ПользовательскиеОбъектыТекстЗапросаВКонсоли(ЗначенияВнешнихИсточников);
	
КонецФункции

&НаКлиенте
Процедура ПослеСохраненияДанных()
	
	СброситьОригинальныйТекст(ДеревоДанных);
	ПодключаемыйЗагрузитьСостояниеРедактораКода();
	
КонецПроцедуры

&НаКлиенте
Процедура СброситьОригинальныйТекст(СтрокаРодитель)
	
	Для Каждого Строка Из СтрокаРодитель.ПолучитьЭлементы() Цикл
		
		Если НЕ ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоТипСтрокиСИспользованиемОригинальногоТекста(Строка.Тип) Тогда
			Продолжить;
		КонецЕсли;
		
		Данные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(Строка);
		ИТК_КонсольРазработчикаДанныеКлиентСервер.СброситьОригинальныйТекст(Данные);
		
		СброситьОригинальныйТекст(Строка);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ВосстановлениеДанныхПослеАварийногоЗавершения(АвтоматическоеСохранениеДанных)
	
	ЗагрузитьДанные(АвтоматическоеСохранениеДанных.Данные);
	ЗаполнитьЗначенияСвойств(РабочиеДанные, АвтоматическоеСохранениеДанных.Тип);
	РабочиеДанные.Комментарий = НСтр("ru = 'восстановлен, аварийное завершение';
									|en = 'restored crash'");
		
	ИТК_КонсольРазработчикаДанныеКлиентСервер.ДанныеМодифицированы(ЭтотОбъект, Ложь);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция РезультатИсполненияКода(Адрес)
	
	РезультатИсполнения = ПолучитьИзВременногоХранилища(Адрес);
	Возврат РезультатИсполнения.Результат;

КонецФункции

&НаКлиенте
Функция ОсновнаяСтрока(Строка, Тип)
	
	Результат = Неопределено;
	
	Родитель = Строка;
	Пока Истина Цикл 
		
		Если Родитель.Тип = Тип Тогда
			
			Результат = Родитель;
			Прервать;
			
		КонецЕсли;
		
		Родитель = Родитель.ПолучитьРодителя();

	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ОсновнойЗапрос(Строка)
	
	Возврат ОсновнаяСтрока(Строка, ИТК_Перечисления.ЭлементДанныхЗапрос());
	
КонецФункции

&НаКлиенте
Функция ОсновнаяСхемаКомпоновкиДанных(Строка)
	
	Возврат ОсновнаяСтрока(Строка, ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных());
	
КонецФункции

&НаКлиенте
Процедура ВыполнитьОперациюОбработчикОповещения(Результат, ДополнительныеПараметры) Экспорт

	Режим = ДополнительныеПараметры.Режим;
	НаименованиеОперации = ДополнительныеПараметры.НаименованиеОперации;
	
	ОбрабатываемаяСтрока = ДополнительныеПараметры.ОбрабатываемаяСтрока;
	ИгнорироватьЛимитСтрок = ДополнительныеПараметры.ИгнорироватьЛимитСтрок;
	
	// Автосохранение перед выполнением
	Если ИТК_НастройкиКлиент.ЗначениеНастройки(ЭтотОбъект, "АвтоСохранениеПередВыполнением") Тогда
		АвтосохранениеДанных();
	КонецЕсли;
	
	Если Режим = ИТК_Перечисления.РежимВыполненияКодаНаКлиенте() Тогда
		ВыполнитьОперациюНаКлиенте(ОбрабатываемаяСтрока, Режим);
	Иначе
		ВыполнитьОперациюЧерезДлительныеОперации(ОбрабатываемаяСтрока, НаименованиеОперации, Режим, ИгнорироватьЛимитСтрок);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ЗавершенВыборЗначенияПараметра(Значение, ДополнительныеПараметры) Экспорт
	
	Если Значение = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрЗапросаТекущиеДанные = Элементы.ПараметрыЗапроса.ТекущиеДанные;
	
	ИмяПараметра = ПараметрЗапросаТекущиеДанные.Имя;
	ИТК_КонсольРазработчикаДанныеКлиент.ВставитьЗначениеПараметраЗапроса(ЭтотОбъект, ТекущаяСтрока, ИмяПараметра, Значение);
	ОбновитьСтрокуПараметра(ПараметрЗапросаТекущиеДанные, ИмяПараметра, ПараметрЗапросаТекущиеДанные.ТипЗначения, Значение);
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицыМВТПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	ТаблицыМВТТекущиеДанные = Элементы.ТаблицыМВТ.ТекущиеДанные;
	Если НоваяСтрока Тогда
		
		ИмяТаблицыМВТ = ИТК_Строки.НовыйИдентификатор(НСтр("ru = 'Таблица';
																	|en = 'Table'"), ИТК_ФормаКлиент.ВыгрузитьКолонкуКоллекции(ТаблицыМВТ, "Имя"));
		ТаблицыМВТТекущиеДанные.Имя = ИмяТаблицыМВТ;
		
		UIDТаблицыМВТ = Новый УникальныйИдентификатор;
		ТаблицыМВТТекущиеДанные.UID = UIDТаблицыМВТ;
		
		Если Копирование Тогда
			
			Тип = КопируемыеДанныеТаблицМВТ.Тип;
			Если Тип = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаВыражение() Тогда
				
				ИТК_КонсольРазработчикаДанныеКлиент.СкопироватьТаблицуМВТ(ЭтотОбъект, ТекущаяСтрока, ИмяТаблицыМВТ,
																		UIDТаблицыМВТ, КопируемыеДанныеТаблицМВТ.UID);
				
			КонецЕсли;
			
		Иначе
			Тип = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаЗначение();
		КонецЕсли;
		ТаблицыМВТТекущиеДанные.Тип = Тип;
		
		ПоследнийТипТаблицыМВТ = Тип;
		
		ТаблицыМВТ.Сортировать("Имя");
		
		ОбновитьСтрокуТаблицыМВТ(ТаблицыМВТТекущиеДанные);
		ТекущийЭлемент = Элементы.ТаблицыМВТИмя;
		
	Иначе
		
		ТекущаяКолонка = Элемент.ТекущийЭлемент;
		ИмяТаблицыМВТ = ТаблицыМВТТекущиеДанные.Имя;
		UIDТаблицыМВТ = ТаблицыМВТТекущиеДанные.UID;
		
		Если СтрНайти(ТекущаяКолонка.Имя, "Имя") Тогда
			
			ЗанятыеИдентификаторы = ИТК_ФормаКлиент.ВыгрузитьКолонкуКоллекции(ТаблицыМВТ, "Имя", ИмяТаблицыМВТ);
			ИТК_ФормаКлиент.ОткрытьРедактированиеИдентификатора(НСтр("ru = 'Имя таблицы МВТ';
																	|en = 'Table name TTM'"),
																	ИТК_Перечисления.РежимРедактированияИдентификатораИдентификаторВременнойТаблицы(), ЭтотОбъект,
																	Новый ОписаниеОповещения("ВводИдентификатораТаблицыМВТЗавершен", ЭтотОбъект),
																	ИмяТаблицыМВТ, ЗанятыеИдентификаторы);
			
		ИначеЕсли СтрНайти(ТекущаяКолонка.Имя, "Представление") Тогда
			
			ДополнительныеПараметры = Новый Структура("UID", UIDТаблицыМВТ);
			
			ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
			ОписаниеТаблицыМВТ = ИТК_КонсольРазработчикаДанныеКлиент.ТаблицаМВТ(ТекущиеДанные, UIDТаблицыМВТ);
			Если ОписаниеТаблицыМВТ = Неопределено Тогда
				ЗначениеТаблицыМВТ = Неопределено;
			Иначе
				ЗначениеТаблицыМВТ = ОписаниеТаблицыМВТ.Значение;
			КонецЕсли;
			ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("РедактированиеЗначенияТаблицаМВТЗавершено", ЭтотОбъект, ДополнительныеПараметры);
			
			Если ТаблицыМВТТекущиеДанные.Тип = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаВыражение() Тогда
				
				ШаблонЗаголовка = НСтр("ru = 'Редактирование выражения (%1): %2';
										|en = 'Expression edit (%1):%2'");
				ЗаголовокФормы = СтрШаблон(ШаблонЗаголовка, ИТК_Строки.ИмяВнешнегоИсточника(), ИмяТаблицыМВТ);
				
				ДополнительныеПараметры = Новый Структура;
				ДополнительныеПараметры.Вставить("Владелец", ЭтотОбъект);
				ДополнительныеПараметры.Вставить("ОписаниеОповещенияОЗакрытии", ОписаниеОповещенияЗавершение);
				
				ИТК_РедакторКодаКлиент.ОткрытьРедактированиеКодаВОтдельномОкне(ЗаголовокФормы, ЗначениеТаблицыМВТ, ДополнительныеПараметры);
				
			ИначеЕсли ТаблицыМВТТекущиеДанные.Тип = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаЗначение() Тогда
				
				ДополнительныеПараметрыОткрытия = Новый Структура;
				ДополнительныеПараметрыОткрытия.Вставить("ДополнениеЗаголовка", СтрШаблон("(%1): %2", ИТК_Строки.ИмяВнешнегоИсточника(), ИмяТаблицыМВТ));
				ДополнительныеПараметрыОткрытия.Вставить("НастройкаИндексацииКолонок", Истина);
				ДополнительныеПараметрыОткрытия.Вставить("ОписаниеОповещенияОЗакрытии", ОписаниеОповещенияЗавершение);
				ДополнительныеПараметрыОткрытия.Вставить("Источник", ИмяТаблицыМВТ);
				
				ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
				ДополнительныеПараметрыОткрытия.Вставить("ДобавляемыеКолонки", ТекущиеДанные.ОписаниеТаблицМВТ.Получить(ИмяТаблицыМВТ));
				
				ИТК_ФормаКлиент.ОткрытьТаблицуЗначений(ЗначениеТаблицыМВТ, ЭтотОбъект, , ДополнительныеПараметрыОткрытия);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
