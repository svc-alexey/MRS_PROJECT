Процедура ПерейтиКОсновномуЗапросу(Команда)
	
	СтрокаОсновнойЗапрос = ОсновнойЗапрос(ТекущаяСтрока);
	Элементы.ДеревоДанных.ТекущаяСтрока = СтрокаОсновнойЗапрос.ПолучитьИдентификатор();
	ТекущийЭлемент = Элементы.СтраницаПараметрыЗапроса;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	Если ТекущаяСтрока = Неопределено Тогда
		ТипСтроки = Неопределено;
	Иначе
		ТипСтроки = ТекущаяСтрока.Тип;
	КонецЕсли;
	
	ИспользуетсяБСП = ИТК_БСПКлиентСервер.ИспользуетсяБСП();
	ЭтоСтрока = (ТекущаяСтрока <> Неопределено);
	ЭтоСтрокаЗапрос = (ТипСтроки = ИТК_Перечисления.ЭлементДанныхЗапрос());
	ЭтоСтрокаСхемаКомпоновкиДанных = (ТипСтроки = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных());
	ЭтоСтрокаГруппа = (ТипСтроки = ИТК_Перечисления.ЭлементДанныхГруппа());
	ЭтоСтрокаВложенныйЗапрос = (ТипСтроки = ИТК_Перечисления.ЭлементДанныхПодзапрос());
	ЭтоСтрокаЗапросИлиПодзапрос = ЭтоСтрокаЗапрос ИЛИ ЭтоСтрокаВложенныйЗапрос;
	ЭтоСтрокаВариантОтчетаСКД = (ТипСтроки = ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД());
	ЭтоСтрокаПользовательскаяНастройкаСКД = (ТипСтроки = ИТК_Перечисления.ЭлементДанныхПользовательскаяНастройкаСКД());
	ЭтоСтрокаСКД = ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоОдинИзТиповСтрокиСКД(ТипСтроки);
	ЭтоСтрокаКод = (ТипСтроки = ИТК_Перечисления.ЭлементДанныхКод());
	КоличествоВыделенныхСтрок = Элементы.ДеревоДанных.ВыделенныеСтроки.Количество();
	ДоступностьКонструктора = ЭтоСтрокаЗапрос ИЛИ ЭтоСтрокаСКД;
	ДоступностьКодНаВстроенномЯзыке = ЭтоСтрокаЗапрос ИЛИ ЭтоСтрокаСхемаКомпоновкиДанных;
	ДоступноРедактированиеТекста = ИТК_КонсольРазработчикаДанныеКлиентСервер.ДоступноРедактированиеТекстаДляСтроки(ТипСтроки);
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	
	// Заголовок
	Если РабочиеДанные.Тип = Неопределено Тогда
		
		Заголовок = НСтр("ru = 'Новый';
						|en = 'New'");
		
	ИначеЕсли РабочиеДанные.Тип = ИТК_Перечисления.ТипХраненияДанныхФайл() Тогда 
		
		Заголовок = ИТК_ФайлыКлиентСервер.ПолноеИмяФайлаКратко(РабочиеДанные.Имя);
		
	ИначеЕсли РабочиеДанные.Тип = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда 
		
		Заголовок = СтрШаблон("(%1)", РабочиеДанные.Имя);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РабочиеДанные.Комментарий) Тогда
		Заголовок = СтрШаблон("%1 - (%2)", Заголовок, РабочиеДанные.Комментарий);
	КонецЕсли;
	
	// Закладка прочее 
	Элементы.ГруппаНастройкиВыводаТаблиц.Видимость = ЭтоСтрокаЗапрос;
	Если ЭтоСтрокаЗапрос Тогда
		ЗаполнитьНастройкиВыводаТаблиц();
	КонецЕсли;
	
	// Представление
	Если ЭтоСтрока Тогда
		Представление = ТекущаяСтрока.Имя;
	Иначе 
		Представление = "";
	КонецЕсли;
	Элементы.Представление.Доступность = ЭтоСтрока;
	
	// ИспользованиеВнешнихФункций
	Если ЭтоСтрокаСхемаКомпоновкиДанных Тогда
		ИспользованиеВнешнихФункций = ТекущиеДанные.ИспользованиеВнешнихФункций;
	КонецЕсли;
	Элементы.ИспользованиеВнешнихФункций.Видимость = ЭтоСтрокаСхемаКомпоновкиДанных;
	
	// Элементы Форма
	Элементы.ФормаПодменюПрочее.Видимость = ИспользуетсяБСП;
	Элементы.ДанныеНастройка.Видимость = Элементы.ФормаВидВидНастройкиДанных.Пометка;
	Элементы.ДеревоДанных.Видимость = Элементы.ФормаВидВидДеревоДанных.Пометка;
	Элементы.Конструктор.Видимость = ДоступностьКонструктора;
	Элементы.ФормаОбработкаРезультата.Доступность = ЭтоСтрокаЗапрос;
	Элементы.ФормаКодНаВстроенномЯзыке.Доступность = ДоступностьКодНаВстроенномЯзыке;
	Элементы.ФормаЗамерПакетаЗапросов.Доступность = ЭтоСтрокаЗапрос;
	Элементы.ФормаОткрытьПапкуСодержащуюФайл.Доступность = ЗначениеЗаполнено(РабочиеДанные.Имя)
																И РабочиеДанные.Тип = ИТК_Перечисления.ТипХраненияДанныхФайл();
	КартинкаКнопкиСохранить = КартинкаКнопкиСохранить();
	Элементы.СохранитьДанные.Картинка = КартинкаКнопкиСохранить;
	Элементы.ФормаСохранитьДанные.Картинка = КартинкаКнопкиСохранить;
	Элементы.ФормаВидВидДеревоДанных.Доступность = Элементы.ФормаВидВидНастройкиДанных.Пометка;
	Элементы.ФормаВидРезультат.Видимость = ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.12");
	
	ЕстьЗамерВремениВыполнения = ЭтоСтрокаЗапрос ИЛИ ЭтоСтрокаСКД ИЛИ ЭтоСтрокаВложенныйЗапрос ИЛИ ЭтоСтрокаКод;
	Элементы.ОбновитьЗамер.Доступность = ЕстьЗамерВремениВыполнения;
	Если ЕстьЗамерВремениВыполнения Тогда
		Элементы.ФормаГруппаЗамеры.Заголовок = ИТК_ОбщийКлиентСервер.ПредставлениеВремениВМс(ТекущиеДанные.ВремяВыполнения);
	КонецЕсли;
	
	Элементы.Выполнить.Доступность = ЭтоСтрокаЗапросИлиПодзапрос ИЛИ ЭтоСтрокаСКД ИЛИ ЭтоСтрокаКод;
	Элементы.ВыполнитьЗапросСВременнымиТаблицами.Видимость = ЭтоСтрокаЗапросИлиПодзапрос;
	Элементы.ВыполнитьАнализИсполняемыхЗапросов.Видимость = ЭтоСтрокаСКД;
	Элементы.ВыполнитьКодНаКлиенте.Видимость = ЭтоСтрокаКод;
	
	ОбновитьЭлементыВыделенияСтроки();
	
	// Управление доступностью "Добавить"
	ДоступностьДобавленияОбособленно = НЕ (ЭтоСтрокаВариантОтчетаСКД ИЛИ ЭтоСтрокаПользовательскаяНастройкаСКД);
	
	Элементы.ДобавитьГруппу.Доступность = ДоступностьДобавленияОбособленно;
	Элементы.ДобавитьГруппу1.Доступность = ДоступностьДобавленияОбособленно;
	
	Элементы.ДобавитьЗапрос.Доступность = ДоступностьДобавленияОбособленно;
	Элементы.ДобавитьЗапрос1.Доступность = ДоступностьДобавленияОбособленно;
	
	Элементы.ДобавитьКод.Доступность = ДоступностьДобавленияОбособленно;
	Элементы.ДобавитьКод1.Доступность = ДоступностьДобавленияОбособленно;
	
	Элементы.ДобавитьСхемуКомпоновкиДанных.Доступность = ДоступностьДобавленияОбособленно;
	Элементы.ДобавитьСхемуКомпоновкиДанных1.Доступность = ДоступностьДобавленияОбособленно;
	
	ДоступностьДобавленияВариантаОтчетаСКД = ЭтоСтрокаСхемаКомпоновкиДанных;
	Элементы.ДобавитьВариантОтчетаСКД.Доступность = ДоступностьДобавленияВариантаОтчетаСКД;
	Элементы.ДобавитьВариантОтчетаСКД1.Доступность = ДоступностьДобавленияВариантаОтчетаСКД;
	
	ДоступностьДобавленияПользовательскойНастройкиСКД = ЭтоСтрокаСхемаКомпоновкиДанных ИЛИ ЭтоСтрокаВариантОтчетаСКД;
	Элементы.ДобавитьПользовательскуюНастройкуСКД.Доступность = ДоступностьДобавленияПользовательскойНастройкиСКД;
	Элементы.ДобавитьПользовательскуюНастройкуСКД1.Доступность = ДоступностьДобавленияПользовательскойНастройкиСКД;
	
	// Управление видимостью закладок
	Элементы.СтраницаТекстЗапроса.Видимость = ЭтоСтрокаЗапросИлиПодзапрос;
	Элементы.СтраницаПараметрыЗапроса.Видимость = ЭтоСтрокаЗапросИлиПодзапрос;
	
	Элементы.СтраницаСхемаКомпоновкиДанныхXML.Видимость = ЭтоСтрокаСхемаКомпоновкиДанных;
	
	ИспользуютсяВнешниеИсточники = ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоТипСтрокиСИспользованиемВнешнихИсточников(ТипСтроки);
	Элементы.СтраницаВнешниеИсточники.Видимость = ИспользуютсяВнешниеИсточники;
	Если ИспользуютсяВнешниеИсточники Тогда
		ЗаполнитьВнешниеИсточники();
	КонецЕсли;
	
	ИспользуютсяТаблицыМВТ = ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоТипСтрокиСИспользованиемМВТ(ТипСтроки);
	Элементы.СтраницаМВТ.Видимость = ИспользуютсяТаблицыМВТ;
	Если ИспользуютсяТаблицыМВТ Тогда
		ЗаполнитьТаблицыМВТ();
	КонецЕсли;
	
	Элементы.СтраницаВариантОтчетаСКД.Видимость = ЭтоСтрокаВариантОтчетаСКД;
	Элементы.СтраницаПользовательскаяНастройкаСКД.Видимость = ЭтоСтрокаПользовательскаяНастройкаСКД;
	Элементы.СтраницаКод.Видимость = ЭтоСтрокаКод;
	Элементы.СтраницаПрочее.Видимость = НЕ ЭтоСтрокаВложенныйЗапрос;
	
	// Элементы ДеревоДанных
	Элементы.СкопироватьСтроку.Доступность = (КоличествоВыделенныхСтрок = 1);
	Элементы.СкопироватьСтроку1.Доступность = (КоличествоВыделенныхСтрок = 1);
	Элементы.Добавить.Доступность = Не ЭтоСтрокаВложенныйЗапрос;
	Элементы.Добавить1.Доступность = Не ЭтоСтрокаВложенныйЗапрос;
	Элементы.Изменение.Доступность = Не ЭтоСтрокаВложенныйЗапрос;
	Элементы.Изменение1.Доступность = Не ЭтоСтрокаВложенныйЗапрос;
	Элементы.Порядок.Доступность = Не ЭтоСтрокаВложенныйЗапрос;
	Элементы.Сортировка.Доступность = Не ЭтоСтрокаВложенныйЗапрос;
	Элементы.УдалитьСтроку.Доступность = Не ЭтоСтрокаВложенныйЗапрос;
	Элементы.УдалитьСтроку1.Доступность = Не ЭтоСтрокаВложенныйЗапрос;
	Элементы.КонструкторВКонтекстномМенюДерева.Доступность = ДоступностьКонструктора;
	
	// Элементы ТабличныйДокументРезультат
	Элементы.МаксимумСтрок.Видимость = ЭтоСтрокаЗапрос;
	Элементы.ГруппаСумма.Видимость = ИТК_НастройкиКлиент.ЗначениеНастройки(ЭтотОбъект, "РасчетСуммыВыделенныхЯчеек");
	
	АктуаленПоСтроке = ТекущийРезультат.АктуаленПоСтроке;
	Элементы.СравнитьРезультаты.Доступность = ЗначениеЗаполнено(АктуаленПоСтроке);
	
	Если ЭтоСтрокаЗапрос Тогда
		
		Если ТекущиеДанные.МаксимумСтрок = Неопределено Тогда
			МаксимумСтрок = ИТК_НастройкиКлиент.ЗначениеНастройки(ЭтотОбъект, "МаксимальноеКоличествоВыводимыхСтрок");
		Иначе 
			МаксимумСтрок = ТекущиеДанные.МаксимумСтрок;
		КонецЕсли;
		
	КонецЕсли;
	
	ПолучениеПлана = ИТК_НастройкиКлиент.ЗначениеНастройки(ЭтотОбъект, "ПолучениеПлана");
	Элементы.АнализироватьПланЗапроса.Видимость = ПолучениеПлана <> ИТК_Перечисления.ПолучениеПланаОтключено()
															И ЗначениеЗаполнено(ТекущийРезультат.IDПроцесса);
															
	СтрокаРезультата = НайтиСтрокуПоUID(ДеревоДанных, АктуаленПоСтроке);
	Если СтрокаРезультата = Неопределено Тогда
		ТипСтрокиРезультата = Неопределено;
	Иначе 
		ТипСтрокиРезультата = СтрокаРезультата.Тип;
	КонецЕсли;
	ПоказатьНеВсеСтрокиВыведены = (ТекущийРезультат.ВсеСтрокиВыведены = Ложь) И ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоОдинИзТиповСтрокиЗапрос(ТипСтрокиРезультата);
	Элементы.КнопкаНеВсеСтрокиВыведены.Видимость = ПоказатьНеВсеСтрокиВыведены;
	Элементы.ГруппаНеВсеСтрокиВыведены.Видимость = ПоказатьНеВсеСтрокиВыведены;
	
	Если ПоказатьНеВсеСтрокиВыведены Тогда
		ЦветФона = Новый Цвет(255, 250, 217);
	Иначе 
		ЦветФона = Новый Цвет();
	КонецЕсли;
	Элементы.ГруппаМаксимумСтрок.ЦветФона = ЦветФона;
	
	Если ЭтоСтрокаЗапросИлиПодзапрос Тогда
		
		Элементы.КоманднаяПанельКнопкиТекстаЗапроса.Видимость = ЭтоСтрокаЗапросИлиПодзапрос;
		Элементы.ПроверитьЗапрос.Доступность = ДоступноРедактированиеТекста;
		Элементы.КодНаВстроенномЯзыке.Доступность = ДоступностьКодНаВстроенномЯзыке;
		
		// Элементы ПараметрыЗапроса 
		Ошибка = ТекущиеДанные.Ошибка;
		ОшибкаВТекстеЗапроса = (Ошибка <> Неопределено);
		ДоступноИзменениеПараметров = ЭтоСтрокаЗапрос И (ПараметрыЗапроса.Количество() > 0);
		
		ЗаполнитьЗакладкуПараметры();
		
		Элементы.ПараметрыЗапроса.ТолькоПросмотр = НЕ ДоступноИзменениеПараметров;
		Элементы.ПараметрыЗапроса.ЦветФона = ИТК_ОбщийКлиентСервер.ЦветФонаЭлементРедактируется(ДоступноИзменениеПараметров);
		Элементы.ГруппаИнформацияПараметровРедактируютсяВГлавномЗапросе.Видимость = ЭтоСтрокаВложенныйЗапрос;
		
		ДоступныДействияСПараметрами = ДоступноИзменениеПараметров И НЕ ОшибкаВТекстеЗапроса;
		Элементы.ПараметрыЗапросаЗаполнитьПараметры.Доступность = ДоступныДействияСПараметрами;
		Элементы.ПараметрыЗапросаКонтекстноеМенюЗаполнитьПараметр.Доступность = ДоступныДействияСПараметрами;
		Элементы.ПараметрыЗапросаКонтекстноеМенюПереименоватьПараметр.Доступность = ДоступныДействияСПараметрами;
		Элементы.ПараметрыЗапросаПереименоватьПараметр.Доступность = ДоступныДействияСПараметрами;
		Элементы.ПараметрыЗапросаИзменитьТипПараметра.Доступность = ДоступныДействияСПараметрами;
		Элементы.ПараметрыЗапросаКонтекстноеМенюЗаменитьПараметрВТекстеНаЗначение.Доступность = ДоступныДействияСПараметрами;
		
		Элементы.ГруппаИнформацияПараметровНеПолученыОшибкаВТексте.Видимость = ЭтоСтрокаЗапрос И ОшибкаВТекстеЗапроса;
		Если ОшибкаВТекстеЗапроса Тогда
			ПредставлениеОшибки = ИТК_Строки.Сократить(ИТК_ОбщийКлиентСервер.ПредставлениеОшибкиВТекстеЗапросаИлиСхемеКомпоновкиДанных(Ошибка), 50);
			Элементы.ПараметрыНеПолученыОшибкаВТекстеПерейти.Заголовок = ПредставлениеОшибки;
		КонецЕсли;
		Элементы.ГруппаИнформацияПараметровНеПолученыТребуетсяПроверка.Видимость = ЭтоСтрокаЗапрос И ТекущиеДанные.ТребуетсяПроверка;
		
	ИначеЕсли ЭтоСтрокаПользовательскаяНастройкаСКД
			ИЛИ ЭтоСтрокаВариантОтчетаСКД Тогда
		
		ЗагрузитьДанныеВКомпоновщикНастроек(ПолныеДанныеСКД(ТекущаяСтрока));
		
	КонецЕсли;
	
	Если НЕ ЭтоСтрокаГруппа Тогда
		ОбновитьЭлементыОшибки();
	КонецЕсли;
	
	УстановитьТребуетсяИнициализацияРедактора();

КонецПроцедуры

&НаКлиенте
Процедура ИТК_ПодключаемыйВосстановлениеФокусаРедактора() Экспорт 
	
	ИТК_РедакторКодаКлиент.ВосстановлениеФокусаРедактора(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьОбработчикСПроверкойНаСохранностьДанных(ОписаниеОбработчика)
	
	Если Модифицированность Тогда
		
		// Список вариантов ответа
		ВариантыОтвета = Новый СписокЗначений;
		ВариантыОтвета.Добавить(КодВозвратаДиалога.Да,		НСтр("ru = 'Сохранить';
																	|en = 'Save'"));
		ВариантыОтвета.Добавить(КодВозвратаДиалога.Нет,		НСтр("ru = 'Не сохранять';
																	|en = 'Not save'"));
		ВариантыОтвета.Добавить(КодВозвратаДиалога.Отмена,	НСтр("ru = 'Отмена';
																	|en = 'Cancel'"));
		
		// Вопрос "сохранить данные"?
		ПоказатьВопрос(Новый ОписаниеОповещения("ВопросСохраненияЗавершение", ЭтотОбъект, ОписаниеОбработчика),
								НСтр("ru = 'Сохранить изменения?';
									|en = 'Save the changes?'"), ВариантыОтвета, , КодВозвратаДиалога.Да, ИТК_КонсольРазработчикаКлиентСервер.Представление());
		
	Иначе 
		
		ВыполнитьОбработкуОповещения(ОписаниеОбработчика);
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ВопросСохраненияЗавершение(Результат, ОписаниеОбработчика) Экспорт
	
	Если Результат = КодВозвратаДиалога.Отмена Тогда // Отмена
		
		Возврат;
		
	ИначеЕсли Результат = КодВозвратаДиалога.Да Тогда
		
		СохранитьДанные(ОписаниеОбработчика);
		
	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда		
		
		ВыполнитьОбработкуОповещения(ОписаниеОбработчика);

	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьФайл(Объединение)
	
	ДиалогОткрытияФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ДиалогОткрытияФайла.Фильтр = ИТК_ОбщийКлиентСервер.ФильтрФайловДанных(Истина, Истина);
	ДиалогОткрытияФайла.Расширение = ИТК_ОбщийКлиентСервер.ОсновноеРасширениеФайловДанных();
	ДиалогОткрытияФайла.МножественныйВыбор = Ложь;
	Если Объединение Тогда
		ЗаголовокДиалога = НСтр("ru = 'Объединение с данными';
								|en = 'Data merge'");
	Иначе
		ЗаголовокДиалога = НСтр("ru = 'Открытие данных';
								|en = 'Opening data'");
	КонецЕсли;
	ДиалогОткрытияФайла.Заголовок = ЗаголовокДиалога;
	
	ОписаниеОповещения = ОповещениеЗагрузкиДанных("ЗагрузкаФайлаЗакончена", Объединение);
	ДиалогОткрытияФайла.Показать(ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузкаФайлаЗакончена(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт 
	
	Если ВыбранныеФайлы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗагрузитьДанныеИзФайла(ВыбранныеФайлы[0], , ДополнительныеПараметры.Объединение);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьДанныеИзФайла(ИмяФайла, ОбновитьЭлементы = Истина, Объединение = Ложь)
	
	Попытка
		
		ОписаниеОповещения = ОповещениеЗагрузкиДанных("ЗаконченоПомещениеФайлаВХранилищеДляЗагрузки", Объединение);
		НачатьПомещениеФайла(ОписаниеОповещения, , ИмяФайла, Ложь);
		
		Если ОбновитьЭлементы Тогда
			
			РаскрытьВеткиДереваВСоответствииСДанными(ДеревоДанных);
			ОбновитьЭлементыФормы();
			
		КонецЕсли;
		
	Исключение
		
		ОбновитьЭлементыПоследниеРабочиеДанные(ИТК_Перечисления.ТипХраненияДанныхФайл(), , ИмяФайла);
		
		Шаблон = НСтр("ru = 'Ошибка загрузки файла: %1';
						|en = 'Error loading file: %1'");
		ПредставлениеОшибки = СтрШаблон(Шаблон, ИмяФайла);
		ПоказатьПредупреждение( , ПредставлениеОшибки, , ИТК_КонсольРазработчикаКлиентСервер.Представление());

	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаконченоПомещениеФайлаВХранилищеДляЗагрузки(Результат, Адрес, ВыбранноеИмяФайла, ДополнительныеПараметры) Экспорт 

	Попытка
		
		ЗагрузитьДанныеИзФайлаСервер(Адрес, ВыбранноеИмяФайла, ДополнительныеПараметры.Объединение);
		
	Исключение
		
		КраткоеПредставлениеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ПоказатьПредупреждение(, СтрШаблон(НСтр("ru = 'Ошибка при загрузке файла: %1
												|%2';
												|en = 'Error loading file: %1
												|%2'"), ВыбранноеИмяФайла, КраткоеПредставлениеОшибки), , ИТК_КонсольРазработчикаКлиентСервер.Представление());
		
	КонецПопытки;
	
КонецПроцедуры

// Получает строку по идентификатору (Приемник перетаскивания) для корня - ДеревоДанных 
//
// Параметры:
//  ИдентификаторСтроки (Число) - Идентификатор строки
// Возвращаемое значение:
//   (ДанныеФормыЭлементДерева,ДанныеФормыДерева) - Строка полученная по идентификатору либо ДеревоДанных для Неопределено
//
&НаКлиенте
Функция ПолучитьСтрокуПриемникПеретаскиванияДереваДанных(ИдентификаторСтроки)
	
	Если ИдентификаторСтроки = Неопределено Тогда // Перенос в корень дерева
		
		Возврат ДеревоДанных;
		
	Иначе
		
		Возврат ДеревоДанных.НайтиПоИдентификатору(ИдентификаторСтроки);
		
	КонецЕсли;	
	
КонецФункции

// Производит установку, снятие или инвертирование выделения для обрабатываемого массива строк 
//
// Параметры:
//  ОбрабатываемыеСтроки	(Массив)				- Массив идентификаторов строки
//  РежимОтметки			(Булево, Неопределено)	- Режим установки отметки Инвертировать - Неопределено, Установить - Истина, Снять - Ложь
//
&НаКлиенте
Процедура УстановитьВыделениеСтрок(ОбрабатываемыеСтроки, РежимОтметки = Неопределено)
	
	Для Каждого ИдентификаторСтроки Из ОбрабатываемыеСтроки Цикл
		
		ОбрабатываемаяСтрока = ДеревоДанных.НайтиПоИдентификатору(ИдентификаторСтроки);
		
		Если РежимОтметки = Неопределено Тогда // Инвертирование
			
			ОбрабатываемаяСтрока.Выделение = НЕ ОбрабатываемаяСтрока.Выделение;
			
		Иначе // Истина - установить отметку, Ложь - снять
			
			ОбрабатываемаяСтрока.Выделение = РежимОтметки
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Производит управление свойствами элементов формы обслуживающих команду выделение 
//
// Параметры: (отсутствуют)
//
&НаКлиенте
Процедура ОбновитьЭлементыВыделенияСтроки()
	
	ЕстьСтрокиВДереве = ДеревоДанных.ПолучитьЭлементы().Количество();
	
	Элементы.ВыделитьСтроку.Доступность = (ЕстьСтрокиВДереве);
	Элементы.ВыделитьСтроку1.Доступность = (ЕстьСтрокиВДереве);
	
	Если ЕстьСтрокиВДереве Тогда
		
		ЕстьВыделенныеСтроки = Ложь;
		
		Для Каждого ВыделеннаяСтрока Из Элементы.ДеревоДанных.ВыделенныеСтроки Цикл
			
			ОбрабатываемаяСтрока = ДеревоДанных.НайтиПоИдентификатору(ВыделеннаяСтрока);
			Если ОбрабатываемаяСтрока <> Неопределено 
					И ОбрабатываемаяСтрока.Выделение Тогда
					
				ЕстьВыделенныеСтроки = Истина; // Есть отмеченные строки значит кнопка должна быть Нажатой (отмеченной)
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Элементы.ВыделитьСтроку.Пометка = ЕстьВыделенныеСтроки;
		Элементы.ВыделитьСтроку1.Пометка = ЕстьВыделенныеСтроки;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЭлементыОшибки()
	
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТипСтроки = ТекущаяСтрока.Тип;
	ЭлементТекст = ЭлементТекстПоТипуСтроки(ТипСтроки);
	Если ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоОдинИзТиповСтрокиЗапрос(ТипСтроки) Тогда
		
		ЭлементГруппаОшибка = Элементы.ГруппаОшибкаВЗапросе;
		ЭлементТекстОшибки = Элементы.ОшибкаВЗапросеТекст;
		ЭлементКартинкаОшибки = Элементы.ОшибкаВЗапросеКартинка;
		
	ИначеЕсли ТипСтроки = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных() Тогда
		
		ЭлементГруппаОшибка = Элементы.ГруппаОшибкаВСхемеКомпоновкиДанных;
		ЭлементТекстОшибки = Элементы.ОшибкаВСхемеКомпоновкиДанныхТекст;
		ЭлементКартинкаОшибки = Элементы.ОшибкаВСхемеКомпоновкиДанныхКартинка;
		
	ИначеЕсли ТипСтроки = ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД() Тогда
		
		ЭлементГруппаОшибка = Элементы.ГруппаОшибкаВВариантеСКД;
		ЭлементТекстОшибки = Элементы.ОшибкаВВариантеСКДТекст;
		ЭлементКартинкаОшибки = Элементы.ОшибкаВВариантеСКДКартинка;
		
	ИначеЕсли ТипСтроки = ИТК_Перечисления.ЭлементДанныхПользовательскаяНастройкаСКД() Тогда
		
		ЭлементГруппаОшибка = Элементы.ГруппаОшибкаВПользовательскойНастройкеСКД;
		ЭлементТекстОшибки = Элементы.ОшибкаВПользовательскойНастройкеСКДТекст;
		ЭлементКартинкаОшибки = Элементы.ОшибкаВПользовательскойНастройкеСКДКартинка;
		
	ИначеЕсли ТипСтроки = ИТК_Перечисления.ЭлементДанныхКод() Тогда
		
		ЭлементГруппаОшибка = Элементы.ГруппаОшибкаВКоде;
		ЭлементТекстОшибки = Элементы.ОшибкаВКодеТекст;
		ЭлементКартинкаОшибки = Элементы.ОшибкаВКодеКартинка;
		
	КонецЕсли;
	
	ТребуетсяПроверка = ТребуетсяПроверкаСтроки();
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	
	Если ТипСтроки = ИТК_Перечисления.ЭлементДанныхКод() Тогда
		
		Элементы.СтекВызововПоОшибке.Видимость = ЗначениеЗаполнено(ТекущиеДанные.ОшибкаПриВыполнении)
													И ЗначениеЗаполнено(ТекущиеДанные.ОшибкаПриВыполнении.СтекВызовов);
		
	КонецЕсли;
	
	Ошибка = ОшибкаВДанных(ТекущиеДанные);
	ЕстьОшибки = ЗначениеЗаполнено(Ошибка);
	АкцентироватьТекст = ЕстьОшибки ИЛИ ТребуетсяПроверка;
	ЭлементГруппаОшибка.Видимость = АкцентироватьТекст;
	
	Если ЭлементТекст <> Неопределено Тогда
		
		Если АкцентироватьТекст Тогда
			ЦветРамки = WebЦвета.Красный;
		Иначе
			ЦветРамки = Новый Цвет();
		КонецЕсли;
		
		ЭлементТекст.ЦветРамки = ЦветРамки;
		ЭлементТекстОшибки.Гиперссылка = Не ТребуетсяПроверка;
		
	КонецЕсли;
	
	Если ТребуетсяПроверка Тогда
		
		ТекстОшибки = НСтр("ru = 'Требуется проверка текста';
							|en = 'You want to check the text'");
		ЭлементКартинкаОшибки.Картинка = Новый Картинка;
		
	Иначе
		
		Если ЕстьОшибки Тогда
			
			Если ТекущаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхКод() Тогда
				ТекстОшибки = ИТК_КодКлиентСервер.ПредставлениеОшибки(Ошибка);
			Иначе
				ТекстОшибки = ИТК_ОбщийКлиентСервер.ПредставлениеОшибкиВТекстеЗапросаИлиСхемеКомпоновкиДанных(Ошибка);
			КонецЕсли;
			ЭлементКартинкаОшибки.Картинка = КартинкаОшибкиВДанных(ТекущиеДанные);
			
		КонецЕсли;
		
	КонецЕсли;
	
	ЭлементТекстОшибки.Заголовок = ТекстОшибки;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЭлементыУправленияПараметровЗапроса()
	
	ПараметрыЗапросаТекущиеДанные = Элементы.ПараметрыЗапроса.ТекущиеДанные;
	
	Если ПараметрыЗапросаТекущиеДанные = Неопределено Тогда
		
		ДоступностьИзменитьТипПараметра = Ложь;
		ДоступнаФормаВыбораУниверсальная = Ложь;
		
	Иначе
			
		ДанныеПараметра = ДанныеПараметраЗапроса(ТекущаяСтрока, ПараметрыЗапросаТекущиеДанные.Имя);
		ОписаниеТипаПараметра = ДанныеПараметра.ОписаниеТипов;
		
		ДоступностьИзменитьТипПараметра = (ПараметрыЗапросаТекущиеДанные.Тип = ИТК_Перечисления.ТипЗначенияПараметраЗапросаЗначение())
											И (ТипЗнч(ОписаниеТипаПараметра) = Тип("ОписаниеТипов") И (ОписаниеТипаПараметра.СодержитТип(Тип("Дата")) ИЛИ ОписаниеТипаПараметра.Типы().Количество() > 1));
											
		ДоступнаФормаВыбораУниверсальная = (ПараметрыЗапросаТекущиеДанные.Тип = ИТК_Перечисления.ТипЗначенияПараметраЗапросаЗначение())
												И ТипЗнч(ОписаниеТипаПараметра) = Тип("ОписаниеТипов")
												И ИТК_ТипыКлиентСервер.ЕстьСсылочныеТипы(ОписаниеТипаПараметра, Истина)
												И ИТК_ТипыКлиентСервер.ЭтоСсылочный(ТипЗнч(ДанныеПараметра.Значение), Истина);
		
	КонецЕсли;
	
	Элементы.ПараметрыЗапросаИзменитьТипПараметра.Доступность = ДоступностьИзменитьТипПараметра;
	Элементы.ПараметрыЗапросаКонтекстноеМенюИзменитьТипПараметра.Доступность = ДоступностьИзменитьТипПараметра;
	Элементы.ПараметрыЗапросаКонтекстноеМенюФормаВыбораУниверсальная.Доступность = ДоступнаФормаВыбораУниверсальная;

КонецПроцедуры

// Проверяет входит можно ли переносить проверяемую строку (ПроверяемаяСтрока) в строку (ПриемникПеретаскивания)
//
// Параметры:
//  ПроверяемаяСтрока		(ДанныеФормыЭлементДерева)						- Проверяемая строка
//  ПриемникПеретаскивания	(ДанныеФормыДерево,ДанныеФормыЭлементДерева)	- Строка приемник перетаскивания
//  ПараметрыПеретаскивания	(ПараметрыПеретаскивания)						- Параметры перетаскивания
// Возвращаемое значение:
//   Булево	- Истина, можно перенести строку; Ложь, нельзя
//
&НаКлиенте
Функция МожноПереместитьСтроку(ПроверяемаяСтрока, ПараметрыПеретаскивания, ПриемникПеретаскивания)
	
	// Правила перетаскивания Drag & Drop
	// 1. В корень дерева можно переносить элементы Запрос, Код, СКД, Группа
	// 2. Нельзя переносить/копировать элементы вложенный запрос
	// 3. Строку нельзя переносить саму в себя
	// 4. Необходимо проверять не перемещается ли группа внутрь самой себя для избежания бесконечной рекурсии
	// В группу переносить можно, но только не в туже самую... копированием можно и в туже самую
	// 5. Группу можно переносить только в другую группу
	// 6. Переносить в родительскую группу только копированием
	// 7. Вариант отчета СКД можно переносить только в другой вариант (т.е. перемещение элементов)
	//     в вариант можно переносить только вариант или пользовательскую настройку
	// 8. Пользовательскую настройку СКД можно перемешать в СКД или Вариант отчета СКД или в другую пользовательскую настройку (перемещение)
	//    внутрь пользовательской настройки ничего перемещать нельзя
	
	Если  ТипЗнч(ПриемникПеретаскивания) = Тип("ДанныеФормыДерево") Тогда // (должно быть начальной проверкой) // 1
		
		Возврат ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхГруппа()
				ИЛИ ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхЗапрос()
				ИЛИ ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных()
				ИЛИ ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхКод();
		
	ИначеЕсли ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхПодзапрос() Тогда // 2
			
		Возврат Ложь;
		
	ИначеЕсли ПроверяемаяСтрока = ПриемникПеретаскивания Тогда // 3
		
		Возврат Ложь;
		
	ИначеЕсли ИТК_ФормаКлиент.СтрокаДеревоВходитВСтроку(ПриемникПеретаскивания, ПроверяемаяСтрока) Тогда // 4
		
		Возврат Ложь;
		
	ИначеЕсли ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхГруппа() 
				И ПриемникПеретаскивания.Тип <> ИТК_Перечисления.ЭлементДанныхГруппа() Тогда // 5
				
		Возврат Ложь;
				
	ИначеЕсли ПриемникПеретаскивания = ПроверяемаяСтрока.ПолучитьРодителя() И ПараметрыПеретаскивания.Действие <> ДействиеПеретаскивания.Копирование Тогда // 6
		
		Возврат Ложь;
	
	ИначеЕсли (ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД() 
				И ПриемникПеретаскивания.Тип <> ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД())
			 ИЛИ (ПриемникПеретаскивания.Тип = ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД()
			 		И НЕ(ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД()
							ИЛИ ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхПользовательскаяНастройкаСКД())) Тогда // 7
				
		Возврат Ложь;
				
	ИначеЕсли ПроверяемаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхПользовательскаяНастройкаСКД() 
				И ПриемникПеретаскивания.Тип <> ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД() Тогда // 8
				
		Возврат ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоОдинИзТиповСтрокиСКД(ПриемникПеретаскивания.Тип);
				
	ИначеЕсли ПриемникПеретаскивания.Тип = ИТК_Перечисления.ЭлементДанныхПользовательскаяНастройкаСКД() Тогда // 8
				
		Возврат Ложь;
				
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

// Возвращает массив строк которые можно перенести (т.е. какие из выделенных строк можно перенести в строку приемник)
//
// Параметры:
//  АнализируемыеСтроки		(Массив)										- Идентификаторы строк, которые нужно проверить 
//  ПриемникПеретаскивания	(ДанныеФормыДерево,ДанныеФормыЭлементДерева)	- Строка приемник перетаскивания
//  ПараметрыПеретаскивания	(ПараметрыПеретаскивания)						- Параметры перетаскивания
// Возвращаемое значение:
//   Массив	- Массив с идентификаторами строк, которые можно перенести
//
&НаКлиенте
Функция ПолучитьСтрокиКоторыеМожноПеренести(АнализируемыеСтроки, ПараметрыПеретаскивания, ПриемникПеретаскивания)
	
	Результат = Новый Массив;
	Для Каждого Идентификатор Из АнализируемыеСтроки Цикл
		
		ПеретаскиваемаяСтрока = ДеревоДанных.НайтиПоИдентификатору(Идентификатор);
		
		Если МожноПереместитьСтроку(ПеретаскиваемаяСтрока, ПараметрыПеретаскивания, ПриемникПеретаскивания) Тогда
			
			Результат.Добавить(Идентификатор);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Переносит (или копирует) строку дерева данных
//
// Параметры:
//  СтрокаИсточник			(ДанныеФормыЭлементДерева)						- Строка источник та которую перетаскиваем 
//  СтрокаПриемник			(ДанныеФормыДерево,ДанныеФормыЭлементДерева)	- Строка в которую перетаскиваем
//  Копирование				(Булево)										- Режим перетаскивания: Истина - копирование, Ложь - перемещение
//  СделатьСтрокуАктивной	(Булево)										- Сделать строку активной
//  ИндексВставки			(Число)											- Индекс вставки
// Возвращаемое значение:
//   ДанныеФормыЭлементДерева - Новая строка перенесенная или скопированная
//
&НаКлиенте
Функция ПереместитьСтрокуДереваДанных(СтрокаИсточник, СтрокаПриемник, Копирование = Ложь, СделатьСтрокуАктивной = Ложь, ИндексВставки = Неопределено)
	
	Если Копирование Тогда // Копирование
		
		ТипСтроки = СтрокаИсточник.Тип;
		
		Картинка = Неопределено;
		Если ТипСтроки = ИТК_Перечисления.ЭлементДанныхЗапрос()
				ИЛИ ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоОдинИзТиповСтрокиСКД(ТипСтроки)
				ИЛИ ТипСтроки = ИТК_Перечисления.ЭлементДанныхГруппа() Тогда
			ИмяНовойСтроки = СтрШаблон(НСтр("ru = '%1 - копия';
											|en = '%1 - copy'"), СтрокаИсточник.Имя);
		ИначеЕсли ТипСтроки = ИТК_Перечисления.ЭлементДанныхПодзапрос() Тогда
			Картинка = СтрокаИсточник.Картинка;
			ИмяНовойСтроки = СтрокаИсточник.Имя;
		КонецЕсли;
		
		// Копирование данных строки
		НачальныеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.НовыйЭлемент(ТипСтроки);
		ЗаполнитьЗначенияСвойств(НачальныеДанные, ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(СтрокаИсточник));
		
		// Оригинальный текст при копировании
		Если ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоТипСтрокиСИспользованиемОригинальногоТекста(ТипСтроки) Тогда
			ИТК_КонсольРазработчикаДанныеКлиентСервер.СброситьОригинальныйТекст(НачальныеДанные);
		КонецЕсли;
		
		Если ТипСтроки = ИТК_Перечисления.ЭлементДанныхЗапрос() Тогда
			
			НовыеЗначенияПараметров = Новый Соответствие;
			Для Каждого ЗначениеПараметра Из НачальныеДанные.ЗначенияПараметров Цикл 
				
				ОписаниеЗначениеПараметра = ЗначениеПараметра.Значение;
				НовыеЗначенияПараметров.Вставить(ЗначениеПараметра.Ключ, СкопироватьЗначениеПараметра(ОписаниеЗначениеПараметра));
				
			КонецЦикла;
			НачальныеДанные.ЗначенияПараметров = НовыеЗначенияПараметров;
			
		КонецЕсли;
		
		// Внешние источники
		Если ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоТипСтрокиСИспользованиемВнешнихИсточников(ТипСтроки) Тогда
			
			НовыеВнешниеИсточники = Новый Соответствие;
			Для Каждого ВременнаяТаблица Из ИТК_КонсольРазработчикаДанныеКлиентСервер.ВнешниеИсточники(НачальныеДанные) Цикл 
				
				ОписаниеВнешнегоИсточника = ИТК_ОбщийКлиентСервер.СкопироватьОбъект(ВременнаяТаблица.Значение);
				ОписаниеВнешнегоИсточника.Значение = ИТК_ОбщийВызовСервера.КопияТаблицыЗначений(ОписаниеВнешнегоИсточника.Значение, УникальныйИдентификатор);
				
				НовыеВнешниеИсточники.Вставить(Новый УникальныйИдентификатор, ОписаниеВнешнегоИсточника);
				
			КонецЦикла;
			НачальныеДанные.ВнешниеИсточники = НовыеВнешниеИсточники;
			
		КонецЕсли;
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Родитель", СтрокаПриемник);
		ДополнительныеПараметры.Вставить("Активизировать", Ложь);
		ДополнительныеПараметры.Вставить("НачальныеДанные", НачальныеДанные);
		ДополнительныеПараметры.Вставить("Картинка", Картинка);
		НоваяСтрока = ДобавитьСтрокуВДеревоДанных(ТипСтроки, ИмяНовойСтроки, ДополнительныеПараметры);
		
		НоваяСтрока.Выделение = СтрокаИсточник.Выделение;
		
	Иначе // Перемещение
		Если ИндексВставки = Неопределено Тогда
			НоваяСтрока = СтрокаПриемник.ПолучитьЭлементы().Добавить();
		Иначе 
			НоваяСтрока = СтрокаПриемник.ПолучитьЭлементы().Вставить(ИндексВставки + 1);
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИсточник);
	КонецЕсли;	
	
	Для Каждого ОбрабатываемаяСтрока Из СтрокаИсточник.ПолучитьЭлементы() Цикл
		
		ПереместитьСтрокуДереваДанных(ОбрабатываемаяСтрока, НоваяСтрока, Копирование);
		
		// Развернем в соответствии с источником
		Если Элементы.ДеревоДанных.Развернут(СтрокаИсточник.ПолучитьИдентификатор()) Тогда
			Элементы.ДеревоДанных.Развернуть(НоваяСтрока.ПолучитьИдентификатор());
		КонецЕсли;
		
	КонецЦикла;
	
	Если СделатьСтрокуАктивной Тогда
		// Установим текущую строку
		Элементы.ДеревоДанных.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
	КонецЕсли;
	
	ИТК_КонсольРазработчикаДанныеКлиентСервер.ДанныеМодифицированы(ЭтотОбъект);
	
	Возврат НоваяСтрока;
	
КонецФункции

// Добавляет новые данные 
//
// Параметры: (Отсутствуют)
//
&НаКлиенте
Процедура НовыеДанные()
	
	ТекущаяСтрока = Неопределено;
	НовыеДанныеСервер();
	
	ПерваяСтрока = ДеревоДанных.ПолучитьЭлементы()[0];
	Элементы.ДеревоДанных.ТекущаяСтрока = ПерваяСтрока.ПолучитьИдентификатор();
	
КонецПроцедуры

&НаСервере
Процедура НовыеДанныеСервер()
	
	ОчиститьДанныеСервер();
	УстановитьРабочиеДанные(РабочиеДанные);
	
	Если Не ЗначениеЗаполнено(КомандаЗапуска) Тогда
		Параметры.Свойство("Команда", КомандаЗапуска);
	КонецЕсли;
	
	Если КомандаЗапуска = "КонсольКода" Тогда
		
		ПредставлениеНовойСтроки = НСтр("ru = 'Код';
										|en = 'Code'");
		ТипНовойСтроки =  ИТК_Перечисления.ЭлементДанныхКод();

	ИначеЕсли КомандаЗапуска = "КонсольСКД" Тогда
		
		ПредставлениеНовойСтроки = НСтр("ru = 'Схема компоновки данных';
										|en = 'Data composition schema'");
		ТипНовойСтроки =  ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных();

	Иначе
		
		ПредставлениеНовойСтроки = НСтр("ru = 'Запрос';
										|en = 'Query'");
		ТипНовойСтроки =  ИТК_Перечисления.ЭлементДанныхЗапрос();
		
	КонецЕсли;
	
	ДобавитьСтрокуВДеревоДанныхСервер(ПредставлениеНовойСтроки, ТипНовойСтроки, ДеревоДанных);
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьДанныеСервер()
	
	ИТК_КонсольРазработчикаДанныеКлиентСервер.СброситьМодифицированность(ЭтотОбъект);
	
	ДеревоДанных.ПолучитьЭлементы().Очистить();
	ИдентификаторПоследнейВыделеннойСтроки = Неопределено;
	
	РезультатКоличество = "";
	ПоследняяАктивнаяОбласть = Неопределено;
	
	ОбновитьРезультатСервер();
	ИТК_КонсольРазработчикаКлиентСервер.НовыйРезультат(ТекущийРезультат);
	
КонецПроцедуры

// Сохраняет данные в файл (формат по умолчанию)
//
// Параметры:
//  ПолноеИмяФайла (Строка) - Полное имя файла
//
// Возвращаемое значение:
//   Булево - Истина, сохранено успешно; Ложь - ошибка (данные не сохранены)
&НаКлиенте
Процедура СохранитьДанныеВФайл(ПолноеИмяФайла)
	
	Состояние(НСтр("ru = 'Сохранение файла:';
					|en = 'Saving file:'"), , ПолноеИмяФайла, БиблиотекаКартинок.ИТК_ДлительнаяОперацияАнимация48);
	
	СохранитьИзмененныеДанныеСтроки();
	
	// Подготовка данных на клиенте для сервера (развернутость веток, надписи, ТипСтроки)
	ПодготовленныеДанные = ПодготовитьДанныеДляСохранения(ДеревоДанных);
	АдресХранилища = ИТК_MCRФормат.ПоместитьДанныеВоВременноеХранилище(ПодготовленныеДанные);
	
	Попытка
		
		ПолучитьФайл(АдресХранилища, ПолноеИмяФайла, Ложь);
		
		ИТК_КонсольРазработчикаДанныеКлиентСервер.СброситьМодифицированность(ЭтотОбъект);
		
		ТипыХраненияДанных = ИТК_Перечисления.ТипХраненияДанныхФайл();
		УстановитьРабочиеДанные(РабочиеДанные, ТипыХраненияДанных, ПолноеИмяФайла);
		ОбновитьЭлементыПоследниеРабочиеДанные(ТипыХраненияДанных, ПолноеИмяФайла);
		
		ПослеСохраненияДанных();
		
	Исключение
		
		// Ошибка файл не удалось сохранить
		ПредставлениеОшибки = НСтр("ru = 'Ошибка сохранения :';
									|en = 'Save failed :'") + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ПоказатьПредупреждение( , ПредставлениеОшибки, , ИТК_КонсольРазработчикаКлиентСервер.Представление());
		Возврат; 
		
	КонецПопытки;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьДанные(ОписаниеОбработчикаПослеВыполнения = Неопределено)
	
	Если ПустаяСтрока(РабочиеДанные.Имя) Тогда
		
		ИмяНастройкиСохранятьДанныеПоУмолчаниюВ = ИТК_НастройкиКлиентСерверПовтИсп.ИмяНастройкиСохранятьДанныеПоУмолчаниюВ();
		СохранятьДанныеПоУмолчаниюВ = ИТК_НастройкиКлиент.ЗначениеНастройки(ЭтотОбъект, ИмяНастройкиСохранятьДанныеПоУмолчаниюВ);

		Если СохранятьДанныеПоУмолчаниюВ = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда
			
			СохранитьКакНастройку();
			
		Иначе
			
			СохранитьКакФайл();
			
		КонецЕсли;
		
	Иначе
		
		Если РабочиеДанные.Тип = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда
			СохранитьДанныеВНастройки(РабочиеДанные.Имя);
		Иначе 
			СохранитьДанныеВФайл(РабочиеДанные.Имя);
		КонецЕсли;
		
		Если ОписаниеОбработчикаПослеВыполнения <> Неопределено Тогда
			ВыполнитьОбработкуОповещения(ОписаниеОбработчикаПослеВыполнения);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьФайлЗакончено(ВыбранныеФайлы, ОписаниеОбработчика) Экспорт 
	
	Если ЗначениеЗаполнено(ВыбранныеФайлы) Тогда
		СохранитьДанныеВФайл(ВыбранныеФайлы[0]);
	КонецЕсли;
	
	Если ОписаниеОбработчика <> Неопределено Тогда
		ВыполнитьОбработкуОповещения(ОписаниеОбработчика);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьЗакладкуПараметры()
	
	ПараметрыЗапросаЭлементы = ПараметрыЗапроса;
	ПараметрыЗапросаЭлементы.Очистить();
	КоличествоПараметровВЗапросе = 0;
	
	Если ТекущаяСтрока = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ТребуетсяПроверка = ТребуетсяПроверкаСтроки();
	
	Если ТребуетсяПроверка Тогда
		Возврат;
	КонецЕсли;
		
	СписокПараметровЗапроса = СписокПараметровЗапроса(ТекущаяСтрока);
	Для Каждого ПараметрЗапроса Из СписокПараметровЗапроса Цикл
		
		СтрокаПараметр = ПараметрыЗапросаЭлементы.Добавить();
		ОбновитьСтрокуПараметра(СтрокаПараметр, ПараметрЗапроса.Представление, ПараметрЗапроса.Значение.Тип, ПараметрЗапроса.Значение.Значение);
		
	КонецЦикла;
	
	КоличествоПараметровВЗапросе = СписокПараметровЗапроса.Количество();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСтрокуПараметра(Строка, Имя, ДоступныеТипы, Значение)
	
	ТипПараметра = ИТК_Перечисления.ТипЗначенияПараметраЗапросаЗначение();
	ТипЗначения = ТипЗнч(Значение);
	СложныйПараметр = ИТК_КонсольРазработчикаКлиентСервер.ЭтоСложныйПараметр(ТипЗначения);
	Если ТипЗначения = Тип("СписокЗначений") Тогда
		
		ТипПараметра = ИТК_Перечисления.ТипЗначенияПараметраЗапросаСписок();
		
	ИначеЕсли СложныйПараметр Тогда
		
		Если Значение.Вид = ИТК_Перечисления.СложныйПараметрЗапросаВыражение() Тогда
			ТипПараметра = ИТК_Перечисления.ТипЗначенияПараметраЗапросаВыражение();
		КонецЕсли;
		
	КонецЕсли;
	
	Если СложныйПараметр Тогда
		
		ПредставлениеПараметра = Значение.Представление;
		
	ИначеЕсли ТипЗнч(Значение) = Тип("СписокЗначений")
				ИЛИ ТипЗнч(Значение) = Тип("МоментВремени")
				ИЛИ ТипЗнч(ТипЗначения) = Тип("Тип") Тогда
		
		ПредставлениеПараметра = Значение;
		
	Иначе
		
		ПредставлениеПараметра = ДоступныеТипы.ПривестиЗначение(Значение);
		
	КонецЕсли;
	
	Строка.Тип = ТипПараметра;
	Строка.Имя = Имя;
	Строка.ТипЗначения = ДоступныеТипы;
	Строка.Картинка = ИТК_КонсольРазработчикаКлиентСервер.КартинкаПараметраЗапроса(ДоступныеТипы);
	Строка.ЗначениеПредставление = ПредставлениеПараметра;
	
	ПараметрыЗапросаПриАктивизацииСтроки(Элементы.ПараметрыЗапроса);
	
КонецПроцедуры

&НаКлиенте
Функция ПреобразоватьЗначениеПараметраКТипу(Значение, ТипЗначения, ИзТипа, КТипу, ТекстОшибки = "")
	
	Результат = Неопределено;
	
	Если ИзТипа = ИТК_Перечисления.ТипЗначенияПараметраЗапросаСписок() Тогда
		
		Если КТипу = ИТК_Перечисления.ТипЗначенияПараметраЗапросаЗначение() Тогда
			
			Если ЗначениеЗаполнено(Значение) Тогда
				
				Если ТипЗнч(Значение) = Тип("Массив") Тогда
					Результат = Значение[0];
				Иначе
					Результат = Значение[0].Значение;
				КонецЕсли;
				
			КонецЕсли;
			
		ИначеЕсли КТипу = ИТК_Перечисления.ТипЗначенияПараметраЗапросаВыражение() Тогда
			
			Результат = ИТК_КодВызовСервера.ЗначениеПараметра(Значение, "Список");
			
		КонецЕсли;
		
	ИначеЕсли ИзТипа = ИТК_Перечисления.ТипЗначенияПараметраЗапросаЗначение() Тогда 
		
		Если КТипу = ИТК_Перечисления.ТипЗначенияПараметраЗапросаСписок() Тогда
			
			Результат = ИТК_ОбщийКлиентСервер.НовыйСписокЗначений(Значение);
			
		ИначеЕсли КТипу = ИТК_Перечисления.ТипЗначенияПараметраЗапросаВыражение() Тогда
			
			Если ТипЗнч(ТипЗначения) = Тип("Структура") Тогда				
				
				Если ТипЗначения.Вид = ИТК_Перечисления.СложныйПараметрЗапросаТаблицаЗначений() Тогда
					
					Если ЗначениеЗаполнено(Значение.Значение) Тогда
						
						Результат = ИТК_КодВызовСервера.ЗначениеПараметра(Значение.Значение, "Таблица");
						
					Иначе
						
						ЯзыкПрограммирования = ИТК_НастройкиКлиент.ЗначениеОбщейНастройки(ЭтотОбъект, "ЯзыкПрограммирования");
						ВидПараметра = ИТК_Перечисления.СложныйПараметрЗапросаВыражение();
						Значение = НСтр("ru = 'Результат = Новый ТаблицаЗначений';
										|en = 'Result = New ValueTable'", ЯзыкПрограммирования);
						
						Результат = ИТК_ЗапросКлиентСервер.ЗначениеСложногоПараметра(ВидПараметра, Значение);
						
					КонецЕсли;
					
				ИначеЕсли ТипЗначения.Вид = ИТК_Перечисления.СложныйПараметрЗапросаГраница() Тогда
					
					Результат = ИТК_КодВызовСервера.ЗначениеПараметра(Значение.Значение);
					
				КонецЕсли;			
				
			Иначе
				
				Результат = ИТК_КодВызовСервера.ЗначениеПараметра(Значение);
				
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли ИзТипа = ИТК_Перечисления.ТипЗначенияПараметраЗапросаВыражение() Тогда 
		
		ВычисленноеЗначение = ИТК_КодВызовСервера.ПараметрИзВыражения(Значение.Значение, УникальныйИдентификатор, ТекстОшибки);
		
		Если ТипЗнч(ВычисленноеЗначение) = Тип("СписокЗначений")
				ИЛИ ТипЗнч(ВычисленноеЗначение) = Тип("Массив") Тогда
			ТипВычисленногоЗначения = ИТК_Перечисления.ТипЗначенияПараметраЗапросаСписок();
		Иначе 
			ТипВычисленногоЗначения = ИТК_Перечисления.ТипЗначенияПараметраЗапросаЗначение();
		КонецЕсли;
		
		Если ТипВычисленногоЗначения = КТипу Тогда
			
			Если ТипЗнч(ВычисленноеЗначение) = Тип("Граница") Тогда
				
				Результат = ИТК_ЗапросКлиентСервер.ЗначениеСложногоПараметра(ИТК_Перечисления.СложныйПараметрЗапросаГраница(),
														ИТК_Запрос.ОписаниеИзГраницы(ВычисленноеЗначение));
				
			ИначеЕсли ТипЗнч(ВычисленноеЗначение) = Тип("Массив") Тогда
				
				Результат = Новый СписокЗначений;
				Результат.ЗагрузитьЗначения(ВычисленноеЗначение);
				
			Иначе
				Результат = ВычисленноеЗначение;
			КонецЕсли;
			
		Иначе 
			
			Если СписокДоступенДляПараметра(ВычисленноеЗначение, ТипЗначения) Тогда
				Результат = ПреобразоватьЗначениеПараметраКТипу(ВычисленноеЗначение, ТипЗначения, ТипВычисленногоЗначения, КТипу, ТекстОшибки);
			Иначе
				
				ТекстПредупреждения = СтрШаблон(НСтр("ru = 'Для значений типа %1 редактирование в списке недоступно';
													|en = 'For values of type %1 editing is not available in the list'"), ТипЗнч(ВычисленноеЗначение));
				ПоказатьПредупреждение( , ТекстПредупреждения, , ИТК_КонсольРазработчикаКлиентСервер.Представление());
				
				Результат = Значение;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

&НаСервере
Процедура ОбновитьЭлементыПоследниеРабочиеДанные(Тип = Неопределено, ИмяДобавляемого = "", ИмяУдаляемого = "")
	
	Если ЗначениеЗаполнено(ИмяУдаляемого) Тогда
		ИТК_КонсольРазработчика.УдалитьИзПоследнихРабочихДанных(ИмяУдаляемого, Тип);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИмяДобавляемого) Тогда
		ИТК_КонсольРазработчика.ДобавитьВПоследниеРабочиеДанные(ИмяДобавляемого, Тип);
	КонецЕсли;
	
	ПоследниеРабочиеДанные = ИТК_КонсольРазработчика.ПоследниеРабочиеДанныеВсе();
	
	Если Тип = Неопределено ИЛИ Тип = ИТК_Перечисления.ТипХраненияДанныхФайл() Тогда
		ОбновитьЭлементыНабораПоследнихРабочихДанных(Элементы.ПоследниеРабочиеФайлы, ИТК_Перечисления.ТипХраненияДанныхФайл());
	КонецЕсли;
	
	Если Тип = Неопределено ИЛИ Тип = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда
		ОбновитьЭлементыНабораПоследнихРабочихДанных(Элементы.ПоследниеРабочиеНастройки, ИТК_Перечисления.ТипХраненияДанныхНастройка());
	КонецЕсли;
	
	ОбновитьЭлементыНабораПоследнихРабочихДанных(Элементы.ПоследниеРабочиеДанные);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьЭлементыНабораПоследнихРабочихДанных(ЭлементРодитель, Тип = Неопределено)
	
	// Уберем видимость всех кнопок
	Для Каждого Кнопка Из ЭлементРодитель.ПодчиненныеЭлементы Цикл
		Кнопка.Видимость = Ложь;
	КонецЦикла;
	
	Если Тип = Неопределено Тогда
		НаборДанных = ПоследниеРабочиеДанные.Все;
	ИначеЕсли Тип = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда
		НаборДанных = ПоследниеРабочиеДанные.Настройки;
	ИначеЕсли Тип = ИТК_Перечисления.ТипХраненияДанныхФайл() Тогда
		НаборДанных = ПоследниеРабочиеДанные.Файлы;
	КонецЕсли;
	
	Индекс = 0;
	Для Каждого ЭлементДанных Из НаборДанных Цикл 
		
		Если ТипЗнч(ЭлементДанных) = Тип("Структура") Тогда
			
			ИмяДанных = ЭлементДанных.Имя;
			ТипПоследнихРабочихДанных = ЭлементДанных.Тип;
			Если ТипПоследнихРабочихДанных = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда
				ИндексКоманды = ПоследниеРабочиеДанные.Настройки.Найти(ИмяДанных);
			ИначеЕсли ТипПоследнихРабочихДанных = ИТК_Перечисления.ТипХраненияДанныхФайл() Тогда
				ИндексКоманды = ПоследниеРабочиеДанные.Файлы.Найти(ИмяДанных);
			КонецЕсли;
			
		Иначе
			
			ИмяДанных = ЭлементДанных;
			ТипПоследнихРабочихДанных = Тип;
			ИндексКоманды = Индекс;
			
		КонецЕсли;
		
		КартинкаКнопки = Новый Картинка;
		Если ТипПоследнихРабочихДанных = ИТК_Перечисления.ТипХраненияДанныхФайл() Тогда
			
			ИмяКоманды = "ОткрытьПоследнийФайл" + ИндексКоманды;
			ИмяДействия = "ПодключаемаяКомандаОткрытьПоследнийФайл";
			КартинкаКнопки = ИТК_ОбщийКлиентСерверПовтИсп.БиблиотекаКартинок("ИТК_ТипХраненияДанныхФайл");
			
		ИначеЕсли ТипПоследнихРабочихДанных = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда
			
			ИмяКоманды = "ОткрытьПоследнююНастройку" + ИндексКоманды;
			ИмяДействия = "ПодключаемаяКомандаОткрытьПоследнююНастройку";
			КартинкаКнопки = ИТК_ОбщийКлиентСерверПовтИсп.БиблиотекаКартинок("ИТК_ТипХраненияДанныхНастройка");
			
		КонецЕсли;
		
		Если Тип = Неопределено Тогда
			ИмяКнопки = "КнопкаОткрытьПоследниеРабочиеДанные" + Индекс;
		ИначеЕсли Тип = ИТК_Перечисления.ТипХраненияДанныхФайл() Тогда
			ИмяКнопки = "КнопкаОткрытьПоследнююНастройку" + Индекс;
		ИначеЕсли Тип = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда
			ИмяКнопки = "КнопкаОткрытьПоследнийФайл" + Индекс;
		КонецЕсли;
		
		Команда = Команды.Найти(ИмяКоманды);
		Если Команда = Неопределено Тогда
			Команда = Команды.Добавить(ИмяКоманды);
			Команда.Действие = ИмяДействия;
		КонецЕсли;
		
		Кнопка = Элементы.Найти(ИмяКнопки);
		Если Кнопка = Неопределено Тогда
			Кнопка = ИТК_Форма.ДобавитьЭлемент(ЭтотОбъект, ИмяКнопки, "Кнопка", , ЭлементРодитель); // Новая кнопка
		КонецЕсли;
		Кнопка.ИмяКоманды = ИмяКоманды; 
		
		Кнопка.Видимость = Истина;
		
		Если ТипПоследнихРабочихДанных = ИТК_Перечисления.ТипХраненияДанныхФайл() Тогда 
			Кнопка.Заголовок = ИТК_ФайлыКлиентСервер.ПолноеИмяФайлаКратко(ИмяДанных);
		Иначе 
			Кнопка.Заголовок = ИмяДанных;
		КонецЕсли;	
		
		Кнопка.Картинка = КартинкаКнопки;
		
		Индекс = Индекс + 1;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура РезультатПриАктивизацииОбластиПодключаемый() Экспорт
	
	ИТК_ТабличныйДокументКлиент.ПриАктивизацииОбластиОбработка(ЭтотОбъект, ТабличныйДокументРезультат);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьКонструкторСхемыКомпоновкиДанных()
	
	ОсновнаяСтрокаСКД = ОсновнаяСхемаКомпоновкиДанных(ТекущаяСтрока);
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ОсновнаяСтрокаСКД);
	ИТК_ФормаКлиент.ОткрытьКонструкторСхемыКомпоновкиДанных(ЭтотОбъект, ТекущиеДанные.Текст);

КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьОперацию(Режим, ИгнорироватьЛимитСтрок = Ложь, ОбрабатываемаяСтрока = Неопределено)
	
	Если ОбрабатываемаяСтрока = Неопределено Тогда
		ОбрабатываемаяСтрока = ТекущаяСтрока;
	КонецЕсли;

	Если Не ИТК_КонсольРазработчикаДанныеКлиентСервер.КорректнаяОперацияВыполнения(ОбрабатываемаяСтрока.Тип, Режим) Тогда
		Возврат;
	КонецЕсли;
	
	НаименованиеОперации = ИТК_КонсольРазработчикаКлиентСервер.НаименованиеВыполняемойОперации(Режим);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Режим", Режим);
	ДополнительныеПараметры.Вставить("НаименованиеОперации", НаименованиеОперации);
	ДополнительныеПараметры.Вставить("ОбрабатываемаяСтрока", ОбрабатываемаяСтрока);
	ДополнительныеПараметры.Вставить("ИгнорироватьЛимитСтрок", ИгнорироватьЛимитСтрок);
	
	ОписаниеОбработчика = Новый ОписаниеОповещения("ВыполнитьОперациюОбработчикОповещения", ЭтотОбъект, ДополнительныеПараметры);
	ЗапуститьОбработчикСПроверкойНаВозможностьВыполнения(ОписаниеОбработчика, НаименованиеОперации, ОбрабатываемаяСтрока);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьОперациюНаКлиенте(Строка, Режим)
	
	//Выполнить 
	Данные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(Строка);

	РезультатВыполнения = ИТК_КодКлиентСервер.Исполнить(Данные.Текст, Режим);
	
	ДополненныйРезультат = Новый Структура;
	ДополненныйРезультат.Вставить("Результат", РезультатВыполнения.Результат);
	ДополненныйРезультат.Вставить("Сообщения", Неопределено);
	
	РезультатВыполнения.Вставить("Результат", ДополненныйРезультат);
	
	Результат = Новый Структура;
	Результат.Вставить("Статус", "Выполнено");
	
	АдресРезультата = ПоместитьВоВременноеХранилище(РезультатВыполнения, УникальныйИдентификатор);
	Результат.Вставить("АдресРезультата", АдресРезультата);
	
	ОповещениеОЗавершении = ОповещениеОЗавершенииВыполнения(Строка);
	ВыполнитьОбработкуОповещения(ОповещениеОЗавершении, Результат);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьОперациюЧерезДлительныеОперации(Строка, НаименованиеОперации, Режим, ИгнорироватьЛимитСтрок)
	
	ОписаниеОперации = Новый Структура;
	ОписаниеОперации.Вставить("Источник", ИТК_Перечисления.ИнструментКонсольРазработчика());
	ОписаниеОперации.Вставить("Наименование", НаименованиеОперации);
	
	// Запуск длительной операции выполнения
	ИТК_ДлительныеОперацииКлиент.НачатьОперацию(ЭтотОбъект, Новый ОписаниеОповещения("НачалоДлительнойОперации", ЭтотОбъект), ОписаниеОперации);
	
	Данные = ПодготовитьДанныеПередВыполнением(Строка);
	
	ФоновоеВыполнение = ИТК_БСПКлиентСервер.ВозможноВыполнениеВФоне()
							И ИТК_НастройкиКлиент.ЗначениеНастройки(ЭтотОбъект, "ФоновоеВыполнение");
	
	АнализируетсяПланЗапроса = (Режим = ИТК_Перечисления.РежимВыполненияЗапросаВыполнение())
									И ИТК_НастройкиКлиент.ЗначениеНастройки(ЭтотОбъект, "ПолучениеПлана") <> ИТК_Перечисления.ПолучениеПланаОтключено();
									
	Если АнализируетсяПланЗапроса Тогда
		ДлительнаяОперация = ЗапуститьВыполнениеСАнализомПланаНаСервере(Данные, Режим, ИгнорироватьЛимитСтрок, УникальныйИдентификатор, ФоновоеВыполнение);
	Иначе
		ДлительнаяОперация = ЗапуститьВыполнениеНаСервере(Данные, Режим, ИгнорироватьЛимитСтрок, УникальныйИдентификатор, ФоновоеВыполнение);
	КонецЕсли;
	
	ИТК_ДлительныеОперацииКлиент.ЗаполнитьОписаниеОперации(ДлительнаяОперация, ОписаниеОперации);
	
	ОповещениеОПрогрессеВыполнения = Новый ОписаниеОповещения("ОбработкаПрогрессаВыполненияДлительнойОперации", ЭтотОбъект);
	ПараметрыОжидания = ИТК_ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект, ОповещениеОПрогрессеВыполнения);
	
	ИТК_ДлительныеОперацииКлиент.ДобавитьОповещениеПользователя(ЭтотОбъект, ПараметрыОжидания);
	ИТК_ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершенииВыполнения(Строка), ПараметрыОжидания);
	
КонецПроцедуры

&НаКлиенте
Функция ОповещениеОЗавершенииВыполнения(Строка)
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("UID", Строка.UID);
	
	Результат = Новый ОписаниеОповещения("ЗавершениеВыполненияДанных", ЭтотОбъект, ДополнительныеПараметры);
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция ЗапуститьВыполнениеСАнализомПланаНаСервере(Знач Данные, Режим, ИгнорироватьЛимитСтрок, УникальныйИдентификатор, ФоновоеВыполнение)
	
	Возврат ЗапуститьВыполнениеНаСервере(Данные, Режим, ИгнорироватьЛимитСтрок, УникальныйИдентификатор, ФоновоеВыполнение);
	
КонецФункции

&НаСервереБезКонтекста
Функция ЗапуститьВыполнениеНаСервере(Знач Данные, Режим, ИгнорироватьЛимитСтрок, УникальныйИдентификатор, ФоновоеВыполнение)
	
	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("Данные", ПодготовитьДанныеПередВыполнениемНаСервере(Данные));
	ПараметрыПроцедуры.Вставить("Режим", Режим);
	
	Если ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоОдинИзТиповСтрокиЗапрос(Данные.Тип) Тогда
		
		ПолноеИмяМетода = "ИТК_Запрос.ПолучитьРезультат";
		ПараметрыПроцедуры.Вставить("ИгнорироватьЛимитСтрок", ИгнорироватьЛимитСтрок);
		
	ИначеЕсли ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоОдинИзТиповСтрокиСКД(Данные.Тип) Тогда
		
		ПолноеИмяМетода = "ИТК_СКД.ПолучитьРезультат";
		
	ИначеЕсли Данные.Тип = ИТК_Перечисления.ЭлементДанныхКод() Тогда
		
		ПолноеИмяМетода = "ИТК_Код.Исполнить";
		
	КонецЕсли;
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор, ФоновоеВыполнение);
	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне(ПолноеИмяМетода, ПараметрыПроцедуры, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ЗавершениеВыполненияДанных(Результат, ДополнительныеПараметры) Экспорт
	
	ИТК_ДлительныеОперацииКлиент.СкрытьПрогресс(ЭтотОбъект);
	
	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПодробноеПредставлениеОшибки = ИТК_ОбщийКлиентСервер.Свойство(Результат, "ПодробноеПредставлениеОшибки");
	Если ЗначениеЗаполнено(ПодробноеПредставлениеОшибки) Тогда
		
		ПоказатьПредупреждение( , СтрШаблон(НСтр("ru = 'Ошибка при выполнении:
												|%1';
												|en = 'Runtime error:
												|%1'"), ПодробноеПредставлениеОшибки), , ИТК_КонсольРазработчикаКлиентСервер.Представление());
		Возврат;
		
	КонецЕсли;
	
	ОбработаннаяСтрока = НайтиСтрокуПоUID(ДеревоДанных, ДополнительныеПараметры.UID);
	Если ОбработаннаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Свойство("АдресРезультата") Тогда
		Результат = ПрочитатьРезультатВыполненияДанных(Результат, УникальныйИдентификатор);
	КонецЕсли;
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ОбработаннаяСтрока);
	
	Если Результат.Свойство("ВремяВыполнения") Тогда
		ТекущиеДанные.ВремяВыполнения = Результат.ВремяВыполнения;
	КонецЕсли;
	
	ОшибкаПриВыполнении = Результат.ОшибкаПриВыполнении;
	ТекущиеДанные.ОшибкаПриВыполнении = ОшибкаПриВыполнении;
	
	ОбновитьЭлементыФормы();
	
	ТребуетсяОбновлениеРезультатаВыполнения = Истина;
	Если ЗначениеЗаполнено(ОшибкаПриВыполнении) Тогда 
		
		ПоказатьОшибкуПослеОжидания();
		ТребуетсяОбновлениеРезультатаВыполнения = ТекущиеДанные.Свойство("Тип") И (ТекущиеДанные.Тип = ИТК_Перечисления.ЭлементДанныхКод());
		
	КонецЕсли;
	
	Если НЕ ТребуетсяОбновлениеРезультатаВыполнения Тогда
		Возврат;
	КонецЕсли;
	
	РежимВыполнения = ИТК_ОбщийКлиентСервер.Свойство(Результат, "РежимВыполнения");
	Если ИТК_ОбщийКлиентСервер.ЭтоРежимВыполненияСРезультатом(РежимВыполнения) Тогда
		
		ОбновитьРезультатВыполнения(Результат);
		
	ИначеЕсли РежимВыполнения = ИТК_Перечисления.РежимВыполненияСКДПолучениеИсполняемыхЗапросов() Тогда
		
		ОткрытьФормуАнализаИсполняемыхЗапросов(Результат.АдресИсполняемыхЗапросовСКД);
		
	КонецЕсли;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПрочитатьРезультатВыполненияДанных(РезультатВыполнения, УникальныйИдентификатор)
	
	Результат = ПолучитьИзВременногоХранилища(РезультатВыполнения.АдресРезультата);
	
	Если Результат.Свойство("Результат") Тогда
		Результат.Вставить("АдресРезультата", ИТК_ВременноеХранилище.Поместить(Результат.Результат, , УникальныйИдентификатор));
		Результат.Удалить("Результат");
	КонецЕсли;
	
	Если Результат.Свойство("ДанныеРасшифровки") Тогда
		Результат.Вставить("АдресДанныхРасшифровки", ИТК_ВременноеХранилище.Поместить(Результат.ДанныеРасшифровки, , УникальныйИдентификатор));
		Результат.Удалить("ДанныеРасшифровки");
	КонецЕсли;
	
	Если Результат.Свойство("СхемаКомпоновкиДанных") Тогда
		Результат.Вставить("АдресСхемыКомпоновкиДанных", ИТК_ВременноеХранилище.Поместить(Результат.СхемаКомпоновкиДанных, , УникальныйИдентификатор));
		Результат.Удалить("СхемаКомпоновкиДанных");
	КонецЕсли;
	
	Если Результат.Свойство("ИсполняемыеЗапросы") Тогда
		Результат.Вставить("АдресИсполняемыхЗапросовСКД", ИТК_ВременноеХранилище.Поместить(Результат.ИсполняемыеЗапросы, , УникальныйИдентификатор));
		Результат.Удалить("ИсполняемыеЗапросы");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ОбработкаПрогрессаВыполненияДлительнойОперации(Результат, ДополнительныеПараметры) Экспорт

	ИТК_ДлительныеОперацииКлиент.ПоказатьПрогресс(ЭтотОбъект);
	
	Прогресс = Результат.Прогресс;
	Если ЗначениеЗаполнено(Прогресс) Тогда
		
		ПрогрессДлительнойОперации = СтрШаблон("%1: %2", ДлительнаяОперация.Наименование, Результат.Прогресс.Текст);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьСхемыКомпоновкиДанныхИзФайлаПослеПомещенияФайлов(ПомещенныеФайлы, ДополнительныеПараметры) Экспорт
	
	Если ПомещенныеФайлы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекстСхемыКомпоновкиДанных = ЗагрузитьФайлСхемыКомпоновкиДанныхНаСервере(ПомещенныеФайлы[0].Хранение);

	ИзменяемыеПоля = Новый Структура;
	ИзменяемыеПоля.Вставить("Текст", ТекстСхемыКомпоновкиДанных);
	ИзменяемыеПоля.Вставить("ТребуетсяПроверка", Истина);
	ИзменяемыеПоля.Вставить("Ошибка", Неопределено);
	
	ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоля(ЭтотОбъект, ТекущаяСтрока, ИзменяемыеПоля);
	
	ПодключаемыйЗагрузитьСостояниеРедактораКода();
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	ПроверитьСхемуКомпоновкиДанных(ТекущиеДанные);
	
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗагрузитьФайлСхемыКомпоновкиДанныхНаСервере(Адрес)
	
	Данные = ПолучитьИзВременногоХранилища(Адрес);
	
	ЧтениеТекста = Новый ЧтениеТекста(Данные.ОткрытьПотокДляЧтения());
	Результат = ЧтениеТекста.Прочитать();
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура СохранитьСхемуКомпоновкиДанныхВФайлПослеВыбораФайла(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныеФайлы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПолноеИмяФайла = ВыбранныеФайлы[0];
	XMLТекст = ИТК_РедакторКодаКлиент.Текст(ЭтотОбъект, "СхемаКомпоновкиДанныхXML");
	
	ТекстовыйДокумент = Новый ТекстовыйДокумент;
	ТекстовыйДокумент.УстановитьТекст(XMLТекст);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ПолноеИмяФайла", ПолноеИмяФайла);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ЗавершенаЗаписьСхемуКомпоновкиДанныхВФайл", ЭтотОбъект, ДополнительныеПараметры);
	ТекстовыйДокумент.НачатьЗапись(ОписаниеОповещения, ПолноеИмяФайла, КодировкаТекста.UTF8);

КонецПроцедуры

&НаКлиенте
Процедура ЗавершенаЗаписьСхемуКомпоновкиДанныхВФайл(Результат, ДополнительныеПараметры) Экспорт
	
	//ИТК_ФайлыКлиент.ОткрытьВПроводнике(ДополнительныеПараметры.ПолноеИмяФайла);

КонецПроцедуры

&НаКлиенте
Процедура ПоказатьОшибку(Нажатие = Ложь)
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	Ошибка = ОшибкаВДанных(ТекущиеДанные);
	
	ЭлементТекст = ЭлементТекстПоТипуСтроки(ТекущаяСтрока.Тип);
	Если ЭлементТекст = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	Если ТипЗнч(Ошибка) = Тип("Структура") Тогда
		
		Если ТекущаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхКод() Тогда
			ПоказатьОшибкуВКоде(ЭлементТекст, Ошибка, Нажатие);
		Иначе
			ИТК_РедакторКодаКлиент.ПоказатьОшибку(ЭлементТекст, Ошибка.НомерСтроки, Ошибка.НомерСтолбца);
		КонецЕсли;
		
	КонецЕсли;
		
	ТекущийЭлемент	= ЭлементТекст;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьОшибкуПослеОжидания()
	
	ПодключитьОбработчикОжидания("ПодключаемыйПоказатьОшибку", 0.1, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйПоказатьОшибку()
	
	ПоказатьОшибку();
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьОшибкуВКоде(ЭлементТекст, Ошибка, Нажатие = Ложь)
	
	ОписаниеОшибки = Ошибка.ОписаниеОшибки;
	
	Если ЗначениеЗаполнено(ОписаниеОшибки.ИмяМодуля) Тогда
		
		ТекущийЭлемент = ЭлементТекст;
		
		Если Нажатие Тогда
			ИТК_РедакторКодаКлиент.ОткрытьКодМодуля(ОписаниеОшибки.ИмяМодуля, ОписаниеОшибки.НомерСтроки);
		КонецЕсли;
		
	Иначе
		
		ИТК_РедакторКодаКлиент.ПоказатьОшибку(ЭлементТекст, ОписаниеОшибки.НомерСтроки);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ОшибкаВДанных(Данные)
	
	Если Данные.Свойство("Ошибка")
			И ЗначениеЗаполнено(Данные.Ошибка) Тогда
			
		Результат = Данные.Ошибка;
			
	Иначе
		
		Результат = Данные.ОшибкаПриВыполнении;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция КартинкаОшибкиВДанных(Данные)
	
	Если Данные.Свойство("Ошибка") 
			И ЗначениеЗаполнено(Данные.Ошибка) Тогда
			
		Результат = БиблиотекаКартинок.ИТК_ОшибкаВТексте;
		
	ИначеЕсли ЗначениеЗаполнено(Данные.ОшибкаПриВыполнении) Тогда
		
		Результат = БиблиотекаКартинок.ИТК_ОшибкаПриВыполнении;
		
	Иначе
		
		Результат = Новый Картинка;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ПроверитьПоказатьОшибку(ВыводитьПредупреждениеОшибокНет = Ложь)
	
	ОписаниеОшибки = ПроверитьДанныеСтроки(ТекущаяСтрока);
	
	ОбновитьЭлементыФормы();
	
	Если ЗначениеЗаполнено(ОписаниеОшибки.Текст) Тогда 
		
		ПоказатьОшибку();
		
	Иначе
		
		Если ВыводитьПредупреждениеОшибокНет Тогда
			
			Если ТекущаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхЗапрос() Тогда
				
				ТекстОшибокНет = НСтр("ru = 'Запрос проверен. Ошибок нет';
										|en = 'Query verified. There are no errors'");
				
			ИначеЕсли ТекущаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных() Тогда
				
				ТекстОшибокНет = НСтр("ru = 'Схема компоновки данных проверена. Ошибок нет';
										|en = 'Data layout scheme has been verified. There are no errors'");
				
			КонецЕсли;
			
			ПоказатьОповещениеПользователя(ИТК_КонсольРазработчикаКлиентСервер.Представление(), , ТекстОшибокНет, БиблиотекаКартинок.СинтаксическийКонтроль);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьПоказатьОшибкуПослеОжидания()
	
	ПодключитьОбработчикОжидания("ПодключаемыйПроверитьПоказатьОшибкуПослеОжидания", 0.1, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйПроверитьПоказатьОшибкуПослеОжидания()

	ПроверитьПоказатьОшибку();

КонецПроцедуры

&НаКлиенте
Функция ПроверитьДанныеСтроки(ДанныеСтроки, Данные = Неопределено)
	
	Если Данные = Неопределено Тогда
		Данные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	КонецЕсли;
	
	ТипДанных = ДанныеСтроки.Тип;
	
	Если Данные.Свойство("ТребуетсяПроверка") Тогда
		
		Если Данные.ТребуетсяПроверка Тогда
			
			Данные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ДанныеСтроки);
			
			Если ТипДанных = ИТК_Перечисления.ЭлементДанныхЗапрос() Тогда
				
				ПроверитьЗапрос(Данные);
				ОбновитьСтруктуруЗапросов(ДанныеСтроки);
				
			ИначеЕсли ТипДанных = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных() Тогда
				
				ПроверитьСхемуКомпоновкиДанных(Данные);
				
			КонецЕсли;
			
		КонецЕсли;
		
		Текст = ИТК_ОбщийКлиентСервер.ПредставлениеОшибкиВТекстеЗапросаИлиСхемеКомпоновкиДанных(Данные.Ошибка);
		
	Иначе
		
		Текст = "";
		
	КонецЕсли;

	Результат = Новый Структура;
	Результат.Вставить("Текст", Текст);
	Результат.Вставить("ТипДанных", ТипДанных);
	
	Возврат Результат
	
КонецФункции

&НаКлиенте
Функция ЗапускНевозможенПроверкаОповещение(Операция, Данные = Неопределено)
	
	СохранитьИзмененныеДанныеСтроки();
	
	// Проверяем, получаем описание
	ОписаниеОшибки = ПроверитьДанныеСтроки(ТекущаяСтрока, Данные);	
	
	Если ЗначениеЗаполнено(ОписаниеОшибки.Текст) Тогда
		
		// Выводим оповещение
		Пояснение = СтрШаблон(НСтр("ru = '%1 содержит ошибку: 
		|%2';
		|en = '%1 contains an error:
		|%2'"), ИТК_Перечисления.Представление(ОписаниеОшибки.ТипДанных), ОписаниеОшибки.Текст);
		
		ПоказатьОповещениеПользователя(СтрШаблон(НСтр("ru = 'Невозможно запустить ""%1""';
														|en = 'Unable to start ""%1""'"), Операция), , Пояснение, БиблиотекаКартинок.ИТК_ПредупреждениеВажное);
		ПроверитьПоказатьОшибкуПослеОжидания();
		
	КонецЕсли;
	
	Возврат ЗначениеЗаполнено(ОписаниеОшибки.Текст);
	
КонецФункции

&НаКлиенте
Процедура ЗапуститьОбработчикСПроверкойНаВозможностьВыполнения(ОписаниеОбработчика, Операция, Строка)
	
	Перем ОписаниеОповещенияОЗакрытии;
	
	СохранитьИзмененныеДанныеСтроки();
	Данные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(Строка);
	
	Если Строка.Тип = ИТК_Перечисления.ЭлементДанныхЗапрос()
			И ЗначениеЗаполнено(Данные.Текст)
			И ЗначениеЗаполнено(Данные.Ошибка) Тогда
			
		ЗаголовокВопроса = ИТК_КонсольРазработчикаКлиентСервер.Представление();
		ОписаниеОповещенияОЗакрытии = Новый ОписаниеОповещения("ЗавершенВопросВТекстеЗапросаИмеютсяОшибки", ЭтотОбъект, ОписаниеОбработчика);
		ТекстВопроса = НСтр("ru = 'В тексте запроса имеются ошибки. Выполнить?'; en = 'There are errors in the request text. Execute?'");
		
		КнопкиВопроса = Новый СписокЗначений;
		КнопкиВопроса.Добавить(Ложь, НСтр("ru = 'Перейти к ошибке'; en = 'Go to error'"));
		КнопкиВопроса.Добавить(Истина, НСтр("ru = 'Выполнить'; en = 'Execute'"));
		КнопкиВопроса.Добавить(Неопределено, НСтр("ru = 'Отмена'; en = 'Cancel'"));
		
		ИТК_ФормаКлиент.ЗадатьВопрос(ОписаниеОповещенияОЗакрытии, ТекстВопроса, КнопкиВопроса, Истина, ЗаголовокВопроса, ЭтотОбъект, "ПередВыполнениемЗапросаСОшибкой");
		
	Иначе
		
		Если ЗапускНевозможенПроверкаОповещение(Операция, Данные) Тогда
			Возврат;
		КонецЕсли;
		
		ВыполнитьОбработкуОповещения(ОписаниеОбработчика);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершенВопросВТекстеЗапросаИмеютсяОшибки(Результат, ОписаниеОбработчика) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат = Истина Тогда
		ВыполнитьОбработкуОповещения(ОписаниеОбработчика);
	Иначе
		ПроверитьПоказатьОшибкуПослеОжидания();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьЗапрос(Данные)
	
	Если ЗначениеЗаполнено(Данные.Текст) Тогда
		
		РезультатПроверки = ИТК_Запрос.ПроверитьТекст(Данные.Текст);
		
		ПолученныеПараметры = РезультатПроверки.Параметры;
		ПолученныеВременныеТаблицы = РезультатПроверки.ВременныеТаблицы;
		ПолученноеОписаниеВнешнихИсточников = РезультатПроверки.ВнешниеИсточники;
		ТекстОшибки = РезультатПроверки.ТекстОшибки;
		
	Иначе
		
		ПолученныеПараметры = Новый Соответствие;
		ПолученныеВременныеТаблицы = Новый Соответствие;
		ПолученноеОписаниеВнешнихИсточников = Новый Соответствие;
		ТекстОшибки = ИТК_ЗапросКлиентСервер.ТекстОшибкиПустойЗапрос();
		
	КонецЕсли;
		
	ИзменяемыеПоля = Новый Структура;
	ИзменяемыеПоля.Вставить("ТребуетсяПроверка", Ложь);
	ИзменяемыеПоля.Вставить("Параметры", ПолученныеПараметры);
	ИзменяемыеПоля.Вставить("ВременныеТаблицы", ПолученныеВременныеТаблицы);
	ИзменяемыеПоля.Вставить("Ошибка", ИТК_ЗапросКлиентСервер.ИнформацияООшибке(ТекстОшибки));
	ИзменяемыеПоля.Вставить("ОписаниеВнешнихИсточников", ПолученноеОписаниеВнешнихИсточников);
	ИзменяемыеПоля.Вставить("ВнешниеИсточники", ДополненныеВнешниеИсточники(Данные, ПолученноеОписаниеВнешнихИсточников));
	ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоля(ЭтотОбъект, ТекущаяСтрока, ИзменяемыеПоля, Ложь);
	
	// Начальная инициализация значений параметров типа таблица по тексту запроса
	Для Каждого Параметр Из ПолученныеПараметры Цикл 
		
		ОписаниеПараметра = Параметр.Значение;
		Если ИТК_КонсольРазработчикаКлиентСервер.ЭтоСложныйПараметр(ТипЗнч(ОписаниеПараметра))
				И ОписаниеПараметра.Вид = ИТК_Перечисления.СложныйПараметрЗапросаТаблицаЗначений() Тогда
			
			ОписаниеСтарогоПараметра = Данные.ЗначенияПараметров.Получить(Параметр.Ключ);
			КолонкиТаблицы = ОписаниеПараметра.Значение;
			НовоеЗначениеПараметра = НовоеЗначениеПараметраТаблицыЗначений(ОписаниеСтарогоПараметра, КолонкиТаблицы, УникальныйИдентификатор);
			НовоеОписаниеПараметра = ИТК_ЗапросКлиентСервер.ЗначениеСложногоПараметра(
				ИТК_Перечисления.СложныйПараметрЗапросаТаблицаЗначений(), НовоеЗначениеПараметра);
			Данные.ЗначенияПараметров.Вставить(Параметр.Ключ, НовоеОписаниеПараметра);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НовоеЗначениеПараметраТаблицыЗначений(ОписаниеСтарогоПараметра, СписокКолонок, УникальныйИдентификаторФормы)
	
	Если ИТК_КонсольРазработчикаКлиентСервер.ЭтоСложныйПараметр(ТипЗнч(ОписаниеСтарогоПараметра))
			И ОписаниеСтарогоПараметра.Вид = ИТК_Перечисления.СложныйПараметрЗапросаТаблицаЗначений() Тогда
		
		УникальныйИдентификатор = ОписаниеСтарогоПараметра.Значение;
		ТаблицаЗначений = ПолучитьИзВременногоХранилища(УникальныйИдентификатор);
		
	Иначе
		
		ТаблицаЗначений = Новый ТаблицаЗначений;
		УникальныйИдентификатор = УникальныйИдентификаторФормы;
		
	КонецЕсли;
	
	Для Каждого ЭлементКолонка Из СписокКолонок Цикл 
		
		ИмяКолонки = ЭлементКолонка.Представление;
		Если ТаблицаЗначений.Колонки.Найти(ИмяКолонки) = Неопределено Тогда
			ТаблицаЗначений.Колонки.Добавить(ИмяКолонки);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ПоместитьВоВременноеХранилище(ТаблицаЗначений, УникальныйИдентификатор);
	
КонецФункции

&НаКлиенте
Процедура ПроверитьСхемуКомпоновкиДанных(Данные, Строка = Неопределено)
	
	Если Строка = Неопределено Тогда
		Строка = ТекущаяСтрока;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Данные.Текст) Тогда
		
		Результат = ИТК_СКД.ПроверитьТекст(Данные.Текст);
		
		ТекстОшибки = Результат.ТекстОшибки;
		ПолученноеОписаниеВнешнихИсточников = Результат.ОписаниеВнешнихИсточников;
		
	Иначе
		
		ТекстОшибки = ИТК_СКДКлиентСервер.ТекстОшибкиПустаяСхема();
		ПолученноеОписаниеВнешнихИсточников = Новый Соответствие;
		
	КонецЕсли;
	
	ИзменяемыеПоля = Новый Структура;
	ИзменяемыеПоля.Вставить("ТребуетсяПроверка", Ложь);
	ИзменяемыеПоля.Вставить("Ошибка", ИТК_СКДКлиентСервер.ИнформацияООшибке(ТекстОшибки));
	ИзменяемыеПоля.Вставить("ОписаниеВнешнихИсточников", ПолученноеОписаниеВнешнихИсточников);
	ИзменяемыеПоля.Вставить("ВнешниеИсточники", ДополненныеВнешниеИсточники(Данные, ПолученноеОписаниеВнешнихИсточников));
	
	ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоля(ЭтотОбъект, Строка, ИзменяемыеПоля, Ложь);
	
КонецПроцедуры

&НаКлиенте
Функция ДополненныеВнешниеИсточники(Данные, ДобавляемыеВнешниеИсточники)
	
	Результат = ИТК_КонсольРазработчикаДанныеКлиентСервер.ВнешниеИсточники(Данные);
	Для Каждого ДобавляемыйВнешнийИсточник Из ДобавляемыеВнешниеИсточники Цикл 
		
		Имя = ДобавляемыйВнешнийИсточник.Ключ;
		Добавлять = Истина;
				
		Для Каждого ВнешнийИсточник Из Результат Цикл 
			
			ОписаниеВнешнегоИсточника = ВнешнийИсточник.Значение;
			Если ОписаниеВнешнегоИсточника.Имя = Имя Тогда
				
				Добавлять = Ложь;
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если Добавлять Тогда
			
			ОписаниеВнешнегоИсточника = ИТК_КонсольРазработчикаДанныеКлиентСервер.НовыйВнешнийИсточник(Имя,	ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаЗначение());
			ИТК_КонсольРазработчикаДанныеКлиент.ВставитьВнешнийИсточник(ЭтотОбъект, ТекущаяСтрока, Новый УникальныйИдентификатор, ОписаниеВнешнегоИсточника);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция СписокПараметровЗапроса(Строка)
	
	Данные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(Строка);
	
	Результат = Новый СписокЗначений;
	
	Если Строка.Тип = ИТК_Перечисления.ЭлементДанныхЗапрос() Тогда
		
		ОшибкаВТекстеЗапроса = (Данные.Ошибка <> Неопределено);
		Если ОшибкаВТекстеЗапроса Тогда
			
			Для Каждого ПараметрЗапроса Из Данные.ЗначенияПараметров Цикл 
				
				ТипЗначения = ИТК_ТипыКлиентСервер.ОписаниеТиповПоТипу(ТипЗнч(ПараметрЗапроса.Значение));
				ДанныеПараметра = Новый Структура("Тип, Значение", ТипЗначения, ИТК_КонсольРазработчикаДанныеКлиент.ЗначениеПараметраЗапроса(Данные, ПараметрЗапроса.Ключ, ТипЗначения));
				
				Результат.Добавить(ДанныеПараметра, ПараметрЗапроса.Ключ);
				
			КонецЦикла;
			
		Иначе
			
			Для Каждого ПараметрЗапроса Из Данные.Параметры Цикл 
				
				ТипЗначения = ПараметрЗапроса.Значение;
				ДанныеПараметра = Новый Структура("Тип, Значение", ТипЗначения, ИТК_КонсольРазработчикаДанныеКлиент.ЗначениеПараметраЗапроса(Данные, ПараметрЗапроса.Ключ, ТипЗначения));
				
				Результат.Добавить(ДанныеПараметра, ПараметрЗапроса.Ключ);
				
			КонецЦикла;
			
		КонецЕсли;
		
	ИначеЕсли Строка.Тип = ИТК_Перечисления.ЭлементДанныхПодзапрос() Тогда
		
		ДанныеОсновногоЗапроса = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ОсновнойЗапрос(Строка));
		
		Для Каждого ИмяПараметра Из Данные.Параметры Цикл 
			
			ТипЗначения = ДанныеОсновногоЗапроса.Параметры[ИмяПараметра];
			ДанныеПараметра = Новый Структура("Тип, Значение", ТипЗначения, ИТК_КонсольРазработчикаДанныеКлиент.ЗначениеПараметраЗапроса(ДанныеОсновногоЗапроса, ИмяПараметра, ТипЗначения));
			
			Результат.Добавить(ДанныеПараметра, ИмяПараметра);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Результат.СортироватьПоПредставлению();
	
	Возврат Результат;
	
КонецФункции 

&НаКлиенте
Функция ДанныеПараметраЗапроса(Строка, Имя)
	
	Если Строка.Тип = ИТК_Перечисления.ЭлементДанныхПодзапрос() Тогда
		СтрокаЗапрос = ОсновнойЗапрос(Строка);
	Иначе
		СтрокаЗапрос = Строка;
	КонецЕсли;

	Данные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(СтрокаЗапрос);
	ОписаниеТипаЗначения = Данные.Параметры[Имя];
	
	Возврат Новый Структура("ОписаниеТипов, Значение", ОписаниеТипаЗначения, ИТК_КонсольРазработчикаДанныеКлиент.ЗначениеПараметраЗапроса(Данные, Имя, ОписаниеТипаЗначения));
	
КонецФункции

&НаКлиенте
Процедура ПодготовитьДанныеДляСравнения(СтрокаИсточник, СписокЗначений, ОбрабатываемыеТипы)
	
	Для Каждого Строка Из СтрокаИсточник.ПолучитьЭлементы() Цикл
		
		Если Строка.Тип = ИТК_Перечисления.ЭлементДанныхГруппа() Тогда
			
			ПодготовитьДанныеДляСравнения(Строка, СписокЗначений, ОбрабатываемыеТипы); 
			
		Иначе
			
			Если ОбрабатываемыеТипы.Найти(Строка.Тип) <> Неопределено Тогда
				
				ДанныеСтроки = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(Строка);
				ТребуетсяПроверка = ИТК_ОбщийКлиентСервер.Свойство(ДанныеСтроки, "ТребуетсяПроверка", Ложь);
				Ошибка = ИТК_ОбщийКлиентСервер.Свойство(ДанныеСтроки, "Ошибка");
				Если Не ТребуетсяПроверка 
						ИЛИ ЗначениеЗаполнено(Ошибка) Тогда
					
					ПредставлениеСтроки = ПолноеИмяСтрокиДляСравнения(Строка);
					Если Строка.Выделение Тогда
						ПредставлениеСтроки = Новый ФорматированнаяСтрока(ПредставлениеСтроки, ИТК_ОбщийКлиентСервер.ШрифтЖирный());
					КонецЕсли;
					
					СписокЗначений.Добавить(Строка(Строка.UID), ПредставлениеСтроки);
					ПодготовитьДанныеДляСравнения(Строка, СписокЗначений, ОбрабатываемыеТипы);
					
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Функция ПолноеИмяСтрокиДляСравнения(Строка)
	
	ПолноеИмя = Строка.Имя;
	
	РодительСтроки = Строка.ПолучитьРодителя();
	
	Если РодительСтроки <> Неопределено Тогда
		ПолноеИмя = РодительСтроки.Имя + " - " +ПолноеИмя;
		РодительСтроки = РодительСтроки.ПолучитьРодителя();
	КонецЕсли;

	Возврат ПолноеИмя;
	
КонецФункции

&НаКлиенте
Процедура ОткрытьФормуСравнения(СтрокаЭталон, ДополнительныеПараметры)
	
	СохранитьИзмененныеДанныеСтроки();
	
	Если Не ИТК_ФормаКлиент.ВозможенЗапускСравненияПредупреждение() Тогда
		Возврат;
	КонецЕсли;
	
	ТипОбъектов = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "ТипОбъектов", Неопределено);
	ТипСравнения = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "ТипСравнения", Неопределено);
	НеизменяемыеПоля = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "НеизменяемыеПоля", Новый Структура);
	СтрокаНовый = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "СтрокаНовый", Неопределено);
	
	ПараметрыФормы = Новый Структура;
	МинимальноеКоличествоОбъектовСравнения = 2;
	
	СписокЗапросов = Новый СписокЗначений;
	ПодготовитьДанныеДляСравнения(ДеревоДанных, СписокЗапросов, ИТК_КонсольРазработчикаДанныеКлиентСервер.ТипыСтрокЗапросПодзапрос());
	ПараметрыФормы.Вставить("СписокЗапросов", СписокЗапросов);

	СписокСхемКомпоновкиДанных = Новый СписокЗначений;
	ПодготовитьДанныеДляСравнения(ДеревоДанных, СписокСхемКомпоновкиДанных, ИТК_КонсольРазработчикаДанныеКлиентСервер.ТипыСтрокСКД());
	ПараметрыФормы.Вставить("СписокСхемКомпоновкиДанных", СписокСхемКомпоновкиДанных);
	
	// Список элементов код
	СписокКод = Новый СписокЗначений;
	
	ТипыСтрокКода = Новый Массив;
	ТипыСтрокКода.Добавить(ИТК_Перечисления.ЭлементДанныхКод());
	
	ПодготовитьДанныеДляСравнения(ДеревоДанных, СписокКод, ТипыСтрокКода);
	ПараметрыФормы.Вставить("СписокКод", СписокКод);

	Если СтрокаЭталон <> Неопределено Тогда
		ПараметрыФормы.Вставить("ОбъектЭталон", СтрокаЭталон.UID);
	КонецЕсли;
	Если СтрокаНовый <> Неопределено Тогда
		ПараметрыФормы.Вставить("ОбъектНовый", СтрокаНовый.UID);
	КонецЕсли;

	НедостаточноДанных = Ложь;
	Если (СписокЗапросов.Количество() < МинимальноеКоличествоОбъектовСравнения
			И СписокСхемКомпоновкиДанных.Количество() < МинимальноеКоличествоОбъектовСравнения
			И СписокКод.Количество() < МинимальноеКоличествоОбъектовСравнения) Тогда
		НедостаточноДанных = Истина;
	КонецЕсли;
	
	Если НеизменяемыеПоля.Свойство("ТипОбъектов") Тогда
		
		Если (ТипОбъектов = ИТК_Перечисления.ЭлементДанныхЗапрос() И СписокЗапросов.Количество() < МинимальноеКоличествоОбъектовСравнения)
				ИЛИ (ТипОбъектов = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных() И СписокСхемКомпоновкиДанных.Количество() < МинимальноеКоличествоОбъектовСравнения) Тогда
			НедостаточноДанных = Истина;
		КонецЕсли;

	КонецЕсли;
	
	Если НедостаточноДанных Тогда
		
		ПоказатьПредупреждение( , НСтр("ru = 'Недостаточно данных для сравнения. Данные должны быть проверены и не иметь ошибок.';
										|en = 'Not enough data to compare. The data should be checked and there should be no errors.'"), , ИТК_КонсольРазработчикаКлиентСервер.Представление());
		Возврат;
		
	КонецЕсли;
	
	ТипОбъектов = СтрокаЭталон.Тип;
	НеизменяемыеПоля.Вставить("ТипОбъектов");
	Если ТипОбъектов = ИТК_Перечисления.ЭлементДанныхКод() Тогда
		НеизменяемыеПоля.Вставить("ТипСравнения");
	КонецЕсли;

	ПараметрыФормы.Вставить("ТипОбъектов", ТипОбъектов);
	ПараметрыФормы.Вставить("ТипСравнения", ТипСравнения);
	ПараметрыФормы.Вставить("НеизменяемыеПоля", НеизменяемыеПоля);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("НастройкаСравненияЗавершена", ЭтотОбъект);
	ОткрытьФорму("Обработка.ИТК_КонсольРазработчика.Форма.НастройкаСравнения", ПараметрыФормы, ЭтотОбъект, , , , ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьРабочиеДанные(РабочиеДанные, Тип = Неопределено, Имя = "", Комментарий = "")
	
	РабочиеДанные.Тип = Тип;
	РабочиеДанные.Имя = Имя;
	РабочиеДанные.Комментарий = Комментарий;
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьДанныеВНастройки(Имя)
	
	Состояние(НСтр("ru = 'Сохранение настройки:';
					|en = 'Saving settings:'"), , Имя, БиблиотекаКартинок.ИТК_ДлительнаяОперацияАнимация48);

	СохранитьИзмененныеДанныеСтроки();
	СохранитьДанныеВНастройкиСервер(Имя);
	
	ИТК_КонсольРазработчикаДанныеКлиентСервер.СброситьМодифицированность(ЭтотОбъект);
	ПослеСохраненияДанных();
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьДанныеИзНастроек(Имя, Пользователь = Неопределено, Объединение = Ложь)
	
	Если Пользователь = Неопределено Тогда
		
		Пояснение = Имя;
		
	Иначе
		
		Пояснение = СтрШаблон("%1\%2", Пользователь, Имя);
		
	КонецЕсли;
	
	Если Объединение Тогда
		
		ЗаголовокСостояния = НСтр("ru = 'Объединение с настройкой';
									|en = 'Merge with customization'");
		
	Иначе
		
		ЗаголовокСостояния = НСтр("ru = 'Загрузка настройки';
									|en = 'Loading settings'");
		
	КонецЕсли;
	
	Состояние(ЗаголовокСостояния, , Пояснение, БиблиотекаКартинок.ИТК_ДлительнаяОперацияАнимация48);
	
	ЗагрузитьДанныеИзНастроекСервер(Имя, Пользователь, Объединение);
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьРезультатВыполнения(Результат)
	
	РежимВыполнения = Результат.РежимВыполнения;
	РезультатКоличество = ИТК_ОбщийКлиентСервер.Свойство(Результат, "Количество");
	
	АдресРезультата = Результат.АдресРезультата;
	РезультатОбновления = ОбновитьРезультатСервер(Результат.АдресРезультата);
	
	// Заполнение данных текущего результата
	ЗаполнитьЗначенияСвойств(ТекущийРезультат, Результат);
	
	ТекущийРезультат.Пустой = Ложь;
	ТекущийРезультат.АктуаленПоСтроке = ТекущаяСтрока.UID;
	ТекущийРезультат.ОкончаниеВыполненияНаКлиенте = ИТК_ОбщийВызовСервера.ТекущаяДатаСервера();
	
	ТекущийРезультат.Адрес = АдресРезультата;
	
	Если РежимВыполнения = ИТК_Перечисления.РежимВыполненияКодаВыполнение()
			ИЛИ РежимВыполнения = ИТК_Перечисления.РежимВыполненияКодаНаКлиенте() Тогда
		
		ТекущаяСтраница = Элементы.СтраницаРезультатКод;
		ТекущийЭлементНовый = Элементы.ПанельРезультат;
		
	Иначе
		
		СкорректироватьВыделениеВТабличномДокументеРезультата(Элементы.ТабличныйДокументРезультат, ТабличныйДокументРезультат, РезультатОбновления);
		
		// Фиксация шапки в табличном документе
		Если Результат.Свойство("КоличествоЗапросовСРезультатом") Тогда
			
			ЗапросСОднимРезультатом = (Результат.КоличествоЗапросовСРезультатом = 1);
			ФиксацияШапкиДоступность = ЗапросСОднимРезультатом;
			ФиксацияШапки = ЗапросСОднимРезультатом;
			
		Иначе
			
			ФиксацияШапки = Ложь;
			ФиксацияШапкиДоступность = Ложь;
			
		КонецЕсли;
		
		Элементы.КнопкаФиксацияШапки.Доступность = ФиксацияШапкиДоступность;
		Элементы.КнопкаФиксацияШапки.Пометка = ФиксацияШапки;
		ИТК_ТабличныйДокументКлиентСервер.ЗафиксироватьШапку(ТабличныйДокументРезультат, ФиксацияШапки);
		
		ИТК_ТабличныйДокументКлиентСервер.ОбновитьЭлементыПодменюУровеньГруппировок(
			Элементы.ТабличныйДокументРезультатКонтекстноеМенюУровеньГруппировки, ТабличныйДокументРезультат);
		
		ТекущаяСтраница = Элементы.СтраницаРезультатТабличныйДокумент;
		ТекущийЭлементНовый = Элементы.ТабличныйДокументРезультат;
		
	КонецЕсли;
	
	ИТК_ФормаКлиентСервер.ПоказатьГруппу(Элементы.ПанельРезультат);
	Элементы.СтраницыРезультат.ТекущаяСтраница = ТекущаяСтраница;
	ТекущийЭлемент = ТекущийЭлементНовый;
	
КонецПроцедуры

&НаСервере
Функция ОбновитьРезультатСервер(АдресРезультата = Неопределено)
	
	ИТК_ВременноеХранилище.Удалить(ТекущийРезультат.Адрес);
	ИТК_ВременноеХранилище.Удалить(ТекущийРезультат.АдресСхемыКомпоновкиДанных);
	ИТК_ВременноеХранилище.Удалить(ТекущийРезультат.АдресДанныхРасшифровки);
	ИТК_ВременноеХранилище.Удалить(ТекущийРезультат.АдресИсполняемыхЗапросовСКД);
	
	ТабличныйДокументРезультат.Очистить();
	РезультатСообщения.Очистить();
	
	Если НЕ ЗначениеЗаполнено(АдресРезультата) Тогда
		Возврат Неопределено;
	КонецЕсли;
		
	Результат = ПолучитьИзВременногоХранилища(АдресРезультата);
	Если ТипЗнч(Результат) = Тип("ТабличныйДокумент") Тогда
		
		ТабличныйДокументРезультат = Результат;
		
		ОписаниеТабличногоДокумента = Новый Структура;
		ОписаниеТабличногоДокумента.Вставить("ВысотаТаблицы", Результат.ВысотаТаблицы);
		ОписаниеТабличногоДокумента.Вставить("ШиринаТаблицы", Результат.ШиринаТаблицы);
		Возврат ОписаниеТабличногоДокумента;
		
	ИначеЕсли ТипЗнч(Результат) = Тип("Структура") Тогда
		
		Элементы.РезультатКодГруппа.Видимость = Истина;
		
		ПредставлениеРезультата = ИТК_КодКлиентСервер.СокращенноеПредставлениеРезультата(Результат.Результат);
		Элементы.РезультатКодДекорацияЗначение.Заголовок = ПредставлениеРезультата;
		
		Попытка
			АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(Результат.Результат, УникальныйИдентификатор);
		Исключение
			АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(ТипЗнч(Результат.Результат), УникальныйИдентификатор);
		КонецПопытки;
		ТекущийРезультат.Адрес = АдресВоВременномХранилище;
		
		Сообщения = Результат.Сообщения;
		Если Сообщения <> Неопределено Тогда
			
			ТекущийРезультат.АдресДанныхРасшифровки = ПоместитьВоВременноеХранилище(Результат.Сообщения, УникальныйИдентификатор);
			ЗначениеВРеквизитФормы(Результат.Сообщения, "РезультатСообщения");
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ЗавершениеПодготовкиСравнения(Результат, ДополнительныеПараметры) Экспорт

	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СравнениеРезультатов = Новый Структура;
	
	РезультатСравнения = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	СравнениеРезультатов.Вставить("Результат", РезультатСравнения);
	
	СравнениеРезультатов.Вставить("ИмяПервогоФайла", ДополнительныеПараметры.ИмяПервогоФайла);
	СравнениеРезультатов.Вставить("ИмяВторогоФайла", ДополнительныеПараметры.ИмяВторогоФайла);
	
	ПодключитьОбработчикОжидания("ПодключаемыйЗавершениеСравнениеРезультатов", 0.1, Истина);	
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйЗавершениеСравнениеРезультатов()

	#Если ТолстыйКлиентУправляемоеПриложение Тогда
	
	ИмяПервогоФайла = СравнениеРезультатов.ИмяПервогоФайла;
	ИмяВторогоФайла = СравнениеРезультатов.ИмяВторогоФайла;
	РезультатСравнения = СравнениеРезультатов.Результат;
	
	НаименованиеОперации = НСтр("ru = 'Сохранение файлов для сравнения';
								|en = 'Save files for comparison'");
	Состояние(НаименованиеОперации, , НСтр("ru = '(1/2) Сохранение файла эталон';
											|en = '(1/2) Saving the master file'"), БиблиотекаКартинок.ИТК_ДлительнаяОперацияАнимация48);
	РезультатСравнения.Эталон.Записать(ИмяПервогоФайла, ТипФайлаТабличногоДокумента.MXL);
	
	Состояние(НаименованиеОперации, , НСтр("ru = '(2/2) Сохранение файла новый';
											|en = '(2/2) Saving the file new'"), БиблиотекаКартинок.ИТК_ДлительнаяОперацияАнимация48);
	РезультатСравнения.Новый.Записать(ИмяВторогоФайла, ТипФайлаТабличногоДокумента.MXL);
	
	ИТК_ДлительныеОперацииКлиент.СкрытьПрогресс(ЭтотОбъект);
	
	ИТК_ФормаКлиент.ПоказатьСравнениеФайловМодально(ИмяПервогоФайла, ИмяВторогоФайла, СпособСравненияФайлов.ТабличныйДокумент);
	
	#КонецЕсли

КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗапуститьПодготовкуСравненияНаСервере(Знач ДанныеЭталон, Знач ДанныеНовый, УникальныйИдентификатор, ФоновоеВыполнение)

	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("Эталон", ПодготовитьДанныеПередВыполнениемНаСервере(ДанныеЭталон));
	ПараметрыПроцедуры.Вставить("Новый", ПодготовитьДанныеПередВыполнениемНаСервере(ДанныеНовый));
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор, ФоновоеВыполнение);
	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_КонсольРазработчика.ПодготовитьДанныеДляСравнения", ПараметрыПроцедуры, ПараметрыВыполнения);
	
КонецФункции

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "ДеревоДанныхИмя", Новый Структура("Шрифт", ИТК_ОбщийКлиентСервер.ШрифтЖирный()), "ДеревоДанных.Выделение", Истина);
	
	ОформлениеПоля = Новый Структура;
	ОформлениеПоля.Вставить("Текст", НСтр("ru = '<Результат>';
											|en = '<Result>'"));

	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "НастройкиВыводаТаблицИмя", ОформлениеПоля, "НастройкиВыводаТаблиц.Имя", "");
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСтруктуруЗапроса(Строка, Данные)
	
	Если Данные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТипСтрокиПодзапрос = ИТК_Перечисления.ЭлементДанныхПодзапрос();
	Для Каждого Элемент Из Данные Цикл 
		
		НачальныеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.НовыйЭлемент(ТипСтрокиПодзапрос);
		НачальныеДанные.Вставить("ТекстИнициализации", Элемент.ТекстИнициализации);
		НачальныеДанные.Вставить("Текст", Элемент.Текст);
		НачальныеДанные.Вставить("Параметры", Элемент.Параметры);
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Родитель", Строка);
		ДополнительныеПараметры.Вставить("Активизировать", Ложь);
		ДополнительныеПараметры.Вставить("НачальныеДанные", НачальныеДанные);
		ДополнительныеПараметры.Вставить("Картинка", Элемент.Картинка);
		ДополнительныеПараметры.Вставить("УстанавливатьМодифицированность", Ложь);
		
		НоваяСтрока = ДобавитьСтрокуВДеревоДанных(ТипСтрокиПодзапрос, Элемент.Представление, ДополнительныеПараметры);
		
		ОбновитьСтруктуруЗапроса(НоваяСтрока, Элемент.Элементы);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСтруктуруЗапросов(Объект, ОбновлениеСтруктуры = Истина)
	
	Если ТипЗнч(Объект) = Тип("Массив") Тогда
		ОбрабатываемыеСтроки = Объект;
	Иначе
		ОбрабатываемыеСтроки = Новый Массив;
		ОбрабатываемыеСтроки.Добавить(Объект);
	КонецЕсли;
	
	// Обновление структуры
	ОбрабатываемыеСтрокиДанные = Новый Соответствие;
	Для Каждого ОбрабатываемаяСтрока Из ОбрабатываемыеСтроки Цикл 
		
		ДанныеСтроки = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ОбрабатываемаяСтрока);
		Если ДанныеСтроки.Ошибка = Неопределено 
				И НЕ ДанныеСтроки.ТребуетсяПроверка Тогда
			ОбрабатываемыеСтрокиДанные.Вставить(ОбрабатываемаяСтрока.UID, ДанныеСтроки.Текст);
		КонецЕсли;
		
		ОбрабатываемаяСтрока.ПолучитьЭлементы().Очистить();
		
	КонецЦикла;
	
	Если ОбновлениеСтруктуры 
			И ИТК_НастройкиКлиент.ЗначениеНастройки(ЭтотОбъект, "РазбиратьСтруктуруЗапроса") Тогда
		
		СтруктурыСтрок = СтруктурыСтрокЗапросов(ОбрабатываемыеСтрокиДанные);
		Для Каждого ОбрабатываемаяСтрока Из ОбрабатываемыеСтроки Цикл 
			ОбновитьСтруктуруЗапроса(ОбрабатываемаяСтрока, СтруктурыСтрок.Получить(ОбрабатываемаяСтрока.UID));
		КонецЦикла;	
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СтруктурыСтрокЗапросов(ОбрабатываемыеСтрокиДанные)
	
	Результат = Новый Соответствие;
	Для Каждого ОбрабатываемаяСтрока Из ОбрабатываемыеСтрокиДанные Цикл 
		Результат.Вставить(ОбрабатываемаяСтрока.Ключ, ИТК_АнализЗапроса.РазборСтруктуры(ОбрабатываемаяСтрока.Значение));
	КонецЦикла;
		
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ВопросПередУдалениемСтрокДанныхЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИТК_КонсольРазработчикаДанныеКлиентСервер.ДанныеМодифицированы(ЭтотОбъект);
	
	// Удаляем строки
	УдаляемыеСтроки = Новый Массив;
	Для Каждого ВыделеннаяСтрока Из Элементы.ДеревоДанных.ВыделенныеСтроки Цикл 
		УдаляемыеСтроки.Добавить(ДеревоДанных.НайтиПоИдентификатору(ВыделеннаяСтрока));
	КонецЦикла;
	
	ИТК_КонсольРазработчикаДанныеКлиент.УдалитьСтроки(ЭтотОбъект, УдаляемыеСтроки);
	
	ОбновлениеЭлементовФормыПослеОжидания();
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросПередУдалениемВнешнегоИсточникаЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	УдаляемыеАдреса = Новый Массив; УдаляемыеСтроки = Новый Массив;
	Для Каждого ИдентификаторВыделеннойСтроки Из Элементы.ВнешниеИсточники.ВыделенныеСтроки Цикл 
		
		ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
		СтрокаВнешнийИсточник = ВнешниеИсточники.НайтиПоИдентификатору(ИдентификаторВыделеннойСтроки);
		ОписаниеВнешнегоИсточника = ИТК_КонсольРазработчикаДанныеКлиент.ВнешнийИсточник(ТекущиеДанные, СтрокаВнешнийИсточник.UID);
		
		Если ОписаниеВнешнегоИсточника <> Неопределено Тогда
			
			УдаляемыеАдреса.Добавить(ОписаниеВнешнегоИсточника.Значение);
			
		КонецЕсли;
		
		УдаляемыеСтроки.Добавить(СтрокаВнешнийИсточник);
		ИТК_КонсольРазработчикаДанныеКлиент.УдалитьВнешнийИсточник(ЭтотОбъект, ТекущаяСтрока, СтрокаВнешнийИсточник.UID);
		
	КонецЦикла;
	
	Для Каждого УдаляемаяСтрока Из УдаляемыеСтроки Цикл 
		ВнешниеИсточники.Удалить(УдаляемаяСтрока);
	КонецЦикла;
	
	ИТК_ВременноеХранилище.Удалить(УдаляемыеАдреса);
	
	ОбновитьКоличествоВнешнихИсточников();
	
КонецПроцедуры

&НаКлиенте
Процедура РедактированиеЗначенияВнешнегоИсточникаЗавершено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИТК_КонсольРазработчикаДанныеКлиентСервер.ДанныеМодифицированы(ЭтотОбъект);
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	ОписаниеВнешнегоИсточника = ИТК_КонсольРазработчикаДанныеКлиент.ВнешнийИсточник(ТекущиеДанные, ДополнительныеПараметры.UID);
	
	Если ОписаниеВнешнегоИсточника = Неопределено Тогда
		ОписаниеВнешнегоИсточника = ИТК_КонсольРазработчикаДанныеКлиентСервер.НовыйВнешнийИсточник();
	КонецЕсли;
	
	ОписаниеВнешнегоИсточника.Значение = Результат;
	ИТК_КонсольРазработчикаДанныеКлиент.ВставитьВнешнийИсточник(ЭтотОбъект, ТекущаяСтрока, ДополнительныеПараметры.UID, ОписаниеВнешнегоИсточника);
	
	ЗагрузитьПользовательскиеОбъектыПодсказки();
	
КонецПроцедуры

&НаКлиенте
Процедура РедактированиеЗначенияТаблицаМВТЗавершено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИТК_КонсольРазработчикаДанныеКлиентСервер.ДанныеМодифицированы(ЭтотОбъект);
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	ОписаниеТаблицыМВТ = ИТК_КонсольРазработчикаДанныеКлиент.ТаблицаМВТ(ТекущиеДанные, ДополнительныеПараметры.UID);
	
	Если ОписаниеТаблицыМВТ = Неопределено Тогда
		ОписаниеТаблицыМВТ = ИТК_КонсольРазработчикаДанныеКлиентСервер.НоваяТаблицаМВТ();
	КонецЕсли;
	
	ОписаниеТаблицыМВТ.Значение = Результат;
	ИТК_КонсольРазработчикаДанныеКлиент.ВставитьТаблицуМВТ(ЭтотОбъект, ТекущаяСтрока, ДополнительныеПараметры.UID, ОписаниеТаблицыМВТ);
	
КонецПроцедуры

&НаКлиенте
Процедура РедактированиеСложногоПараметраЗавершено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	ИТК_КонсольРазработчикаДанныеКлиентСервер.ДанныеМодифицированы(ЭтотОбъект);
	
	ИмяПараметра = ДополнительныеПараметры.Имя;
	НовоеЗначение = ИТК_ЗапросКлиентСервер.ЗначениеСложногоПараметра(ДополнительныеПараметры.ВидСложногоПараметра, Результат);
	
	ИТК_КонсольРазработчикаДанныеКлиент.ВставитьЗначениеПараметраЗапроса(ЭтотОбъект, ТекущаяСтрока, ИмяПараметра, НовоеЗначение);
	ПараметрЗапросаТекущиеДанные = Элементы.ПараметрыЗапроса.ТекущиеДанные;
	
	ОбновитьСтрокуПараметра(ПараметрЗапросаТекущиеДанные, ИмяПараметра, ПараметрЗапросаТекущиеДанные.ТипЗначения, НовоеЗначение);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьВнешниеИсточники()

	ВнешниеИсточники.Очистить();
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	Для Каждого ВнешнийИсточник Из ИТК_КонсольРазработчикаДанныеКлиентСервер.ВнешниеИсточники(ТекущиеДанные) Цикл 
		
		ОписаниеВнешнегоИсточника = ВнешнийИсточник.Значение;
		НоваяСтрока = ВнешниеИсточники.Добавить();
		НоваяСтрока.Имя = ОписаниеВнешнегоИсточника.Имя;
		НоваяСтрока.Тип = ОписаниеВнешнегоИсточника.Тип;
		НоваяСтрока.UID = ВнешнийИсточник.Ключ;
		
		ОбновитьСтрокуВнешнийИсточник(НоваяСтрока);
		
	КонецЦикла;

	ОбновитьКоличествоВнешнихИсточников();

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСтрокуВнешнийИсточник(Строка)
	
	Если Строка.Тип = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаВыражение() Тогда
		
		ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
		ОписаниеВнешнегоИсточника = ИТК_КонсольРазработчикаДанныеКлиент.ВнешнийИсточник(ТекущиеДанные, Строка.UID);
		ПредставлениеВнешнегоИсточника = ИТК_Строки.Сокращенно(ОписаниеВнешнегоИсточника.Значение, 70);
		
	ИначеЕсли Строка.Тип = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаЗначение() Тогда
		
		ПредставлениеВнешнегоИсточника = НСтр("ru = '<Таблица значений>';
												|en = '<Table of values>'");
		
	КонецЕсли;
	
	Строка.Представление = ПредставлениеВнешнегоИсточника;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьКоличествоВнешнихИсточников()
	
	КоличествоВнешнихИсточников = ВнешниеИсточники.Количество();
	
КонецПроцедуры

&НаКлиенте
Функция ПреобразоватьЗначениеВнешнегоИсточникаКТипу(Значение, ИзТипа, КТипу)
	
	Если ИзТипа = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаЗначение() Тогда 
		
		Если КТипу = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаВыражение() Тогда
			Возврат ИТК_КодВызовСервера.ТаблицаЗначений(Значение, "ТаблицаЗначений");
		КонецЕсли;
		
	ИначеЕсли ИзТипа = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаВыражение() Тогда 
		
		Возврат ИТК_КодВызовСервера.ТаблицаЗначенийИзВыражения(Значение, УникальныйИдентификатор);

	КонецЕсли;

КонецФункции

&НаКлиенте
Процедура ЗаполнитьТаблицыМВТ()
	
	ТаблицыМВТ.Очистить();
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	Для Каждого ТаблицаМВТ Из ИТК_КонсольРазработчикаДанныеКлиентСервер.ТаблицыМВТ(ТекущиеДанные) Цикл 
		
		ОписаниеТаблицыМВТ = ТаблицаМВТ.Значение;
		НоваяСтрока = ТаблицыМВТ.Добавить();
		НоваяСтрока.Имя = ОписаниеТаблицыМВТ.Имя;
		НоваяСтрока.Тип = ОписаниеТаблицыМВТ.Тип;
		НоваяСтрока.UID = ТаблицаМВТ.Ключ;
		
		ОбновитьСтрокуТаблицыМВТ(НоваяСтрока);
		
	КонецЦикла;
	
	ОбновитьКоличествоТаблицМВТ();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСтрокуТаблицыМВТ(Строка)
	
	Если Строка.Тип = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаВыражение() Тогда
		
