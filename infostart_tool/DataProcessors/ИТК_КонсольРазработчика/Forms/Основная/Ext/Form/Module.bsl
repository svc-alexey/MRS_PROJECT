#Область ОписаниеПеременных

&НаКлиенте
Перем ТекущаяСтрока Экспорт;

&НаКлиенте
Перем ПоследнийТипПараметра; // При изменении типа параметра запроса эта переменная содержит последний тип активной строки

&НаКлиенте
Перем ПоследнийТипВнешнегоИсточника; // При изменении типа внешнего источника эта переменная содержит последний тип активной строки

&НаКлиенте
Перем КопируемыеДанныеВнешнихИсточников;

&НаКлиенте
Перем ПоследнийТипТаблицыМВТ; // При изменении типа таблицы МВТ эта переменная содержит последний тип активной строки

&НаКлиенте
Перем КопируемыеДанныеТаблицМВТ;

&НаКлиенте
Перем ЗакрытиеРазрешено;

&НаКлиенте
Перем СравнениеРезультатов Экспорт;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИТК_КонсольРазработчика.ПереносНастроекПриПереходеУИРКToolkit();
	
	РабочиеДанные = Новый Структура("Тип, Имя, Комментарий");
	
	ИТК_Перечисления.ЗаполнитьСписок(Элементы.НастройкиВыводаТаблицВывод, ИТК_Перечисления.ВидыВыводаТаблицы());
	ИТК_Перечисления.ЗаполнитьСписок(Элементы.ВнешниеИсточникиТип, ИТК_Перечисления.ТипыЗначенияВнешнегоИсточника());
	
	ИТК_КонсольРазработчикаКлиентСервер.НовыйРезультат(ТекущийРезультат);

	АдресДанных = ИТК_ВременноеХранилище.Поместить(Новый Соответствие, , УникальныйИдентификатор);
	ИТК_ТабличныйДокумент.ИнициализироватьФорму(ЭтотОбъект);
	ИТК_Форма.ЗаполнитьСписокВыбораМаксимальноеКоличествоВыводимыхСтрок(Элементы.МаксимумСтрок);
	
	УстановитьУсловноеОформление();
	
	Элементы.ВнешниеИсточникиИмя.ЦветТекста = ИТК_ОбщийКлиентСервер.ЦветТекстаГиперссылки();
	Элементы.ВнешниеИсточникиПредставление.ЦветТекста = ИТК_ОбщийКлиентСервер.ЦветТекстаГиперссылки();
	Элементы.СтраницаМВТ.Видимость = ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.17");
	Элементы.ГруппаПрогрессДлительнойОперации.Видимость = Ложь;
	Элементы.РезультатКодГруппа.Видимость = Ложь;
	
	ИТК_Настройки.ИнициализироватьФорму(ЭтотОбъект, ИТК_Перечисления.ИнструментКонсольРазработчика());
	
	// Начальные данные и восстановление аварийного завершения
	ЗавершеноАварийно = ИТК_КонсольРазработчика.ЗначениеПеременной("ЗавершеноАварийно");
	Если ЗавершеноАварийно = Ложь Тогда // Может быть Неопределено когда настроек нет
		
		ИТК_КонсольРазработчика.ЗаписатьЗначениеПеременной("АвтоматическоеСохранениеДанных", Неопределено);
		НовыеДанныеСервер();
		
	Иначе
		
		АвтоматическоеСохранениеДанных = ИТК_КонсольРазработчика.ЗначениеПеременной("АвтоматическоеСохранениеДанных");
		Если ЗначениеЗаполнено(АвтоматическоеСохранениеДанных) Тогда
			ВосстановлениеДанныхПослеАварийногоЗавершения(АвтоматическоеСохранениеДанных);
		Иначе
			НовыеДанныеСервер();
		КонецЕсли;
		
	КонецЕсли;
	ИТК_КонсольРазработчика.ЗаписатьЗначениеПеременной("ЗавершеноАварийно", Истина);
	
	ОбновитьЭлементыПоследниеРабочиеДанные();
	
КонецПроцедуры

&НаСервере
Процедура ПриСохраненииДанныхВНастройкахНаСервере(Настройки)
	
	ИТК_КонсольРазработчика.ЗаписатьЗначениеПеременной("ЗавершеноАварийно", Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	ИТК_ОбщийКлиент.ОбработчикПриОткрытии(Отказ);
	
	// Установим признак модифицированности сохраняемых в настройках формы данных,
	// должна быть ПриОткрытии в ПриСозданииНаСервере не устанавливается
	СохраняемыеВНастройкахДанныеМодифицированы = Истина; 
	
	Если ЗначениеЗаполнено(ИмяФайлаЗагружаемогоПриОткрытии) Тогда
		
		ЗагрузитьДанныеИзФайла(ИмяФайлаЗагружаемогоПриОткрытии, Ложь);
		УстановитьРабочиеДанные(РабочиеДанные, ИТК_Перечисления.ТипХраненияДанныхФайл(),
									ИмяФайлаЗагружаемогоПриОткрытии, НСтр("ru = 'последний сеанс';
																			|en = 'last session'"));
		
		ИмяФайлаЗагружаемогоПриОткрытии = "";
		
	КонецЕсли;
	
	УстановитьТекущейСтрокойДереваПервую();
	РаскрытьВеткиДереваВСоответствииСДанными(ДеревоДанных);
	
	ОбновитьОбработчикАвтоСохранения();
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)

	Если ИмяСобытия = "ИзмененыПоследниеОткрытыеДанные" Тогда
		
		ОбновитьЭлементыПоследниеРабочиеДанные(ИТК_Перечисления.ТипХраненияДанныхНастройка());
		
	КонецЕсли;
	
	НастройкиИзменены = ИТК_НастройкиКлиент.ОбработкаОповещения(ЭтотОбъект, ИмяСобытия, ИТК_Перечисления.ИнструментКонсольРазработчика());
	Если НастройкиИзменены Тогда
		НастройкиИзменены();
	КонецЕсли;
	
	ИТК_РедакторКодаКлиент.ОбработкаОповещения(ЭтотОбъект, ИмяСобытия, Параметр, Источник);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	ТипЗначенияИсточника = ТипЗнч(ИсточникВыбора);
	
	ИсточникУправляемаяФорма = (ТипЗначенияИсточника = Тип("УправляемаяФорма"));
	#Если ТолстыйКлиентУправляемоеПриложение Тогда
		ИсточникКонструкторСКД1С = (ТипЗначенияИсточника = Тип("КонструкторСхемыКомпоновкиДанных"));
	#Иначе
		ИсточникКонструкторСКД1С = Ложь;
	#КонецЕсли
	
	Если ИсточникКонструкторСКД1С
			ИЛИ ИТК_СКДКлиент.ИсточникВыбораКонструкторСКД(ИсточникВыбора) Тогда
			
		Если ИсточникКонструкторСКД1С Тогда
			АдресЗначения = ПоместитьВоВременноеХранилище(ВыбранноеЗначение);
		Иначе
			АдресЗначения = ВыбранноеЗначение;
		КонецЕсли;
		
		ОсновнаяСтрокаСКД = ОсновнаяСхемаКомпоновкиДанных(ТекущаяСтрока);
		ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоле(ЭтотОбъект, ОсновнаяСтрокаСКД, "Текст", ИТК_СКД.XMLТекстИзАдреса(АдресЗначения));
		
		ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ОсновнаяСтрокаСКД);
		ПроверитьСхемуКомпоновкиДанных(ТекущиеДанные, ОсновнаяСтрокаСКД);
		
		ПодключаемыйЗагрузитьСостояниеРедактораКода();
		
		ОбновитьЭлементыФормы();
		
	КонецЕсли;
	
	Если ИсточникУправляемаяФорма Тогда
		
		ИмяФормыИсточника = ИсточникВыбора.ИмяФормы;
		Если СтрНайти(ИмяФормыИсточника, "ОбработкаРезультата") Тогда
			
			ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоле(ЭтотОбъект, ТекущаяСтрока, "АлгоритмыОбработки", ВыбранноеЗначение); 
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы = Истина Тогда
		
		Если Модифицированность Тогда
			
			ТекстПредупреждения = НСтр("ru = 'В консоли имеются несохраненные данные, они будут потеряны.
			|Для сохранения изменений нажмите ""Продолжить работу"", сохраните данные, а потом завершите работу.';
			|en = 'The console has unsaved data, it will be lost.
			|To save your changes, click Continue, save the data, and then exit.'");
			
			Отказ = Истина;
			
		КонецЕсли;
		
	Иначе
		
		Если ЗакрытиеРазрешено = Неопределено Тогда
			
			Отказ = Истина;
			ЗапуститьОбработчикСПроверкойНаСохранностьДанных(Новый ОписаниеОповещения("ОбработчикЗакрытиеРазрешеноЗакрыть", ЭтотОбъект));
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ОшибкаТекстНажатие(Элемент)
	
	ПоказатьОшибку(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПредставлениеПриИзменении(Элемент)
	
	Если ТекущаяСтрока <> Неопределено Тогда
		
		ТекущаяСтрока.Имя = Представление;
		ИТК_КонсольРазработчикаДанныеКлиентСервер.ДанныеМодифицированы(ЭтотОбъект);

	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ИспользованиеВнешнихФункцийПриИзменении(Элемент)
	
	ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоле(ЭтотОбъект, ТекущаяСтрока, "ИспользованиеВнешнихФункций", ИспользованиеВнешнихФункций);
	
КонецПроцедуры

&НаКлиенте
Процедура ТабличныйДокументРезультатПриАктивизацииОбласти(Элемент)
	
	ИТК_ТабличныйДокументКлиент.ОбработчикПриАктивизацииОбласти(ЭтотОбъект, Элемент, ТабличныйДокументРезультат, ПоследняяАктивнаяОбласть, ТекущийРезультат.АдресДанныхРасшифровки);
	
КонецПроцедуры

&НаКлиенте
Процедура ТабличныйДокументРезультатВыбор(Элемент, Область, СтандартнаяОбработка)

	ИТК_ТабличныйДокументКлиент.ОбработчикВыбор(ЭтотОбъект, ТекущийРезультат.АдресДанныхРасшифровки, Область, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура МаксимальноСтрокПриИзменении(Элемент)
	
	ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоле(ЭтотОбъект, ТекущаяСтрока, "МаксимумСтрок", МаксимумСтрок);

КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииНастроекСКД(Элемент)
	
	ИТК_КонсольРазработчикаДанныеКлиентСервер.ДанныеМодифицированы(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура СКДПерейтиКОтчету(Элемент)
	
	ЭлементСтруктуры = КомпоновщикНастроек.Настройки.ПолучитьОбъектПоИдентификатору(Элементы.СКДСтруктура.ТекущаяСтрока);
	НастройкиЭлемента =  КомпоновщикНастроек.Настройки.НастройкиЭлемента(ЭлементСтруктуры);
	Элементы.СКДСтруктура.ТекущаяСтрока = КомпоновщикНастроек.Настройки.ПолучитьИдентификаторПоОбъекту(НастройкиЭлемента);
	
КонецПроцедуры

&НаКлиенте
Процедура СКДЛокальныеВыбранныеПоляПриИзменении(Элемент)
	
	Если СКДЛокальныеВыбранныеПоля Тогда
		
		Элементы.СтраницыСКДПоляВыбора.ТекущаяСтраница = Элементы.СКДНастройкиВыбранныхПолей;
			
	Иначе
		
		Элементы.СтраницыСКДПоляВыбора.ТекущаяСтраница = Элементы.СКДОтключенныеНастройкиВыбранныхПолей;

		ЭлементСтруктуры = КомпоновщикНастроек.Настройки.ПолучитьОбъектПоИдентификатору(Элементы.СКДСтруктура.ТекущаяСтрока);
		КомпоновщикНастроек.Настройки.ОчиститьВыборЭлемента(ЭлементСтруктуры);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СКДЛокальныйОтборПриИзменении(Элемент)
	
	Если СКДЛокальныйОтбор Тогда
		
		Элементы.СКДСтраницыОтбора.ТекущаяСтраница = Элементы.СКДНастройкиОтбора;
			
	Иначе
		
		Элементы.СКДСтраницыОтбора.ТекущаяСтраница = Элементы.СКДОтключенныеНастройкиОтбора;

		ЭлементСтруктуры = КомпоновщикНастроек.Настройки.ПолучитьОбъектПоИдентификатору(Элементы.СКДСтруктура.ТекущаяСтрока);
		КомпоновщикНастроек.Настройки.ОчиститьОтборЭлемента(ЭлементСтруктуры);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СКДЛокальныйПорядокПриИзменении(Элемент)
	
	Если СКДЛокальныйПорядок Тогда
		
		Элементы.СтраницыСКДПорядок.ТекущаяСтраница = Элементы.СКДНастройкиПорядка;
					
	Иначе
		
		Элементы.СтраницыСКДПорядок.ТекущаяСтраница = Элементы.СКДОтключенныеНастройкиПорядка;
					
		ЭлементСтруктуры = КомпоновщикНастроек.Настройки.ПолучитьОбъектПоИдентификатору(Элементы.СКДСтруктура.ТекущаяСтрока);
		КомпоновщикНастроек.Настройки.ОчиститьПорядокЭлемента(ЭлементСтруктуры);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СКДЛокальноеУсловноеОформлениеПриИзменении(Элемент)
	
	Если СКДЛокальноеУсловноеОформление Тогда
		
		Элементы.СтраницыСКДУсловногоОформления.ТекущаяСтраница = Элементы.СКДНастройкиУсловногоОформления;
					
	Иначе
		
		Элементы.СтраницыСКДУсловногоОформления.ТекущаяСтраница = Элементы.СКДОтключенныеНастройкиУсловногоОформления;
					
		ЭлементСтруктуры = КомпоновщикНастроек.Настройки.ПолучитьОбъектПоИдентификатору(Элементы.СКДСтруктура.ТекущаяСтрока);
		КомпоновщикНастроек.Настройки.ОчиститьУсловноеОформлениеЭлемента(ЭлементСтруктуры);
					
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СКДЛокальныеПараметрыВыводаПриИзменении(Элемент)
	
	Если СКДЛокальныеПараметрыВывода Тогда
		
		Элементы.СтраницыСКДПараметрыВывода.ТекущаяСтраница = Элементы.СКДНастройкиПараметровВывода;
					
	Иначе
		
		Элементы.СтраницыСКДПараметрыВывода.ТекущаяСтраница = Элементы.СКДОтключенныеНастройкиПараметровВывода;
					
		ЭлементСтруктуры = КомпоновщикНастроек.Настройки.ПолучитьОбъектПоИдентификатору(Элементы.СКДСтруктура.ТекущаяСтрока);
		КомпоновщикНастроек.Настройки.ОчиститьПараметрыВыводаЭлемента(ЭлементСтруктуры);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПанельНастроекПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	
	ИмяСтраницы = Сред(ТекущаяСтраница.Имя, СтрДлина("Страница") + 1);
	ТекущиеДанные.Страница = ИмяСтраницы;
	
	Если ТекущаяСтраница = Элементы.СтраницаПараметрыЗапроса
			ИЛИ ТекущаяСтраница = Элементы.СтраницаВнешниеИсточники Тогда
		
		ПроверитьДанныеСтроки(ТекущаяСтрока);
		ОбновитьЭлементыФормы();
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ИТК_ПодключаемыйРедакторПриИзменении(Элемент)
	
	ИмяЭлемента = Элемент.Имя;
	Если ИмяЭлемента = "Код" Тогда
		
		ИзменяемыеПоля = Новый Структура;
		ИзменяемыеПоля.Вставить("Текст", Код);
		ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоля(ЭтотОбъект, ТекущаяСтрока, ИзменяемыеПоля);
		
	ИначеЕсли ИмяЭлемента = "ТекстЗапроса" Тогда
		
		ИзменяемыеПоля = Новый Структура;
		ИзменяемыеПоля.Вставить("ТребуетсяПроверка", Истина);
		ИзменяемыеПоля.Вставить("Текст", ТекстЗапроса);
		ИзменяемыеПоля.Вставить("Ошибка", Неопределено);
		ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоля(ЭтотОбъект, ТекущаяСтрока, ИзменяемыеПоля);
		
		ОбновитьСтруктуруЗапросов(ТекущаяСтрока, Ложь);
		
	ИначеЕсли ИмяЭлемента = "СхемаКомпоновкиДанныхXML" Тогда
		
		ИзменяемыеПоля = Новый Структура;
		ИзменяемыеПоля.Вставить("ТребуетсяПроверка", Истина);
		ИзменяемыеПоля.Вставить("Текст", СхемаКомпоновкиДанныхXML);
		ИзменяемыеПоля.Вставить("Ошибка", Неопределено);
		ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоля(ЭтотОбъект, ТекущаяСтрока, ИзменяемыеПоля);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИТК_ПодключаемыйДокументСформирован(Элемент)
	
	ДополнительныеПараметры = Новый Структура;
	
	// Подготовка пользовательских объектов
	ПользовательскиеОбъекты = Неопределено;
	Если Элемент = Элементы.ТекстЗапроса Тогда
		ПользовательскиеОбъекты = ПользовательскиеОбъектыТекстЗапроса();
	КонецЕсли;
	
	Если Элемент = Элементы.Код Тогда
		ПользовательскиеОбъекты = ИТК_РедакторКодаВызовСервера.ПользовательскиеОбъектыРезультат();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПользовательскиеОбъекты) Тогда
		ДополнительныеПараметры.Вставить("ПользовательскиеОбъекты", ПользовательскиеОбъекты);
	КонецЕсли;
	
	ИТК_РедакторКодаКлиент.ДополнительнаяИнициализация(ЭтотОбъект, Элемент, ДополнительныеПараметры);
	
	ПодключаемыйЗагрузитьСостояниеРедактораКода();
	
КонецПроцедуры

&НаКлиенте
Процедура ИТК_ПодключаемыйПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	Если Элемент = Элементы.ТекстЗапроса Тогда
		ИмяОбработчика = "ОбработкаТекстЗапросаПриИзменении";
	ИначеЕсли Элемент = Элементы.СхемаКомпоновкиДанныхXML Тогда
		ИмяОбработчика = "ОбработкаСхемаКомпоновкиДанныхXMLПриИзменении";
	Иначе
		ИмяОбработчика = "ОбработкаКодПриИзменении";
	КонецЕсли;
	ОписаниеОповещения = Новый ОписаниеОповещения(ИмяОбработчика, ЭтотОбъект);
	
	ИТК_РедакторКодаКлиент.ОбработкаСобытий(ЭтотОбъект, Элемент, ДанныеСобытия, СтандартнаяОбработка, ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура РезультатКодДекорацияЗначениеНажатие(Элемент)

	Результат = РезультатИсполненияКода(ТекущийРезультат.Адрес);
	
	Если ТипЗнч(Результат) = Тип("Строка") Тогда
		
		ИТК_ФормаКлиент.ОткрытьМногострочныйТекст(ЭтотОбъект, Результат, Ложь);
		
	Иначе 
		
		ПоказатьЗначение( , Результат);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДеревоДанных

&НаКлиенте
Процедура ДеревоДанныхПриИзменении(Элемент)
	
	ИТК_КонсольРазработчикаДанныеКлиентСервер.ДанныеМодифицированы(ЭтотОбъект);
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоДанныхПриАктивизацииСтроки(Элемент)
	
	ТекущаяСтрока = Элемент.ТекущиеДанные;
	
	Если ТекущаяСтрока <> Неопределено Тогда
		
		ТипСтроки = ТекущаяСтрока.Тип;
		ЭлементТекст = ЭлементТекстПоТипуСтроки(ТипСтроки);
		Если ТипСтроки = ИТК_Перечисления.ЭлементДанныхКод() 
				И ИТК_РедакторКодаКлиент.ТребуетсяПервоначальнаяИнициализация(ЭлементТекст) Тогда
			
			ИнициализацияРедактораКода();	
			ИТК_РедакторКодаКлиент.Инициализация(ЭтотОбъект, "Код");
			
		ИначеЕсли ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоОдинИзТиповСтрокиЗапрос(ТипСтроки) 
				И ИТК_РедакторКодаКлиент.ТребуетсяПервоначальнаяИнициализация(ЭлементТекст) Тогда
			
			ИнициализацияРедактораЗапроса();
			ИТК_РедакторКодаКлиент.Инициализация(ЭтотОбъект, "ТекстЗапроса");
			
		ИначеЕсли ТипСтроки = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных()
				И ИТК_РедакторКодаКлиент.ТребуетсяПервоначальнаяИнициализация(ЭлементТекст) Тогда
			
			ИнициализацияСхемаКомпоновкиДанныхXML();
			ИТК_РедакторКодаКлиент.Инициализация(ЭтотОбъект, "СхемаКомпоновкиДанныхXML");
			
		КонецЕсли;
		
	КонецЕсли;
	
	// При новом получении формы если выделена одна та же самая строка ничего не делаем http://partners.v8.1c.ru/forum/thread.jsp?id=808386#808386
	ИдентификаторТекущейСтроки = Элемент.ТекущаяСтрока;
	Если ИдентификаторПоследнейВыделеннойСтроки <> ИдентификаторТекущейСтроки Тогда 
		
		СохранитьИзмененныеДанныеСтроки();

		ИдентификаторПоследнейВыделеннойСтроки = ИдентификаторТекущейСтроки;
		
		ПодключитьОбработчикОжидания("ПодключаемыйВосстановитьСостояниеСтрокиПослеОжидания", 0.1, Истина);
		
	КонецЕсли;
	
	// Необходимо обновлять сразу (ОбновлениеЭлементовФормыПослеОжидания не подходит) 
	// т.к. при обновлении после не срабатывают пункты контекстного меню Конструктор, Удалить и т.д.
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоДанныхПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа)
	
	// Обработка стандартного события добавления строки в Дерево (Insert)
	Отказ = Истина;
	
	Если ТекущаяСтрока <> Неопределено 
			И ТекущаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхПодзапрос() Тогда
		
		Возврат;
		
	ИначеЕсли Копирование Тогда // Добавлено копированием
		
		РодительТекущейСтроки = ИТК_КонсольРазработчикаДанныеКлиент.ПолучитьРодителяСтроки(ЭтотОбъект, ТекущаяСтрока);
		
		// Скопируем строку
		ПереместитьСтрокуДереваДанных(ТекущаяСтрока, РодительТекущейСтроки, Истина, Истина)
		
	Иначе
		
		ДобавитьСтрокуВДеревоДанных(ИТК_Перечисления.ЭлементДанныхЗапрос());
		
	КонецЕсли;
	
	ИТК_КонсольРазработчикаДанныеКлиентСервер.ДанныеМодифицированы(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоДанныхПередНачаломИзменения(Элемент, Отказ)
	
	Отказ = Истина;
	ТекущийЭлемент = Элементы.Представление;

КонецПроцедуры

&НаКлиенте
Процедура ДеревоДанныхПроверкаПеретаскивания(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Поле)
	
	СтандартнаяОбработка = Ложь;
	
	// Проверим есть ли строки для которых доступно перетаскивание
	ПриемникПеретаскивания = ПолучитьСтрокуПриемникПеретаскиванияДереваДанных(Строка);
	СтрокиКоторыеМожноПеренести = ПолучитьСтрокиКоторыеМожноПеренести(Элемент.ВыделенныеСтроки, ПараметрыПеретаскивания, ПриемникПеретаскивания);
	
	Если Не ЗначениеЗаполнено(СтрокиКоторыеМожноПеренести) Тогда
		
		ПараметрыПеретаскивания.Действие = ДействиеПеретаскивания.Отмена;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоДанныхПеретаскивание(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Поле)
	
	СтандартнаяОбработка = Ложь;
	
	СтрокаПриемникПеретаскивания = ПолучитьСтрокуПриемникПеретаскиванияДереваДанных(Строка);
	СтрокиКоторыеМожноПеренести = ПолучитьСтрокиКоторыеМожноПеренести(Элемент.ВыделенныеСтроки, ПараметрыПеретаскивания, СтрокаПриемникПеретаскивания);
	
	Копирование = (ПараметрыПеретаскивания.Действие = ДействиеПеретаскивания.Копирование);
	Для Каждого Идентификатор Из СтрокиКоторыеМожноПеренести Цикл
		
		ПереносимаяСтрока = ДеревоДанных.НайтиПоИдентификатору(Идентификатор);
		АктивироватьСтроку = (Элемент.ТекущаяСтрока = Идентификатор);
		
		Если ТипЗнч(СтрокаПриемникПеретаскивания) = Тип("ДанныеФормыДерево") 
			ИЛИ ИТК_КонсольРазработчикаДанныеКлиентСервер.ПереносСтрокиВнутрь(СтрокаПриемникПеретаскивания.Тип, ПереносимаяСтрока.Тип) Тогда
			
			ИндексВставки = Неопределено;
			
		Иначе
			
			ПриемникПеретаскиванияРодитель = ИТК_КонсольРазработчикаДанныеКлиент.ПолучитьРодителяСтроки(ЭтотОбъект, СтрокаПриемникПеретаскивания);
			ИндексВставки = ПриемникПеретаскиванияРодитель.ПолучитьЭлементы().Индекс(СтрокаПриемникПеретаскивания);
			СтрокаПриемникПеретаскивания = ПриемникПеретаскиванияРодитель;
			
		КонецЕсли;
		
		ПереместитьСтрокуДереваДанных(ПереносимаяСтрока, СтрокаПриемникПеретаскивания, Копирование, АктивироватьСтроку, ИндексВставки);
		
		// Удалим перемещенную строку (сделали копию строки на новом месте и нужно удалить старую)
		Если Не Копирование Тогда
			
			РодительПереносимойСтроки = ИТК_КонсольРазработчикаДанныеКлиент.ПолучитьРодителяСтроки(ЭтотОбъект, ПереносимаяСтрока);
			
			Если ПереносимаяСтрока <> Неопределено Тогда // Возможно уже была удалена
				РодительПереносимойСтроки.ПолучитьЭлементы().Удалить(ПереносимаяСтрока);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ТипЗнч(СтрокаПриемникПеретаскивания) <> Тип("ДанныеФормыДерево") Тогда // Не перенос в корень дерева
		Элементы.ДеревоДанных.Развернуть(СтрокаПриемникПеретаскивания.ПолучитьИдентификатор());
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоДанныхВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ВыполнитьСтроку();
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоДанныхПередРазворачиванием(Элемент, Строка, Отказ)
	
	СтрокаДанных = ДеревоДанных.НайтиПоИдентификатору(Строка);
	СтрокаДанных.Развернуто = Истина;

КонецПроцедуры

&НаКлиенте
Процедура ДеревоДанныхПередСворачиванием(Элемент, Строка, Отказ)
	
	СтрокаДанных = ДеревоДанных.НайтиПоИдентификатору(Строка);
	Если СтрокаДанных <> Неопределено Тогда
		СтрокаДанных.Развернуто = Ложь;
