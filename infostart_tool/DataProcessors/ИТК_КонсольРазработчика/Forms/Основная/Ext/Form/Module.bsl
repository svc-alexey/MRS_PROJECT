		ПредставлениеТаблицыМВТ = ИТК_Строки.Сокращенно(ОписаниеТаблицыМВТ.Значение, 70);
		
	ИначеЕсли Строка.Тип = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаЗначение() Тогда
		
		ПредставлениеТаблицыМВТ = НСтр("ru = '<Таблица значений>';
												|en = '<Table of values>'");
		
	КонецЕсли;
	
	Строка.Представление = ПредставлениеТаблицыМВТ;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьКоличествоТаблицМВТ()
	
	КоличествоТаблицМВТ = ТаблицыМВТ.Количество();
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросПередУдалениемТаблицыМВТЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	УдаляемыеАдреса = Новый Массив; УдаляемыеСтроки = Новый Массив;
	Для Каждого ИдентификаторВыделеннойСтроки Из Элементы.ТаблицыМВТ.ВыделенныеСтроки Цикл 
		
		ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
		СтрокаТаблицаМВТ = ТаблицыМВТ.НайтиПоИдентификатору(ИдентификаторВыделеннойСтроки);
		ОписаниеТаблицыМВТ = ИТК_КонсольРазработчикаДанныеКлиент.ТаблицаМВТ(ТекущиеДанные, СтрокаТаблицаМВТ.UID);
		
		Если ОписаниеТаблицыМВТ <> Неопределено Тогда
			УдаляемыеАдреса.Добавить(ОписаниеТаблицыМВТ.Значение);
		КонецЕсли;
		
		УдаляемыеСтроки.Добавить(СтрокаТаблицаМВТ);
		ИТК_КонсольРазработчикаДанныеКлиент.УдалитьТаблицуМВТ(ЭтотОбъект, ТекущаяСтрока, СтрокаТаблицаМВТ.UID);
		
	КонецЦикла;
	
	Для Каждого УдаляемаяСтрока Из УдаляемыеСтроки Цикл 
		ТаблицыМВТ.Удалить(УдаляемаяСтрока);
	КонецЦикла;
	
	ИТК_ВременноеХранилище.Удалить(УдаляемыеАдреса);
	
	ОбновитьКоличествоТаблицМВТ();
	
КонецПроцедуры

&НаКлиенте
Процедура СохранениеНастройкиЗавершено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	СохранитьДанныеВНастройки(Результат);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузкаНастройкиЗавершена(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		
		ЗагрузитьДанныеИзНастроек(Результат.Имя, Результат.Пользователь, ДополнительныеПараметры.Объединение);
		
	Иначе
		
		ЗагрузитьДанныеИзНастроек(Результат, , ДополнительныеПараметры.Объединение);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаСравненияЗавершена(ПараметрыСравнения, ДополнительныеПараметры) Экспорт
	
	Если ПараметрыСравнения = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ИТК_ФормаКлиент.ВозможенЗапускСравненияПредупреждение(ПараметрыСравнения.ТипСравнения) Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаЭталон = НайтиСтрокуПоUID(ДеревоДанных, ПараметрыСравнения.ОбъектЭталон);
	СтрокаНовый = НайтиСтрокуПоUID(ДеревоДанных, ПараметрыСравнения.ОбъектНовый);
	
	ДанныеЭталон = ПодготовитьДанныеПередВыполнением(СтрокаЭталон);
	ДанныеНовый = ПодготовитьДанныеПередВыполнением(СтрокаНовый);
	
	Если ПараметрыСравнения.ТипСравнения = ИТК_Перечисления.ВариантСравненияДанныхТексты() Тогда
		
		Текст1 = ПолучитьТекстДляСравнения(ДанныеЭталон);
		Текст2 = ПолучитьТекстДляСравнения(ДанныеНовый);
		
		Если ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоОдинИзТиповСтрокиЗапрос(СтрокаЭталон.Тип) Тогда
			ТипЯзыка = ИТК_Перечисления.ТипЯзыкаРедактораЗапросы();
		ИначеЕсли СтрокаЭталон.Тип = ИТК_Перечисления.ЭлементДанныхКод() Тогда
			ТипЯзыка = ИТК_Перечисления.ТипЯзыкаРедактораВстроенный();
		ИначеЕсли ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоОдинИзТиповСтрокиСКД(СтрокаЭталон.Тип) Тогда
			ТипЯзыка = ИТК_Перечисления.ТипЯзыкаРедактораXML();
		Иначе 
			ТипЯзыка = Неопределено;
		КонецЕсли;
		
		ИТК_ФормаКлиент.ОткрытьСравнениеТекстов(ЭтотОбъект, Текст1, Текст2, ТипЯзыка);
		
	ИначеЕсли ПараметрыСравнения.ТипСравнения = ИТК_Перечисления.ВариантСравненияДанныхРезультаты() Тогда
		
		#Если ТолстыйКлиентУправляемоеПриложение Тогда
			
			ОписаниеОперации = Новый Структура;
			ОписаниеОперации.Вставить("Источник", ИТК_Перечисления.ИнструментКонсольРазработчика());
			ОписаниеОперации.Вставить("Наименование", НСтр("ru = 'Подготовка сравнения';
															|en = 'Comparison preparation'"));
			
			Расширение = "mxl";
			ИмяПервогоФайла = ПолучитьИмяВременногоФайла(Расширение);
			ИмяВторогоФайла = ПолучитьИмяВременногоФайла(Расширение);
			
			ИТК_ДлительныеОперацииКлиент.НачатьОперацию(ЭтотОбъект, Новый ОписаниеОповещения("НачалоДлительнойОперации", ЭтотОбъект), ОписаниеОперации);
			
			ФоновоеВыполнение = ИТК_БСПКлиентСервер.ВозможноВыполнениеВФоне();
			ДлительнаяОперация = ЗапуститьПодготовкуСравненияНаСервере(ДанныеЭталон, ДанныеНовый, УникальныйИдентификатор, ФоновоеВыполнение);
			ИТК_ДлительныеОперацииКлиент.ЗаполнитьОписаниеОперации(ДлительнаяОперация, ОписаниеОперации);
			
			ОповещениеОПрогрессеВыполнения = Новый ОписаниеОповещения("ОбработкаПрогрессаВыполненияДлительнойОперации", ЭтотОбъект);
			ПараметрыОжидания = ИТК_ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект, ОповещениеОПрогрессеВыполнения);
			
			ИТК_ДлительныеОперацииКлиент.ДобавитьОповещениеПользователя(ЭтотОбъект, ПараметрыОжидания);
			
			ДополнительныеПараметры = Новый Структура("ИмяПервогоФайла, ИмяВторогоФайла", ИмяПервогоФайла, ИмяВторогоФайла);
			ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершениеПодготовкиСравнения", ЭтотОбъект, ДополнительныеПараметры);
			ИТК_ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
			
		#КонецЕсли
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура РедактированиеЗначенияПараметраЗавершено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	ИТК_КонсольРазработчикаДанныеКлиентСервер.ДанныеМодифицированы(ЭтотОбъект);
		
	ПараметрЗапросаТекущиеДанные = Элементы.ПараметрыЗапроса.ТекущиеДанные;
	ИТК_КонсольРазработчикаДанныеКлиент.ВставитьЗначениеПараметраЗапроса(ЭтотОбъект, ТекущаяСтрока, ПараметрЗапросаТекущиеДанные.Имя, Результат);
	ОбновитьСтрокуПараметра(ПараметрЗапросаТекущиеДанные, ПараметрЗапросаТекущиеДанные.Имя, ПараметрЗапросаТекущиеДанные.ТипЗначения, Результат);
	
КонецПроцедуры

&НаКлиенте
Процедура ВводЗначенияПараметраЗавершен(Результат, ДополнительныеПараметры) Экспорт
	
	ПараметрЗапросаТекущиеДанные = Элементы.ПараметрыЗапроса.ТекущиеДанные;
	НовоеЗначение = Неопределено;
	ЕстьРезультат = ИТК_ФормаКлиент.ОбработкаЗавершенВводЗначенияВФорме(Элементы.ПараметрыЗапросаЗначениеПредставление, Результат, ДополнительныеПараметры,
																НовоеЗначение, ПараметрЗапросаТекущиеДанные.ТипЗначения); 
																
	Если ТипЗнч(НовоеЗначение) = Тип("Граница") Тогда
				
		НовоеЗначение = ИТК_ЗапросКлиентСервер.ЗначениеСложногоПараметра(ИТК_Перечисления.СложныйПараметрЗапросаГраница(),
														ИТК_Запрос.ОписаниеИзГраницы(НовоеЗначение));
				
	КонецЕсли;
																
	Если ЕстьРезультат Тогда
		
		ИмяПараметра = ПараметрЗапросаТекущиеДанные.Имя;
		ИТК_КонсольРазработчикаДанныеКлиент.ВставитьЗначениеПараметраЗапроса(ЭтотОбъект, ТекущаяСтрока, ИмяПараметра, НовоеЗначение);
		ОбновитьСтрокуПараметра(ПараметрЗапросаТекущиеДанные, ИмяПараметра, ПараметрЗапросаТекущиеДанные.ТипЗначения, НовоеЗначение);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПреобразованиеТипаЗначенияПараметраЗавершено(ОписаниеТипов, ДополнительныеПараметры) Экспорт
	
	Если ОписаниеТипов = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	
	ВыбранныйТипЗначения = ОписаниеТипов.Типы()[0];
	Для Каждого ИдентификаторСтрокиПараметр Из Элементы.ПараметрыЗапроса.ВыделенныеСтроки Цикл 
		
		СтрокаПараметр = ПараметрыЗапроса.НайтиПоИдентификатору(ИдентификаторСтрокиПараметр);
		
		Если НЕ (СтрокаПараметр.ТипЗначения.СодержитТип(ВыбранныйТипЗначения)
					ИЛИ СтрокаПараметр.ТипЗначения.СодержитТип(Тип("Дата"))) Тогда
			Продолжить;
		КонецЕсли;
		
		НовоеЗначение = Неопределено;
		СтароеЗначение = ИТК_КонсольРазработчикаДанныеКлиент.ЗначениеПараметраЗапроса(ТекущиеДанные, СтрокаПараметр.Имя, СтрокаПараметр.ТипЗначения);
		Если ТипЗнч(СтароеЗначение) = Тип("Дата") Тогда
			
			Если ВыбранныйТипЗначения = Тип("Граница") Тогда
				
				НовоеЗначение = ИТК_ЗапросКлиентСервер.ЗначениеСложногоПараметра(ИТК_Перечисления.СложныйПараметрЗапросаГраница(),
				ИТК_ЗапросКлиентСервер.ОписаниеГраницы(СтароеЗначение));
				
			ИначеЕсли ВыбранныйТипЗначения = Тип("МоментВремени") Тогда
				
				НовоеЗначение = ИТК_ОбщийВызовСервера.НовыйМоментВремени(СтароеЗначение);
			КонецЕсли;
			
		ИначеЕсли ТипЗнч(СтароеЗначение) = Тип("МоментВремени") Тогда
			
			Если ВыбранныйТипЗначения = Тип("Дата") Тогда
				НовоеЗначение = ИТК_Запрос.ДатаИзМоментаВремени(СтароеЗначение);
			ИначеЕсли ВыбранныйТипЗначения = Тип("Граница") Тогда
				
				НовоеЗначение = ИТК_ЗапросКлиентСервер.ЗначениеСложногоПараметра(ИТК_Перечисления.СложныйПараметрЗапросаГраница(),
				ИТК_ЗапросКлиентСервер.ОписаниеГраницы(СтароеЗначение));
				
			КонецЕсли;
			
		ИначеЕсли ИТК_ОбщийКлиентСервер.ЭтоЗначениеПараметраГраница(СтароеЗначение) Тогда
			
			ОписаниеЗначенияПараметра = СтароеЗначение.Значение;
			Если ВыбранныйТипЗначения = Тип("Дата") Тогда
				НовоеЗначение = ИТК_Запрос.ДатаИзОписанияГраницы(ОписаниеЗначенияПараметра);
			ИначеЕсли ВыбранныйТипЗначения = Тип("МоментВремени") Тогда
				НовоеЗначение = ИТК_Запрос.МоментВремениИзОписанияГраницы(ОписаниеЗначенияПараметра);
			КонецЕсли;
			
		КонецЕсли;
		
		Если НовоеЗначение = Неопределено Тогда
			НовоеЗначение = ОписаниеТипов.ПривестиЗначение(Неопределено);
		КонецЕсли;
		
		ИТК_КонсольРазработчикаДанныеКлиент.ВставитьЗначениеПараметраЗапроса(ЭтотОбъект, ТекущаяСтрока, СтрокаПараметр.Имя, НовоеЗначение);
		ОбновитьСтрокуПараметра(СтрокаПараметр, СтрокаПараметр.Имя, СтрокаПараметр.ТипЗначения, НовоеЗначение);
		
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Функция ПодготовитьДанныеЗаполненияПараметров(Имена, ИсточникСтрок)
	
	ДанныеЗаполнения = Новый Массив;
	Для Каждого СтрокаДерева Из ИсточникСтрок.ПолучитьЭлементы() Цикл 
		
		Если СтрокаДерева = ТекущаяСтрока Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрокаДерева.Тип = ИТК_Перечисления.ЭлементДанныхЗапрос() Тогда
			
			ЗначенияПараметров = ПодготовитьЗначенияПараметровДляЗаполнения(Имена, СтрокаДерева);
			
			Если ЗначениеЗаполнено(ЗначенияПараметров) Тогда
				
				ОписаниеСтроки = Новый Структура;
				ОписаниеСтроки.Вставить("Имя", СтрокаДерева.Имя);
				ОписаниеСтроки.Вставить("Выделение", СтрокаДерева.Выделение);
				ОписаниеСтроки.Вставить("Картинка", СтрокаДерева.Картинка);
				ОписаниеСтроки.Вставить("Параметры", ЗначенияПараметров);
				
				ДанныеЗаполнения.Добавить(ОписаниеСтроки);
				
			КонецЕсли;
			
		ИначеЕсли СтрокаДерева.Тип = ИТК_Перечисления.ЭлементДанныхГруппа() Тогда
			
			Строки = ПодготовитьДанныеЗаполненияПараметров(Имена, СтрокаДерева);
			
			Если ЗначениеЗаполнено(Строки) Тогда
				ОписаниеСтроки = Новый Структура;
				ОписаниеСтроки.Вставить("Имя", СтрокаДерева.Имя);
				ОписаниеСтроки.Вставить("Выделение", СтрокаДерева.Выделение);
				ОписаниеСтроки.Вставить("Картинка", СтрокаДерева.Картинка);
				ОписаниеСтроки.Вставить("Строки", Строки);
				
				ДанныеЗаполнения.Добавить(ОписаниеСтроки);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ДанныеЗаполнения;
	
КонецФункции

&НаКлиенте
Функция ПодготовитьЗначенияПараметровДляЗаполнения(Имена, СтрокаДерева)
	
	НесколькоПараметров = (Имена.Количество() > 1);
	ЗначенияПараметров = Новый Соответствие;
	
	ДанныеСтроки = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(СтрокаДерева);
	
	Для Каждого ПараметрИсточник Из ДанныеСтроки.ЗначенияПараметров Цикл 
		
		ДобавляемЭтоЗначение = Ложь;
		Если НесколькоПараметров Тогда
			
			Если Имена.Найти(ПараметрИсточник.Ключ) <> Неопределено 
					И ПодходящийПараметрДляЗаполнения(ПараметрИсточник.Ключ, ПараметрИсточник.Ключ, ТекущаяСтрока, СтрокаДерева) Тогда
				ДобавляемЭтоЗначение = Истина;
			КонецЕсли;
			
		Иначе
			
			Если ПодходящийПараметрДляЗаполнения(Имена[0], ПараметрИсточник.Ключ, ТекущаяСтрока, СтрокаДерева) Тогда
				ДобавляемЭтоЗначение = Истина;
			КонецЕсли;
			
		КонецЕсли;
		
		Если ДобавляемЭтоЗначение Тогда
			ЗначенияПараметров.Вставить(ПараметрИсточник.Ключ, ПараметрИсточник.Значение);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ЗначенияПараметров;
	
КонецФункции

&НаКлиенте
Функция ПодходящийПараметрДляЗаполнения(ИмяПриемник, ИмяИсточник, СтрокаПриемника, СтрокаИсточника)
	
	Результат = Ложь;
	
	Приемник = ДанныеПараметраЗапроса(СтрокаПриемника, ИмяПриемник);
	Источник = ДанныеПараметраЗапроса(СтрокаИсточника, ИмяИсточник);
	
	Если (Приемник.Значение <> Источник.Значение 
				ИЛИ  ИТК_КонсольРазработчикаДанныеКлиентСервер.ТипПараметраТаблицаЗначений(Приемник.ОписаниеТипов))
			И (Приемник.ОписаниеТипов = Источник.ОписаниеТипов
				ИЛИ (ТипЗнч(Приемник.ОписаниеТипов) = Тип("ОписаниеТипов") И Приемник.ОписаниеТипов.СодержитТип(ТипЗнч(Источник.Значение)))
				ИЛИ (Приемник.ОписаниеТипов.СодержитТип(Тип("Дата")) 
							И (ИТК_ОбщийКлиентСервер.ЭтоЗначениеПараметраГраница(Источник.Значение)
								ИЛИ ТипЗнч(Источник.Значение) = Тип("МоментВремени")))) Тогда
				
		Результат = Истина;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ЗаполнениеПараметровЗакончено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	Если ДополнительныеПараметры.Свойство("Имя") Тогда
		
		ЗаполнитьЗначениеПараметра(ДополнительныеПараметры.Имя, Результат);
		
	Иначе
		
		Для Каждого ЗначениеПараметра Из Результат Цикл 
			ЗаполнитьЗначениеПараметра(ЗначениеПараметра.Ключ, ЗначениеПараметра.Значение);
		КонецЦикла;
		
	КонецЕсли;
	
	ЗаполнитьЗакладкуПараметры();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьЗначениеПараметра(ИмяПараметраПриемника, Значение)
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	СтароеЗначениеПараметра = ТекущиеДанные.ЗначенияПараметров.Получить(ИмяПараметраПриемника);
	
	Если ТипЗнч(СтароеЗначениеПараметра) = Тип("Структура")
			И СтароеЗначениеПараметра.Вид = ИТК_Перечисления.СложныйПараметрЗапросаТаблицаЗначений() Тогда
		ИТК_ВременноеХранилище.Удалить(СтароеЗначениеПараметра.Значение);
	КонецЕсли;
	
	ЗначениеПараметра = СкопироватьЗначениеПараметра(Значение);
	ИТК_КонсольРазработчикаДанныеКлиент.ВставитьЗначениеПараметраЗапроса(ЭтотОбъект, ТекущаяСтрока, ИмяПараметраПриемника, ЗначениеПараметра);
	
КонецПроцедуры

&НаКлиенте
Процедура ПереименованиеПараметраЗавершено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	
	ИзменяемыеПоля = Новый Структура;
	ИзменяемыеПоля.Вставить("ТребуетсяПроверка", Истина);
	
	СтароеИмя = ДополнительныеПараметры.Имя;
	НовоеИмя = Результат;
	
	// Заменить в тексте параметр
	НовыйТекст = ИТК_ЗапросКлиентСервер.ЗаменитьПараметрВТексте(ТекущиеДанные.Текст, СтароеИмя, "&" + НовоеИмя);
	ИзменяемыеПоля.Вставить("Текст", НовыйТекст);
	
	ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоля(ЭтотОбъект, ТекущаяСтрока, ИзменяемыеПоля);
	
	// Перенести значение для нового параметра
	ЗначенияПараметров = ТекущиеДанные.ЗначенияПараметров;
	ЗначенияПараметров.Вставить(НовоеИмя, ЗначенияПараметров[СтароеИмя]);
	
	ПодключаемыйЗагрузитьСостояниеРедактораКода();
	
	ПроверитьПоказатьОшибку();
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Функция СкопироватьЗначениеПараметра(Результат)
	
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		
		Если Результат.Вид = ИТК_Перечисления.СложныйПараметрЗапросаВыражение() Тогда
			НовоеЗначение = ИТК_ОбщийКлиентСервер.СкопироватьОбъект (Результат);
		ИначеЕсли Результат.Вид = ИТК_Перечисления.СложныйПараметрЗапросаТаблицаЗначений() Тогда
			НовоеЗначение = ИТК_ОбщийКлиентСервер.СкопироватьОбъект (Результат);
			НовоеЗначение.Значение = ИТК_ОбщийВызовСервера.КопияТаблицыЗначений(Результат.Значение, УникальныйИдентификатор);
		ИначеЕсли Результат.Вид = ИТК_Перечисления.СложныйПараметрЗапросаГраница() Тогда
			НовоеЗначение = ИТК_ОбщийКлиентСервер.СкопироватьОбъект(Результат);
		КонецЕсли;
		
	Иначе 
		
		НовоеЗначение = Результат;
		
	КонецЕсли;
	
	Возврат НовоеЗначение;
	
КонецФункции

&НаСервереБезКонтекста
Функция ЗапуститьПолучениеРезультатаДляОбработкиНаСервере(Знач Данные, УникальныйИдентификатор, ФоновоеВыполнение = Истина)

	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("Данные", ПодготовитьДанныеПередВыполнениемНаСервере(Данные));
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор, ФоновоеВыполнение);
	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_Запрос.РезультатДляОбработки", ПараметрыПроцедуры, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ЗавершениеПолученияРезультатаДляОбработки(Результат, ДополнительныеПараметры) Экспорт
	
	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	
	РезультатВыполнения = ПрочитатьРезультатВыполненияДанных(Результат, УникальныйИдентификатор);

	ОбработаннаяСтрока = НайтиСтрокуПоUID(ДеревоДанных, ДополнительныеПараметры.UID);
	
	Если ОбработаннаяСтрока <> Неопределено Тогда
		
		ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ОбработаннаяСтрока);
		
		Если ЗначениеЗаполнено(РезультатВыполнения.Ошибка) Тогда
			
			ТекущиеДанные.ОшибкаПриВыполнении = РезультатВыполнения.Ошибка;
			ОбновитьЭлементыОшибки();
			ПоказатьОшибку();
			
		Иначе 
			
			ПараметрыФормы = Новый Структура;
			ПараметрыФормы.Вставить("Алгоритмы", ТекущиеДанные.АлгоритмыОбработки);
			ПараметрыФормы.Вставить("АдресОбрабатываемыхДанных", РезультатВыполнения.АдресРезультата);
			ПараметрыФормы.Вставить("Данные", ТекущиеДанные);
			
			ОткрытьФорму("Обработка.ИТК_КонсольРазработчика.Форма.ОбработкаРезультата", ПараметрыФормы, ЭтотОбъект, , , ,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			
		КонецЕсли;
		
	КонецЕсли;
	
	ИТК_ДлительныеОперацииКлиент.СкрытьПрогресс(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьДанныеВКомпоновщикНастроек(ДанныеСКД)
	
	СхемаКомпоновкиДанных = ИТК_СКД.СхемаКомпоновкиДанных(ДанныеСКД.XMLСхемаКомпоновкиДанных);
	АдресВременногоХранилищаСхемыКомпоновкиДанных = ИТК_ВременноеХранилище.Поместить(СхемаКомпоновкиДанных, АдресВременногоХранилищаСхемыКомпоновкиДанных, УникальныйИдентификатор);
	КомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресВременногоХранилищаСхемыКомпоновкиДанных));
	
	Если ДанныеСКД.Свойство("XMLВариантОтчета") И ЗначениеЗаполнено(ДанныеСКД.XMLВариантОтчета) Тогда
		НастройкиВарианта = ИТК_СКД.ВариантНастроек(ДанныеСКД.XMLВариантОтчета);
	Иначе
		НастройкиВарианта = СхемаКомпоновкиДанных.НастройкиПоУмолчанию;
	КонецЕсли;
	
	КомпоновщикНастроек.ЗагрузитьНастройки(НастройкиВарианта);
	
	Если ДанныеСКД.Свойство("XMLПользовательскиеНастройки") Тогда
		ПользовательскиеНастройки = ИТК_СКД.ПользовательскиеНастройки(ДанныеСКД.XMLПользовательскиеНастройки);
		КомпоновщикНастроек.ЗагрузитьПользовательскиеНастройки(ПользовательскиеНастройки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ПолныеДанныеСКД(Строка)
	
	Результат = Новый Структура;
	
	СтрокаВариантаОтчета = Неопределено;
	СтрокаПользовательскихНастроек = Неопределено;
	Если Строка.Тип = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных() Тогда
		
		СтрокаСхемыКомпоновкиДанных = Строка;
		
	ИначеЕсли Строка.Тип = ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД() Тогда
		
		СтрокаВариантаОтчета = Строка;
		СтрокаСхемыКомпоновкиДанных = Строка.ПолучитьРодителя();
		
	ИначеЕсли Строка.Тип = ИТК_Перечисления.ЭлементДанныхПользовательскаяНастройкаСКД() Тогда
		
		СтрокаПользовательскихНастроек = Строка;
		РодительСтроки = Строка.ПолучитьРодителя();
		
		Если РодительСтроки.Тип = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных() Тогда
			СтрокаСхемыКомпоновкиДанных = РодительСтроки;
		ИначеЕсли РодительСтроки.Тип = ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД() Тогда
			СтрокаВариантаОтчета = РодительСтроки;
			СтрокаСхемыКомпоновкиДанных = РодительСтроки.ПолучитьРодителя();
		КонецЕсли;
		
	КонецЕсли;
	
	Если СтрокаСхемыКомпоновкиДанных <> Неопределено Тогда
		
		ДанныеСхемаКомпоновкиДанных = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(СтрокаСхемыКомпоновкиДанных);
		Результат.Вставить("XMLСхемаКомпоновкиДанных", ДанныеСхемаКомпоновкиДанных.Текст);
		Результат.Вставить("ИспользованиеВнешнихФункций", ДанныеСхемаКомпоновкиДанных.ИспользованиеВнешнихФункций);
		Результат.Вставить("ВнешниеИсточники", ДанныеСхемаКомпоновкиДанных.ВнешниеИсточники);
		Результат.Вставить("ТаблицыМВТ", ДанныеСхемаКомпоновкиДанных.ТаблицыМВТ);
		
	КонецЕсли;
	
	Если СтрокаВариантаОтчета <> Неопределено Тогда
		Результат.Вставить("XMLВариантОтчета", ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(СтрокаВариантаОтчета).Текст);	
	КонецЕсли;
	
	Если СтрокаПользовательскихНастроек <> Неопределено Тогда
		Результат.Вставить("XMLПользовательскиеНастройки", ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(СтрокаПользовательскихНастроек).Текст);	
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура СохранитьИзмененныеДанныеСтроки()
	
	Если ИдентификаторПоследнейВыделеннойСтроки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Строка = ДеревоДанных.НайтиПоИдентификатору(ИдентификаторПоследнейВыделеннойСтроки);
	
	Если Строка = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТипСтроки = Строка.Тип;
	Если ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоТипСтрокиСИспользованиемТекста(ТипСтроки) Тогда
		
		ЭлементТекст = ЭлементТекстПоТипуСтроки(ТипСтроки);
		
		ГраницыВыделения = ИТК_РедакторКодаКлиент.ГраницыВыделения(ЭлементТекст);
		Если ГраницыВыделения <> Неопределено Тогда
			ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоле(ЭтотОбъект, Строка, "ГраницыВыделенияТекста", ГраницыВыделения, Ложь);
		КонецЕсли;
			
		Закладки = ИТК_РедакторКодаКлиент.УстановленныеЗакладки(ЭлементТекст);
		Если Закладки <> Неопределено Тогда
			ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоле(ЭтотОбъект, Строка, "Закладки", Закладки, Ложь);
		КонецЕсли;
	
		СостояниеРедактора = ИТК_РедакторКодаКлиент.СостояниеРедактора(ЭлементТекст);
		Если СостояниеРедактора <> Неопределено Тогда
			ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоле(ЭтотОбъект, Строка, "СостояниеРедактора", СостояниеРедактора, Ложь);
		КонецЕсли;
		
	КонецЕсли;
	
	Если ТипСтроки = ИТК_Перечисления.ЭлементДанныхПользовательскаяНастройкаСКД() Тогда
		
		АдресЗначения = ПоместитьВоВременноеХранилище(КомпоновщикНастроек.ПользовательскиеНастройки);
		ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоле(ЭтотОбъект, Строка, "Текст", ИТК_СКД.XMLТекстИзАдреса(АдресЗначения));
		
	ИначеЕсли ТипСтроки = ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД() Тогда
		
		АдресЗначения = ПоместитьВоВременноеХранилище(КомпоновщикНастроек.Настройки);
		ИТК_КонсольРазработчикаДанныеКлиент.ИзменитьПоле(ЭтотОбъект, Строка, "Текст", ИТК_СКД.XMLТекстИзАдреса(АдресЗначения));
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ПодготовитьДанныеПередВыполнением(Строка)
	
	Результат = Новый Структура;
	
	Если Строка.Тип = ИТК_Перечисления.ЭлементДанныхПодзапрос() Тогда
		
		Результат = ИТК_КонсольРазработчикаДанныеКлиентСервер.НовыйЭлемент(ИТК_Перечисления.ЭлементДанныхЗапрос());
		ДанныеСтроки = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(Строка);
		
		ДанныеОсновногоЗапроса = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ОсновнойЗапрос(Строка));
		ЗаполнитьЗначенияСвойств(Результат, ДанныеОсновногоЗапроса);
		
		Результат.Текст = ДанныеСтроки.Текст;
		Результат.Вставить("ТекстИнициализации", ДанныеСтроки.ТекстИнициализации);
		
	ИначеЕсли ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоОдинИзТиповСтрокиСКД(Строка.Тип) Тогда
		
		ДанныеСКД = ПолныеДанныеСКД(Строка);
		Для Каждого ПараметрДанныхСКД Из ДанныеСКД Цикл 
			Результат.Вставить(ПараметрДанныхСКД.Ключ, ПараметрДанныхСКД.Значение);
		КонецЦикла;
		
	Иначе
		
		Результат = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(Строка);
		
	КонецЕсли;
	
	Результат.Вставить("Тип", Строка.Тип);
	Результат.Вставить("Представление", Строка.Имя);
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ПолучитьТекстДляСравнения(Данные)
	
	ТипДанных = Данные.Тип;
	Если ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоОдинИзТиповСтрокиЗапрос(ТипДанных)
			ИЛИ ТипДанных = ИТК_Перечисления.ЭлементДанныхКод() Тогда
		
		Результат = Данные.Текст;
		
	ИначеЕсли ТипДанных = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных() Тогда
		
		Результат = Данные.XMLСхемаКомпоновкиДанных;
		
	ИначеЕсли ТипДанных = ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД() Тогда
		
		Результат = Данные.XMLВариантОтчета;
		
	ИначеЕсли ТипДанных = ИТК_Перечисления.ЭлементДанныхПользовательскаяНастройкаСКД() Тогда
		
		Результат = Данные.XMLПользовательскиеНастройки;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция СписокДоступенДляПараметра(Значение, ОписаниеТипов)
	
	Возврат НЕ (ИТК_КонсольРазработчикаДанныеКлиентСервер.ТипПараметраТаблицаЗначений(ОписаниеТипов) 
					ИЛИ ТипЗнч(Значение) = Тип("МоментВремени")
					ИЛИ ТипЗнч(Значение) = Тип("Граница")
					ИЛИ ИТК_ОбщийКлиентСервер.ЭтоЗначениеПараметраГраница(Значение));
	
КонецФункции

&НаКлиенте
Процедура ВводИдентификатораВнешнегоИсточникаЗавершен(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВнешниеИсточникиТекущиеДанные = Элементы.ВнешниеИсточники.ТекущиеДанные;
	ВнешниеИсточникиТекущиеДанные.Имя = Результат;
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	ОписаниеВнешнегоИсточника = ИТК_КонсольРазработчикаДанныеКлиент.ВнешнийИсточник(ТекущиеДанные, ВнешниеИсточникиТекущиеДанные.UID);
	ОписаниеВнешнегоИсточника.Имя = Результат;
	
	ИТК_КонсольРазработчикаДанныеКлиент.ВставитьВнешнийИсточник(ЭтотОбъект, ТекущаяСтрока, ВнешниеИсточникиТекущиеДанные.UID, ОписаниеВнешнегоИсточника);
	
	ИТК_КонсольРазработчикаДанныеКлиентСервер.ДанныеМодифицированы(ЭтотОбъект);
		
	ВнешниеИсточники.Сортировать("Имя");
	ЗагрузитьПользовательскиеОбъектыПодсказки();
	
КонецПроцедуры

&НаКлиенте
Процедура ВводИдентификатораТаблицыМВТЗавершен(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицыМВТТекущиеДанные = Элементы.ТаблицыМВТ.ТекущиеДанные;
	ТаблицыМВТТекущиеДанные.Имя = Результат;
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	ОписаниеТаблицыМВТ = ИТК_КонсольРазработчикаДанныеКлиент.ВнешнийИсточник(ТекущиеДанные, ТаблицыМВТТекущиеДанные.UID);
	ОписаниеТаблицыМВТ.Имя = Результат;
	
	ИТК_КонсольРазработчикаДанныеКлиент.ВставитьТаблицуМВТ(ЭтотОбъект, ТекущаяСтрока, ТаблицыМВТТекущиеДанные.UID, ОписаниеТаблицыМВТ);
	
	ИТК_КонсольРазработчикаДанныеКлиентСервер.ДанныеМодифицированы(ЭтотОбъект);
	
	ТаблицыМВТ.Сортировать("Имя");
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьСтрокиДереваДанных(Строка, ОтборТип)
	
	Результат = Новый Массив;
	Для Каждого ВложеннаяСтрока Из Строка.ПолучитьЭлементы() Цикл 
		
		Если ВложеннаяСтрока.Тип = ОтборТип Тогда
			Результат.Добавить(ВложеннаяСтрока);
		ИначеЕсли ВложеннаяСтрока.Тип = ИТК_Перечисления.ЭлементДанныхГруппа() Тогда
			
			СтрокиГруппы = ПолучитьСтрокиДереваДанных(ВложеннаяСтрока, ОтборТип);
			Для Каждого СтрокаВГруппе Из СтрокиГруппы Цикл 
				Результат.Добавить(СтрокаВГруппе);
			КонецЦикла;
			
		КонецЕсли;

	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ТребуетсяПроверкаСтроки()
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	Возврат ИТК_ОбщийКлиентСервер.Свойство(ТекущиеДанные, "ТребуетсяПроверка", Ложь);
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура СкорректироватьВыделениеВТабличномДокументеРезультата(Элемент, ТабличныйДокумент, РезультатОбновления)
	
	ТекущаяОбласть = ТабличныйДокумент.ТекущаяОбласть;
	
	ШиринаТаблицы = ПолеТаблицыРезультатаСУчетомОбновления(ТабличныйДокумент, "ШиринаТаблицы", РезультатОбновления);
	
	Лево = ТекущаяОбласть.Лево;
	Если Лево > ШиринаТаблицы Тогда
		Лево = ШиринаТаблицы;
	КонецЕсли;
	
	Право = ТекущаяОбласть.Право;
	Если Право > ШиринаТаблицы Тогда
		Право = ШиринаТаблицы;
	КонецЕсли;
	
	ВысотаТаблицы = ПолеТаблицыРезультатаСУчетомОбновления(ТабличныйДокумент, "ВысотаТаблицы", РезультатОбновления);
	
	Низ = ТекущаяОбласть.Низ;
	Если Низ > ВысотаТаблицы Тогда
		Низ = ВысотаТаблицы;
	КонецЕсли;
	
	Верх = ТекущаяОбласть.Верх;
	Если Верх > ВысотаТаблицы Тогда
		Верх = ВысотаТаблицы;
	КонецЕсли;
	
	Элемент.ТекущаяОбласть = ТабличныйДокумент.Область(Верх, Лево, Низ, Право);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПолеТаблицыРезультатаСУчетомОбновления(ТабличныйДокумент, Поле, РезультатОбновления)
	
	Если ЗначениеЗаполнено(РезультатОбновления) Тогда
		Результат = Мин(ТабличныйДокумент[Поле], РезультатОбновления[Поле]);
	Иначе
		Результат = ТабличныйДокумент[Поле];
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция ПодготовитьДанныеПередВыполнениемНаСервере(Данные) Экспорт
	
	Если Данные.Тип = ИТК_Перечисления.ЭлементДанныхЗапрос() Тогда
		
		Для Каждого Параметр Из Данные.Параметры Цикл
			
			ЗначениеПараметра = Данные.ЗначенияПараметров.Получить(Параметр.Ключ);
			Если ТипЗнч(ЗначениеПараметра) = Тип("Структура") Тогда
				
				Если ЗначениеПараметра.Вид = ИТК_Перечисления.СложныйПараметрЗапросаТаблицаЗначений() Тогда
					ЗначениеПараметра.Значение = ПолучитьИзВременногоХранилища(ЗначениеПараметра.Значение);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если ИТК_КонсольРазработчикаДанныеКлиентСервер.ЭтоТипСтрокиСИспользованиемВнешнихИсточников(Данные.Тип) Тогда
		
		Для Каждого ВнешнийИсточник Из Данные.ВнешниеИсточники Цикл 
			
			ОписаниеВнешнегоИсточника = ВнешнийИсточник.Значение;
			
			Если ОписаниеВнешнегоИсточника.Тип = ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаЗначение() Тогда
				
				Если ЗначениеЗаполнено(ОписаниеВнешнегоИсточника.Значение) Тогда
					ОписаниеВнешнегоИсточника.Значение = ПолучитьИзВременногоХранилища(ОписаниеВнешнегоИсточника.Значение);
				Иначе
					ОписаниеВнешнегоИсточника.Значение = Неопределено;
				КонецЕсли;
				
			КонецЕсли;				
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Данные;
	
КонецФункции

&НаКлиенте
Процедура ЭкспортФайлаЗакончен(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ВыводРезультатаВТабличныйДокументНаСервер(ТабличныйДокумент, Результат.УдалитьЗаголовок);
	
	ИТК_ТабличныйДокументКлиент.ЭкспортФайлаЗакончен(ТабличныйДокумент, Результат, ПоследняяАктивнаяОбласть);
	
КонецПроцедуры

&НаКлиенте
Процедура ЭкспортВоВнешнийОтчетФайлаЗакончен(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = ИТК_КонсольРазработчикаДанныеКлиентСервер.Получить(ТекущаяСтрока);
	ДвоичныеДанные = ДвоичныеДанныеВнешнегоОтчета(ТекущиеДанные.Текст, Результат.Имя, Результат.Синоним);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПустойОбработчикОповещенийДополнительныеПараметры", ИТК_ОбщийКлиент);
	ДвоичныеДанные.НачатьЗапись(ОписаниеОповещения, Результат.ПолноеИмяФайла);
	
КонецПроцедуры

