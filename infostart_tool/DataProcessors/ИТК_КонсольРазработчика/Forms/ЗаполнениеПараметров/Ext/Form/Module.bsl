#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОдинЗаполняемыйПараметр = (Параметры.Имена.Количество() = 1);
	Заголовок = СтрШаблон(НСтр("ru = 'Заполнение значений параметров: %1';
								|en = 'Filling in the values of the parameters: %1'"), СтрСоединить(Параметры.Имена, ", "));
	
	ЗаполнитьДерево(Параметры.ДанныеЗаполнения, ДанныеЗаполнения);
	
	Если ОдинЗаполняемыйПараметр Тогда
		
		УстановитьПометкуНаПервомПараметре(ДанныеЗаполнения);
		
	КонецЕсли;
	
	УстановитьУсловноеОформление();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДанныеЗаполнения

&НаКлиенте
Процедура ДанныеЗаполненияПометкаПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ДанныеЗаполнения.ТекущиеДанные;
	
	Если ОдинЗаполняемыйПараметр Тогда
		
		ИТК_ФормаКлиент.ДеревоУстановитьПодчиненнымПометку(ДанныеЗаполнения, 0);
		ИТК_ФормаКлиент.ОпределитьПометкуТриСостояния(ТекущиеДанные);
		
	Иначе
		
		Пометка = ИТК_ФормаКлиент.ОпределитьПометкуТриСостояния(ТекущиеДанные);
		ИТК_ФормаКлиент.ДеревоУстановитьПодчиненнымПометку(ТекущиеДанные, Пометка);
		ИТК_ФормаКлиент.ДеревоОпределитьПометкуРодителя(ТекущиеДанные, Пометка);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаОК(Команда)
	
	ЗначенияПараметров = ЗначенияПараметров(ДанныеЗаполнения);
	
	Если ОдинЗаполняемыйПараметр Тогда
		
		Для Каждого ЗначениеПараметра Из ЗначенияПараметров Цикл 
			
			Закрыть(ЗначениеПараметра.Значение);
			Прервать;
			
		КонецЦикла;
		
	Иначе 
		
		Закрыть(ЗначенияПараметров);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьДерево(Элементы, СтрокаПриемник)
	
	Для Каждого Элемент Из Элементы Цикл 
		
		НоваяСтрока = СтрокаПриемник.ПолучитьЭлементы().Добавить();
		НоваяСтрока.ТипСтроки = ИТК_Перечисления.ЭлементДанныхЗапрос();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Элемент);
		
		Если Элемент.Свойство("Строки") Тогда
			
			ЗаполнитьДерево(Элемент.Строки, НоваяСтрока);
			НоваяСтрока.ТипСтроки = ИТК_Перечисления.ЭлементДанныхГруппа();
			
		Иначе
			
			Для Каждого ЗначениеПараметра Из Элемент.Параметры Цикл 
				
				НоваяСтрокаПараметр = НоваяСтрока.ПолучитьЭлементы().Добавить();
				НоваяСтрокаПараметр.Имя = ЗначениеПараметра.Ключ;
				НоваяСтрокаПараметр.Картинка = БиблиотекаКартинок.Реквизит;
				НоваяСтрокаПараметр.Значение = ЗначениеПараметра.Значение;
				
				Если ТипЗнч(ЗначениеПараметра.Значение) = Тип("Структура") Тогда
					Представление = ЗначениеПараметра.Значение.Представление;
				Иначе 
					Представление = ЗначениеПараметра.Значение;
				КонецЕсли;
				
				НоваяСтрокаПараметр.Представление = Представление;
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "ДанныеЗаполненияИмя", Новый Структура("Шрифт", ИТК_ОбщийКлиентСервер.ШрифтЖирный()),
															"ДанныеЗаполнения.Выделение", Истина);
	
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "ДанныеЗаполнения", Новый Структура("Шрифт", ИТК_ОбщийКлиентСервер.ШрифтЖирный()),
															"ДанныеЗаполнения.Пометка", Истина);
			
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "ДанныеЗаполненияПометка", Новый Структура("Отображать", Ложь),
															"ДанныеЗаполнения.ТипСтроки", ИТК_Перечисления.ЭлементДанныхГруппа());
	
	Если ОдинЗаполняемыйПараметр Тогда
		
		ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "ДанныеЗаполненияПометка", Новый Структура("Отображать", Ложь),
															"ДанныеЗаполнения.ТипСтроки", ИТК_Перечисления.ЭлементДанныхЗапрос());
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ЗначенияПараметров(Строка)
	
	ЗначенияПараметров = Новый Соответствие;
	Если ТипЗнч(Строка) <> Тип("ДанныеФормыДерево")
		И ПустаяСтрока(Строка.ТипСтроки) Тогда 
		
		Если Строка.Пометка Тогда
			ЗначенияПараметров.Вставить(Строка.Имя, Строка.Значение);
		КонецЕсли;
		
	КонецЕсли;
	
	Для Каждого ВложеннаяСтрока Из Строка.ПолучитьЭлементы() Цикл 
		
		Для Каждого ЗначенияПараметровВложенных Из ЗначенияПараметров(ВложеннаяСтрока) Цикл 
			ЗначенияПараметров.Вставить(ЗначенияПараметровВложенных.Ключ, ЗначенияПараметровВложенных.Значение);
		КонецЦикла;
		 
	КонецЦикла;
	
	Возврат ЗначенияПараметров;
	
КонецФункции

&НаСервере
Процедура УстановитьПометкуНаПервомПараметре(Строка)
	
	Для Каждого ВложеннаяСтрока Из Строка.ПолучитьЭлементы() Цикл 
		
		Если ЗначениеЗаполнено(ВложеннаяСтрока.ТипСтроки) Тогда
			
			УстановитьПометкуНаПервомПараметре(ВложеннаяСтрока);
			
		Иначе
			
			ВложеннаяСтрока.Пометка = Истина;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти