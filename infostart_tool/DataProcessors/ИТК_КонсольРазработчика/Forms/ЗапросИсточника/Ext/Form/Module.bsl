#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Колонки = Параметры.Колонки;
	Источник = Параметры.Источник;
	Псевдоним = СтрЗаменить(Параметры.Источник, "&", "");
	
	ДобавлятьИндексы = Истина;
	ВыразитьТипы = Истина;
	
	ИТК_ФормаКлиентСервер.УстановитьЗаголовок(ЭтотОбъект, НСтр("ru = 'Запрос источника';
																|en = 'Source query'"));
	
	Язык = ИТК_Общий.КодЯзыкаПрограммирования();
	ИТК_Форма.ЗаполнитьСписокВыбораЯзыкПрограммирования(Элементы.Язык);
	
	// Инициализация элемента текст запроса
	ДополнительныеСвойства = Новый Структура;
	ДополнительныеСвойства.Вставить("ТолькоПросмотр", Истина);
	ДополнительныеСвойства.Вставить("ТипЯзыка", ИТК_Перечисления.ТипЯзыкаРедактораЗапросы());
	ИТК_РедакторКода.Инициализация(ЭтотОбъект, "ТекстЗапроса", ДополнительныеСвойства);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИТК_РедакторКодаКлиент.Инициализация(ЭтотОбъект, "ТекстЗапроса");
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	ИТК_РедакторКодаКлиент.ОбработкаОповещения(ЭтотОбъект, ИмяСобытия, Параметр, Источник);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВыразитьТипыПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавлятьИндексыПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ЯзыкПриИзменении(Элемент)

	Если Язык = ИТК_ОбщийКлиентСервер.КодЯзыкаРусский()
			И Псевдоним = "Table1" Тогда
		Псевдоним = "Таблица1";
	КонецЕсли;
	
	Если Язык = ИТК_ОбщийКлиентСервер.КодЯзыкаАнглийский()
			И Псевдоним = "Таблица1" Тогда
		Псевдоним = "Table1";
	КонецЕсли;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПсевдонимНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ИТК_ФормаКлиент.ОткрытьРедактированиеИдентификатора(НСтр("ru = 'Псевдоним';
															|en = 'Alias'"),
															ИТК_Перечисления.РежимРедактированияИдентификатораИдентификатор(), ЭтотОбъект,
															Новый ОписаниеОповещения("ВводПсевдонимаЗавершен", ЭтотОбъект), Псевдоним);

КонецПроцедуры

&НаКлиенте
Процедура ИТК_ПодключаемыйДокументСформирован(Элемент)
	
	ИТК_РедакторКодаКлиент.ДополнительнаяИнициализация(ЭтотОбъект, Элемент);
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ИТК_ПодключаемыйПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	ИТК_РедакторКодаКлиент.ОбработкаСобытий(ЭтотОбъект, Элемент, ДанныеСобытия, СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Копировать(Команда)
	
	ИТК_БуферОбменаКлиент.Копировать(ТекстЗапроса);
	
КонецПроцедуры

#Область ПодключаемыеКоманды

&НаКлиенте
Процедура ИТК_ПодключаемаяКомандаРедакторКодаОбработчик(Команда)
	
	ИТК_РедакторКодаКлиент.ПодключаемыйОбработчикКоманд(ЭтотОбъект, Команда.Имя);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	Элементы.Псевдоним.ПоложениеЗаголовка = ИТК_ОбщийКлиентСервер.ПоложениеЗаголовкаАвтоВверхПоДлине(Псевдоним, 20);
	
	// Генерация текста
	ПараметрыГенерации = Новый Структура;
	ПараметрыГенерации.Вставить("Язык", Язык);
	ПараметрыГенерации.Вставить("Колонки", Колонки);
	ПараметрыГенерации.Вставить("ДобавлятьИндексы", ДобавлятьИндексы);
	ПараметрыГенерации.Вставить("ВыразитьТипы", ВыразитьТипы);
	ПараметрыГенерации.Вставить("Источник", Источник);
	ПараметрыГенерации.Вставить("Псевдоним", Псевдоним);
	
	Результат = ИТК_Запрос.ПоИсточнику(ПараметрыГенерации);
	ИТК_РедакторКодаКлиент.УстановитьТекст(ЭтотОбъект, Элементы["ТекстЗапроса"], Результат);

КонецПроцедуры

&НаКлиенте
Процедура ВводПсевдонимаЗавершен(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Псевдоним = Результат;
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти
