#Область ОписаниеПеременных

&НаКлиенте
Перем ЗакрытиеРазрешено;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Данные = Параметры.Данные;
	
	// Инициализация обработки объектов
	ИТК_ОбработкаОбъектов.СоздатьЭлементыИРеквизиты(ЭтотОбъект, Элементы.СтраницаРезультат, Элементы.ГруппаИнформацияООбработкеОбъектов);
	
	ИТК_Настройки.ИнициализироватьФорму(ЭтотОбъект);
	ИТК_Перечисления.ЗаполнитьСписок(Элементы.Транзакция, ИТК_Перечисления.ТипыТранзакцииОбработкиРезультата());
	
	ЭтотОбъект["АдресОбрабатываемыхДанных"] = Параметры.АдресОбрабатываемыхДанных;
	ОбрабатываемыеДанные = ПолучитьИзВременногоХранилища(Параметры.АдресОбрабатываемыхДанных);
	КоличествоСтрок = ОбрабатываемыеДанные.Количество();
		
	Если КоличествоСтрок = 0 Тогда
		Элементы.ФормаГруппаОбработать.Доступность = Ложь;
	КонецЕсли;			
	
	ШаблонЗаголовка = НСтр("ru = 'Обработка результата %1';
							|en = 'Processing of results %1'");
	Заголовок = СтрШаблон(ШаблонЗаголовка, ИТК_Строки.ТекстНекотороеКоличествоСтрок(КоличествоСтрок));
	
	Если ЗначениеЗаполнено(Параметры.Алгоритмы) Тогда
		Алгоритмы = Параметры.Алгоритмы;
	Иначе
		Алгоритмы.Добавить(ИТК_MCRФорматКлиентСервер.ОписаниеАлгоритмаОбработки(), НСтр("ru = 'Основной';
																						|en = 'Main'"));
	КонецЕсли;
	
	ЗаполнитьСтраницуКод("", НСтр("ru = 'Основной';
									|en = 'Main'"));
	
	Элементы.СтраницыКод.ТекущаяСтраница = Элементы.СтраницаКод;
	ТекущийЭлемент = Элементы["Код"];
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ЗакрыватьПриВыборе = Ложь;
	
	ОбновитьСписокАлгоритмов();
	УстановитьТекущийАлгоритм(0);
	ОбновитьЗаголовокАлгоритмы();
	
	РазвернутьВеткиСтраницыДереваКода("");
	ИТК_РедакторКодаКлиент.Инициализация(ЭтотОбъект, "Код");
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	ИТК_НастройкиКлиент.ОбработкаОповещения(ЭтотОбъект, ИмяСобытия);
	ИТК_РедакторКодаКлиент.ОбработкаОповещения(ЭтотОбъект, ИмяСобытия, Параметр, Источник);
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если Не ЗавершениеРаботы 
		И ЗакрытиеРазрешено = Неопределено Тогда
		
		Если Модифицированность Тогда
			
			Отказ = Истина;
			
			ЗаголовокВопроса = НСтр("ru = 'Обработка результата';
									|en = 'Processing of results'");
			ТекстВопроса = НСтр("ru = 'Имеются несохраненные данные при закрытии они будут потеряны. Продолжить?';
								|en = 'If you have unsaved data when you close it, it will be lost. Continue?'");

			ОписаниеОповещенияОЗавершении = Новый ОписаниеОповещения("ВопросСохраненияЗавершение", ЭтотОбъект);
			ИТК_ФормаКлиент.ЗадатьВопрос(ОписаниеОповещенияОЗавершении, ТекстВопроса, ИТК_ФормаКлиент.КнопкиВопросаПродолжитьОтмена(), Неопределено, ЗаголовокВопроса, ЭтотОбъект);
								
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура АлгоритмПриИзменении(Элемент)
	
	УстановитьТекущийАлгоритм(ИТК_ОбщийКлиентСервер.СписокЗначенийНайтиПоПредставлению(Алгоритмы, Алгоритм));
	ОбновитьЗаголовокАлгоритмы();
	
КонецПроцедуры

&НаКлиенте
Процедура АлгоритмОткрытие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ПереименоватьАлгоритм();
	
КонецПроцедуры

&НаКлиенте
Процедура ТранзакцияПриИзменении(Элемент)
	
	ИзмененноеОписание = Новый Структура("Транзакция", Транзакция);
	
	Если Транзакция = ИТК_Перечисления.ТипТранзакцииОбработкиРезультатаНаВсе() Тогда
		ПрерыватьПриОшибке = Истина;
		ИзмененноеОписание.Вставить("ПрерыватьПриОшибке", ПрерыватьПриОшибке);
	КонецЕсли;
	
	ИзменитьОписаниеТекущегоАлгоритма(ИзмененноеОписание);
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаКлиенте
Процедура ТранзакцияОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ИТК_ПодключаемыйРедакторПриИзменении(Элемент)
	
	ИмяПоля = Элемент.Имя;
	ИзменитьОписаниеТекущегоАлгоритма(Новый Структура(ИмяПоля, ЭтотОбъект[ИмяПоля]));
	
	ЭлементАлгоритм = ИТК_ОбщийКлиентСервер.СписокЗначенийНайтиПоПредставлению(Алгоритмы, Алгоритм);
	ОбновитьЗаголовокСтраницыКод(ИмяПоля, ЭлементАлгоритм.Значение);
	
КонецПроцедуры

&НаКлиенте
Процедура ИТК_ПодключаемыйДокументСформирован(Элемент)
	
	ДополнительныеПараметры = Новый Структура;
	
	ПользовательскиеОбъекты = ИТК_РедакторКодаВызовСервера.ПользовательскиеОбъектыОбработкаРезультатов(Данные, ЭтотОбъект["АдресОбрабатываемыхДанных"], Элемент.Имя);
	ДополнительныеПараметры.Вставить("ПользовательскиеОбъекты", ПользовательскиеОбъекты);
	
	ИТК_РедакторКодаКлиент.ДополнительнаяИнициализация(ЭтотОбъект, Элемент, ДополнительныеПараметры);
	
	УстановитьТекущийАлгоритм(0);
	
КонецПроцедуры

&НаКлиенте
Процедура ИТК_ПодключаемыйПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ОбработкаКодПриИзменении", ЭтотОбъект);
	ИТК_РедакторКодаКлиент.ОбработкаСобытий(ЭтотОбъект, Элемент, ДанныеСобытия, СтандартнаяОбработка, ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ПрерыватьПриОшибкеПриИзменении(Элемент)
	
	ИзменитьОписаниеТекущегоАлгоритма(Новый Структура("ПрерыватьПриОшибке", ПрерыватьПриОшибке));
	
КонецПроцедуры

&НаКлиенте
Процедура СтраницыКодПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	СуффиксКод = СтрЗаменить(ТекущаяСтраница.Имя, "СтраницаКод", "");

	ИмяЭлементаКод = "Код" + СуффиксКод;
	ЭлементКод = Элементы[ИмяЭлементаКод];
	Если НЕ ИТК_РедакторКодаКлиент.ТребуетсяПервоначальнаяИнициализация(ЭлементКод) Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьСтраницуКод(СуффиксКод, ТекущаяСтраница.Заголовок);
	
	РазвернутьВеткиСтраницыДереваКода(СуффиксКод);
	ИТК_РедакторКодаКлиент.Инициализация(ЭтотОбъект, ИмяЭлементаКод);
	
	ЭлементАлгоритм = ИТК_ОбщийКлиентСервер.СписокЗначенийНайтиПоПредставлению(Алгоритмы, Алгоритм);
	ОписаниеАлгоритма = ЭлементАлгоритм.Значение;
	ЗаполнитьКодСтраницы(СуффиксКод, ОписаниеАлгоритма);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовЖурналРезультатовОбработки

&НаКлиенте
Процедура ПодключаемыйЖурналРезультатовОбработкаРасшифровки(Элемент, Расшифровка, СтандартнаяОбработка, ДополнительныеПараметры)
	
	СтандартнаяОбработка = Ложь;
	ИндексОбъекта = Расшифровка;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Индекс", ИндексОбъекта);
	ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("ЗавершенаРасшифровкаРезультата", ЭтотОбъект, ДополнительныеПараметры);
	
	Если ИТК_ОбработкаРезультатаКлиентСервер.ЭтоИндексОбъекта(ИндексОбъекта) Тогда
		
		АдресОбрабатываемыхДанных = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаДанных()];
		АдресРезультатовОбработки = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаРезультатов()];
		
		ДанныеСтроки = ДанныеСтроки(АдресОбрабатываемыхДанных, ИндексОбъекта);
		ИТК_ФормаКлиент.ОткрытьРасшифровкуДанныхСтроки(ЭтотОбъект, АдресРезультатовОбработки, ДанныеСтроки, ИндексОбъекта, ОписаниеОповещенияЗавершение);
		
	Иначе
		
		Результат = Новый Структура;
		Результат.Вставить("НомерСтроки", 1);
		Результат.Вставить("НомерСтолбца", 1);

		ВыполнитьОбработкуОповещения(ОписаниеОповещенияЗавершение, Результат);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДеревоКода

&НаКлиенте
Процедура ПодключаемыйДеревоКодаНачалоПеретаскивания(Элемент, ПараметрыПеретаскивания, Выполнение)
	
	ВставляемыйТекст = ПодсказкаКода(Элемент.ТекущиеДанные);
	
	Если ЗначениеЗаполнено(ВставляемыйТекст) Тогда
		ПараметрыПеретаскивания.Значение = ВставляемыйТекст;
	Иначе
		Выполнение = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйДеревоКодаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ВставляемыйТекст = ПодсказкаКода(Элемент.ТекущиеДанные);

	Если ЗначениеЗаполнено(ВставляемыйТекст) Тогда
		
		ЭлементКод = Элементы[ИТК_Строки.РазборПрочитатьДоСимвола(Элемент.Имя, "_")];		
		
		ЭлементКод.ВыделенныйТекст = ВставляемыйТекст;
		ТекущийЭлемент = ЭлементКод;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйДеревоКодаПередРазворачиванием(Элемент, Строка, Отказ)
	
	РазворачиваемаяСтрока = ЭтотОбъект[Элемент.Имя].НайтиПоИдентификатору(Строка);
	
	Если ИТК_ФормаКлиентСервер.НеобходимоРазвернутьСтроку(РазворачиваемаяСтрока) Тогда
		
		ДобавитьСтрокиДляСсылочногоТипаВДеревоКода(Элемент.Имя, Строка, РазворачиваемаяСтрока.ТипЗначения);

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ДобавитьАлгоритм(Команда)
	
	ИзменитьАлгоритм(Истина);

КонецПроцедуры

&НаКлиенте
Процедура ПереименоватьАлгоритм(Команда = Неопределено)
	
	ИзменитьАлгоритм();
	
КонецПроцедуры
					
&НаКлиенте
Процедура ИзменитьАлгоритм(Добавление = Ложь)
	
	Если Добавление Тогда
		
		НачальноеЗначение = "";
		ЗанятыеИдентификаторы = ЗанятыеИдентификаторыАлгоритмов();
		Оповещение = Новый ОписаниеОповещения("ЗавершенВводНаименованияНовогоАлгоритма", ЭтотОбъект);
		
	Иначе
		
		НачальноеЗначение = Алгоритм;
		ЗанятыеИдентификаторы = ЗанятыеИдентификаторыАлгоритмов(Алгоритм);
		Оповещение = Новый ОписаниеОповещения("ЗавершеноПереименованиеАлгоритма", ЭтотОбъект);
		
	КонецЕсли;
	
	ИТК_ФормаКлиент.ОткрытьРедактированиеИдентификатора(НСтр("ru = 'Введите наименование алгоритма';
															|en = 'Enter the name of the algorithm'"),
							ИТК_Перечисления.РежимРедактированияИдентификатораСтрока(), ЭтотОбъект,	Оповещение, НачальноеЗначение, ЗанятыеИдентификаторы);
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьАлгоритм(Команда)
	
	Если Алгоритмы.Количество() > 1 Тогда
		
		Модифицированность = Истина;
		ЭлементАлгоритм = ИТК_ОбщийКлиентСервер.СписокЗначенийНайтиПоПредставлению(Алгоритмы, Алгоритм);
		Алгоритмы.Удалить(ЭлементАлгоритм);
		ОбновитьСписокАлгоритмов();
		
		УстановитьТекущийАлгоритм(0);
		ОбновитьЗаголовокАлгоритмы();
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьВсе(Команда)
	
	ВариантыОтвета = Новый СписокЗначений;
	ВариантыОтвета.Добавить(КодВозвратаДиалога.Да,		НСтр("ru = 'Продолжить';
																|en = 'Continue'"));
	ВариантыОтвета.Добавить(КодВозвратаДиалога.Отмена,	НСтр("ru = 'Отмена';
																|en = 'Cancel'"));
	
	Оповещение = Новый ОписаниеОповещения("ВопросОбработатьВсеЗавершение", ЭтотОбъект);
	ЗаголовокВопроса = НСтр("ru = 'Будут обработаны все данные. Данная операция не обратима. Продолжить?';
							|en = 'All data will be processed. This operation is not reversible. Proceed?'");
	ПоказатьВопрос(Оповещение, ЗаголовокВопроса, ВариантыОтвета, , КодВозвратаДиалога.Да, ИТК_КонсольРазработчикаКлиентСервер.Представление());
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьПервуюСтроку(Команда)
	
	ОбрабатываемыеСтроки = Новый Массив;
	ОбрабатываемыеСтроки.Добавить(0);
	
	ВыполнитьОбработку(ОбрабатываемыеСтроки);
	
КонецПроцедуры

&НаКлиенте
Процедура Сохранить(Команда = Неопределено)
	
	ОповеститьОВыборе(Алгоритмы);
	Модифицированность = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьИЗакрыть(Команда)
	
	Сохранить();
	Закрыть();

КонецПроцедуры

&НаКлиенте
Процедура ОтменитьДлительнуюОперацию(Команда)
	
	ИТК_ДлительныеОперацииКлиент.ОтменитьОперацию(ЭтотОбъект);
	
КонецПроцедуры

#Область ПодключаемыеКоманды

&НаКлиенте
Процедура ИТК_ПодключаемаяКомандаРедакторКодаОбработчик(Команда)
	
	ИТК_РедакторКодаКлиент.ПодключаемыйОбработчикКоманд(ЭтотОбъект, Команда.Имя);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйОбработчикКомандОбработкаОбъектов(Команда)
	
	ИТК_ОбработкаОбъектовКлиент.ОбработатьКоманду(ЭтотОбъект, Команда.Имя);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	Элементы.ПрерыватьПриОшибке.Доступность = (Транзакция <> ИТК_Перечисления.ТипТранзакцииОбработкиРезультатаНаВсе());
	
КонецПроцедуры

&НаКлиенте
Процедура ИТК_ПодключаемыйВосстановлениеФокусаРедактора() Экспорт 
	
	ИТК_РедакторКодаКлиент.ВосстановлениеФокусаРедактора(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершенВводНаименованияНовогоАлгоритма(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	Модифицированность = Истина;
	Алгоритмы.Добавить(ИТК_MCRФорматКлиентСервер.ОписаниеАлгоритмаОбработки(), Результат);
	ОбновитьСписокАлгоритмов();
		
	УстановитьТекущийАлгоритм(Алгоритмы.Количество() - 1);
	ОбновитьЗаголовокАлгоритмы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписокАлгоритмов()
	
	СписокВыбора = Элементы.Алгоритм.СписокВыбора;
	СписокВыбора.Очистить();
	
	Для Каждого ЭлементАлгоритм Из Алгоритмы Цикл 
		
		СписокВыбора.Добавить(ЭлементАлгоритм.Представление);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершеноПереименованиеАлгоритма(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Алгоритм <> Результат Тогда
		
		Модифицированность = Истина;
		
		ЭлементАлгоритм = ИТК_ОбщийКлиентСервер.СписокЗначенийНайтиПоПредставлению(Алгоритмы, Алгоритм);
		ЭлементАлгоритм.Представление = Результат;
		
		ОбновитьСписокАлгоритмов();
		Алгоритм = Результат;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьТекущийАлгоритм(НовыйАлгоритм)
	
	Если ТипЗнч(НовыйАлгоритм) = Тип("Число") Тогда
		ЭлементАлгоритм = Алгоритмы[НовыйАлгоритм];
	Иначе
		ЭлементАлгоритм = НовыйАлгоритм;
	КонецЕсли;
	
	Алгоритм = ЭлементАлгоритм.Представление;
	ОписаниеАлгоритма = ЭлементАлгоритм.Значение;
	
	ЗаполнитьКодСтраницы("Перед", ОписаниеАлгоритма);
	ЗаполнитьКодСтраницы("", ОписаниеАлгоритма);
	ЗаполнитьКодСтраницы("После", ОписаниеАлгоритма);
	
	ПрерыватьПриОшибке = ОписаниеАлгоритма.ПрерыватьПриОшибке;
	Транзакция = ОписаниеАлгоритма.Транзакция;
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьОписаниеТекущегоАлгоритма(ОписаниеКлючей)
	
	ОписаниеАлгоритма = ИТК_ОбщийКлиентСервер.СписокЗначенийНайтиПоПредставлению(Алгоритмы, Алгоритм).Значение;
	
	Для Каждого ОписаниеКлюча Из ОписаниеКлючей Цикл 
		ОписаниеАлгоритма[ОписаниеКлюча.Ключ] = ОписаниеКлюча.Значение;
	КонецЦикла;

	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Функция ЗанятыеИдентификаторыАлгоритмов(ИдентификаторИсключение = Неопределено)
	
	Результат = Новый Массив;
	Для Каждого ЭлементАлгоритм Из Алгоритмы Цикл 
		
		ИдентификаторАлгоритма = ЭлементАлгоритм.Представление;
		Если ИдентификаторАлгоритма <> ИдентификаторИсключение Тогда
			Результат.Добавить(ИдентификаторАлгоритма);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ОбновитьЗаголовокАлгоритмы()
	
	КоличествоАлгоритмов = Алгоритмы.Количество();
	ЭлементАлгоритм = ИТК_ОбщийКлиентСервер.СписокЗначенийНайтиПоПредставлению(Алгоритмы, Алгоритм);
	
	Если КоличествоАлгоритмов > 1 Тогда
		ЗаголовокАлгоритм = СтрШаблон(НСтр("ru = 'Алгоритм (%1/%2)';
											|en = 'Algorithm (%1/%2)'"), Алгоритмы.Индекс(ЭлементАлгоритм) + 1, КоличествоАлгоритмов);
	Иначе
		ЗаголовокАлгоритм = НСтр("ru = 'Алгоритм';
								|en = 'Algorithm'");
	КонецЕсли;
	
	Элементы.Алгоритм.Заголовок = ЗаголовокАлгоритм;
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросСохраненияЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗакрытиеРазрешено = Истина;
	Закрыть();

КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйОбработкаПрерыванияПользователем() Экспорт
	
	ЗавершенаОбработкаДанных();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнениеДереваКодаСтраницы(Имя, Реквизит)
	
	ДеревоКода = ЭтотОбъект[Реквизит];
	
	ДобавитьСтрокуВДеревоКода(ДеревоКода, ИТК_ОбработкаРезультатаКлиентСервер.ИдентификаторДополнительныеСвойства());
	
	Если Имя = "" Тогда
		
		СтрокаСтрока = ДобавитьСтрокуВДеревоКода(ДеревоКода, ИТК_ОбработкаРезультатаКлиентСервер.ИдентификаторСтроки());
		
		ОбрабатываемыеДанные = ПолучитьИзВременногоХранилища(ЭтотОбъект["АдресОбрабатываемыхДанных"]);
		Для Каждого Колонка Из ОбрабатываемыеДанные.Колонки Цикл 
			ДобавитьРазворачиваемуюСтрокуВДеревоКода(СтрокаСтрока, Колонка.Имя, Колонка.ТипЗначения);
		КонецЦикла;
	
	КонецЕсли;
	
	// Параметры
	ЗначенияПараметров = ИТК_Запрос.ЗначенияПараметров(Данные);
	Если ЗначениеЗаполнено(ЗначенияПараметров) Тогда
		
		СтрокаПараметры = ДобавитьСтрокуВДеревоКода(ДеревоКода, ИТК_ОбработкаРезультатаКлиентСервер.ИдентификаторПараметры(), БиблиотекаКартинок.ИТК_Параметры);
		
		Для Каждого Параметр Из Данные.Параметры Цикл 
			
			ДобавитьСтрокуВДеревоКода(СтрокаПараметры, Параметр.Ключ, ИТК_Типы.КартинкаОписания(Параметр.Значение), "%1." + Параметр.Ключ);

		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ДобавитьСтрокуВДеревоКода(Родитель, Представление, Картинка = Неопределено, Значение = Неопределено, ТипЗначения = Неопределено)
	
	НоваяСтрока = Родитель.ПолучитьЭлементы().Добавить();
	НоваяСтрока.Представление = Представление;
	НоваяСтрока.ТипЗначения = ТипЗначения;
	
	Если ЗначениеЗаполнено(Картинка) Тогда
		НоваяСтрока.Картинка = Картинка;
	КонецЕсли;
	
	Если Значение = Неопределено Тогда
		НоваяСтрока.Значение = Представление;
	Иначе 
		НоваяСтрока.Значение = Значение;
	КонецЕсли;

	Возврат НоваяСтрока;
	
КонецФункции

&НаСервере
Процедура ДобавитьРазворачиваемуюСтрокуВДеревоКода(Родитель, Представление, ТипЗначения)
	
	Картинка = ИТК_Типы.КартинкаОписания(ТипЗначения);
	
	Если ИТК_ТипыКлиентСервер.ЕстьСсылочныеТипы(ТипЗначения, Истина) Тогда
		
		НоваяСтрока = ДобавитьСтрокуВДеревоКода(Родитель, Представление, Картинка, "%1." + Представление, ТипЗначения);
		ДобавитьСтрокуВДеревоКода(НоваяСтрока, "");
		
	Иначе
		
		ДобавитьСтрокуВДеревоКода(Родитель, Представление, Картинка, "%1." + Представление);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьСтрокиДляСсылочногоТипаВДеревоКода(ИмяДерева, ИдентификаторСтроки, ТипЗначения)
	
	Строка = ЭтотОбъект[ИмяДерева].НайтиПоИдентификатору(ИдентификаторСтроки);
	Строка.ПолучитьЭлементы().Очистить();
	
	КонтекстПоТипам = СобратьПоМетаданным(ТипЗначения);
	
	Если ЗначениеЗаполнено(КонтекстПоТипам.Функции) Тогда
		
		Для Каждого ОписаниеФункции Из КонтекстПоТипам.Функции Цикл 
			ДобавитьСтрокуВДеревоКода(Строка, ОписаниеФункции.Представление, БиблиотекаКартинок.ПроизвольноеВыражение, ОписаниеФункции.Код);
		КонецЦикла;
		
	КонецЕсли;
	
	ТекстПримеры = НСтр("ru = 'Примеры';
						|en = 'Examples'");
	
	Если ЗначениеЗаполнено(КонтекстПоТипам.Примеры) Тогда
		
		СтрокаПримеры = ДобавитьСтрокуВДеревоКода(Строка, ТекстПримеры, , "");
		Для Каждого ОписаниеПримера Из КонтекстПоТипам.Примеры Цикл 
			ДобавитьСтрокуВДеревоКода(СтрокаПримеры, ОписаниеПримера.Представление, , ОписаниеПримера.Код);
		КонецЦикла;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КонтекстПоТипам.ТабличныеЧасти) Тогда
		
		Для Каждого ОписаниеТабличнойЧасти Из КонтекстПоТипам.ТабличныеЧасти Цикл 
			
			СтрокаТЧ = ДобавитьСтрокуВДеревоКода(Строка, ОписаниеТабличнойЧасти.Имя, БиблиотекаКартинок.ВложеннаяТаблица, ОписаниеТабличнойЧасти.Код);
			СтрокаПримеры = ДобавитьСтрокуВДеревоКода(СтрокаТЧ, ТекстПримеры, , "");
			
			ШаблонКода = НСтр("ru = 'Для Каждого СтрокаТЧ Из Объект.%1 Цикл
			|		
			|КонецЦикла;';
			|en = 'For Each RowTable Из Object.%1 Loop
			|		
			|EndLoop;'");
			ПримерКода = СтрШаблон(ШаблонКода, ОписаниеТабличнойЧасти.Имя);
			ДобавитьСтрокуВДеревоКода(СтрокаПримеры, НСтр("ru = 'Обход табличной части';
															|en = 'Traversing the tabular part'"), , ПримерКода);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КонтекстПоТипам.Реквизиты) Тогда
		
		Для Каждого ОписаниеРеквизита Из КонтекстПоТипам.Реквизиты Цикл
			ДобавитьРазворачиваемуюСтрокуВДеревоКода(Строка, ОписаниеРеквизита.Имя, ОписаниеРеквизита.Тип);
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СобратьПоМетаданным(ТипЗначения)
	
	Реквизиты = Новый ТаблицаЗначений;
	Реквизиты.Колонки.Добавить("Имя");
	Реквизиты.Колонки.Добавить("Тип");
	
	ТабличныеЧасти = Новый ТаблицаЗначений;
	ТабличныеЧасти.Колонки.Добавить("Имя");
	ТабличныеЧасти.Колонки.Добавить("Код");
	
	Примеры = Новый ТаблицаЗначений;
	Примеры.Колонки.Добавить("Представление");
	Примеры.Колонки.Добавить("Код");
	
	Функции = Новый ТаблицаЗначений;
	Функции.Колонки.Добавить("Представление");
	Функции.Колонки.Добавить("Код");
	
	ИдентификаторОбъекта = НСтр("ru = 'Объект';
								|en = 'Object'");
	
	Для Каждого Тип Из ТипЗначения.Типы() Цикл 
		
		ОбъектМетаданных = Метаданные.НайтиПоТипу(Тип);
		
		Если ОбъектМетаданных = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ПолноеИмяОбъектаМетаданных = ОбъектМетаданных.ПолноеИмя();
		ИмяЭлементаКоллекцииМетаданных = ИТК_Строки.РазборПрочитатьИдентификатор(ПолноеИмяОбъектаМетаданных);
		
		Если ИмяЭлементаКоллекцииМетаданных = "Перечисление" Тогда
			Продолжить;
		КонецЕсли;
		
		ДобавитьРеквизитыПоМетаданным(Реквизиты, ОбъектМетаданных.СтандартныеРеквизиты);
		ДобавитьРеквизитыПоМетаданным(Реквизиты, ОбъектМетаданных.Реквизиты);
		
		// Табличные части
		Для Каждого ТЧОбъекта Из ОбъектМетаданных.ТабличныеЧасти Цикл 
			
			Если ТабличныеЧасти.Найти(ТЧОбъекта.Имя, "Имя") = Неопределено Тогда
				
				НоваяСтрока = ТабличныеЧасти.Добавить();
				НоваяСтрока.Имя = ТЧОбъекта.Имя;
				НоваяСтрока.Код = "%1." + ТЧОбъекта.Имя;
				
			КонецЕсли;
			
		КонецЦикла;
		
		ДобавитьФункцииКодаПоМетаданным(Функции, НСтр("ru = 'ПолучитьОбъект()';
														|en = 'GetObject()'"),
		НСтр("ru = '%1.ПолучитьОбъект()';
			|en = '%1.GetObject()'"));
		ПримерКода = НСтр("ru = '%2 = %1.ПолучитьОбъект();
		|//%2.ОбменДанными.Загрузка = Истина;
		|//%2.ИмяПоля = ;
		|%2.Записать();';
		|en = '%2 = %1.GetObject();
		|//%2.DataExchange.Load = True;
		|//%2.FieldName = ;
		|%2.Write();'");
		ДобавитьПримерКодаПоМетаданным(Примеры, НСтр("ru = 'Изменить реквизит, записать';
													|en = 'Change props, write'"), СтрШаблон(ПримерКода, "%1", ИдентификаторОбъекта));
		
		ПримерКода = НСтр("ru = '%2 = %1.ПолучитьОбъект();
		|%2.УстановитьПометкуУдаления(Истина);';
		|en = '%2 = %1.GetObject();
		|%2.SetDeletionMark(True);'");
		ДобавитьПримерКодаПоМетаданным(Примеры, НСтр("ru = 'Установить пометку на удаление';
													|en = 'Set mark for deletion'"), СтрШаблон(ПримерКода, "%1", ИдентификаторОбъекта));
		
		ПримерКода = НСтр("ru = '%2 = %1.ПолучитьОбъект();
		|%2.УстановитьПометкуУдаления(Ложь);';
		|en = '%2 = %1.GetObject();
		|%2.SetDeletionMark(False);'");
		ДобавитьПримерКодаПоМетаданным(Примеры, НСтр("ru = 'Снять пометку на удаление';
													|en = 'Unmark removal'"), СтрШаблон(ПримерКода, "%1", ИдентификаторОбъекта));
		
		ПримерКода = НСтр("ru = '%2 = %1.ПолучитьОбъект();
		|%2.Удалить();';
		|en = '%2 = %1.GetObject();
		|%2.Delete();'");
		ДобавитьПримерКодаПоМетаданным(Примеры, НСтр("ru = 'Удалить непосредственно (без контроля)';
													|en = 'Delete directly (without control)'"),
		СтрШаблон(ПримерКода, "%1", ИдентификаторОбъекта));
		
		Если ИмяЭлементаКоллекцииМетаданных = "Документ" Тогда
			
			ПримерКода = НСтр("ru = '%2 = %1.ПолучитьОбъект();
			|%2.Записать(РежимЗаписиДокумента.Проведение);';
			|en = '%2 = %1.GetObject();
			|%2.Write(DocumentWriteMode.Posting);'");
			ДобавитьПримерКодаПоМетаданным(Примеры, НСтр("ru = 'Проведение документа';
														|en = 'Document holding'"), СтрШаблон(ПримерКода, "%1", ИдентификаторОбъекта));
			
			ПримерКода = НСтр("ru = '%2 = %1.ПолучитьОбъект();
			|%2.Записать(РежимЗаписиДокумента.ОтменаПроведения);';
			|en = '%2 = %1.GetObject();
			|%2.Write(DocumentWriteMode.UndoPosting);'");
			ДобавитьПримерКодаПоМетаданным(Примеры, НСтр("ru = 'Отмена проведения документа';
														|en = 'Cancel a document'"), СтрШаблон(ПримерКода, "%1", ИдентификаторОбъекта));
			
		ИначеЕсли ИмяЭлементаКоллекцииМетаданных = "БизнесПроцесс" Тогда
			
			ПримерКода = НСтр("ru = '%2 = %1.ПолучитьОбъект();
			|%2.Старт();';
			|en = '%2 = %1.GetObject();
			|%2.Start();'");
			ДобавитьПримерКодаПоМетаданным(Примеры, НСтр("ru = 'Старт бизнес процесса';
														|en = 'Starting a business process'"), СтрШаблон(ПримерКода, "%1", ИдентификаторОбъекта));
			
		ИначеЕсли ИмяЭлементаКоллекцииМетаданных = "Задача" Тогда
			
			ПримерКода = НСтр("ru = '%2 = %1.ПолучитьОбъект();
			|%2.ВыполнитьЗадачу();';
			|en = '%2 = %1.GetObject();
			|%2.ExecuteTask();'");
			ДобавитьПримерКодаПоМетаданным(Примеры, НСтр("ru = 'Выполнить задачу';
														|en = 'Complete the task'"), СтрШаблон(ПримерКода, "%1", ИдентификаторОбъекта));
			
		КонецЕсли;
		
		ПримерКода = НСтр("ru = 'Узлы = Новый Массив;
		|Узлы.Добавить();
		|
		|ПланыОбмена.ЗарегистрироватьИзменения(Узлы, %1);
		|';
		|en = 'Nodes = New Array;
		|Nodes.Add();
		|
		|ExchangePlans.RecordChanges(Nodes, %1);'");
		ДобавитьПримерКодаПоМетаданным(Примеры, НСтр("ru = 'Зарегистрировать в планах обмена';
													|en = 'Register exchange plans'"), ПримерКода);
		
		ПримерКода = НСтр("ru = 'Узлы = Новый Массив;
		|Узлы.Добавить();
		|
		|ПланыОбмена.УдалитьРегистрациюИзменений(Узлы, %1);
		|';
		|en = 'Nodes = New Array;
		|Nodes.Add();
		|
		|ExchangePlans.DeleteChangeRecords(Nodes, %1);'");
		ДобавитьПримерКодаПоМетаданным(Примеры, НСтр("ru = 'Удалить регистрацию в планах обмена';
													|en = 'Unregister exchange plans'"), ПримерКода);
		
	КонецЦикла;
	
	Реквизиты.Сортировать("Имя");
	ТабличныеЧасти.Сортировать("Имя");
	
	Результат = Новый Структура;
	Результат.Вставить("Реквизиты", Реквизиты);
	Результат.Вставить("Примеры", Примеры);
	Результат.Вставить("Функции", Функции);
	Результат.Вставить("ТабличныеЧасти", ТабличныеЧасти);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ДобавитьРеквизитыПоМетаданным(Реквизиты, Источник)
	
	Для Каждого Реквизит Из Источник Цикл 
		
		Если Реквизит.Имя = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляОбъекта("Ссылка") Тогда
			Продолжить;
		КонецЕсли;
		
		НайденнаяСтрока = Реквизиты.Найти(Реквизит.Имя, "Имя");
		
		Если НайденнаяСтрока = Неопределено Тогда 
			
			НоваяСтрока = Реквизиты.Добавить();
			НоваяСтрока.Имя = Реквизит.Имя;
			НоваяСтрока.Тип = Реквизит.Тип;
			
		Иначе
			
			НайденнаяСтрока.Тип = ИТК_ТипыКлиентСервер.СложитьОписания(НайденнаяСтрока.Тип, Реквизит.Тип);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьПримерКодаПоМетаданным(Примеры, Представление, ПримерКода)
	
	НайденнаяСтрока = Примеры.Найти(Представление, "Представление");
	
	Если НайденнаяСтрока = Неопределено Тогда 
		
		НоваяСтрока = Примеры.Добавить();
		НоваяСтрока.Представление = Представление;
		НоваяСтрока.Код = ПримерКода;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьФункцииКодаПоМетаданным(Функции, Представление, ПримерКода)
	
	НайденнаяСтрока = Функции.Найти(Представление, "Представление");
	
	Если НайденнаяСтрока = Неопределено Тогда 
		
		НоваяСтрока = Функции.Добавить();
		НоваяСтрока.Представление = Представление;
		НоваяСтрока.Код = ПримерКода;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ПодсказкаКода(СтрокаДанные)
	
	Если ЗначениеЗаполнено(СтрокаДанные.Значение) Тогда
		
		Результат = ПодсказкаКодаПоСтроке(СтрокаДанные);
		
	Иначе
		
		Результат = "";
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ПодсказкаКодаПоСтроке(СтрокаДанные)
	
	Если ЗначениеЗаполнено(СтрокаДанные.Значение) 
		И Не СтрНайти(СтрокаДанные.Значение, "%1") Тогда
		
		Результат = СтрокаДанные.Значение;
		
	Иначе
		
		ПодсказкаКода = ПодсказкаКодаПоСтроке(СтрокаДанные.ПолучитьРодителя());
		Если ЗначениеЗаполнено(СтрокаДанные.Значение) Тогда
			Результат = СтрШаблон(СтрокаДанные.Значение, ПодсказкаКода);
		Иначе
			Результат = ПодсказкаКода;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьСтраницуКод(Имя, Представление)
	
	УлучшенныйРедакторКода = ИТК_РедакторКода.ИспользуетсяMonaco();	
	ИмяРеквизитаКод = "Код" + Имя;
	СтраницаКод = Элементы["СтраницаКод" + Имя];
	
	Если Не УлучшенныйРедакторКода Тогда 
		
		ДобавляемыеРеквизиты = Новый Массив;
		
		// Добавление реквизитов
		
		ИмяДерева = ИмяДереваКода(Имя);
		ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, ИмяДерева, "ДеревоЗначений");
		
		ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, "Картинка", "Картинка", , ИмяДерева);
		ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, "Представление", "Строка", , ИмяДерева);
		ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, "Значение", "Строка", , ИмяДерева);
		ИТК_Форма.ДобавитьРеквизит(ДобавляемыеРеквизиты, "ТипЗначения", "ОписаниеТипов", , ИмяДерева);

		ИзменитьРеквизиты(ДобавляемыеРеквизиты);
		
	КонецЕсли;
	
	// Элемент "Код"
	ДополнительныеСвойства = Новый Структура;
	ДополнительныеСвойства.Вставить("Заголовок", Представление);
	ДополнительныеСвойства.Вставить("Подсказка", ИТК_ОбработкаРезультатаКлиентСервер.ПодсказкаПоКодуОбработки(Имя));
	ДополнительныеСвойства.Вставить("Ширина", 60);
	ДополнительныеСвойства.Вставить("Высота", 15);
	ЭлементКод = ИТК_РедакторКода.Инициализация(ЭтотОбъект, ИмяРеквизитаКод, ДополнительныеСвойства);
	
	Если Не УлучшенныйРедакторКода Тогда
		
		ЭлементКод.УстановитьДействие("ПриИзменении", "ИТК_ПодключаемыйРедакторПриИзменении");
		
		// Добавление дерева кода
		Поля = Новый Структура;
		Поля.Вставить("ПутьКДанным", ИмяДерева);
		Поля.Вставить("Заголовок", СтрШаблон(НСтр("ru = 'Дерево код (%1)';
													|en = 'Tree code (%1)'"), Представление));
		Поля.Вставить("Шапка", Ложь);
		Поля.Вставить("ИзменятьСоставСтрок", Ложь);
		Поля.Вставить("ИзменятьПорядокСтрок", Ложь);
		Поля.Вставить("ПоложениеКоманднойПанели", ПоложениеКоманднойПанелиЭлементаФормы.Нет);
		Поля.Вставить("Ширина", 30);
		ДеревоКод = ИТК_Форма.ДобавитьЭлемент(ЭтотОбъект, ИмяДерева, "Таблица", Поля, СтраницаКод);
		ДеревоКод.УстановитьДействие("НачалоПеретаскивания", "ПодключаемыйДеревоКодаНачалоПеретаскивания");
		ДеревоКод.УстановитьДействие("Выбор", "ПодключаемыйДеревоКодаВыбор");
		ДеревоКод.УстановитьДействие("ПередРазворачиванием", "ПодключаемыйДеревоКодаПередРазворачиванием");
		
		Поля = Новый Структура;
		Поля.Вставить("Группировка", ГруппировкаКолонок.ВЯчейке);
		Поля.Вставить("Заголовок", НСтр("ru = 'Представление (группа)';
										|en = 'Presentation (group)'"));
		ГруппаКолонокПредставление = ИТК_Форма.ДобавитьЭлемент(ЭтотОбъект, ИмяДерева + "ГруппаПредставление", "Группа", Поля, ДеревоКод);
		
		Поля = Новый Структура("ПутьКДанным", ИмяДерева + ".Представление");
		ИТК_Форма.ДобавитьЭлемент(ЭтотОбъект, ИмяДерева + "Представление", "ПолеВвода", Поля, ГруппаКолонокПредставление);
		
		Поля = Новый Структура;
		Поля.Вставить("ПутьКДанным", ИмяДерева + ".Картинка");
		ИТК_Форма.ДобавитьЭлемент(ЭтотОбъект, ИмяДерева + "Картинка", "ПолеКартинки", Поля, ГруппаКолонокПредставление);
		
		ЗаполнениеДереваКодаСтраницы(Имя, ИмяДерева);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РазвернутьВеткиСтраницыДереваКода(Имя)
	
	ИмяДерева = ИмяДереваКода(Имя);
	
	Если Элементы.Найти("ИмяДерева") = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Для Каждого Строка Из ЭтотОбъект[ИмяДерева].ПолучитьЭлементы() Цикл 
		Элементы[ИмяДерева].Развернуть(Строка.ПолучитьИдентификатор());
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьКодСтраницы(Имя, ОписаниеАлгоритма)
	
	ИмяПоля = "Код" + Имя;
	КодТекст = ОписаниеАлгоритма[ИмяПоля];
	
	Элемент = Элементы[ИмяПоля];
	ИТК_РедакторКодаКлиент.УстановитьТекст(ЭтотОбъект, Элемент, КодТекст);
	
	ОбновитьЗаголовокСтраницыКод(ИмяПоля, ОписаниеАлгоритма);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЗаголовокСтраницыКод(ИмяПоля, ОписаниеАлгоритма)
	
	КодСтраницы = ОписаниеАлгоритма[ИмяПоля];
	
	Если ЗначениеЗаполнено(КодСтраницы) Тогда
		ДополнениеЗаголовка = "!";
	Иначе
		ДополнениеЗаголовка = "";
	КонецЕсли;
	
	ЭтотОбъект[ИмяПоля + "ДополнениеЗаголовка"] = ДополнениеЗаголовка;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ИмяДереваКода(Имя)
	
	Возврат "Код" + Имя + "_Дерево";
	
КонецФункции

&НаКлиенте
Процедура НачалоДлительнойОперации(Результат, ДополнительныеПараметры) Экспорт
	
	Элементы.ФормаГруппаОбработать.Доступность = Ложь;
	ОчиститьЖурналаРезультата();
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросОбработатьВсеЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
		
	ВыполнитьОбработку();

КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьОбработку(ОбрабатываемыеСтроки = Неопределено)
	
	ФоновоеВыполнение = ИТК_БСПКлиентСервер.ВозможноВыполнениеВФоне();
	Если Транзакция = ИТК_Перечисления.ТипТранзакцииОбработкиРезультатаНаВсе()
			И НЕ ФоновоеВыполнение Тогда
		
		ЗаголовокПредупреждения = НСтр("ru = 'Транзакция на все обрабатываемые данные может использоваться только для фонового выполнения';
										|en = 'A transaction to all processed data can only be used for background execution'");
		ПоказатьПредупреждение( , ЗаголовокПредупреждения, , ИТК_КонсольРазработчикаКлиентСервер.Представление());
		
		Возврат;
		
	КонецЕсли;
	
	ТекущийЭлемент = Элементы.СтраницаРезультат;
	
	// Начальные данные (длительной операции)
	Если ОбрабатываемыеСтроки = Неопределено Тогда
		Обрабатывается = КоличествоСтрок;
	Иначе 
		Обрабатывается = ОбрабатываемыеСтроки.Количество();
	КонецЕсли;
	
	ОписаниеОперации = Новый Структура;
	ОписаниеОперации.Вставить("Источник", ИТК_Перечисления.ИнструментКонсольРазработчика());
	ОписаниеОперации.Вставить("Наименование", НСтр("ru = 'Обработка результата';
													|en = 'Processing of results'"));
	
	ОповещениеНачала = Новый ОписаниеОповещения("НачалоДлительнойОперации", ЭтотОбъект);
	ИТК_ОбработкаОбъектовКлиент.Инициализация(ЭтотОбъект, Обрабатывается, ОписаниеОперации, ОповещениеНачала);
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершенаОбработкаДанных", ЭтотОбъект);
	
	АдресОбрабатываемыхДанных = ЭтотОбъект["АдресОбрабатываемыхДанных"];
	ОписаниеАлгоритма = ИТК_ОбщийКлиентСервер.СписокЗначенийНайтиПоПредставлению(Алгоритмы, Алгоритм).Значение;
	Если ФоновоеВыполнение Тогда
		
		ДлительнаяОперация = ЗапуститьОбработкуНаСервере(ОписаниеАлгоритма, АдресОбрабатываемыхДанных,
																ОбрабатываемыеСтроки, Данные, УникальныйИдентификатор, ФоновоеВыполнение);
																
		ОповещениеОПрогрессеВыполнения = Новый ОписаниеОповещения("ОбработкаПрогрессаВыполнения", ЭтотОбъект);
		ИТК_ОбработкаОбъектовКлиент.ИнициализацияДлительнойОперации(ЭтотОбъект, ДлительнаяОперация, ОписаниеОперации, ОповещениеОПрогрессеВыполнения, ОповещениеОЗавершении);
		
	Иначе
		
		ВыполнитьОбработкуВСеансе(АдресОбрабатываемыхДанных, ОписаниеАлгоритма, ОбрабатываемыеСтроки);
		ВыполнитьОбработкуОповещения(ОповещениеОЗавершении, Неопределено);
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ОчиститьЖурналаРезультата() Экспорт
	
	ИТК_ОбработкаОбъектов.ОчиститьЖурналаРезультата(ЭтотОбъект);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗапуститьОбработкуНаСервере(ОписаниеАлгоритма, АдресОбрабатываемыхДанных, ОбрабатываемыеСтроки, Данные, УникальныйИдентификатор, ФоновоеВыполнение) Экспорт

	ПараметрыПроцедуры = Новый Структура;
	
	ОбрабатываемыеДанные = ПолучитьИзВременногоХранилища(АдресОбрабатываемыхДанных);
	ПараметрыПроцедуры.Вставить("ОбрабатываемыеДанные", ОбрабатываемыеДанные);
	ПараметрыПроцедуры.Вставить("ОписаниеАлгоритма", ОписаниеАлгоритма);
	ПараметрыПроцедуры.Вставить("ОбрабатываемыеСтроки", ОбрабатываемыеСтроки);
	ПараметрыПроцедуры.Вставить("ДополнительныеСвойства", Новый Структура);
	ПараметрыПроцедуры.Вставить("ЗначенияПараметров", ИТК_Запрос.ЗначенияПараметров(Данные));
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор, ФоновоеВыполнение);
	Результат = ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_ОбработкаРезультата.Обработать", ПараметрыПроцедуры, ПараметрыВыполнения);
	
	Возврат Результат;

КонецФункции

&НаКлиенте
Процедура ВыполнитьОбработкуВСеансе(АдресОбрабатываемыхДанных, ОписаниеАлгоритма, ОбрабатываемыеСтроки)
	
	ДополнительныеСвойства = Новый Структура;
	АдресДанных = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаДанных()];
	
	// Инициализация параметров + Обработка кода перед
	РезультатИнициализации = ИнициализацияПередОбработкой(АдресОбрабатываемыхДанных, ОписаниеАлгоритма.КодПеред, ДополнительныеСвойства);
	ОшибкаВыполнения = РезультатИнициализации.Ошибка;
	АдресЗначенийПараметров = РезультатИнициализации.АдресЗначенийПараметров;
	Если ЗначениеЗаполнено(ОшибкаВыполнения) Тогда
		Возврат;
	КонецЕсли;
	
	ИндексНачалаПакета = 0;
	КоличествоСтрокВПакете = 1;
	
	ИмяПроцедурыОбработкиПрерыванияПользователем = "ПодключаемыйОбработкаПрерыванияПользователем";
	ПодключитьОбработчикОжидания(ИмяПроцедурыОбработкиПрерыванияПользователем, 0.1, Истина);
	
	ИнтервалОбновления = 0.5;
	ПоказываетсяПрогресс = Ложь;
	
	СостояниеОбработки = ИТК_ОбработкаОбъектовКлиент.СостояниеОбработки(ЭтотОбъект);
	Пока СостояниеОбработки.Обработано < СостояниеОбработки.Обрабатывается  Цикл 
		
		// Подготавливаем пакет обрабатываемых строк
		ПакетСтрок = Новый Массив;
		Для ИндексСтроки = ИндексНачалаПакета По (ИндексНачалаПакета + КоличествоСтрокВПакете - 1) Цикл
			
			Если ОбрабатываемыеСтроки = Неопределено Тогда
				ПакетСтрок.Добавить(ИндексСтроки);
			Иначе
				ПакетСтрок.Добавить(ОбрабатываемыеСтроки[ИндексСтроки]);
			КонецЕсли;
			
		КонецЦикла;
		
		// Обрабатываем
		РезультатОбработки = ОбработатьОбновитьРезультатСервер(ОписаниеАлгоритма, АдресЗначенийПараметров, АдресДанных, ПакетСтрок, ДополнительныеСвойства);
		ВремяОбработки = ИТК_ОбщийКлиентСервер.МиллисекВСек(РезультатОбработки.ВремяОбработки);
		
		ИТК_ОбработкаОбъектовКлиент.ПоказатьПрогрессНаФорме(ЭтотОбъект, ПоказываетсяПрогресс);
		ОбработатьСообщенияПрогресса(РезультатОбработки.Сообщения);
		СостояниеОбработки = ИТК_ОбработкаОбъектовКлиент.СостояниеОбработки(ЭтотОбъект);
		
		Если ОписаниеАлгоритма.ПрерыватьПриОшибке 
				И СостояниеОбработки.Ошибок > 0 Тогда
			Прервать;
		КонецЕсли;
		
		ИТК_ОбработкаОбъектовКлиент.ЗаполняемДанныеСледующегоПакета(СостояниеОбработки.Обрабатывается, ВремяОбработки, ИндексНачалаПакета, КоличествоСтрокВПакете, ИнтервалОбновления);
		ОбработкаПрерыванияПользователя();
		
	КонецЦикла;
	
	// Код после (завершения)
	Если ЗначениеЗаполнено(ОписаниеАлгоритма.КодПосле) Тогда
		ВыполнениеОбработкиПосле(АдресЗначенийПараметров, ОписаниеАлгоритма.КодПосле, ДополнительныеСвойства);
	КонецЕсли;

	ОтключитьОбработчикОжидания(ИмяПроцедурыОбработкиПрерыванияПользователем);
	
КонецПроцедуры

&НаСервере
Функция ОбработатьОбновитьРезультатСервер(ОписаниеАлгоритма, АдресЗначенийПараметров, АдресДанных, ПакетСтрок, ДополнительныеСвойства)
	
	НачалоОбработки = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("АдресДанных", АдресДанных);
	ПараметрыПроцедуры.Вставить("ОбрабатываемыеДанные", ПолучитьИзВременногоХранилища(АдресДанных));
	ПараметрыПроцедуры.Вставить("ОписаниеАлгоритма", ОписаниеАлгоритма);
	ПараметрыПроцедуры.Вставить("ЗначенияПараметров", ПолучитьИзВременногоХранилища(АдресЗначенийПараметров));
	ПараметрыПроцедуры.Вставить("ОбрабатываемыеСтроки", ПакетСтрок);
	ПараметрыПроцедуры.Вставить("ДополнительныеСвойства", ДополнительныеСвойства);
	ПараметрыПроцедуры.Вставить("АдресРезультатов", ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаРезультатов()]);
	ИТК_ОбработкаРезультата.Обработать(ПараметрыПроцедуры);
	
	Возврат ИТК_ОбработкаОбъектов.ВернутьРезультат(НачалоОбработки);
	
КонецФункции

&НаСервере
Функция ИнициализацияПередОбработкой(АдресОбрабатываемыхДанных, Код, ДополнительныеСвойства)
	
	АдресЖурнала = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаЖурналаРезультата()];
	АдресРезультатов = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаРезультатов()];
	ПоследниеСообщения = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторСообщенияОбработкиПоследнегоОбъекта()];
	ИндексПоследнегоОбрабатываемогоОбъекта = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторИндексПоследнегоОбрабатываемогоОбъекта()];
	
	Возврат ИТК_ОбработкаОбъектов.ИнициализацияПередОбработкой(АдресОбрабатываемыхДанных, АдресЖурнала, АдресРезультатов, ПоследниеСообщения, ИндексПоследнегоОбрабатываемогоОбъекта, Данные, Код, УникальныйИдентификатор, ДополнительныеСвойства);
	
КонецФункции

&НаСервере
Процедура ВыполнениеОбработкиПосле(АдресЗначенийПараметров, Код, ДополнительныеСвойства)
	
	АдресЖурнала = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаЖурналаРезультата()];
	АдресРезультатов = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаРезультатов()];
	ПоследниеСообщения = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторСообщенияОбработкиПоследнегоОбъекта()];
	ИндексПоследнегоОбрабатываемогоОбъекта = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторИндексПоследнегоОбрабатываемогоОбъекта()];
	
	ИТК_ОбработкаОбъектов.ВыполнениеОбработкиПосле(АдресЖурнала, АдресРезультатов, ПоследниеСообщения, ИндексПоследнегоОбрабатываемогоОбъекта, АдресЗначенийПараметров, Код, ДополнительныеСвойства);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаПрогрессаВыполнения(Результат, ДополнительныеПараметры) Экспорт
	
	ИТК_ДлительныеОперацииКлиент.ПодготовитьПрогрессВыполнения(Результат);
	
	ОбработатьСообщенияПрогресса(Результат.Сообщения);
	ИТК_ДлительныеОперацииКлиент.ПоказатьПрогресс(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСообщенияПрогресса(Сообщения)
	
	Результат = ОбработатьСообщенияПрогрессаСервер(Сообщения);
	
	СостояниеОбработки = ИТК_ОбработкаОбъектовКлиент.СостояниеОбработки(ЭтотОбъект);
	СостояниеОбработки.Ошибок = СостояниеОбработки.Ошибок + Результат.Ошибок;
	СостояниеОбработки.Обработано = СостояниеОбработки.Обработано + Результат.Обработано;
	
	ФоновоеВыполнение = ИТК_БСПКлиентСервер.ВозможноВыполнениеВФоне();
	ИТК_ОбработкаОбъектовКлиент.ОбновитьПрогресс(ЭтотОбъект, ФоновоеВыполнение);
	
КонецПроцедуры

&НаСервере
Функция ОбработатьСообщенияПрогрессаСервер(Сообщения)
	
	АдресДанных = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаДанных()];
	АдресЖурнала = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаЖурналаРезультата()];
	АдресРезультатов = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторАдресаРезультатов()];
	ПоследниеСообщения = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторСообщенияОбработкиПоследнегоОбъекта()];
	ИндексПоследнегоОбрабатываемогоОбъекта = ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторИндексПоследнегоОбрабатываемогоОбъекта()];
	
	Результат = ИТК_ОбработкаОбъектов.ОбработатьСообщенияПрогресса(АдресЖурнала, АдресРезультатов, ПоследниеСообщения, ИндексПоследнегоОбрабатываемогоОбъекта, Сообщения, АдресДанных);
	ЭтотОбъект[ИТК_ОбработкаОбъектовКлиентСервер.ИдентификаторИндексПоследнегоОбрабатываемогоОбъекта()] = ИндексПоследнегоОбрабатываемогоОбъекта;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ЗавершенаОбработкаДанных(Результат = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт

	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	
	Если ЗначениеЗаполнено(Результат) Тогда
		
		ОбработатьСообщенияПрогресса(Результат.Сообщения);
		
	КонецЕсли;
	
	Элементы.ФормаГруппаОбработать.Доступность = Истина;
	
	ИТК_ДлительныеОперацииКлиент.СкрытьПрогресс(ЭтотОбъект);
	ИТК_ОбработкаОбъектовКлиент.ПоказатьИнформациюОПоследнейОбработке(ЭтотОбъект);
	
	ТекущийЭлемент = Элементы.СтраницаРезультат;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершенаРасшифровкаРезультата(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЭлементТекст = ЭлементКод(ДополнительныеПараметры.Индекс);
	ЭлементТекст.УстановитьГраницыВыделения(Результат.НомерСтроки, Результат.НомерСтолбца, Результат.НомерСтроки, Результат.НомерСтолбца);
	ТекущийЭлемент = ЭлементТекст;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДанныеСтроки(АдресДанных, ИндексОбъекта)
	
	ОбрабатываемыеДанные = ПолучитьИзВременногоХранилища(АдресДанных);
	Строка = ОбрабатываемыеДанные[ИндексОбъекта];
	
	Результат = Новый Структура;
	Для Каждого Колонка Из ОбрабатываемыеДанные.Колонки Цикл 
		
		Результат.Вставить(Колонка.Имя, Строка[Колонка.Имя]);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ЭлементКод(Индекс)
	
	Если Индекс = ИТК_ОбработкаРезультатаКлиентСервер.НомерСтрокиКодПеред() Тогда
		
		Результат = Элементы.КодПеред;
		
	ИначеЕсли Индекс = ИТК_ОбработкаРезультатаКлиентСервер.НомерСтрокиКодПосле() Тогда
		
		Результат = Элементы.КодПосле;
		
	Иначе
		
		Результат = Элементы.Код;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ОбработкаКодПриИзменении(Результат, ДополнительныеПараметры) Экспорт
	
	Элемент = ТекущийЭлемент;
	
	ИмяПоля = Элемент.Имя;
	Текст = ИТК_РедакторКодаКлиент.Текст(ЭтотОбъект, ИмяПоля);
	ИзменитьОписаниеТекущегоАлгоритма(Новый Структура(ИмяПоля, Текст));
	
	ЭлементАлгоритм = ИТК_ОбщийКлиентСервер.СписокЗначенийНайтиПоПредставлению(Алгоритмы, Алгоритм);
	ОбновитьЗаголовокСтраницыКод(ИмяПоля, ЭлементАлгоритм.Значение);
	
КонецПроцедуры

#КонецОбласти
