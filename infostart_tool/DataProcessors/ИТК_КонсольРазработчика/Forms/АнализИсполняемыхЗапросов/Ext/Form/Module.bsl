#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИТК_ФормаКлиентСервер.Заголовок(ЭтотОбъект, НСтр("ru = 'Анализ исполняемых СКД запросов';
													|en = 'Analysis of executable DCS requests'"));
	
	УстановитьУсловноеОформление();
	
	ИсполняемыеЗапросы = ПолучитьИзВременногоХранилища(Параметры.Адрес);
	ИнициализироватьДерево(НаборыДанных, ИсполняемыеЗапросы.НаборыДанных);
	
	// Заполнение параметров
	ЗаполнитьЗначенияПараметров(ИсполняемыеЗапросы);
	
	КоличествоПараметров = ЗначенияПараметров.Количество();
	Если Не ЗначениеЗаполнено(ЗначенияПараметров) Тогда
		ИТК_ФормаКлиентСервер.СкрытьГруппу(Элементы.ГруппаПараметры);
	КонецЕсли;
	
	// Заполнение связей наборов данных
	Для Каждого ОписаниеСвязиНабора Из ИсполняемыеЗапросы.СвязиНаборов Цикл 
		
		НоваяСтрока = СвязиНаборовДанных.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ОписаниеСвязиНабора);
		
	КонецЦикла;
	
	КоличествоСвязейНаборовДанных = СвязиНаборовДанных.Количество();
	
	ИТК_ФормаКлиентСервер.СкрытьГруппу(Элементы.ГруппаСвязиНаборов);
	
	// Инициализация элемента текст запроса
	ДополнительныеСвойства = Новый Структура;
	ДополнительныеСвойства.Вставить("ТолькоПросмотр", Истина);
	ДополнительныеСвойства.Вставить("ТипЯзыка", ИТК_Перечисления.ТипЯзыкаРедактораЗапросы());
	ИТК_РедакторКода.Инициализация(ЭтотОбъект, "Текст", ДополнительныеСвойства);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИТК_РедакторКодаКлиент.Инициализация(ЭтотОбъект, "Текст");

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	ИТК_РедакторКодаКлиент.ОбработкаОповещения(ЭтотОбъект, ИмяСобытия, Параметр, Источник);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыЗапросы

&НаКлиенте
Процедура ЗапросыПриАктивизацииСтроки(Элемент)
	
	ОбновитьЭлементыУправления();
	
КонецПроцедуры

&НаКлиенте
Процедура ИТК_ПодключаемыйДокументСформирован(Элемент)
	
	ИТК_РедакторКодаКлиент.ДополнительнаяИнициализация(ЭтотОбъект, Элемент);
	ОбновитьЭлементыУправления();
	
КонецПроцедуры

&НаКлиенте
Процедура ИТК_ПодключаемыйПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	ИТК_РедакторКодаКлиент.ОбработкаСобытий(ЭтотОбъект, Элемент, ДанныеСобытия, СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СравнитьСИсходнымТекстом(Команда)
	
	ТекущиеДанные = Элементы.НаборыДанных.ТекущиеДанные;
	ИТК_ФормаКлиент.ОткрытьСравнениеТекстов(ЭтотОбъект, ТекущиеДанные.ИсходныйТекст, ТекущиеДанные.Текст, ИТК_Перечисления.ТипЯзыкаРедактораЗапросы());

КонецПроцедуры

&НаКлиенте
Процедура АнализироватьЗапрос(Команда)
	
	ТекущиеДанные = Элементы.НаборыДанных.ТекущиеДанные;
	
	Результат = Новый Структура;
	Результат.Вставить("Имя", ТекущиеДанные.Имя);
	Результат.Вставить("Текст", ТекущиеДанные.Текст);
	Результат.Вставить("ЗначенияПараметров", ПодготовитьЗначенияПараметров());
	
	Закрыть(Результат);
	
КонецПроцедуры

#Область ПодключаемыеКоманды

&НаКлиенте
Процедура ИТК_ПодключаемаяКомандаРедакторКодаОбработчик(Команда)
	
	ИТК_РедакторКодаКлиент.ПодключаемыйОбработчикКоманд(ЭтотОбъект, Команда.Имя);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	Условия = Новый Массив;
	Условия.Добавить(Новый Структура("Поле, Значение", "НаборыДанных.Текст", ""));
	Условия.Добавить(Новый Структура("Поле, Значение", "НаборыДанных.Тип", ИТК_Перечисления.СКДНаборДанныхЗапрос()));

	ИТК_Форма.ДобавитьУсловноеОформлениеГруппой(УсловноеОформление, "НаборыДанныхИмя", Новый Структура("Шрифт", ИТК_ОбщийКлиентСервер.ШрифтЗачеркнутый120()), Условия);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЗначенияПараметров(ИсполняемыеЗапросы)

	// Заполнение параметров
	Для Каждого ОписаниеЗначения Из ИсполняемыеЗапросы.ЗначенияПараметров Цикл 
		
		Значение = ОписаниеЗначения.Значение;
		ТипЗначения = ТипЗнч(Значение);
		
		НоваяСтрока = ЗначенияПараметров.Добавить();
		НоваяСтрока.Имя = ОписаниеЗначения.Ключ;
		НоваяСтрока.Картинка = ИТК_Типы.Картинка(ТипЗначения);
		
		// Значение типа массив не может храниться в форме, преобразуем в список
		Если ТипЗначения = Тип("Массив") Тогда
			Значение = ИТК_ОбщийКлиентСервер.МассивВСписокЗначений(Значение);
		КонецЕсли;
		НоваяСтрока.Значение = Значение;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЭлементыУправления()
	
	ТекущиеДанные = Элементы.НаборыДанных.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НаборДанныхЗапрос = (ТекущиеДанные.Тип = ИТК_Перечисления.СКДНаборДанныхЗапрос());
	
	ТекстыИдентичны = (ТекущиеДанные.Текст = ТекущиеДанные.ИсходныйТекст);
	Элементы.СравнитьСИсходнымТекстом.Видимость = НаборДанныхЗапрос И НЕ ТекстыИдентичны;
	Элементы.ГруппаЗапросыИдентичны.Видимость = НаборДанныхЗапрос И ТекстыИдентичны;
	Элементы.ДобавитьЗапросВДанные.Видимость = НаборДанныхЗапрос И ЗначениеЗаполнено(ТекущиеДанные.Текст);
	
	ИТК_РедакторКодаКлиент.УстановитьТекст(ЭтотОбъект, Элементы["Текст"], ТекущиеДанные.Текст);
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьДерево(Приемник, Источник)
	
	Для Каждого Строка Из Источник.Строки Цикл 
		
		НоваяСтрока = Приемник.ПолучитьЭлементы().Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
		
		НоваяСтрока.Картинка = ИТК_КонструкторСКДКлиентСервер.КартинкаНабораДанных(Строка.Тип);
		
		ИнициализироватьДерево(НоваяСтрока, Строка);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Функция ПодготовитьЗначенияПараметров()
	
	Результат = Новый Соответствие;
	
	Для Каждого ЗначениеПараметра Из ЗначенияПараметров Цикл 
		
		Результат.Вставить(ЗначениеПараметра.Имя, ЗначениеПараметра.Значение);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти