#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Инициализация элемента код
	ДополнительныеСвойства = Новый Структура;
	ДополнительныеСвойства.Вставить("ТолькоПросмотр", Истина);
	ИТК_РедакторКода.Инициализация(ЭтотОбъект, "Код", ДополнительныеСвойства);
	
	Данные = Параметры.Данные;
	Тип = Параметры.Тип;
	
	ЭтоЗапрос = (Параметры.Тип = ИТК_Перечисления.ЭлементДанныхЗапрос());
	ЭтоСхемаКомпоновкиДанных = (Параметры.Тип = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных());
	
	Язык = ИТК_Общий.КодЯзыкаПрограммирования();
	ИТК_Форма.ЗаполнитьСписокВыбораЯзыкПрограммирования(Элементы.Язык);
	
	ИТК_Перечисления.ЗаполнитьСписок(Элементы.ВыводРезультатаВ, ИТК_Перечисления.ВариантыВыводаРезультатаСКД());
	
	Если ЭтоЗапрос Тогда
		
		ТекстЗапроса = Данные.Текст;
		ДобавлятьКомментарии = Истина;
		ИмяФункции = НСтр("ru = 'ВыполнитьЗапрос';
							|en = 'ExecuteQuery'", Язык);
		
		СхемаЗапроса = Новый СхемаЗапроса;
		СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
		
		КоличествоЗапросов = ИТК_Запрос.КоличествоВПакете(СхемаЗапроса);
		КоличествоЗапросовСВременнымиТаблицами = ИТК_Запрос.КоличествоВПакете(СхемаЗапроса, , Ложь);
		КоличествоЗапросовСРезультатом = ИТК_Запрос.КоличествоВПакете(СхемаЗапроса, Ложь);
		ПрисутствуютЗапросыСозданияВременнойТаблицы = (КоличествоЗапросовСВременнымиТаблицами > 0);
		
		Выборка = Истина;
		ИспользуютсяИтоги = (КоличествоЗапросовСРезультатом = 1) И ИТК_Запрос.ИспользуютсяИтоги(СхемаЗапроса);
		ВыборкаПоГруппировкам = ИспользуютсяИтоги;
		
		// Параметры
		НайденныеПараметры = ИТК_Запрос.НайтиПараметры(ТекстЗапроса);
		СуществуютПараметры = ЗначениеЗаполнено(НайденныеПараметры);
		ПараметрыЗапроса = СуществуютПараметры;
		Элементы.ПараметрыЗапроса.Доступность = СуществуютПараметры;
		
		// Менеджер временных таблиц
		МенеджерВременныхТаблиц = ПрисутствуютЗапросыСозданияВременнойТаблицы;
		МенеджерВременныхТаблицДоступен = ПрисутствуютЗапросыСозданияВременнойТаблицы И (КоличествоЗапросов <> КоличествоЗапросовСВременнымиТаблицами);
		Элементы.МенеджерВременныхТаблиц.Доступность = МенеджерВременныхТаблицДоступен;
		
		ИТК_Перечисления.ЗаполнитьСписок(Элементы.ВидРезультата, ИТК_Перечисления.ВидыРезультатаЗапроса(), КоличествоЗапросов);
		Элементы.ВидРезультата.Видимость = Элементы.ВидРезультата.СписокВыбора.Количество() > 1;
		ВидРезультата = ИТК_Перечисления.ВидРезультатаЗапросаЗапрос();
		
	ИначеЕсли ЭтоСхемаКомпоновкиДанных Тогда
		
		ИспользуетсяВОтчете = Истина;
		ВыводРезультатаВ = ИТК_Перечисления.ВариантВыводаРезультатаСКДТабличныйДокумент();
		
	КонецЕсли;
	
	Элементы.ГруппаЗапрос.Видимость = ЭтоЗапрос;
	Элементы.ГруппаСхемаКомпоновкиДанных.Видимость = ЭтоСхемаКомпоновкиДанных;
	
	Если ЭтоСхемаКомпоновкиДанных Тогда
		Элементы.Страницы.ОтображениеСтраниц = ОтображениеСтраницФормы.Нет;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИТК_РедакторКодаКлиент.Инициализация(ЭтотОбъект, "Код");
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	ИТК_РедакторКодаКлиент.ОбработкаОповещения(ЭтотОбъект, ИмяСобытия, Параметр, Источник);
	
КонецПроцедуры

#КонецОбласти

