#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	ЭтоЗапрос = (Тип = ИТК_Перечисления.ЭлементДанныхЗапрос()
							И Элементы.Страницы.ТекущаяСтраница = Элементы.ГруппаЗапрос);
	ЭтоСхемаЗапроса = (Тип = ИТК_Перечисления.ЭлементДанныхЗапрос()
							И Элементы.Страницы.ТекущаяСтраница = Элементы.ГруппаСхемаЗапроса);
	ЭтоСхемаКомпоновкиДанных = (Тип = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных());
	
	РезультатКод = "";
	Если ЭтоЗапрос Тогда
		
		ДополнениеЗаголовка = НСтр("ru = 'Запрос';
									|en = 'Query'");
		
		ВидРезультатаЗапрос = (ВидРезультата = ИТК_Перечисления.ВидРезультатаЗапросаЗапрос());
		Элементы.ПроверкаРезультата.Доступность = ВидРезультатаЗапрос;
		Элементы.Выборка.Доступность = ВидРезультатаЗапрос;
		Элементы.ВыборкаПоГруппировкам.Доступность = ВидРезультатаЗапрос И ИспользуютсяИтоги;
		Элементы.ИмяФункции.ПоложениеЗаголовка = ИТК_ОбщийКлиентСервер.ПоложениеЗаголовкаАвтоВверхПоДлине(ИмяФункции, 25);
		
		Настройки = Новый Структура;
		Настройки.Вставить("ДобавлятьКомментарии", ДобавлятьКомментарии);
		Настройки.Вставить("МенеджерВременныхТаблиц", МенеджерВременныхТаблиц);
		Настройки.Вставить("Параметры", ПараметрыЗапроса);
		Настройки.Вставить("ВидРезультата", ВидРезультата);
		Настройки.Вставить("ПроверкаРезультата", ПроверкаРезультата);
		Настройки.Вставить("ВключитьВФункцию", ВключитьВФункцию);
		Настройки.Вставить("ИмяФункции", ИмяФункции);
		Настройки.Вставить("Выборка", Выборка);
		Настройки.Вставить("ВыборкаПоГруппировкам", ВыборкаПоГруппировкам);
		Настройки.Вставить("Язык", Язык);
		
		РезультатКод = ИТК_Код.Запрос(Данные, Настройки);
		
	ИначеЕсли ЭтоСхемаКомпоновкиДанных Тогда
		
		ДополнениеЗаголовка = НСтр("ru = 'Схема компоновки данных';
									|en = 'Data composition schema'");
		
		Настройки = Новый Структура;
		Настройки.Вставить("ДобавлятьКомментарии", ДобавлятьКомментарии);
		Настройки.Вставить("ИспользуетсяВОтчете", ИспользуетсяВОтчете);
		Настройки.Вставить("ВыводРезультатаВ", ВыводРезультатаВ);
		Настройки.Вставить("Язык", Язык);
		
		РезультатКод = ИТК_Код.СхемаКомпоновкиДанных(Данные, Настройки);
		
	ИначеЕсли ЭтоСхемаЗапроса Тогда
		
		ДополнениеЗаголовка = НСтр("ru = 'Схема запроса';
									|en = 'Query schema'");
		
		Настройки = Новый Структура;
		Настройки.Вставить("Язык", Язык);
		Настройки.Вставить("ДобавлятьКомментарии", ДобавлятьКомментарии);
		Настройки.Вставить("ДобавлятьЗначенияСвойствПоУмолчанию", ДобавлятьЗначенияСвойствПоУмолчанию);
		
		РезультатКод = ИТК_Код.СхемаЗапроса(Данные, Настройки);
		
	КонецЕсли;
	
	ИТК_РедакторКодаКлиент.УстановитьТекст(ЭтотОбъект, Элементы["Код"], РезультатКод);
	
	ИТК_ФормаКлиентСервер.Заголовок(ЭтотОбъект, СтрШаблон(НСтр("ru = 'Код на встроенном языке (%1)';
																|en = 'Code in the built-in language (%1)'"), ДополнениеЗаголовка));

КонецПроцедуры

&НаКлиенте
Процедура ВводИмениФункцииЗавершен(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ИмяФункции = Результат;
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти
