#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИТК_ФормаКлиентСервер.Заголовок(ЭтотОбъект, НСтр("ru = 'Вставка предопределенного в текст запроса';
													|en = 'Insert predefined in query text'"));
	
	Язык = ИТК_Общий.КодЯзыкаПрограммирования();
	
	СписокВыбораВид = Элементы.Вид.СписокВыбора;
	СписокВыбораВид.Добавить("", "<...>");
	СписокВыбораВид.Добавить(ВидЗначение(), НСтр("ru = 'ЗНАЧЕНИЕ(<?>)';
												|en = 'VALUE(<?>)'"));
	СписокВыбораВид.Добавить(ВидСсылка(), НСтр("ru = 'ССЫЛКА <?>';
												|en = 'REF <?>'"));
	
	Вид = ВидЗначение();
	
	ИТК_Форма.ОбновитьСписокВыбораТипОбъекта(Элементы.ТипОбъекта, Язык);
	СписокВыбора = Элементы.ТипОбъекта.СписокВыбора;
	СписокВыбора.Добавить(ИдентификаторКоллекцииПрочие(), НСтр("ru = 'Прочие';
																|en = 'Other'"));
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновитьЭлементыУправления();
	ОбновитьРезультат();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ТипОбъектаПриИзменении(Элемент)
	
	ПроверитьДоступностьВыбранногоВида();
	
	ИмяОбъекта = "";
	ИмяПредопределенного = "";
	
	ОбновитьСписокВыбораИмяОбъекта();
	ОбновитьЭлементыУправления();
	ОбновитьРезультат();
	
КонецПроцедуры

&НаКлиенте
Процедура ТипОбъектаАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)

	ИТК_ФормаКлиент.ПоискПоСпискуВыбора(Элемент, Текст, ДанныеВыбора, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ИмяОбъектаПриИзменении(Элемент)
	
	СписокВыбора = Элементы.ИмяПредопределенного.СписокВыбора;
	СписокВыбора.Очистить();
	
	Если ТипОбъекта = ИдентификаторКоллекцииПрочие() Тогда
		
		Если ИмяОбъекта = ИТК_КодКлиентСервер.ИмяОбъектаВидДвиженияБухгалтерии(Язык) Тогда
			
			СписокВыбора.Добавить(НСтр("ru = 'Дебет';
										|en = 'Debit'", Язык));
			СписокВыбора.Добавить(НСтр("ru = 'Кредит';
										|en = 'Credit'", Язык));
			
		ИначеЕсли ИмяОбъекта = ИТК_КодКлиентСервер.ИмяОбъектаВидДвиженияНакопления(Язык) Тогда
			
			СписокВыбора.Добавить(НСтр("ru = 'Приход';
										|en = 'Receipt'", Язык));
			СписокВыбора.Добавить(НСтр("ru = 'Расход';
										|en = 'Expense'", Язык));
			
		ИначеЕсли ИмяОбъекта = ИТК_КодКлиентСервер.ИмяОбъектаВидСчета(Язык) Тогда
			
			СписокВыбора.Добавить(НСтр("ru = 'АктивноПассивный';
										|en = 'ActivePassive'", Язык));
			СписокВыбора.Добавить(НСтр("ru = 'Активный';
										|en = 'Active'", Язык));
			СписокВыбора.Добавить(НСтр("ru = 'Пассивный';
										|en = 'Passiv'", Язык));
			
		КонецЕсли;
		
		ИмяПредопределенного = СписокВыбора[0];
		
	ИначеЕсли ИТК_МетаданныеКлиентСерверПовтИсп.ОбъектCПредопределенными(ТипОбъекта) Тогда
		
		ИмяПредопределенного = "";
		ОбновитьСписокВыбораПредопределенные();
		
	КонецЕсли;
	
	ОбновитьЭлементыУправления();
	ОбновитьРезультат();

КонецПроцедуры

&НаКлиенте
Процедура ИмяОбъектаАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	ИТК_ФормаКлиент.ПоискПоСпискуВыбора(Элемент, Текст, ДанныеВыбора, СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура ИмяПредопределенногоПриИзменении(Элемент)
	
	ОбновитьРезультат();

КонецПроцедуры

&НаКлиенте
Процедура ИмяПредопределенногоАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.ПоискПоСпискуВыбора(Элемент, Текст, ДанныеВыбора, СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаОК(Команда)
	
	Закрыть (Результат);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьЭлементыУправления()
	
	ЭтоКоллекцияПрочие = (ТипОбъекта = ИдентификаторКоллекцииПрочие());
	
	Элементы.ИмяОбъекта.Доступность = ЗначениеЗаполнено(ТипОбъекта);
	Элементы.ИмяОбъекта.АвтоОтметкаНезаполненного = ЭтоКоллекцияПрочие;
	Элементы.ИмяПредопределенного.Доступность = ЗначениеЗаполнено(ИмяОбъекта)
													И Вид = ВидЗначение() 
													И (ИТК_МетаданныеКлиентСерверПовтИсп.ОбъектCПредопределенными(ТипОбъекта)
														ИЛИ ЭтоКоллекцияПрочие);
	Элементы.ИмяПредопределенного.КнопкаОчистки = Не ЭтоКоллекцияПрочие;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСписокВыбораИмяОбъекта()
	
	СписокВыбора = Элементы.ИмяОбъекта.СписокВыбора;
	СписокВыбора.Очистить();
	
	Если ТипОбъекта = ИдентификаторКоллекцииПрочие() Тогда
		
		СписокВыбора.Добавить(ИТК_КодКлиентСервер.ИмяОбъектаВидДвиженияНакопления(Язык), , , БиблиотекаКартинок.ИТК_ТипВидДвиженияНакопления); 
		СписокВыбора.Добавить(ИТК_КодКлиентСервер.ИмяОбъектаВидДвиженияБухгалтерии(Язык), , , БиблиотекаКартинок.ИТК_ТипВидДвиженияБухгалтерии); 
		СписокВыбора.Добавить(ИТК_КодКлиентСервер.ИмяОбъектаВидСчета(Язык), , , БиблиотекаКартинок.ИТК_ТипВидСчета); 
		
	ИначеЕсли ЗначениеЗаполнено(ТипОбъекта) Тогда
		
		ИмяКоллекции = ИТК_МетаданныеКлиентСерверПовтИсп.ИмяКоллекции(ТипОбъекта, Язык);
		КоллекцияОбъектов = ИТК_МетаданныеПовтИсп.КоллекцияМетаданныхПоИмени(ИмяКоллекции);
		
		Для Каждого ОбъектМетаданных Из КоллекцияОбъектов Цикл 
			
			СписокВыбора.Добавить(ОбъектМетаданных.Имя);
			
		КонецЦикла;
		
	КонецЕсли;
	
	СписокВыбора.СортироватьПоЗначению();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСписокВыбораПредопределенные()
	
	СписокВыбора = Элементы.ИмяПредопределенного.СписокВыбора;
	СписокВыбора.Очистить();
	
	Если Не ЗначениеЗаполнено(ИмяОбъекта) Тогда
		Возврат;
	КонецЕсли;
	
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоТочкаМаршрутаБизнесПроцесса(ТипОбъекта) Тогда
		
		Для Каждого ТочкаМаршрута Из БизнесПроцессы[ИмяОбъекта].ТочкиМаршрута Цикл 
			СписокВыбора.Добавить(ТочкаМаршрута.Имя);
		КонецЦикла;
		
	Иначе
		
		ИмяКоллекции = ИТК_Метаданные.ИмяКоллекции(ТипОбъекта);
		ОбъектМетаданных = Метаданные[ИмяКоллекции][ИмяОбъекта];
		
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПеречисление(ТипОбъекта) Тогда
			
			Для Каждого ОбъектМетаданныхЗначениеПеречисления Из ОбъектМетаданных.ЗначенияПеречисления Цикл 
				СписокВыбора.Добавить(ОбъектМетаданныхЗначениеПеречисления.Имя);
			КонецЦикла;
			СписокВыбора.СортироватьПоЗначению();
			
		Иначе
			
			Предопределенные = ИТК_Метаданные.СписокПредопределенных(ОбъектМетаданных);
			Для Каждого ОписаниеПредопределенного Из Предопределенные Цикл
					
				СписокВыбора.Добавить(ОписаниеПредопределенного.Значение, ОписаниеПредопределенного.Представление);
					
			КонецЦикла;
			
		КонецЕсли;
	
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьРезультат()

	ЧастиСтроки = Новый Массив;
	
	// Коллекция
	Если ТипОбъекта = ИдентификаторКоллекцииПрочие() Тогда
		ИмяКоллекции = "";
	Иначе
		ИмяКоллекции = ТипОбъекта;
	КонецЕсли;
	ЧастиСтроки.Добавить(ИмяКоллекции);
	
	// Имя объекта
	Если ЗначениеЗаполнено(ИмяОбъекта) Тогда
		
		Если ЗначениеЗаполнено(ИмяКоллекции) Тогда
			ЧастиСтроки.Добавить(".");
		КонецЕсли;
		
		ЧастиСтроки.Добавить(ИмяОбъекта);
		
	КонецЕсли;
	
	// Имя предопределенного
	Если (Вид = ВидЗначение()) Тогда
		
		Если ЗначениеЗаполнено(ИмяПредопределенного) Тогда
			
			ЧастиСтроки.Добавить(".");
			ЧастиСтроки.Добавить(ИмяПредопределенного);
			
		Иначе
			
			Если ЗначениеЗаполнено(ИмяОбъекта) Тогда
				ЧастиСтроки.Добавить(НСтр("ru = '.ПустаяСсылка';
											|en = '.EmptyRef'", Язык));
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	// Окончательный результат
	Результат = СтрСоединить(ЧастиСтроки, "");
	Если (Вид = ВидЗначение()) Тогда
		
		Результат = СтрШаблон(НСтр("ru = 'ЗНАЧЕНИЕ(%1)';
									|en = 'VALUE(%1)'", Язык), СтрСоединить(ЧастиСтроки, ""));
		
	ИначеЕсли (Вид = ВидСсылка()) Тогда
		
		Результат = СтрШаблон(НСтр("ru = 'ССЫЛКА %1';
									|en = 'REF %1'", Язык), СтрСоединить(ЧастиСтроки, ""));
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВидПриИзменении(Элемент)
	
	ПроверитьДоступностьВыбранногоВида();
	
	ОбновитьЭлементыУправления();
	ОбновитьРезультат();
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьДоступностьВыбранногоВида()
	
	Если ТипОбъекта = ИдентификаторКоллекцииПрочие()
			И Вид <> ВидЗначение() Тогда
			
		Вид = ВидЗначение();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ВидСсылка()
	Возврат "ССЫЛКА";
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ВидЗначение()
	Возврат "ЗНАЧЕНИЕ";
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ИдентификаторКоллекцииПрочие()
	
	Возврат "Прочие";
	
КонецФункции

#КонецОбласти
