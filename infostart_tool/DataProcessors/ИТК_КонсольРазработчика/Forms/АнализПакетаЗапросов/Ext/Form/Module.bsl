#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ШаблонЗаголовка = НСтр("ru = 'Замер пакета запросов: %1'; en = 'Metering a batch of requests: %1'");
	Заголовок = СтрШаблон(ШаблонЗаголовка, Параметры.ДополнениеЗаголовка);
	
	Запросы = Новый Массив;
	Запросы.Добавить(Список.ТекстЗапроса);
	
	ДанныеЗамера = ПолучитьИзВременногоХранилища(Параметры.АдресДанных);
	НомерСтроки = 1;
	Для Каждого Строка Из ДанныеЗамера Цикл 
		
		Запросы.Добавить(СтрШаблон("ВЫБРАТЬ %1,%2,%3,%4,%5", ИТК_Код.Значение(НомерСтроки), ИТК_Код.Значение(Строка.Представление),
									ИТК_Код.Значение(Строка.КоличествоСтрок), ИТК_Код.Значение(Строка.Время), ИТК_Код.Значение(Строка.Доля)));

		НомерСтроки = НомерСтроки + 1;
		
	КонецЦикла;
	
	Элементы.СписокИмя.ТекстПодвала = СтрШаблон(НСтр("ru = 'Количество: %1';
													|en = 'Quantity: %1'"), ДанныеЗамера.Количество());
	Элементы.СписокВремя.ТекстПодвала = ДанныеЗамера.Итог("Время");
	
	УдалитьИзВременногоХранилища(Параметры.АдресДанных);
	Список.ТекстЗапроса = СтрСоединить(Запросы, " ОБЪЕДИНИТЬ ВСЕ ");
	
КонецПроцедуры

#КонецОбласти
