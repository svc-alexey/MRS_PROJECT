#Область ОписаниеПеременных

&НаКлиенте
Перем ИдентификаторПоследнейВыделеннойСтроки;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОтборПоМетаданным = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "ОтборМетаданных");
	УстановитьУсловноеОформление();
	ОбновитьПодписки();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИТК_ОбщийКлиент.ОбработчикПриОткрытии(Отказ);
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ОтборПоМетаданнымПредставлениеНажатие(Элемент, СтандартнаяОбработка)
	
	ДополнительныеПараметрыОповещения = Новый Структура;
	ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("НастройкаОтбораМетаданныхЗавершена", ЭтотОбъект, ДополнительныеПараметрыОповещения);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Исключаемые", "Подсистемы,ПараметрыСеанса");
	
	ИТК_ФормаКлиент.ОткрытьРедактированиеТипаЗначения(ЭтотОбъект, Неопределено, ИТК_Перечисления.РежимРедактированияТипаЗначенияОтборМетаданных(),
														ОтборПоМетаданным, ОписаниеОповещенияЗавершение, СтандартнаяОбработка, ДополнительныеПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборПоПодпискеПриИзменении(Элемент)
	
	ОбновитьПодпискиИЭлементы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОтключитьОтборПоМетаданным(Команда)
	
	ОтборПоМетаданным = "";
	ОбновитьПодпискиИЭлементы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьНовоеОкно(Команда)
	
	ИТК_ФормаКлиент.ОткрытьНовую(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПодписки

&НаКлиенте
Процедура ПодпискиПриАктивизацииСтроки(Элемент)
	
	ИдентификаторТекущейСтроки = Элемент.ТекущаяСтрока;
	Если ИдентификаторПоследнейВыделеннойСтроки = ИдентификаторТекущейСтроки Тогда 
		Возврат;
	КонецЕсли;
	ИдентификаторПоследнейВыделеннойСтроки = ИдентификаторТекущейСтроки;
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		
		// Сбросить все пометки
		ИТК_ФормаКлиент.ДеревоУстановитьПодчиненнымПометку(Подписки, Ложь);
		
		// Устанавливаем пометку текущей строки и подчиненным
		ТекущиеДанные.Пометка = Истина;
		ИТК_ФормаКлиент.ДеревоУстановитьПодчиненнымПометку(ТекущиеДанные, Истина);		
		
		// Устанавливаем пометку родителя
		Если ЗначениеЗаполнено(ТекущиеДанные.Обработчик) Тогда
			
			Родитель = ТекущиеДанные.ПолучитьРодителя();
			Родитель.Пометка = Истина;
			
		КонецЕсли;
		
	КонецЕсли;
	
	ОбновитьДанныеПодписок();
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПодпискиПередРазворачиванием(Элемент, Строка, Отказ)
	
	РазворачиваемаяСтрока = Подписки.НайтиПоИдентификатору(Строка);
	
	Если ИТК_ФормаКлиентСервер.НеобходимоРазвернутьСтроку(РазворачиваемаяСтрока) Тогда
		
		РазвернутьСтрокуСобытие(Строка);
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыОбработчики

&НаКлиенте
Процедура ОбработчикиВыбор(Элемент, ИдентификаторВыбраннойСтроки, Поле, СтандартнаяОбработка)

	ВыбраннаяСтрока = Обработчики.НайтиПоИдентификатору(ИдентификаторВыбраннойСтроки);
	СтрокаРодитель = ВыбраннаяСтрока.ПолучитьРодителя();
	Если СтрокаРодитель = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИТК_РедакторКодаКлиент.ОткрытьКодМодуля(СтрокаРодитель.Представление, ВыбраннаяСтрока.Представление);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ОбновитьПодписки()
	
	Подписки.ПолучитьЭлементы().Очистить();
	Источники.ПолучитьЭлементы().Очистить();
	Обработчики.ПолучитьЭлементы().Очистить();
	
	ДеревоПодписок = РеквизитФормыВЗначение("Подписки");
	
	События = Новый Соответствие;
	
	ПодпискиНаСобытия = ПодпискиНаСобытия();
	КоличествоПодписок = ПодпискиНаСобытия.Количество();
	Для Каждого ОписаниеПодписки Из ПодпискиНаСобытия Цикл 
		
		ИмяСобытия = ОписаниеПодписки.Событие;
		Количество = События.Получить(ИмяСобытия);
		
		Если Количество = Неопределено Тогда
			
			События.Вставить(ИмяСобытия, 1);
		Иначе 
			
			События.Вставить(ИмяСобытия, Количество + 1);
			
		КонецЕсли;

	КонецЦикла;
	
	Для Каждого Событие Из События Цикл 
		
		ИмяСобытия = Событие.Ключ;
		
		ПредставлениеСобытия = ИТК_ПодпискиНаСобытия.ПредставлениеСобытия(ИмяСобытия);
		Представление = ИТК_ФормаКлиентСервер.ЗаголовокСКоличеством(ПредставлениеСобытия, Событие.Значение);
		
		СтрокаСобытия = ДобавитьСтрокуВПодписки(ДеревоПодписок, ИмяСобытия, Представление);
		ДобавитьСтрокуВПодписки(СтрокаСобытия);
		
	КонецЦикла;
	
	ДеревоПодписок.Строки.Сортировать("Представление");
	ЗначениеВРеквизитФормы(ДеревоПодписок, "Подписки");
	
КонецПроцедуры

&НаСервере
Функция ДобавитьСтрокуВПодписки(Родитель, Имя = Неопределено, Представление = Неопределено, Поля = Неопределено)
	
	ЭтоКоллекцияФормы = (ТипЗнч(Родитель) = Тип("ДанныеФормыЭлементДерева"));
	
	Если ЭтоКоллекцияФормы Тогда
		Коллекция = Родитель.ПолучитьЭлементы();
	Иначе 
		Коллекция = Родитель.Строки;
	КонецЕсли;
	
	НоваяСтрока = Коллекция.Добавить();

	НоваяСтрока.Имя = Имя;
	НоваяСтрока.Представление = Представление;
	
	Если ТипЗнч(Родитель) <> Тип("ДеревоЗначений") Тогда
		НоваяСтрока.Пометка = Родитель.Пометка;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Поля) Тогда
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Поля);
	КонецЕсли;
	
	Возврат НоваяСтрока;
	
КонецФункции

&НаСервере
Процедура РазвернутьСтрокуСобытие(Идентификатор)
	
	РазворачиваемаяСтрока = Подписки.НайтиПоИдентификатору(Идентификатор);
	РазворачиваемаяСтрока.ПолучитьЭлементы().Очистить();
	
	ИмяСобытия = РазворачиваемаяСтрока.Имя;
	
	ПодпискиНаСобытия = ПодпискиНаСобытия(ИмяСобытия);
	Для Каждого ОписаниеПодписки Из ПодпискиНаСобытия Цикл 
		
		Поля = Новый Структура("Синоним, Комментарий, Обработчик");
		ЗаполнитьЗначенияСвойств(Поля, ОписаниеПодписки);
		Поля.Вставить("Картинка", БиблиотекаКартинок.ИТК_МетаданныеПодпискаНаСобытие);
		
		ДобавитьСтрокуВПодписки(РазворачиваемаяСтрока, ОписаниеПодписки.Имя, ОписаниеПодписки.Имя, Поля); 
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	ИТК_ДлительныеОперацииКлиент.ОбновитьЭлементыОтображенияСостояния(ДлительнаяОперация,
		Элементы.ГруппаДанныеПодписокРезультат, Элементы.ИдетПолучениеДанныхПодписокТабличныйДокумент,
		НСтр("ru = 'Получение данных подписок...';
			|en = 'Retrieving subscription data...'"));
	
	Элементы.ОтключитьОтборПоМетаданным.Видимость = ЗначениеЗаполнено(ОтборПоМетаданным);
	ОтборПоМетаданнымПредставление = ИТК_ФормаКлиентСервер.ПредставлениеСписка(ОтборПоМетаданным, 60);
	
	Шаблон = НСтр("ru = 'Всего подписок: %1';
					|en = 'Total subscriptions: %1'");
	Элементы.ПодпискиПредставление.ТекстПодвала = СтрШаблон(Шаблон, КоличествоПодписок);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанныеПодписок()
	
	ТекущиеДанные = Элементы.Подписки.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущиеДанные.Картинка = БиблиотекаКартинок.ИТК_МетаданныеПодпискаНаСобытие Тогда
		Событие = Неопределено;
		Подписка = ТекущиеДанные.Имя;
	Иначе
		Событие = ТекущиеДанные.Имя;
		Подписка = Неопределено;
	КонецЕсли;
	
	ПараметрыОперации = Новый Структура;
	ПараметрыОперации.Вставить("Событие", Событие);
	ПараметрыОперации.Вставить("Подписка", Подписка);
	ПараметрыОперации.Вставить("ОтборПоМетаданным", ОтборПоМетаданным);
	ПараметрыОперации.Вставить("ОтборПоПодписке", ОтборПоПодписке);
	
	ДлительнаяОперация = ДанныеПодписокНаСервере(ПараметрыОперации, УникальныйИдентификатор);
	
	ПараметрыОжидания = ИТК_ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершеноОбновлениеДанныхПодписок", ЭтотОбъект);
	ИТК_ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДанныеПодписокНаСервере(ПараметрыОперации, УникальныйИдентификатор)
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_ПодпискиНаСобытия.ДанныеПодписок", ПараметрыОперации, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ЗавершеноОбновлениеДанныхПодписок(Результат, ДополнительныеПараметры) Экспорт
	
	ДлительнаяОперация = Результат;
	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		ОбновитьДанныеПодписокСервер(Результат.АдресРезультата);
		ПодключитьОбработчикОжидания("ПодключаемыйРазвернутьДанныеПодписок", 0.1, Истина);
		
	КонецЕсли;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьДанныеПодписокСервер(АдресРезультата)
	
	Результат = ПолучитьИзВременногоХранилища(АдресРезультата);
	
	ЗначениеВРеквизитФормы(Результат.Обработчики, "Обработчики");
	ЗначениеВРеквизитФормы(Результат.Источники, "Источники");
	
	ИТК_ВременноеХранилище.Удалить(АдресРезультата);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйРазвернутьДанныеПодписок() Экспорт
	
	РазвернутьДеревоПодписок();
	РазвернутьДеревоИсточников();
	ИТК_ФормаКлиент.РазвернутьДерево(Элементы.Обработчики, Обработчики, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура РазвернутьДеревоПодписок()
	
	КоличествоРазворачиваемыхПодписок = 15;
	Если КоличествоПодписок <= КоличествоРазворачиваемыхПодписок Тогда
		
		ИТК_ФормаКлиент.РазвернутьДерево(Элементы.Подписки, Подписки, Истина);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РазвернутьДеревоИсточников()
	
	Если ЗначениеЗаполнено(ОтборПоМетаданным) Тогда
		
		Для Каждого Строка Из Источники.ПолучитьЭлементы() Цикл 
			
			Если Строка.Выделить Тогда 
				
				Элементы.Источники.Развернуть(Строка.ПолучитьИдентификатор());
				
			КонецЕсли;
			
		КонецЦикла;
		
	Иначе 
		
		ИТК_ФормаКлиент.РазвернутьДерево(Элементы.Источники, Источники, Истина);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "Подписки", Новый Структура("Шрифт", ИТК_ОбщийКлиентСервер.ШрифтЖирный()), "Подписки.Пометка", Истина);
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "Источники", Новый Структура("Шрифт", ИТК_ОбщийКлиентСервер.ШрифтЖирный()), "Источники.Выделить", Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаОтбораМетаданныхЗавершена(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОтборПоМетаданным = Результат;
	ОбновитьПодпискиИЭлементы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПодпискиИЭлементы()
	
	ОбновитьПодписки();
	
	// Активируем первую строку (при необходимости)
	ПодпискиСтроки = Подписки.ПолучитьЭлементы();
	Если ЗначениеЗаполнено(ПодпискиСтроки)
			И Элементы.Подписки.ТекущаяСтрока = Неопределено Тогда
			
		Элементы.Подписки.ТекущаяСтрока	= ПодпискиСтроки[0].ПолучитьИдентификатор();
			
	КонецЕсли;

	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаСервере
Функция ПодпискиНаСобытия(ИмяСобытия = Неопределено)
	
	Возврат ИТК_ПодпискиНаСобытия.Получить(ИмяСобытия, ОтборПоМетаданным, ОтборПоПодписке);
	
КонецФункции

#КонецОбласти