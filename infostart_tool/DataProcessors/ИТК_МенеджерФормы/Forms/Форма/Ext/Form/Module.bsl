#Область ОписаниеПеременных

&НаКлиенте
Перем ПоследнийАктивныйЭлемент Экспорт;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УстановитьУсловноеОформление();
	
	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.Свойства);
	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.Реквизиты);
	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.ЭлементыДерево);
	
	ИТК_ПодключаемыеКоманды.ИнструментыКТаблицеЗначений(ЭтотОбъект, "Реквизиты");
	
	СортироватьСвойстваПоАлфавиту = Ложь;
	УникальныйИдентификаторФормы = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "УникальныйИдентификаторФормы");
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновитьСписокДоступныхФорм();
	ПодключитьОбработчикОжидания("ПодключаемыйОбновитьСписокДоступныхФорм", 5);
	
	Если ЗначениеЗаполнено(УникальныйИдентификаторФормы) Тогда
		
		ВыбраннаяФорма = УникальныйИдентификаторФормы;
		ОбновитьВсеДанныеФормы();
		
		УникальныйИдентификаторФормы = Неопределено;
		
	КонецЕсли;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	ВосстановитьОформлениеАктивизированногоЭлемента();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВыбраннаяФормаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	ОбновитьСписокДоступныхФорм();
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбраннаяФормаПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	ОбновитьВсеДанныеФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыЭлементыДерево

&НаКлиенте
Процедура ЭлементыДеревоПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	АнализируемаяФорма = ВыбраннаяФорма();
	Если АнализируемаяФорма = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Элемент = НайтиЭлементНаВыбраннойФорме(ТекущиеДанные.Имя);
	Если Элемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВосстановитьОформлениеАктивизированногоЭлемента();
	
	НачальноеОформление = Новый Соответствие;
	Для Каждого Оформление Из ИТК_МенеджерФормКлиентСервер.ОформлениеАктивизированногоЭлемента(Элемент) Цикл 
		
		НачальноеОформление.Вставить(Оформление.Ключ, Элемент[Оформление.Ключ]);
		Элемент[Оформление.Ключ] = Оформление.Значение;
		
	КонецЦикла;
	
	ПоследнийАктивныйЭлемент = Новый Структура;
	ПоследнийАктивныйЭлемент.Вставить("Имя", ТекущиеДанные.Имя);
	ПоследнийАктивныйЭлемент.Вставить("НачальноеОформление", НачальноеОформление);
	
	АнализируемаяФорма.ТекущийЭлемент = Элемент;
	ПодключитьОбработчикОжидания("ПодключаемыйВосстановитьОформлениеАктивизированногоЭлемента", 5, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ЭлементыДеревоВидимостьПриИзменении(Элемент)
	
	ИзменениеСвойстваЭлемента("Видимость");

КонецПроцедуры

&НаКлиенте
Процедура ЭлементыДеревоТолькоПросмотрПриИзменении(Элемент)
	
	ИзменениеСвойстваЭлемента("ТолькоПросмотр");

КонецПроцедуры

&НаКлиенте
Процедура ЭлементыДеревоДоступностьПриИзменении(Элемент)
	
	ИзменениеСвойстваЭлемента("Доступность");

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыРеквизиты

&НаКлиенте
Процедура РеквизитыПриАктивизацииЯчейки(Элемент)
	
	ИТК_ПодключаемыеКомандыКлиент.ОбновитьЭлементы(ЭтотОбъект, Элемент, "Значение");
	
КонецПроцедуры

&НаКлиенте
Процедура РеквизитыВыбор(Элемент, ИдентификаторВыбраннойСтроки, Поле, СтандартнаяОбработка)
	
	Перем ОписаниеОповещенияОЗакрытии;
	
	СтандартнаяОбработка = Ложь;
	ВыбраннаяСтрока = Реквизиты.НайтиПоИдентификатору(ИдентификаторВыбраннойСтроки);
	
	АнализируемаяФорма = ВыбраннаяФорма();
	Если АнализируемаяФорма = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ВыбраннаяСтрока.ТипЗначения.СодержитТип(Тип("ДинамическийСписок")) Тогда
		
		ИмяРеквизита = ВыбраннаяСтрока.Имя;
		ЗначениеРеквизита = АнализируемаяФорма[ИмяРеквизита];
		
		ПараметрыФормы = Новый Структура;
	    ПараметрыФормы.Вставить("ИсточникДоступныхНастроек" , ЗначениеРеквизита.КомпоновщикНастроек.ПолучитьИсточникДоступныхНастроек());
	    ПараметрыФормы.Вставить("Настройки" , ЗначениеРеквизита.КомпоновщикНастроек.Настройки);
	    ПараметрыФормы.Вставить("ПользовательскиеНастройки" , ЗначениеРеквизита.КомпоновщикНастроек.ПользовательскиеНастройки);
	    ПараметрыФормы.Вставить("ФиксированныеНастройки" , ЗначениеРеквизита.КомпоновщикНастроек.ФиксированныеНастройки);
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("ИмяРеквизита", ИмяРеквизита);
		
		ОписаниеОповещенияОЗакрытии = Новый ОписаниеОповещения("ЗавершеноРедактированиеНастроекДинамическогоСписка",
			ЭтотОбъект, ДополнительныеПараметры);
		
		ОткрытьФорму("ОбщаяФорма.ИТК_РедактированиеНастроекДинамическогоСписка", ПараметрыФормы,
			ЭтотОбъект, , , , ОписаниеОповещенияОЗакрытии, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РеквизитыПередРазворачиванием(Элемент, ИдентификаторСтроки, Отказ)
	
	РазворачиваемаяСтрока = Реквизиты.НайтиПоИдентификатору(ИдентификаторСтроки);
	
	АнализируемаяФорма = ВыбраннаяФорма();
	Если АнализируемаяФорма = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ИТК_ФормаКлиентСервер.НеобходимоРазвернутьСтроку(РазворачиваемаяСтрока, "Имя") Тогда
		
		РазворачиваемаяСтрока.ПолучитьЭлементы().Очистить();
		
		ИмяРеквизитаФормыОбъект = ИТК_ОбщийКлиентСервер.ИмяРеквизитаФормыОбъект();
		РеквизитыОбъекта = ПодчиненныеРеквизитыФормыОбъекта(АнализируемаяФорма[РазворачиваемаяСтрока.Имя], ИмяРеквизитаФормыОбъект);
		Для Каждого ЭлементРеквизит Из РеквизитыОбъекта Цикл 
			
			ИмяРеквизита = ЭлементРеквизит.Значение;
			ЗначениеРеквизита = АнализируемаяФорма[ИмяРеквизитаФормыОбъект][ИмяРеквизита];
			ДобавитьСтрокуВРеквизиты(РазворачиваемаяСтрока, ИмяРеквизита, ЗначениеРеквизита);
			
		КонецЦикла;
		
		ЗаполнитьДанныеРеквизитовНаСервере();
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСвойства

&НаКлиенте
Процедура СвойстваПередНачаломИзменения(Элемент, Отказ)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если ТекущиеДанные.ТолькоПросмотр Тогда
		Отказ = Истина;
	КонецЕсли;
	
	ТипЗначения = ТипЗнч(ТекущиеДанные.Значение);
	Элемент.ТекущийЭлемент.ОграничениеТипа = ИТК_ТипыКлиентСервер.ОписаниеТиповПоТипу(ТипЗначения);
	
КонецПроцедуры

&НаКлиенте
Процедура СвойстваЗначениеПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Свойства.ТекущиеДанные;
	
	АнализируемаяФорма = ВыбраннаяФорма(Истина);
	Если АнализируемаяФорма = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	АнализируемаяФорма[ТекущиеДанные.Имя] = ТекущиеДанные.Значение;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПерейтиКТекущемуЭлементуФормы(Команда)
	
	АнализируемаяФорма = ВыбраннаяФорма();
	Если АнализируемаяФорма = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	АктивизироватьТекущийЭлементФормы(АнализируемаяФорма);
	
КонецПроцедуры

&НаКлиенте
Процедура СвойстваСортироватьПоАлфавиту(Команда)
	
	СортироватьСвойстваПоАлфавиту = Истина;
	ОбновитьЭлементыФормы();
	
	ОбновитьСвойства();
	
КонецПроцедуры

&НаКлиенте
Процедура СвойстваСортироватьПоКатегориям(Команда)
	
	СортироватьСвойстваПоАлфавиту = Ложь;
	ОбновитьЭлементыФормы();
	
	ОбновитьСвойства();
	
КонецПроцедуры

&НаКлиенте
Процедура СвойстваОбновить(Команда)
	
	ОбновитьСвойства();
	
КонецПроцедуры

&НаКлиенте
Процедура РеквизитыОбновить(Команда)
	
	ОбновитьРеквизиты();
	
КонецПроцедуры

#Область ПодключаемыеКоманды

&НаКлиенте
Процедура ПодключаемаяКоманда(Команда)
	
	ИТК_ПодключаемыеКомандыКлиент.ОбработатьКоманду(ЭтотОбъект, Команда.Имя, "Значение");
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПодключаемыйОбновитьСписокДоступныхФорм()
	
	ОбновитьСписокДоступныхФорм();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписокДоступныхФорм()
	
	ДоступныеФормы = Новый СписокЗначений;
	Для Каждого ОткрытаяФорма Из ВсеОткрытыеИДоступныеОкна() Цикл 
		
		Для Каждого ПодчиненнаяФорма Из ОткрытаяФорма.Содержимое Цикл 
			
			ПредставлениеФормы = ИТК_ИнструментМенеджерФормыКлиент.ПредставлениеФормы(ОткрытаяФорма, ПодчиненнаяФорма);
			ДоступныеФормы.Добавить(ПодчиненнаяФорма.УникальныйИдентификатор, ПредставлениеФормы);
			
		КонецЦикла;
		
	КонецЦикла;
	
	СписокВыбораФорм = Элементы.ВыбраннаяФорма.СписокВыбора;
	СписокВыбораФорм.Очистить();
	
	Если ЗначениеЗаполнено(ВыбраннаяФорма) Тогда
		
		НайденнаяФорма = ДоступныеФормы.НайтиПоЗначению(ВыбраннаяФорма);
		Если НайденнаяФорма = Неопределено Тогда
			СписокВыбораФорм.Добавить(ВыбраннаяФорма, НСтр("ru = '<Недоступная форма>'; en = '<Unavailable form>'"));
		КонецЕсли;
		
	КонецЕсли;
	
	КартинкаФормы = БиблиотекаКартинок.Форма;
	Для Каждого ДоступнаяФорма Из ДоступныеФормы Цикл 
		СписокВыбораФорм.Добавить(ДоступнаяФорма.Значение, ДоступнаяФорма.Представление, , КартинкаФормы);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	Элементы.Страницы.Доступность = ЗначениеЗаполнено(ВыбраннаяФорма);
	
	Элементы.СвойстваСвойстваСортироватьПоАлфавиту.Пометка = СортироватьСвойстваПоАлфавиту;
	Элементы.СвойстваСвойстваСортироватьПоКатегориям.Пометка = НЕ СортироватьСвойстваПоАлфавиту;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьВсеДанныеФормы()
	
	ОбновитьЭлементы();
	ОбновитьСвойства();
	ОбновитьРеквизиты();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЭлементы()
	
	АнализируемаяФорма = ВыбраннаяФорма();
	Если АнализируемаяФорма = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЭлементыДерево.ПолучитьЭлементы().Очистить();
	ЗаполнитьДанныеЭлементовРекурсивно(ЭлементыДерево, АнализируемаяФорма);
	АктивизироватьТекущийЭлементФормы(АнализируемаяФорма);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДанныеЭлементовРекурсивно(Родитель, Элемент)
	
	ДоступныПодчиненныеЭлементы = ТипЗнч(Элемент) = Тип("ГруппаФормы")
									ИЛИ ТипЗнч(Элемент) = Тип("ТаблицаФормы")
									ИЛИ ТипЗнч(Элемент) = Тип("ДополнениеЭлементаФормы")
									ИЛИ ТипЗнч(Элемент) = Тип("ФормаКлиентскогоПриложения");
									
	Если НЕ ДоступныПодчиненныеЭлементы Тогда
		Возврат;
	КонецЕсли;
	
	ДоступнаКоманднаяПанель = ТипЗнч(Элемент) = Тип("ТаблицаФормы")
									ИЛИ ТипЗнч(Элемент) = Тип("ФормаКлиентскогоПриложения");
	Если ДоступнаКоманднаяПанель Тогда								
		
		СтрокаКоманднаяПанель = ДобавитьСтрокуЭлемент(Родитель, Элемент.КоманднаяПанель);
		ЗаполнитьДанныеЭлементовРекурсивно(СтрокаКоманднаяПанель, Элемент.КоманднаяПанель);
		
	КонецЕсли;
	
	Для Каждого ПодчиненныйЭлемент Из Элемент.ПодчиненныеЭлементы Цикл 
		
		НоваяСтрока = ДобавитьСтрокуЭлемент(Родитель, ПодчиненныйЭлемент);
		ЗаполнитьДанныеЭлементовРекурсивно(НоваяСтрока, ПодчиненныйЭлемент);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура АктивизироватьТекущийЭлементФормы(Форма)
	
	ИменаЭлементов = Новый Массив;
	
	Элемент = Форма.ТекущийЭлемент;
	Если ТипЗнч(Элемент) = Тип("ОсновнойЭлементФормы") Тогда
		Возврат;
	КонецЕсли;
	
	Пока ТипЗнч(Элемент) <> Тип("ФормаКлиентскогоПриложения") Цикл
		
		Если ТипЗнч(Элемент) = Тип("ТаблицаФормы") Тогда
			ИменаЭлементов.Вставить(0, Элемент.ТекущийЭлемент.Имя);
		КонецЕсли;
		ИменаЭлементов.Вставить(0, Элемент.Имя);
		
		Элемент = Элемент.Родитель;
		
	КонецЦикла;
	
	ТекущаяСтрокаЭлемент = Неопределено;
	РодительДереваЭлементов = ЭлементыДерево;
	Для Каждого ИмяЭлемента Из ИменаЭлементов Цикл 
		
		Для Каждого СтрокаЭлемент Из РодительДереваЭлементов.ПолучитьЭлементы() Цикл 
			
			Если СтрокаЭлемент.Имя = ИмяЭлемента Тогда
				
				ТекущаяСтрокаЭлемент = СтрокаЭлемент;
				РодительДереваЭлементов = СтрокаЭлемент;
				Продолжить;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Элементы.ЭлементыДерево.ТекущаяСтрока = ТекущаяСтрокаЭлемент.ПолучитьИдентификатор();
	
КонецПроцедуры

&НаКлиенте
Функция ДобавитьСтрокуЭлемент(Родитель, Элемент)
	
	НоваяСтрока = Родитель.ПолучитьЭлементы().Добавить();
	НоваяСтрока.Имя = Элемент.Имя;
	НоваяСтрока.Заголовок = Элемент.Заголовок;
	НоваяСтрока.Картинка = ИТК_МенеджерФормКлиентСервер.КартинкаЭлемента(Элемент);
	НоваяСтрока.Тип = ТипЗнч(Элемент);
	НоваяСтрока.Вид = ИТК_МенеджерФормКлиентСервер.ВидЭлемента(Элемент);
	
	ДоступенТолькоПросмотр = ИТК_МенеджерФормКлиентСервер.ДоступенТолькоПросмотр(Элемент);
	НоваяСтрока.ДоступенТолькоПросмотр = ДоступенТолькоПросмотр;
	Если ДоступенТолькоПросмотр Тогда
		НоваяСтрока.ТолькоПросмотр = Элемент.ТолькоПросмотр;
	КонецЕсли;
	
	НоваяСтрока.Видимость = Элемент.Видимость;
	НоваяСтрока.Доступность = Элемент.Доступность;
	
	Возврат НоваяСтрока;
	
КонецФункции

&НаКлиенте
Процедура ОбновитьСвойства()
	
	АнализируемаяФорма = ВыбраннаяФорма();
	Если АнализируемаяФорма = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗначенияСвойствФормы = Новый Соответствие;
	СвойстваФормы = ИТК_СвойстваФормыКлиентСервер.СоответствиеОписаниеСвойств();
	Для Каждого СвойствоФормы Из СвойстваФормы Цикл 
		ЗначенияСвойствФормы.Вставить(СвойствоФормы.Ключ, АнализируемаяФорма[СвойствоФормы.Ключ]);
	КонецЦикла;
	
	ОбновитьСвойстваНаСервере(ЗначенияСвойствФормы);
	ИТК_ФормаКлиент.РазвернутьДерево(Элементы.Свойства, Свойства);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСвойстваНаСервере(ЗначенияСвойствФормы)
	
	ДеревоСвойств = ИТК_МенеджерФорм.ЗначенияСвойств(ЗначенияСвойствФормы, СортироватьСвойстваПоАлфавиту);
	ЗначениеВРеквизитФормы(ДеревоСвойств, "Свойства");
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьРеквизиты()
	
	АнализируемаяФорма = ВыбраннаяФорма();
	Если АнализируемаяФорма = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Реквизиты.ПолучитьЭлементы().Очистить();
	
	ПроверяемыеРеквизиты = Новый Структура;
	ПроверяемыеРеквизиты.Вставить("Объект");
	ПроверяемыеРеквизиты.Вставить("Object");
	ПроверяемыеРеквизиты.Вставить("Запись");
	ПроверяемыеРеквизиты.Вставить("Record");
	ПроверяемыеРеквизиты.Вставить("Отчет");
	ПроверяемыеРеквизиты.Вставить("Report");
	
	ДобавлениеРеквизитовНаПроверкуПоЭлементамРекурсивно(Реквизиты, АнализируемаяФорма, ПроверяемыеРеквизиты);
	
	СлужебныеЗначенияРеквизитов = Новый Соответствие;
	Для Каждого ПроверяемыйРеквизит Из ПроверяемыеРеквизиты Цикл 
		
		СлужебноеЗначение = Новый УникальныйИдентификатор;
		
		ПроверяемыеРеквизиты.Вставить(ПроверяемыйРеквизит.Ключ, СлужебноеЗначение);
		СлужебныеЗначенияРеквизитов.Вставить(ПроверяемыйРеквизит.Ключ, СлужебноеЗначение);
		
	КонецЦикла;
	
	ЗаполнитьЗначенияСвойств(ПроверяемыеРеквизиты, АнализируемаяФорма);
	
	РеквизитыФормы = Новый Соответствие;
	Для Каждого ПроверяемыйРеквизит Из ПроверяемыеРеквизиты Цикл 
		
		ИмяРеквизита = ПроверяемыйРеквизит.Ключ;
		ЗначениеРеквизита = ПроверяемыйРеквизит.Значение;
		
		Если ЗначениеРеквизита = СлужебныеЗначенияРеквизитов.Получить(ИмяРеквизита) Тогда
			Продолжить;
		КонецЕсли;
		
		РеквизитыФормы.Вставить(ИмяРеквизита, ЗначениеРеквизита);
		
		Если ТипЗнч(ЗначениеРеквизита) = Тип("ДанныеФормыСтруктура") Тогда
			
			РеквизитыФормыОбъекта = ПодчиненныеРеквизитыФормыОбъекта(ЗначениеРеквизита);
			Для Каждого ЭлементРеквизит Из РеквизитыФормыОбъекта Цикл 
				
				ИмяПодчиненногоРеквизита = ЭлементРеквизит.Значение;
				ЗначениеРеквизита = АнализируемаяФорма[ИмяПодчиненногоРеквизита];
				РеквизитыФормы.Вставить(ИмяПодчиненногоРеквизита, ЗначениеРеквизита);
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
	//ПодчиненныеРеквизитыФормыОбъекта(
	СписокРеквизитовФормы = Новый СписокЗначений;
	Для Каждого РеквизитФормы Из РеквизитыФормы Цикл 
		СписокРеквизитовФормы.Добавить(РеквизитФормы.Значение, РеквизитФормы.Ключ);
	КонецЦикла;
	
	СписокРеквизитовФормы.СортироватьПоПредставлению();
	
	Для Каждого ЭлементРеквизитФормы Из СписокРеквизитовФормы Цикл 
		ДобавитьСтрокуВРеквизиты(Реквизиты, ЭлементРеквизитФормы.Представление, ЭлементРеквизитФормы.Значение);
	КонецЦикла;
	
	ЗаполнитьДанныеРеквизитовНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеРеквизитовНаСервере()
	
	ЗаполнитьДанныеРеквизитовНаСервереПоРодителю(Реквизиты);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеРеквизитовНаСервереПоРодителю(Родитель)
	
	Для Каждого Строка Из Родитель.ПолучитьЭлементы() Цикл 
		
		Строка.КартинкаТипа = ИТК_Типы.КартинкаОписания(Строка.ТипЗначения);
		ЗаполнитьДанныеРеквизитовНаСервереПоРодителю(Строка);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьСтрокуВРеквизиты(Родитель, Имя, Значение)
	
	НоваяСтрока = Родитель.ПолучитьЭлементы().Добавить();
	НоваяСтрока.Имя = Имя;
	
	Попытка
		НоваяСтрока.ПредставлениеЗначения = Значение;
	Исключение
		НоваяСтрока.ПредставлениеЗначения = Строка(Значение);
	КонецПопытки;
	
	ТипЗначения = ТипЗнч(Значение);
	НоваяСтрока.ТипЗначения = ИТК_ТипыКлиентСервер.ОписаниеТиповПоТипу(ТипЗначения);
	
	Если ТипЗначения = Тип("ДанныеФормыСтруктура") Тогда
		НоваяСтрока.ПолучитьЭлементы().Добавить();
	КонецЕсли;
	
	Если ИТК_ФормаКлиент.ЗначениеВозможноХранитьВПолеФормы(Значение) Тогда
		НоваяСтрока.Значение = Значение;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПодчиненныеРеквизитыФормыОбъекта(ДанныеФормыСтруктура, Родитель = "root")
	
	Результат = Новый СписокЗначений;
	
	// Сериализация объекта в строку XML
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку();
	
	Попытка
		СериализаторXDTO.ЗаписатьXML(ЗаписьXML, ДанныеФормыСтруктура, НазначениеТипаXML.Явное);
		СтрокаXML = ЗаписьXML.Закрыть();
	Исключение
		Возврат Результат;
	КонецПопытки;
	
	// Разбор объекта в строке XML
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(СтрокаXML);
	
	ТекущийРодитель = Неопределено;
	Пока ЧтениеXML.Прочитать() Цикл
		
		Если ЧтениеXML.Имя = "structure" 
				И ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
			
			ПутьКДанным = ЧтениеXML.ПолучитьАтрибут("name");
			
			ЧастиПутиКДанным = СтрРазделить(ПутьКДанным, ".");
			Если ЧастиПутиКДанным.Количество() = 2 Тогда
				ТекущийРодитель = ЧастиПутиКДанным[1];
			ИначеЕсли ЧастиПутиКДанным.Количество() = 1 Тогда
				ТекущийРодитель = ЧастиПутиКДанным[0];
			Иначе
				ТекущийРодитель = Неопределено;
			КонецЕсли;
			
		КонецЕсли;
		
		Если ТекущийРодитель <> Родитель Тогда
			Продолжить;
		КонецЕсли;
			
		Если ЧтениеXML.Имя = "field" 
			И ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
			
			Поле = ЧтениеXML.ПолучитьАтрибут("name");
			Если ЗначениеЗаполнено(Поле) Тогда
				Результат.Добавить(Поле);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ЧтениеXML.Закрыть();
	
	Результат.СортироватьПоЗначению();
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ДобавлениеРеквизитовНаПроверкуПоЭлементамРекурсивно(Родитель, РодительскийЭлемент, ПроверяемыеРеквизиты)
	
	Для Каждого Элемент Из РодительскийЭлемент.ПодчиненныеЭлементы Цикл 
		
		Если ТипЗнч(Элемент) = Тип("ПолеФормы")
				ИЛИ ТипЗнч(Элемент) = Тип("ТаблицаФормы") Тогда
			ПроверяемыеРеквизиты.Вставить(Элемент.Имя);
		КонецЕсли;

		Если ТипЗнч(Элемент) = Тип("ГруппаФормы") Тогда
			ДобавлениеРеквизитовНаПроверкуПоЭлементамРекурсивно(Родитель, Элемент, ПроверяемыеРеквизиты)
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Функция ВсеОткрытыеИДоступныеОкна()
	
	Результат = Новый Массив;
	
	ВсеОткрытыеОкна = ПолучитьОкна();
	Для Каждого ОткрытоеОкно Из ВсеОткрытыеОкна Цикл 
		
		Если НЕ ИТК_ИнструментМенеджерФормыКлиент.ДоступнаяФорма(ОткрытоеОкно) Тогда
			Продолжить;
		КонецЕсли;
		
		Результат.Добавить(ОткрытоеОкно);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ВыбраннаяФорма(ПоказатьОшибку = Ложь)
	
	Для Каждого ОткрытаяФорма Из ВсеОткрытыеИДоступныеОкна() Цикл 
		
		Для Каждого ПодчиненнаяФорма Из ОткрытаяФорма.Содержимое Цикл 
			
			Если ПодчиненнаяФорма.УникальныйИдентификатор = ВыбраннаяФорма Тогда
				Возврат ПодчиненнаяФорма;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Если ПоказатьОшибку Тогда
		ПоказатьПредупреждение( , НСтр("ru = 'Форма недоступна'; en = 'Form not available'"));
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаКлиенте
Функция НайтиЭлементНаВыбраннойФорме(Имя, ПоказатьОшибку = Ложь)

	АнализируемаяФорма = ВыбраннаяФорма(ПоказатьОшибку);
	Если АнализируемаяФорма = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = АнализируемаяФорма.Элементы.Найти(Имя);
	Если Результат = Неопределено
			И ПоказатьОшибку Тогда
			
		ШаблонТекстаОшибки = НСтр("ru = 'Не найден элемент: %1'; en = 'Item not found: %1'");	
		ПоказатьПредупреждение( , СтрШаблон(ШаблонТекстаОшибки, Имя));
		
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

&НаКлиенте
Функция ЗначениеРеквизитаНаВыбраннойФорме(Имя, ПоказатьОшибку = Истина)

	АнализируемаяФорма = ВыбраннаяФорма(ПоказатьОшибку);
	Если АнализируемаяФорма = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		
		Значение = АнализируемаяФорма[Имя];
		ПроизошлаОшибка = Ложь;
		
	Исключение
		
		Значение = Неопределено;
		ПроизошлаОшибка = Истина;

	КонецПопытки;

	Если ПроизошлаОшибка
			И ПоказатьОшибку Тогда
			
		ШаблонТекстаОшибки = НСтр("ru = 'Не найден реквизит: %1'; en = 'Field not found: %1'");	
		ПоказатьПредупреждение( , СтрШаблон(ШаблонТекстаОшибки, Имя));
		
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ПроизошлаОшибка", ПроизошлаОшибка);
	Результат.Вставить("Значение", Значение);
	
	Возврат Результат;

КонецФункции

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	// Свойства
	Оформление = Новый Структура("Шрифт", ИТК_ОбщийКлиентСервер.ШрифтЖирный());
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "Свойства", Оформление, "Свойства.ЭтоГруппа", Истина);
	
	// Элементы
	Оформление = Новый Структура("Отображать", Ложь);
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "ЭлементыДеревоТолькоПросмотр", Оформление,
		"ЭлементыДерево.ДоступенТолькоПросмотр", Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйВосстановитьОформлениеАктивизированногоЭлемента()
	
	ВосстановитьОформлениеАктивизированногоЭлемента();
	
КонецПроцедуры

&НаКлиенте
Процедура ВосстановитьОформлениеАктивизированногоЭлемента()
	
	Если ПоследнийАктивныйЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Элемент = НайтиЭлементНаВыбраннойФорме(ПоследнийАктивныйЭлемент.Имя);
	Если Элемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Оформление Из ПоследнийАктивныйЭлемент.НачальноеОформление Цикл 
		Элемент[Оформление.Ключ] = Оформление.Значение;
	КонецЦикла;
	
	ПоследнийАктивныйЭлемент = Неопределено;
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменениеСвойстваЭлемента(Свойство)

	ТекущиеДанные = Элементы.ЭлементыДерево.ТекущиеДанные;
	Элемент = НайтиЭлементНаВыбраннойФорме(ТекущиеДанные.Имя, Истина);

	Если Элемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Элемент[Свойство] = ТекущиеДанные[Свойство];

КонецПроцедуры

&НаКлиенте
Процедура ЗавершеноРедактированиеНастроекДинамическогоСписка(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	Если РезультатЗакрытия = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОписаниеЗначенияРеквизита = ЗначениеРеквизитаНаВыбраннойФорме(ДополнительныеПараметры.ИмяРеквизита);
	Если ОписаниеЗначенияРеквизита.ПроизошлаОшибка Тогда
		Возврат;
	КонецЕсли;
	ЗначениеРеквизита = ОписаниеЗначенияРеквизита.Значение;

	КомпоновщикНастроекИсточник = РезультатЗакрытия.КомпоновщикНастроек;
	КомпоновщикНастроекПриемник = ЗначениеРеквизита.КомпоновщикНастроек;
	
	КомпоновщикНастроекПриемник.ЗагрузитьНастройки(КомпоновщикНастроекИсточник.Настройки);
	КомпоновщикНастроекПриемник.ЗагрузитьФиксированныеНастройки(КомпоновщикНастроекИсточник.ФиксированныеНастройки);
	КомпоновщикНастроекПриемник.ЗагрузитьПользовательскиеНастройки(КомпоновщикНастроекИсточник.ПользовательскиеНастройки);
	
КонецПроцедуры

#КонецОбласти
