#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТипПредставленияОбъктов = ИТК_Перечисления.ПредставлениеОбъектовСиноним();
	
	ИТК_ФормаКлиентСервер.ОформитьСтрокуПоискаПоПодобию(Элементы.Поиск);
	
	Коллекции = ИТК_МетаданныеКлиентСерверПовтИсп.ДоступныеКоллекцииВсеДействия();
	Для Каждого ИмяКоллекции Из Коллекции Цикл 
		
		КоллекцияОбъектов = Метаданные[ИмяКоллекции];
		Если Не ЗначениеЗаполнено(КоллекцияОбъектов) Тогда
			Продолжить;
		КонецЕсли;
		
		ИмяОбъектаКоллекции = ИТК_МетаданныеКлиентСерверПовтИсп.ИмяОбъектаКоллекции(ИмяКоллекции);
		ПредставлениеКоллекции = ИТК_Строки.ПредставлениеИдентификатора(ИмяКоллекции);
		
		СтрокаКоллекция = ДобавитьСтрокуДерева(Дерево, ИмяКоллекции, ПредставлениеКоллекции, ИТК_МетаданныеКлиентСерверПовтИсп.КартинкаОбъектаКоллекции(ИмяОбъектаКоллекции));
		ДобавитьСтрокуДерева(СтрокаКоллекция);
		
	КонецЦикла;
	
	// Стандартные
	СтрокаКоллекция = ДобавитьСтрокуДерева(Дерево, "Стандартные", НСтр("ru = 'Стандартные';
																		|en = 'Standard'"), БиблиотекаКартинок.Форма);
	ДобавитьСтрокуДерева(СтрокаКоллекция);
	
КонецПроцедуры

&НаСервере
Процедура ПередЗагрузкойДанныхИзНастроекНаСервере(Настройки)
	
	ТипПредставленияОбъктовИзНастроек = Настройки.Получить("ТипПредставленияОбъктов");
	Если ЗначениеЗаполнено(ТипПредставленияОбъктовИзНастроек) Тогда
		ТипПредставленияОбъктов = ТипПредставленияОбъктовИзНастроек;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИТК_ОбщийКлиент.ОбработчикПриОткрытии(Отказ);
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПоискПриИзменении(Элемент)
	
	ОбновитьПоискПоСтроке();
	
КонецПроцедуры

&НаКлиенте
Процедура ПоискОчистка(Элемент, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ЧастиКлюча = СтрРазделить(ТекущиеДанные.Значение, ".");
	
	ИмяКоллекции = ЧастиКлюча[0];
	СтрокаКоллекция = НайтиСтрокуПоИдентификатору(ИмяКоллекции);
	РазвернутьСтрокуКоллекции(СтрокаКоллекция.ПолучитьИдентификатор());
	
	Строка = НайтиСтрокуПоИдентификатору(ТекущиеДанные.Значение);
	Элементы.Дерево.ТекущаяСтрока = Строка.ПолучитьИдентификатор();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура НачатьПоиск(Команда)
	
	ОбновитьПоискПоСтроке();
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьОбъект(Команда)
	
	ОткрытьВыбранноеЗначение();
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьОбъектВНовомОкне(Команда)
	
	ОткрытьВыбранноеЗначение("ВНовомОкне");
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьУниверсальнуюФорму(Команда)
	
	ОткрытьВыбранноеЗначение("УниверсальнаяФорма");
	
КонецПроцедуры

&НаКлиенте
Процедура ТипПредставленияОбъктовИмя(Команда)
	
	ИзменитьТипПредставленияОбъктов(ИТК_Перечисления.ПредставлениеОбъектовИмя());
	
КонецПроцедуры

&НаКлиенте
Процедура ТипПредставленияОбъктовСиноним(Команда)
	
	ИзменитьТипПредставленияОбъктов(ИТК_Перечисления.ПредставлениеОбъектовСиноним());

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДерево

&НаКлиенте
Процедура ДеревоПриАктивизацииСтроки(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ОткрытьВыбранноеЗначение( , СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоПередРазворачиванием(Элемент, Строка, Отказ)
	
	РазворачиваемаяСтрока = Дерево.НайтиПоИдентификатору(Строка);
	
	Если ИТК_ФормаКлиентСервер.НеобходимоРазвернутьСтроку(РазворачиваемаяСтрока) Тогда
		РазвернутьСтрокуКоллекции(Строка);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписок

&НаКлиенте
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ОткрытьВыбранноеЗначение( , СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ДобавитьСтрокуДерева(Родитель, Имя = Неопределено, Синоним = Неопределено, Картинка = Неопределено, Представление = Неопределено)

	НоваяСтрока = Родитель.ПолучитьЭлементы().Добавить();
	НоваяСтрока.Картинка = Картинка;
	НоваяСтрока.Имя = Имя;
	НоваяСтрока.Синоним = Синоним;
	
	Если Представление = Неопределено Тогда
		Представление = Синоним;
	КонецЕсли;
	НоваяСтрока.Представление = Представление;
	
    Возврат НоваяСтрока;
	
КонецФункции

&НаСервере
Процедура РазвернутьСтрокуКоллекции(ИдентификаторСтроки)

	РазворачиваемаяСтрока = Дерево.НайтиПоИдентификатору(ИдентификаторСтроки);
	РазворачиваемаяСтрока.ПолучитьЭлементы().Очистить();
	
	ИмяКоллекции = ЗначениеПоСтроке(РазворачиваемаяСтрока);
	Если ИмяКоллекции = "Стандартные" Тогда
		
		Для Каждого ЭлементКоллекции Из ИТК_ВсеФункцииПовтИсп.СписокКоллекцииСтандартные() Цикл 
			ДобавитьСтрокуДерева(РазворачиваемаяСтрока, ЭлементКоллекции.Значение, ЭлементКоллекции.Представление, РазворачиваемаяСтрока.Картинка);
		КонецЦикла;
		
	Иначе
		
		// Добавление объектов коллекции
		ПредставленияИИменаМетаданных = ИТК_МетаданныеПовтИсп.КэшПредставленийИИменКоллекции(ИмяКоллекции);
		Если ТипПредставленияОбъктов = ИТК_Перечисления.ПредставлениеОбъектовИмя() Тогда
			ПредставленияИИменаМетаданных.СортироватьПоЗначению();
		КонецЕсли;

		Для Каждого ЭлементОбъектаМетаданных Из ПредставленияИИменаМетаданных Цикл 
			
			ИмяОбъектаМетаданных = ЭлементОбъектаМетаданных.Значение;
			ПредставлениеОбъектаМетаданных = ЭлементОбъектаМетаданных.Представление;
			
			ПолноеПредставление = ПолноеПредставление(ТипПредставленияОбъктов, ИмяОбъектаМетаданных, ПредставлениеОбъектаМетаданных);
			СтрокаОбъект = ДобавитьСтрокуДерева(РазворачиваемаяСтрока, ИмяОбъектаМетаданных, ПредставлениеОбъектаМетаданных, РазворачиваемаяСтрока.Картинка, ПолноеПредставление);
			
			Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоВнешнийИсточникДанных(ИмяКоллекции) Тогда
				
				КартинкаТаблицыВнешнегоИсточника = ИТК_ОбщийКлиентСерверПовтИсп.БиблиотекаКартинок("ИТК_ВнешнийИсточникДанныхТаблица");
				Для Каждого ОбъектТаблица Из Метаданные[ИмяКоллекции][ИмяОбъектаМетаданных].Таблицы Цикл 
					
					ПолноеПредставлениеОбъектаТаблица = ПолноеПредставление(ТипПредставленияОбъктов, ОбъектТаблица.Имя, ОбъектТаблица.Синоним);
					ДобавитьСтрокуДерева(СтрокаОбъект, ОбъектТаблица.Имя, ОбъектТаблица.Синоним, КартинкаТаблицыВнешнегоИсточника, ПолноеПредставлениеОбъектаТаблица);
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ЗначениеПоСтроке(Строка)
	
	Возврат Строка.Имя;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ИдентификаторСтроки(Строка)
	
	Если Строка = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ЧастиИдентификатора = Новый Массив;
	ЧастиИдентификатора.Добавить(ЗначениеПоСтроке(Строка));
	
	Родитель = Строка.ПолучитьРодителя();
	Пока Родитель <> Неопределено Цикл 
		
		ЧастиИдентификатора.Вставить(0, ЗначениеПоСтроке(Родитель));
		Родитель = Родитель.ПолучитьРодителя();
		
	КонецЦикла;
	
	Возврат СтрСоединить(ЧастиИдентификатора, ".");
	
КонецФункции

&НаКлиенте
Процедура ОбновитьПоискПоСтроке()
	
	Список.Очистить();
	Если ЗначениеЗаполнено(Поиск) Тогда
		
		ЗаполнитьСписокПоискаСервер();
		ПодключитьОбработчикОжидания("ПодключаемыйТекущийЭлементСтрокаПоискаПослеОжидания", 0.2, Истина);
		
	КонецЕсли;
	
	ОбновлениеЭлементовФормыПослеОжидания();
	ТекущийЭлемент = Элементы.Поиск;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокПоискаСервер()
	
	ЛимитСписка = 50;
	ПараметрыПоиска = ИТК_Строки.ПараметрыПоискаПоПодобию(Поиск);
	
	// Коллекции
	Коллекции = ИТК_МетаданныеКлиентСерверПовтИсп.ДоступныеКоллекцииВсеДействия();
	Для Каждого ИмяКоллекции Из Коллекции Цикл 
		
		Если ЗначениеЗаполнено(ПараметрыПоиска.Коллекция) И НЕ СтрНайти(НРег(ИмяКоллекции), ПараметрыПоиска.Коллекция) Тогда
			Продолжить;
		КонецЕсли;
		
		Картинка = ИТК_МетаданныеКлиентСерверПовтИсп.КартинкаКоллекции(ИмяКоллекции);
		КартинкаТаблицыВнешнегоИсточника = ИТК_ОбщийКлиентСерверПовтИсп.БиблиотекаКартинок("ИТК_ВнешнийИсточникДанныхТаблица");
		Для Каждого ОбъектМетаданных Из Метаданные[ИмяКоллекции] Цикл 
			
			Если Список.Количество() = ЛимитСписка Тогда
				Прервать;
			КонецЕсли;
			
			АнализируемаяСтрока = ИТК_Строки.АнализируемаяСтрокаПоискаПоПодобию(ОбъектМетаданных.Имя + Символы.НПП + ОбъектМетаданных.Синоним);
			Если ИТК_Строки.ПоискПоПодобиюНайденыСовпадения(АнализируемаяСтрока, ПараметрыПоиска) Тогда
				
				Идентификатор = ИмяКоллекции + "." + ОбъектМетаданных.Имя;
				Представление = ПолноеПредставление(ТипПредставленияОбъктов, ОбъектМетаданных.Имя, ОбъектМетаданных.Синоним);
				Список.Добавить(Идентификатор, Представление, , Картинка);
				
			КонецЕсли;
			
			Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоВнешнийИсточникДанных(ИмяКоллекции) Тогда
				
				Для Каждого ОбъектТаблица Из ОбъектМетаданных.Таблицы Цикл
					
					Если Список.Количество() = ЛимитСписка Тогда
						Прервать;
					КонецЕсли;
					
					АнализируемаяСтрока = ИТК_Строки.АнализируемаяСтрокаПоискаПоПодобию(ОбъектТаблица.Имя + Символы.НПП + ОбъектТаблица.Синоним);
					Если НЕ ИТК_Строки.ПоискПоПодобиюНайденыСовпадения(АнализируемаяСтрока, ПараметрыПоиска) Тогда
						Продолжить;
					КонецЕсли;
					
					Идентификатор = СтрШаблон("%1.%2.%3", ИмяКоллекции, ОбъектМетаданных.Имя, ОбъектТаблица.Имя);
					
					ПредставлениеВнешнегоИсточника = ПолноеПредставление(ТипПредставленияОбъктов, ОбъектМетаданных.Имя, ОбъектМетаданных.Синоним);
					ПредставлениеОбъектаТаблица = ПолноеПредставление(ТипПредставленияОбъктов, ОбъектТаблица.Имя, ОбъектТаблица.Синоним);
					Представление = СтрШаблон("%1 (%2)", ПредставлениеОбъектаТаблица, ПредставлениеВнешнегоИсточника);
					
					Список.Добавить(Идентификатор, Представление, , КартинкаТаблицыВнешнегоИсточника);
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	// Стандартные
	Картинка = БиблиотекаКартинок.Форма;
	Для Каждого ЭлементКоллекции Из ИТК_ВсеФункцииПовтИсп.СписокКоллекцииСтандартные() Цикл 
		
		Если Список.Количество() = ЛимитСписка Тогда
			Прервать;
		КонецЕсли;
		
		Если НЕ ИТК_Строки.ПоискПоПодобиюНайденыСовпадения(ЭлементКоллекции.Представление, ПараметрыПоиска) Тогда
			Продолжить;
		КонецЕсли;
		
		Список.Добавить("Стандартные." + ЭлементКоллекции.Значение, ЭлементКоллекции.Представление, , Картинка);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	ПоискЗаполнен = ЗначениеЗаполнено(Поиск);
	
	Элементы.Дерево.Видимость = Не ПоискЗаполнен;
	Элементы.Список.Видимость = ПоискЗаполнен;

	ТипПредставленияОбъктовИмя = (ТипПредставленияОбъктов = ИТК_Перечисления.ПредставлениеОбъектовИмя());
	Элементы.ТипПредставленияОбъктовИмя.Пометка = ТипПредставленияОбъктовИмя;
	
	ТипПредставленияОбъктовСиноним = (ТипПредставленияОбъктов = ИТК_Перечисления.ПредставлениеОбъектовСиноним());
	Элементы.ТипПредставленияОбъктовСиноним.Пометка = ТипПредставленияОбъктовСиноним;
	
	ОбновитьДоступностьДействий();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновлениеЭлементовФормыПослеОжидания()
	
	ПодключитьОбработчикОжидания("ПодключаемыйОбновлениеЭлементовФормыПослеОжидания", 0.1, Истина);	
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйОбновлениеЭлементовФормыПослеОжидания()

	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаКлиенте
Функция НайтиСтрокуПоИдентификатору(Идентификатор)
	
	ЧастиИдентификатора = СтрРазделить(Идентификатор, ".");

	Для Каждого СтрокаКоллекция Из Дерево.ПолучитьЭлементы() Цикл 
		
		Если ЗначениеПоСтроке(СтрокаКоллекция) <> ЧастиИдентификатора[0] Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЧастиИдентификатора.Количество() = 1 Тогда
			Возврат СтрокаКоллекция;
		КонецЕсли;
		
		Для Каждого СтрокаОбъектМетаданных Из СтрокаКоллекция.ПолучитьЭлементы() Цикл 
			
			Если ЗначениеПоСтроке(СтрокаОбъектМетаданных) <> ЧастиИдентификатора[1] Тогда
				Продолжить;
			КонецЕсли;
				
			Если ЧастиИдентификатора.Количество() = 2 Тогда
				Возврат СтрокаОбъектМетаданных;
			КонецЕсли;
			
			Для Каждого СтрокаЭлементОбъектМетаданных Из СтрокаОбъектМетаданных.ПолучитьЭлементы() Цикл 
				
				Если ЗначениеПоСтроке(СтрокаЭлементОбъектМетаданных) <> ЧастиИдентификатора[2] Тогда
					Продолжить;
				КонецЕсли;
				
				Возврат СтрокаЭлементОбъектМетаданных;
				
			КонецЦикла
			
		КонецЦикла
		
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

&НаКлиенте
Процедура ОткрытьВыбранноеЗначение(Вариант = "Открыть", СтандартнаяОбработка = Неопределено)
	
	СтандартнаяОбработка = Ложь;
	
	Если ЗначениеЗаполнено(Поиск) Тогда
		Строка = Элементы.Список.ТекущиеДанные;
	Иначе 
		Строка = Элементы.Дерево.ТекущиеДанные;
	КонецЕсли;
	
	Если НЕ СтрокаВыбирается(Строка) Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Поиск) Тогда
		
		ЧастиИдентификатора = СтрРазделить(Строка.Значение, ".");
		ИмяКоллекции = ЧастиИдентификатора[0];
		ИмяОбъекта = ЧастиИдентификатора[1];
	
		ИмяЭлементаОбъекта = Неопределено;
		Если ЧастиИдентификатора.Количество() > 2 Тогда
			ИмяЭлементаОбъекта = ЧастиИдентификатора[2];
		КонецЕсли;
		
	Иначе
		
		Родитель = ОсновнойРодительСтроки(Строка);
		ИмяКоллекции = ЗначениеПоСтроке(Родитель);
		
		ИмяЭлементаОбъекта = Неопределено;
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоВнешнийИсточникДанных(ИмяКоллекции) Тогда
			
			ИмяОбъекта = ЗначениеПоСтроке(Строка.ПолучитьРодителя());
			ИмяЭлементаОбъекта = ЗначениеПоСтроке(Строка);
			
		Иначе
			ИмяОбъекта = ЗначениеПоСтроке(Строка);
		КонецЕсли;
		
	КонецЕсли;
	
	Закрыть();
	ОткрытьФормуОбъекта(ИмяКоллекции, ИмяОбъекта, ИмяЭлементаОбъекта, Вариант);
	
	ПодключитьОбработчикОжидания("ПодключаемыйТекущийЭлементСтрокаПоискаПослеОжидания", 0.1, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуОбъекта(ИмяКоллекции, ИмяОбъекта, ИмяЭлементаОбъекта, Вариант = Ложь)
	
	ПараметрыФормы = Новый Структура;
	Если ИмяКоллекции = "Стандартные" Тогда
		
		Если ИмяОбъекта = "StandardActiveUsers" Тогда
			
			ПолноеИмяФормы = "Обработка.ИТК_Пользователи.Форма";
			ПараметрыФормы.Вставить("НачальнаяСтраница", "АктивныеПользователи");
			
		ИначеЕсли ИмяОбъекта = "StandardUsers" Тогда
			
			ПолноеИмяФормы = "Обработка.ИТК_Пользователи.Форма";
			ПараметрыФормы.Вставить("НачальнаяСтраница", "Пользователи");
			
		ИначеЕсли ИмяОбъекта = "StandardFindByRef" Тогда
			
			ПолноеИмяФормы = "Обработка.ИТК_ПоискСсылокНаОбъект.Форма";
			
		ИначеЕсли ИмяОбъекта = "StandardEventLog" Тогда

			ПолноеИмяФормы = "Обработка.ИТК_ЖурналРегистрации.Форма";			
			
		Иначе
			
			ИТК_ОбщийВызовСервера.ПодключитьСтандартнуюОбработку(ИмяОбъекта);
			ПолноеИмяФормы = СтрШаблон("ВнешняяОбработка.%1.Форма", ИмяОбъекта);
			
		КонецЕсли;
		
	ИначеЕсли ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоВнешнийИсточникДанных(ИмяКоллекции) Тогда
		
		Вариант = "УниверсальнаяФорма";
		
	ИначеЕсли ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоКонстанта(ИмяКоллекции) Тогда
		
		ПолноеИмяФормы = "Обработка.ИТК_РедакторКонстант.Форма";
		ПараметрыФормы.Вставить("Имя", ИмяОбъекта);
		
	Иначе
		
		ИмяОбъектаКоллекции = ИТК_МетаданныеКлиентСерверПовтИсп.ИмяОбъектаКоллекции(ИмяКоллекции);
		ПолноеИмяФормы = ИмяОбъектаКоллекции + "." + ИмяОбъекта;
		
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоОбработка(ИмяКоллекции)
				ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоОтчет(ИмяКоллекции) Тогда
			Дополнение = "Форма";
		Иначе
			Дополнение = "ФормаСписка";
		КонецЕсли;
		ПолноеИмяФормы = ПолноеИмяФормы + "." + Дополнение;
	
	КонецЕсли;
	
	Уникальность = Неопределено;
	Если Вариант = "ВНовомОкне" Тогда
		Уникальность = Истина;
	КонецЕсли;
	
	Если Вариант = "УниверсальнаяФорма" Тогда
		
		ИмяОбъектаКоллекции = ИТК_МетаданныеКлиентСерверПовтИсп.ИмяОбъектаКоллекции(ИмяКоллекции);
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоВнешнийИсточникДанных(ИмяКоллекции) Тогда
			Таблица = СтрШаблон("%1.%2.Таблица.%3", ИмяОбъектаКоллекции, ИмяОбъекта, ИмяЭлементаОбъекта); 
		Иначе
			Таблица = СтрШаблон("%1.%2", ИмяОбъектаКоллекции, ИмяОбъекта);
		КонецЕсли;
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Уникальность", Уникальность);
		ИТК_ФормаКлиент.ОткрытьУниверсальнуюФормуСписка(Таблица, , ДополнительныеПараметры);
		
	Иначе
		ОткрытьФорму(ПолноеИмяФормы, ПараметрыФормы, , Уникальность, , , , РежимОткрытияОкнаФормы.Независимый);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция СтрокаВыбирается(Строка)
	
	Если Строка = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат ТипЗнч(Строка) = Тип("ДанныеФормыСтруктура")
				ИЛИ НЕ ЗначениеЗаполнено(Строка.ПолучитьЭлементы());
	
КонецФункции

&НаКлиенте
Процедура ИзменитьТипПредставленияОбъктов(Значение) 
	
	Если ТипПредставленияОбъктов = Значение Тогда
		Возврат;
	КонецЕсли;
	
	ТипПредставленияОбъктов = Значение;
	ОбновитьЭлементыФормы();

	ОбновитьПолноеПредставление();
	ОбновитьПоискПоСтроке();
	ПересортироватьДерево();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПолноеПредставление()
	
	Для Каждого Строка Из Дерево.ПолучитьЭлементы() Цикл 
		
		Если ИТК_ФормаКлиентСервер.НеобходимоРазвернутьСтроку(Строка) Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого ПодчиненнаяСтрока Из Строка.ПолучитьЭлементы() Цикл 
			
			ПодчиненнаяСтрока.Представление = ПолноеПредставление(ТипПредставленияОбъктов, ПодчиненнаяСтрока.Имя, ПодчиненнаяСтрока.Синоним);
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДоступностьДействий()
	
	Строка = Элементы.Дерево.ТекущиеДанные;
	Если Строка = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Родитель = ОсновнойРодительСтроки(Строка);
	ИмяКоллекции = ЗначениеПоСтроке(Родитель);

	ЭтоВнешнийИсточникДанных = ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоВнешнийИсточникДанных(ИмяКоллекции);
	СтрокаВыбирается = СтрокаВыбирается(Строка);
	
	ДоступноОткрытие = СтрокаВыбирается И НЕ ЭтоВнешнийИсточникДанных;
	Элементы.Открыть.Доступность = ДоступноОткрытие;
	Элементы.ДеревоКонтекстноеМенюОткрытьОбъект.Доступность = ДоступноОткрытие;
	
	Если ЭтоВнешнийИсточникДанных Тогда
		ДоступнаУниверсальнаяФорма = Истина;
	ИначеЕсли СтрокаВыбирается
			И НЕ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоГруппаСтандартные(ИмяКоллекции) Тогда

		ИмяОбъектаКоллекции = ИТК_МетаданныеКлиентСерверПовтИсп.ИмяОбъектаКоллекции(ИмяКоллекции);
		
		ДоступныеТипыОбъектов = ИТК_МетаданныеКлиентСерверПовтИсп.ДоступныеОбъектыОсновнойТаблицыДинамическогоСписка();
		ДоступнаУниверсальнаяФорма = (ДоступныеТипыОбъектов.Найти(ИмяОбъектаКоллекции) <> Неопределено);
		
	Иначе
		ДоступнаУниверсальнаяФорма = Ложь;
	КонецЕсли;
	
	Элементы.ДеревоКонтекстноеМенюОткрытьУниверсальнуюФорму.Доступность = ДоступнаУниверсальнаяФорма;
	
КонецПроцедуры

&НаКлиенте
Процедура ПересортироватьДерево()
	
	ПолеСортировки = ПолеПредставленияОбъектов(ТипПредставленияОбъктов);
	Для Каждого Строка Из Дерево.ПолучитьЭлементы() Цикл 
		ИТК_ФормаКлиент.СортироватьСтрокиДерева(Строка.ПолучитьЭлементы(), ПолеСортировки);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПолеПредставленияОбъектов(Значение)
	
	Результат = "Представление";
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПолноеПредставление(ТипПредставленияОбъектов, Имя, Синоним)
	
	Если ТипПредставленияОбъектов = ИТК_Перечисления.ПредставлениеОбъектовИмя() Тогда
		
		Представление = Имя;
		Пояснение = Синоним;
		
	Иначе
		
		Представление = Синоним;
		Пояснение = Имя;
		
	КонецЕсли;
	
	СинонимБезПробелов = СтрЗаменить(Синоним, " ", "");
	Если СтрСравнить(Имя, СинонимБезПробелов) = 0 Тогда
		Результат = Представление;
	Иначе
		Результат = СтрШаблон("%1 (%2)", Представление, Пояснение); 
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ОсновнойРодительСтроки(Строка)
	
	Результат = Строка;
	Родитель = Строка.ПолучитьРодителя();
	Пока Родитель <> Неопределено Цикл 
		
		Результат = Родитель;
		Родитель = Родитель.ПолучитьРодителя();
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ПодключаемыйТекущийЭлементСтрокаПоискаПослеОжидания()

	ТекущийЭлемент = Элементы.Поиск;
	
КонецПроцедуры

#КонецОбласти