
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Новое = Параметры.Новое;
	Копирование = Параметры.Копирование;
	
	Идентификатор = Параметры.Идентификатор;
	
	ИТК_Форма.ЗаполнитьСписокПользователей(Элементы.ИмяПользователя.СписокВыбора);
	
	// Заполним список регламентных заданий
	СписокВыбора = Элементы.ИмяРегламентногоЗадания.СписокВыбора;
	Для Каждого РегламентноеЗадание Из Метаданные.РегламентныеЗадания Цикл
		СписокВыбора.Добавить(РегламентноеЗадание.Имя, РегламентноеЗадание.Представление());
	КонецЦикла;
	
	Если НЕ (Новое
				ИЛИ Копирование) Тогда
		
		РегламентноеЗадание = ИТК_РегламентныеЗадания.Получить(Идентификатор);
		ИмяРегламентногоЗадания = РегламентноеЗадание.Метаданные.Имя;
		
		ЗаполнитьФорму(РегламентноеЗадание);
		
	Иначе 
		
		Идентификатор = НСтр("ru = '<Авто>';
							|en = '<Auto>'");
		
		Расписание = Новый РасписаниеРегламентногоЗадания;
		Расписание.ПериодПовтораДней = 1;
		
	КонецЕсли;
	
	ТипЗначенияПараметра = Новый ОписаниеТипов;
	ИТК_ПодключаемыеКоманды.ИнструментыКТаблицеЗначений(ЭтотОбъект, "ПараметрыЗадания");
	
	ОбновитьЭлементыФормыПриСозданииНаСервере();
	
КонецПроцедуры 

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура НаименованиеПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура РегламентноеЗаданиеОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ИмяРегламентногоЗаданияПриИзменении(Элемент)
	
	ЗаполнитьФорму(ИмяРегламентногоЗадания);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйПолноеИмяМетодаНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ЧастиИмениМетода = СтрРазделить(ПолноеИмяМетода, ".");
	
	ИмяМодуля = ЧастиИмениМетода[0];
	ИмяМетода = ЧастиИмениМетода[1];
	
	ИТК_РедакторКодаКлиент.ОткрытьКодМодуля(ИмяМодуля, ИмяМетода);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПараметрыЗадания

&НаКлиенте
Процедура ПараметрыЗаданияПриАктивизацииЯчейки(Элемент)
	
	ИТК_ПодключаемыеКомандыКлиент.ОбновитьЭлементы(ЭтотОбъект, Элемент, "Значение");
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыЗаданияПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЭлементЗначение = Элементы.ПараметрыЗаданияЗначение;
	ИТК_ФормаКлиент.АктивизацияЗначенияВФорме(ЭлементЗначение, ТекущиеДанные.Значение, ТипЗначенияПараметра);
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыЗаданияПриИзменении(Элемент)
	
	Модифицированность = Истина;
	ИТК_ПодключаемыеКомандыКлиент.ОбновитьЭлементы(ЭтотОбъект, Элементы.ПараметрыЗадания);
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыЗаданияЗначениеНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ПараметрыЗадания.ТекущиеДанные;
	
	ЗаголовокПараметра = НСтр("ru = 'Параметр'; en = 'Parameter'");
	
	ДополнительныеПараметры = Новый Структура;
	ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("ВводЗначенияПараметраЗавершен", ЭтотОбъект, ДополнительныеПараметры);
	
	ИТК_ФормаКлиент.ВводЗначенияСтрокиВФорме(ЗаголовокПараметра, Элемент, ТекущиеДанные.Значение,
		ТипЗначенияПараметра, СтандартнаяОбработка, ОписаниеОповещенияЗавершение);
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыЗаданияЗначениеОчистка(Элемент, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.ОчисткаЗначенияСтрокиВФорме(Элемент);
	ИТК_ФормаКлиент.АктивизацияЗначенияВФорме(Элемент, Неопределено, ТипЗначенияПараметра);
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыЗаданияЗначениеОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.ОбработкаВыбораЗначенияВФорме(Элемент, ВыбранноеЗначение, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыЗаданияЗначениеАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	ИТК_ФормаКлиент.АвтоПодборЗначенияВФорме(Текст, Элемент, ДанныеВыбора, СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура НастроитьРасписание(Команда)

	ДиалогРасписанияРегламентногоЗадания = Новый ДиалогРасписанияРегламентногоЗадания(Расписание);
	
	Оповещение = Новый ОписаниеОповещения("НастройкаРасписанияЗавершена", ЭтотОбъект);
	ДиалогРасписанияРегламентногоЗадания.Показать(Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьИЗакрытьВыполнить(Команда)
	
	Свойства = Новый Структура;
	Свойства.Вставить("Ключ");
	Свойства.Вставить("Наименование");
	Свойства.Вставить("Использование");
	Свойства.Вставить("ИмяПользователя");
	Свойства.Вставить("ИнтервалПовтораПриАварийномЗавершении");
	Свойства.Вставить("КоличествоПовторовПриАварийномЗавершении");
	Свойства.Вставить("Расписание");
	Свойства.Вставить("Избранное");
	Свойства.Вставить("ИзбранноеКартинка");
	Свойства.Вставить("Метаданные", ИмяРегламентногоЗадания);
	
	ЗаполнитьЗначенияСвойств(Свойства, ЭтотОбъект);
	
	ИдентификаторЗадания = Неопределено;
	Если Не Новое Тогда
		ИдентификаторЗадания = Новый УникальныйИдентификатор(Идентификатор);
	КонецЕсли;
	Свойства.Вставить("Идентификатор", ИдентификаторЗадания);
	
	ПараметрыРегламентногоЗадания = Новый Массив;
	Для Каждого ЗначениеПараметраЗадания Из ПараметрыЗадания Цикл 
		ПараметрыРегламентногоЗадания.Добавить(ЗначениеПараметраЗадания.Значение);
	КонецЦикла;
	Свойства.Вставить("Параметры", ПараметрыРегламентногоЗадания);
	
	// Избранное
	Свойства.ИзбранноеКартинка = ИТК_ОбщийКлиентСерверПовтИсп.КартинкаИзбранное(Избранное);
	ИТК_ИзбранноеВызовСервера.ЗаписатьВИзбранное(ИТК_Перечисления.ИнструментРегламентныеИФоновыеЗадания(), ИдентификаторЗадания, Избранное);
	
	Закрыть(Свойства);
	
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиКОшибке(Команда)
	
	ОписаниеОшибкиВМодуле = ИТК_КодКлиентСервер.ОписаниеОшибкиВМодуле(Ошибка);
	ИТК_РедакторКодаКлиент.ОткрытьКодМодуля(ОписаниеОшибкиВМодуле.ИмяМодуля, ОписаниеОшибкиВМодуле.НомерСтроки);
	
КонецПроцедуры

#Область ПодключаемыеКоманды

&НаКлиенте
Процедура ПодключаемаяКоманда(Команда)
	
	ИТК_ПодключаемыеКомандыКлиент.ОбработатьКоманду(ЭтотОбъект, Команда.Имя);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйОбработчикКоманд(Команда)
	
	ИТК_ПараметрыЗаписиКлиент.ОбработатьКоманду(ЭтотОбъект, Команда.Имя);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	СозданиеНового = Новое И Не Копирование;
	
	// Заголовок
	Если НЕ ПустаяСтрока(Наименование) Тогда
		Представление = Наименование;
	ИначеЕсли НЕ ПустаяСтрока(СинонимМетаданных) Тогда
		Представление = СинонимМетаданных;
	Иначе
		Представление = ИмяМетаданных;
	КонецЕсли;
	
	Если Новое Тогда
		Заголовок = НСтр("ru = 'Регламентное задание (создание)';
						|en = 'Scheduled job (creation)'");
	Иначе
		Заголовок = СтрШаблон(НСтр("ru = '%1 (Регламентное задание)';
									|en = '%1 (Scheduled job)'"), Представление);
	КонецЕсли;
	
	Элементы.НастроитьРасписание.Заголовок = ИТК_РегламентныеИФоновыеЗаданияКлиентСервер.ПредставлениеРасписания(Расписание);
	Элементы.ИмяРегламентногоЗадания.Доступность = СозданиеНового;
	
	Элементы.СообщенияПользователюИОписаниеИнформацииОбОшибке.Видимость = НЕ Новое;
	
	ПараметрыЗаданияКоличество = ПараметрыЗадания.Количество();
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаРасписанияЗавершена(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Расписание = Результат;
	Модифицированность = Истина;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьФорму(Знач Источник)
	
	Если ТипЗнч(Источник) = Тип("Строка") Тогда
		
		ОбъектМетаданных = Метаданные.РегламентныеЗадания[Источник];
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ОбъектМетаданных);
		Наименование = ОбъектМетаданных.Представление();
		
	ИначеЕсли ТипЗнч(Источник) = Тип("РегламентноеЗадание") Тогда
		
		ОбъектМетаданных = Источник.Метаданные;
		
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, Источник);
		Идентификатор = Источник.УникальныйИдентификатор;
		
		СообщенияИОписаниеИнформацииОбОшибке = ИТК_РегламентныеЗадания.СообщенияИОписанияОшибок(Источник);
		Ошибка = СообщенияИОписаниеИнформацииОбОшибке.Ошибка;
		Сообщения = СтрСоединить(СообщенияИОписаниеИнформацииОбОшибке.Сообщения, Символы.ПС);
		
		ВидИнструмента = ИТК_Перечисления.ИнструментРегламентныеИФоновыеЗадания();
		Избранное = ИТК_Избранное.ОбъектВИзбранном(ВидИнструмента, Источник.УникальныйИдентификатор);
		
		// Заполнение параметров
		Для Каждого ЗначениеПараметраЗадания Из Источник.Параметры Цикл 
			
			НоваяСтрока = ПараметрыЗадания.Добавить();
			НоваяСтрока.Значение = ЗначениеПараметраЗадания;
			
		КонецЦикла;
		ЗаполнитьДополнительныеПолеПараметровЗаданий();
		
	КонецЕсли;
	
	ИмяМетаданных		= ОбъектМетаданных.Имя;
	СинонимМетаданных	= ОбъектМетаданных.Синоним;
	ПолноеИмяМетода		= ОбъектМетаданных.ИмяМетода;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДополнительныеПолеПараметровЗаданий()
	
	Для Каждого СтрокаПараметр Из ПараметрыЗадания Цикл 
		
		ТипЗначения = ТипЗнч(СтрокаПараметр.Значение);
		СтрокаПараметр.ТипПредставление = ИТК_Типы.ПредставлениеТипа(ТипЗначения);
		СтрокаПараметр.ТипКартинка = ИТК_Типы.Картинка(ТипЗначения);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьЭлементыФормыПриСозданииНаСервере()
	
	ВыгруженныеФайлы = ИТК_ФайлыКонфигурации.ПутьКФайлам();
	
	ОписаниеОшибкиВМодуле = ИТК_КодКлиентСервер.ОписаниеОшибкиВМодуле(Ошибка);
	Элементы.ПерейтиКОшибке.Видимость = ЗначениеЗаполнено(ВыгруженныеФайлы) И ЗначениеЗаполнено(ОписаниеОшибкиВМодуле);
	
	Если ЗначениеЗаполнено(ВыгруженныеФайлы) Тогда
		
		ЭлементПолноеИмяМетода = Элементы.ПолноеИмяМетода;
		
		ЭлементПолноеИмяМетода.Вид = ВидПоляФормы.ПолеНадписи;
		ЭлементПолноеИмяМетода.Гиперссылка = Истина;
		ЭлементПолноеИмяМетода.АвтоМаксимальнаяШирина = Ложь;
		
		ЭлементПолноеИмяМетода.УстановитьДействие("Нажатие", "ПодключаемыйПолноеИмяМетодаНажатие");
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПараметрыЗадания) Тогда
		ИТК_ФормаКлиентСервер.ПоказатьГруппу(Элементы.ГруппаПараметры);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВводЗначенияПараметраЗавершен(Результат, ДополнительныеПараметры) Экспорт
	
	ТекущиеДанные = Элементы.ПараметрыЗадания.ТекущиеДанные;
	ИТК_ФормаКлиент.ОбработкаЗавершенВводЗначенияВФорме(Элементы.ПараметрыЗаданияЗначение, Результат,
		ДополнительныеПараметры, ТекущиеДанные.Значение, ТипЗначенияПараметра, Модифицированность);
	
	ЗаполнитьДополнительныеПолеПараметровЗаданий();
	
КонецПроцедуры

#КонецОбласти
