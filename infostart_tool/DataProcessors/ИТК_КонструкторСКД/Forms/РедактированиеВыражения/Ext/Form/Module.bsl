#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Заголовок = НСтр("ru = 'Редактирование выражения';
					|en = 'Editing an expression'");
	ПояснениеЗаголовка = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "Заголовок");
	ИТК_ФормаКлиентСервер.ЗаголовокСРасшифровкой(Заголовок,  ПояснениеЗаголовка);
	
	НачальноеВыражение = Параметры.Выражение;
	Контекст = Параметры.Контекст;
	
	ДополнительныеСвойства = Новый Структура;
	ДополнительныеСвойства.Вставить("ТипЯзыка", ИТК_Перечисления.ТипЯзыкаРедактораВыраженияСКД());
	ДополнительныеСвойства.Вставить("Текст", НачальноеВыражение);
	
	ФиксированныеНастройки = ИТК_РедакторКодаКлиентСервер.ФиксированныеНастройкиВыражения();
	ДополнительныеСвойства.Вставить("ФиксированныеНастройки", ФиксированныеНастройки);
	
	ИТК_РедакторКода.Инициализация(ЭтотОбъект, "Выражение", ДополнительныеСвойства);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИТК_РедакторКодаКлиент.Инициализация(ЭтотОбъект, "Выражение");
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	ИТК_РедакторКодаКлиент.ОбработкаОповещения(ЭтотОбъект, ИмяСобытия, Параметр, Источник);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ИТК_ПодключаемыйДокументСформирован(Элемент)
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Текст", НачальноеВыражение);
	ДополнительныеПараметры.Вставить("ОтображатьНомераСтрок", Ложь);
	
	ПользовательскиеОбъекты = ИТК_РедакторКодаВызовСервера.ПользовательскиеОбъектыВыраженияСКД(Контекст);
	ДополнительныеПараметры.Вставить("ПользовательскиеОбъекты", ПользовательскиеОбъекты);
	
	ИТК_РедакторКодаКлиент.ДополнительнаяИнициализация(ЭтотОбъект, Элемент, ДополнительныеПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ИТК_ПодключаемыйПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	ИТК_РедакторКодаКлиент.ОбработкаСобытий(ЭтотОбъект, Элемент, ДанныеСобытия, СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Сохранить(Команда)
	
	Результат = ИТК_РедакторКодаКлиент.Текст(ЭтотОбъект, "Выражение");
	ОповеститьОВыборе(Результат);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьСправкуПоЯзыкуВыражений(Команда)
	
	ОткрытьСправку("v8help://dcsui/SKD_Functions");
	
КонецПроцедуры

#Область ПодключаемыеКоманды

&НаКлиенте
Процедура ИТК_ПодключаемаяКомандаРедакторКодаОбработчик(Команда)
	
	ИТК_РедакторКодаКлиент.ПодключаемыйОбработчикКоманд(ЭтотОбъект, Команда.Имя);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ИТК_ПодключаемыйВосстановлениеФокусаРедактора() Экспорт 
	
	ИТК_РедакторКодаКлиент.ВосстановлениеФокусаРедактора(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти
