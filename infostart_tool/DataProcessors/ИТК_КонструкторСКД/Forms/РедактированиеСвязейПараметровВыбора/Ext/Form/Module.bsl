#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Заголовок = НСтр("ru = 'Редактирование связей параметров выбора';
					|en = 'Editing selection parameter links'");
	ДоступныеПоля = Параметры.ДоступныеПоля;
	Значение = Параметры.Значение;
	
	// Инициализация значения в форму
	Для Каждого СвязьПараметровВыбора Из Значение Цикл 
		
		НоваяСтрока = СвязиПараметровВыбора.Добавить();
		НоваяСтрока.Имя = СвязьПараметровВыбора.Имя;
		НоваяСтрока.Поле = СвязьПараметровВыбора.Поле;
		НоваяСтрока.Очищать = (СвязьПараметровВыбора.ИзменениеЗначения = РежимИзмененияСвязанногоЗначения.Очищать);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыСвязиПараметровВыбора

&НаКлиенте
Процедура СвязиПараметровВыбораПолеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ИТК_СКДКлиент.ОткрытьВыборПоля(Элемент, ДоступныеПоля, СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СохранитьИЗакрыть(Команда)
	
	Результат = Значение;
	Результат.Очистить();
	
	Для Каждого СтрокаСвязьПараметровВыбора Из СвязиПараметровВыбора Цикл 
		
		СвязьПараметровВыбора = Результат.Добавить();
		СвязьПараметровВыбора.Имя = СтрокаСвязьПараметровВыбора.Имя;
		СвязьПараметровВыбора.Поле = Новый ПолеКомпоновкиДанных(СтрокаСвязьПараметровВыбора.Поле);
		
		Если СтрокаСвязьПараметровВыбора.Очищать Тогда
			ИзменениеЗначения = РежимИзмененияСвязанногоЗначения.Очищать;
		Иначе
			ИзменениеЗначения = РежимИзмененияСвязанногоЗначения.НеИзменять;
		КонецЕсли;
		СвязьПараметровВыбора.ИзменениеЗначения = ИзменениеЗначения;
		
	КонецЦикла;
	
	Закрыть(Результат);

КонецПроцедуры

#КонецОбласти
