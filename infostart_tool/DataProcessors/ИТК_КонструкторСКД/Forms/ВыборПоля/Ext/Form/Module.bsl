#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Поле = СокрЛП(Параметры.Поле);
	ЭтоПолеПредставления = Параметры.ЭтоПолеПредставления;
	ПервоначальноеЗаполнениеДерева(Параметры.ДоступныеПоля);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИнициализацияСтрокиВыбранногоПоля(Поле);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовДереваДоступныеПоля

&НаКлиенте
Процедура ДоступныеПоляВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если НЕ ТекущиеДанные.Выбирается Тогда
		Возврат;
	КонецЕсли;
	
	Выбрать();

КонецПроцедуры

&НаКлиенте
Процедура ДоступныеПоляПередРазворачиванием(Элемент, Строка, Отказ)
	
	РазворачиваемаяСтрока = ДоступныеПоля.НайтиПоИдентификатору(Строка);
	
	Если ИТК_ФормаКлиентСервер.НеобходимоРазвернутьСтроку(РазворачиваемаяСтрока) Тогда
		
		РазвернутьСтрокуКоллекции(Строка);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Выбрать(Команда = Неопределено)
	
	ТекущиеДанные = Элементы.ДоступныеПоля.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено
			ИЛИ НЕ ТекущиеДанные.Выбирается Тогда
		Возврат;
	КонецЕсли;
	
	Результат = ПолноеИмяПоля(ТекущиеДанные);
	
	Если ЭтоПолеПредставления 
			И ИТК_ТипыКлиентСервер.ЕстьСсылочныеТипы(ТекущиеДанные.ТипЗначения) Тогда
			
		Шаблон = "Представление(%1)";
		Результат = СтрШаблон(Шаблон, Результат);
			
	КонецЕсли;

	ОповеститьОВыборе(Результат);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПервоначальноеЗаполнениеДерева(НачальныеДоступныеПоля)
	
	Для Каждого ДоступноеПоле Из НачальныеДоступныеПоля Цикл 
		
		ДоступноеПолеЗначение = ДоступноеПоле.Значение;
		НоваяСтрока = ДобавитьСтрокуДерева(ДоступныеПоля, ДоступноеПолеЗначение, ДоступноеПоле.Представление); 
		
		Если ТипЗнч(ДоступноеПолеЗначение) <> Тип("СписокЗначений") Тогда
			Продолжить;
		КонецЕсли;
			
		Для Каждого ДоступноеПолеНабора Из ДоступноеПолеЗначение Цикл 
			
			ДобавитьСтрокуДерева(НоваяСтрока, ДоступноеПолеНабора.Значение, ДоступноеПолеНабора.Представление); 
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ДобавитьСтрокуДерева(Родитель, ТипЗначения, Представление = "")

	НоваяСтрока = Родитель.ПолучитьЭлементы().Добавить();
	
	Выбирается = (ТипЗнч(ТипЗначения) <> Тип("СписокЗначений"));
	НоваяСтрока.Выбирается = Выбирается;
	
	Если Выбирается Тогда
		
		Картинка = ИТК_Типы.КартинкаОписания(ТипЗначения);
		НоваяСтрока.ТипЗначения = ТипЗначения;
		
		Если ИТК_ТипыКлиентСервер.ЕстьСсылочныеТипы(ТипЗначения, Истина) Тогда
			ДобавитьСтрокуДерева(НоваяСтрока, Новый ОписаниеТипов);
		КонецЕсли;
		
	Иначе
		
		Картинка = БиблиотекаКартинок.ВложеннаяТаблица;
		
	КонецЕсли;
	НоваяСтрока.Картинка = Картинка;
	
	НоваяСтрока.Представление = Представление;
	
    Возврат НоваяСтрока;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция НайтиСтрокуДерева(Родитель, Имя)
	
	Результат = Неопределено;
	Для Каждого Строка Из Родитель.ПолучитьЭлементы() Цикл 
		
		Если Строка.Представление = Имя Тогда
			
			Результат = Строка;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ПолноеИмяПоля(Знач Строка)
	
	Результат = Новый Массив;
	
	Пока Строка <> Неопределено Цикл 
		
		Результат.Вставить(0, Строка.Представление);
		Строка = Строка.ПолучитьРодителя();
		
	КонецЦикла;
	
	Возврат СтрСоединить(Результат, ".");
	
КонецФункции

&НаСервере
Процедура РазвернутьСтрокуКоллекции(ИдентификаторСтроки)

	РазворачиваемаяСтрока = ДоступныеПоля.НайтиПоИдентификатору(ИдентификаторСтроки);
	РазворачиваемаяСтрока.ПолучитьЭлементы().Очистить();
	
	ДоступныеПоляСтроки = ИТК_СКД.ДоступныеПоляВыбора(РазворачиваемаяСтрока.ТипЗначения);
	Для Каждого ОписаниеДоступногоПоля Из ДоступныеПоляСтроки Цикл 
		
		ЗначениеДоступногоПоля = ОписаниеДоступногоПоля.Значение;
		ИмяДоступногоПоля = ОписаниеДоступногоПоля.Имя;
		
		Если ТипЗнч(ЗначениеДоступногоПоля) = Тип("СписокЗначений") Тогда
			
			СтрокаТЧ = ДобавитьСтрокуДерева(РазворачиваемаяСтрока, ЗначениеДоступногоПоля, ИмяДоступногоПоля);
			Для Каждого ДоступноеПолеНабора Из ЗначениеДоступногоПоля Цикл 
				
				ДобавитьСтрокуДерева(СтрокаТЧ, ДоступноеПолеНабора.Значение, ДоступноеПолеНабора.Представление); 
				
			КонецЦикла;
			
		Иначе
			
			ДобавитьСтрокуДерева(РазворачиваемаяСтрока, ЗначениеДоступногоПоля, ИмяДоступногоПоля);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ИнициализацияСтрокиВыбранногоПоля(Поле)
	
	Результат = ИнициализацияСтрокиВыбранногоПоляСервер(Поле);
	
	Если НЕ Результат.Активизировать Тогда
		Возврат;
	КонецЕсли;
	
	Родитель = ДоступныеПоля;
	Для Каждого ЧастьИмениПоля Из Результат.Части Цикл 
		
		НайденнаяСтрока = НайтиСтрокуДерева(Родитель, ЧастьИмениПоля);
		Родитель = НайденнаяСтрока;
		
		ИдентификаторСтроки = НайденнаяСтрока.ПолучитьИдентификатор();
		Элементы.ДоступныеПоля.Развернуть(ИдентификаторСтроки);
		
	КонецЦикла;
	
	Элементы.ДоступныеПоля.ТекущаяСтрока = ИдентификаторСтроки;
	
КонецПроцедуры

&НаСервере
Функция ИнициализацияСтрокиВыбранногоПоляСервер(Поле)
	
	ЧастиПоля = СтрРазделить(Поле, ".");
	АктивизироватьСтроку = Истина;
	
	Родитель = ДоступныеПоля;
	Для Каждого ЧастьПоля Из ЧастиПоля Цикл 
		
		НайденнаяСтрока = НайтиСтрокуДерева(Родитель, ЧастьПоля);
		Если НайденнаяСтрока = Неопределено Тогда
			
			АктивизироватьСтроку = Ложь;
			Прервать;
			
		Иначе
			
			Если ИТК_ФормаКлиентСервер.НеобходимоРазвернутьСтроку(НайденнаяСтрока) Тогда
				
				РазвернутьСтрокуКоллекции(НайденнаяСтрока.ПолучитьИдентификатор());
				
			КонецЕсли;
			
			Родитель = НайденнаяСтрока;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Результат = Новый Структура;
	Результат.Вставить("Активизировать", АктивизироватьСтроку);
	Результат.Вставить("Части", ЧастиПоля);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
