#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Заголовок = НСтр("ru = 'Связь по типу';
					|en = 'Relationship by type'");
	ДоступныеПоля = Параметры.ДоступныеПоля;
	
	// Инициализация значения в форму
	СвязьПоТипу = Параметры.Значение;
	Поле = СвязьПоТипу.Поле;
	ЭлементСвязи = СвязьПоТипу.ЭлементСвязи;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПолеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ИТК_СКДКлиент.ОткрытьВыборПоля(Элемент, ДоступныеПоля, СтандартнаяОбработка);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СохранитьИЗакрыть(Команда)
	
	ПолеКомпоновкиДанных = Новый ПолеКомпоновкиДанных(Поле);
	Результат = Новый СвязьПоТипуКомпоновкиДанных(ПолеКомпоновкиДанных, ЭлементСвязи);
	
	Закрыть(Результат);

КонецПроцедуры

#КонецОбласти