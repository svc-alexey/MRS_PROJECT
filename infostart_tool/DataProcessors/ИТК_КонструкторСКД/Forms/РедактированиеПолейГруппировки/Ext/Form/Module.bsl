#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Заголовок = НСтр("ru = 'Редактирование полей группировки';
					|en = 'Editing grouping fields'");
	
	СтрокаВсе = ПоляГруппировки.ПолучитьЭлементы().Добавить();
	СтрокаВсе.Значение = НСтр("ru = 'Все';
								|en = 'All'");
	
	Для Каждого ПолеГруппировки Из Параметры.Значение Цикл 
		
		НоваяСтрока = СтрокаВсе.ПолучитьЭлементы().Добавить();
		НоваяСтрока.Рассчитывать = ПолеГруппировки.Пометка;
		НоваяСтрока.Значение = ПолеГруппировки.Представление;
		
		ТипЗначения = ПолеГруппировки.Значение;
		НоваяСтрока.КартинкаТип = ИТК_Типы.КартинкаОписания(ТипЗначения);
		
	КонецЦикла;
	
	УстановитьУсловноеОформление();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовДереваПоляГруппировки

&НаКлиенте
Процедура ПоляГруппировкиРассчитыватьПриИзменении(Элемент)
	
	ИмяПометки = "Рассчитывать";
	Строка = Элемент.Родитель.ТекущиеДанные;
	
	Пометка = ИТК_ФормаКлиент.ОпределитьПометкуТриСостояния(Строка, ИмяПометки);
	
	ИТК_ФормаКлиент.ДеревоУстановитьПодчиненнымПометку(Строка, Пометка, ИмяПометки);
	ИТК_ФормаКлиент.ДеревоОпределитьПометкуРодителя(Строка, Пометка, ИмяПометки);

КонецПроцедуры

&НаКлиенте
Процедура ПоляГруппировкиПередСворачиванием(Элемент, Строка, Отказ)
	
	Отказ = Истина;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СохранитьИЗакрыть(Команда)
	
	Результат = Новый СписокЗначений;
	
	СтрокаВсе = ПоляГруппировки.ПолучитьЭлементы()[0];
	Для Каждого Строка Из СтрокаВсе.ПолучитьЭлементы() Цикл 
		
		Если НЕ Строка.Рассчитывать Тогда
			Продолжить;
		КонецЕсли;
		
		Результат.Добавить(Строка.Значение);
		
	КонецЦикла;
	
	ОповеститьОВыборе(Результат);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции
&НаСервере
Процедура УстановитьУсловноеОформление()
	
	Оформление = Новый Структура("Шрифт", ИТК_ОбщийКлиентСервер.ШрифтЖирный());
	
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "ПоляГруппировкиЗначение", Оформление, "ПоляГруппировки.Значение",
											ИТК_СКДКлиентСервер.ИмяПоляИтогаОбщийИтог());

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// Определение пометки родителя
	СтрокаВсе = ПоляГруппировки.ПолучитьЭлементы()[0];
	Для Каждого Строка Из СтрокаВсе.ПолучитьЭлементы() Цикл 
		
		ИТК_ФормаКлиент.ДеревоОпределитьПометкуРодителя(Строка, Строка.Рассчитывать, "Рассчитывать");
		
	КонецЦикла;

КонецПроцедуры

#КонецОбласти
