#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СохранитьИЗакрыть(Команда)
	
	Результат = ПредставлениеИОписаниеРоли();
	Закрыть(Результат);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	Элементы.Период.Доступность = РольПериод;
	Элементы.ПериодДополнительный.Доступность = РольПериод;
	
	Элементы.ИзмерениеРодитель.Доступность = РольИзмерение;
	
	Элементы.ВыражениеВидаСчета.Доступность = РольСчет;
	
	Элементы.ОстатокИмя.Доступность = РольОстаток;
	Элементы.ОстатокТип.Доступность = РольОстаток;
	Элементы.ОстатокБухТип.Доступность = РольОстаток;
	Элементы.ОстатокПолеСчета.Доступность = РольОстаток;
	
КонецПроцедуры

&НаСервере
Функция ПредставлениеИОписаниеРоли()
	
	ОписаниеРоли = Новый Структура;
	Если РольПериод Тогда
		
		ОписаниеРоли.Вставить("НомерПериода", Период);
		Если ПериодДополнительный Тогда
			ТипПериода = "Дополнительный";
		Иначе
			ТипПериода = "Основной";
		КонецЕсли;
		ОписаниеРоли.Вставить("ТипПериода", ТипПериода);
		
	ИначеЕсли РольИзмерение Тогда
		
		ОписаниеРоли.Вставить("Измерение", Истина);
		ОписаниеРоли.Вставить("РодительскоеИзмерение", ИзмерениеРодитель);
		
	ИначеЕсли РольСчет Тогда
		
		ОписаниеРоли.Вставить("Счет", Истина);
		ОписаниеРоли.Вставить("ВыражениеВидаСчета", ВыражениеВидаСчета);
		
	ИначеЕсли РольОстаток Тогда
		
		ОписаниеРоли.Вставить("Остаток", Истина);
		ОписаниеРоли.Вставить("ГруппаОстатка", ОстатокИмя);
		ОписаниеРоли.Вставить("ТипОстатка", ОстатокТип);
		ОписаниеРоли.Вставить("ТипБухгалтерскогоОстатка", ОстатокБухТип);
		ОписаниеРоли.Вставить("ПолеСчета", ОстатокПолеСчета);
		
	КонецЕсли;
	
	Если Обязательное Тогда
		ОписаниеРоли.Вставить("Обязательное", Обязательное);
	КонецЕсли;
	
	Если ИгнорироватьЗначенияNULL Тогда
		ОписаниеРоли.Вставить("ИгнорироватьЗначенияNULL", ИгнорироватьЗначенияNULL);
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ОписаниеРоли", ОписаниеРоли);
	
	Представление = ИТК_СКД.ПредставлениеОписанияРолиПоляНабораДанных(ОписаниеРоли);
	Результат.Вставить("Представление", Представление);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
