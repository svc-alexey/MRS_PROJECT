#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Поле = Параметры.Поле;
	КонтекстВыражения = Параметры.КонтекстВыражения;
	
	Шаблон = НСтр("ru = 'Роль - %1';
					|en = 'Role - %1'");
	Заголовок = СтрШаблон(Шаблон, Поле);
	
	// Группа остатков
	ЭлементГруппаОстатков = Элементы.ОстатокИмя;
	ЭлементГруппаОстатков.СписокВыбора.ЗагрузитьЗначения(Параметры.ВариантыИменРолиОстаток);
	ЭлементГруппаОстатков.КнопкаВыпадающегоСписка = ЗначениеЗаполнено(ЭлементГруппаОстатков.СписокВыбора);
	
	СписокВыбора = Элементы.ОстатокТип.СписокВыбора;
	СписокВыбора.Добавить("Нет", НСтр("ru = 'Нет';
										|en = 'No'"));
	СписокВыбора.Добавить("НачальныйОстаток", НСтр("ru = 'Начальный остаток';
													|en = 'Initial balance'"));
	СписокВыбора.Добавить("КонечныйОстаток", НСтр("ru = 'Конечный остаток';
													|en = 'Final balance'"));
	ОстатокТип = СписокВыбора[0].Значение;
	
	СписокВыбора = Элементы.ОстатокБухТип.СписокВыбора;
	СписокВыбора.Добавить("Нет", НСтр("ru = 'Нет';
										|en = 'No'"));
	СписокВыбора.Добавить("Дебет", НСтр("ru = 'Дебет';
										|en = 'Debit'"));
	СписокВыбора.Добавить("Кредит", НСтр("ru = 'Кредит';
										|en = 'Credit'"));
	ОстатокБухТип = СписокВыбора[0].Значение;
	
	// Инициализация роли
	НачальноеЗначение = Параметры.Значение;
	НомерПериода = ИТК_ОбщийКлиентСервер.Свойство(НачальноеЗначение, "НомерПериода");
	РольИзмерение = ИТК_ОбщийКлиентСервер.Свойство(НачальноеЗначение, "Измерение", Ложь);
	РольСчет = ИТК_ОбщийКлиентСервер.Свойство(НачальноеЗначение, "Счет", Ложь);
	РольОстаток = ИТК_ОбщийКлиентСервер.Свойство(НачальноеЗначение, "Остаток", Ложь);
	Если ЗначениеЗаполнено(НомерПериода) Тогда 
		
		РольПериод = Истина;
		Период = НомерПериода;
		
		ТипПериода = НачальноеЗначение.ТипПериода;
		ПериодДополнительный = (ТипПериода = "Дополнительный");
		
	ИначеЕсли РольИзмерение Тогда 
		
		ИзмерениеРодитель = НачальноеЗначение.РодительскоеИзмерение;
		
	ИначеЕсли РольСчет Тогда 
		
		ВыражениеВидаСчета = НачальноеЗначение.ВыражениеВидаСчета;
		
	ИначеЕсли РольОстаток Тогда 
		
		ОстатокИмя = НачальноеЗначение.ГруппаОстатка;
		ОстатокТип = НачальноеЗначение.ТипОстатка;
		ОстатокБухТип = НачальноеЗначение.ТипБухгалтерскогоОстатка;
		ОстатокПолеСчета = НачальноеЗначение.ПолеСчета;
		
	Иначе
		
		БезРоли = Истина;
		
	КонецЕсли;
	
	ИгнорироватьЗначенияNULL = ИТК_ОбщийКлиентСервер.Свойство(НачальноеЗначение, "ИгнорироватьЗначенияNULL", Ложь);
	Обязательное = ИТК_ОбщийКлиентСервер.Свойство(НачальноеЗначение, "Обязательное", Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура РольПриИзменении(Элемент)
	
	ИмяРеквизита = Элемент.Имя;
	УстановленФлаг = ЭтотОбъект[ИмяРеквизита];
	
	Если Не УстановленФлаг Тогда
		
		ЭтотОбъект[ИмяРеквизита] = Истина;
		Возврат;
		
	КонецЕсли;
	
	Если Элемент = Элементы.РольПериод
			И Период = 0 Тогда
		Период = 1;
	КонецЕсли;
	
	ВсеЭлементыРолей = Новый Массив;
	ВсеЭлементыРолей.Добавить(Элементы.БезРоли);
	ВсеЭлементыРолей.Добавить(Элементы.РольПериод);
	ВсеЭлементыРолей.Добавить(Элементы.РольИзмерение);
	ВсеЭлементыРолей.Добавить(Элементы.РольСчет);
	ВсеЭлементыРолей.Добавить(Элементы.РольОстаток);

	Для Каждого ЭлементРоль Из ВсеЭлементыРолей Цикл 
		
		Если ЭлементРоль = Элемент Тогда
			Продолжить;
		КонецЕсли;
		
		ЭтотОбъект[ЭлементРоль.Имя] = Ложь;
		
	КонецЦикла;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ИзмерениеРодительНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
 	ИТК_СКДКлиент.ОткрытьВыборПоля(Элемент, КонтекстВыражения.ДоступныеПоля, СтандартнаяОбработка);
	
КонецПроцедуры

