&НаКлиенте
Процедура ПараметрыСКДТипЗначенияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ПараметрыСКД.ТекущиеДанные;

	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Системные", Истина);
	
	РежимРедактирования = ИТК_Перечисления.РежимРедактированияТипаЗначенияРедактированиеОписанияТипов();
	ОписаниеОповещения = Новый ОписаниеОповещения("РедактированиеТипаЗначенияПараметраСКДЗавершено", ЭтотОбъект, Новый Структура);
	
	ИТК_ФормаКлиент.ОткрытьРедактированиеТипаЗначения(ЭтотОбъект, ТекущиеДанные.Имя, РежимРедактирования, ТекущиеДанные.ТипЗначения, ОписаниеОповещения, СтандартнаяОбработка, ДополнительныеПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыСКДЗначениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ПараметрыСКД.ТекущиеДанные;
	
	Если ТекущиеДанные.ДоступенСписокЗначений Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("РедактированиеЗначениеПараметраСКДВСпискеЗавершено", ЭтотОбъект);
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("ДополнениеЗаголовка", НСтр("ru = 'Значение';
																	|en = 'Value'"));
		
		ИТК_ФормаКлиент.ОткрытьСписокЗначений(ЭтотОбъект, ИТК_Перечисления.ВариантФормыСписокЗначенийРедактирование(),
													ТекущиеДанные.Значение, ТекущиеДанные.ТипЗначения,
													ОписаниеОповещения, СтандартнаяОбработка, ДополнительныеПараметры);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыСКДДоступныеЗначенияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ПараметрыСКД.ТекущиеДанные;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("РедактированиеДоступныхЗначенийПараметраСКДВСпискеЗавершено", ЭтотОбъект);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ДополнениеЗаголовка", ТекущиеДанные.Поле);
	
	ИТК_ФормаКлиент.ОткрытьСписокЗначений(ЭтотОбъект, ИТК_Перечисления.ВариантФормыСписокЗначенийРедактированиеСПредставлением(),
											ТекущиеДанные.ДоступныеЗначения, ТекущиеДанные.ТипЗначения,
											ОписаниеОповещения, СтандартнаяОбработка, ДополнительныеПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыСКДВыражениеОткрытие(Элемент, СтандартнаяОбработка)
	
	КонтекстВыражения = КонтекстВыражения(Ложь);
	ОткрытьРедактированиеВыражения(Элемент, КонтекстВыражения, "Выражение", СтандартнаяОбработка);

КонецПроцедуры

&НаКлиенте
Процедура ПараметрыСКДДоступенСписокЗначенийПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ПараметрыСКД.ТекущиеДанные;
	ТекущееЗначение = ТекущиеДанные.Значение;
	
	Если ТекущиеДанные.ДоступенСписокЗначений Тогда
		
		НовоеЗначение = Новый СписокЗначений;
		Если ЗначениеЗаполнено(ТекущееЗначение) Тогда
			НовоеЗначение.Добавить(ТекущееЗначение);
		КонецЕсли;
		
	Иначе	
		
		Если ЗначениеЗаполнено(ТекущееЗначение) Тогда
			НовоеЗначение = ТекущееЗначение[0].Значение;
		КонецЕсли;
		
	КонецЕсли;
	
	ТекущиеДанные.Значение = НовоеЗначение;	
	ПривестиЗначениеПараметраСКДВТекущейСтроке();
	
КонецПроцедуры

