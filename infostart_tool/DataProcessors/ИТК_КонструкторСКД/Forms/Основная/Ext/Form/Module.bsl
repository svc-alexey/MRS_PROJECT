&НаСервере
Процедура ЗагрузитьМакетыСхемыКомпоновкиДанныхВДанныеФормы(СхемаКомпоновкиДанных)
	
	Макет.Очистить();
	Макеты.Очистить();
	
	ДобавитьЭлементыМакетов(СхемаКомпоновкиДанных.Макеты, СхемаКомпоновкиДанных.МакетыПолей);
	ДобавитьЭлементыМакетов(СхемаКомпоновкиДанных.Макеты, СхемаКомпоновкиДанных.МакетыГруппировок);
	ДобавитьЭлементыМакетов(СхемаКомпоновкиДанных.Макеты, СхемаКомпоновкиДанных.МакетыЗаголовковГруппировок, Истина);
	ДобавитьЭлементыМакетов(СхемаКомпоновкиДанных.Макеты, СхемаКомпоновкиДанных.МакетыПолейИтога);
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьЭлементыМакетов(МакетыСКД, КоллекцияМакетов, Заголовки = Ложь)
	
	ОбъектОбработка = РеквизитФормыВЗначение("Объект");
	ОбластьРазделительОбластейМакета = ОбъектОбработка.ПолучитьМакет("Макет").ПолучитьОбласть("РазделительОбластейМакета");
	
	НомерСтроки = 1;
	Для Каждого ОписаниеМакета Из КоллекцияМакетов Цикл 
		
		Вид  = ИТК_СКД.ПеречислениеВидМакета(ОписаниеМакета, Заголовки);
		Значение = ИТК_СКД.ЗначениеМакета(Вид, ОписаниеМакета);
		
		НовыйМакет = Макеты.Добавить();
		
		НовыйМакет.Вид = Вид;
		НовыйМакет.Картинка = ИТК_КонструкторСКДКлиентСервер.КартинкаМакета(Вид);
		НовыйМакет.Представление = ИТК_СКДКлиентСервер.ПредставлениеМакета(Значение);
		НовыйМакет.Значение = Значение;
		
		ПодробноеОписаниеМакета = МакетыСКД.Найти(ОписаниеМакета.Макет);
		МакетОбласти = ПодробноеОписаниеМакета.Макет;
		
		Если МакетОбласти = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Макет.Вывести(ОбластьРазделительОбластейМакета);
		НомерСтроки = НомерСтроки + 1;
		
		НомерСтрокиНачалоОбласти = НомерСтроки;
		НомерСтрокиКонецОбласти = НомерСтроки + МакетОбласти.Количество() - 1;
		
		// Заполнение областей
		НомерКолонкиКонцаОбласти = 0;
		Для Каждого СтрокаОбластиТаблицы Из МакетОбласти Цикл 
			
			ОбластьСтрока = Новый ТабличныйДокумент;
			
			НомерКолонкиКонцаОбласти = Макс(НомерКолонкиКонцаОбласти, СтрокаОбластиТаблицы.Ячейки.Количество());
			Для Каждого ЯчейкаОбластиТаблицы Из СтрокаОбластиТаблицы.Ячейки Цикл 
				
				ОбластьЯчейка = Новый ТабличныйДокумент;
				ДанныеОбластиЯчейка = ОбластьЯчейка.Область(1, 1);
				
				// Содержимое области
				Для Каждого ЯчейкаОбластиТаблицы Из ЯчейкаОбластиТаблицы.Элементы Цикл 
					ДанныеОбластиЯчейка.Текст = ЯчейкаОбластиТаблицы.Значение;
				КонецЦикла;
				
				// Оформление области
				Для Каждого ЭлементОформления Из ЯчейкаОбластиТаблицы.Оформление.Элементы Цикл 
					
					Если НЕ ЭлементОформления.Использование Тогда
						Продолжить;
					КонецЕсли;
					
					ИмяОформления = Строка(ЭлементОформления.Параметр);
					Если ИмяОформления = "МинимальнаяШирина" 
							ИЛИ ИмяОформления = "МаксимальнаяШирина" 
							ИЛИ ИмяОформления = "ОбъединятьПоГоризонтали" 
							ИЛИ ИмяОформления = "ОбъединятьПоВертикали"
							Тогда
						Продолжить;
					КонецЕсли;
					
					ДанныеОбластиЯчейка[ИмяОформления] = ЭлементОформления.Значение;

				КонецЦикла;
				
				ВыводимаяОбластьЯчейки = ОбластьЯчейка.ПолучитьОбласть(1, 1);
				ОбластьСтрока.Присоединить(ВыводимаяОбластьЯчейки);
				
			КонецЦикла;
			
			НомерСтроки = НомерСтроки + 1;
			Макет.Вывести(ОбластьСтрока);
			
		КонецЦикла;
		
		ШаблонПредставленияОбласти = "R%1C1:R%2C%3";
		НовыйМакет.Область = СтрШаблон(ШаблонПредставленияОбласти, ИТК_Строки.ЧислоВСтроку(НомерСтрокиНачалоОбласти),
											ИТК_Строки.ЧислоВСтроку(НомерСтрокиКонецОбласти), ИТК_Строки.ЧислоВСтроку(НомерКолонкиКонцаОбласти));
		
		// Заполнение параметров
		Для Каждого ПараметрМакета Из ПодробноеОписаниеМакета.Параметры Цикл 
			
			НовыйПараметр = НовыйМакет.ПараметрыМакета.Добавить();
			ЗаполнитьЗначенияСвойств(НовыйПараметр, ПараметрМакета);

		КонецЦикла;

	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьВложенныеСхемыСхемыКомпоновкиДанныхВДанныеФормы(СхемаКомпоновкиДанных)
	
	ВложенныеСхемы.Очистить();
	
	Для Каждого ВложеннаяСхема Из СхемаКомпоновкиДанных.ВложенныеСхемыКомпоновкиДанных Цикл 
		
		ИмяВложеннойСхемы = ВложеннаяСхема.Имя;
		
		НоваяВложеннаяСхема = ВложенныеСхемы.Добавить();
		НоваяВложеннаяСхема.Имя = ИмяВложеннойСхемы;
		
		ЛокализированнаяСтрокаНСтр = ИТК_СКД.ЛокализированнаяСтрокаНСтрИзXDTO(ВложеннаяСхема, "title");
		НоваяВложеннаяСхема.Заголовок = ЛокализированнаяСтрокаНСтр;
		НоваяВложеннаяСхема.ЗаголовокПредставление = ПредставлениеЗаголовкаПоляКоллекции(ЛокализированнаяСтрокаНСтр, ИмяВложеннойСхемы);
		
		НоваяВложеннаяСхема.Схема = ИТК_СКД.XMLТекст(ВложеннаяСхема.Схема);
		НоваяВложеннаяСхема.Настройки = ИТК_СКД.XMLТекст(ВложеннаяСхема.Настройки);
		
		ИдентификаторСтроки = НоваяВложеннаяСхема.ПолучитьИдентификатор();
		ЗаполнитьПредставлениеСтрокиВложеннаяСхема(ИдентификаторСтроки);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПредставлениеСтрокиВложеннаяСхема(Идентификатор)
	
	Строка = ВложенныеСхемы.НайтиПоИдентификатору(Идентификатор);
	
	Строка.СхемаПредставление = НСтр("ru = 'Схема';
									|en = 'Scheme'");
	Строка.НастройкиПредставление = НСтр("ru = 'Настройки';
										|en = 'Settings'");
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьСхемуКомпоновкиДанныхИзФайлаПослеПомещенияФайлов(ПомещенныеФайлы, ДополнительныеПараметры) Экспорт
	
	Если ПомещенныеФайлы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗагрузитьФайлСхемыКомпоновкиДанныхНаСервере(ПомещенныеФайлы[0].Хранение);
	ПослеЗагрузкиСхемыКомпоновкиДанных();
	
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаСервере
Процедура ЗагрузитьФайлСхемыКомпоновкиДанныхНаСервере(Адрес)
	
	ИсточникиДанных.Очистить();
	НаборыДанных.ПолучитьЭлементы().Очистить();
	
	Данные = ПолучитьИзВременногоХранилища(Адрес);
	
	ЧтениеТекста = Новый ЧтениеТекста(Данные.ОткрытьПотокДляЧтения());
	СхемаКомпоновкиДанныхXML = ЧтениеТекста.Прочитать();
	ЧтениеТекста.Закрыть();
	
	ЗагрузитьСхемуКомпоновкиДанныхИзТекста(СхемаКомпоновкиДанныхXML);
	ЗагрузитьСхемуКомпоновкиДанныхВДанныеФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьСхемуКомпоновкиДанныхВФайлЗавершениеВыбораФайла(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныеФайлы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОбновитьОсновнуюСхемуКомпоновкиДанныхИзДанныхФормы();
	
	ПолноеИмяФайла = ВыбранныеФайлы[0];
	
	СхемаКомпоновкиДанныхXML =  ИТК_СКД.XMLТекстИзАдреса(АдресСхемыКомпоновкиДанных);
	ИТК_ФайлыКлиентСервер.ЗаписатьТекст(ПолноеИмяФайла, СхемаКомпоновкиДанныхXML);

КонецПроцедуры

&НаКлиенте
Функция ВложенВОбъединение(Строка)
	
	Результат = Ложь;
	
	Родитель = Строка;
	Пока Истина Цикл
		
		Родитель = Родитель.ПолучитьРодителя();
		
		Если Родитель = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		Если Родитель.Вид = ИТК_Перечисления.СКДНаборДанныхОбъединение() Тогда
			Результат = Истина;
			Прервать;
		КонецЕсли;

	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьПоляНабораДанныхОбъединение(Идентификатор)
	
	// Собрать поля объединений
	ДобавляемыеПоля = Новый Массив;
	СтрокаНаборДанных = НаборыДанных.НайтиПоИдентификатору(Идентификатор);
	
	СобратьПоляНабораДанныхОбъединениеРекурсивно(СтрокаНаборДанных, ДобавляемыеПоля);
	
	КоллекцияПолей = СтрокаНаборДанных.Поля;
	
	// Удаляем неиспользуемые поля
	УдаляемыеСтрокиПоля = Новый Массив;
	Для Каждого Поле Из КоллекцияПолей Цикл 
		
		НайденныйИндекс = ДобавляемыеПоля.Найти(Поле.Поле);
		Если НайденныйИндекс = Неопределено Тогда
			УдаляемыеСтрокиПоля.Добавить(Поле);
		Иначе
			ДобавляемыеПоля.Удалить(НайденныйИндекс);
		КонецЕсли;

	КонецЦикла;
	
	Для Каждого УдаляемаяСтрока Из УдаляемыеСтрокиПоля Цикл 
		КоллекцияПолей.Удалить(УдаляемаяСтрока);
	КонецЦикла;
	
	// Добавляем поля
	Для Каждого ИмяПоля Из ДобавляемыеПоля Цикл 
		
		НовоеПоле = КоллекцияПолей.Добавить();
		НовоеПоле.Поле = ИмяПоля;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура СобратьПоляНабораДанныхОбъединениеРекурсивно(Строка, Результат)
	
	Для Каждого ВложеннаяСтрока Из Строка.ПолучитьЭлементы() Цикл 
		
		Если ВложеннаяСтрока.Вид = ИТК_Перечисления.СКДНаборДанныхОбъединение() Тогда
			СобратьПоляНабораДанныхОбъединениеРекурсивно(ВложеннаяСтрока, Результат);
			Продолжить;
		КонецЕсли;
		
		Для Каждого Поле Из ВложеннаяСтрока.Поля Цикл 
			
			Если Поле.Вид <> ИТК_Перечисления.СКДВидыПолейНаборовДанныхПоле() Тогда
				Продолжить;
			КонецЕсли;
			
			ИмяПоля = Поле.Поле;
			Если Результат.Найти(ИмяПоля) = Неопределено Тогда
				Результат.Добавить(ИмяПоля);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура НачалоВыбораНабораДанныхИзСписка(Элемент, СтандартнаяОбработка, ДополнительныеПараметры = Неопределено)
	
	СтандартнаяОбработка = Ложь;
	
	СписокВыбора = Элемент.СписокВыбора;
	СписокВыбора.Очистить();

	ИсключитьТекущий = ИТК_ОбщийКлиентСервер.Свойство(ДополнительныеПараметры, "ИсключитьТекущий", Ложь);
	СписокНаборовДанных = СписокНаборовДанных(ИсключитьТекущий);
	
	Для Каждого НаборДанных Из СписокНаборовДанных Цикл 
		СписокВыбора.Добавить(НаборДанных.Значение, , , НаборДанных.Картинка);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Функция СписокНаборовДанных(ИсключитьТекущий)
	
	Результат = Новый СписокЗначений;
	Для Каждого НаборДанных Из НаборыДанных.ПолучитьЭлементы() Цикл 
		
		Если ИсключитьТекущий 
				И НаборДанных = Элементы.НаборыДанных.ТекущиеДанные Тогда
				
			Продолжить;
			
		КонецЕсли;
		
		Результат.Добавить(НаборДанных.Представление, , , НаборДанных.Картинка);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция НайтиНаборовДанныхПоИмени(Имя)
	
	Результат = Неопределено;
	Для Каждого НаборДанных Из НаборыДанных.ПолучитьЭлементы() Цикл 
		
		Если НаборДанных.Представление = Имя Тогда
			
			Результат = НаборДанных;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура РедактированиеТипаЗначенияПоляНабораДанныхЗавершено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Модифицированность = Истина;
	
	ТекущиеДанные = Элементы.ПоляНаборовДанных.ТекущиеДанные;
	ТекущиеДанные.ТипЗначения = Результат;

КонецПроцедуры

&НаКлиенте
Процедура РедактированиеДоступныхЗначенийПоляНабораДанныхЗавершено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Модифицированность = Истина;
	
	ТекущиеДанные = Элементы.ПоляНаборовДанных.ТекущиеДанные;
	ТекущиеДанные.ДоступныеЗначения = Результат;

КонецПроцедуры

&НаКлиенте
Процедура РедактированиеПараметровРедактированияПоляНабораДанныхЗавершено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Модифицированность = Истина;
	
	ТекущиеДанные = Элементы.ПоляНаборовДанных.ТекущиеДанные;
	ИТК_СКД.СкопироватьСтруктурноеПоле(ТекущиеДанные.ПараметрыРедактирования, Результат);

КонецПроцедуры

&НаКлиенте
Процедура СохранитьИзмененныеДанныеСтрокиВариантаНастроек()
	
	Если ВариантыИдентификаторПоследнейВыделеннойСтроки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Строка = ВариантыНастроек.НайтиПоИдентификатору(ВариантыИдентификаторПоследнейВыделеннойСтроки);
	
	Если Строка = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	АдресЗначения = ПоместитьВоВременноеХранилище(КомпоновщикНастроек.Настройки);
	Строка.Значение = ИТК_СКД.XMLТекстИзАдреса(АдресЗначения);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьДанныеВариантаНастроек()
	
	Если ВариантыИдентификаторПоследнейВыделеннойСтроки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Строка = ВариантыНастроек.НайтиПоИдентификатору(ВариантыИдентификаторПоследнейВыделеннойСтроки);
	
	Если Строка = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗагрузитьДанныеВариантаВКомпоновщикНастроек(Строка.Значение);
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьДанныеВариантаВКомпоновщикНастроек(ВариантНастроекXML)
	
	ОбновитьОсновнуюСхемуКомпоновкиДанныхИзДанныхФормы();
	
	СхемаКомпоновкиДанных = ПолучитьИзВременногоХранилища(АдресСхемыКомпоновкиДанных);
	КомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСхемыКомпоновкиДанных));
	
	Если ЗначениеЗаполнено(ВариантНастроекXML) Тогда
		НастройкиВарианта = ИТК_СКД.ВариантНастроек(ВариантНастроекXML);
	Иначе
		НастройкиВарианта = СхемаКомпоновкиДанных.НастройкиПоУмолчанию;
	КонецЕсли;
	
	КомпоновщикНастроек.ЗагрузитьНастройки(НастройкиВарианта);
	
КонецПроцедуры

&НаСервере
Функция НайтиСоздатьПолеГруппу(Родитель, Поле)
	
	Результат = НайтиПолеГруппу(Родитель, Поле);
	Если Результат = Неопределено Тогда
		
		ВидГруппа = ИТК_Перечисления.СКДВидыПолейНаборовДанныхГруппа();
		
		Результат = Родитель.ПолучитьЭлементы().Добавить();
		Результат.Вид = ВидГруппа;
		Результат.Картинка = ИТК_КонструкторСКДКлиентСервер.КартинкаПоляНабораДанных(ВидГруппа);
		Результат.Поле = Поле;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция НайтиПолеГруппу(Родитель, Поле)
	
	Результат = Неопределено;
	
	Для Каждого СтрокаПоле Из Родитель.ПолучитьЭлементы() Цикл 
		
		Если СтрокаПоле.Вид = ИТК_Перечисления.СКДВидыПолейНаборовДанныхГруппа()
				И СтрокаПоле.Поле = Поле Тогда
				
			Результат = СтрокаПоле;
			Прервать;
			
		КонецЕсли;

	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ЗначениеВыраженияУпорядочивания(ВыраженияУпорядочивания = Неопределено)
	
	Результат = Новый СписокЗначений;
	
	Если ВыраженияУпорядочивания = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого ВыражениеУпорядочивания Из ВыраженияУпорядочивания Цикл 
		
		Результат.Добавить(ВыражениеУпорядочивания.ТипУпорядочивания, ВыражениеУпорядочивания.Выражение, ВыражениеУпорядочивания.Автоупорядочивание);
		
	КонецЦикла;

	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ДобавитьВычисляемоеПоле(Активировать = Истина)
	
	ЭлементКоллекция = Элементы.ВычисляемыеПоля;
	
	НоваяСтрока = ВычисляемыеПоля.Добавить();
	
	Вид = ИТК_Перечисления.СКДВидыПолейНаборовДанныхПоле();
	НоваяСтрока.Вид = Вид;
	НоваяСтрока.Картинка = ИТК_КонструкторСКДКлиентСервер.КартинкаПоляНабораДанных(Вид);

	// Имя поля
	ЗанятыеИдентификаторы = ИспользуемыеИдентификаторыКоллекции(ЭлементКоллекция, ВычисляемыеПоля);
	ПрефиксИмени = ИТК_КонструкторСКДКлиентСервер.ПрефиксИмениНовогоПоляНабораДанных(Вид);
	
	НовыйИдентификатор = ИТК_Строки.НовыйИдентификатор(ПрефиксИмени, ЗанятыеИдентификаторы);
	НоваяСтрока.ПутьКДанным = НовыйИдентификатор;
	
	Если Активировать Тогда
		ЭлементКоллекция.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
	КонецЕсли;
	//
	ОбновитьКоличествоВЗаголовке(ЭлементКоллекция);
	
	Возврат НоваяСтрока;
	
КонецФункции

&НаКлиенте
Процедура ВычисляемыеПоляВыраженияУпорядочиванияЗавершениеРедактирования(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Модифицированность = Истина;
	
	ТекущиеДанные = Элементы.ВычисляемыеПоля.ТекущиеДанные;
	ТекущиеДанные.ВыраженияУпорядочивания = Результат;
	ТекущиеДанные.ВыраженияУпорядочиванияПредставление = ИТК_СКДКлиентСервер.ПредставлениеВыраженийУпорядочивания(Результат);

КонецПроцедуры

