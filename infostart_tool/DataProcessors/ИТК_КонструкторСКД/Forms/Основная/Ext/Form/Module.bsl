&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	Элементы.РедактироватьИсточникиДанных.Заголовок = ИТК_ФормаКлиентСервер.ЗаголовокСКоличеством(НСтр("ru = 'Источники';
																										|en = 'Sources'"), ИсточникиДанных.Количество());
	
	Если ТекущаяСтрока = Неопределено Тогда
		ВидНабораДанных = Неопределено;
	Иначе
		ВидНабораДанных = ТекущаяСтрока.Вид;
	КонецЕсли;
	ПрисутствуютНаборыДанных = (ВидНабораДанных <> Неопределено);
	НаборДанныхЗапрос = (ВидНабораДанных = ИТК_Перечисления.СКДНаборДанныхЗапрос());
	НаборДанныхОбъект = (ВидНабораДанных = ИТК_Перечисления.СКДНаборДанныхОбъект());
	НаборДанныхОбъединение = (ВидНабораДанных = ИТК_Перечисления.СКДНаборДанныхОбъединение());

	Элементы.ГруппаНовыйНаборДанных.Видимость = НЕ ПрисутствуютНаборыДанных;
	Элементы.ГруппаПоляНаборовДанных.Доступность = ПрисутствуютНаборыДанных;
	Элементы.ГруппаОбъект.Видимость = НаборДанныхОбъект;
	
	Элементы.ГруппаЗапрос.Видимость = НаборДанныхЗапрос;
	Если НЕ НаборДанныхЗапрос Тогда
		ИТК_РедакторКодаКлиент.УстановитьТребуетсяДополнительнаяИнициализация(Элементы.ТекстЗапроса);
	КонецЕсли;
	
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НаборДанныхЗапрос Тогда
		
		Элементы.ИспользоватьГруппировкиЗапросаЕслиВозможно.Видимость = ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.14");
		ОбновитьЭлементыОшибки();
	Иначе
		
		ИТК_РедакторКодаКлиент.УстановитьТребуетсяДополнительнаяИнициализация(Элементы.ТекстЗапроса);

	КонецЕсли;
	
	// Поля наборов
	ТекущиеДанныеПоляНаборовДанных = Элементы.ПоляНаборовДанных.ТекущиеДанные;
	
	ЭтоСтрокаГруппа = (ТекущиеДанныеПоляНаборовДанных <> Неопределено 
						И ТекущиеДанныеПоляНаборовДанных.Вид = ИТК_Перечисления.СКДВидыПолейНаборовДанныхГруппа());
	ДоступныДействияСПолями = ЭтоСтрокаГруппа ИЛИ НаборДанныхОбъект;
	ДоступноДобавлениеПолей = НаборДанныхОбъект;
	
	Элементы.ДобавитьПоле.Видимость = ДоступноДобавлениеПолей;
	Элементы.СкопироватьПоле.Доступность = ДоступныДействияСПолями;
	Элементы.УдалитьПоле.Доступность = ДоступныДействияСПолями;
	Элементы.ДобавитьПолеНабор.Видимость = ДоступноДобавлениеПолей;
	
	Элементы.ПоляНаборовДанныхКонтекстноеМенюДобавить.Видимость = ДоступноДобавлениеПолей;
	Элементы.ПоляНаборовДанныхКонтекстноеМенюСкопироватьПоле.Доступность = ДоступныДействияСПолями;
	Элементы.ПоляНаборовДанныхКонтекстноеМенюУдалитьПоле.Доступность = ДоступныДействияСПолями;
	Элементы.ПоляНаборовДанныхКонтекстноеМенюДобавитьПолеНабор.Видимость = ДоступноДобавлениеПолей;
	
	ПолеНабораДанныхРедактируется = ЭтоСтрокаГруппа ИЛИ НаборДанныхОбъект;
	Элементы.ПоляНаборовДанныхПоле.ТолькоПросмотр = НЕ ПолеНабораДанныхРедактируется;
	
	ДоступноИзменениеПорядкаПолейНабораДанных = НаборДанныхОбъект ИЛИ НаборДанныхОбъединение;
	Элементы.ГруппаПоляНаборовДанныхИзменениеПорядка.Видимость = ДоступноИзменениеПорядкаПолейНабораДанных;
	Элементы.ПоляНаборовДанныхКонтекстноеМенюГруппаПорядок.Видимость = ДоступноИзменениеПорядкаПолейНабораДанных;
	
	// Видимость колонок полей
	// Поля наборов
	ДоступноУправлениеПолямиНабора = НЕ ВложенВОбъединение(ТекущаяСтрока);
	
	Поля = Новый Массив;
	Поля.Добавить("ВыражениеПредставления");
	Поля.Добавить("ВыраженияУпорядочиванияПредставление");
	Поля.Добавить("НаборДанныхПроверкиИерархии");
	Поля.Добавить("ПараметрНабораДанныхПроверкиИерархии");
	Поля.Добавить("ТипЗначения");
	Поля.Добавить("ДоступныеЗначения");
	Поля.Добавить("Оформление");
	Поля.Добавить("ПараметрыРедактирования");
	ОбновитьВидимостьСкрываемыхПолейКоллекций(Элементы.ПоляНаборовДанных, Поля, ДоступноУправлениеПолямиНабора);
	
	Элементы.ПоляНаборовДанныхЗаголовокПредставление.Видимость = ДоступноУправлениеПолямиНабора;
	Элементы.ПоляНаборовДанныхРольПредставление.Видимость = ДоступноУправлениеПолямиНабора;
	
	// Связи наборов данных
	Поля = Новый Массив;
	Поля.Добавить("НачальноеВыражение");
	Поля.Добавить("УсловиеСвязи");
	ОбновитьВидимостьСкрываемыхПолейКоллекций(Элементы.СвязиНаборовДанных, Поля);
	
	// Вычисляемые поля
	Поля = Новый Массив;
	Поля.Добавить("ВыражениеПредставления");
	Поля.Добавить("ВыраженияУпорядочиванияПредставление");
	Поля.Добавить("ТипЗначения");
	Поля.Добавить("ДоступныеЗначения");
	Поля.Добавить("Оформление");
	Поля.Добавить("ПараметрыРедактирования");
	ОбновитьВидимостьСкрываемыхПолейКоллекций(Элементы.ВычисляемыеПоля, Поля);
	
	// Параметры
	ВыделеныПараметрыКоторыеМожноУдалить = ВыделеныПараметрыКоторыеМожноУдалить();
	Элементы.ПараметрыСКДУдалить.Доступность = ВыделеныПараметрыКоторыеМожноУдалить;
	Элементы.ПараметрыСКДКонтекстноеМенюУдалить.Доступность = ВыделеныПараметрыКоторыеМожноУдалить;
	
	Поля = Новый Массив;
	Поля.Добавить("ДоступныеЗначения");
	Поля.Добавить("ПараметрФункциональныхОпций");
	Поля.Добавить("ПараметрыРедактирования");
	ОбновитьВидимостьСкрываемыхПолейКоллекций(Элементы.ПараметрыСКД, Поля);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЭлементыОшибки()
	
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЭлементГруппаОшибка = Элементы.ГруппаОшибкаВЗапросе;
	ЭлементТекст = Элементы.ТекстЗапроса;
	ЭлементТекстОшибки = Элементы.ОшибкаВЗапросеТекст;
	ЭлементКартинкаОшибки = Элементы.ОшибкаВЗапросеКартинка;
		
	ТребуетсяПроверка = ТекущаяСтрока.ТребуетсяПроверка;
	
	Ошибка = ИТК_ЗапросКлиентСервер.ИнформацияООшибке(ТекущаяСтрока.ТекстОшибки);
	ЕстьОшибки = ЗначениеЗаполнено(Ошибка);
	
	АкцентироватьТекст = ЕстьОшибки ИЛИ ТребуетсяПроверка;
	ЭлементГруппаОшибка.Видимость = АкцентироватьТекст;
	
	Если ЭлементТекст <> Неопределено Тогда
		
		Если АкцентироватьТекст Тогда
			ЦветРамки = WebЦвета.Красный;
		Иначе
			ЦветРамки = Новый Цвет();
		КонецЕсли;
		
		ЭлементТекст.ЦветРамки = ЦветРамки;
		ЭлементТекстОшибки.Гиперссылка = Не ТребуетсяПроверка;
		
	КонецЕсли;
	
	Если ТребуетсяПроверка Тогда
		
		ТекстОшибки = НСтр("ru = 'Требуется проверка текста';
							|en = 'You want to check the text'");
		ЭлементКартинкаОшибки.Картинка = Новый Картинка;
		
	Иначе
		
		Если ЕстьОшибки Тогда
			
			ТекстОшибки = ИТК_ОбщийКлиентСервер.ПредставлениеОшибкиВТекстеЗапросаИлиСхемеКомпоновкиДанных(Ошибка);
			ЭлементКартинкаОшибки.Картинка = БиблиотекаКартинок.ИТК_ОшибкаВТексте;
			
		КонецЕсли;
		
	КонецЕсли;

	ЭлементТекстОшибки.Заголовок = ТекстОшибки;
	
КонецПроцедуры

&НаКлиенте
Процедура ИТК_ПодключаемыйВосстановлениеФокусаРедактора() Экспорт 
	
	ИТК_РедакторКодаКлиент.ВосстановлениеФокусаРедактора(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьОшибку()
	
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЭлементТекст = Элементы.ТекстЗапроса;
	Ошибка = ИТК_ЗапросКлиентСервер.ИнформацияООшибке(ТекущаяСтрока.ТекстОшибки);
		
	Если ТипЗнч(Ошибка) = Тип("Структура") Тогда
		
		ИТК_РедакторКодаКлиент.ПоказатьОшибку(ЭлементТекст, Ошибка.НомерСтроки, Ошибка.НомерСтолбца);

	КонецЕсли;
		
	ТекущийЭлемент = ЭлементТекст;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьОшибкуПослеОжидания()
	
	ПодключитьОбработчикОжидания("ПоказатьОшибку", 0.1, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьПоказатьОшибку(ВыводитьПредупреждениеОшибокНет = Ложь)
	
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекстОшибки = ПроверитьТекстЗапроса(ТекущаяСтрока);
	ЗаполнитьПоляНабораДанных();
	
	ОбновитьЭлементыФормы();
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда 
		
		ПоказатьОшибкуПослеОжидания();
		
	Иначе
		
		Если ВыводитьПредупреждениеОшибокНет Тогда
			
			ТекстОшибокНет = НСтр("ru = 'Запрос проверен. Ошибок нет';
									|en = 'Query verified. There are no errors'");
			ПоказатьОповещениеПользователя(ИТК_КонструкторСКДКлиентСервер.Представление(), , ТекстОшибокНет, БиблиотекаКартинок.СинтаксическийКонтроль);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ПроверитьТекстЗапроса(Данные)
	
	Если Данные.ТребуетсяПроверка Тогда
			
		ПроверитьДанныеЗапроса(Данные);
		Результат = ИТК_ОбщийКлиентСервер.ПредставлениеОшибкиВТекстеЗапросаИлиСхемеКомпоновкиДанных(Данные.ТекстОшибки);
		
	Иначе
		
		Результат = "";
		
	КонецЕсли;
	
	Возврат Результат
	
КонецФункции

&НаКлиенте
Процедура ПроверитьДанныеЗапроса(Данные)
	
	ТекстЗапроса = Данные.ТекстЗапроса;
	Если ЗначениеЗаполнено(ТекстЗапроса) Тогда
		
		РезультатПроверки = ИТК_Запрос.ПроверитьТекст(ТекстЗапроса);
		ТекстОшибки = РезультатПроверки.ТекстОшибки;
		
	Иначе
		
		ТекстОшибки = ИТК_ЗапросКлиентСервер.ТекстОшибкиПустойЗапрос();
		
	КонецЕсли;
	
	Данные.ТребуетсяПроверка = Ложь;
	Данные.ТекстОшибки = ТекстОшибки;

КонецПроцедуры

&НаКлиенте
Функция ДобавитьНаборДанных(Вид, Активировать = Истина)
	
	Модифицированность = Истина;
	
	ЭлементКоллекция = Элементы.НаборыДанных;
	Родитель = ЭлементКоллекция.ТекущиеДанные;
	Если Родитель = Неопределено Тогда
		
		Родитель = НаборыДанных;
		
	ИначеЕсли Родитель.Вид <> ИТК_Перечисления.СКДНаборДанныхОбъединение() Тогда
			
		Родитель = ИТК_ФормаКлиент.РодительСтрокиДерева(НаборыДанных, Родитель);
		
	КонецЕсли;

	Индекс = ИТК_ФормаКлиент.МаксимальныйИндексСтрокДерева(Родитель);
	Представление = НСтр("ru = 'НаборДанных';
						|en = 'Datasets'") + ИТК_Строки.ЧислоВСтроку(Индекс + 1);
	
	НоваяСтрока = Родитель.ПолучитьЭлементы().Добавить();
	НоваяСтрока.Вид = Вид;
	НоваяСтрока.Картинка = ИТК_КонструкторСКДКлиентСервер.КартинкаНабораДанных(Вид);
	НоваяСтрока.Представление = Представление;
	
	НаборДанныхЗапрос = (Вид = ИТК_Перечисления.СКДНаборДанныхЗапрос());
	
	Если НаборДанныхЗапрос Тогда
		
		НоваяСтрока.АвтоЗаполнение = Истина;
		НоваяСтрока.ИспользоватьГруппировкиЗапросаЕслиВозможно = Истина;
		НоваяСтрока.ТекстОшибки = ИТК_ЗапросКлиентСервер.ТекстОшибкиПустойЗапрос();
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИсточникиДанных) Тогда
		НоваяСтрока.Источник = ИсточникиДанных[0].Имя;
	КонецЕсли;
	НоваяСтрока.ТребуетсяПроверка = Ложь;
	
	Если Активировать Тогда
		
		ЭлементКоллекция.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
		
		Если НаборДанныхЗапрос Тогда
			ИТК_РедакторКодаКлиент.УстановитьФокус(ЭтотОбъект, Элементы.ТекстЗапроса);
		КонецЕсли;
		
	КонецЕсли;
	
	ОбновитьКоличествоВЗаголовке(ЭлементКоллекция);
	
	Возврат НоваяСтрока;
	
КонецФункции

&НаКлиенте
Функция СтрокаПриемникПеретаскиванияНабораДанных(Идентификатор)
	
	Если Идентификатор = Неопределено Тогда // Перенос в корень дерева
		
		Возврат НаборыДанных;
		
	Иначе
		
		Возврат НаборыДанных.НайтиПоИдентификатору(Идентификатор);
		
	КонецЕсли;	
	
КонецФункции

&НаКлиенте
Функция СтрокиНабораДанныхКоторыеМожноПеренести(АнализируемыеСтроки, ПараметрыПеретаскивания, ПриемникПеретаскивания)
	
	Результат = Новый Массив;
	Для Каждого Идентификатор Из АнализируемыеСтроки Цикл
		
		ПеретаскиваемаяСтрока = НаборыДанных.НайтиПоИдентификатору(Идентификатор);
		
		Если МожноПереместитьСтрокуНабораДанных(ПеретаскиваемаяСтрока, ПараметрыПеретаскивания, ПриемникПеретаскивания) Тогда
			
			Результат.Добавить(Идентификатор);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция МожноПереместитьСтрокуНабораДанных(ПроверяемаяСтрока, ПараметрыПеретаскивания, ПриемникПеретаскивания)
	
	// Правила перетаскивания
	// 1. В корень дерева можно переносить любые элементы
	// 2. Строку нельзя переносить саму в себя
	// 3. Необходимо проверять не перемещается ли группа внутрь самой себя для избежания бесконечной рекурсии
	
	Если ТипЗнч(ПриемникПеретаскивания) = Тип("ДанныеФормыДерево") Тогда // (должно быть начальной проверкой) // 1
		
		Результат = Истина;
		
	ИначеЕсли ПроверяемаяСтрока = ПриемникПеретаскивания Тогда // 2
		
		Результат = Ложь;
		
	ИначеЕсли ИТК_ФормаКлиент.СтрокаДеревоВходитВСтроку(ПриемникПеретаскивания, ПроверяемаяСтрока) Тогда // 3
		
		Результат = Ложь;
		
	Иначе
		
		Результат = Истина;
				
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ПереместитьСтрокуНабораДанных(Источник, Приемник, Копирование = Ложь, Активизировать = Ложь, ИндексВставки = Неопределено)
	
	Элемент = Элементы.НаборыДанных;
	Коллекция = Приемник.ПолучитьЭлементы();
	
	Если ИндексВставки = Неопределено Тогда
		НоваяСтрока = Коллекция.Добавить();
	Иначе 
		НоваяСтрока = Коллекция.Вставить(ИндексВставки + 1);
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(НоваяСтрока, Источник, , "Поля");
	
	// Скопировать поля
	Для Каждого СтрокаИсточника Из Источник.Поля Цикл 
		
		НоваяСтрока = НоваяСтрока.Поля.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИсточника);
		
	КонецЦикла;
	
	Для Каждого Строка Из Источник.ПолучитьЭлементы() Цикл
		
		ПереместитьСтрокуНабораДанных(Строка, НоваяСтрока, Копирование);
		
		// Развернем в соответствии с источником
		Если Элемент.Развернут(Источник.ПолучитьИдентификатор()) Тогда
			Элемент.Развернуть(НоваяСтрока.ПолучитьИдентификатор());
		КонецЕсли;
		
	КонецЦикла;
	
	Если Активизировать Тогда
		
		Элемент.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
		
	КонецЕсли;
	
	Возврат НоваяСтрока;
	
КонецФункции

&НаКлиенте
Функция ЭтоПолеНабораДанныхКоллеция(Вид)
	
	Результат = (Вид = ИТК_Перечисления.СКДВидыПолейНаборовДанныхГруппа()
					ИЛИ Вид = ИТК_Перечисления.СКДВидыПолейНаборовДанныхНабор());
					
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ОбработкаТекстЗапросаПриИзменении(Результат, ДополнительныеПараметры) Экспорт
	
	ИзмененТекстЗапроса();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаКомандыРедактораЗавершена(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИТК_РедакторКодаКлиент.СтандартныйОбработчикЗавершенияКоманды(Результат, ДополнительныеПараметры);	
	
	ИТК_РедакторКодаКлиент.УстановитьТекст(ЭтотОбъект, ДополнительныеПараметры.Элемент, Результат);
	ИзмененТекстЗапроса(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура РаботаКонструктораЗапросаЗавершена(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Элемент = Элементы["ТекстЗапроса"];
	ИТК_РедакторКодаКлиент.УстановитьТекст(ЭтотОбъект, Элемент, Результат);
	ИзмененТекстЗапроса(Истина);
	
	ОбработкаПослеИзмененияЗапросаНабораДанных();
	
КонецПроцедуры

&НаКлиенте
Процедура ИзмененТекстЗапроса(Проверен = Ложь)
	
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Модифицированность = Истина;
	
	ТекущаяСтрока.ТекстЗапроса = ИТК_РедакторКодаКлиент.Текст(ЭтотОбъект, "ТекстЗапроса");
	ТекущаяСтрока.ТекстОшибки = Неопределено;
	ТекущаяСтрока.ТребуетсяПроверка = НЕ Проверен;
	
	Если Проверен Тогда
		
		ЗаполнитьПоляНабораДанных();
		ОбновитьЭлементыФормы();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоляНабораДанных()
	
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ТекущаяСтрока.Автозаполнение Тогда
		Возврат;
	КонецЕсли;
	
	Идентификатор = Элементы.НаборыДанных.ТекущаяСтрока;
	ЗаполнитьПоляНабораДанныхНаСервере(Идентификатор);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоляНабораДанныхНаСервере(Идентификатор)
	
	СтрокаНабора = НаборыДанных.НайтиПоИдентификатору(Идентификатор);
	Если НЕ ЗначениеЗаполнено(СтрокаНабора.ТекстЗапроса) Тогда
		Возврат;
	КонецЕсли;

	СхемаЗапроса = Новый СхемаЗапроса;
	Если ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.14") Тогда
		СхемаЗапроса.РежимКомпоновкиДанных = Истина;
	КонецЕсли;
	
	СхемаЗапроса.УстановитьТекстЗапроса(СтрокаНабора.ТекстЗапроса);
	
	ЗапросПакета = ИТК_КонструкторСКД.ПоследнийЗапросВыборкиПакета(СхемаЗапроса);
	Если ЗапросПакета = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	// Добавляем/обновляем поля набора
	// Выражения отбора https://github.com/infostart-hub/toolkit/issues/670
	Если ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.14") Тогда
		
		ВыраженияОтбора = Новый Массив;
		Для Каждого ОператорЗапроса Из ЗапросПакета.Операторы Цикл 
			
			Для Каждого ВыражениеОтбора Из ОператорЗапроса.ВыраженияОтбораКомпоновкиДанных Цикл 
				
				ВыраженияОтбора.Добавить(ВыражениеОтбора.Псевдоним);
				ДобавитьОбновитьПолеНабора(СтрокаНабора.Поля, ВыражениеОтбора);
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЕсли;
	
	// Колонки
	Для Каждого Колонка Из ЗапросПакета.Колонки Цикл
		
		ОписаниеРолиПоля = ОписаниеРолиПоля(ЗапросПакета, Колонка);
		ДобавитьОбновитьПолеНабора(СтрокаНабора.Поля, Колонка, ОписаниеРолиПоля);
		
	КонецЦикла;
	
	УдалитьНеиспользуемыеПоляНабораДанных(СтрокаНабора.Поля, ЗапросПакета.Колонки, ВыраженияОтбора);
		
КонецПроцедуры

&НаСервере
Функция ДобавитьОбновитьПолеНабора(Приемник, ПолеНабора, ОписаниеРоли = Неопределено)
	
	ЭтоКолонкаСхемыЗапроса = (ТипЗнч(ПолеНабора) = Тип("КолонкаСхемыЗапроса"));
	ЭтоКолонкаВложеннаяТаблицаСхемыЗапроса = (ТипЗнч(ПолеНабора) = Тип("КолонкаВложеннаяТаблицаСхемыЗапроса"));
	
	ЭтоПолеНабораДанныхСхемыКомпоновкиДанных = (ТипЗнч(ПолеНабора) = Тип("ПолеНабораДанныхСхемыКомпоновкиДанных"));
	Если ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.14") Тогда
		
		ИмяТипаВыражениеОтбораКомпоновкиДанныхСхемыЗапроса = "ВыражениеОтбораКомпоновкиДанныхСхемыЗапроса";
		ЭтоПолеВыражениеОтбораНабораДанныхСхемыКомпоновкиДанных = (ТипЗнч(ПолеНабора) = Тип(ИмяТипаВыражениеОтбораКомпоновкиДанныхСхемыЗапроса));
		
	Иначе
		ЭтоПолеВыражениеОтбораНабораДанныхСхемыКомпоновкиДанных = Ложь;
	КонецЕсли;
	
	ЭтоВложенныйНаборДанныхСхемыКомпоновкиДанных = (ТипЗнч(ПолеНабора) = Тип("ВложенныйНаборДанныхСхемыКомпоновкиДанных"));
	ЭтоПапкаПолейНабораДанныхСхемыКомпоновкиДанных = (ТипЗнч(ПолеНабора) = Тип("ПапкаПолейНабораДанныхСхемыКомпоновкиДанных"));
	
	Если ЭтоКолонкаВложеннаяТаблицаСхемыЗапроса
			ИЛИ ЭтоВложенныйНаборДанныхСхемыКомпоновкиДанных Тогда
		
		Вид = ИТК_Перечисления.СКДВидыПолейНаборовДанныхНабор();
		
	ИначеЕсли ЭтоПапкаПолейНабораДанныхСхемыКомпоновкиДанных Тогда
		
		Вид = ИТК_Перечисления.СКДВидыПолейНаборовДанныхГруппа();
		
	ИначеЕсли ЭтоКолонкаСхемыЗапроса
				ИЛИ ЭтоПолеНабораДанныхСхемыКомпоновкиДанных Тогда
		
		Вид = ИТК_Перечисления.СКДВидыПолейНаборовДанныхПоле();
		
	ИначеЕсли ЭтоПолеВыражениеОтбораНабораДанныхСхемыКомпоновкиДанных Тогда
		
		Вид = ИТК_Перечисления.СКДВидыПолейНаборовДанныхПолеВыражениеОтбора();
		
	КонецЕсли;
	
	Если ЭтоПолеНабораДанныхСхемыКомпоновкиДанных
			ИЛИ ЭтоВложенныйНаборДанныхСхемыКомпоновкиДанных Тогда
			
		ИмяПоля = ПолеНабора.Поле;
		
	ИначеЕсли ЭтоКолонкаСхемыЗапроса
			ИЛИ ЭтоКолонкаВложеннаяТаблицаСхемыЗапроса
			ИЛИ ЭтоПолеВыражениеОтбораНабораДанныхСхемыКомпоновкиДанных Тогда
			
		ИмяПоля = ПолеНабора.Псевдоним;
		
	ИначеЕсли ЭтоПапкаПолейНабораДанныхСхемыКомпоновкиДанных Тогда
		
		ИмяПоля = ПолеНабора.ПутьКДанным;
		
	КонецЕсли;
	
	СтрокаПоле = НайтиСтрокуПолеНабора(Приемник, ИмяПоля);
	
	ОбновлениеПоля = (СтрокаПоле <> Неопределено);
	Если НЕ ОбновлениеПоля Тогда
		СтрокаПоле = Приемник.Добавить();
	КонецЕсли;
	
	СтрокаПоле.Вид = Вид;
	СтрокаПоле.Картинка = ИТК_КонструкторСКДКлиентСервер.КартинкаПоляНабораДанных(Вид);
	СтрокаПоле.Поле = ИмяПоля;
	
	// Заполнение других полей
	ТипЗначенияВЗапросе = Неопределено;
	ВыражениеПредставления = "";
	ВыраженияУпорядочивания = ЗначениеВыраженияУпорядочивания();
	НаборДанныхПроверкиИерархии = Неопределено;
	ПараметрНабораДанныхПроверкиИерархии = Неопределено;
	ТипЗначения = Неопределено;
	ДоступныеЗначения = Неопределено;
	Оформление = Неопределено;
	ПараметрыРедактирования = Неопределено;
	
	ОграничениеИспользованияПоле = Неопределено;
	ОграничениеИспользованияУсловие = Неопределено;
	ОграничениеИспользованияГруппировка = Неопределено;
	ОграничениеИспользованияПорядок = Неопределено;
	
	ОграничениеИспользованияРеквизитовПоле = Неопределено;
	ОграничениеИспользованияРеквизитовУсловие = Неопределено;
	ОграничениеИспользованияРеквизитовГруппировка = Неопределено;
	ОграничениеИспользованияРеквизитовПорядок = Неопределено;
			
	Если ОбновлениеПоля Тогда
		
		ПутьКДанным = СтрокаПоле.ПутьКДанным;
		ЗаголовокПоля = СтрокаПоле.Заголовок;
		
		Роль = СтрокаПоле.Роль;
		Если ЗначениеЗаполнено(ОписаниеРоли) Тогда
			ЗаполнитьЗначенияСвойств(Роль, ОписаниеРоли);
		КонецЕсли;
		
		ВыражениеПредставления = СтрокаПоле.ВыражениеПредставления;
		ВыраженияУпорядочивания = СтрокаПоле.ВыраженияУпорядочивания;
		
		НаборДанныхПроверкиИерархии = СтрокаПоле.НаборДанныхПроверкиИерархии;
		ПараметрНабораДанныхПроверкиИерархии = СтрокаПоле.ПараметрНабораДанныхПроверкиИерархии;
		
		ТипЗначения = СтрокаПоле.ТипЗначения;
		ДоступныеЗначения = СтрокаПоле.ДоступныеЗначения;
		
		Если ЭтоПолеВыражениеОтбораНабораДанныхСхемыКомпоновкиДанных Тогда
			
			ОграничениеИспользованияПоле = Истина;
			ОграничениеИспользованияУсловие = СтрокаПоле.ОграничениеИспользованияУсловие;
			ОграничениеИспользованияГруппировка = Истина;
			ОграничениеИспользованияПорядок = Истина;
			
		Иначе
			
			ОграничениеИспользованияПоле = СтрокаПоле.ОграничениеИспользованияПоле;
			ОграничениеИспользованияУсловие = СтрокаПоле.ОграничениеИспользованияУсловие;
			ОграничениеИспользованияГруппировка = СтрокаПоле.ОграничениеИспользованияГруппировка;
			ОграничениеИспользованияПорядок = СтрокаПоле.ОграничениеИспользованияПорядок;
			
		КонецЕсли;
		
		ОграничениеИспользованияРеквизитовПоле = СтрокаПоле.ОграничениеИспользованияРеквизитовПоле;
		ОграничениеИспользованияРеквизитовУсловие = СтрокаПоле.ОграничениеИспользованияРеквизитовУсловие;
		ОграничениеИспользованияРеквизитовГруппировка = СтрокаПоле.ОграничениеИспользованияРеквизитовГруппировка;
		ОграничениеИспользованияРеквизитовПорядок = СтрокаПоле.ОграничениеИспользованияРеквизитовПорядок;
		
		Если ЭтоПолеНабораДанныхСхемыКомпоновкиДанных
				ИЛИ ЭтоКолонкаСхемыЗапроса Тогда
				
			ТипЗначенияВЗапросе = ПолеНабора.ТипЗначения;
				
		КонецЕсли;
		
	Иначе
		
		Если ЭтоКолонкаВложеннаяТаблицаСхемыЗапроса Тогда
			
			// Добавление полей набора
			Для Каждого ВложеннаяКолонка Из ПолеНабора.Колонки Цикл
				ДобавитьОбновитьПолеНабора(СтрокаПоле, ВложеннаяКолонка);
			КонецЦикла;
			
		ИначеЕсли ЭтоКолонкаСхемыЗапроса Тогда
			
			Если ЗначениеЗаполнено(СтрокаПоле.ПутьКДанным) Тогда
				ПутьКДанным = СтрокаПоле.ПутьКДанным;
			Иначе
				ПутьКДанным = ПолеНабора.Псевдоним;
			КонецЕсли;
			
			ЗаголовокПоля = ИТК_Строки.ПредставлениеИдентификатора(ПолеНабора.Псевдоним);
			Роль = ИТК_СКДКлиентСервер.ПустоеОписаниеРолиПоляНабораДанных();
			ТипЗначенияВЗапросе = ПолеНабора.ТипЗначения;
			
		ИначеЕсли ЭтоПолеВыражениеОтбораНабораДанныхСхемыКомпоновкиДанных Тогда
			
			ПутьКДанным = ПолеНабора.Псевдоним;
			ЗаголовокПоля = ИТК_Строки.ПредставлениеИдентификатора(ПолеНабора.Псевдоним);
			
			ОграничениеИспользованияПоле = Истина;
			ОграничениеИспользованияУсловие = Ложь;
			ОграничениеИспользованияГруппировка = Истина;
			ОграничениеИспользованияПорядок = Истина;
			
		ИначеЕсли ЭтоПолеНабораДанныхСхемыКомпоновкиДанных Тогда
			
			ПутьКДанным = ПолеНабора.ПутьКДанным;
			ЗаголовокПоля = ПолеНабора.Заголовок;
			Роль = ИТК_СКД.ОписаниеРолиПоляНабораДанных(ПолеНабора.Роль);
			ВыражениеПредставления = ПолеНабора.ВыражениеПредставления;
			ТипЗначенияВЗапросе = Ложь;
			
			НаборДанныхПроверкиИерархии = ПолеНабора.НаборДанныхПроверкиИерархии;
			ПараметрНабораДанныхПроверкиИерархии = ПолеНабора.ПараметрНабораДанныхПроверкиИерархии;
			
			ТипЗначения = ПолеНабора.ТипЗначения;
			ДоступныеЗначения = ПолеНабора.ПолучитьДоступныеЗначения();
			Оформление = ПолеНабора.Оформление;
			ПараметрыРедактирования = ПолеНабора.ПараметрыРедактирования;
			
			ВыраженияУпорядочивания = ЗначениеВыраженияУпорядочивания(ПолеНабора.ВыраженияУпорядочивания);
			
		КонецЕсли;
		
		Если ЭтоПапкаПолейНабораДанныхСхемыКомпоновкиДанных
				ИЛИ ЭтоПолеНабораДанныхСхемыКомпоновкиДанных Тогда
			
			ОграничениеИспользования = ПолеНабора.ОграничениеИспользования;
			ОграничениеИспользованияПоле = ОграничениеИспользования.Поле;
			ОграничениеИспользованияУсловие = ОграничениеИспользования.Условие;
			ОграничениеИспользованияГруппировка = ОграничениеИспользования.Группировка;
			ОграничениеИспользованияПорядок = ОграничениеИспользования.Порядок;
			
		КонецЕсли;
		
	КонецЕсли;
	
	СтрокаПоле.ПутьКДанным = ПутьКДанным;
	
	// Заголовок поля
	Если Не ЗначениеЗаполнено(ЗаголовокПоля) Тогда
		ЗаголовокПоля = ИТК_Строки.ПредставлениеИдентификатора(ИмяПоля);
	КонецЕсли;
	СтрокаПоле.Заголовок = ЗаголовокПоля;
	
	// Роль
	СтрокаПоле.Роль = Роль;
	ПредставлениеРоли = ИТК_СКД.ПредставлениеОписанияРолиПоляНабораДанных(Роль);
	СтрокаПоле.РольПредставление = ПредставлениеРоли;
	
	СтрокаПоле.ВыражениеПредставления = ВыражениеПредставления;
	СтрокаПоле.ВыраженияУпорядочивания = ВыраженияУпорядочивания;
	СтрокаПоле.ВыраженияУпорядочиванияПредставление = ИТК_СКДКлиентСервер.ПредставлениеВыраженийУпорядочивания(ВыраженияУпорядочивания);
	
	СтрокаПоле.НаборДанныхПроверкиИерархии = НаборДанныхПроверкиИерархии;
	СтрокаПоле.ПараметрНабораДанныхПроверкиИерархии = ПараметрНабораДанныхПроверкиИерархии;
	
	СтрокаПоле.ТипЗначения = ТипЗначения;
	СтрокаПоле.ДоступныеЗначения = ДоступныеЗначения;
	
	ИТК_СКД.СкопироватьСтруктурноеПоле(СтрокаПоле.Оформление, Оформление);
	ИТК_СКД.СкопироватьСтруктурноеПоле(СтрокаПоле.ПараметрыРедактирования, ПараметрыРедактирования);
	
	// Тип значения и определяемые по нему
	Если ТипЗначенияВЗапросе = Неопределено Тогда
		
		ПолеСРеквизитами = Ложь;
		ПолеТолькоДляВыбора = Ложь;
		
	ИначеЕсли ТипЗначенияВЗапросе = Ложь Тогда
		
		ПолеСРеквизитами = Истина;
		ПолеТолькоДляВыбора = Ложь;
		
	Иначе 
		
		ПолеСРеквизитами = ИТК_КонструкторСКД.ПолеСРеквизитами(ТипЗначенияВЗапросе);
		ПолеТолькоДляВыбора = ИТК_КонструкторСКД.ПолеТолькоДляВыбора(ТипЗначенияВЗапросе);
		
	КонецЕсли;
	СтрокаПоле.ТипЗначенияВЗапросе = ТипЗначенияВЗапросе;
	СтрокаПоле.ПолеСРеквизитами = ПолеСРеквизитами;
	СтрокаПоле.ПолеТолькоДляВыбора = ПолеТолькоДляВыбора;
	
	Если ПолеТолькоДляВыбора Тогда
		
		ОграничениеИспользованияУсловие = Истина;
		ОграничениеИспользованияГруппировка = Истина;
		ОграничениеИспользованияПорядок = Истина;
		
	КонецЕсли;
	
	СтрокаПоле.ОграничениеИспользованияПоле = ОграничениеИспользованияПоле;
	СтрокаПоле.ОграничениеИспользованияУсловие = ОграничениеИспользованияУсловие;
	СтрокаПоле.ОграничениеИспользованияГруппировка = ОграничениеИспользованияГруппировка;
	СтрокаПоле.ОграничениеИспользованияПорядок = ОграничениеИспользованияПорядок;
	
	Если НЕ ПолеСРеквизитами Тогда
		
		ОграничениеИспользованияРеквизитовПоле = Истина;
		ОграничениеИспользованияРеквизитовУсловие = Истина;
		ОграничениеИспользованияРеквизитовГруппировка = Истина;
		ОграничениеИспользованияРеквизитовПорядок = Истина;
		
	КонецЕсли;
	
	СтрокаПоле.ОграничениеИспользованияРеквизитовПоле = ОграничениеИспользованияРеквизитовПоле;
	СтрокаПоле.ОграничениеИспользованияРеквизитовУсловие = ОграничениеИспользованияРеквизитовУсловие;
	СтрокаПоле.ОграничениеИспользованияРеквизитовГруппировка = ОграничениеИспользованияРеквизитовГруппировка;
	СтрокаПоле.ОграничениеИспользованияРеквизитовПорядок = ОграничениеИспользованияРеквизитовПорядок;
	
	Возврат СтрокаПоле;
	
КонецФункции

&НаСервере
Функция НайтиСтрокуПолеНабора(КоллекцияСтрок, Имя)
	
	Результат = Неопределено;
	Для Каждого СтрокаПоле Из КоллекцияСтрок Цикл 
		
		Если СтрокаПоле.Поле = Имя Тогда
			
			Результат = СтрокаПоле;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура УдалитьНеиспользуемыеПоляНабораДанных(Коллекция, Колонки, ВыраженияОтбора)
	
	УдаляемыеПоля = Новый Массив;
	Для Каждого Строка Из Коллекция Цикл 
		
		Если Колонки.Найти(Строка.Поле) <> Неопределено
				ИЛИ ВыраженияОтбора.Найти(Строка.Поле) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		УдаляемыеПоля.Добавить(Строка);

	КонецЦикла;
	
	Для Каждого УдаляемоеПоле Из УдаляемыеПоля Цикл 
		Коллекция.Удалить(УдаляемоеПоле);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура НаборыДанныхПоляРольЗавершениеРедактирования(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Модифицированность = Истина;
	
	ТекущиеДанные = Элементы.ПоляНаборовДанных.ТекущиеДанные;
	ТекущиеДанные.Роль = Результат.ОписаниеРоли;
	ТекущиеДанные.РольПредставление = Результат.Представление;

КонецПроцедуры

&НаКлиенте
Функция ДоступныеПоляНабораДанных(Данные = Неопределено)
	
	Если Данные = Неопределено Тогда
		Данные = Элементы.НаборыДанных.ТекущиеДанные;
	КонецЕсли;
	
	Если Данные = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = Новый СписокЗначений;
	
	Если ТипЗнч(Данные) = Тип("ДанныеФормыДерево") Тогда
		
		Для Каждого СтрокаНабора Из Данные.ПолучитьЭлементы() Цикл 
			ДобавитьДоступныеПоляНабораДанных(Результат, СтрокаНабора.Поля);
		КонецЦикла;
		
	Иначе 
		ДобавитьДоступныеПоляНабораДанных(Результат, Данные.Поля);
	КонецЕсли;
	
	// Добавление вычисляемых полей
	Для Каждого СтрокаВычисляемоеПоле Из ВычисляемыеПоля Цикл
		ДобавитьДоступноеПоляНабораДанных(Результат, СтрокаВычисляемоеПоле.ПутьКДанным, СтрокаВычисляемоеПоле.ТипЗначения, Истина);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура ДобавитьДоступноеПоляНабораДанных(Результат, ПутьКДанным, ТипЗначения = Неопределено, Пометка = Ложь)
	
	ЧастиПутиКДанным = СтрРазделить(ПутьКДанным, ".");
	Для Каждого ЧастьПутиКДанным Из ЧастиПутиКДанным Цикл 
		
		Если ИТК_Строки.НекорректныйИдентификатор(ЧастьПутиКДанным) Тогда
			Возврат;
		КонецЕсли;
		
	КонецЦикла;
	
	Родитель = Результат;
	Для Индекс = 0 По ЧастиПутиКДанным.ВГраница() Цикл 
		
		ЧастьПутиКДанным = ЧастиПутиКДанным[Индекс];
		
		ЭлементСписка = ИТК_ОбщийКлиентСервер.СписокЗначенийНайтиПоПредставлению(Результат, ЧастьПутиКДанным);
		Если ЭлементСписка = Неопределено Тогда
			ЭлементСписка = Родитель.Добавить( , ЧастьПутиКДанным, Пометка);
		КонецЕсли;
		
		Если Индекс = ЧастиПутиКДанным.ВГраница() Тогда
			
			ЗначениеЭлемента = ТипЗначения;
			КартинкаЭлемента = ИТК_Типы.КартинкаОписания(ТипЗначения);
			
		Иначе
			
			ЗначениеЭлемента = Новый СписокЗначений;
			КартинкаЭлемента = Новый Картинка;
			
		КонецЕсли;
		ЭлементСписка.Значение = ЗначениеЭлемента;
		ЭлементСписка.Картинка = КартинкаЭлемента;
		
		Родитель = ЗначениеЭлемента;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьДоступныеПоляНабораДанных(Результат, Знач Коллекция) 

	Для Каждого ПолеНабораДанных Из Коллекция Цикл 
		
		Если ПолеНабораДанных.Вид = ИТК_Перечисления.СКДВидыПолейНаборовДанныхГруппа() Тогда
			Продолжить;
		КонецЕсли;
		
		ТипЗначения = Неопределено;
		Если ПолеНабораДанных.Вид = ИТК_Перечисления.СКДВидыПолейНаборовДанныхПоле() Тогда
			
			ТипЗначения = ПолеНабораДанных.ТипЗначения;
			Если НЕ ЗначениеЗаполнено(ТипЗначения) Тогда
				ТипЗначения = ПолеНабораДанных.ТипЗначенияВЗапросе;
			КонецЕсли;
			
		КонецЕсли;
		
		ДобавитьДоступноеПоляНабораДанных(Результат, ПолеНабораДанных.ПутьКДанным, ТипЗначения);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура НаборыДанныхПоляВыраженияУпорядочиванияЗавершениеРедактирования(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Модифицированность = Истина;
	
	ТекущиеДанные = Элементы.ПоляНаборовДанных.ТекущиеДанные;
	ТекущиеДанные.ВыраженияУпорядочивания = Результат;
	ТекущиеДанные.ВыраженияУпорядочиванияПредставление = ИТК_СКДКлиентСервер.ПредставлениеВыраженийУпорядочивания(Результат);

КонецПроцедуры

&НаКлиенте
Процедура ИсточникиДанныхЗавершениеРедактирования(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИсточникиДанных.Очистить();
	
	Для Каждого ЭлементИсточникДанных Из Результат Цикл 
		
		НоваяСтрока = ИсточникиДанных.Добавить();
		НоваяСтрока.Имя = ЭлементИсточникДанных.Представление;
		
	КонецЦикла;
	
	ОбновитьСписокДоступныхИсточников();
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписокДоступныхИсточников()
	
	СписокВыбора = Элементы.Источник.СписокВыбора;
	СписокВыбора.Очистить();
	
	Для Каждого ОписаниеИсточникаДанных Из ИсточникиДанных Цикл 
		
		
		СписокВыбора.Добавить(ОписаниеИсточникаДанных.Имя);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьОбработчикСПроверкойНаСохранностьДанных(ОписаниеОбработчика)
	
	Если Модифицированность Тогда
		
		// Список вариантов ответа
		ВариантыОтвета = Новый СписокЗначений;
		ВариантыОтвета.Добавить(КодВозвратаДиалога.Да,		НСтр("ru = 'Сохранить';
																	|en = 'Save'"));
		ВариантыОтвета.Добавить(КодВозвратаДиалога.Нет,		НСтр("ru = 'Нет';
																	|en = 'No'"));
		ВариантыОтвета.Добавить(КодВозвратаДиалога.Отмена,	НСтр("ru = 'Отмена';
																	|en = 'Cancel'"));
		
		ПоказатьВопрос(Новый ОписаниеОповещения("ВопросСохраненияЗавершение", ЭтотОбъект, ОписаниеОбработчика),
								НСтр("ru = 'Схема компоновки данных изменена. Сохранить схему?';
									|en = 'Data composition schema changed. Save schematic?'"), ВариантыОтвета, , КодВозвратаДиалога.Да,
								ИТК_ТуллкитКлиентСервер.КонструкторСКДПредставление());
		
	Иначе 
		
		ВыполнитьОбработкуОповещения(ОписаниеОбработчика);
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ВопросСохраненияЗавершение(Результат, ОписаниеОбработчика) Экспорт
	
	Если Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	ВыполнитьОбработкуОповещения(ОписаниеОбработчика, Результат);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработчикЗакрытиеРазрешеноЗакрыть(Результат, ДополнительныеПараметры) Экспорт
	
	ЗакрытиеРазрешено = Истина;
	Закрыть();
	
КонецПроцедуры

&НаСервере
Функция СобратьСхемуКомпоновкиДанныхИзДанныхФормы()
	
	Результат = ПолучитьИзВременногоХранилища(АдресСхемыКомпоновкиДанных);
	
	// Источники
	Для Каждого ОписаниеИсточникаДанных Из ИсточникиДанных Цикл 
		
		НовыйИсточник = Результат.ИсточникиДанных.Добавить();
		НовыйИсточник.Имя = ОписаниеИсточникаДанных.Имя;
		НовыйИсточник.ТипИсточникаДанных = "Local";
		
	КонецЦикла;
	
	ЗагрузитьИсточникиДанныхВСхему(Результат.ИсточникиДанных);
	ЗагрузитьНаборДанныхВСхему(Результат.НаборыДанных, НаборыДанных);
	ЗагрузитьСвязиНаборовДанныхВСхему(Результат.СвязиНаборовДанных);
	ЗагрузитьВычисляемыеПоляВСхему(Результат.ВычисляемыеПоля);
	ЗагрузитьРесурсыВСхему(Результат.ПоляИтога);
	ЗагрузитьПараметрыВСхему(Результат.Параметры);
	ЗагрузитьМакетВСхему(Результат);
	ЗагрузитьВложенныеСхемыВСхему(Результат.ВложенныеСхемыКомпоновкиДанных);
	ЗагрузитьВариантыНастроекВСхему(Результат.ВариантыНастроек);
	
	ЗагрузитьПредставленияЗаголовковВСхему(Результат);
	
	Возврат ПоместитьВоВременноеХранилище(Результат, УникальныйИдентификатор);
	
КонецФункции

&НаСервере
Процедура ЗагрузитьИсточникиДанныхВСхему(ИсточникиДанныхСКД)
	
	ИсточникиДанныхСКД.Очистить();
	
	Для Каждого СтрокаИсточникДанных Из ИсточникиДанных Цикл 
		
		НовыйИсточникДанных = ИсточникиДанныхСКД.Добавить();
		НовыйИсточникДанных.Имя = СтрокаИсточникДанных.Имя;
		НовыйИсточникДанных.ТипИсточникаДанных = "Local";
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьНаборДанныхВСхему(КоллекцияНаборовДанныхСКД, Родитель)
	
	КоллекцияНаборовДанныхСКД.Очистить();
	
	Для Каждого ОписаниеНабораДанных Из Родитель.ПолучитьЭлементы() Цикл 
		
		ТипНабораДанных = ИТК_СКД.ТипНабораДанныхСхемыКомпоновкиДанных(ОписаниеНабораДанных.Вид);
		НовыйНаборДанных = КоллекцияНаборовДанныхСКД.Добавить(ТипНабораДанных);
		
		НовыйНаборДанных.Имя = ОписаниеНабораДанных.Представление;
		
		Если ТипНабораДанных = Тип("НаборДанныхЗапросСхемыКомпоновкиДанных") Тогда
			
			НовыйНаборДанных.ИсточникДанных = ОписаниеНабораДанных.Источник;
			НовыйНаборДанных.Запрос = ОписаниеНабораДанных.ТекстЗапроса;
			НовыйНаборДанных.АвтоЗаполнениеДоступныхПолей = ОписаниеНабораДанных.АвтоЗаполнение;
			
			Если ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.14") Тогда
				НовыйНаборДанных.ИспользоватьГруппировкиЗапросаЕслиВозможно = ОписаниеНабораДанных.ИспользоватьГруппировкиЗапросаЕслиВозможно;
			КонецЕсли;
			
		ИначеЕсли ТипНабораДанных = Тип("НаборДанныхОбъектСхемыКомпоновкиДанных") Тогда
			
			НовыйНаборДанных.ИмяОбъекта = ОписаниеНабораДанных.ИмяОбъекта;
			НовыйНаборДанных.ИсточникДанных = ОписаниеНабораДанных.Источник;
			
		ИначеЕсли ТипНабораДанных = Тип("НаборДанныхОбъединениеСхемыКомпоновкиДанных") Тогда
			
			ЗагрузитьНаборДанныхВСхему(НовыйНаборДанных.Элементы, ОписаниеНабораДанных);
			
		КонецЕсли;
		
		ЗагрузитьНаборПолейДанныхВСхему(НовыйНаборДанных.Поля, ОписаниеНабораДанных.Поля);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьНаборПолейДанныхВСхему(КоллекцияПолейНаборовДанныхСКД, КоллекцияПолей)
	
	Для Каждого ОписаниеПоляНабораДанных Из КоллекцияПолей Цикл 
		
		Поле = ОписаниеПоляНабораДанных.Поле;
		ТипПоляНабораДанных = ИТК_СКД.ТипПоляНабораДанныхСхемыКомпоновкиДанных(ОписаниеПоляНабораДанных.Вид);
		НовоеПолеНабораДанных = КоллекцияПолейНаборовДанныхСКД.Добавить(ТипПоляНабораДанных);
		
		АвтоЗаголовокПоля = ИТК_Строки.ПредставлениеИдентификатора(Поле);
		Если АвтоЗаголовокПоля <> ОписаниеПоляНабораДанных.Заголовок Тогда
			НовоеПолеНабораДанных.Заголовок = ОписаниеПоляНабораДанных.Заголовок;
		КонецЕсли;
		
		НовоеПолеНабораДанных.ПутьКДанным = ОписаниеПоляНабораДанных.ПутьКДанным;
		
		Если ТипПоляНабораДанных = Тип("ПолеНабораДанныхСхемыКомпоновкиДанных") Тогда
			
			НовоеПолеНабораДанных.Поле = Поле;
			НовоеПолеНабораДанных.ВыражениеПредставления = ОписаниеПоляНабораДанных.ВыражениеПредставления;
			
			ОграничениеИспользования = НовоеПолеНабораДанных.ОграничениеИспользования;
			ОграничениеИспользования.Поле = ОписаниеПоляНабораДанных.ОграничениеИспользованияПоле;
			ОграничениеИспользования.Условие = ОписаниеПоляНабораДанных.ОграничениеИспользованияУсловие;
			ОграничениеИспользования.Группировка = ОписаниеПоляНабораДанных.ОграничениеИспользованияГруппировка;
			ОграничениеИспользования.Порядок = ОписаниеПоляНабораДанных.ОграничениеИспользованияПорядок;
			
			Если ОписаниеПоляНабораДанных.ПолеСРеквизитами Тогда
				
				ОграничениеИспользованияРеквизитов = НовоеПолеНабораДанных.ОграничениеИспользованияРеквизитов;
				ОграничениеИспользованияРеквизитов.Поле = ОписаниеПоляНабораДанных.ОграничениеИспользованияРеквизитовПоле;
				ОграничениеИспользованияРеквизитов.Условие = ОписаниеПоляНабораДанных.ОграничениеИспользованияРеквизитовУсловие;
				ОграничениеИспользованияРеквизитов.Группировка = ОписаниеПоляНабораДанных.ОграничениеИспользованияРеквизитовГруппировка;
				ОграничениеИспользованияРеквизитов.Порядок = ОписаниеПоляНабораДанных.ОграничениеИспользованияРеквизитовПорядок;
				
			КонецЕсли;
			
			ИТК_СКД.ЗаполнитьРольПолеНабораДанныхПоОписанию(НовоеПолеНабораДанных.Роль, ОписаниеПоляНабораДанных.Роль);
			
			// ВыраженияУпорядочивания
			ВыраженияУпорядочивания = НовоеПолеНабораДанных.ВыраженияУпорядочивания;
			Для Каждого ЭлементВыраженияУпорядочивания Из ОписаниеПоляНабораДанных.ВыраженияУпорядочивания Цикл 
				
				НовыйЭлементУпорядочивания = ВыраженияУпорядочивания.Добавить();
				НовыйЭлементУпорядочивания.Автоупорядочивание = ЭлементВыраженияУпорядочивания.Пометка;
				НовыйЭлементУпорядочивания.Выражение = ЭлементВыраженияУпорядочивания.Представление;
				НовыйЭлементУпорядочивания.ТипУпорядочивания = ЭлементВыраженияУпорядочивания.Значение;

			КонецЦикла;
			
			// Проверка Иерархии
			НовоеПолеНабораДанных.НаборДанныхПроверкиИерархии = ОписаниеПоляНабораДанных.НаборДанныхПроверкиИерархии;
			НовоеПолеНабораДанных.ПараметрНабораДанныхПроверкиИерархии = ОписаниеПоляНабораДанных.ПараметрНабораДанныхПроверкиИерархии;
			
			// Тип значения и доступные значения
			НовоеПолеНабораДанных.ТипЗначения = ОписаниеПоляНабораДанных.ТипЗначения;
			НовоеПолеНабораДанных.УстановитьДоступныеЗначения(ОписаниеПоляНабораДанных.ДоступныеЗначения);
			
			// Оформление и параметры редактирования
			ИТК_СКД.СкопироватьСтруктурноеПоле(НовоеПолеНабораДанных.Оформление, ОписаниеПоляНабораДанных.Оформление);
			ИТК_СКД.СкопироватьСтруктурноеПоле(НовоеПолеНабораДанных.ПараметрыРедактирования, ОписаниеПоляНабораДанных.ПараметрыРедактирования);
			
		ИначеЕсли ТипПоляНабораДанных = Тип("ВложенныйНаборДанныхСхемыКомпоновкиДанных") Тогда
			
			НовоеПолеНабораДанных.Поле = ОписаниеПоляНабораДанных.Поле;
			
		ИначеЕсли ТипПоляНабораДанных = Тип("ПапкаПолейНабораДанныхСхемыКомпоновкиДанных") Тогда
			
			ОграничениеИспользования = НовоеПолеНабораДанных.ОграничениеИспользования;
			ОграничениеИспользования.Поле = ОписаниеПоляНабораДанных.ОграничениеИспользованияПоле;
			ОграничениеИспользования.Условие = ОписаниеПоляНабораДанных.ОграничениеИспользованияУсловие;
			ОграничениеИспользования.Группировка = ОписаниеПоляНабораДанных.ОграничениеИспользованияГруппировка;
			ОграничениеИспользования.Порядок = ОписаниеПоляНабораДанных.ОграничениеИспользованияПорядок;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьВариантыНастроекВСхему(ВариантыНастроекСКД)
	
	ВариантыНастроекСКД.Очистить();
	
	Для Каждого СтрокаВариантНастроек Из ВариантыНастроек Цикл 
		
		НовыйВариантНастроек = ВариантыНастроекСКД.Добавить();
		НовыйВариантНастроек.Имя = СтрокаВариантНастроек.Имя;
		НовыйВариантНастроек.Представление = СтрокаВариантНастроек.Заголовок;
		
		ВариантНастроек = ИТК_СКД.ВариантНастроек(СтрокаВариантНастроек.Значение);
		ИТК_СКД.СкопироватьВариантНастроек(НовыйВариантНастроек.Настройки, ВариантНастроек);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьСвязиНаборовДанныхВСхему(СвязиНаборовДанныхСКД)
	
	СвязиНаборовДанныхСКД.Очистить();
	
	Для Каждого СтрокаСвязьНаборовДанных Из СвязиНаборовДанных Цикл 
		
		НоваяСвязьНаборовДанных = СвязиНаборовДанныхСКД.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСвязьНаборовДанных, СтрокаСвязьНаборовДанных); 
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьВычисляемыеПоляВСхему(ВычисляемыеПоляСКД)
	
	ВычисляемыеПоляСКД.Очистить();
	
	Для Каждого СтрокаВычисляемоеПоле Из ВычисляемыеПоля Цикл 
		
		НовоеВычисляемоеПоле = ВычисляемыеПоляСКД.Добавить();
		
		ЗаполнитьЗначенияСвойств(НовоеВычисляемоеПоле, СтрокаВычисляемоеПоле,
									"ПутьКДанным, Заголовок, Выражение, ВыражениеПредставления");
		
		ОграничениеИспользования = НовоеВычисляемоеПоле.ОграничениеИспользования;
		ОграничениеИспользования.Поле = СтрокаВычисляемоеПоле.ОграничениеИспользованияПоле;
		ОграничениеИспользования.Условие = СтрокаВычисляемоеПоле.ОграничениеИспользованияУсловие;
		ОграничениеИспользования.Группировка = СтрокаВычисляемоеПоле.ОграничениеИспользованияГруппировка;
		ОграничениеИспользования.Порядок = СтрокаВычисляемоеПоле.ОграничениеИспользованияПорядок;
		
		// ВыраженияУпорядочивания
		ВыраженияУпорядочивания = НовоеВычисляемоеПоле.ВыраженияУпорядочивания;
		Для Каждого ЭлементВыраженияУпорядочивания Из СтрокаВычисляемоеПоле.ВыраженияУпорядочивания Цикл 
			
			НовыйЭлементУпорядочивания = ВыраженияУпорядочивания.Добавить();
			НовыйЭлементУпорядочивания.Автоупорядочивание = ЭлементВыраженияУпорядочивания.Пометка;
			НовыйЭлементУпорядочивания.Выражение = ЭлементВыраженияУпорядочивания.Представление;
			НовыйЭлементУпорядочивания.ТипУпорядочивания = ЭлементВыраженияУпорядочивания.Значение;
			
		КонецЦикла;
		
		// Тип значения и доступные значения
		НовоеВычисляемоеПоле.ТипЗначения = СтрокаВычисляемоеПоле.ТипЗначения;
		НовоеВычисляемоеПоле.УстановитьДоступныеЗначения(СтрокаВычисляемоеПоле.ДоступныеЗначения);
		
		// Оформление и параметры редактирования
		ИТК_СКД.СкопироватьСтруктурноеПоле(НовоеВычисляемоеПоле.Оформление, СтрокаВычисляемоеПоле.Оформление);
		ИТК_СКД.СкопироватьСтруктурноеПоле(НовоеВычисляемоеПоле.ПараметрыРедактирования, СтрокаВычисляемоеПоле.ПараметрыРедактирования);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьРесурсыВСхему(ПоляИтогаСКД)
	
	ПоляИтогаСКД.Очистить();
	
	Для Каждого СтрокаРесурс Из Ресурсы Цикл 
		
		ПолеИтога = ПоляИтогаСКД.Добавить();
		
		ПолеИтога.ПутьКДанным = СтрокаРесурс.Поле;
		ПолеИтога.Выражение = СтрокаРесурс.Выражение;
		
		Группировки = СтрокаРесурс.Группировки.ВыгрузитьЗначения();
		Группировки = ПолеИтога.Группировки;
		Для Каждого ПолеГруппировки Из СтрокаРесурс.Группировки Цикл 
			Группировки.Добавить(ПолеГруппировки.Значение);
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьПараметрыВСхему(ТаблицаПараметровСКД)
	
	ТаблицаПараметровСКД.Очистить();
	
	Для Каждого СтрокаПараметр Из ПараметрыСКД Цикл 
		
		Параметр = ТаблицаПараметровСКД.Добавить();
		ЗаполнитьЗначенияСвойств(Параметр, СтрокаПараметр);
		
		Если СтрокаПараметр.ИспользоватьВсегда Тогда
			Использование = ИспользованиеПараметраКомпоновкиДанных.Всегда;
		Иначе
			Использование = ИспользованиеПараметраКомпоновкиДанных.Авто;
		КонецЕсли;
		Параметр.Использование = Использование;
		
		Параметр.УстановитьДоступныеЗначения(СтрокаПараметр.ДоступныеЗначения);
		ИТК_СКД.СкопироватьСтруктурноеПоле(Параметр.ПараметрыРедактирования, СтрокаПараметр.ПараметрыРедактирования);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьМакетВСхему(СхемаКомпоновкиДанных)
	
	Для Каждого МакетСКД Из СхемаКомпоновкиДанных.Макеты Цикл 
		
		Если МакетСКД.Макет = Неопределено Тогда
			МакетСКД.Макет = Новый МакетОбластиКомпоновкиДанных;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьВложенныеСхемыВСхему(ВложенныеСхемыСКД)
	
	ВложенныеСхемыСКД.Очистить();
	
	Для Каждого СтрокаВложеннаяСхема Из ВложенныеСхемы Цикл 
		
		ВложеннаяСхема = ВложенныеСхемыСКД.Добавить();
		ВложеннаяСхема.Имя = СтрокаВложеннаяСхема.Имя;
		ВложеннаяСхема.Заголовок = СтрокаВложеннаяСхема.Заголовок;
		
		ВложеннаяСхема.Схема = ИТК_СКД.СхемаКомпоновкиДанных(СтрокаВложеннаяСхема.Схема);
		
		Настройки = ИТК_СКД.ВариантНастроек(СтрокаВложеннаяСхема.Настройки);
		ИТК_СКД.СкопироватьВариантНастроек(ВложеннаяСхема.Настройки, Настройки);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьПредставленияЗаголовковВСхему(СхемаКомпоновкиДанных)
	
	СхемаXDTO = СериализаторXDTO.ЗаписатьXDTO(СхемаКомпоновкиДанных);
	
	// Поля наборов данных
	Для Каждого ОбъектXDTOНаборДанных Из СхемаXDTO["dataSet"] Цикл 
		
		НаборДанных = СхемаКомпоновкиДанных.НаборыДанных.Найти(ОбъектXDTOНаборДанных.name);
		ЗагрузитьЗаголовкиКоллекцииВСхемуXDTO(ОбъектXDTOНаборДанных, "field", "dataPath", "title", НаборДанных.Поля, "Заголовок")

	КонецЦикла;
	
	ЗагрузитьЗаголовкиКоллекцииВСхемуXDTO(СхемаXDTO, "calculatedField", "dataPath", "title", СхемаКомпоновкиДанных.ВычисляемыеПоля, "Заголовок");
	ЗагрузитьЗаголовкиКоллекцииВСхемуXDTO(СхемаXDTO, "parameter", "name", "title", СхемаКомпоновкиДанных.Параметры, "Заголовок");
	ЗагрузитьЗаголовкиКоллекцииВСхемуXDTO(СхемаXDTO, "nestedSchema", "name", "title", СхемаКомпоновкиДанных.ВложенныеСхемыКомпоновкиДанных, "Заголовок");
	ЗагрузитьЗаголовкиКоллекцииВСхемуXDTO(СхемаXDTO, "settingsVariant", "name", "presentation", СхемаКомпоновкиДанных.ВариантыНастроек, "Представление");
	
	СхемаКомпоновкиДанных = СериализаторXDTO.ПрочитатьXDTO(СхемаXDTO);
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьЗаголовкиКоллекцииВСхемуXDTO(СхемаXDTO, ИмяКоллекцииXDTO, ИмяПоляПоискаXDTO, ИмяПоляXDTO, КоллекцияСхемы, ИмяПоляСхемы)
	
	Для Каждого ЭлементСхемы Из СхемаXDTO[ИмяКоллекцииXDTO] Цикл 
		
		СтрокаКоллекции = КоллекцияСхемы.Найти(ЭлементСхемы[ИмяПоляПоискаXDTO]);
		Если СтрокаКоллекции = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЗаголовокНСтр = СтрокаКоллекции[ИмяПоляСхемы];
		ИТК_СКД.ЛокализированнаяСтрокаЗаписатьНСтрВСхемуXDTO(ЭлементСхемы, ИмяПоляXDTO, ЗаголовокНСтр);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьСхемуКомпоновкиДанныхИзТекста(Текст)

	СхемаКомпоновкиДанных = ИТК_СКД.СхемаКомпоновкиДанных(Текст);
	АдресСхемыКомпоновкиДанных = ИТК_ВременноеХранилище.Поместить(СхемаКомпоновкиДанных, АдресСхемыКомпоновкиДанных, УникальныйИдентификатор);

КонецПроцедуры

&НаСервере
Процедура ЗагрузитьСхемуКомпоновкиДанныхВДанныеФормы()
	
	СхемаКомпоновкиДанных = ПолучитьИзВременногоХранилища(АдресСхемыКомпоновкиДанных);
	
	// Источники
	Для Каждого ИсточникДанных Из СхемаКомпоновкиДанных.ИсточникиДанных Цикл 
		
		НовыйИсточник = ИсточникиДанных.Добавить();
		НовыйИсточник.Имя = ИсточникДанных.Имя;
		
	КонецЦикла;
	
	ЗагрузитьИсточникиДанныхСхемыКомпоновкиДанныхВДанныеФормы(СхемаКомпоновкиДанных);
	
	НаборыДанных.ПолучитьЭлементы().Очистить();
	ЗагрузитьНаборыДанныхСхемыКомпоновкиДанныхВДанныеФормы(СхемаКомпоновкиДанных.НаборыДанных, НаборыДанных);
	
	ЗагрузитьСвязиНаборовДанныхСхемыКомпоновкиДанныхВДанныеФормы(СхемаКомпоновкиДанных);
	ЗагрузитьВычисляемыеПоляСхемыКомпоновкиДанныхВДанныеФормы(СхемаКомпоновкиДанных);
