&НаКлиенте
Процедура ПоляНаборовДанныхРольПредставлениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	
	ТекущиеДанные = Элементы.ПоляНаборовДанных.ТекущиеДанные;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Поле", ТекущиеДанные.Поле);
	ПараметрыФормы.Вставить("Значение", ТекущиеДанные.Роль);
	ПараметрыФормы.Вставить("КонтекстВыражения", КонтекстВыражения());
	ПараметрыФормы.Вставить("ВариантыИменРолиОстаток", ВариантыИменРолиОстаток());
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("НаборыДанныхПоляРольЗавершениеРедактирования", ЭтотОбъект);
	
	ОткрытьФорму("Обработка.ИТК_КонструкторСКД.Форма.РедактированиеРолиПоляНабораДанных", ПараметрыФормы, ЭтотОбъект, , , ,
							ОповещениеОЗакрытии, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

