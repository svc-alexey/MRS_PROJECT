&НаКлиенте
Процедура ОбновитьДоступныеПоляРесурсов()
	
	ДоступныеПоля = ДоступныеПоляНабораДанных(НаборыДанных);
	
	Если ЗначениеЗаполнено(ДоступныеПоля) Тогда
		ОбновитьДоступныеПоляРесурсовСервер(ДоступныеПоля);
	КонецЕсли;
	
	// Очистка более несуществующих полей
	УдаляемыеРесурсы = Новый Массив;
	Для Каждого Ресурс Из Ресурсы Цикл 
		
		ДоступноеПолеРесурсов = ИТК_ОбщийКлиентСервер.СписокЗначенийНайтиПоПредставлению(ДоступныеПоля, Ресурс.Поле);
		Если ДоступноеПолеРесурсов = Неопределено Тогда
			УдаляемыеРесурсы.Добавить(Ресурс);
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого УдаляемыйРесурс Из УдаляемыеРесурсы Цикл 
		Ресурсы.Удалить(УдаляемыйРесурс);
	КонецЦикла;
	
	ОбновитьКоличествоВЗаголовке(Элементы.Ресурсы);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьДоступныеПоляРесурсовСервер(ДоступныеПоля)
	
	ДоступныеПоляРесурсов.Очистить();
	
	// Добавление полей
	Для Каждого ДоступноеПоле Из ДоступныеПоля Цикл 
		ДобавитьСтрокуДоступноеПолеРесурсов(ДоступноеПоле.Представление, ДоступноеПоле.Значение, ДоступноеПоле.Пометка);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьСтрокуДоступноеПолеРесурсов(Поле, ТипЗначения, Вычисляемое = Ложь)
	
	Если ТипЗначения = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НоваяСтрока = ДоступныеПоляРесурсов.Добавить();
	НоваяСтрока.Поле = Поле;
	НоваяСтрока.КартинкаТип = ИТК_Типы.КартинкаОписания(ТипЗначения);
	НоваяСтрока.ТипЗначения = ТипЗначения;
	
	Если ТипЗначения.СодержитТип(Тип("Число")) Тогда
		Картинка = БиблиотекаКартинок.ПроизвольноеВыражение;
	Иначе
		Картинка = БиблиотекаКартинок.Реквизит;
	КонецЕсли;
	НоваяСтрока.Картинка = Картинка;
	
КонецПроцедуры

&НаКлиенте
Функция КонтекстВыражения(ЗаполнитьДоступныеПоля = Истина) Экспорт 
	
	Результат = Новый Структура;
	Результат.Вставить("Параметры", ДоступныеПараметрыСКД());
	
	ДоступныеПоля = Неопределено;
	Если ЗаполнитьДоступныеПоля Тогда
		ДоступныеПоля = ДоступныеПоляНабораДанных();
	КонецЕсли;
	Результат.Вставить("ДоступныеПоля", ДоступныеПоля);
	
	Возврат Результат
	
КонецФункции

&НаКлиенте
Функция ВариантыИменРолиОстаток(Данные = Неопределено)
	
	Если Данные = Неопределено Тогда
		Данные = Элементы.НаборыДанных.ТекущиеДанные;
	КонецЕсли;
	
	Результат = Новый Массив;
	
	ПостфиксыНачальногоОстатка = СтрРазделить("НачальныйОстаток,НачОст", ",");
	ПостфиксыКонечногоОстатка = СтрРазделить("КонечныйОстаток,КонОст", ",");
	Для Каждого СтрокаПолеНабора Из Данные.Поля Цикл 
		
		ИмяПоля = СтрокаПолеНабора.Поле;
		
		ВариантИмениНачальныйОстаток = ВариантИмениРолиОстатокПоИмениПоля(ИмяПоля, ПостфиксыНачальногоОстатка);
		ДобавитьВариантИмениРолиОстаток(Результат, ВариантИмениНачальныйОстаток);
		
		ВариантИмениКонечныйОстаток = ВариантИмениРолиОстатокПоИмениПоля(ИмяПоля, ПостфиксыКонечногоОстатка);
		ДобавитьВариантИмениРолиОстаток(Результат, ВариантИмениКонечныйОстаток);
		
		ОписаниеРоли = СтрокаПолеНабора.Роль;
		
		РольОстаток = ИТК_ОбщийКлиентСервер.Свойство(ОписаниеРоли, "Остаток", Ложь);
		Если РольОстаток Тогда
			ДобавитьВариантИмениРолиОстаток(Результат, ОписаниеРоли.ГруппаОстатка);
		КонецЕсли;

	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ДобавитьВариантИмениРолиОстаток(Варианты, Имя)
	
	Если НЕ ЗначениеЗаполнено(Имя) Тогда
		Возврат;
	КонецЕсли;
	
	ВариантИмени = Варианты.Найти(Имя);
	Если ВариантИмени <> Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Варианты.Добавить(Имя);
	
КонецПроцедуры

&НаКлиенте
Функция ВариантИмениРолиОстатокПоИмениПоля(Имя, Постфиксы)
	
	Результат = "";
	
	Для Каждого Постфикс Из Постфиксы Цикл 
		
		Если СтрЗаканчиваетсяНа(Имя, Постфикс) Тогда
			Результат = Лев(Имя, СтрДлина(Имя) - СтрДлина(Постфикс));
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ОткрытьРедактированиеВыражения(Элемент, Контекст, Поле, СтандартнаяОбработка)
	
	ЭлементКоллекция = ИТК_ФормаКлиент.КоллекцияРодитель(Элемент);
	ТекущиеДанные = ЭлементКоллекция.ТекущиеДанные;
	
	ИТК_СКДКлиент.ОткрытьРедактированиеВыражения(Элемент, Контекст, СтандартнаяОбработка, ТекущиеДанные[Поле]);
	
КонецПроцедуры

&НаКлиенте
Функция ПоляГруппировкиРесурсаСтроки(Строка)
	
	Результат = Новый СписокЗначений;
	ТекущиеГруппировки = Строка.Группировки;
	
	ДоступныеПоля = ДоступныеПоляНабораДанных();
	
	ДобавитьПоляИерархииРесурсов(ДоступныеПоля);
	
	// Добавим Общий итог
	ИмяПоляИтогаОбщийИтог = ИТК_СКДКлиентСервер.ИмяПоляИтогаОбщийИтог();
	ДоступныеПоля.Добавить( , ИмяПоляИтогаОбщийИтог);
	
	Для Каждого ПолеГруппировки Из ДоступныеПоля Цикл  
		
		Поле = ПолеГруппировки.Представление;
		
		// Определение пометки
		НайденнаяГруппировка = ТекущиеГруппировки.НайтиПоЗначению(Поле);
		Пометка = (НайденнаяГруппировка <> Неопределено);
		
		Результат.Добавить(ПолеГруппировки.Значение, ПолеГруппировки.Представление, Пометка);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ДобавитьРесурсИзДоступныхПолей(ВыбраннаяСтрока)
	
	Поле = ВыбраннаяСтрока.Поле;
	
	НоваяСтрока = Ресурсы.Добавить();
	НоваяСтрока.Поле = Поле;
	
	АгрегатныеФункцииРесурса = АгрегатныеФункцииРесурса(Поле, ВыбраннаяСтрока.ТипЗначения);
	НоваяСтрока.Выражение = АгрегатныеФункцииРесурса[0];
	
КонецПроцедуры

&НаКлиенте
Функция СуммируемоеДоступноеПолеРесурсов(Строка)
	
	Возврат Строка.ТипЗначения.СодержитТип(Тип("Число"));
	
КонецФункции

&НаКлиенте
Функция АгрегатныеФункцииРесурса(Имя, ТипЗначения)
	
	Результат = Новый Массив;
	
	ПрисутствуетТипЧисло = ТипЗначения.СодержитТип(Тип("Число"));
	ПрисутствуетТипДата = ТипЗначения.СодержитТип(Тип("Дата"));
	ПрисутствуетТипСтрока = ТипЗначения.СодержитТип(Тип("Строка"));
	ПрисутствуетТипБулево = ТипЗначения.СодержитТип(Тип("Булево"));
	ПрисутствуетТипДругие = НЕ (ПрисутствуетТипЧисло ИЛИ ПрисутствуетТипДата ИЛИ ПрисутствуетТипСтрока ИЛИ ПрисутствуетТипБулево);
	
	Если ПрисутствуетТипЧисло Тогда
		
		ДобавитьАгрегатнуюФункциюРесурса(Результат, Имя, НСтр("ru = 'Сумма(%1)';
																|en = 'Sum(%1)'"));
		ДобавитьАгрегатнуюФункциюРесурса(Результат, Имя, НСтр("ru = 'Среднее(%1)';
																|en = 'Avg(%1)'"));
		
	КонецЕсли;	
	
	Если ПрисутствуетТипСтрока Тогда
		
		ДобавитьАгрегатнуюФункциюРесурса(Результат, Имя, НСтр("ru = 'СоединитьСтроки(%1)';
																|en = 'JoinStrings(%1)'"));
		
	КонецЕсли;	
	
	Если ПрисутствуетТипБулево Тогда
		
		ДобавитьАгрегатнуюФункциюРесурса(Результат, Имя, НСтр("ru = 'Каждый(%1)';
																|en = 'Every(%1)'"));
		ДобавитьАгрегатнуюФункциюРесурса(Результат, Имя, НСтр("ru = 'Любой(%1)';
																|en = 'Any(%1)'"));
		
	КонецЕсли;	
	
	Если ПрисутствуетТипДругие Тогда
	
		ДобавитьАгрегатнуюФункциюРесурса(Результат, Имя, НСтр("ru = 'Количество(%1)';
																|en = 'Count(%1)'"));
		ДобавитьАгрегатнуюФункциюРесурса(Результат, Имя, НСтр("ru = 'Количество(Различные %1)';
																|en = 'Count(Distinct %1)'"));
	
	КонецЕсли;
	
	Если ПрисутствуетТипЧисло
			ИЛИ ПрисутствуетТипДата
			ИЛИ ПрисутствуетТипДругие Тогда
			
		ДобавитьАгрегатнуюФункциюРесурса(Результат, Имя, НСтр("ru = 'Максимум(%1)';
																|en = 'Max(%1)'"));
		
	КонецЕсли;
	
	Если ПрисутствуетТипЧисло
			ИЛИ ПрисутствуетТипДата Тогда
			
		ДобавитьАгрегатнуюФункциюРесурса(Результат, Имя, НСтр("ru = 'Минимум(%1)';
																|en = 'Min(%1)'"));
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ДобавитьАгрегатнуюФункциюРесурса(Список, Поле, Шаблон)
	
	Текст = СтрШаблон(Шаблон, Поле);
	Список.Добавить(Текст);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПараметры()
	
	ОбновитьПараметрыНаСервере();
	ОбновитьКоличествоВЗаголовке(Элементы.ПараметрыСКД);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьПараметрыНаСервере()
	
	ОбновитьОсновнуюСхемуКомпоновкиДанныхИзДанныхФормы();
	СхемаКомпоновкиДанных = ПолучитьИзВременногоХранилища(АдресСхемыКомпоновкиДанных);
	
	// Добавим используемые параметры
	ИспользуемыеПараметры = ИТК_СКД.ИспользуемыеПараметры(СхемаКомпоновкиДанных);
	Для Каждого Параметр Из ИспользуемыеПараметры Цикл 
		ДобавитьОбновитьСтрокуПараметр(Параметр.Ключ, Параметр.Значение);
	КонецЦикла;
	
	// Удалим неиспользуемые
	УдаляемыеПараметры = Новый Массив;
	Для Каждого Параметр Из ПараметрыСКД Цикл 
		
		ИспользуетсяПараметр = ИспользуемыеПараметры.Свойство(Параметр.Имя);
		Если Параметр.ДобавленАвтоматически
				И НЕ ИспользуетсяПараметр Тогда
				
			УдаляемыеПараметры.Добавить(Параметр);
				
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого Параметр Из УдаляемыеПараметры Цикл 
		ПараметрыСКД.Удалить(Параметр);
	КонецЦикла;
	
	// Заполним список выбора Параметр функциональных опций
	СписокВыбора = Элементы.ПараметрыСКДПараметрФункциональныхОпций.СписокВыбора;
	
	СписокВыбора.Очистить();
	Для Каждого ОписаниеПараметраФункциональныхОпций Из Метаданные.ПараметрыФункциональныхОпций Цикл 
		СписокВыбора.Добавить(ОписаниеПараметраФункциональныхОпций.Имя);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьОбновитьСтрокуПараметр(Имя, ТипЗначения) 
	
	Отбор = Новый Структура("Имя", Имя);
	НайденныеСтроки = ПараметрыСКД.НайтиСтроки(Отбор);
	
	Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
		
		Строка = НайденныеСтроки[0];
		ДобавленАвтоматически = Строка.ДобавленАвтоматически;
		ОграничениеИспользования = Строка.ОграничениеИспользования;
		
	Иначе
		
		ДобавленАвтоматически = Истина;
		ОграничениеИспользования = Истина;
		
		Строка = ПараметрыСКД.Добавить();
		Строка.Имя = Имя;
		Строка.ВключатьВДоступныеПоля = Истина;
		
	КонецЕсли;
	
	Строка.ТипЗначения = ТипЗначения;
	
	Если НЕ Строка.ДоступенСписокЗначений Тогда
		Строка.Значение = ТипЗначения.ПривестиЗначение(Строка.Значение);
	КонецЕсли;
	
	Строка.ОграничениеИспользования = ОграничениеИспользования;
	Строка.ДобавленАвтоматически = ДобавленАвтоматически;
	
КонецПроцедуры

&НаКлиенте
Функция ВыделеныПараметрыКоторыеМожноУдалить()
	
	Результат = Ложь;
	Для Каждого ИдентификаторВыделеннойСтроки Из Элементы.ПараметрыСКД.ВыделенныеСтроки Цикл 
		
		ВыделеннаяСтрока = ПараметрыСКД.НайтиПоИдентификатору(ИдентификаторВыделеннойСтроки);
		
		Если НЕ ВыделеннаяСтрока.ДобавленАвтоматически Тогда
			Результат = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура РедактированиеТипаЗначенияПараметраСКДЗавершено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
