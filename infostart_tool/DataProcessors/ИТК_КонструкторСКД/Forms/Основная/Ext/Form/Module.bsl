&НаКлиенте
Процедура ДобавитьПолеВНаборДанных(Вид, АктивизироватьСтроку = Истина)
	
	Модифицированность = Истина;
	КоллекцияПолей = Элементы.НаборыДанных.ТекущиеДанные.Поля;
	
	НоваяСтрока = КоллекцияПолей.Добавить();
	НоваяСтрока.Вид = Вид;
	НоваяСтрока.Картинка = ИТК_КонструкторСКДКлиентСервер.КартинкаПоляНабораДанных(Вид);
	НоваяСтрока.ПолеСРеквизитами = Истина;
	НоваяСтрока.Роль = ИТК_СКДКлиентСервер.ПустоеОписаниеРолиПоляНабораДанных();
	
	// Заполнение имени поля
	ЗанятыеИдентификаторы = ИспользуемыеИдентификаторыКоллекции(Элементы.ПоляНаборовДанных, КоллекцияПолей);
	ПрефиксИмени = ИТК_КонструкторСКДКлиентСервер.ПрефиксИмениНовогоПоляНабораДанных(Вид);
	
	Поле = ИТК_Строки.НовыйИдентификатор(ПрефиксИмени, ЗанятыеИдентификаторы);
	Если Вид <> ИТК_Перечисления.СКДВидыПолейНаборовДанныхГруппа() Тогда
		НоваяСтрока.Поле = Поле;
	КонецЕсли;
	НоваяСтрока.ПутьКДанным = Поле;
	
	Если АктивизироватьСтроку Тогда
		
		Элементы.ПоляНаборовДанных.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
		
		// Начать редактирование нужного поля
		Если Вид = ИТК_Перечисления.СКДВидыПолейНаборовДанныхГруппа() Тогда
			ТекущаяКолонка = Элементы.ПоляНаборовДанныхПутьКДанным;
		Иначе
			ТекущаяКолонка = Элементы.ПоляНаборовДанныхПоле;
		КонецЕсли;
		Элементы.ПоляНаборовДанных.ТекущийЭлемент = ТекущаяКолонка;
		Элементы.ПоляНаборовДанных.ИзменитьСтроку();
		
	КонецЕсли;
	
КонецПроцедуры

