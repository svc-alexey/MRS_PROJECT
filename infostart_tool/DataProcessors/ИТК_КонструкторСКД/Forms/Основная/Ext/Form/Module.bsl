&НаКлиенте
Перем СвязиНаборовДанныхИдентификаторПоследнейВыделеннойСтроки Экспорт;

&НаКлиенте
Перем НаборыДанныхСтароеИмя Экспорт;

&НаКлиенте
Перем ВариантыИдентификаторПоследнейВыделеннойСтроки Экспорт;

&НаКлиенте
Перем ПоляНаборовДанныхИдентификаторПоследнейВыделеннойСтроки Экспорт;

&НаКлиенте
Перем ПредыдущийИдентификатор Экспорт;

&НаКлиенте
Перем ПредыдущийПутьКДанным Экспорт;

&НаКлиенте
Перем ПредыдущаяСтраница Экспорт;

&НаКлиенте
Перем ЗакрытиеРазрешено;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЗагрузитьСхемуКомпоновкиДанныхИзТекста(Параметры.XMLТекст);
	ЗагрузитьСхемуКомпоновкиДанныхВДанныеФормы();
	
	УстановитьУсловноеОформление();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если Не ЗначениеЗаполнено(НаборыДанных.ПолучитьЭлементы()) Тогда
		
		НоваяСтрока = ИсточникиДанных.Добавить();
		НоваяСтрока.Имя = "ИсточникДанных1";
		
	КонецЕсли;
	
	ОбновитьСписокДоступныхИсточников();
	ПослеЗагрузкиСхемыКомпоновкиДанных();
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	ТекущиеДанные = Элементы.ВложенныеСхемы.ТекущиеДанные;
	ТекущиеДанные.Схема = ИТК_СКД.XMLТекстИзАдреса(ВыбранноеЗначение);
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы = Истина Тогда
		
		Если Модифицированность Тогда
			
			ТекстПредупреждения = НСтр("ru = 'Имеются несохраненные данные, они будут потеряны.
                                        |Для сохранения изменений нажмите ""Продолжить работу"", сохраните данные, а потом завершите работу.';
                                        |en = 'There is unsaved data, it will be lost.
                                        |To save changes, click Continue, save the data, and then exit.'");
			
			Отказ = Истина;
			
		КонецЕсли;
		
	Иначе
		
		Если ЗакрытиеРазрешено = Неопределено Тогда
			
			Отказ = Истина;
			ЗапуститьОбработчикСПроверкойНаСохранностьДанных(Новый ОписаниеОповещения("ОбработчикЗакрытиеРазрешеноЗакрыть", ЭтотОбъект));

		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	ИТК_РедакторКодаКлиент.ОбработкаОповещения(ЭтотОбъект, ИмяСобытия, Параметр, Источник);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ОшибкаТекстНажатие(Элемент)
	
	ПоказатьОшибку();
	
КонецПроцедуры

&НаКлиенте
Процедура СтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	Если ПредыдущаяСтраница = Элементы.СтраницаНастройки Тогда
		СохранитьИзмененныеДанныеСтрокиВариантаНастроек();
	КонецЕсли;
	
	ТекущаяСтраница = Элемент.ТекущаяСтраница;
	Если ТекущаяСтраница = Элементы.СтраницаРесурсы Тогда
		
		ОбновитьДоступныеПоляРесурсов();
		
	ИначеЕсли ТекущаяСтраница = Элементы.СтраницаПараметры Тогда
		
		ОбновитьПараметры();
		
	ИначеЕсли ТекущаяСтраница = Элементы.СтраницаНастройки Тогда
		
		ЗагрузитьДанныеВариантаНастроек();
		
	КонецЕсли;
	
	ПредыдущаяСтраница = ТекущаяСтраница;
	
КонецПроцедуры

&НаКлиенте
Процедура НаборыДанныхИмяОбъектаОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	
	Если ИТК_Строки.НекорректныйИдентификатор(Текст) Тогда 
		
		СтандартнаяОбработка = Ложь;
		Элемент.ОбновитьТекстРедактирования();
		
		ТекстПредупреждения = НСтр("ru = 'Некорректное имя!
                                  |Имя должно состоять из слова,
                                  |Начинаться с буквы и не содержать специальных символов кроме ""_"".';
                                  |en = 'Invalid name!
                                  |The name must be composed of a word,
                                  |Start with a letter and contain no special characters other than ""_"".'");
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеЗакрытияПредупрежденияНекорректноеИмяОбъектаНабораДанных", ЭтотОбъект);
		ПоказатьПредупреждение(ОписаниеОповещения, ТекстПредупреждения);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИТК_ПодключаемыйРедакторПриИзменении(Элемент)
	
	ИзмененТекстЗапроса();
	
