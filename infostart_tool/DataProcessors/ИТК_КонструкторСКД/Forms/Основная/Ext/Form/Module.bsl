&НаКлиенте
Процедура НаборыДанныхПроверкаПеретаскивания(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Поле)
	
	СтандартнаяОбработка = Ложь;
	
	ПриемникПеретаскивания = СтрокаПриемникПеретаскиванияНабораДанных(Строка);
	СтрокиКоторыеМожноПеренести = СтрокиНабораДанныхКоторыеМожноПеренести(Элемент.ВыделенныеСтроки, ПараметрыПеретаскивания, ПриемникПеретаскивания);
	
	Если Не ЗначениеЗаполнено(СтрокиКоторыеМожноПеренести) Тогда
		
		ПараметрыПеретаскивания.Действие = ДействиеПеретаскивания.Отмена;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НаборыДанныхПеретаскивание(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Поле)
	
	СтандартнаяОбработка = Ложь;
	
	ПриемникПеретаскивания = СтрокаПриемникПеретаскиванияНабораДанных(Строка);
	СтрокиКоторыеМожноПеренести = СтрокиНабораДанныхКоторыеМожноПеренести(Элемент.ВыделенныеСтроки, ПараметрыПеретаскивания, ПриемникПеретаскивания);
	
	Копирование = (ПараметрыПеретаскивания.Действие = ДействиеПеретаскивания.Копирование);
	Для Каждого Идентификатор Из СтрокиКоторыеМожноПеренести Цикл
		
		ПереносимаяСтрока = НаборыДанных.НайтиПоИдентификатору(Идентификатор);
		АктивироватьСтроку = (Элемент.ТекущаяСтрока = Идентификатор);
		
		Если ТипЗнч(ПриемникПеретаскивания) = Тип("ДанныеФормыДерево") 
				ИЛИ ПриемникПеретаскивания.Вид = ИТК_Перечисления.СКДНаборДанныхОбъединение() Тогда
			
			ИндексВставки = Неопределено;
			
		Иначе
			
			РодительПриемникаПеретаскивания = ИТК_ФормаКлиент.РодительСтрокиДерева(НаборыДанных, ПриемникПеретаскивания);
			ИндексВставки = РодительПриемникаПеретаскивания.ПолучитьЭлементы().Индекс(ПриемникПеретаскивания);
			ПриемникПеретаскивания = РодительПриемникаПеретаскивания;
			
		КонецЕсли;

		ПереместитьСтрокуНабораДанных(ПереносимаяСтрока, ПриемникПеретаскивания, Копирование, АктивироватьСтроку, ИндексВставки);
		
		// Удалим перемещенную строку (сделали копию строки на новом месте и нужно удалить старую)
		Если Не Копирование Тогда
			
			РодительПереносимойСтроки = ИТК_ФормаКлиент.РодительСтрокиДерева(НаборыДанных, ПереносимаяСтрока);
			
			Если ПереносимаяСтрока <> Неопределено Тогда // Возможно уже была удалена
				
				РодительПереносимойСтроки.ПолучитьЭлементы().Удалить(ПереносимаяСтрока);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовДереваПоляНаборовДанных

&НаКлиенте
Процедура ПоляНаборовДанныхПриАктивизацииСтроки(Элемент)
	
	ПоляНаборовДанныхИдентификаторТекущейСтроки = Элемент.ТекущаяСтрока;
	Если ПоляНаборовДанныхИдентификаторПоследнейВыделеннойСтроки <> ПоляНаборовДанныхИдентификаторТекущейСтроки Тогда 
		
		ПоляНаборовДанныхИдентификаторПоследнейВыделеннойСтроки = ПоляНаборовДанныхИдентификаторТекущейСтроки;
		
	КонецЕсли;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПоляНаборовДанныхПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	Отказ = Истина;
	
	ДоступноКопирование = Элементы.СкопироватьПоле.Доступность;
	Если Копирование 
			И НЕ ДоступноКопирование Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено 
			ИЛИ Не Копирование Тогда
			
		ВидДобавляемогоПоля = ИТК_Перечисления.СКДВидыПолейНаборовДанныхПоле();
		
	Иначе
		
		ВидДобавляемогоПоля = ТекущиеДанные.Вид;
		
	КонецЕсли;
	
	ЭтоПолеГруппа = (ВидДобавляемогоПоля = ИТК_Перечисления.СКДВидыПолейНаборовДанныхГруппа());
	
	ДоступноДобавлениеПоля = Элементы.ДобавитьПоле.Видимость;
	ДоступноДобавлениеГруппы = Элементы.ДобавитьПолеГруппу.Доступность;
	
	ДоступноДобавление = ДоступноДобавлениеПоля
							ИЛИ (ЭтоПолеГруппа
									И ДоступноДобавлениеГруппы);
	Если Не ДоступноДобавление Тогда
		Возврат;
	КонецЕсли;
		
	ДобавитьПолеВНаборДанных(ВидДобавляемогоПоля);
	
КонецПроцедуры

