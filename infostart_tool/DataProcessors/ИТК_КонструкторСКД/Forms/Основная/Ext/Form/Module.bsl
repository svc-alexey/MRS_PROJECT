&НаСервере
Процедура УстановитьУсловноеОформление()
	
	// Поля наборов данных
	// Оформление видимости ОграничениеИспользованияРеквизитов набора
	Оформление = Новый Структура("Отображать", Ложь);
	
	ОформляемыеПоля = Новый Массив;
	ОформляемыеПоля.Добавить("ПоляНаборовДанныхОграничениеИспользованияПоле");
	ОформляемыеПоля.Добавить("ПоляНаборовДанныхОграничениеИспользованияУсловие");
	ОформляемыеПоля.Добавить("ПоляНаборовДанныхОграничениеИспользованияГруппировка");
	ОформляемыеПоля.Добавить("ПоляНаборовДанныхОграничениеИспользованияПорядок");
	ОформляемыеПоля.Добавить("ПоляНаборовДанныхОграничениеИспользованияРеквизитовПоле");
	ОформляемыеПоля.Добавить("ПоляНаборовДанныхОграничениеИспользованияРеквизитовУсловие");
	ОформляемыеПоля.Добавить("ПоляНаборовДанныхОграничениеИспользованияРеквизитовГруппировка");
	ОформляемыеПоля.Добавить("ПоляНаборовДанныхОграничениеИспользованияРеквизитовПорядок");
	
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, ОформляемыеПоля, Оформление, "Элементы.НаборыДанных.ТекущиеДанные.Поля.Вид",
											ИТК_Перечисления.СКДВидыПолейНаборовДанныхНабор());
											
	// Оформление видимости ОграничениеИспользованияРеквизитов группы
	Оформление = Новый Структура("Отображать", Ложь);
	
	ОформляемыеПоля = Новый Массив;
	ОформляемыеПоля.Добавить("ПоляНаборовДанныхОграничениеИспользованияРеквизитовПоле");
	ОформляемыеПоля.Добавить("ПоляНаборовДанныхОграничениеИспользованияРеквизитовУсловие");
	ОформляемыеПоля.Добавить("ПоляНаборовДанныхОграничениеИспользованияРеквизитовГруппировка");
	ОформляемыеПоля.Добавить("ПоляНаборовДанныхОграничениеИспользованияРеквизитовПорядок");
	
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, ОформляемыеПоля, Оформление, "Элементы.НаборыДанных.ТекущиеДанные.Поля.Вид",
											ИТК_Перечисления.СКДВидыПолейНаборовДанныхГруппа());
	
	// Оформление только просмотр Поле для полей наборов типа группа
	Оформление = Новый Структура("ТолькоПросмотр", Истина);
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "ПоляНаборовДанныхПоле", Оформление, "Элементы.НаборыДанных.ТекущиеДанные.Поля.Вид",
											ИТК_Перечисления.СКДВидыПолейНаборовДанныхГруппа());

	// Оформление только просмотр ОграничениеИспользованияРеквизитов для полей без реквизитов
	Оформление = Новый Структура("ТолькоПросмотр", Истина);
	
	ОформляемыеПоля = Новый Массив;
	ОформляемыеПоля.Добавить("ПоляНаборовДанныхОграничениеИспользованияРеквизитовПоле");
