&НаКлиенте
Процедура КомпоновщикНастроекНастройкиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если СтрНайти(Поле.Имя, "НаличиеВыбора") Тогда
		
		АктивируемаяСтраница = Элементы.СтраницаПоляВыбора; 
		
	ИначеЕсли СтрНайти(Поле.Имя, "НаличиеОтбора") Тогда
		
		АктивируемаяСтраница = Элементы.СтраницаОтбор; 
		
	ИначеЕсли СтрНайти(Поле.Имя, "НаличиеПорядка") Тогда
		
		АктивируемаяСтраница = Элементы.СтраницаПорядок; 
		
	ИначеЕсли СтрНайти(Поле.Имя, "НаличиеУсловногоОформления") Тогда
		
		АктивируемаяСтраница = Элементы.СтраницаУсловноеОформление; 
		
	ИначеЕсли СтрНайти(Поле.Имя, "НаличиеПараметровВывода") Тогда
		
		АктивируемаяСтраница = Элементы.СтраницаПараметрыВывода; 
		
	Иначе
		
		Возврат;

	КонецЕсли;
	
	Элементы.СтраницыТекущихНастроек.ТекущаяСтраница = АктивируемаяСтраница;

