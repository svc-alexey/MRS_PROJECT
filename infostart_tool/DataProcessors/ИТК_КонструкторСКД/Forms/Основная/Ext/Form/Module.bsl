		НовыйПараметр.ИспользоватьВсегда = (Параметр.Использование = ИспользованиеПараметраКомпоновкиДанных.Всегда);
		ИТК_СКД.СкопироватьСтруктурноеПоле(НовыйПараметр.ПараметрыРедактирования, Параметр.ПараметрыРедактирования);

