&НаСервере
Процедура ЗагрузитьНаборыДанныхСхемыКомпоновкиДанныхВДанныеФормы(КоллекцияНаборовДанных, Родитель)
	
	Для Каждого НаборДанных Из КоллекцияНаборовДанных Цикл 
		
		ТипНабораДанных = ИТК_СКД.ПеречислениеТипНабораДанных(ТипЗнч(НаборДанных));
		ТипНабораДанныхЗапрос = (ТипНабораДанных = ИТК_Перечисления.СКДНаборДанныхЗапрос());
		
		НовыйНаборДанных = Родитель.ПолучитьЭлементы().Добавить();
		
		НовыйНаборДанных.Вид = ТипНабораДанных;
		НовыйНаборДанных.Картинка = ИТК_КонструкторСКДКлиентСервер.КартинкаНабораДанных(ТипНабораДанных);
		НовыйНаборДанных.Представление = НаборДанных.Имя;
		
		Если ТипНабораДанныхЗапрос Тогда
			
			НовыйНаборДанных.Источник = НаборДанных.ИсточникДанных;
			НовыйНаборДанных.ТекстЗапроса = НаборДанных.Запрос;
			
			АвтоЗаполнениеДоступныхПолей = НаборДанных.АвтоЗаполнениеДоступныхПолей;
			НовыйНаборДанных.АвтоЗаполнение = АвтоЗаполнениеДоступныхПолей;
			Если ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.14") Тогда
				НовыйНаборДанных.ИспользоватьГруппировкиЗапросаЕслиВозможно = НаборДанных.ИспользоватьГруппировкиЗапросаЕслиВозможно;
			КонецЕсли;
			
		ИначеЕсли ТипНабораДанных = ИТК_Перечисления.СКДНаборДанныхОбъект() Тогда
			
			НовыйНаборДанных.Источник = НаборДанных.ИсточникДанных;
			НовыйНаборДанных.ИмяОбъекта = НаборДанных.ИмяОбъекта;
			
		ИначеЕсли ТипНабораДанных = ИТК_Перечисления.СКДНаборДанныхОбъединение() Тогда
			
			ЗагрузитьНаборыДанныхСхемыКомпоновкиДанныхВДанныеФормы(НаборДанных.Элементы, НовыйНаборДанных)
			
		КонецЕсли;
		
		ЗагрузитьНаборПолейСхемыКомпоновкиДанныхВДанныеФормы(НаборДанных.Поля, НовыйНаборДанных.Поля);
		
		Если ТипНабораДанныхЗапрос Тогда
			
			Если АвтоЗаполнениеДоступныхПолей Тогда
				
				Идентификатор = НовыйНаборДанных.ПолучитьИдентификатор();
				ЗаполнитьПоляНабораДанныхНаСервере(Идентификатор);
				
			КонецЕсли;
			
		КонецЕсли;

	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьНаборПолейСхемыКомпоновкиДанныхВДанныеФормы(КоллекцияПолейНаборовДанных, Источник)
	
	Для Каждого ПолеНабораДанных Из КоллекцияПолейНаборовДанных Цикл 
		
		СтрокаПоле = ДобавитьОбновитьПолеНабора(Источник, ПолеНабораДанных);
		СтрокаПоле.ПутьКДанным = ПолеНабораДанных.ПутьКДанным;
		
		ЛокализированнаяСтрокаНСтр = ИТК_СКД.ЛокализированнаяСтрокаНСтрИзXDTO(ПолеНабораДанных, "title");
		СтрокаПоле.Заголовок = ЛокализированнаяСтрокаНСтр;
		СтрокаПоле.ЗаголовокПредставление = ПредставлениеЗаголовкаПоляКоллекции(ЛокализированнаяСтрокаНСтр, СтрокаПоле.Поле);
		
	КонецЦикла;
	
КонецПроцедуры

