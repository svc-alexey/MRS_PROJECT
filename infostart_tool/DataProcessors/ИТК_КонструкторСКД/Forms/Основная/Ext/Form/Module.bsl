&НаКлиенте
Процедура ПривестиЗначениеПараметраСКДВТекущейСтроке()
	
	ТекущиеДанные = Элементы.ПараметрыСКД.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущиеДанные.ДоступенСписокЗначений Тогда
		
		ОграничениеТипа = ИТК_ТипыКлиентСервер.ОписаниеТиповПоТипу(Тип("СписокЗначений"))
		
	Иначе
		
		ОграничениеТипа = ТекущиеДанные.ТипЗначения;
		ТекущиеДанные.Значение = ОграничениеТипа.ПривестиЗначение(ТекущиеДанные.Значение); 

	КонецЕсли;

	Элементы.ПараметрыСКДЗначение.ОграничениеТипа = ОграничениеТипа;
	
КонецПроцедуры

&НаКлиенте
Функция ДобавитьМакет(Вид, Активировать = Истина)
	
	НоваяСтрока = Макеты.Добавить();
