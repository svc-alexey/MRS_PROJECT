	НоваяСтрока.Представление = "123";
	
	Если Активировать Тогда
		Элементы.Макеты.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
	КонецЕсли;
	
	ОбновитьКоличествоВЗаголовке(Элементы.Макеты);
	
	Возврат НоваяСтрока;
	
КонецФункции

&НаКлиенте
Процедура РедактированияЗаголовкаПоляКоллекцииВОтдельнойФорме(Элемент, СтандартнаяОбработка) Экспорт
	
	СтандартнаяОбработка = Ложь;
	
	ЭлементКоллекция = ИТК_ФормаКлиент.КоллекцияРодитель(Элемент);
	ТекущиеДанные = ЭлементКоллекция.ТекущиеДанные;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Элемент", ЭлементКоллекция);
	ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("РедактированияЗаголовкаПоляКоллекцииВОтдельнойФормеЗавершено", ЭтотОбъект, ДополнительныеПараметры);
	
	ИТК_ФормаКлиент.ОткрытьКонструкторСтрокНаРазныхЯзыках(ЭтотОбъект, ОписаниеОповещенияЗавершение, ТекущиеДанные.Заголовок);
	
КонецПроцедуры

&НаКлиенте
Процедура РедактированияЗаголовкаПоляКоллекцииВОтдельнойФормеЗавершено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Модифицированность = Истина;
	
	ЭлементКоллекция = ДополнительныеПараметры.Элемент;
	ИмяПоля = ИмяПоляИдентификатораКоллекции(ЭлементКоллекция);
	Если НЕ ЗначениеЗаполнено(ИмяПоля) Тогда 
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = ЭлементКоллекция.ТекущиеДанные;
	ТекущиеДанные["Заголовок"] = Результат;
	ТекущиеДанные["ЗаголовокПредставление"] = ПредставлениеЗаголовкаПоляКоллекции(Результат, ТекущиеДанные[ИмяПоля]);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗафиксироватьИзменениеЗаголовка(Элемент, НовыйЗаголовок = Неопределено)
	
	ЭлементКоллекция = ИТК_ФормаКлиент.КоллекцияРодитель(Элемент);
	ТекущиеДанные = ЭлементКоллекция.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(НовыйЗаголовок) Тогда
		
		Если НЕ ЗначениеЗаполнено(ТекущиеДанные["ЗаголовокПредставление"]) Тогда
			ТекущиеДанные["ЗаголовокПредставление"] = НовыйЗаголовок;
		КонецЕсли;
		
	КонецЕсли;

	ИТК_Строки.ЛокализированнаяСтрокаОбновитьПредставление(ТекущиеДанные["Заголовок"], ТекущиеДанные["ЗаголовокПредставление"]);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаконченоИзменениеИмяПоляКоллекцииСЗаголовком(Элемент)
	
	ЭлементКоллекция = ИТК_ФормаКлиент.КоллекцияРодитель(Элемент);
	ТекущиеДанные = ЭлементКоллекция.ТекущиеДанные;
	
	ИмяПоля = ИмяПоляИдентификатораКоллекции(ЭлементКоллекция);
	Если НЕ ЗначениеЗаполнено(ИмяПоля) Тогда 
		Возврат;
	КонецЕсли;
	
	ИмяПоля = ТекущиеДанные[ИмяПоля];
	НовыйЗаголовок = ИТК_Строки.ПредставлениеИдентификатора(ИмяПоля);
	ЗафиксироватьИзменениеЗаголовка(Элемент, НовыйЗаголовок);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаконченоИзменениеПутьКДанным(Элемент)
	
	ЭлементКоллекция = ИТК_ФормаКлиент.КоллекцияРодитель(Элемент);
	ТекущиеДанные = ЭлементКоллекция.ТекущиеДанные;
	
	ПутьКДанным = ИТК_КонструкторСКДКлиентСервер.ПутьКДанным(ТекущиеДанные["ПутьКДанным"]);
	ТекущиеДанные["ПутьКДанным"] = ПутьКДанным;
	
	ЗафиксироватьИзменениеЗаголовка(Элемент, ПутьКДанным);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПредставлениеЗаголовкаПоляКоллекции(ЛокализированнаяСтрока, ИмяПоля)
	
	ПредставлениеНаТекущемЯзыке = ИТК_Строки.ЛокализированнаяСтрокаПредставлениеНаТекущемЯзыке(ЛокализированнаяСтрока);
	
	Результат = ПредставлениеНаТекущемЯзыке;
	Если НЕ ИТК_Строки.ЛокализированнаяСтрокаНаНесколькихЯзыках(ЛокализированнаяСтрока)
			И ПредставлениеНаТекущемЯзыке = ИТК_Строки.ПредставлениеИдентификатора(ИмяПоля) Тогда
			
		Результат = "";
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ОбновитьВидимостьСкрываемыхПолейКоллекций(Элемент, Поля, Видимость = Истина)
	
	ИмяКоллекции = Элемент.Имя;
	Если Элемент = Элементы.ПоляНаборовДанных Тогда
		Коллекция = Элементы.НаборыДанных.ТекущиеДанные.Поля;
	Иначе
		Коллекция = ЭтотОбъект[ИмяКоллекции];
	КонецЕсли;
	
	ИмяПоказыватьПодробно = ИмяКоллекции + "Подробно";
	ПоказыватьПодробно = ЭтотОбъект[ИмяПоказыватьПодробно];
	Элементы[ИмяПоказыватьПодробно].Пометка = ПоказыватьПодробно;
	
	ЗаполненныеПоля = ИТК_ФормаКлиент.ПрисутствуютЗаполненныеЗначенияКоллекции(Коллекция, Поля);
	Для Каждого ИмяПоля Из Поля Цикл 
		
		Элементы[ИмяКоллекции + ИмяПоля].Видимость = Видимость 
														И (ПоказыватьПодробно
															ИЛИ ЗаполненныеПоля.Свойство(ИмяПоля));
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗагрузкиСхемыКомпоновкиДанных()
	
	ОбновитьКоличествоВоВсехЗаголовках();
	ОбновитьОсновнойВариантНастроек();
	
	// Активируем первый набор данных
	НаборыДанныхЭлменты = НаборыДанных.ПолучитьЭлементы();
	Если ЗначениеЗаполнено(НаборыДанныхЭлменты) Тогда
		
		ПервыйНаборДанных = НаборыДанныхЭлменты[0];
		Элементы.НаборыДанных.ТекущаяСтрока = ПервыйНаборДанных.ПолучитьИдентификатор();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьКоличествоВоВсехЗаголовках()
	
	ОбновитьКоличествоВЗаголовке(Элементы.НаборыДанных);
	ОбновитьКоличествоВЗаголовке(Элементы.ВычисляемыеПоля);
	ОбновитьКоличествоВЗаголовке(Элементы.СвязиНаборовДанных);
	ОбновитьКоличествоВЗаголовке(Элементы.Ресурсы);
	ОбновитьКоличествоВЗаголовке(Элементы.ПараметрыСКД);
	ОбновитьКоличествоВЗаголовке(Элементы.Макеты);
	ОбновитьКоличествоВЗаголовке(Элементы.ВложенныеСхемы);
	ОбновитьКоличествоВЗаголовке(Элементы.ВариантыНастроек);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьКоличествоВЗаголовке(Элемент)
	
	Коллекция = ЭтотОбъект[Элемент.Имя];
	
	Если ТипЗнч(Коллекция) = Тип("ДанныеФормыДерево") Тогда
		
		Отбор = Неопределено;
		Если Элемент = Элементы.ВычисляемыеПоля Тогда
			Отбор = Новый Структура;
			Отбор.Вставить("Вид", ИТК_Перечисления.СКДВидыПолейНаборовДанныхПоле());
		КонецЕсли;
		
		КоличествоВКоллекции = ИТК_ФормаКлиент.КоличествоСтрокВДереве(Коллекция, Отбор);
		
	Иначе
		
		КоличествоВКоллекции = Коллекция.Количество();
		
	КонецЕсли;
	
	ЭтотОбъект[Элемент.Имя + "Количество"] = КоличествоВКоллекции;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОсновнойВариантНастроек()
	
	Для Индекс = 0 По ВариантыНастроек.Количество() - 1 Цикл 
		
		ВариантНастроек = ВариантыНастроек[Индекс];
		ВариантНастроек.Основной = (Индекс = 0);
		
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСписокВыбораОформления(Элемент, ИмяПоля)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТипЗначения = ТекущиеДанные[ИмяПоля];
	
	ЭлементКолонка = Элементы[Элемент.Имя + "Оформление"];
	СписокВыбора = ЭлементКолонка.СписокВыбора;
	СписокВыбора.Очистить();
	
	Если ТипЗначения.СодержитТип(Тип("Число")) Тогда
		
		КвалификаторыЧисла = ТипЗначения.КвалификаторыЧисла;
		
		Если КвалификаторыЧисла.Разрядность >= 5 Тогда
			
			Если ЗначениеЗаполнено(КвалификаторыЧисла.РазрядностьДробнойЧасти) Тогда
				
				Оформление = Новый Структура;
				Оформление.Вставить("Формат", "ЧЦ=15; ЧДЦ=2");
				СписокВыбора.Добавить(Оформление, "Формат: денежный (15, 2)");
				
				Оформление = Новый Структура;
				Оформление.Вставить("Формат", "ЧЦ=10; ЧДЦ=3");
				СписокВыбора.Добавить(Оформление, "Формат: количество (10, 3)");
				
			КонецЕсли;
			
			Если КвалификаторыЧисла.ДопустимыйЗнак = ДопустимыйЗнак.Любой Тогда
				
				Оформление = Новый Структура;
				Оформление.Вставить("ВыделятьОтрицательные", Истина);
				СписокВыбора.Добавить(Оформление, "Выделять отрицательные");
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ТипЗначения.СодержитТип(Тип("Дата")) Тогда
		
		КвалификаторыДаты = ТипЗначения.КвалификаторыДаты;
		
		Если КвалификаторыДаты.ЧастиДаты = ЧастиДаты.Время Тогда
			
			Оформление = Новый Структура;
			Оформление.Вставить("Формат", "ДФ=HH:mm");
			СписокВыбора.Добавить(Оформление, "Формат: время кратко ЧЧ:мм");
			
		КонецЕсли;
		
		Если КвалификаторыДаты.ЧастиДаты = ЧастиДаты.ДатаВремя Тогда
			
			Оформление = Новый Структура;
			Оформление.Вставить("Формат", "ДЛФ=D");
			СписокВыбора.Добавить(Оформление, "Формат: дата без времени(локальный)");
			
			Оформление = Новый Структура;
			Оформление.Вставить("Формат", "ДФ='dd.MM.yyyy HH:mm'");
			СписокВыбора.Добавить(Оформление, "Формат: дата и время кратко дд.ММ.гггг ЧЧ:мм");
			
		КонецЕсли;
		
	КонецЕсли;
	
	КнопкаСпискаВыбора = ЗначениеЗаполнено(СписокВыбора);
	ЭлементКолонка.КнопкаВыпадающегоСписка = КнопкаСпискаВыбора;
	ЭлементКолонка.КнопкаСпискаВыбора = КнопкаСпискаВыбора;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДобавитьПоляИерархииРесурсов(ОписаниеПолей)
	
	ИерархическиеРесурсы = Новый Массив;
	Для Каждого ОписаниеПоля Из ОписаниеПолей Цикл 
		
		СсылочныеТипы = ИТК_ТипыКлиентСервер.СсылочныеТипы(ОписаниеПоля.Значение);
		Если НЕ ЗначениеЗаполнено(СсылочныеТипы) Тогда
			Продолжить;
		КонецЕсли;
		
		Иерархический = Ложь;
		Для Каждого Тип Из СсылочныеТипы.Типы() Цикл 
			
			ОбъектМетаданных = Метаданные.НайтиПоТипу(Тип);
			Если ИТК_Метаданные.ОбъектСИерархией(ОбъектМетаданных) Тогда
				
				Иерархический = Истина;
				Прервать;
				
			КонецЕсли;
			
			
		КонецЦикла;
		
		ИерархическиеРесурсы.Добавить(ОписаниеПоля.Представление);
		
	КонецЦикла;
	
	Для Каждого ИмяРесурса Из ИерархическиеРесурсы Цикл 
		
		ЭлементРесурс = ИТК_ОбщийКлиентСервер.СписокЗначенийНайтиПоПредставлению(ОписаниеПолей, ИмяРесурса);
		
		ИндексВставки = ОписаниеПолей.Индекс(ЭлементРесурс);
		ОписаниеПолей.Вставить(ИндексВставки + 1, ЭлементРесурс.Значение, ИмяРесурса + " Иерархия");

	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Функция ДоступныеПараметрыСКД()
	
	Результат = Новый Соответствие;
	
	Для Каждого СтрокаПараметрСКД Из ПараметрыСКД Цикл 
		
		Результат.Вставить(СтрокаПараметрСКД.Имя, СтрокаПараметрСКД.ТипЗначения);

	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ОбновитьОсновнуюСхемуКомпоновкиДанныхИзДанныхФормы()
	
	АдресСхемыКомпоновкиДанных = СобратьСхемуКомпоновкиДанныхИзДанныхФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйЗагрузитьСостояниеРедактораЗапроса()
	
	ТекущиеДанные = Элементы.НаборыДанных.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Элемент = Элементы.ТекстЗапроса;
	ИТК_РедакторКодаКлиент.УстановитьТекст(ЭтотОбъект, Элемент, ТекущиеДанные.ТекстЗапроса);
	
	Если НЕ ИТК_РедакторКодаКлиент.Инициализирован(Элемент) Тогда
		
		ПодключитьОбработчикОжидания("ПодключаемыйЗагрузитьСостояниеРедактораЗапроса", 0.1, Истина);
		Возврат;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ИмяПоляИдентификатораКоллекции(Элемент)
	
	Если Элемент = Элементы.ПоляНаборовДанных Тогда
		Результат = "Поле";
	ИначеЕсли Элемент = Элементы.ВычисляемыеПоля Тогда
		Результат = "ПутьКДанным";
	Иначе
		Результат = "Имя";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ИмяПоляПутьКДаннымКоллекции(Элемент)
	
	Результат = Неопределено;
	Если Элемент = Элементы.ПоляНаборовДанных
			ИЛИ Элемент = Элементы.ВычисляемыеПоля Тогда
			
		Результат = "ПутьКДанным";
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция КоллекцияПоЭлементуКоллекции(Элемент)
	
	Если Элемент = Элементы.ПоляНаборовДанных Тогда
		Результат = Элементы.НаборыДанных.ТекущиеДанные.Поля;
	ИначеЕсли Элемент = Элементы.ВычисляемыеПоля Тогда
		Результат = ВычисляемыеПоля;
	ИначеЕсли Элемент = Элементы.ПараметрыСКД Тогда
		Результат = ПараметрыСКД;
	ИначеЕсли Элемент = Элементы.ВложенныеСхемы Тогда
		Результат = ВложенныеСхемы;
	ИначеЕсли Элемент = Элементы.ВариантыНастроек Тогда
		Результат = ВариантыНастроек;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ПроверкаСтрокиПриНачалеРедактирования(Элемент)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;

	ИмяПоля = ИмяПоляИдентификатораКоллекции(Элемент);
	ПредыдущийИдентификатор = ТекущиеДанные[ИмяПоля];
	
	ИмяПоляПутьКДанным = ИмяПоляПутьКДаннымКоллекции(Элемент);
	ПредыдущийПутьКДанным = ТекущиеДанные[ИмяПоляПутьКДанным];
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаСтрокиПередОкончаниемРедактирования(Элемент, ОтменаРедактирования, Отказ)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИмяПоля = ИмяПоляИдентификатораКоллекции(Элемент);
	ИмяПоляПутьКДанным = ИмяПоляПутьКДаннымКоллекции(Элемент);
	
	Если ОтменаРедактирования Тогда
		
		ТекущиеДанные[ИмяПоля] = ПредыдущийИдентификатор;
		ТекущиеДанные[ИмяПоляПутьКДанным] = ПредыдущийПутьКДанным;
		Возврат;
		
	КонецЕсли;
	
	Ошибки = Новый Массив;
	Коллекция = КоллекцияПоЭлементуКоллекции(Элемент);
	
	// Проверка идентификатора
	НовыйИдентификатор = ТекущиеДанные[ИмяПоля];
	Если (Элемент = Элементы.ПоляНаборовДанных И ТекущиеДанные.Вид <> ИТК_Перечисления.СКДВидыПолейНаборовДанныхГруппа())
			ИЛИ Элемент <> Элементы.ВычисляемыеПоля Тогда
			
		Если ИТК_Строки.НекорректныйИдентификатор(НовыйИдентификатор) Тогда
			
			ТекстОшибки = НСтр("ru = 'Некорректный идентификатор';
								|en = 'Invalid identifier'");
			Ошибки.Добавить(ТекстОшибки);
			
		КонецЕсли;
		
		ЗанятыеИдентификаторы = ИспользуемыеИдентификаторыКоллекции(Элемент, Коллекция, ТекущиеДанные.ПолучитьИдентификатор());
		Если ЗанятыеИдентификаторы.Найти(НовыйИдентификатор) <> Неопределено Тогда
			
			ТекстОшибки = НСтр("ru = 'Идентификатор уже используется';
								|en = 'The identifier is already in use'");
			Ошибки.Добавить(ТекстОшибки);
			
		КонецЕсли;
		
	КонецЕсли;
	
	// Проверки путь к данным
	Если ЗначениеЗаполнено(ИмяПоляПутьКДанным) Тогда
		
		НовыйПутьКДанным = ТекущиеДанные[ИмяПоляПутьКДанным];
		ЗанятыеПутиКДанным = ИспользуемыеПутиКДаннымКоллекции(Элемент, Коллекция, ТекущиеДанные.ПолучитьИдентификатор());
		Если ЗанятыеПутиКДанным.Найти(НовыйПутьКДанным) <> Неопределено Тогда
			
			ТекстОшибки = НСтр("ru = 'Путь к данным уже используется';
								|en = 'The data path is already in use'");
			Ошибки.Добавить(ТекстОшибки);
				
		КонецЕсли;
	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Ошибки) Тогда
		
		Отказ = Истина;
		
		ТекстПредупреждения = СтрСоединить(Ошибки, Символы.ПС);
		ПоказатьПредупреждение( , ТекстПредупреждения);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ИспользуемыеИдентификаторыКоллекции(Элемент, Коллекция, ИдентификаторИсключения = Неопределено)
	
	Результат = Новый Массив;
	ИмяПоля = ИмяПоляИдентификатораКоллекции(Элемент);
	
	Если ТипЗнч(Коллекция) = Тип("ДанныеФормыДерево") Тогда
		ИсточникПолей = Коллекция.ПолучитьЭлементы();
	Иначе
		ИсточникПолей = Коллекция;
	КонецЕсли;
	
	Для Каждого Поле Из ИсточникПолей Цикл 
		
		Если ИдентификаторИсключения = Поле.ПолучитьИдентификатор() Тогда
			Продолжить;
		КонецЕсли;
		
		Результат.Добавить(Поле[ИмяПоля]);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ИспользуемыеПутиКДаннымКоллекции(Элемент, Коллекция, ИдентификаторИсключения = Неопределено)
	
	Результат = Новый Массив;
	ИмяПоляПутьКДанным = ИмяПоляПутьКДаннымКоллекции(Элемент);
	
	Если ТипЗнч(Коллекция) = Тип("ДанныеФормыДерево") Тогда
		ИсточникПолей = Коллекция.ПолучитьЭлементы();
	Иначе
		ИсточникПолей = Коллекция;
	КонецЕсли;
	
	Для Каждого Поле Из ИсточникПолей Цикл 
		
		Если ИдентификаторИсключения = Поле.ПолучитьИдентификатор() Тогда
			Продолжить;
		КонецЕсли;
		
		Результат.Добавить(Поле[ИмяПоляПутьКДанным]);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ОбработкаПереименованияНабораДанных(Элемент, НоваяСтрока, ОтменаРедактирования)
	
	Если ОтменаРедактирования Тогда
		НаборыДанныхСтароеИмя = Неопределено;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(НаборыДанныхСтароеИмя) Тогда
		
		ТекущиеДанные = Элемент.ТекущиеДанные;
		Если ТекущиеДанные.ПолучитьРодителя() = Неопределено Тогда
			
			НовоеИмя = ТекущиеДанные["Представление"];
			Если НаборыДанныхСтароеИмя <> НовоеИмя Тогда
				
				Для Каждого СтрокаСвязьНабораДанных Из СвязиНаборовДанных Цикл 
					
					Если СтрокаСвязьНабораДанных.НаборДанныхИсточник = НаборыДанныхСтароеИмя Тогда
						СтрокаСвязьНабораДанных.НаборДанныхИсточник = НовоеИмя;
					КонецЕсли;
					
					Если СтрокаСвязьНабораДанных.НаборДанныхПриемник = НаборыДанныхСтароеИмя Тогда
						СтрокаСвязьНабораДанных.НаборДанныхПриемник = НовоеИмя;
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЕсли;
		
		КонецЕсли;
		
	КонецЕсли;
	
	НаборыДанныхСтароеИмя = Неопределено;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаУдалениеНабораДанных(СтрокаНабораДанных)
	
	Если СтрокаНабораДанных.ПолучитьРодителя() <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИмяНабораДанных = СтрокаНабораДанных["Представление"];

	УдаляемыеСвязиНаборовДанных = Новый Массив;
	Для Каждого СтрокаСвязьНабораДанных Из СвязиНаборовДанных Цикл 
		
		Если СтрокаСвязьНабораДанных.НаборДанныхИсточник = ИмяНабораДанных
				ИЛИ СтрокаСвязьНабораДанных.НаборДанныхПриемник = ИмяНабораДанных Тогда
				
			УдаляемыеСвязиНаборовДанных.Добавить(СтрокаСвязьНабораДанных);
				
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого УдаляемаяСвязьНаборовДанных Из УдаляемыеСвязиНаборовДанных Цикл 
		
		СвязиНаборовДанных.Удалить(УдаляемаяСвязьНаборовДанных);
		
	КонецЦикла;
	
	ОбновитьКоличествоВЗаголовке(Элементы.СвязиНаборовДанных);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаПослеИзмененияЗапросаНабораДанных()
	
	ОбновитьДоступныеПоляРесурсов();
	ОбновитьПараметры();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаПослеУдаленияПоляНабораОбъект()
	
	ОбновитьДоступныеПоляРесурсов();

КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияПредупрежденияНекорректноеИмяОбъектаНабораДанных(ДополнительныеПараметры) Экспорт
	
	ТекущийЭлемент = Элементы.НаборыДанныхИмяОбъекта;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписокВыбораПараметраСвязейНаборов()
	
	ДанныеВыбора = Новый Массив;
	Для Каждого СтрокаПараметр Из ПараметрыСКД Цикл 
		ДанныеВыбора.Добавить(СтрокаПараметр.Имя);
	КонецЦикла;
	
	ЭлементПараметрСвязейВыбора = Элементы.СвязиНаборовДанныхПараметр;
	
	ЭлементПараметрСвязейВыбора.СписокВыбора.ЗагрузитьЗначения(ДанныеВыбора);
	ЭлементПараметрСвязейВыбора.КнопкаВыпадающегоСписка = ЗначениеЗаполнено(ДанныеВыбора);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписокВыбораВыраженияСвязиНаборов(Поле)
	
	ТекущиеДанные = Элементы.СвязиНаборовДанных.ТекущиеДанные;
	ИмяНабораДанных = ТекущиеДанные["НаборДанных" + Поле];
	
	Элемент = Элементы["СвязиНаборовДанныхВыражение" + Поле];
	Элемент.СписокВыбора.Очистить();
	
	Если ЗначениеЗаполнено(ИмяНабораДанных) Тогда
		
		НаборДанных = НайтиНаборовДанныхПоИмени(ИмяНабораДанных);
		
		ДоступныеПоля = ДоступныеПоляНабораДанных(НаборДанных);
		Для Каждого ЭлементДоступноеПоле Из ДоступныеПоля Цикл 
			Элемент.СписокВыбора.Добавить(ЭлементДоступноеПоле.Представление, , , ЭлементДоступноеПоле.Картинка);
		КонецЦикла;
		
	КонецЕсли;
	
	Элемент.КнопкаВыпадающегоСписка = ЗначениеЗаполнено(Элемент.СписокВыбора);

КонецПроцедуры

&НаСервере
Процедура ИнициализацияРедактораЗапроса()
	
	ДополнительныеСвойства = Новый Структура;
	ДополнительныеСвойства.Вставить("ТипЯзыка", ИТК_Перечисления.ТипЯзыкаРедактораЗапросы());
	ДополнительныеСвойства.Вставить("РежимКомпоновкиДанных", Истина);
	
	ИТК_РедакторКода.Инициализация(ЭтотОбъект, "ТекстЗапроса", ДополнительныеСвойства);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ОписаниеРолиПоля(ЗапросПакета, Колонка)
	
	Измерение = Ложь;
	НомерПериода = 0;

	Остаток = Ложь;
	ТипОстатка = Неопределено;
	ТипБухгалтерскогоОстатка = Неопределено;
	ПолеСчета = "";
	ГруппаОстатка = "";
	
	Счет = Ложь;
	ВыражениеВидаСчета = "";
	
	ИгнорироватьЗначенияNULL = Ложь;

	Для Каждого ПолеКолонки Из Колонка.Поля Цикл 
		
		Если ТипЗнч(ПолеКолонки) = Тип("КолонкаВложеннаяТаблицаСхемыЗапроса") Тогда
			Продолжить;
		КонецЕсли;
		
		ЧастиВыражения = СтрРазделить(ПолеКолонки, ".");
		Если ЧастиВыражения.Количество() <> 2 Тогда
			Продолжить;
		КонецЕсли;
		
		ПсевдонимИсточника = ЧастиВыражения[0];
		ИмяПоля = ЧастиВыражения[1];
		
		Для Каждого ОператорЗапроса Из ЗапросПакета.Операторы Цикл 
			
			Для Каждого ИсточникОператораЗапроса Из ОператорЗапроса.Источники Цикл 
				
				Источник = ИсточникОператораЗапроса.Источник;
				Если НЕ (ТипЗнч(Источник) = Тип("ТаблицаСхемыЗапроса")
							И ПсевдонимИсточника = Источник.Псевдоним) Тогда 
					Продолжить;
				КонецЕсли;
				
				ЧастиИсточника = СтрРазделить(Источник.ИмяТаблицы, ".");
				Если ЧастиИсточника.Количество() = 1 Тогда
					Продолжить;
				КонецЕсли;
				
				ИмяКоллекции = ЧастиИсточника[0];
				ИмяОбъектКоллекции = ЧастиИсточника[1];
				
				ИмяВиртуальнойТаблицы = Неопределено;
				Если ЧастиИсточника.Количество() > 2 Тогда
					ИмяВиртуальнойТаблицы = ЧастиИсточника[2];
				КонецЕсли;
				
				ДоступноеПоле = ИсточникОператораЗапроса.Источник.ДоступныеПоля.Найти(ИмяПоля);
				Если ДоступноеПоле <> Неопределено Тогда
					
					Если ДоступноеПоле.Роль.Измерение Тогда
						
						
						Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоРегистрБухгалтерии(ИмяКоллекции) Тогда
							
							ИмяПоляСчет = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляСчетРегистраБухгалтерии();
							Если ИмяПоля = ИмяПоляСчет Тогда
								
								Счет = Истина;
								ВыражениеВидаСчета = ИмяПоляСчет + "." + ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляВидСчетаПланаСчетов();
								
							Иначе
								
								Измерение = Истина;
								
								Для НомерСубконто = 1 По 10 Цикл
									
									Если СтрЗаканчиваетсяНа(ИмяПоля, "Субконто" + НомерСубконто)
											ИЛИ СтрЗаканчиваетсяНа(ИмяПоля, "ExtDimensions" + НомерСубконто) Тогда
										ИгнорироватьЗначенияNULL = Истина;
									КонецЕсли;
									
								КонецЦикла;
								
							КонецЕсли;
							
						Иначе
							Измерение = Истина;
						КонецЕсли;
						
					ИначеЕсли ДоступноеПоле.Роль.Ресурс Тогда
						
						// Остаток
						Если (ИмяВиртуальнойТаблицы = "ОстаткиИОбороты"
								ИЛИ ИмяВиртуальнойТаблицы = "BalanceAndTurnovers") Тогда
									
							ВариантыОкончанияИмениПоля = Новый СписокЗначений;
							Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоРегистрНакопления(ИмяКоллекции) Тогда
								
								ВариантыОкончанияИмениПоля.Добавить("НачальныйОстаток", "НачальныйОстаток");
								ВариантыОкончанияИмениПоля.Добавить("НачальныйОстаток", "OpeningBalance");
								
								ВариантыОкончанияИмениПоля.Добавить("КонечныйОстаток", "КонечныйОстаток");
								ВариантыОкончанияИмениПоля.Добавить("КонечныйОстаток", "ClosingBalance");
									
							ИначеЕсли ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоРегистрБухгалтерии(ИмяКоллекции) Тогда
								
								// Развернутый
								ВариантыОкончанияИмениПоля.Добавить("НачальныйОстаток", "НачальныйРазвернутыйОстатокДт");
								ВариантыОкончанияИмениПоля.Добавить("НачальныйОстаток", "OpeningSplittedBalanceDr");
								ВариантыОкончанияИмениПоля.Добавить("НачальныйОстаток", "НачальныйРазвернутыйОстатокКт");
								ВариантыОкончанияИмениПоля.Добавить("НачальныйОстаток", "OpeningSplittedBalanceCr");
								ВариантыОкончанияИмениПоля.Добавить("КонечныйОстаток", "КонечныйРазвернутыйОстатокДт");
								ВариантыОкончанияИмениПоля.Добавить("КонечныйОстаток", "ClosingSplittedBalanceDr");
								ВариантыОкончанияИмениПоля.Добавить("КонечныйОстаток", "КонечныйРазвернутыйОстатокКт");
								ВариантыОкончанияИмениПоля.Добавить("КонечныйОстаток", "ClosingSplittedBalanceCr");
								
								// НачальныйОстаток - Дебет
								ОписаниеЗначенийВарианта = Новый Структура;
								ОписаниеЗначенийВарианта.Вставить("ТипОстатка", "НачальныйОстаток");
								ОписаниеЗначенийВарианта.Вставить("ТипБухгалтерскогоОстатка", "Дебет");
								
								ВариантыОкончанияИмениПоля.Добавить(ОписаниеЗначенийВарианта, "НачальныйОстатокДт");
								ВариантыОкончанияИмениПоля.Добавить(ОписаниеЗначенийВарианта, "OpeningBalanceDr");
								
								// КонечныйОстаток - Дебет
								ОписаниеЗначенийВарианта = Новый Структура;
								ОписаниеЗначенийВарианта.Вставить("ТипОстатка", "КонечныйОстаток");
								ОписаниеЗначенийВарианта.Вставить("ТипБухгалтерскогоОстатка", "Дебет");
								
								ВариантыОкончанияИмениПоля.Добавить(ОписаниеЗначенийВарианта, "КонечныйОстатокДт");
								ВариантыОкончанияИмениПоля.Добавить(ОписаниеЗначенийВарианта, "ClosingBalanceDr");

								// НачальныйОстаток - Кредит
								ОписаниеЗначенийВарианта = Новый Структура;
								ОписаниеЗначенийВарианта.Вставить("ТипОстатка", "НачальныйОстаток");
								ОписаниеЗначенийВарианта.Вставить("ТипБухгалтерскогоОстатка", "Кредит");
								
								ВариантыОкончанияИмениПоля.Добавить(ОписаниеЗначенийВарианта, "НачальныйОстатокКт");
								ВариантыОкончанияИмениПоля.Добавить(ОписаниеЗначенийВарианта, "OpeningBalanceCr");
								
								// КонечныйОстаток - Кредит
								ОписаниеЗначенийВарианта = Новый Структура;
								ОписаниеЗначенийВарианта.Вставить("ТипОстатка", "КонечныйОстаток");
								ОписаниеЗначенийВарианта.Вставить("ТипБухгалтерскогоОстатка", "Кредит");
								
								ВариантыОкончанияИмениПоля.Добавить(ОписаниеЗначенийВарианта, "КонечныйОстатокКт");
								ВариантыОкончанияИмениПоля.Добавить(ОписаниеЗначенийВарианта, "ClosingBalanceCr");
								
							КонецЕсли;
							
							Для Каждого ЭлементВариантаОкончанияИмениПоля Из ВариантыОкончанияИмениПоля Цикл 
								
								ОписаниеЗначенийВарианта = ЭлементВариантаОкончанияИмениПоля.Значение;
								ВариантОкончанияИмениПоля = ЭлементВариантаОкончанияИмениПоля.Представление;
								
								Если СтрЗаканчиваетсяНа(ИмяПоля, ВариантОкончанияИмениПоля) Тогда
									
									Остаток = Истина;
									ГруппаОстатка = Лев(ИмяПоля, СтрДлина(ИмяПоля) - СтрДлина(ВариантОкончанияИмениПоля));
									
									Если ТипЗнч(ОписаниеЗначенийВарианта) = Тип("Строка") Тогда
										ТипОстатка = ОписаниеЗначенийВарианта;
									Иначе
										
										ТипОстатка = ОписаниеЗначенийВарианта.ТипОстатка;
										ТипБухгалтерскогоОстатка = ОписаниеЗначенийВарианта.ТипБухгалтерскогоОстатка;
										ПолеСчета = ИТК_МетаданныеКлиентСерверПовтИсп.СтандартноеИмяПоляСчетРегистраБухгалтерии();
										
									КонецЕсли;
									
									Прервать;
									
								КонецЕсли;	
								
							КонецЦикла;
							
						КонецЕсли;
					
					Иначе
						НомерПериода = РольПоляНомерПериода(ЗапросПакета, ИмяКоллекции, ИмяПоля);
					КонецЕсли;
					
				КонецЕсли;

			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Результат = Новый Структура;
	
	// Роль "Измерение"
	Результат.Вставить("Измерение", Измерение);
	
	// Роль "Период"
	Результат.Вставить("НомерПериода", НомерПериода);
	
	// Роль "Остаток"
	Результат.Вставить("Остаток", Остаток);
	
	Если НЕ ЗначениеЗаполнено(ТипОстатка) Тогда
		ТипОстатка = "Нет";
	КонецЕсли;
	Результат.Вставить("ТипОстатка", ТипОстатка);

	Если НЕ ЗначениеЗаполнено(ТипБухгалтерскогоОстатка) Тогда
		ТипБухгалтерскогоОстатка = "Нет";
	КонецЕсли;
	Результат.Вставить("ТипБухгалтерскогоОстатка", ТипБухгалтерскогоОстатка);
	
	Результат.Вставить("ПолеСчета", ПолеСчета);
	
	Результат.Вставить("ГруппаОстатка", ГруппаОстатка);
	
	// Роль "Счет"
	Результат.Вставить("Счет", Счет);
	Результат.Вставить("ВыражениеВидаСчета", ВыражениеВидаСчета);
	
	// Прочие
	Результат.Вставить("ИгнорироватьЗначенияNULL", ИгнорироватьЗначенияNULL);
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция РольПоляНомерПериода(ЗапросПакета, ИмяКоллекции, ИмяПоля)
	
	Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоРегистрНакопления(ИмяКоллекции)
			ИЛИ ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоРегистрБухгалтерии(ИмяКоллекции) Тогда
		СписокПолейПериода = ИТК_КонструкторСКДКлиентСервер.СписокПолейНомерПериодаРегистрыБухгалтерииИНакопления();
	ИначеЕсли ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоРегистрРасчета(ИмяКоллекции) Тогда
		СписокПолейПериода = ИТК_КонструкторСКДКлиентСервер.СписокПолейНомерПериодаРегистрыРасчета();;
	Иначе
		СписокПолейПериода = Неопределено;
	КонецЕсли;
	
	Если СписокПолейПериода = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	
	ПоляРолиПериод = СтрРазделить(СписокПолейПериода, ",");
	Если ПоляРолиПериод.Найти(ИмяПоля) = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
						
	НомерПериода = 1;
	Для Каждого ПолеРолиПериод Из ПоляРолиПериод Цикл 
		
		Если ПолеРолиПериод = ИмяПоля Тогда
			Прервать;
		КонецЕсли;
		
		Если ЗапросПакета.Колонки.Найти(ПолеРолиПериод) <> Неопределено Тогда
			НомерПериода = НомерПериода + 1;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат НомерПериода;
	
КонецФункции

&НаКлиенте
Процедура ЗавершениеРаботыКонструктораНастроек(Результат, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(Результат) <> Тип("НастройкиКомпоновкиДанных") Тогда
		Возврат;
	КонецЕсли;
	
	КомпоновщикНастроек.ЗагрузитьНастройки(Результат);
	
КонецПроцедуры

#КонецОбласти