#КонецОбласти

#Область ОбработчикиСобытийЭлементовДереваНаборыДанных

&НаКлиенте
Процедура НаборыДанныхПриАктивизацииСтроки(Элемент)
	
	ТекущаяСтрока = Элемент.ТекущиеДанные;
	НаборыДанныхИдентификаторТекущейСтроки = Элемент.ТекущаяСтрока;
	
	Если НаборыДанныхИдентификаторПоследнейВыделеннойСтроки <> НаборыДанныхИдентификаторТекущейСтроки Тогда 
		
		НаборыДанныхИдентификаторПоследнейВыделеннойСтроки = НаборыДанныхИдентификаторТекущейСтроки;
		
		ПодключаемыйЗагрузитьСостояниеРедактораЗапроса();
		
		Если ТекущаяСтрока = Неопределено Тогда
			ТекущаяСтрокаВид = Неопределено;
		Иначе
			ТекущаяСтрокаВид = ТекущаяСтрока.Вид;
		КонецЕсли;

		Если ТекущаяСтрокаВид = ИТК_Перечисления.СКДНаборДанныхОбъединение() Тогда
				
			ЗаполнитьПоляНабораДанныхОбъединение(НаборыДанныхИдентификаторТекущейСтроки);
			
		ИначеЕсли ТекущаяСтрокаВид = ИТК_Перечисления.СКДНаборДанныхЗапрос() Тогда
			
			ЭлементТекст = Элементы.ТекстЗапроса;
			Если ИТК_РедакторКодаКлиент.ТребуетсяПервоначальнаяИнициализация(ЭлементТекст) Тогда
				
				ИнициализацияРедактораЗапроса();
				ИТК_РедакторКодаКлиент.Инициализация(ЭтотОбъект, "ТекстЗапроса");
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура НаборыДанныхПриИзменении(Элемент)
	
	ОбновитьКоличествоВЗаголовке(Элемент);
	
