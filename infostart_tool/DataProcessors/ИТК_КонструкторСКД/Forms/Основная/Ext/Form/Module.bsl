	ВыбраннаяСтрока = ДоступныеПоляРесурсов.НайтиПоИдентификатору(ВыбраннаяСтрокаИдентификатор);
	ДобавитьРесурсИзДоступныхПолей(ВыбраннаяСтрока);
	
