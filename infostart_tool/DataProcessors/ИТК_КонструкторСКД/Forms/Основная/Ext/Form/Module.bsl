	ПрефиксИмени = ИТК_КонструкторСКДКлиентСервер.ПрефиксИмениНовогоВариантаНастроек();
	ИТК_ФормаКлиент.ПриНачалеРедактированияНовоеИмяВКоллекции(Элемент, ВариантыНастроек, НоваяСтрока, Копирование, ПрефиксИмени);
	
