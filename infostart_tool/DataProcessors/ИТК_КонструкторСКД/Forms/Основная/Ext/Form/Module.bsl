	ИТК_ФормаКлиент.ПриНачалеРедактированияНовоеИмяВКоллекции(Элемент, ПараметрыСКД, НоваяСтрока, Копирование, ПрефиксИмени);
	
	Если НЕ НоваяСтрока
			ИЛИ Копирование Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	ТекущиеДанные.ВключатьВДоступныеПоля = Истина;
	
