#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Заголовок = НСтр("ru = 'Параметры редактирования';
					|en = 'Editing options'");
	ДоступныеПоля = Параметры.ДоступныеПоля;
	
	Значение = Параметры.Значение;
	// Инициализация значения в форму
	Для Каждого ЗначениеПараметра Из Значение.Элементы Цикл 
		
		ПараметрРедактирования = Значение.ДоступныеПараметры.НайтиПараметр(ЗначениеПараметра.Параметр);
		ИмяПараметра = Строка(ЗначениеПараметра.Параметр);

		НоваяСрока = ПараметрыРедактирования.Добавить();
		
		НоваяСрока.Имя = ИмяПараметра;
		НоваяСрока.Представление = ПараметрРедактирования.Заголовок;
		
		Если РедактируетсяПараметрВФормеВыбора(ИмяПараметра) Тогда
			ТипЗначения = ИТК_ТипыКлиентСервер.ОписаниеСтрока();
		Иначе 
			ТипЗначения = ПараметрРедактирования.ТипЗначения;
		КонецЕсли;
		НоваяСрока.Тип = ТипЗначения;
		
		НоваяСрока.Использование = ЗначениеПараметра.Использование;
		НоваяСрока.Значение = ЗначениеПараметра.Значение;
		НоваяСрока.ПредставлениеЗначения = ПредставлениеЗначенияПараметраРедактирования(ЗначениеПараметра.Значение);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыПараметрыРедактирования

&НаКлиенте
Процедура ПараметрыРедактированияПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элементы.ПараметрыРедактирования.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Имя = ТекущиеДанные.Имя;
	
	ЭлементПоле = Элементы.ПараметрыРедактированияПредставлениеЗначения;
	ЭлементПоле.ВыбиратьТип = Ложь;
	ЭлементПоле.ОграничениеТипа = ТекущиеДанные.Тип;
	ЭлементПоле.КнопкаВыбора = РедактируетсяПараметрВФормеВыбора(Имя);
	ЭлементПоле.РедактированиеТекста = РедактируетсяПараметрВТексте(Имя);
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыРедактированияПредставлениеЗначенияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ПараметрыРедактирования.ТекущиеДанные;
	Имя = ТекущиеДанные.Имя;
	
	Если НЕ РедактируетсяПараметрВФормеВыбора(Имя) Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Значение", ТекущиеДанные.Значение);
	ПараметрыФормы.Вставить("ДоступныеПоля", ДоступныеПоля);
	
	ОписаниеОповещенияЗавершения = Новый ОписаниеОповещения("РедактированиеПараметраВФормеЗавершено", ЭтотОбъект);
		
	Если Имя = "ФорматРедактирования" Тогда
		
		КонструкторФорматнойСтроки = Новый КонструкторФорматнойСтроки;
		КонструкторФорматнойСтроки.Текст = Элемент.ТекстРедактирования;
		КонструкторФорматнойСтроки.Показать(ОписаниеОповещенияЗавершения);
		
	ИначеЕсли Имя = "СвязьПоТипу" Тогда
		
		ОткрытьФорму("Обработка.ИТК_КонструкторСКД.Форма.РедактированиеСвязиПоТипу", ПараметрыФормы, ЭтотОбъект, , , , ОписаниеОповещенияЗавершения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	ИначеЕсли Имя = "ПараметрыВыбора" Тогда
		
		ОткрытьФорму("Обработка.ИТК_КонструкторСКД.Форма.РедактированиеПараметровВыбора", ПараметрыФормы, ЭтотОбъект, , , , ОписаниеОповещенияЗавершения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	ИначеЕсли Имя = "СвязиПараметровВыбора" Тогда
		
		ОткрытьФорму("Обработка.ИТК_КонструкторСКД.Форма.РедактированиеСвязейПараметровВыбора", ПараметрыФормы, ЭтотОбъект, , , , ОписаниеОповещенияЗавершения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПараметрыРедактированияПредставлениеЗначенияПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ПараметрыРедактирования.ТекущиеДанные;
	ТекущиеДанные.Использование = Истина;
	ТекущиеДанные.Значение = ТекущиеДанные.ПредставлениеЗначения;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СохранитьИЗакрыть(Команда)
	
	Результат = Значение;
	Для Каждого ЗначениеПараметраРедактирования Из Результат.Элементы Цикл 
		
		Отбор = Новый Структура("Имя", Строка(ЗначениеПараметраРедактирования.Параметр));
		НайденныеСтроки = ПараметрыРедактирования.НайтиСтроки(Отбор);
		СтрокаЗначениеПараметра = НайденныеСтроки[0];
		
		ЗначениеПараметраРедактирования.Использование = СтрокаЗначениеПараметра.Использование;
		ЗначениеПараметраРедактирования.Значение = СтрокаЗначениеПараметра.Значение;

	КонецЦикла;
	
	Закрыть(Результат);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура РедактированиеПараметраВФормеЗавершено(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Модифицированность = Истина;
	
	ТекущиеДанные = Элементы.ПараметрыРедактирования.ТекущиеДанные;
	ТекущиеДанные.Использование = Истина;
	ТекущиеДанные.Значение = Результат;
	ТекущиеДанные.ПредставлениеЗначения = ПредставлениеЗначенияПараметраРедактирования(Результат);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПредставлениеЗначенияПараметраРедактирования(Значение)
	
	Если ТипЗнч(Значение) = Тип("СвязиПараметровВыбораКомпоновкиДанных") Тогда
		
		ЧастиРезультата = Новый Массив;
		Для Каждого СвязьПараметровВыбора Из Значение Цикл 

			ПредставлениеСвязиПараметровВыбора = СтрШаблон("%1 : %2", СвязьПараметровВыбора.Имя, СвязьПараметровВыбора.Поле);
			ЧастиРезультата.Добавить(ПредставлениеСвязиПараметровВыбора);
			
		КонецЦикла;
		
		Результат = СтрСоединить(ЧастиРезультата, ", ");
		
	ИначеЕсли ТипЗнч(Значение) = Тип("ПараметрыВыбораКомпоновкиДанных") Тогда
		
		ЧастиРезультата = Новый Массив;
		Для Каждого ПараметрВыбора Из Значение Цикл 

			ПредставлениеПараметрыВыбора = СтрШаблон("%1 : %2", ПараметрВыбора.Имя, ПараметрВыбора.Значение);
			ЧастиРезультата.Добавить(ПредставлениеПараметрыВыбора);
			
		КонецЦикла;
		
		Результат = СтрСоединить(ЧастиРезультата, ", ");
		
	ИначеЕсли ТипЗнч(Значение) = Тип("СвязьПоТипуКомпоновкиДанных") Тогда

		Результат = СтрШаблон("%1, %2", Значение.Поле, Значение.ЭлементСвязи);
		
	Иначе 
		
		Результат = Значение;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция РедактируетсяПараметрВФормеВыбора(Имя)
	
	Возврат (Имя = "ФорматРедактирования"
				ИЛИ Имя = "СвязиПараметровВыбора"
				ИЛИ Имя = "ПараметрыВыбора"
				ИЛИ Имя = "СвязьПоТипу");
				
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция РедактируетсяПараметрВТексте(Имя)
	
	Возврат НЕ (Имя = "СвязиПараметровВыбора"
				ИЛИ Имя = "ПараметрыВыбора"
				ИЛИ Имя = "СвязьПоТипу");
				
КонецФункции

#КонецОбласти
