#Область ОписаниеПеременных

&НаКлиенте
Перем ИдетПоискПоПодобию;

&НаКлиенте
Перем ПродолжаетсяПоискПоПодобию;

&НаКлиенте
Перем ИдентификаторПоследнейВыделеннойСтроки;

&НаКлиенте
Перем ИдентификаторПоследнейВыделеннойСтрокиИзбранного;

&НаКлиенте
Перем ИдентификаторПоследнейВыделеннойСтрокиРезультатаПоиска;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ФильтрМетаданных = "Все";
	
	ТолькоВажныеСвойства = Ложь;
	СортироватьСвойстваПоАлфавиту = Ложь;
	
	УстановитьУсловноеОформление();

	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.Избранное);
	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.ЗначенияСвойств);
	
	ДополнительныйТекст = НСтр("ru = 'В результат поиска выводится не более 50 найденных.'; en = 'The search result displays no more than 50 found.'");
	ИТК_ФормаКлиентСервер.ОформитьСтрокуПоискаПоПодобию(Элементы.ДеревоМетаданныхПоисковаяСтрока, ДополнительныйТекст);
	ИТК_ФормаКлиентСервер.ОформитьСтрокуПоискаПоПодобию(Элементы.ДеревоМетаданныхПоисковаяСтрокаКоманднаяПанель, ДополнительныйТекст);
	
	ИТК_ФормаКлиентСервер.ПанельГиперссылок_УстановитьТекущуюСтраницу(Элементы.ПанельМетаданныеЗаголовкиСтраниц,
														Элементы.ПанельМетаданныеСтраницы, Элементы.ПанельМетаданныеЗаголовокСтраницы_Все);
	
	ПервоначальноеЗаполнениеДереваМетаданных();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИТК_ОбщийКлиент.ОбработчикПриОткрытии(Отказ);

	ИдетПоискПоПодобию = Ложь;
	ПродолжаетсяПоискПоПодобию = Ложь;

	НачальноеОтображениеДерева();
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПанельМетаданныеЗаголовокСтраницыСменаСтраницы(Элемент)
	
	ИТК_ФормаКлиентСервер.ПанельГиперссылок_УстановитьТекущуюСтраницу(Элементы.ПанельМетаданныеЗаголовкиСтраниц, Элементы.ПанельМетаданныеСтраницы, Элемент);

КонецПроцедуры

&НаКлиенте
Процедура ДеревоМетаданныхПоисковаяСтрокаПриИзменении(Элемент)
	
	ОбновитьПоиск();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДеревоМетаданных

&НаКлиенте
Процедура ДеревоМетаданныхВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	СвойстваОбъекта();
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоМетаданныхПередРазворачиванием(Элемент, Строка, Отказ)
	
	РазворачиваемаяСтрока = ДеревоМетаданных.НайтиПоИдентификатору(Строка);
	
	Если ИТК_ФормаКлиентСервер.НеобходимоРазвернутьСтроку(РазворачиваемаяСтрока) Тогда
		
		РазвернутьСтрокуКоллекцииМетаданных(Строка);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыРезультатыПоиска

&НаКлиенте
Процедура РезультатыПоискаПриАктивизацииСтроки(Элемент)
	
	ИдентификаторТекущейСтроки = Элемент.ТекущаяСтрока;
	Если ИдентификаторПоследнейВыделеннойСтрокиРезультатаПоиска = ИдентификаторТекущейСтроки Тогда 
		Возврат;
	КонецЕсли;
	ИдентификаторПоследнейВыделеннойСтрокиРезультатаПоиска = ИдентификаторТекущейСтроки;
	
	ПодключитьОбработчикОжидания("ПодключаемыйОбновитьСвойства", 0.1, Истина);
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаКлиенте
Процедура РезультатыПоискаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СвойстваОбъекта();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыИзбранное

&НаКлиенте
Процедура ИзбранноеПриАктивизацииСтроки(Элемент)

	ИдентификаторТекущейСтроки = Элемент.ТекущаяСтрока;
	Если ИдентификаторПоследнейВыделеннойСтрокиИзбранного = ИдентификаторТекущейСтроки Тогда 
		Возврат;
	КонецЕсли;
	ИдентификаторПоследнейВыделеннойСтрокиИзбранного = ИдентификаторТекущейСтроки;
	
	ПодключитьОбработчикОжидания("ПодключаемыйОбновитьСвойства", 0.1, Истина);
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаКлиенте
Процедура ИзбранноеВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СвойстваОбъекта();

КонецПроцедуры

&НаКлиенте
Процедура ИзбранноеПослеУдаления(Элемент)
	
	ОбновитьЭлементыФормы();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыЗначенияСвойств

&НаКлиенте
Процедура ЗначенияСвойствВыбор(Элемент, ИдентификаторВыбраннойСтроки, Поле, СтандартнаяОбработка)
	
	Если Элемент.ТекущийЭлемент <> Элементы.ЗначенияСвойствПредставлениеГиперссылки Тогда
		Возврат;
	КонецЕсли;
	
	ВыбраннаяСтрока = ЗначенияСвойств.НайтиПоИдентификатору(ИдентификаторВыбраннойСтроки);
	ДанныеГиперссылки = ВыбраннаяСтрока.ДанныеГиперссылки;
	
	ЗначениеСвойства = Элемент.ТекущиеДанные.Значение;
	ИТК_ИнструментМетаданныеКлиент.ОбработкаГиперссылкиСвойства(ЭтотОбъект, ДанныеГиперссылки, ЗначениеСвойства, ПолноеИмяОбъектаМетаданных, СтандартнаяОбработка);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СвойстваОбъекта(Команда = Неопределено)

	ПолноеИмя = ПолноеИмяОбъектаСвойствОбъекта();
	Если НЕ ЗначениеЗаполнено(ПолноеИмя) Тогда
		Возврат;
	КонецЕсли;
	
	ИТК_ТуллкитКлиент.ОткрытьИнструмент(ИТК_Перечисления.ИнструментМетаданные(), ПолноеИмя);

КонецПроцедуры

&НаКлиенте
Процедура ДобавитьВИзбранное(Команда)
	
	Строка = Элементы.ДеревоМетаданных.ТекущиеДанные;
	ДобавитьСтрокуМетаданныхВИзбранное(Строка);
	
КонецПроцедуры

&НаКлиенте
Процедура СвернутьВсе(Команда)
	
	ИТК_ФормаКлиент.СвернутьДерево(Элементы.ДеревоМетаданных, ДеревоМетаданных);
	ИТК_ФормаКлиент.РазвернутьДерево(Элементы.ДеревоМетаданных, ДеревоМетаданных);
	
КонецПроцедуры

&НаКлиенте
Процедура СвернутьРаздел(Команда)
	
	ТекущиеДанные = Элементы.ДеревоМетаданных.ТекущиеДанные;
	
	Если ТекущиеДанные.Коллекция Тогда 
		СворачиваемаяСтрока = ТекущиеДанные;
	Иначе
		СворачиваемаяСтрока = ТекущиеДанные.ПолучитьРодителя();
	КонецЕсли;
	
	Элементы.ДеревоМетаданных.Свернуть(СворачиваемаяСтрока.ПолучитьИдентификатор());
	
КонецПроцедуры

&НаКлиенте
Процедура СортироватьСвойстваПоАлфавиту(Команда)
	
	СортироватьСвойстваПоАлфавиту = Истина;
	ОбновитьСвойства();
	
КонецПроцедуры

&НаКлиенте
Процедура СортироватьСвойстваПоКатегориям(Команда)
	
	СортироватьСвойстваПоАлфавиту = Ложь;
	ОбновитьСвойства();
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказыватьТолькоВажныеСвойства(Команда)
	
	ТолькоВажныеСвойства = НЕ ТолькоВажныеСвойства;
	ОбновитьСвойства();
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьНовоеОкно(Команда)
	
	ИТК_ФормаКлиент.ОткрытьНовую(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_МетаданныеПерейти(Команда)
	
	ПолноеИмяОбъекта = ПолноеИмяОбъектаСвойствОбъекта();
	ИТК_ИнструментМетаданныеКлиент.ОбработкаГруппыКомандПерейти(Команда, ПолноеИмяОбъекта);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	ДеревоМетаданныхТекущиеДанных = Элементы.ДеревоМетаданных.ТекущиеДанные;
	СтрокаДереваМетаданныхВыбрана = (ДеревоМетаданныхТекущиеДанных <> Неопределено);

	СтрокаДереваМетаданныхОбъект = (СтрокаДереваМетаданныхВыбрана
												И НЕ ДеревоМетаданныхТекущиеДанных.Коллекция);
	Элементы.ДеревоМетаданныхКонтекстноеМенюДобавитьВИзбранное.Доступность = СтрокаДереваМетаданныхОбъект;
	Элементы.ДеревоМетаданныхКонтекстноеМенюСвойстваОбъекта.Доступность = СтрокаДереваМетаданныхОбъект;	
	
	// Поиск
	ИспользуетсяПоиск = ЗначениеЗаполнено(ДеревоМетаданныхПоисковаяСтрока);
	Если ИспользуетсяПоиск Тогда
		ТекущаяСтраницаПанелиМетаданных = Элементы.ПанельДеревоМетаданныхРезультатыПоиска;
	Иначе
		ТекущаяСтраницаПанелиМетаданных = Элементы.ПанельДеревоМетаданных;
	КонецЕсли;
	Элементы.СтраницыПанелиМетаданных.ТекущаяСтраница = ТекущаяСтраницаПанелиМетаданных;
	
	Элементы.ГруппаПоискПродолжается.Видимость = ПродолжаетсяПоискПоПодобию	ИЛИ ИдетПоискПоПодобию;
	
	// Избранное
	ЗаголовокИзбранное = ИТК_ФормаКлиентСервер.ЗаголовокСКоличеством(
							НСтр("ru = 'Избранное'; en = 'Favorites'"), Избранное.Количество());
	Элементы.ПанельМетаданныеЗаголовокСтраницы_Избранное.Заголовок = ЗаголовокИзбранное;

	// Свойства
	Элементы.ПоказыватьТолькоВажныеСвойства.Пометка = ТолькоВажныеСвойства;
	
	Элементы.ЗначенияСвойствСортироватьСвойстваПоАлфавиту.Пометка = СортироватьСвойстваПоАлфавиту;
	Элементы.ЗначенияСвойствСортироватьСвойстваПоКатегориям.Пометка = НЕ СортироватьСвойстваПоАлфавиту;

КонецПроцедуры

&НаСервере
Процедура ПервоначальноеЗаполнениеДереваМетаданных()
	
	СтрокаКорень = ДобавитьСтрокуВДеревоМетаданных(ДеревоМетаданных, Метаданные.Имя, БиблиотекаКартинок.ИТК_Метаданные, Метаданные.ПолноеИмя(), Ложь);
	
	СтрокаМетаданные = ДобавитьСтрокуВДеревоМетаданных(СтрокаКорень, НСтр("ru = 'Общие'; en = 'General'"), БиблиотекаКартинок.ИТК_МетаданныеОбщие);
	ДобавитьСтрокуВДеревоМетаданных(СтрокаМетаданные);
	
	Для Каждого ИмяКоллекции Из ИТК_МетаданныеКлиентСерверПовтИсп.ДоступныеКоллекцииМетаданных() Цикл 
		
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПланОбмена(ИмяКоллекции) Тогда
			Продолжить;
		КонецЕсли;
		
		ДобавитьСтрокуКоллекцииМетаданныхВДерево(СтрокаКорень, ИмяКоллекции);
		
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура НачальноеОтображениеДерева()
	
	КорневаяСтрока = ДеревоМетаданных.ПолучитьЭлементы()[0];
	Элементы.ДеревоМетаданных.Развернуть(КорневаяСтрока.ПолучитьИдентификатор()); 
	
КонецПроцедуры

&НаСервере
Процедура РазвернутьСтрокуКоллекцииМетаданных(Идентификатор)

	РазворачиваемаяСтрока = ДеревоМетаданных.НайтиПоИдентификатору(Идентификатор);
	РазворачиваемаяСтрока.ПолучитьЭлементы().Очистить();
	
	ИмяКоллекции = РазворачиваемаяСтрока.Представление;

	Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоГруппаОбщие(ИмяКоллекции) Тогда
		
		Для Каждого ЭлементСписка Из ИТК_МетаданныеКлиентСерверПовтИсп.ДоступныеКоллекцииМетаданныхГруппыОбщие() Цикл 
			ДобавитьСтрокуКоллекцииМетаданныхВДерево(РазворачиваемаяСтрока, ЭлементСписка.Представление);
		КонецЦикла;
		
	Иначе
		
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоПодсистема(ИмяКоллекции) Тогда
			
			РазвернутьСтрокуПодсистемы(РазворачиваемаяСтрока, Метаданные);
			Возврат;
			
		КонецЕсли;
		
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоДокумент(ИмяКоллекции) Тогда
			
			ДобавитьСтрокуКоллекцииМетаданныхВДерево(РазворачиваемаяСтрока, "НумераторыДокументов");
			ДобавитьСтрокуКоллекцииМетаданныхВДерево(РазворачиваемаяСтрока, "Последовательности");
			
		КонецЕсли;
		
		СписокИменКоллекции = ИТК_МетаданныеПовтИсп.КэшИменКоллекции(ИмяКоллекции, Ложь);
		Для Каждого ЭлементСписка Из СписокИменКоллекции Цикл 
					
			ИмяОбъектаКоллекции = ЭлементСписка.Представление;
			ДобавитьСтрокуВДеревоМетаданных(РазворачиваемаяСтрока, ИмяОбъектаКоллекции, РазворачиваемаяСтрока.Картинка, , Ложь);
				
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура РазвернутьСтрокуПодсистемы(Строка, КоллекцияМетаданных)
	
	СписокЗначений = Новый СписокЗначений;
	
	Для Каждого ОбъектМетаданных Из КоллекцияМетаданных.Подсистемы Цикл 
		СписокЗначений.Добавить(ОбъектМетаданных, ОбъектМетаданных.Имя);
	КонецЦикла;
	
	СписокЗначений.СортироватьПоПредставлению();
	
	Для Каждого ЭлементСписка Из СписокЗначений Цикл 
		
		ИмяОбъектаКоллекции = ЭлементСписка.Представление;
		ОбъектКоллекция = ЭлементСписка.Значение;
		
		Если ТипЗнч(КоллекцияМетаданных) = Тип("ОбъектМетаданныхКонфигурация") Тогда
			ЗначениеСтроки = ИмяОбъектаКоллекции;
		Иначе
			ЗначениеСтроки = "Подсистема." + ИмяОбъектаКоллекции;
		КонецЕсли;
		
		НоваяСтрока = ДобавитьСтрокуВДеревоМетаданных(Строка, ИмяОбъектаКоллекции, Строка.Картинка, ЗначениеСтроки, Ложь);
		РазвернутьСтрокуПодсистемы(НоваяСтрока, ОбъектКоллекция);

	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ДобавитьСтрокуВДеревоМетаданных(Родитель, Представление = Неопределено, Картинка = Неопределено, Значение = Неопределено, Коллекция = Истина)
	
	НоваяСтрока = Родитель.ПолучитьЭлементы().Добавить();
	НоваяСтрока.Представление = Представление;
	
	Если Картинка <> Неопределено Тогда
		НоваяСтрока.Картинка = Картинка;
	КонецЕсли;
	
	НоваяСтрока.Значение = Значение;
	НоваяСтрока.Коллекция = Коллекция;
	
	Возврат НоваяСтрока;
	
КонецФункции

&НаСервере
Процедура ДобавитьСтрокуКоллекцииМетаданныхВДерево(Родитель, ИмяКоллекции)
	
	Если НЕ ЗначениеЗаполнено(Метаданные[ИмяКоллекции]) Тогда
		Возврат;
	КонецЕсли;
	
	Картинка = ИТК_МетаданныеКлиентСерверПовтИсп.КартинкаКоллекции(ИмяКоллекции);
	ИмяОбъектаКоллекции = ИТК_МетаданныеКлиентСерверПовтИсп.ИмяОбъектаКоллекции(ИмяКоллекции);
	
	СтрокаМетаданные = ДобавитьСтрокуВДеревоМетаданных(Родитель, ИмяКоллекции, Картинка, ИмяОбъектаКоллекции);
	ДобавитьСтрокуВДеревоМетаданных(СтрокаМетаданные);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПолноеИмяСтрокиДереваМетаданных(Строка)
	
	Результат = ИдентификаторСтрокиДереваМетаданных(Строка);
	Родитель = Строка.ПолучитьРодителя();

	Пока НЕ (Родитель = Неопределено
			ИЛИ Родитель.ПолучитьРодителя() = Неопределено) Цикл 
			
		Идентификатор = ИдентификаторСтрокиДереваМетаданных(Родитель);
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоГруппаОбщие(Идентификатор) Тогда
			Возврат Результат;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Результат) Тогда
			Результат = "." + Результат;
		КонецЕсли;
		
		Родитель = Родитель.ПолучитьРодителя();
		Результат = Идентификатор + Результат;
		
		Если ИТК_МетаданныеКлиентСерверПовтИсп.ЭтоДокумент(Родитель.Представление) Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ИдентификаторСтрокиДереваМетаданных(Строка)
	
	Результат = Строка.Представление;
	Если ЗначениеЗаполнено(Строка.Значение) Тогда
		Результат = Строка.Значение;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ДобавитьСтрокуМетаданныхВИзбранное(Строка)
	
	ПолноеИмя = ПолноеИмяСтрокиДереваМетаданных(Строка);
	Если Избранное.НайтиПоЗначению(ПолноеИмя) <> Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Избранное.Добавить(ПолноеИмя, Строка.Представление, , Строка.Картинка);
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоМетаданныхПриАктивизацииСтроки(Элемент)
	
	ИдентификаторТекущейСтроки = Элемент.ТекущаяСтрока;
	Если ИдентификаторПоследнейВыделеннойСтроки <> ИдентификаторТекущейСтроки Тогда 
		
		ИдентификаторПоследнейВыделеннойСтроки = ИдентификаторТекущейСтроки;
		
		ПодключитьОбработчикОжидания("ПодключаемыйОбновитьСвойства", 0.1, Истина);
		
	КонецЕсли;
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйОбновитьСвойства()

	ОбновитьСвойства();

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСвойства()

	ПолноеИмяОбъектаМетаданных = ПолноеИмяОбъектаСвойствОбъекта();
	Если НЕ ЗначениеЗаполнено(ПолноеИмяОбъектаМетаданных) Тогда
		
		ЗначенияСвойств.ПолучитьЭлементы().Очистить();
		Возврат;
		
	КонецЕсли;
		
	ОбновитьСвойстваНаСервере(ПолноеИмяОбъектаМетаданных);
	ИТК_ФормаКлиент.РазвернутьДерево(Элементы.ЗначенияСвойств, ЗначенияСвойств, Истина);
	
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаСервере
Процедура ОбновитьСвойстваНаСервере(ПолноеИмя)
	
	// Получение и обновление свойств
	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("ПолноеИмя", ПолноеИмя);
	ПараметрыПроцедуры.Вставить("ТолькоВажные", ТолькоВажныеСвойства);
	ПараметрыПроцедуры.Вставить("СортироватьПоАлфавиту", СортироватьСвойстваПоАлфавиту);

	ЗначенияСвойствОбъекта = ИТК_ИнструментМетаданные.ЗначенияСвойств(ПараметрыПроцедуры); 
	ЗначениеВРеквизитФормы(ЗначенияСвойствОбъекта, "ЗначенияСвойств");
	
	// Обновление элементов группы Перейти
	ИТК_ИнструментМетаданные.ОбновитьГруппуПерейти(ЭтотОбъект, Элементы.ЗначенияСвойствГруппаПерейти, ПолноеИмя);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	Оформление = Новый Структура("Шрифт", ИТК_ОбщийКлиентСервер.ШрифтЖирный());
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "ЗначенияСвойствПредставление", Оформление, "ЗначенияСвойств.ЭтоГруппа", Истина);
	
	Оформление = Новый Структура("Видимость", Ложь);
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "ЗначенияСвойствПредставлениеЗначения", Оформление, "ЗначенияСвойств.ПредставлениеГиперссылки", , ВидСравненияКомпоновкиДанных.Заполнено);
	
	Оформление = Новый Структура("Видимость", Ложь);
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "ЗначенияСвойствПредставлениеГиперссылки", Оформление, "ЗначенияСвойств.ПредставлениеГиперссылки", , ВидСравненияКомпоновкиДанных.НеЗаполнено);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПоиск()

	РезультатыПоиска.Очистить();	
	ИТК_ДлительныеОперации.Отменить(ДлительнаяОперация);
	
	Если НЕ ЗначениеЗаполнено(ДеревоМетаданныхПоисковаяСтрока) Тогда
		Возврат;
	КонецЕсли;
	
	ИдетПоискПоПодобию = Истина;
	ПродолжаетсяПоискПоПодобию = Ложь;
	
	ОбновитьЭлементыФормы();
	ПодключитьОбработчикОжидания("ПодключаемыйТекущийЭлементСтрокаПоискаПослеОжидания", 0.1, Истина);
	
	ОбновитьПрогрессПоискаПоПодобию();
	ДлительнаяОперация = ОбновитьПоискНаСервере(ДеревоМетаданныхПоисковаяСтрока, УникальныйИдентификатор);
	
	ОповещениеОПрогрессеВыполнения = Новый ОписаниеОповещения("ОбработкаПрогрессаПоискаПоПодобию", ЭтотОбъект);
	ПараметрыОжидания = ИТК_ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект, ОповещениеОПрогрессеВыполнения);
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершенПоискПоПодобию", ЭтотОбъект);
	ИТК_ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаСервереБезКонтекста
Функция ОбновитьПоискНаСервере(СтрокаПоиска, УникальныйИдентификатор)
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	
	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("СтрокаПоиска", СтрокаПоиска);

	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_ИнструментМетаданные.ПоискПоПодобию", ПараметрыПроцедуры, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ОбработкаПрогрессаПоискаПоПодобию(Результат, ДополнительныеПараметры) Экспорт
	
	ИТК_ДлительныеОперацииКлиент.ПодготовитьПрогрессВыполнения(Результат);
	
	Если Результат.Прогресс = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	ОбработатьРезультатыПоиска(Результат.Прогресс.ДополнительныеПараметры);
	
	// Обновить прогресс
	ПродолжаетсяПоискПоПодобию = Истина;
	ОбновитьПрогрессПоискаПоПодобию(Результат.Прогресс.Процент);
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПрогрессПоискаПоПодобию(Завершено = Неопределено)
	
	ПояснениеПрогресса = НСтр("ru = 'Поиск продолжается...'; en = 'Search continues...'");
	Если Завершено <> Неопределено Тогда
		ПояснениеПрогресса = ПояснениеПрогресса + Символы.НПП + СтрШаблон(НСтр("ru = 'завершено %1%%'; en = 'completed %1%%'"), Завершено);
	КонецЕсли;
	
	Элементы.НадписьПоискПродолжается.Заголовок = ПояснениеПрогресса;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершенПоискПоПодобию(Результат, ДополнительныеПараметры) Экспорт
	
	ИдетПоискПоПодобию = Ложь;
	ПродолжаетсяПоискПоПодобию = Ложь;
	
	ОбновитьЭлементыФормы();

	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		ОбновитьРезультатыПоискаПоПодобиюНаФорме(Результат.АдресРезультата);
	КонецЕсли;
	
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаСервере
Процедура ОбновитьРезультатыПоискаПоПодобиюНаФорме(АдресРезультата)
	
	Результат = ПолучитьИзВременногоХранилища(АдресРезультата);
	ОбработатьРезультатыПоиска(Результат);
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьРезультатыПоиска(Результат)
	
	// Добавить найденные
	Для Каждого ОписаниеОбъекта Из Результат Цикл 
		
		Если РезультатыПоиска.НайтиПоЗначению(ОписаниеОбъекта.ПолноеИмя) <> Неопределено Тогда 
			Продолжить;
		КонецЕсли;
		
		РезультатыПоиска.Добавить(ОписаниеОбъекта.ПолноеИмя, ОписаниеОбъекта.Имя, , ОписаниеОбъекта.Картинка);

	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйТекущийЭлементСтрокаПоискаПослеОжидания()

	ТекущийЭлемент = Элементы.ДеревоМетаданныхПоисковаяСтрока;
	
КонецПроцедуры

&НаКлиенте
Функция ПолноеИмяОбъектаСвойствОбъекта()
	
	Если Элементы.ПанельМетаданныеСтраницы.ТекущаяСтраница = Элементы.ПанельМетаданныеСтраница_Все Тогда
		Если Элементы.СтраницыПанелиМетаданных.ТекущаяСтраница = Элементы.ПанельДеревоМетаданных Тогда 
			ЭлементИсточник = Элементы.ДеревоМетаданных;
		Иначе
			ЭлементИсточник = Элементы.РезультатыПоиска;
		КонецЕсли;
	Иначе
		ЭлементИсточник = Элементы.Избранное;
	КонецЕсли;
	
	
	ТекущиеДанные = ЭлементИсточник.ТекущиеДанные;
	
	Результат = Неопределено;
	Если ЭлементИсточник = Элементы.ДеревоМетаданных Тогда
		
		Если ТекущиеДанные.Коллекция Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		Результат = ПолноеИмяСтрокиДереваМетаданных(ТекущиеДанные);
		
	Иначе
		
		Если ТекущиеДанные = Неопределено Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		Результат = ТекущиеДанные.Значение;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
