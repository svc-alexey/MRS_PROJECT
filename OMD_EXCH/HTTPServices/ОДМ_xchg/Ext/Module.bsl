КонецФункции

Функция objectPOST(Запрос)
	
	//TODO: подумать как реализовать проверку,
	//что бы из по дефолту от тестовых баз, например, к боевой отказ шел
	РазрешеноПолучатьДанные = Истина;
	Если РазрешеноПолучатьДанные = Ложь Тогда
		ТекстСообщения = НСтр("ru='Клиент не имеет прав доступа к контенту';
								|en='The client does not have access rights to the content'");
		Возврат HTTPОтветJSON(ТекстСообщения, 403);
	КонецЕсли;
	
	РезультатМетода = Новый Структура("ВозвращаемыеДанные, КодСостояния", Новый Структура, 200);
	
	ТелоЗапросаHTTP = Запрос.ПолучитьТелоКакСтроку();
	ОписаниеЗапроса = ОДМ_ОбменДанными.ДесериализоватьJSON(ТелоЗапросаHTTP);
	
	//FIXME: плохой кусок
	Идентификатор = Неопределено;
	АсинхронныйВызов = ЭтоАсинхронныйВызов(Запрос, Идентификатор);
	//<-
	
	ОписаниеЗадачи = ОДМ_ОбменДанными.Конструктор_ОписаниеЗадачи(Идентификатор);
	ОписаниеЗадачи.Метод			= "objectPOST";
	ОписаниеЗадачи.АсинхронныйВызов	= АсинхронныйВызов;
	ОписаниеЗадачи.Статус			= Перечисления.ОДМ_СтатусыЗадач.Подготовлен;
	ОписаниеЗадачи.Параметры		= ОписаниеЗапроса;
	
	РезультатМетода = ОбработатьВходящуюЗадачу(ОписаниеЗадачи);
	
	Возврат HTTPОтветJSON(РезультатМетода.ВозвращаемыеДанные, РезультатМетода.КодСостояния);
	
КонецФункции

Функция Code(Запрос)
	
	//TODO: подумать как реализовать проверку,
	//что бы из по дефолту от тестовых баз, например, к боевой отказ шел
	РазрешеноПолучатьДанные = Истина;
	Если РазрешеноПолучатьДанные = Ложь Тогда
		ТекстСообщения = НСтр("ru='Клиент не имеет прав доступа к контенту';
								|en='The client does not have access rights to the content'");
		Возврат HTTPОтветJSON(ТекстСообщения, 403);
	КонецЕсли;
	
	Попытка
		Тело = Запрос.ПолучитьТелоКакСтроку();
		лСтруктураПараметры = ДесериализоватьJSON(Тело);
		Если ТипЗнч(лСтруктураПараметры) <> Тип("Структура") Тогда 
			Возврат HTTPОтветJSON("В теле запроса должна быть передана структура с полями: Текст или Имя, Параметры", 400);
		КонецЕсли;
		
		лТекстОшибки = Неопределено;
		лТекст = мПолучитьТекст(лСтруктураПараметры, Ложь, лТекстОшибки);
		Если лТекст = Неопределено Тогда Возврат HTTPОтветJSON(лТекстОшибки, 400); КонецЕсли; 
		
		Параметры = лСтруктураПараметры.Параметры;
		лТекст = СтрЗаменить(лТекст,"$","""");
		ЗначениеВозврата = Неопределено;
		
		//ОбщегоНазначения.ВыполнитьВБезопасномРежиме(лТекст,Параметры);//Не возвращает ГУИД ссылки справочника
		
		Выполнить(лТекст);
		
		Возврат HTTPОтветJSON(ЗначениеВозврата);
		
	Исключение 
		лИнформацияОбОшибке = ИнформацияОбОшибке();
		Возврат HTTPОтветJSON(ПолучитьПолноеОписаниеОшибки(лИнформацияОбОшибке), 400);
	КонецПопытки;

КонецФункции

