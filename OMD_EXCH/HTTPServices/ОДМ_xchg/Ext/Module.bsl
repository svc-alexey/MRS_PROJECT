// Устарела. Следует использовать ОДМ_ОбменДанными.ПолноеОписаниеОшибки
// Функция: ПолучитьПолноеОписаниеОшибки
// Назначение: Возвращает полное описание ошибки, включая вложенные причины.
// Входные параметры:
//   пИнформацияОбОшибке - ИнформацияОбОшибке - Объект с информацией об ошибке.
// Возвращаемое значение:
//   Строка - Полное описание ошибки.
Функция ПолучитьПолноеОписаниеОшибки(пИнформацияОбОшибке) Экспорт
	лОписание = пИнформацияОбОшибке.Описание;
	Если ЗначениеЗаполнено(пИнформацияОбОшибке.НомерСтроки) Тогда лОписание=лОписание+" {"+пИнформацияОбОшибке.ИмяМодуля+": "+пИнформацияОбОшибке.НомерСтроки+"}"; КонецЕсли;
	Если пИнформацияОбОшибке.Причина<>Неопределено Тогда лОписание=лОписание+Символы.ПС+ПолучитьПолноеОписаниеОшибки(пИнформацияОбОшибке.Причина); КонецЕсли;
	Возврат лОписание;
КонецФункции

// Функция: мВыгрузкаВJSONНайтиПутьОшибочногоЗначения
// Назначение: Рекурсивно ищет значение, которое не может быть сериализовано в JSON.
// Входные параметры:
//   пЗначение - Произвольный - Объект для проверки.
//   пПутьОшибки - Строка - Переменная для возврата пути к ошибочному значению.
// Возвращаемое значение:
//   Произвольный - Ошибочное значение или Неопределено, если ошибок нет.
Функция мВыгрузкаВJSONНайтиПутьОшибочногоЗначения(пЗначение, пПутьОшибки)
	лТип = ТипЗнч(пЗначение);
	Если лТип = Тип("Соответствие") или лТип=Тип("Структура") Тогда 
		Для Каждого лКлючИЗначение Из пЗначение Цикл
			Если лТип = Тип("Соответствие") Тогда 
				лПутьОшибки = Неопределено;
				лЗначениеОшибки = мВыгрузкаВJSONНайтиПутьОшибочногоЗначения(лКлючИЗначение.Ключ, лПутьОшибки);
				Если лЗначениеОшибки<>Неопределено Тогда 
					пПутьОшибки=лКлючИЗначение.Ключ+" (ключ)"+"."+лПутьОшибки;
					Возврат лЗначениеОшибки; 
				КонецЕсли;
			КонецЕсли;
			лПутьОшибки = Неопределено;
			лЗначениеОшибки = мВыгрузкаВJSONНайтиПутьОшибочногоЗначения(лКлючИЗначение.Значение, лПутьОшибки);
			Если лЗначениеОшибки <> Неопределено Тогда 
				пПутьОшибки=лКлючИЗначение.Ключ+?(лПутьОшибки<>Неопределено, ?(Лев(лПутьОшибки, 1)<>"[", ".", "")+лПутьОшибки, "");
				Возврат лЗначениеОшибки;
			КонецЕсли;
		КонецЦикла;
		Возврат Неопределено;
		
	ИначеЕсли лТип = Тип("Массив") Тогда
		лНомерСтроки = 0;
		Для Каждого лЗначение Из пЗначение Цикл
			лНомерСтроки = лНомерСтроки+1;
			лПутьОшибки = Неопределено;
			лЗначениеОшибки = мВыгрузкаВJSONНайтиПутьОшибочногоЗначения(лЗначение, лПутьОшибки);
			Если лЗначениеОшибки <> Неопределено Тогда 
				пПутьОшибки = "["+Формат(лНомерСтроки, "ЧГ=")+"]"+?(лПутьОшибки<>Неопределено, ?(Лев(лПутьОшибки, 1)<>"[", ".", "")+лПутьОшибки, "");
				Возврат лЗначениеОшибки;
			КонецЕсли;
		КонецЦикла;
		Возврат Неопределено;
	КонецЕсли;
	
	лЗаписьJSON = Новый ЗаписьJSON;
	лЗаписьJSON.УстановитьСтроку();
	Попытка	
		ЗаписатьJSON(лЗаписьJSON, пЗначение);
	Исключение 
		Возврат пЗначение;
	КонецПопытки;
	Возврат Неопределено;
КонецФункции

// Функция: ВМассивСтруктур
// Назначение: Преобразование таблицы значений или дерева значений в массив структур
// Входные параметры:
//   пТз (ТаблицаЗначений/ДеревоЗначений) - Таблица или дерево значений, которые необходимо преобразовать
//   пМассивСтруктур (Массив) - Опциональный параметр. Если указан, то результаты добавляются в этот массив
// Возвращаемое значение:
//   Массив - Массив структур, представляющих строки таблицы или ветки дерева
Функция ВМассивСтруктур(пТз, пМассивСтруктур = Неопределено) Экспорт
	лЭтоДерево = ТипЗнч(пТз) = Тип("ДеревоЗначений");
	Возврат мПолучитьМассивСтруктурСтрокПоВеткеДерева(?(лЭтоДерево, пТз.Строки, пТз), лЭтоДерево, пТз.Колонки, пМассивСтруктур); // лСтрокаКолонок, 
КонецФункции

// Функция: мПолучитьМассивСтруктурСтрокПоВеткеДерева
// Назначение: Вспомогательная функция для преобразования строк таблицы или веток дерева в массив структур
// Входные параметры:
//   пСтрокиВеткиДерева (Массив) - Массив строк таблицы или веток дерева
//   пЭтоДерево (Булево) - Флаг, указывающий, что обрабатывается дерево значений
//   пТзКолонки (КоллекцияКолонок) - Колонки таблицы или дерева значений
//   пМассивСтруктур (Массив) - Опциональный параметр. Если указан, то результаты добавляются в этот массив
// Возвращаемое значение:
//   Массив - Массив структур, представляющих строки таблицы или ветки дерева
Функция мПолучитьМассивСтруктурСтрокПоВеткеДерева(пСтрокиВеткиДерева, пЭтоДерево, пТзКолонки, пМассивСтруктур=Неопределено) // пСтрокаСвойств, 
	лМассивСтрок = ?(пМассивСтруктур = Неопределено, Новый Массив, пМассивСтруктур);
	Для Каждого лСтрокаВетки Из пСтрокиВеткиДерева Цикл
		лСтруктура = Новый Структура;// (пСтрокаСвойств);
		Если пЭтоДерево Тогда лСтруктура.Вставить("Строки"); КонецЕсли; 
		
		лИндекс = 0;
		Для Каждого лКолонка Из пТзКолонки Цикл
			лСтруктура.Вставить(лКолонка.Имя, лСтрокаВетки[лИндекс]);
			лИндекс = лИндекс+1;
		КонецЦикла; 
		
		Если пЭтоДерево Тогда лСтруктура.Строки=мПолучитьМассивСтруктурСтрокПоВеткеДерева(лСтрокаВетки.Строки, пЭтоДерево, пТзКолонки); КонецЕсли; // пСтрокаСвойств, 
		лМассивСтрок.Добавить(лСтруктура);
	КонецЦикла;
	Возврат лМассивСтрок;
КонецФункции

#КонецОбласти // СлужебныеПроцедурыИФункции

