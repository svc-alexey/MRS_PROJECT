Функция СписокПодходящихЭлементов(Знач ИмяМетаданных, Знач ПараметрыЗапроса)
	
	РезультатМетода = Новый Структура("quantity, list", 0, Новый Массив);
	
	Запрос = Новый Запрос;
	
	ТекстЗапроса = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	т.ВерсияДанных КАК ВерсияДанных
	               |ИЗ
	               |	Справочник.ОДМ_БазыДанных КАК т
	               |ГДЕ
	               |	ИСТИНА
	               |	И НЕ т.ПометкаУдаления";
	
	// # TODO: завернуть в параметр filters (пометка, группа, дата, ...)
	Если СтрНачинаетсяС(ИмяМетаданных, "Справочник.") Тогда
		ТекстЗапроса = ТекстЗапроса + " И НЕ т.ЭтоГруппа";
	КонецЕсли;
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Справочник.ОДМ_БазыДанных", ИмяМетаданных);
	
	СтрокаПоиска = ПараметрыЗапроса.Получить("search");
	Если НЕ ПустаяСтрока(СтрокаПоиска) Тогда
		МассивУсловий = Новый Массив;
		МассивСтрок = СтрРазделить(СтрокаПоиска, " ", Ложь); //#TODO: свернуть? разные раделитель?
		
		Для Индекс = 0 По МассивСтрок.ВГраница() Цикл
			ИмяПараметра = СтрШаблон("ПараметрПодобногоПоиска%1", Формат(Индекс, "ЧГ=''"));
			МассивУсловий.Добавить( СтрШаблон("т.Наименование подобно &%1", ИмяПараметра) );
			Запрос.Параметры.Вставить(ИмяПараметра, "%" + МассивСтрок[Индекс] + "%" );
		КонецЦикла;
		
		ТекстЗапроса = СтрШаблон(	"%1
									|И (%2)",
									ТекстЗапроса,
									СтрСоединить(МассивУсловий, " И ")
		);
	КонецЕсли;
	
	ТекстЗапроса1 = СтрЗаменить(ТекстЗапроса,	"т.ВерсияДанных КАК ВерсияДанных", "КОЛИЧЕСТВО(РАЗЛИЧНЫЕ т.Ссылка) КАК Количество");
	
	ВыбираемыеПоля = Новый Соответствие;
	ВыбираемыеПоля.Вставить("guid", "УНИКАЛЬНЫЙИДЕНТИФИКАТОР(т.Ссылка)");
	ВыбираемыеПоля.Вставить("name", "т.Наименование");
	
	ЗапрашиваемыеПоля = ПараметрыЗапроса.Получить("fields");
	Если НЕ ПустаяСтрока(СтрокаПоиска) Тогда
		МассивСтрок = СтрРазделить(ЗапрашиваемыеПоля, ",", Ложь);
		
		Для Каждого Элемент Из МассивСтрок Цикл
			//fields=Код:code,Артикул
			БлокПоля = СтрРазделить(Элемент, ":");
			Если БлокПоля.Количество()=1 Тогда
				БлокПоля.Добавить( БлокПоля[0] );
			КонецЕсли;
			ВыбираемыеПоля.Вставить(БлокПоля[1], СтрШаблон("т.%1", БлокПоля[0]));
		КонецЦикла;
		
	КонецЕсли;
	
	СвойстваЭлемента = Новый Массив;
	МассивПолей = Новый Массив;
	Для Каждого Элемент Из ВыбираемыеПоля Цикл
		МассивПолей.Добавить( СтрШаблон("%1 как %2", Элемент.Значение, Элемент.Ключ) );
		СвойстваЭлемента.Добавить(Элемент.Ключ);
	КонецЦикла;
	
	БлокИменПолей = СтрСоединить(МассивПолей, ", ");
	СвойстваЭлемента = СтрСоединить(СвойстваЭлемента, ", ");
	
	ТекстЗапроса2 = СтрЗаменить(ТекстЗапроса,	"т.ВерсияДанных КАК ВерсияДанных", БлокИменПолей);
	
	РазмерПорции = ПараметрыЗапроса.Получить("portion_size");
	РазмерПорции = ОбщегоНазначения.ОписаниеТипаЧисло(5).ПривестиЗначение(РазмерПорции);
	РазмерПорции = Формат(РазмерПорции, "ЧДЦ=0; ЧН=50; ЧГ=");
	
	ТекстЗапроса2 = СтрЗаменить(ТекстЗапроса2,	"ВЫБРАТЬ РАЗРЕШЕННЫЕ", СтрШаблон("ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ %1", РазмерПорции));
	
	Запрос.Текст = СтрШаблон(	"%1;
								|
								|%2", ТекстЗапроса1, ТекстЗапроса2);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[0].Выбрать();
	Если Выборка.Следующий() Тогда
		РезультатМетода["quantity"] = Выборка.Количество;
	КонецЕсли;
	
	Если РезультатМетода["quantity"] > 0 Тогда
		Выборка = РезультатЗапроса[1].Выбрать();
		Пока Выборка.Следующий() Цикл
			ОписаниеЭлемента = Новый Структура(СвойстваЭлемента);
			ЗаполнитьЗначенияСвойств(ОписаниеЭлемента, Выборка);
			ОписаниеЭлемента["guid"] = Строка(ОписаниеЭлемента["guid"]);
			РезультатМетода["list"].Добавить(ОписаниеЭлемента);
		КонецЦикла;
	КонецЕсли;
	
	Возврат РезультатМетода;
	
КонецФункции

Функция ОбработатьВходящуюЗадачу(ОписаниеЗадачи)
	
	РезультатМетода = Новый Структура("ВозвращаемыеДанные, КодСостояния", Новый Структура, 200);
	
	Если ОписаниеЗадачи.АсинхронныйВызов Тогда
		РегистрыСведений.ОДМ_ЗадачиОбмена.ЗаписатьДанныеЗадач(ОписаниеЗадачи);
		РезультатМетода.ВозвращаемыеДанные.Вставить("Идентификатор", ОписаниеЗадачи.Идентификатор);
		
	ИначеЕсли Перечисления.ОДМ_СтатусыЗадач.ЭтоЗавершенныйСтатус(ОписаниеЗадачи.Статус) Тогда
		РегистрыСведений.ОДМ_ЗадачиОбмена.ЗаписатьДанныеЗадач(ОписаниеЗадачи);
		РезультатМетода.ВозвращаемыеДанные = ОписаниеЗадачи.Результат;
		
		Если ОписаниеЗадачи.Результат = "Ошибка доступа" Тогда // FIXME: ужос как плохо
			РезультатМетода.КодСостояния = 403;
		КонецЕсли;
		
	Иначе
		
		Попытка
			
			//FIXME: плохой роутер - связать переделку c ОДМ_РегламентныеЗадания.ОДМ_ОбработкаЗадач()
			Если ОписаниеЗадачи.Метод = "query" Тогда
				ОДМ_ОбменДанными.ВыполнитьЗапрос(ОписаниеЗадачи);
				
			ИначеЕсли ОписаниеЗадачи.Метод = "objectPOST" Тогда
				ОДМ_ОбменДанными.ЗаписатьОбъект(ОписаниеЗадачи);
				
			Иначе
				ТекстСообщения = НСтр("ru='Что-то пошло не так :( Неизвестный метод %1';
										|en='Something went wrong :( Unknown method %1'");
				ВызватьИсключение СтрШаблон(ТекстСообщения, ОписаниеЗадачи.Метод);
			КонецЕсли;
			//<-
			
			РезультатМетода.ВозвращаемыеДанные = ОписаниеЗадачи.Результат;
		Исключение
			РезультатМетода.ВозвращаемыеДанные = ПолучитьПолноеОписаниеОшибки(ИнформацияОбОшибке());
			РезультатМетода.КодСостояния = 400;
		КонецПопытки;
	КонецЕсли;
	
	Возврат РезультатМетода;
	
КонецФункции

Функция ХарактеристикиДоступа(Знач Запрос, ОписаниеЗадачи)
	
	РезультатМетода = Ложь;
	
	//TODO: причесать спрятать в менеджер справочника
	
	Попытка
		ЗначениеПараметра = Запрос.ПараметрыЗапроса["initiator"];
		ЗначениеПараметра = СтрЗаменить(ЗначениеПараметра, "/", "\"); //FIXME: кастыль :( нет времени разбераться почему при передаче угол черты меняется :(
		ОписаниеИнициатора = ОДМ_ОбщегоНазначения.JSONВЗначение(ЗначениеПараметра);
	Исключение
		ОписаниеЗадачи.Статус = Перечисления.ОДМ_СтатусыЗадач.Отменен;
		ОписаниеЗадачи.Результат = "Ошибка доступа";
		Возврат РезультатМетода;
	КонецПопытки;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	т.Ссылка КАК Ссылка,
	                      |	тт.Доступность КАК Доступность
	                      |ИЗ
	                      |	Справочник.ОДМ_БазыДанных.ТехническиеПараметры КАК т
	                      |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОДМ_БазыДанных.Разрешения КАК тт
	                      |		ПО т.Ссылка = тт.Ссылка
	                      |ГДЕ
	                      |	т.СтрокаПодключения = &СтрокаПодключения
	                      |	И тт.Сервис = &Сервис");
	Запрос.УстановитьПараметр("СтрокаПодключения",		ОписаниеИнициатора["connectionPath"]);
	Запрос.УстановитьПараметр("Сервис",					ОписаниеЗадачи.Метод);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Количество() > 1 Тогда
		ОписаниеЗадачи.Статус = Перечисления.ОДМ_СтатусыЗадач.Отменен;
		ОписаниеЗадачи.Результат = "Для источника обнаружена неопределенность данных. Свяжитесь со службой поддержки!";
		Возврат РезультатМетода;
	Иначе
		Если Выборка.Следующий() Тогда
			
			Если Выборка.Доступность = NULL Тогда
				БазаДанныхОбъект = Выборка.Ссылка.ПолучитьОбъект();

				НоваяСтрока = БазаДанныхОбъект.Разрешения.Добавить();
				НоваяСтрока.Сервис = ОписаниеЗадачи.ИмяМетода;
				
				БазаДанныхОбъект.Записать();
				ОписаниеЗадачи.Инициатор = БазаДанныхОбъект.Ссылка;
			Иначе
				РезультатМетода = Выборка.Доступность;
				ОписаниеЗадачи.Инициатор = Выборка.Ссылка;
			КонецЕсли;
			
		Иначе
			БазаДанныхОбъект = Справочники.ОДМ_БазыДанных.СоздатьЭлемент();
			БазаДанныхОбъект.УстановитьНовыйКод();
		
			НоваяСтрока = БазаДанныхОбъект.ТехническиеПараметры.Добавить();
			НоваяСтрока.СтрокаПодключения = ОписаниеИнициатора["connectionPath"];
			
			НоваяСтрока = БазаДанныхОбъект.Разрешения.Добавить();
			НоваяСтрока.Сервис = ОписаниеЗадачи.Метод;
			
			БазаДанныхОбъект.Записать();
			ОписаниеЗадачи.Инициатор = БазаДанныхОбъект.Ссылка;
		КонецЕсли;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Если НЕ РезультатМетода = Истина Тогда
		ОписаниеЗадачи.Статус = Перечисления.ОДМ_СтатусыЗадач.Отменен;
		ОписаниеЗадачи.Результат = "Ошибка доступа";
	КонецЕсли;
	
	Возврат РезультатМетода;
	
КонецФункции

Функция ЭтоАсинхронныйВызов(Знач Запрос, Идентификатор)
	
	РезультатМетода = Истина;
	Попытка
		Идентификатор = Запрос.ПараметрыЗапроса["async"];
	Исключение
		РезультатМетода = Ложь;
	КонецПопытки;
	
	Возврат РезультатМетода;
	
КонецФункции

// Функция: СериализоватьXML
// Назначение: Сериализует объект в формат XML.
// Входные параметры:
//   ОбъектСериализации - Произвольный - Объект для сериализации.
// Возвращаемое значение:
//   Строка - XML-строка, представляющая объект.
Функция СериализоватьXML(ОбъектСериализации)
	
	ОбъектВXDTO = СериализаторXDTO.ЗаписатьXDTO(ОбъектСериализации);
	Запись = Новый ЗаписьXML;
	Запись.УстановитьСтроку();
	ФабрикаXDTO.ЗаписатьXML(Запись, ОбъектВXDTO);
	Возврат Запись.Закрыть();
	
КонецФункции

// Функция: ДесериализоватьXML
// Назначение: Десериализует XML-строку в объект.
// Входные параметры:
//   XMLСтруктура - Строка - XML-строка для десериализации.
// Возвращаемое значение:
//   Произвольный - Десериализованный объект.
Функция ДесериализоватьXML(XMLСтруктура) 
	
	ЧтениеXMLДанных = Новый ЧтениеXML; 
	ЧтениеXMLДанных.УстановитьСтроку(XMLСтруктура); 
	Параметр = СериализаторXDTO.ПрочитатьXML(ЧтениеXMLДанных); 
	ЧтениеXMLДанных.Закрыть(); 
	
	Возврат Параметр;
	
КонецФункции

// Устарела. Следует использовать ОДМ_ОбменДанными.СериализоватьJSON
// Функция: СериализоватьJSON
// Назначение: Сериализует объект в формат JSON.
// Входные параметры:
//   пЗначение - Произвольный - Объект для сериализации.
// Возвращаемое значение:
//   Строка - JSON-строка, представляющая объект.
Функция СериализоватьJSON(пЗначение)
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	Попытка	
		ЗаписатьJSON(ЗаписьJSON, пЗначение);
	Исключение 
		лПутьОшибки = Неопределено;
		лЗначениеОшибочное = мВыгрузкаВJSONНайтиПутьОшибочногоЗначения(пЗначение, лПутьОшибки);
		лТекстОшибки = "Не смогли выгрузить значение: "+?(лЗначениеОшибочное=Null, "Null", лЗначениеОшибочное)+", по пути: "+лПутьОшибки;
		Сообщить(лТекстОшибки); 
		ВызватьИсключение лТекстОшибки;
	КонецПопытки;
	
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

// Устарела. Следует использовать ОДМ_ОбменДанными.ДесериализоватьJSON
// Функция: ДесериализоватьJSON
// Назначение: Десериализует JSON-строку в объект.
// Входные параметры:
//   пЗначение - Строка - JSON-строка для десериализации.
//   пПрочитатьВСоответствие - Булево - Флаг, указывающий, нужно ли преобразовывать JSON в соответствие.
// Возвращаемое значение:
//   Произвольный - Десериализованный объект.
Функция ДесериализоватьJSON(пЗначение, пПрочитатьВСоответствие=Ложь)
	
	ЧтениеJSONДанных = Новый ЧтениеJSON;
	ЧтениеJSONДанных.УстановитьСтроку(пЗначение);
	Структура=ПрочитатьJSON(ЧтениеJSONДанных, пПрочитатьВСоответствие);
	ЧтениеJSONДанных.Закрыть();
	
	Возврат Структура;
	
КонецФункции

// Функция: HTTPОтветJSON
// Назначение: Формирует HTTP-ответ в формате JSON.
// Входные параметры:
//   пДанные - Произвольный - Данные для возврата в ответе.
//   пКод - Число - HTTP-код ответа (по умолчанию 200).
// Возвращаемое значение:
//   HTTPСервисОтвет - Ответ в формате JSON.
Функция HTTPОтветJSON(Знач Данные, Знач Код = 200)
	
	ХТТПСервисОтвет = Новый HTTPСервисОтвет(Код);
	ХТТПСервисОтвет.Заголовки.Вставить("Content-Type", "application/json");
	
	СериализованныеДанные = ОДМ_ОбменДанными.СериализоватьJSON(Данные);
	
	ХТТПСервисОтвет.УстановитьТелоИзСтроки(СериализованныеДанные);
	
	Возврат ХТТПСервисОтвет;
	
КонецФункции

