Функция listGET(Запрос)
	
	ИмяМетода = "list";
	
	РезультатМетода = Новый Структура("ВозвращаемыеДанные, КодСостояния", "", 200);
	
	Попытка
		ИмяМетаданных = Запрос.ПараметрыURL["metaname"];
		Если ПустаяСтрока(ИмяМетаданных) Тогда
			ВызватьИсключение "не заполнено имя запрашиваемых данных";
		КонецЕсли;
		
		РезультатМетода.ВозвращаемыеДанные = СписокПодходящихЭлементов(ИмяМетаданных, Запрос.ПараметрыЗапроса);
		
	Исключение
		РезультатМетода.ВозвращаемыеДанные = ОписаниеОшибки();
		РезультатМетода.КодСостояния = 400;
	КонецПопытки;
	
	Возврат HTTPОтветJSON(РезультатМетода.ВозвращаемыеДанные, РезультатМетода.КодСостояния);
	
КонецФункции

