
#Область ОбработчикиСобытий

Функция jobGET(Запрос)
	
	ТелоЗапросаHTTP = Запрос.ПолучитьТелоКакСтроку();
	СтруктураОтбора = ОДМ_ОбменДанными.ДесериализоватьJSON(ТелоЗапросаHTTP);
	
	Если НЕ ЗначениеЗаполнено(СтруктураОтбора) Тогда
		ТекстСообщения = НСтр("ru='Не заполнены параметры получения задач';
								|en='The task receipt parameters are not filled in'");
		Возврат HTTPОтветJSON(ТекстСообщения, 400);
	КонецЕсли;
	
	ОписаниеЗадачи = ОДМ_ОбменДанными.СостояниеЗадач(СтруктураОтбора);
	Возврат HTTPОтветJSON(ОписаниеЗадачи);
	
КонецФункции

Функция Query(Запрос)
	
	ИмяМетода = "query";
	
	РезультатМетода = Новый Структура("ВозвращаемыеДанные, КодСостояния", Новый Структура, 200);
	
	//FIXME: плохой кусок
	Идентификатор = Неопределено;
	АсинхронныйВызов = ЭтоАсинхронныйВызов(Запрос, Идентификатор);
	//<-
	
	ОписаниеЗадачи = ОДМ_ОбменДанными.Конструктор_ОписаниеЗадачи(Идентификатор);
	ОписаниеЗадачи.Метод			= ИмяМетода;
	ОписаниеЗадачи.АсинхронныйВызов	= АсинхронныйВызов;
	ОписаниеЗадачи.Статус			= Перечисления.ОДМ_СтатусыЗадач.Подготовлен;
	
	//FIXME: плохой кусок + объединить в ЭтоАсинхронныйВызов() ?
	ХарактеристикиДоступа(Запрос, ОписаниеЗадачи);
	//<-
	
	ТелоЗапросаHTTP = Запрос.ПолучитьТелоКакСтроку();
	ОписаниеЗадачи.Параметры = ОДМ_ОбменДанными.ДесериализоватьJSON(ТелоЗапросаHTTP);
	
	РезультатМетода = ОбработатьВходящуюЗадачу(ОписаниеЗадачи);
	
	Возврат HTTPОтветJSON(РезультатМетода.ВозвращаемыеДанные, РезультатМетода.КодСостояния);
	
КонецФункции

