#Область МетодыКоторымТутНичегоДелать

Функция ВернутьДополнительнуюКонстанту(Знач Имя) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Параметры.Вставить("Имя", Имя);
	
	мТекст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПЛ_ДополнительныеКонстанты.Имя КАК Имя,
	|	ПЛ_ДополнительныеКонстанты.Значение КАК Значение
	|ИЗ
	|	РегистрСведений.ПЛ_ДополнительныеКонстанты КАК ПЛ_ДополнительныеКонстанты
	|ГДЕ
	|	ПЛ_ДополнительныеКонстанты.Имя = &Имя";
	
	Если ТипЗнч(Имя) = Тип("Массив") Тогда
		мТекст = СтрЗаменить(мТекст, "= &Имя", "В (&Имя)");
		Имя = СтрСоединить(Имя, ",");
	КонецЕсли;
	
	СтруктураОтвета = Новый Структура(СтрСоединить(Имя, ","));
	
	Запрос.Текст = мТекст;
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		СтруктураОтвета[Выборка.Имя] = Выборка.Значение;
	КонецЦикла;
	
	Возврат ?(СтруктураОтвета.Количество() = 1, СтруктураОтвета[Имя], СтруктураОтвета);
	
КонецФункции

#КонецОбласти // УстаревшиеМетоды
