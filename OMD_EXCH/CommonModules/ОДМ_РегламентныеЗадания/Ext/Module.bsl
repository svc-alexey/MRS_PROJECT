
Процедура ОДМ_ОбработкаЗадач() Экспорт
	
	ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ОДМ_ОбработкаЗадач);
	
	//TODO: режем на кучу фоновых заданий по обработке разных функциональностей,
	//все что ниже к полному рефакторингу
	
	//FIXME: плохой роутер - связать
	ФоновыеЗадания.Выполнить("ОДМ_РегламентныеЗадания.ОбработкаЗаданий_Запросы",		,	"ОбработкаЗаданий_Запросы");
	ФоновыеЗадания.Выполнить("ОДМ_РегламентныеЗадания.ОбработкаЗаданий_ЗаписьОбъектов",	,	"ОбработкаЗаданий_ЗаписьОбъектов");
	//<-
	
	ОДМ_ОбменДанными.ОтправитьДанныеВБазыПолучателей();
	ОДМ_ОбменДанными.СоздатьЭлементыСправочникаИзЗадач();
	ОДМ_ОбменДанными.ПолучитьГУИДИзВнешнейБазы();
	
КонецПроцедуры

Процедура ОДМ_ОбработкаУстаревшихЗадач() Экспорт
	
	ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ОДМ_ОбработкаУстаревшихЗадач);
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	т.Идентификатор КАК Идентификатор
	                      |ИЗ
	                      |	РегистрСведений.ОДМ_ЗадачиОбмена КАК т
	                      |ГДЕ
	                      |	т.ДатаСоздания < &ДатаСоздания
	                      |;
	                      |
	                      |////////////////////////////////////////////////////////////////////////////////
	                      |ВЫБРАТЬ
	                      |	т.Идентификатор КАК Идентификатор
	                      |ИЗ
	                      |	РегистрСведений.ОДМ_ЗадачиОбмена КАК т
	                      |ГДЕ
	                      |	т.ДатаСоздания >= &ДатаСоздания
	                      |	И т.Попытка >= &Попытка
	                      |	И т.Статус В(&АктивныеСтатусы)");
	Запрос.УстановитьПараметр("ДатаСоздания",		ДатаОчисткиЗадач());
	Запрос.УстановитьПараметр("Попытка",			КоличествоПопытокНаЗадачу());
	Запрос.УстановитьПараметр("АктивныеСтатусы",	Перечисления.ОДМ_СтатусыЗадач.АктивныеСтатусы());
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ЗадачиСтарогоПериода = РезультатЗапроса[0].Выбрать();
	Пока ЗадачиСтарогоПериода.Следующий() Цикл
		Запись = РегистрыСведений.ОДМ_ЗадачиОбмена.СоздатьМенеджерЗаписи();
		Запись.Идентификатор = ЗадачиСтарогоПериода.Идентификатор;
		Запись.Удалить();
	КонецЦикла;
	
	ЗадачиПревысившиеЛимитПопыток = РезультатЗапроса[1].Выбрать();
	Пока ЗадачиПревысившиеЛимитПопыток.Следующий() Цикл
		Запись = РегистрыСведений.ОДМ_ЗадачиОбмена.СоздатьМенеджерЗаписи();
		Запись.Идентификатор = ЗадачиПревысившиеЛимитПопыток.Идентификатор;
		Запись.Прочитать();
		Если Запись.Выбран() Тогда
			Запись.Статус = Перечисления.ОДМ_СтатусыЗадач.Ошибка;
			Запись.Записать(Истина);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#Область СлужебныйПрограммныйИнтерфейс

//FIXME: требуется унификация - делаем примерно одно и тоже

Процедура ОбработкаЗаданий_Запросы() Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	т.Идентификатор КАК Идентификатор
	                      |ИЗ
	                      |	РегистрСведений.ОДМ_ЗадачиОбмена КАК т
	                      |ГДЕ
	                      |	т.Метод = &Метод
	                      |	И т.Статус В (&АктивныеСтатусы)
	                      |	И т.Попытка < &Попытка");
	Запрос.Параметры.Вставить("Метод",				"query");
	Запрос.Параметры.Вставить("АктивныеСтатусы",	Перечисления.ОДМ_СтатусыЗадач.АктивныеСтатусы());
	Запрос.Параметры.Вставить("Попытка",			КоличествоПопытокНаЗадачу());
	Выборка = Запрос.Выполнить().Выбрать();
	
	//вставить проверку, что бы фоновых заданий не было больше X
	Пока Выборка.Следующий() Цикл
		ФоновыеЗадания.Выполнить("ОДМ_РегламентныеЗадания.ОбработкаЗадания_ВыполнитьЗапрос", Выборка.Идентификатор, Выборка.Идентификатор);
	КонецЦикла;
	
КонецПроцедуры // СлужебныйПрограммныйИнтерфейс

