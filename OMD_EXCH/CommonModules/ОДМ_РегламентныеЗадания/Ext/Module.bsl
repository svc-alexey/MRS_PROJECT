#Область СлужебныеПроцедурыИФункции

Функция КоличествоПопытокНаЗадачу()
	
	Возврат 5;
	
КонецФункции

Функция ДатаОчисткиЗадач()
	
	Возврат ТекущаяДатаСеанса() - 30*24*60*60;
	
КонецФункции

#Область РазныеОбертки

Процедура ПриНачалеВыполненияРегламентногоЗадания(Знач РегламентноеЗадание)
	
	ОбщийМодуль_ОбщегоНазначения = ОДМ_ОбщегоНазначения.ОбщийМодуль("ОбщегоНазначения");
	Если НЕ ОбщийМодуль_ОбщегоНазначения = Неопределено Тогда
		ОбщийМодуль_ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(РегламентноеЗадание);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти // РазныеОбертки

