Процедура ВыполнитьЗапрос(ОписаниеЗадачи) Экспорт
	
	ОписаниеЗадачи.Попытка = ОписаниеЗадачи.Попытка + 1;
	
	ОписаниеЗапроса = ОписаниеЗадачи.Параметры;
	
	Попытка
		
		//TODO: переделать на схему запроса
		Запрос = Новый Запрос(ОписаниеЗапроса.ТекстЗапроса);
		Для Каждого КлючИЗначениеПараметры Из ОписаниеЗапроса.Параметры Цикл
			ИмяПараметра = Строка(КлючИЗначениеПараметры.Ключ);
			ЗначениеПараметра = КлючИЗначениеПараметры.Значение;
			ТипЗначенияПараметра = ТипЗнч(ЗначениеПараметра);
			
			//TODO: значение параметров собирать через единый для всей подсистемы метод сериализации
			Если ИСТИНА
			И	ТипЗначенияПараметра = Тип("Массив")
			И	ЗначениеПараметра.Количество() > 0
			И	ТипЗнч(ЗначениеПараметра[0]) = Тип("Структура")
			Тогда
				ЗначениеПараметра = МассивСтруктурВТаблицуЗначений(ЗначениеПараметра);
			КонецЕсли;
				
			Запрос.Параметры.Вставить(ИмяПараметра, ЗначениеПараметра);
		КонецЦикла;
		
		#Область TODO
		//TODO: подумать нужна ли такая возможность и как экранировать от левых использований
		//АлгоритмВыполнения = "";
		//Если ИСТИНА
		//	И ПараметрыЗапроса.Свойство("ПередВыполнениемЗапроса", АлгоритмВыполнения)
		//	И НЕ ПустаяСтрока(АлгоритмВыполнения)
		//	Тогда
		//	
		//	Выполнить(АлгоритмВыполнения);
		//КонецЕсли;
		#КонецОбласти // TODO
		
		Если ОДМ_ОбменДанными.ЭтоПакетныйЗапрос(ОписаниеЗапроса) Тогда
			ОписаниеЗадачи.Результат = Новый Структура;
			ТаблицыРезультата = ОписаниеЗапроса.ТаблицыРезультата;
			РезультатЗапроса = Запрос.ВыполнитьПакет();
			
			Для Каждого КлючИЗначение Из ТаблицыРезультата Цикл
				ТаблицаЗначений = РезультатЗапроса[КлючИЗначение.Значение].Выгрузить();
				//ОписаниеЗадачи.Результат.Вставить(КлючИЗначение.Ключ, ОДМ_ОбщегоНазначения.ТаблицаЗначенийВМассив(ТаблицаЗначений));
				ОписаниеЗадачи.Результат.Вставить(КлючИЗначение.Ключ, ТаблицаЗначений);
			КонецЦикла;
		Иначе
			ТаблицаЗначений = Запрос.Выполнить().Выгрузить();
			//ОписаниеЗадачи.Результат = ОДМ_ОбщегоНазначения.ТаблицаЗначенийВМассив(ТаблицаЗначений);
			ОписаниеЗадачи.Результат = ТаблицаЗначений;
		КонецЕсли;
		
		#Область TODO
		//TODO: подумать нужна ли такая возможность и как экранировать от левых использований
		//АлгоритмВыполнения = "";
		//Если ИСТИНА
		//	И ПараметрыЗапроса.Свойство("ПослеПолученияРезультатов", АлгоритмВыполнения)
		//	И НЕ ПустаяСтрока(АлгоритмВыполнения)
		//	Тогда
		//	
		//	Выполнить(АлгоритмВыполнения);
		//КонецЕсли;
		#КонецОбласти // TODO
		
		ОписаниеЗадачи.Статус = Перечисления.ОДМ_СтатусыЗадач.Выполнен;
		УстановитьМоментыДействий(ОписаниеЗадачи);
		РегистрыСведений.ОДМ_ЗадачиОбмена.ЗаписатьДанныеЗадач(ОписаниеЗадачи);
		
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ОписаниеЗадачи.Ошибка = ОписаниеЗадачи.Ошибка + Символы.ПС + ТекстОшибки;
		ОписаниеЗадачи.Статус = Перечисления.ОДМ_СтатусыЗадач.Ошибка;
		РегистрыСведений.ОДМ_ЗадачиОбмена.ЗаписатьДанныеЗадач(ОписаниеЗадачи);
		
		ВызватьИсключение ТекстОшибки;
	КонецПопытки;
	
КонецПроцедуры

Процедура ЗаписатьОбъект(ОписаниеЗадачи) Экспорт
	
	Перем КэшЗначений;
	
	ОписаниеЗадачи.Результат = Новый Массив;
	ОписаниеЗадачи.Попытка = ОписаниеЗадачи.Попытка + 1;
	
	ОписаниеОбъекта = ОписаниеЗадачи.Параметры.Данные;
	
	Если ТипЗнч(ОписаниеОбъекта) = Тип("Массив") Тогда
		ДанныеКЗаписи = ОписаниеОбъекта;
	Иначе
		ДанныеКЗаписи = Новый Массив;
		ДанныеКЗаписи.Добавить(ОписаниеОбъекта);
	КонецЕсли;
	
	НачатьТранзакцию();
	Попытка
		Для Каждого ЭлементДанных Из ДанныеКЗаписи Цикл
			ОбъектДанных = ПолучитьОбъектПоСвойству(ЭлементДанных);
		
			Для Каждого КлючИЗначение Из ЭлементДанных Цикл
				Если ЛОЖЬ //FIXME: в метод с параметром по типу передплть
				ИЛИ	КлючИЗначение.Ключ = "Ссылка"
				ИЛИ КлючИЗначение.Ключ = "ЭтоГруппа"
				ИЛИ КлючИЗначение.Ключ = "ИмяПредопределенного"
				Тогда
					Продолжить;
				КонецЕсли;
				
				Если ТипЗнч(КлючИЗначение.Значение) = Тип("Массив") Тогда
					Если ОписаниеЗадачи.Параметры.ОчищатьТабличнуюЧасть Тогда
						ОбъектДанных[КлючИЗначение.Ключ].Очистить();
					КонецЕсли;
					Для Каждого СтрокаТабличнойЧасти Из КлючИЗначение.Значение Цикл
						НоваяСтрокаОбъекта = ОбъектДанных[КлючИЗначение.Ключ].Добавить();
						Для Каждого КолонкаТЧ Из СтрокаТабличнойЧасти Цикл
							НоваяСтрокаОбъекта[КолонкаТЧ.Ключ] = ПрочитатьЗначениеСвойства(КолонкаТЧ.Значение, КэшЗначений);
						КонецЦикла;
					КонецЦикла;
				Иначе
					ОбъектДанных[КлючИЗначение.Ключ] = ПрочитатьЗначениеСвойства(КлючИЗначение.Значение, КэшЗначений);
				КонецЕсли;
			КонецЦикла;
			
			ОДМ_ОбменДанными_Переопределяемый.ПриОбработкеОбъекта(ОбъектДанных);
			
			//<< ДеевС 20.11.2025 CPM-321 При интеграции выписок передавать признак проведения/пометка удаления
			//Если ОписаниеЗадачи.Параметры.Проводить Тогда
			//	ОбъектДанных.Записать(РежимЗаписиДокумента.Проведение);
			//ИначеЕсли ОписаниеЗадачи.Параметры.ВключитьОбменДанными Тогда
			//	ОбъектДанных.ОбменДанными.Загрузка = Истина;
			//	ОбъектДанных.Записать();
			//Иначе
			//	ОбъектДанных.Записать();
			//КонецЕсли;
			ЭтоДокумент = ОбщегоНазначения.ЭтоДокумент(ОбъектДанных.Метаданные());
			ЭтоСправочник = ОбщегоНазначения.ЭтоСправочник(ОбъектДанных.Метаданные());
			
			Если ЭтоСправочник Тогда
				// Для справочников простая запись с синхронизацией пометки удаления.
					Если ОписаниеЗадачи.Параметры.ВключитьОбменДанными Тогда
						ОбъектДанных.ОбменДанными.Загрузка = Истина;
						ОбъектДанных.Записать();
					Иначе
						ОбъектДанных.Записать();
					КонецЕсли;
				
			ИначеЕсли ЭтоДокумент Тогда
				// Для документов: синхронизация статусов с нормализацией состояний.
				Если ОписаниеЗадачи.Параметры.Проводить Тогда
					// Синхронизация проведённого статуса: снять пометку, отменить текущее проведение, провести.
					Если ОбъектДанных.ПометкаУдаления Тогда
						ОбъектДанных.ПометкаУдаления = Ложь;
					КонецЕсли;
					Если ОбъектДанных.Проведен Тогда
						ОбъектДанных.Записать(РежимЗаписиДокумента.ОтменаПроведения);
					КонецЕсли;
					ОбъектДанных.Записать(РежимЗаписиДокумента.Проведение);
					
				Иначе
					// Синхронизация непроведённого статуса: отменить проведение если нужно, записать как есть.
					НужноОтменитьПроведение = ОбъектДанных.Проведен
						И (ОбъектДанных.ПометкаУдаления // Если пометка удаления, обязательно распроводить.
						ИЛИ Истина); // Для синхронизации: если в источнике не проведён, отменить в базе.
					Если НужноОтменитьПроведение Тогда
						ОбъектДанных.Записать(РежимЗаписиДокумента.ОтменаПроведения);
					Иначе
						ОбъектДанных.Записать();
					КонецЕсли;
					
				КонецЕсли;
				
			Иначе
				// Для других типов (регистры и т.д.): стандартная запись.
				ОбъектДанных.Записать();
				
			КонецЕсли;
			//>> ДеевС 20.11.2025
			
			РезультатДанных = Новый Структура("ОписаниеСсылки, Идентификатор", ЭлементДанных.Ссылка, ОбъектДанных.Ссылка.УникальныйИдентификатор());
			ОписаниеЗадачи.Результат.Добавить(РезультатДанных);
		КонецЦикла;
		
		Если ОписаниеЗадачи.Результат.Количество()=1 Тогда
			ОписаниеЗадачи.Результат = ОписаниеЗадачи.Результат[0];
		КонецЕсли;
		
		ОписаниеЗадачи.Статус = Перечисления.ОДМ_СтатусыЗадач.Выполнен;
		УстановитьМоментыДействий(ОписаниеЗадачи);
		РегистрыСведений.ОДМ_ЗадачиОбмена.ЗаписатьДанныеЗадач(ОписаниеЗадачи);
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		ОтменитьТранзакцию();
		
		ТекстОшибки = ОписаниеОшибки();
		ОписаниеЗадачи.Ошибка = ОписаниеЗадачи.Ошибка + Символы.ПС + ТекстОшибки;
		ОписаниеЗадачи.Статус = Перечисления.ОДМ_СтатусыЗадач.Ошибка;
		РегистрыСведений.ОДМ_ЗадачиОбмена.ЗаписатьДанныеЗадач(ОписаниеЗадачи);
		
		ВызватьИсключение ТекстОшибки;
	КонецПопытки;
	
КонецПроцедуры

// Выполняет шаблон интеграции из справочника ОДМ_МетодыИнтеграции.
// Шаблон ищется по коду, переданному в ОписаниеЗадачи.Параметры["Шаблон"].
// Поведение определяется полем ТипШаблона элемента справочника:
//   ЗаписьОбъектов — необязательный BSL-код предобработки, затем ЗаписатьОбъект;
//   Запрос         — текст запроса из поля Шаблон, параметры из тела запроса;
//   Обработчик     — произвольный BSL-код или вызов экспортной процедуры базы.
//
// Параметры:
//   ОписаниеЗадачи - Структура - стандартная структура задачи обмена.
Процедура ВыполнитьПоШаблону(ОписаниеЗадачи) Экспорт
	
	ОписаниеЗадачи.Попытка = ОписаниеЗадачи.Попытка + 1;
	
	КодШаблона = "";
	Если НЕ ОписаниеЗадачи.Параметры.Свойство("Шаблон", КодШаблона)
		ИЛИ ПустаяСтрока(КодШаблона) Тогда
		ВызватьИсключение НСтр("ru='В параметрах вызова отсутствует или пуст ключ ""Шаблон""'");
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	т.Активен    КАК Активен,
	|	т.ТипШаблона КАК ТипШаблона,
	|	т.Шаблон     КАК Шаблон
	|ИЗ
	|	Справочник.ОДМ_МетодыИнтеграции КАК т
	|ГДЕ
	|	т.Код = &Код
	|	И НЕ т.ПометкаУдаления";
	Запрос.УстановитьПараметр("Код", КодШаблона);
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		ВызватьИсключение СтрШаблон(НСтр("ru='Шаблон интеграции с кодом ""%1"" не найден'"), КодШаблона);
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	Если НЕ Выборка.Активен Тогда
		ВызватьИсключение СтрШаблон(НСтр("ru='Шаблон интеграции ""%1"" неактивен'"), КодШаблона);
	КонецЕсли;
	
	ТипШаблона   = Выборка.ТипШаблона;
	ТекстШаблона = Выборка.Шаблон;
	
	Попытка
		
		Если ТипШаблона = "ЗаписьОбъектов" Тогда
			
			Если НЕ ПустаяСтрока(ТекстШаблона) Тогда
				Выполнить(ТекстШаблона); // предобработка: маппинг входного JSON в Данные
			КонецЕсли;
			ЗаписатьОбъект(ОписаниеЗадачи);
			
		ИначеЕсли ТипШаблона = "Запрос" Тогда
			
			ОписаниеЗадачи.Параметры.Вставить("ТекстЗапроса", ТекстШаблона);
			ВыполнитьЗапрос(ОписаниеЗадачи);
			
		ИначеЕсли ТипШаблона = "Обработчик" Тогда
			
			Выполнить(ТекстШаблона);
			Если НЕ Перечисления.ОДМ_СтатусыЗадач.ЭтоЗавершенныйСтатус(ОписаниеЗадачи.Статус) Тогда
				ОписаниеЗадачи.Статус = Перечисления.ОДМ_СтатусыЗадач.Выполнен;
			КонецЕсли;
			УстановитьМоментыДействий(ОписаниеЗадачи);
			РегистрыСведений.ОДМ_ЗадачиОбмена.ЗаписатьДанныеЗадач(ОписаниеЗадачи);
			
		ИначеЕсли ТипШаблона = "Составной" Тогда
			ВызватьИсключение НСтр("ru='Тип шаблона ""Составной"" не реализован'");
			
		Иначе
			ВызватьИсключение СтрШаблон(НСтр("ru='Неизвестный тип шаблона: ""%1""'"), ТипШаблона);
		КонецЕсли;
		
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ОписаниеЗадачи.Ошибка = ОписаниеЗадачи.Ошибка + Символы.ПС + ТекстОшибки;
		Если ОписаниеЗадачи.Статус <> Перечисления.ОДМ_СтатусыЗадач.Ошибка Тогда
			ОписаниеЗадачи.Статус = Перечисления.ОДМ_СтатусыЗадач.Ошибка;
			РегистрыСведений.ОДМ_ЗадачиОбмена.ЗаписатьДанныеЗадач(ОписаниеЗадачи);
		КонецЕсли;
		ВызватьИсключение ТекстОшибки;
	КонецПопытки;
	
КонецПроцедуры

Функция СостояниеЗадач(Знач СтруктураОтбора) Экспорт
	
	РезультатМетода = Новый Массив;
	
	//TODO: подумать как более красиво обвязать и настроить считываение отборов
	Если ТипЗнч(СтруктураОтбора) = Тип("Строка") Тогда
		СтруктураОтбора = СтрРазделить(СтруктураОтбора, ",");
	КонецЕсли;
	Если ТипЗнч(СтруктураОтбора) = Тип("Массив") Тогда
		МассивИдентификаторов = Новый Массив;
		Для Каждого ЭлементМассива Из СтруктураОтбора Цикл
			МассивИдентификаторов.Добавить(ПолучитьGUIDИзДанных(ЭлементМассива));
		КонецЦикла;
		СтруктураОтбора = Новый Структура("Идентификаторы", МассивИдентификаторов);
	КонецЕсли;
	
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1 РЕГИСТРСВЕДЕНИЙ.ОДМ_ЗадачиОбмена.* ГДЕ Идентификатор В (&Идентификаторы)"); //TODO: в менеджер регистра с переделкой на нормальную реализацию
	Запрос.Параметры.Вставить("Идентификаторы", СтруктураОтбора.Идентификаторы);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ОписаниеЗадачи = ОДМ_ОбменДанными.Конструктор_ОписаниеЗадачи();
		ЗаполнитьЗначенияСвойств(ОписаниеЗадачи, Выборка, , "Параметры, Результат");
		ОписаниеЗадачи.Параметры = Выборка.Параметры.Получить();
		ОписаниеЗадачи.Результат = Выборка.Результат.Получить();
		
		РезультатМетода.Добавить(ОписаниеЗадачи);
	КонецЕсли;
		
	Возврат РезультатМетода;
	
КонецФункции

