// Сериализует объект в формат JSON.
// Входные параметры:
//   Значение - Произвольный - Объект для сериализации.
// Возвращаемое значение:
//   Строка - JSON-строка, представляющая объект.
Функция СериализоватьJSON(Знач Значение) Экспорт
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	
	Попытка
		ЗаписатьJSON(ЗаписьJSON, Значение, , "ПреобразованиеJSON", Вычислить("ОДМ_ОбменДанными"));
	Исключение
		ПутьОшибки = Неопределено;
		ЗначениеОшибочное = ЗаписатьJSON_НайтиПутьОшибочногоЗначения(Значение, ПутьОшибки);
		
		ШаблонТекстаОшибки = "Не смогли выгрузить значение: %1, по пути: %2";
		ТекстОшибки = СтрШаблон(ШаблонТекстаОшибки, ?(ЗначениеОшибочное = Null, "Null", ЗначениеОшибочное), ПутьОшибки);
		
		ВызватьИсключение ТекстОшибки;
	КонецПопытки;
	
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

// Десериализует объект в формат JSON
// Входные параметры:
//   Значение - Строка - строка JSON
// Возвращаемое значение:
//   Структура или Соответствие
Функция ДесериализоватьJSON(Знач Значение, Знач ПрочитатьВСоответствие = Ложь) Экспорт
	
	ЧтениеJSONДанных = Новый ЧтениеJSON;
	ЧтениеJSONДанных.УстановитьСтроку(Значение);
	
	РезультатМетода = ПрочитатьJSON(ЧтениеJSONДанных, ПрочитатьВСоответствие, , , "ВосстановлениеJSON", Вычислить("ОДМ_ОбменДанными"));
	
	ЧтениеJSONДанных.Закрыть();
	
	Возврат РезультатМетода;
	
КонецФункции

// Возвращает полное описание ошибки, включая вложенные причины.
// Входные параметры:
//   ИнформацияОбОшибке - ИнформацияОбОшибке - Объект с информацией об ошибке.
// Возвращаемое значение:
//   Строка - Полное описание ошибки.
Функция ПолноеОписаниеОшибки(ИнформацияОбОшибке) Экспорт
	
	Описание = ИнформацияОбОшибке.Описание;
	Если ЗначениеЗаполнено(ИнформацияОбОшибке.НомерСтроки) Тогда
		Описание = СтрШаблон("%1 {%2: %3}", ИнформацияОбОшибке.ИмяМодуля, ИнформацияОбОшибке.НомерСтроки);
	КонецЕсли;
	
	Если ИнформацияОбОшибке.Причина <> Неопределено Тогда
		Описание = СтрШаблон("%1
							|%2", Описание, ПолноеОписаниеОшибки(ИнформацияОбОшибке.Причина));
	КонецЕсли;
	
	Возврат Описание;
	
КонецФункции

// Преобразует массив структур в таблицу значений. Обратная функция ОбщегоНазначения.ТаблицаЗначенийВМассив(ТаблицаЗначений)
//
// Входные параметры:
//   МассивСтруктур - Массив из Структура - Объект для проверки
//     * Ключ							- Строка		- имя колонки
//     * Значение						- Произвольный	- значение
//
// Возвращаемое значение:
//   ТаблицаЗначений - Ошибочное значение или Неопределено, если ошибок нет
//
Функция МассивСтруктурВТаблицуЗначений(МассивСтруктур, Знач СтрогаяТипизация = Истина) Экспорт
	
	РезультатМетода = Новый ТаблицаЗначений;
	
	ТипыКолонок = Новый Соответствие;
	
	Если СтрогаяТипизация Тогда
		Для Каждого ЭлементКоллекции Из МассивСтруктур Цикл
			Для Каждого КлючИЗначение Из ЭлементКоллекции Цикл
				Если ТипыКолонок[КлючИЗначение.Ключ] = Неопределено Тогда
					ТипыКолонок[КлючИЗначение.Ключ] = Новый Массив;
				КонецЕсли;
				
				ТипЗначения = ТипЗнч(КлючИЗначение.Значение);
				Если ТипыКолонок[КлючИЗначение.Ключ].Найти(ТипЗначения) = Неопределено Тогда
					ТипыКолонок[КлючИЗначение.Ключ].Добавить(ТипЗначения);
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
	Для Каждого ЭлементКоллекции Из МассивСтруктур Цикл
		
		НоваяСтрока = РезультатМетода.Добавить();
		
		Для Каждого КлючИЗначение Из ЭлементКоллекции Цикл
			Если РезультатМетода.Колонки.Найти(КлючИЗначение.Ключ) = Неопределено Тогда
				ТипыКолонки = ТипыКолонок[КлючИЗначение.Ключ];
				Если ТипыКолонки = Неопределено Тогда
					ОписаниеТипаКолонки = ОДМ_ОбменДанными_ПовтИсп.ОписаниеТипаВсеТипыОбмена();
				Иначе
					ОписаниеТипаКолонки = ОписаниеТипаПоМассивуТипов(ТипыКолонки);
				КонецЕсли;
				РезультатМетода.Колонки.Добавить(КлючИЗначение.Ключ, ОписаниеТипаКолонки);
			КонецЕсли;
			//НоваяСтрока[КлючИЗначение.Ключ] = КлючИЗначение.Значение;
		КонецЦикла;
		
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементКоллекции);
		
	КонецЦикла;
	
	Возврат РезультатМетода;
	
КонецФункции

// Для получения GUID из данных
// Входные параметры:
//   Значение - Произвольный - используется для вычисления УникальногоИдентификатора
Функция ПолучитьGUIDИзДанных(Знач Значение, Знач ВызыватьИсключение = Ложь) Экспорт
	
	ТипЗначения = ТипЗнч(Значение);
	
	Попытка
		Если ТипЗначения = Тип("Строка") Тогда
			Возврат Новый УникальныйИдентификатор(Значение);
		ИначеЕсли ТипЗначения = Тип("УникальныйИдентификатор") Тогда
			Возврат Значение;
		КонецЕсли;
	Исключение
		Если ВызыватьИсключение Тогда
			ВызватьИсключение;
		Иначе
			Возврат Неопределено;
		КонецЕсли;
	КонецПопытки;
	
КонецФункции

