Функция ПолучитьОбъектПоСвойству(Знач ОписаниеОбъекта)
	
	ОписаниеСсылки = ОписаниеОбъекта.Ссылка;
	ТипЗначения = ТипЗнч(ОписаниеСсылки);
	
	Если ТипЗначения = Тип("Структура") Тогда
		Если ПустаяСтрока(ОписаниеСсылки.Значение) Тогда
			ОписаниеСсылки.Значение = "00000000-0000-0000-0000-000000000000";
		КонецЕсли;
		
		ТипЗначения = Тип(ОписаниеСсылки.Тип);
		Ссылка = XMLЗначение(ТипЗначения, ОписаниеСсылки.Значение);
	Иначе
		Ссылка = ОписаниеСсылки;
	КонецЕсли;
	
	Если ОДМ_ОбщегоНазначения.СсылкаСуществует(Ссылка) Тогда
		Объект = Ссылка.ПолучитьОбъект();
	Иначе
		Менеджер = ОДМ_ОбщегоНазначения.МенеджерОбъектаПоСсылке(Ссылка);
		
		ВидОбъекта = ОДМ_ОбщегоНазначения.ВидОбъектаПоТипу(ТипЗначения);
		Если ВидОбъекта = "Справочник" Тогда
			#Если Сервер и Не Сервер Тогда
				Менеджер = Справочники.ОДМ_БазыДанных;
			#КонецЕсли
			
			Если ОписаниеОбъекта.Свойство("ЭтоГруппа")
			И (ОписаниеОбъекта.ЭтоГруппа = Истина
				ИЛИ ПрочитатьЗначениеСвойства(ОписаниеОбъекта.ЭтоГруппа) = Истина)
			Тогда
				Объект = Менеджер.СоздатьГруппу();
			Иначе
				Объект = Менеджер.СоздатьЭлемент();
			КонецЕсли;
			
			Попытка //FIXME: если стандартный реквизит отсутвует - исключение. переделать на проверку метаданных
				ОписаниеОбъекта.Свойство("Код", Объект.Код);
				Если НЕ ЗначениеЗаполнено(Объект.Код) Тогда
					Объект.УстановитьНовыйКод(Объект.Код);
				КонецЕсли;
			Исключение КонецПопытки;
			
		ИначеЕсли ВидОбъекта = "Документ" Тогда
			#Если Сервер и Не Сервер Тогда
				Менеджер = Документы.ОДМ_ХТТПЗапросы;
			#КонецЕсли
			
			Объект = Менеджер.СоздатьДокумент();
			
			Попытка //FIXME: если стандартный реквизит отсутвует - исключение. переделать на проверку метаданных
				ОписаниеОбъекта.Свойство("Номер", Объект.Номер);
				Если ЗначениеЗаполнено(Объект.Номер) Тогда
					Объект.УстановитьНовыйНомер();
				КонецЕсли;
			Исключение КонецПопытки;
			
		ИначеЕсли ВидОбъекта = "ПланВидовХарактеристик" Тогда
			
			Если ОписаниеОбъекта.Свойство("ЭтоГруппа")
			И (ОписаниеОбъекта.ЭтоГруппа = Истина
				ИЛИ ПрочитатьЗначениеСвойства(ОписаниеОбъекта.ЭтоГруппа) = Истина)
			Тогда
				Объект = Менеджер.СоздатьГруппу();
			Иначе
				Объект = Менеджер.СоздатьЭлемент();
			КонецЕсли;
			
			Попытка //FIXME: если стандартный реквизит отсутвует - исключение. переделать на проверку метаданных
				ОписаниеОбъекта.Свойство("Код", Объект.Код);
				Если НЕ ЗначениеЗаполнено(Объект.Код) Тогда
					Объект.УстановитьНовыйКод();
				КонецЕсли;
			Исключение КонецПопытки;
				
		Иначе
			ВызватьИсключение "пока поддерживаются только документы, справочники, ПВХ";
		КонецЕсли;
		
		УстановитьДополнительныеСвойстваОбъекту(Объект, ВидОбъекта);
		
		ИдентификаторСсылки = Ссылка.УникальныйИдентификатор();
		Если ЗначениеЗаполнено(ИдентификаторСсылки) Тогда
			СсылкаНового = Менеджер.ПолучитьСсылку(ИдентификаторСсылки);
			Объект.УстановитьСсылкуНового(СсылкаНового);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Объект;
	
КонецФункции

