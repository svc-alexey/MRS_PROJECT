// Процедура: мВыгрузкаВJSONНайтиПутьОшибочногоЗначения
// Назначение: Создает задачу обмена для указанного источника и массива баз данных.
// Входные параметры:
//   Ссылка - СправочникСсылка - Ссылка на объект, для которого создается задача.
//   МассивБазДанных - Массив - Массив баз данных, в которые нужно отправить данные.
Процедура ДобавитьЗадачуОбменаПоИБ(Ссылка,МассивБазДанных) Экспорт
	
	СоздатьЗадачуОбмена(Ссылка, Ложь, МассивБазДанных); 

КонецПроцедуры

// Процедура: СоздатьЗадачуОбмена
// Назначение: Создает задачу обмена для указанного источника и массива баз данных.
// Входные параметры:
//   Источник - Произвольный - Объект, для которого создается задача.
//   Отказ - Булево - Флаг, указывающий на отказ от создания задачи.
//   МассивБазДанных - Массив - Массив баз данных, в которые нужно отправить данные.
Процедура СоздатьЗадачуОбмена(Источник, Отказ, МассивБазДанных = "")
	
	ТипИсточника = Источник.Метаданные().Имя;
	Если НЕ ЗначениеЗаполнено(МассивБазДанных) Тогда
		СтрокаБаз = ВернутьДополнительнуюКонстанту("БазыОбмен_" + ТипИсточника);
		Если НЕ ЗначениеЗаполнено(СтрокаБаз) Тогда
			Возврат;
		КонецЕсли;
		МассивБазДанных = СтрРазделить(СтрокаБаз, "|");
	КонецЕсли;
	
	ТекущаяПубликация = ВернутьДополнительнуюКонстанту("ТекущаяВебПубликация");
	ВебСервер = ВернутьДополнительнуюКонстанту("СерверВебПубликаций");
		
	НаборЗадач = РегистрыСведений.ОДМ_ЗадачиОбмена.СоздатьНаборЗаписей();
	
	СоответствиеБаз = ПолучитьСоответствиеБазИспользования(МассивБазДанных);
	
	СоответствиеОбъектов = ПолучитьСоответствиеОбъектовПоБазам(СоответствиеБаз,Источник);
	
	Для Каждого МестоИспользования Из МассивБазДанных Цикл
		
		ИдентификаторЗадачи =  Новый УникальныйИдентификатор;
		
		Задача = НаборЗадач.Добавить();
		Задача.Идентификатор = ИдентификаторЗадачи;
		Задача.Инициатор =  Строка(Пользователи.ТекущийПользователь());
		Задача.Статус = Перечисления.ОДМ_СтатусыЗадач.Подготовлен;
		Задача.Метод = "Отправить";
		
		Данные = Новый Структура;	
		Инициатор = Новый Структура;
		Получатель = Новый Структура;
		
		Данные.Вставить("TaskID", Строка(ИдентификаторЗадачи)); 
		
		БазаОтправитель = Новый Структура;
		БазаОтправитель.Вставить("server", ВебСервер); 
		БазаОтправитель.Вставить("name", ТекущаяПубликация);     
		БазаОтправитель.Вставить("id", "");
		Инициатор.Вставить("base", БазаОтправитель);
		Инициатор.Вставить("user", Строка(Пользователи.ТекущийПользователь()));
		Инициатор.Вставить("idSettings", "");  
		Данные.Вставить("initiator", Инициатор);
		
		БазаПолучатель = Новый Структура;
		БазаПолучатель.Вставить("server", ВебСервер); 
		БазаПолучатель.Вставить("name", МестоИспользования);     
		БазаПолучатель.Вставить("id", "");
        Получатель.Вставить("base", БазаПолучатель);
		Получатель.Вставить("user", Строка(Пользователи.ТекущийПользователь()));
		Получатель.Вставить("idSettings", "");  
		Данные.Вставить("recipient", Получатель);
		
		Данные.Вставить("action", "object");
		
		ДанныеДляЗаписи = Новый Структура;
		
		ГУИДИсточника = ПолучитьГУИДИзРегистра(СоответствиеОбъектов, Источник.Ссылка, МестоИспользования);
		Если ГУИДИсточника = Неопределено Тогда
			ГУИДИсточника = Строка(Источник.Ссылка.УникальныйИдентификатор());
		КонецЕсли;
		ДанныеДляЗаписи.Вставить("ГУИД", ГУИДИсточника);
		
		ДанныеДляЗаписи.Вставить("Наименование", Источник.Наименование);
		ДанныеДляЗаписи.Вставить("Код", Источник.Код);
		ДанныеДляЗаписи.Вставить("Тип", ТипИсточника);
		
		Если ЗначениеЗаполнено(Источник.Ссылка.Родитель) Тогда
			Родитель = Источник.Ссылка.Родитель;
			
			ГУИДРодителя = ПолучитьГУИДИзРегистра(СоответствиеОбъектов, Родитель, МестоИспользования);
			Если ГУИДРодителя = Неопределено Тогда
				ГУИДРодителя = Строка(Родитель.УникальныйИдентификатор());
			КонецЕсли;
			ДанныеДляЗаписи.Вставить("РодительГУИД", ГУИДРодителя);
			
			ДанныеДляЗаписи.Вставить("РодительНаименование", Родитель.Наименование);
			ДанныеДляЗаписи.Вставить("РодительКод", Родитель.Код);
			ДанныеДляЗаписи.Вставить("РодительТип", Родитель.Метаданные().Имя);
			ДанныеДляЗаписи.Вставить("РодительЭтоГруппа", Родитель.ЭтоГруппа);
		КонецЕсли;
		
		Для Каждого Реквизит Из Источник.Метаданные().Реквизиты Цикл
			ДанныеДляЗаписи.Вставить(Реквизит.Имя, СокрЛП(Источник[Реквизит.Имя]));
		КонецЦикла;
		Данные.Вставить("data", ДанныеДляЗаписи);

		Задача.Параметры = Новый ХранилищеЗначения(Данные);
		
	КонецЦикла;
	
	Если НаборЗадач.Количество() > 0 Тогда
		НаборЗадач.Записать();
	КонецЕсли;
	
КонецПроцедуры

// Процедура: ОтправитьДанныеВБазыПолучателей
// Назначение: Отправляет данные в базы получателей на основе задач из регистра.
Процедура ОтправитьДанныеВБазыПолучателей() Экспорт

    НаборЗадач = РегистрыСведений.ОДМ_ЗадачиОбмена.СоздатьНаборЗаписей();
    НаборЗадач.Отбор.Метод.Установить("Отправить");
    НаборЗадач.Прочитать();

    Если НаборЗадач.Количество() = 0 Тогда
        Возврат;
    КонецЕсли;

    СоответствиеБазПолучателей = Новый Соответствие;
	
	//Для Каждого Задача Из НаборЗадач Цикл
	//	Задача.Статус = Перечисления.ОДМ_СтатусыЗадач.Выполняется;
	//	Задача.МоментСтарта = ТекущаяДата();
	//	Задача.Попытка = ?(НЕ ЗначениеЗаполнено(Задача.Попытка), 1, Задача.Попытка + 1);

	//КонецЦикла;
	//НаборЗадач.Записать();

	Для Каждого Задача Из НаборЗадач Цикл
		
		Если Задача.Статус <> Перечисления.ОДМ_СтатусыЗадач.Подготовлен Тогда
			 Продолжить;
		КонецЕсли;
		 
        Параметры = Задача.Параметры.Получить();
        БазаПолучатель = Параметры.recipient.base.name;
		ВебСервер = Параметры.recipient.base.server;
		
        Если СоответствиеБазПолучателей.Получить(БазаПолучатель) = Неопределено Тогда
            СоответствиеБазПолучателей.Вставить(БазаПолучатель, Новый Массив);
        КонецЕсли;

        МассивЗадач = СоответствиеБазПолучателей[БазаПолучатель];
        МассивЗадач.Добавить(Параметры);
	КонецЦикла;

    Для Каждого ЭлементСоответствия Из СоответствиеБазПолучателей Цикл
        БазаПолучатель = ЭлементСоответствия.Ключ;
        МассивЗадач = ЭлементСоответствия.Значение;

		Для Каждого Задача Из НаборЗадач Цикл
			ВнешнийИнтерфейс = ОДМ_ОбменДанными.Конструктор_ВнешнийИнтерфейс();
			ВнешнийИнтерфейс.АдресСервера = ВебСервер;
			ВнешнийИнтерфейс.ИмяБазы = БазаПолучатель;
		
			Если ВнешнийИнтерфейс.ОтправитьДанныеНаСервер(МассивЗадач) Тогда
            	Если Задача.Параметры.recipient.base = БазаПолучатель Тогда
            		Задача.Статус = Перечисления.ОДМ_СтатусыЗадач.Отправлен;
					Задача.МоментФиниша = ТекущаяДата();
            	КонецЕсли;
			КонецЕсли;
		КонецЦикла;
    КонецЦикла;

    НаборЗадач.Записать();

КонецПроцедуры

