Функция ПрочитатьЗначениеСвойства(Знач ОписаниеЗначения, КэшЗначений = Неопределено, ВызыватьИсключениеПустогоСсылочногоТипа = Ложь)
	
	РезультатМетода = Неопределено;
	
	Если КэшЗначений = Неопределено Тогда
		КэшЗначений = Новый Соответствие;
	КонецЕсли;
	
	РезультатМетода = КэшЗначений.Получить(ОписаниеЗначения);
	Если НЕ РезультатМетода = Неопределено Тогда
		Возврат РезультатМетода;
	КонецЕсли;
	
	РезультатМетода = ОписаниеЗначения;
	
	ТипОписания = ТипЗнч(ОписаниеЗначения);
	Если ЛОЖЬ
		ИЛИ ТипОписания = Тип("Неопределено")
		ИЛИ ТипОписания = Тип("Дата")
		ИЛИ ТипОписания = Тип("Булево")
		Или ТипОписания = Тип("Строка")
		Или ТипОписания = Тип("Число")
		Тогда
		Возврат РезультатМетода;
		
	ИначеЕсли ОДМ_ОбщегоНазначения.ЭтоСсылка(ТипОписания) Тогда
		КэшЗначений.Вставить(ОписаниеЗначения, РезультатМетода);
		Возврат РезультатМетода;
		
	ИначеЕсли ЛОЖЬ
		Или НЕ ТипОписания = Тип("Структура")
		Или НЕ ОписаниеЗначения.Свойство("Тип")
		Или НЕ ОписаниеЗначения.Свойство("Значение")
		Тогда
		ТекстСообщения = НСтр("ru='Невозможно обработать значение свойства: %1';
		|en='The property value cannot be processed: %1'");
		ВызватьИсключение СтрШаблон(ТекстСообщения, СериализоватьJSON(ОписаниеЗначения));
	КонецЕсли;
	
	Попытка
		ТипЗначения = Тип(ОписаниеЗначения.Тип);
		Если ТипЗначения = ТипЗнч(ОписаниеЗначения.Значение) Тогда
			Возврат ОписаниеЗначения.Значение;
		КонецЕсли;
		
		Если ТипЗначения = Тип("Null") Тогда
			Возврат Null;
		КонецЕсли;
		
		// Специальная обработка для планов счетов: поиск по коду вместо GUID
		Если ОписаниеЗначения.Тип = "ПланСчетовСсылка.Хозрасчетный" Тогда
			
			КодСчета = Строка(ОписаниеЗначения.Значение);
			Если ПустаяСтрока(КодСчета) Тогда
				РезультатМетода = ПланыСчетов.Хозрасчетный.ПустаяСсылка();
			Иначе
				РезультатМетода = ПланыСчетов.Хозрасчетный.НайтиПоКоду(КодСчета);
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(РезультатМетода) Тогда
				РезультатМетода = ПланыСчетов.Хозрасчетный.ПустаяСсылка();
			КонецЕсли;
		//Поиск по наименованию, пока по типу
		ИначеЕсли ОписаниеЗначения.Тип = "СправочникСсылка.ВидыНалоговИПлатежейВБюджет" ИЛИ ОписаниеЗначения.Тип = "СправочникСсылка.ПрочиеДоходыИРасходы" 
																						ИЛИ ОписаниеЗначения.Тип = "СправочникСсылка.Пользователи" Тогда
			
			ИмяСправочника = СтрРазделить(ОписаниеЗначения.Тип, ".")[1];
			
			НаименованиеЗначение = Строка(ОписаниеЗначения.Значение);
			Если ПустаяСтрока(НаименованиеЗначение) Тогда
				РезультатМетода = Справочники[ИмяСправочника].ПустаяСсылка();
			Иначе
				РезультатМетода = Справочники[ИмяСправочника].НайтиПоНаименованию(НаименованиеЗначение);
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(РезультатМетода) Тогда
				РезультатМетода = Справочники[ИмяСправочника].ПустаяСсылка();
			КонецЕсли;
			
		Иначе
			
			Если ОДМ_ОбщегоНазначения.ЭтоСсылка(ТипЗначения) И НЕ ЗначениеЗаполнено(ОписаниеЗначения.Значение) Тогда
				ОписаниеЗначения.Значение = "00000000-0000-0000-0000-000000000000";
			КонецЕсли;
			
			ИмяПредопределенныхДанных = "";
			Если Истина
				И   ОписаниеЗначения.Свойство("ИмяПредопределенныхДанных", ИмяПредопределенныхДанных)
				И   НЕ ПустаяСтрока(ИмяПредопределенныхДанных)
				Тогда
				МенеджерОбъекта = ОДМ_ОбщегоНазначения.МенеджерОбъектаПоСсылке(Новый(ТипЗначения));
				РезультатМетода = МенеджерОбъекта[ИмяПредопределенныхДанных];
			Иначе
				РезультатМетода = XMLЗначение(ТипЗначения, ОписаниеЗначения.Значение);
				Если Истина
					И   ВызыватьИсключениеПустогоСсылочногоТипа = Истина
					И   ОДМ_ОбщегоНазначения.ЗначениеСсылочногоТипа(РезультатМетода)
					И   ОДМ_ОбщегоНазначения.СсылкаСуществует(РезультатМетода)
					Тогда
					ТекстСообщения = НСтр("ru='В базе данных отсутствует объект: %1';
					|en='The object is missing in the database: %1'");
					ВызватьИсключение СтрШаблон(ТекстСообщения, СериализоватьJSON(ОписаниеЗначения));
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
	Исключение
		ТекстСообщения = НСтр("ru='Невозможно обработать значение свойства: %1';
		|en='The property value cannot be processed: %1'");
		ВызватьИсключение СтрШаблон(ТекстСообщения, СериализоватьJSON(ОписаниеЗначения));
	КонецПопытки;
	
	КэшЗначений.Вставить(ОписаниеЗначения, РезультатМетода);
	
	Возврат РезультатМетода;
	
КонецФункции

// TODO: поглядеть как оно будет работать в модуле ПовтИсп. если плохо, тогда через кэшСоответствий реализовать
//       ибо на больших таблицах работа с метаданными и типами будет долгой
Функция ПреобразованиеJSON(Свойство, Значение, ДополнительныеПараметры, Отказ) Экспорт
	
	РезультатМетода = Значение;
	ТипЗначения = ТипЗнч(Значение);
	
	Если Ложь Тогда
		//заглушка
		
	ИначеЕсли ТипЗначения = Тип("УникальныйИдентификатор") Тогда
		РезультатМетода = УстановитьСвойство("УникальныйИдентификатор", Строка(Значение));
		
	ИначеЕсли ТипЗначения = Тип("ТаблицаЗначений") Тогда
		РезультатМетода = ОбщегоНазначения.ТаблицаЗначенийВМассив(Значение);
		
	ИначеЕсли Значение = Null Тогда
		РезультатМетода = УстановитьСвойство("Null", "<Null>");
		
	ИначеЕсли ТипЗначения = Тип("Тип") Тогда
		ОбъектМетаданных = Метаданные.НайтиПоТипу(Значение);
		Если ОбъектМетаданных = Неопределено Тогда
			РезультатМетода = Строка(Значение)
		Иначе
			ПредставлениеТипа = "<ВРАЗРАБОТКЕ>";
			Если Метаданные.Справочники.Содержит(Метаданные.НайтиПоТипу(Значение)) Тогда
				ПредставлениеТипа = "Справочник";
			ИначеЕсли Метаданные.Документы.Содержит(Метаданные.НайтиПоТипу(Значение)) Тогда
				ПредставлениеТипа = "Документ";
			ИначеЕсли Метаданные.ПланыСчетов.Содержит(Метаданные.НайтиПоТипу(Значение)) Тогда
				ПредставлениеТипа = "ПланСчетов";
			ИначеЕсли Метаданные.БизнесПроцессы.Содержит(Метаданные.НайтиПоТипу(Значение)) Тогда
				ПредставлениеТипа = "БизнесПроцесс";
			ИначеЕсли Метаданные.Задачи.Содержит(Метаданные.НайтиПоТипу(Значение)) Тогда
				ПредставлениеТипа = "Задача";
			КонецЕсли;
			
			//"e1cib/data/Документ.ПриобретениеТоваровУслуг"
			ШаблонПредставления = "e1cib/data/%1.%2";
			РезультатМетода = СтрШаблон(ШаблонПредставления, ПредставлениеТипа, ОбъектМетаданных.Имя);
			
		КонецЕсли;
		
	ИначеЕсли ОДМ_ОбщегоНазначения.ЭтоСсылка(ТипЗначения) Тогда
		РезультатМетода = XMLСтрока(Значение);
		
	Иначе
		РезультатМетода = УстановитьСвойство(Строка(ТипЗначения), Строка(Значение));
	КонецЕсли;
	
	Возврат РезультатМетода;
	
КонецФункции

Функция ВосстановлениеJSON(Свойство, Значение, ДополнительныеПараметры) Экспорт
	
	//FIXME: -> для преобразования примитивных типов - переделать под общую конструкцию
	Попытка
		_Значение = XMLЗначение(Тип("Дата"), Строка(Значение));
		Возврат _Значение;
	Исключение
		ТекстОшибки = ОписаниеОшибки(); //для отладки
	КонецПопытки;
	
	Попытка
		Если Значение = "0" или Значение = "1" или Значение = 0 или Значение = 1 Тогда
			ВызватьИсключение "XMLЗначение(Тип(""Булево""), Строка(1)) возвращает истину"; //FIXME: подумать и переписать
		КонецЕсли;
		Если ТипЗнч(Значение) = Тип("Булево") Тогда
			Возврат Значение;
		КонецЕсли;
		
		_Значение = XMLЗначение(Тип("Булево"), Строка(Значение));
		Возврат _Значение;
	Исключение
		ТекстОшибки = ОписаниеОшибки(); //для отладки
	КонецПопытки;
	//<-
	
	Если ТипЗнч(Значение) = Тип("Структура")
	И Значение.Свойство("Тип")
	И Значение.Свойство("Значение")
	ТОГДА
	
		Значение = ПрочитатьЗначениеСвойства(Значение);
	
	КонецЕсли;
	
	Возврат Значение;
	
КонецФункции

Функция ОписаниеТипаПоМассивуТипов(Знач МассивТипов) Экспорт
	
	КвСтроки = Новый КвалификаторыСтроки(250);
