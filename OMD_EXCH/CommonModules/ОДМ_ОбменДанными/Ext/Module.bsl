Функция Конструктор_ВнешнийИнтерфейс(Знач ИмяИнтерфейса = "ОДМ_xchg") Экспорт
	
	Попытка
		ВнешнийИнтерфейс = Обработки[ИмяИнтерфейса].Создать();
		ВнешнийИнтерфейс.Инициализация();
	Исключение
		//TODO: подумать а надо ли...
		ВнешнийИнтерфейс = Новый Структура;
		
		ВнешнийИнтерфейс.Вставить("Соединение",								Неопределено);
		ВнешнийИнтерфейс.Вставить("АдресСервера",							"");
		ВнешнийИнтерфейс.Вставить("Порт",									80);
		ВнешнийИнтерфейс.Вставить("ИмяБазы",									"");
		ВнешнийИнтерфейс.Вставить("Логин",									"");
		ВнешнийИнтерфейс.Вставить("Пароль",									"");
		ВнешнийИнтерфейс.Вставить("Токен",									"");
		ВнешнийИнтерфейс.Вставить("ИспользоватьАутентификациюОС",			Ложь);
		ВнешнийИнтерфейс.Вставить("ЗащищенноеСоединение",					Неопределено);
		ВнешнийИнтерфейс.Вставить("Заголовки",								Конструктор_Заголовки());
	КонецПопытки;
	
	Возврат ВнешнийИнтерфейс;
	
КонецФункции

// Конструктор структуры для параметра Запрос, который будет отправляться во внешнюю базу
//
// Возвращаемое значение:
//   Структура:
//     * ТекстЗапроса				- Строка							- текст запроса в нотации внешней базы
//     * Параметры					- Соответствие из КлючИЗначение		- параметры запроса
//       * Ключ							- Строка		- имя параметра
//       * Значение						- Произвольный	- сериализуемое значение
//     * ТаблицыРезультата			- Соответствие из КлючИЗначение		- пустое, если запрос не пакетный
//       * Ключ							- Строка	- имя таблицы
//       * Значение						- Число		- номер результата
//     * ПередВыполнениемЗапроса	- Строка							- выполнить блок кода перед выполнением запроса (TODO, возможно не будет)
//     * ПослеПолученияРезультатов	- Строка							- выполнить блок кода после получания результатов (TODO, возможно не будет)
//
Функция Конструктор_ОписаниеЗапросаВнешнейБазы() Экспорт
	
	ОписаниеЗапроса = Новый Структура;
	
	ОписаниеЗапроса.Вставить("ТекстЗапроса",				"");
	ОписаниеЗапроса.Вставить("Параметры",					Новый Соответствие);
	ОписаниеЗапроса.Вставить("ТаблицыРезультата",			Новый Структура); 		//ключ: номер результата, значение: имя / если не пакетный запрос, тогда пустое
	ОписаниеЗапроса.Вставить("ПередВыполнениемЗапроса",		"");
	ОписаниеЗапроса.Вставить("ПослеПолученияРезультатов",	"");
	
	Возврат ОписаниеЗапроса;
	
КонецФункции

