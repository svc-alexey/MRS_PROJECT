КонецФункции

// Рекурсивно ищет значение, которое не может быть сериализовано в JSON.
//
// Входные параметры:
//   Значение - Произвольный - Объект для проверки.
//   ПутьОшибки - Строка - Переменная для возврата пути к ошибочному значению.
//
// Возвращаемое значение:
//   Произвольный - Ошибочное значение или Неопределено, если ошибок нет
//
Функция ЗаписатьJSON_НайтиПутьОшибочногоЗначения(Знач Значение, ПутьОшибки)
	
	ТипЗначения = ТипЗнч(Значение);
	
	Если ТипЗначения = Тип("Соответствие") или ТипЗначения = Тип("Структура") Тогда
		
		Для Каждого КлючИЗначение Из Значение Цикл
			
			Если ТипЗначения = Тип("Соответствие") Тогда 
				ПутьОшибки = Неопределено;
				ЗначениеОшибки = ЗаписатьJSON_НайтиПутьОшибочногоЗначения(КлючИЗначение.Ключ, ПутьОшибки);
				Если ЗначениеОшибки <> Неопределено Тогда 
					ПутьОшибки = СтрШаблон("%1 (ключ).%2", КлючИЗначение.Ключ, ПутьОшибки);
					Возврат ЗначениеОшибки; 
				КонецЕсли;
			КонецЕсли;
			
			ПутьОшибки = Неопределено;
			ЗначениеОшибки = ЗаписатьJSON_НайтиПутьОшибочногоЗначения(КлючИЗначение.Значение, ПутьОшибки);
			Если ЗначениеОшибки <> Неопределено Тогда 
				ПутьОшибки = СтрШаблон("%1%2",
									КлючИЗначение.Ключ,
									?(ПутьОшибки<>Неопределено, ?(Лев(ПутьОшибки, 1) <> "[", ".", "") + ПутьОшибки, "")
				);
				Возврат ЗначениеОшибки;
			КонецЕсли;
		КонецЦикла;
		
		Возврат Неопределено;
		
	ИначеЕсли ТипЗначения = Тип("Массив") Тогда
		
		НомерСтроки = 0;
		Для Каждого ЭлементМассива Из Значение Цикл
			НомерСтроки = НомерСтроки + 1;
			ПутьОшибки = Неопределено;
			ЗначениеОшибки = ЗаписатьJSON_НайтиПутьОшибочногоЗначения(ЭлементМассива, ПутьОшибки);
			Если ЗначениеОшибки <> Неопределено Тогда 
				ПутьОшибки = СтрШаблон("[%1]%2",
									Формат(НомерСтроки, "ЧГ="),
									?(ПутьОшибки <> Неопределено, ?(Лев(ПутьОшибки, 1) <> "[", ".", "") + ПутьОшибки, "")
				);
				Возврат ЗначениеОшибки;
			КонецЕсли;
		КонецЦикла;
		Возврат Неопределено;
		
	КонецЕсли;
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	
	Попытка
		ЗаписатьJSON(ЗаписьJSON, Значение, , "ПреобразованиеJSON", Вычислить("ОДМ_ОбменДанными"));
	Исключение 
		Возврат Значение;
	КонецПопытки;
	
	Возврат Неопределено;
	
КонецФункции 

Процедура УстановитьМоментыДействий(Запись)
	
	#Если Сервер и Не Сервер Тогда
		Запись = РегистрыСведений.ОДМ_ЗадачиОбмена.СоздатьМенеджерЗаписи();
	#КонецЕсли
	
	Если Запись.МоментСтарта = '0001-01-01' Тогда
		Запись.МоментСтарта = ТекущаяДатаСеанса();
	КонецЕсли;
	
	Если Запись.Попытка >= 5 Тогда
		Запись.Статус = Перечисления.ОДМ_СтатусыЗадач.Ошибка;
	КонецЕсли;
	
	Если Запись.МоментФиниша = '0001-01-01' и Перечисления.ОДМ_СтатусыЗадач.ЭтоЗавершенныйСтатус(Запись.Статус) Тогда
		Запись.МоментФиниша = ТекущаяДатаСеанса();
	КонецЕсли;
	
КонецПроцедуры

