// Устарела. Следует использовать РегистрыСведений.ОДМ_ЗадачиОбмена.ЗаписатьДанныеЗадач
// Создает задачи обмена на основе входящих данных.
// Входные параметры:
//   МассивЗадач - Массив - Массив задач, которые нужно добавить в регистр.
Функция СоздатьЗадачуОбменаВходящиеДанные(МассивЗадач) Экспорт
	
	//TODO: в регистр пишем через обертку РегистрыСведений.ОДМ_ЗадачиОбмена.ЗаписатьДанныеЗадач(ОписаниеЗадачи);
	
	НаборЗадач = РегистрыСведений.ОДМ_ЗадачиОбмена.СоздатьНаборЗаписей();
	
	Для Каждого Задача Из МассивЗадач Цикл
		НоваяЗадача = НаборЗадач.Добавить();
		НоваяЗадача.Идентификатор = Новый УникальныйИдентификатор(Задача.TaskID);
		НоваяЗадача.ДатаСоздания = ТекущаяДата();
		НоваяЗадача.Инициатор = Задача.initiator.user;
		НоваяЗадача.Статус = Перечисления.ОДМ_СтатусыЗадач.Подготовлен;
		НоваяЗадача.Метод = "Записать";
		НоваяЗадача.Параметры = Новый ХранилищеЗначения(Задача);
	КонецЦикла;
	
	Если НаборЗадач.Количество() > 0 Тогда
		НаборЗадач.Записать();
	КонецЕсли;
	
