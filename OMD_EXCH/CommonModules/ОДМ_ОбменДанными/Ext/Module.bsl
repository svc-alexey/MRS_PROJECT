Процедура ЗаписатьСоответствиеОбъектов(Элемент, GUIDЭлемента, ТипИсточника, БазаОтправитель, Задача)
    
    Если Метаданные.РегистрыСведений.Найти("СоответствиеОбъектовТекущейИВнешнихИБ") <> Неопределено Тогда
       
        ИмяРегистра = "СоответствиеОбъектовТекущейИВнешнихИБ";
        ИмяИзмеренияБазы = "ИспользуемаяИБ";
        ИмяПоляГУИД = "ОбъектВнешнейИБ";
        ИмяПоляОбъекта = "ОбъектТекущейИБ";
        ИмяПоляНастройки = "НастройкиСоответствия";
    ИначеЕсли Метаданные.РегистрыСведений.Найти("СоответствияОбъектовИнформационныхБаз") <> Неопределено Тогда
        
        ИмяРегистра = "СоответствияОбъектовИнформационныхБаз";
        ИмяИзмеренияБазы = "УзелИнформационнойБазы";
        ИмяПоляГУИД = "УникальныйИдентификаторПриемника";
        ИмяПоляОбъекта = "УникальныйИдентификаторИсточника";
		ИмяПоляОбъектаГУИДСтрокой = "УникальныйИдентификаторИсточникаСтрокой";
        ИмяПоляТипаПриемника = "ТипПриемника";
        ИмяПоляТипаИсточника = "ТипИсточника";
    Иначе
        // Если ни одна из конфигураций не найдена, завершаем выполнение
        Возврат;
    КонецЕсли;

    НоваяЗапись = РегистрыСведений[ИмяРегистра].СоздатьМенеджерЗаписи();
    
    Если ИмяРегистра = "СоответствиеОбъектовТекущейИВнешнихИБ" Тогда
		
		НастройкиСоответствия = Справочники.СоответствиеВнешнимИБ.НайтиПоРеквизиту("ИмяОбъектаМетаданных", ТипИсточника,,БазаОтправитель.ТипБД);
		
		НоваяЗапись[ИмяПоляОбъекта] = Элемент.Ссылка;
        НоваяЗапись[ИмяПоляГУИД] = GUIDЭлемента;
        НоваяЗапись[ИмяИзмеренияБазы] = БазаОтправитель;
        НоваяЗапись[ИмяПоляНастройки] = НастройкиСоответствия;
	Иначе
        НоваяЗапись[ИмяПоляОбъекта] = Элемент.Ссылка;
		НоваяЗапись[ИмяПоляОбъектаГУИДСтрокой] = Строка(Элемент.Ссылка.УникальныйИдентификатор());
		НоваяЗапись[ИмяПоляГУИД] = GUIDЭлемента;
        НоваяЗапись[ИмяПоляТипаПриемника] = "СправочникСсылка." + ТипИсточника;
        НоваяЗапись[ИмяПоляТипаИсточника] = "СправочникСсылка." + ТипИсточника;
        НоваяЗапись[ИмяИзмеренияБазы] = БазаОтправитель;
    КонецЕсли;

    НоваяЗапись.Записать();

КонецПроцедуры

// Функция для обработки реквизитов (перечисления, ссылки и т.д.)
Функция ОбработатьРеквизит(Элемент, ИмяРеквизита, Знач Значение)
	
	МетаданныеРеквизита = Элемент.Метаданные().Реквизиты.Найти(ИмяРеквизита);
	//Если МетаданныеРеквизита = Неопределено Тогда
	//    Возврат Неопределено;
	//КонецЕсли;

	ТипРеквизита = ТипЗнч(Элемент[ИмяРеквизита]);
	
    Если Перечисления.ТипВсеСсылки().СодержитТип(ТипРеквизита) Тогда
        ТипПеречисления = Элемент[ИмяРеквизита].Метаданные().Имя;
		Попытка
			
			Для Каждого ЗначениеПеречисления ИЗ Перечисления[ТипПеречисления] Цикл
				Если Строка(ЗначениеПеречисления) = Значение Тогда
					 Возврат ЗначениеПеречисления;
				КонецЕсли;
			КонецЦикла;
		
			//Возврат Перечисления[Элемент[ИмяРеквизита].Метаданные().Имя][Значение];
        Исключение
            Возврат Неопределено;
        КонецПопытки;
	ИначеЕсли Справочники.ТипВсеСсылки().СодержитТип(ТипРеквизита) 
		ИЛИ Документы.ТипВсеСсылки().СодержитТип(ТипРеквизита) Тогда
        
        Попытка
            Возврат Справочники[МетаданныеРеквизита.ИмяСправочника].НайтиПоНаименованию(Значение);
        Исключение
            Возврат Неопределено;
        КонецПопытки;
    Иначе
        
        Возврат Значение;
		
	КонецЕсли;
	
КонецФункции

