Функция УстановитьСвойство(Знач Тип, Знач Значение) Экспорт
	
	РезультатМетода = Новый Соответствие;
	
	РезультатМетода["Тип"]							= Тип;
	РезультатМетода["Значение"]						= Значение;
	
	Если ИСТИНА
	И ОДМ_ОбщегоНазначения.ЗначениеСсылочногоТипа(Значение)
	ТОГДА
		Попытка
			ИмяСтрокой = ОДМ_ОбщегоНазначения.ИмяТаблицыПоСсылке(Значение);
			Менеджер = ОДМ_ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ИмяСтрокой);
			ИмяПредопределенныхДанных = Менеджер.ПолучитьИмяПредопределенного(Значение);
			Если Не ПустаяСтрока(ИмяПредопределенныхДанных) Тогда
				РезультатМетода["ИмяПредопределенныхДанных"] = ИмяПредопределенныхДанных;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Возврат РезультатМетода;
	
