// Процедура: СоздатьЭлементыСправочникаИзЗадач
// Назначение: Создает элементы справочника на основе данных из задач обмена.
Процедура СоздатьЭлементыСправочникаИзЗадач() Экспорт

    НаборЗадач = РегистрыСведений.ОДМ_ЗадачиОбмена.СоздатьНаборЗаписей();
    НаборЗадач.Отбор.Метод.Установить("Записать");
    НаборЗадач.Прочитать();

    Если НаборЗадач.Количество() = 0 Тогда
        Возврат;
    КонецЕсли;

    Для Каждого Задача Из НаборЗадач Цикл
        
        Если Задача.Статус <> Перечисления.ОДМ_СтатусыЗадач.Подготовлен Тогда
            Продолжить;
        КонецЕсли;
        
        Параметры = Задача.Параметры.Получить();
        Данные = Параметры.data;
        БазаОтправительСтрокой = Параметры.initiator.base.name;
		БазаОтправитель = ВернутьДополнительнуюКонстанту("ОДМ_DataExchange_Base_" + БазаОтправительСтрокой);

        ТипИсточника = Данные.Тип;

        Если Данные.Свойство("РодительГУИД") Тогда
            Если НЕ Данные.РодительЭтоГруппа Тогда
                РодительГУИД = ПолучитьGUIDИзДанных(Данные.РодительГУИД);
                РодительНаименование = Данные.РодительНаименование;
                РодительКод = Данные.РодительКод;
                РодительТип = Данные.РодительТип;

                Родитель = НайтиЭлементПоГУИД(РодительТип, РодительГУИД);
                Если ЭлементНеНайден(Родитель) Тогда
                    Родитель = НайтиЭлементПоКоду(РодительТип, РодительКод);
                КонецЕсли;
                Если НЕ ЗначениеЗаполнено(Родитель) Тогда
                    Родитель = НайтиЭлементПоНаименованию(РодительТип, РодительНаименование);
                КонецЕсли;
                Если НЕ ЗначениеЗаполнено(Родитель) Тогда
                    Родитель = Справочники[РодительТип].СоздатьЭлемент();
                    Родитель.Наименование = РодительНаименование;
                    Родитель.Код = РодительКод;
                    ПодменнаяСсылка = Справочники[РодительТип].ПолучитьСсылку(РодительГУИД);
                    Родитель.УстановитьСсылкуНового(ПодменнаяСсылка);
                    Родитель.ОбменДанными.Загрузка = Истина;
                    Родитель.Записать();
                    УстановитьGUIDДляЭлемента(Родитель, РодительГУИД);
                КонецЕсли;

                ЗаписатьСоответствиеОбъектов(Родитель, РодительГУИД, РодительТип, БазаОтправитель, Задача);

            Иначе
                Родитель = НайтиЭлементПоНаименованию(РодительТип, РодительНаименование);
                Если НЕ ЗначениеЗаполнено(Родитель) Тогда
                    Родитель = Справочники[РодительТип].СоздатьЭлемент();
                    Родитель.Наименование = РодительНаименование;
                    Родитель.ЭтоГруппа = ИСТИНА;
                    ПодменнаяСсылка = Справочники[РодительТип].ПолучитьСсылку(РодительГУИД);
                    Родитель.УстановитьСсылкуНового(ПодменнаяСсылка);
                    Родитель.ОбменДанными.Загрузка = Истина;
                    Родитель.Записать();
                КонецЕсли;

                ЗаписатьСоответствиеОбъектов(Родитель, РодительГУИД, РодительТип, БазаОтправитель, Задача);

            КонецЕсли;
        КонецЕсли;

        GUIDЭлемента = ПолучитьGUIDИзДанных(Данные.ГУИД);
        Элемент = НайтиЭлементПоГУИД(ТипИсточника, GUIDЭлемента);
        Если ЭлементНеНайден(Элемент) Тогда
            Элемент = НайтиЭлементПоКоду(ТипИсточника, Данные.Код);
        КонецЕсли;
        Если НЕ ЗначениеЗаполнено(Элемент) Тогда
            Элемент = НайтиЭлементПоНаименованию(ТипИсточника, Данные.Наименование);
        КонецЕсли;

        Если НЕ ЗначениеЗаполнено(Элемент) Тогда
            Элемент = Справочники[ТипИсточника].СоздатьЭлемент();
            Элемент.Наименование = Данные.Наименование;
            Элемент.Код = Данные.Код;

            Если Данные.Свойство("РодительГУИД") Тогда
                Элемент.Родитель = Родитель;
            КонецЕсли;

            Для Каждого Реквизит Из Данные Цикл
                Если Элемент.Метаданные().Реквизиты.Найти(Реквизит.Ключ) <> Неопределено Тогда
                    Элемент[Реквизит.Ключ] = ОбработатьРеквизит(Элемент, Реквизит.Ключ, Реквизит.Значение);
                КонецЕсли;
            КонецЦикла;
            ПодменнаяСсылка = Справочники[ТипИсточника].ПолучитьСсылку(GUIDЭлемента);
            Элемент.УстановитьСсылкуНового(ПодменнаяСсылка);
            Элемент.ОбменДанными.Загрузка = Истина;
            Элемент.Записать();

            ЗаписатьСоответствиеОбъектов(Элемент, GUIDЭлемента, ТипИсточника, БазаОтправитель, Задача);
        Иначе
            Элемент = Элемент.ПолучитьОбъект();
            Элемент.Наименование = Данные.Наименование;
            Элемент.Код = Данные.Код;

            Если Данные.Свойство("РодительГУИД") Тогда
                Элемент.Родитель = Родитель;
            КонецЕсли;

            Для Каждого Реквизит Из Данные Цикл
                Если Элемент.Метаданные().Реквизиты.Найти(Реквизит.Ключ) <> Неопределено Тогда
                    Элемент[Реквизит.Ключ] = ОбработатьРеквизит(Элемент, Реквизит.Ключ, Реквизит.Значение);
                КонецЕсли;
            КонецЦикла;
            Элемент.ОбменДанными.Загрузка = Истина;
            Элемент.Записать();

            ЗаписатьСоответствиеОбъектов(Элемент, GUIDЭлемента, ТипИсточника, БазаОтправитель, Задача);
        КонецЕсли;

        Задача.Статус = Перечисления.ОДМ_СтатусыЗадач.Выполнен;    
        Задача.МоментФиниша = ТекущаяДата();
    КонецЦикла;

    НаборЗадач.Записать();

КонецПроцедуры

