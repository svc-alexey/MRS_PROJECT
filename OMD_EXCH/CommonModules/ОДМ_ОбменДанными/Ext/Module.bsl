// Функция для получения соответствия "МестоИспользования - ИнформационнаяБаза"
Функция ПолучитьСоответствиеБазИспользования(МассивБазДанных)
    СоответствиеБаз = Новый Соответствие;
    
    Для Каждого МестоИспользования Из МассивБазДанных Цикл
        БазаИспользования = ВернутьДополнительнуюКонстанту("ОДМ_DataExchange_Base_" + МестоИспользования);
        СоответствиеБаз.Вставить(МестоИспользования, БазаИспользования);
    КонецЦикла;
    
    Возврат СоответствиеБаз;
КонецФункции

// Функция для получения ГУИД из регистра
Функция ПолучитьГУИДИзРегистра(СоответствиеОбъектов, Ссылка, МестоИспользования)
	
	Если СоответствиеОбъектов.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
    Ключ = Строка(Ссылка) + "_" + МестоИспользования;
		
    Если СоответствиеОбъектов.Свойство(Ключ) Тогда
        Возврат СоответствиеОбъектов[Ключ];
    Иначе
        Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция для получения данных из регистра СоответствиеОбъектовТекущейИВнешнихИБ
Функция ПолучитьСоответствиеОбъектовПоБазам(СоответствиеБаз,Источник)
	
	    СоответствиеОбъектов = Новый Соответствие;
    
    // Проверяем, какая конфигурация используется
    Если Метаданные.РегистрыСведений.Найти("СоответствиеОбъектовТекущейИВнешнихИБ") <> Неопределено Тогда
        // Конфигурация "Управление холдингом"
        ИмяРегистра = "СоответствиеОбъектовТекущейИВнешнихИБ";
        ИмяИзмеренияБазы = "ИспользуемаяИБ";
        ИмяПоляГУИД = "ГУИДВнешнейИБ";
        ИмяПоляОбъекта = "ОбъектТекущейИБ";
    ИначеЕсли Метаданные.РегистрыСведений.Найти("СоответствияОбъектовИнформационныхБаз") <> Неопределено Тогда
        // Конфигурация "1С:Бухгалтерия предприятия КОРП"
        ИмяРегистра = "СоответствияОбъектовИнформационныхБаз";
        ИмяИзмеренияБазы = "УзелИнформационнойБазы";
        ИмяПоляГУИД = "УникальныйИдентификаторПриемника";
        ИмяПоляОбъекта = "УникальныйИдентификаторИсточника";
    Иначе
        // Если ни одна из конфигураций не найдена, возвращаем пустое соответствие
        Возврат СоответствиеОбъектов;
    КонецЕсли;
	
	Для Каждого ЭлементСоответствия Из СоответствиеБаз Цикл
        МестоИспользования = ЭлементСоответствия.Ключ;
        БазаИспользования = ЭлементСоответствия.Значение;
        
        НаборЗаписей = РегистрыСведений[ИмяРегистра].СоздатьНаборЗаписей();
        
        НаборЗаписей.Отбор[ИмяИзмеренияБазы].Установить(БазаИспользования);
        НаборЗаписей.Отбор[ИмяПоляОбъекта].Установить(Источник);
        
        НаборЗаписей.Прочитать();
        
        Для Каждого Запись Из НаборЗаписей Цикл
            Если Запись[ИмяПоляОбъекта] = Источник Тогда
                Ключ = Строка(Запись[ИмяПоляОбъекта]) + "_" + МестоИспользования;
                СоответствиеОбъектов.Вставить(Ключ, Запись[ИмяПоляГУИД]);
            КонецЕсли;
        КонецЦикла;
    КонецЦикла;
    
    Возврат СоответствиеОбъектов;
	
КонецФункции

Функция ЭлементНеНайден(Элемент)
    Возврат Элемент = Неопределено ИЛИ Найти(Элемент, "<Объект не найден>") > 0;
КонецФункции

Функция ПолучитьЗапросОтправки(ИмяРегистра, GUIDЭлемента, РодительГУИД = Неопределено)
    
    Запрос = Конструктор_ОписаниеЗапросаВнешнейБазы();

    Если ИмяРегистра = "СоответствиеОбъектовТекущейИВнешнихИБ" Тогда
        Запрос.ТекстЗапроса = "
        | ВЫБРАТЬ
        |     СоответствиеОбъектовТекущейИВнешнихИБ.УникальныйИдентификаторИсточника КАК ГУИДИсточника
        | ИЗ
        |     РегистрСведений.СоответствиеОбъектовТекущейИВнешнихИБ КАК СоответствиеОбъектовТекущейИВнешнихИБ
        | ГДЕ
        |     СоответствиеОбъектовТекущейИВнешнихИБ.УникальныйИдентификаторПриемника = &ГУИДСтрокой";
        Запрос.Параметры.Вставить("ГУИДСтрокой", GUIDЭлемента);

        Если РодительГУИД <> Неопределено Тогда
            Запрос.ТекстЗапроса = Запрос.ТекстЗапроса + "
            | ОБЪЕДИНИТЬ ВСЕ
            | ВЫБРАТЬ
            |     СоответствиеОбъектовТекущейИВнешнихИБ.УникальныйИдентификаторИсточника
            | ИЗ
            |     РегистрСведений.СоответствиеОбъектовТекущейИВнешнихИБ КАК СоответствиеОбъектовТекущейИВнешнихИБ
            | ГДЕ
            |     СоответствиеОбъектовТекущейИВнешнихИБ.УникальныйИдентификаторПриемника = &РодительГУИД";
            Запрос.Параметры.Вставить("РодительГУИД", РодительГУИД);
        КонецЕсли;

    ИначеЕсли ИмяРегистра = "СоответствияОбъектовИнформационныхБаз" Тогда
        Запрос.ТекстЗапроса = "
        | ВЫБРАТЬ
        |     СоответствияОбъектовИнформационныхБаз.УникальныйИдентификаторИсточникаСтрокой КАК ГУИДИсточника
        | ИЗ
        |     РегистрСведений.СоответствияОбъектовИнформационныхБаз КАК СоответствияОбъектовИнформационныхБаз
        | ГДЕ
        |     СоответствияОбъектовИнформационныхБаз.УникальныйИдентификаторПриемника = &ГУИДСтрокой";
        Запрос.Параметры.Вставить("ГУИДСтрокой", GUIDЭлемента);

        Если РодительГУИД <> Неопределено Тогда
            Запрос.ТекстЗапроса = Запрос.ТекстЗапроса + "
            | ОБЪЕДИНИТЬ ВСЕ
            | ВЫБРАТЬ
            |     СоответствияОбъектовИнформационныхБаз.УникальныйИдентификаторИсточникаСтрокой
            | ИЗ
            |     РегистрСведений.СоответствияОбъектовИнформационныхБаз КАК СоответствияОбъектовИнформационныхБаз
            | ГДЕ
            |     СоответствияОбъектовИнформационныхБаз.УникальныйИдентификаторПриемника = &РодительГУИД";
            Запрос.Параметры.Вставить("РодительГУИД", РодительГУИД);
        КонецЕсли;
    КонецЕсли;

    Возврат Запрос;

КонецФункции

Функция ВернутьДополнительнуюКонстанту(Имя) Экспорт 
	
	ЭтоМассивПараметров = Ложь;
	Результат = Неопределено;
	СтруктураРезультат = Новый Структура;
	
	Запрос = Новый Запрос;
	мТекст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПЛ_ДополнительныеКонстанты.Имя КАК Имя,
	|	ПЛ_ДополнительныеКонстанты.Значение КАК Значение
	|ИЗ
	|	РегистрСведений.ПЛ_ДополнительныеКонстанты КАК ПЛ_ДополнительныеКонстанты
	|ГДЕ
	|	ПЛ_ДополнительныеКонстанты.Имя =&Имя";
	
	Если ТипЗнч(Имя)=Тип("Массив") Тогда
		мТекст=СтрЗаменить(мТекст,"=&Имя"," в (&Имя)");
		ЭтоМассивПараметров=Истина;
		Для ффф=0 по Имя.ВГраница() Цикл
			СтруктураРезультат.Вставить(Имя[ффф],Неопределено);
		КонецЦикла; 
	КонецЕсли; 
	
	Запрос.Текст = мТекст;
	Запрос.УстановитьПараметр("Имя", Имя);
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Для каждого стр Из РезультатЗапроса Цикл
		Если ЭтоМассивПараметров Тогда
			СтруктураРезультат[стр.Имя]=стр.Значение;
		иначе	
			Результат = стр.Значение;
		КонецЕсли; 
	КонецЦикла;
		
	возврат ?(ЭтоМассивПараметров = Истина,СтруктураРезультат,Результат);
	
КонецФункции

