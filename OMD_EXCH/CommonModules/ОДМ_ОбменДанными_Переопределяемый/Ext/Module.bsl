#Область ВсякаяВременнаяШляпаЧтоБыНеЛомалаОсновнуюФункциональность

Процедура Временно_ДопискиПоДокументам(ОбъектДанных)
	
	Попытка
		ОМ_СчетаУчетаВДокументах = ОДМ_ОбщегоНазначения.ОбщийМодуль("СчетаУчетаВДокументах");
		ОМ_БухгалтерскийУчетПереопределяемый = ОДМ_ОбщегоНазначения.ОбщийМодуль("БухгалтерскийУчетПереопределяемый");
	Исключение
		//если нет нужных модулей - то не работает так в этой конфе
		Возврат;
	КонецПопытки;
	
	Если ТипЗнч(ОбъектДанных) = Тип("ДокументОбъект.ПоступлениеТоваровУслуг") Тогда
		
		ОМ_СчетаУчетаВДокументах.ЗаполнитьСчетаУчетаРасчетов(ОбъектДанных);
		
		Для Каждого СтрокаТЧ Из ОбъектДанных.Услуги Цикл
			СчетаУчета = ОМ_БухгалтерскийУчетПереопределяемый.ПолучитьСчетаУчетаНоменклатуры(ОбъектДанных.Организация, СтрокаТЧ.Номенклатура);
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, СчетаУчета);
			СтрокаТЧ.СчетУчетаНДС = СчетаУчета.СчетУчетаНДС;
			СтрокаТЧ.СчетЗатрат = СчетаУчета.СчетУчета;
			СтрокаТЧ.СчетЗатратНУ = СчетаУчета.СчетУчета;
			СтрокаТЧ.ПодразделениеЗатрат = ОбъектДанных.ПодразделениеОрганизации;
			СтрокаТЧ.СпособУчетаНДС = Перечисления.СпособыУчетаНДС.ПринимаетсяКВычету;
			СтрокаТЧ.Содержание = СтрокаТЧ.Номенклатура.Наименование;
		КонецЦикла;
		
	ИначеЕсли ТипЗнч(ОбъектДанных) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
		
		ОМ_СчетаУчетаВДокументах.ЗаполнитьСчетаУчетаРасчетов(ОбъектДанных);
		ОбъектДанных.ВидЭлектронногоДокумента = Документы.РеализацияТоваровУслуг.ВидЭлектронногоДокумента(ОбъектДанных);
		
		// Заполняем счета учета и субконто в табличной части
		Для Каждого СтрокаТЧ Из ОбъектДанных.Услуги Цикл
			СчетаУчета = ОМ_БухгалтерскийУчетПереопределяемый.ПолучитьСчетаУчетаНоменклатуры(ОбъектДанных.Организация, СтрокаТЧ.Номенклатура);
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, СчетаУчета);
			СтрокаТЧ.СчетУчетаНДСПоРеализации = СчетаУчета.СчетУчетаНДСПродажи;
			СтрокаТЧ.ПодразделениеОрганизации = ОбъектДанных.ПодразделениеОрганизации;
			НоменклатурнаяГруппаТовара = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТЧ.Номенклатура, "НоменклатурнаяГруппа");
			СтрокаТЧ.Содержание = СтрокаТЧ.Номенклатура.Наименование;
			
			СтрокаТЧ.Субконто = ?(ЗначениеЗаполнено(НоменклатурнаяГруппаТовара), НоменклатурнаяГруппаТовара, Неопределено);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти // ВсякаяВременнаяШляпаЧтоБыНеЛомалаОсновнуюФункциональность

#Область ТакПисатьНеНадо_Временно

// Функция формирует структуру описания объекта для передачи в другую базу данных.
// Поддерживает справочники и документы, включая ПоступлениеНаРасчетныйСчет и СписаниеСРасчетногоСчета.
// Параметры:
//   ОбъектСсылка - Ссылка на объект (справочник или документ).
//   БазаДанных - Строка, идентификатор базы данных (например, "WebServERP" или "БП").
// Возвращаемое значение:
//   Структура - Описание объекта для передачи.
Функция СформироватьОписание(Знач ОбъектСсылка, Знач БазаДанных) Экспорт
	
	Перем РезультатМетода;
	
	Если ТипЗнч(ОбъектСсылка.Ссылка) = Тип("СправочникСсылка.СтатьиЗатрат") Тогда
		
		// Проверяем, отправляем ли в ERP
		Если Строка(БазаДанных) = "WebServERP" Тогда
			// Логика для ПланВидовХарактеристик.СтатьиРасходов (ERP)
			// Заглушка по отправке
			Если НЕ ОбъектСсылка.ЭтоГруппа Тогда
				Если НЕ ОбъектСсылка.АктуальнаяСтатьяСписания Тогда
					РезультатМетода = Неопределено;
					Возврат РезультатМетода;
				КонецЕсли;
			КонецЕсли;
		
			РезультатМетода = ?(ОбъектСсылка.ЭтоГруппа, 
			Новый Структура("Ссылка, Наименование, Код, Родитель, ЭтоГруппа"),
			Новый Структура("Ссылка, Наименование, Код, Родитель, ТипРасходов, ВариантРаспределенияРасходовУпр, ВариантРаспределенияРасходовРегл, ВариантРаспределенияРасходовНУ, АктуальнаяСтатьяСписания, ОграничитьИспользование, ЭтоГруппа"));
			
			РезультатМетода.Ссылка = ОДМ_ОбменДанными.УстановитьСвойство(
			"ПланВидовХарактеристикСсылка.СтатьиРасходов", 
			Строка(ОбъектСсылка.Ссылка.УникальныйИдентификатор()));
			РезультатМетода.Наименование = ОДМ_ОбменДанными.УстановитьСвойство("Строка", ОбъектСсылка.Наименование);
			РезультатМетода.Код = ОДМ_ОбменДанными.УстановитьСвойство("Строка", ОбъектСсылка.Код);
			РезультатМетода.ЭтоГруппа = ОДМ_ОбменДанными.УстановитьСвойство("Булево", ОбъектСсылка.ЭтоГруппа);
			
			Если ЗначениеЗаполнено(ОбъектСсылка.Родитель) Тогда
				РезультатМетода.Родитель = ОДМ_ОбменДанными.УстановитьСвойство(
				"ПланВидовХарактеристикСсылка.СтатьиРасходов", 
				Строка(ОбъектСсылка.Родитель.УникальныйИдентификатор()));
			Иначе
				РезультатМетода.Родитель = ОДМ_ОбменДанными.УстановитьСвойство(
				"ПланВидовХарактеристикСсылка.СтатьиРасходов", "");
			КонецЕсли;
			
			Если НЕ ОбъектСсылка.ЭтоГруппа Тогда
				ТипРасходов = "ПрочиеРасходы";
				РезультатМетода.ТипРасходов = ОДМ_ОбменДанными.УстановитьСвойство(
				"ПеречислениеСсылка.ТипыРасходов", 
				ТипРасходов);
				РезультатМетода.АктуальнаяСтатьяСписания = ОДМ_ОбменДанными.УстановитьСвойство("Булево", ОбъектСсылка.АктуальнаяСтатьяСписания);
				РезультатМетода.ОграничитьИспользование = ОДМ_ОбменДанными.УстановитьСвойство("Булево", ОбъектСсылка.АктуальнаяСтатьяСписания);
				
				Если ОбъектСсылка.АктуальнаяСтатьяСписания Тогда
					РезультатМетода.ВариантРаспределенияРасходовУпр = ОДМ_ОбменДанными.УстановитьСвойство("ПеречислениеСсылка.ВариантыРаспределенияРасходов","НеРаспределять");
					РезультатМетода.ВариантРаспределенияРасходовРегл = ОДМ_ОбменДанными.УстановитьСвойство("ПеречислениеСсылка.ВариантыРаспределенияРасходов","НеРаспределять");
					РезультатМетода.ВариантРаспределенияРасходовНУ = ОДМ_ОбменДанными.УстановитьСвойство("ПеречислениеСсылка.ВариантыРаспределенияРасходов","НеРаспределять");
				КонецЕсли;
				
			КонецЕсли;
			
		Иначе
			// Логика для Справочник.СтатьиЗатрат (БП)
			// Заглушка по отправке
			Если НЕ ОбъектСсылка.ЭтоГруппа Тогда
				Если НЕ ОбъектСсылка.АктуальнаяСтатьяСписания Тогда
					РезультатМетода = Неопределено;
					Возврат РезультатМетода;
				КонецЕсли;
			КонецЕсли;
			
			РезультатМетода = ?(ОбъектСсылка.ЭтоГруппа, 
			Новый Структура("Ссылка, Наименование, Код, Родитель, ЭтоГруппа"),
			Новый Структура("Ссылка, Наименование, Код, Родитель, ВидДеятельностиДляНалоговогоУчетаЗатрат, ВидРасходовНУ, ЭтоГруппа, ИмяПредопределенныхДанных"));
			
			РезультатМетода.Ссылка = ОДМ_ОбменДанными.УстановитьСвойство(
			"СправочникСсылка.СтатьиЗатрат", 
			Строка(ОбъектСсылка.Ссылка.УникальныйИдентификатор()));
			РезультатМетода.Наименование = ОДМ_ОбменДанными.УстановитьСвойство("Строка", ОбъектСсылка.Наименование);
			РезультатМетода.Код = ОДМ_ОбменДанными.УстановитьСвойство("Строка", ОбъектСсылка.Код);
			РезультатМетода.ЭтоГруппа = ОДМ_ОбменДанными.УстановитьСвойство("Булево", ОбъектСсылка.ЭтоГруппа);
			
			Если ЗначениеЗаполнено(ОбъектСсылка.Родитель) Тогда
				РезультатМетода.Родитель = ОДМ_ОбменДанными.УстановитьСвойство(
				"СправочникСсылка.СтатьиЗатрат", 
				Строка(ОбъектСсылка.Родитель.УникальныйИдентификатор()));
			Иначе
				РезультатМетода.Родитель = ОДМ_ОбменДанными.УстановитьСвойство(
				"СправочникСсылка.СтатьиЗатрат", "");
			КонецЕсли;
			
			Если НЕ ОбъектСсылка.ЭтоГруппа Тогда
				Если ЗначениеЗаполнено(ОбъектСсылка.ВидДеятельностиДляНалоговогоУчетаЗатрат) Тогда
					ИмяЗначения = ПолучитьИмяЗначенияПеречисления(ОбъектСсылка.ВидДеятельностиДляНалоговогоУчетаЗатрат);
					РезультатМетода.ВидДеятельностиДляНалоговогоУчетаЗатрат = ОДМ_ОбменДанными.УстановитьСвойство(
					"ПеречислениеСсылка.ВидыДеятельностиДляНалоговогоУчетаЗатрат", ИмяЗначения);
				Иначе
					РезультатМетода.ВидДеятельностиДляНалоговогоУчетаЗатрат = ОДМ_ОбменДанными.УстановитьСвойство(
					"ПеречислениеСсылка.ВидыДеятельностиДляНалоговогоУчетаЗатрат", "");
				КонецЕсли;
				
				РезультатМетода.ИмяПредопределенныхДанных = ОДМ_ОбменДанными.УстановитьСвойство("Строка", ОбъектСсылка.ИмяПредопределенныхДанных);
				
				Если ЗначениеЗаполнено(ОбъектСсылка.ВидРасходовНУ) Тогда
					ИмяЗначения = ПолучитьИмяЗначенияПеречисления(ОбъектСсылка.ВидРасходовНУ);
					РезультатМетода.ВидРасходовНУ = ОДМ_ОбменДанными.УстановитьСвойство(
					"ПеречислениеСсылка.ВидыРасходовНУ", ИмяЗначения);
				Иначе
					РезультатМетода.ВидРасходовНУ = ОДМ_ОбменДанными.УстановитьСвойство(
					"ПеречислениеСсылка.ВидыРасходовНУ", "");
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		// Проверяем, что передан контрагент и база данных - 1С БП
	ИначеЕсли ТипЗнч(ОбъектСсылка.Ссылка) = Тип("СправочникСсылка.Контрагенты") Тогда
		
		РезультатМетода = ?(ОбъектСсылка.ЭтоГруппа, 
		Новый Структура("Ссылка, Наименование, Родитель, ЭтоГруппа"),
		Новый Структура("Ссылка, Наименование, Родитель, 
		|ИНН, КПП, НаименованиеПолное, ЭтоГруппа, 
		|Комментарий, ИндивидуальныйПредприниматель,
		|ГосударственныйОрган, КодПоОКПО,
		|ОбособленноеПодразделение,ЮридическоеФизическоеЛицо"));
		
		РезультатМетода.Ссылка = ОДМ_ОбменДанными.УстановитьСвойство(
		"СправочникСсылка.Контрагенты", 
		Строка(ОбъектСсылка.Ссылка.УникальныйИдентификатор()));
		РезультатМетода.Наименование = ОДМ_ОбменДанными.УстановитьСвойство("Строка", ОбъектСсылка.Наименование);
		РезультатМетода.ЭтоГруппа = ОДМ_ОбменДанными.УстановитьСвойство("Булево", ОбъектСсылка.ЭтоГруппа);
		
		Если ЗначениеЗаполнено(ОбъектСсылка.Родитель) Тогда
			РезультатМетода.Родитель = ОДМ_ОбменДанными.УстановитьСвойство(
			"СправочникСсылка.Контрагенты", 
			Строка(ОбъектСсылка.Родитель.УникальныйИдентификатор()));
		КонецЕсли;
		
		Если НЕ ОбъектСсылка.ЭтоГруппа Тогда
			РезультатМетода.ИНН = ОДМ_ОбменДанными.УстановитьСвойство("Строка", ОбъектСсылка.ИНН);
			РезультатМетода.КПП = ОДМ_ОбменДанными.УстановитьСвойство("Строка", ОбъектСсылка.КПП);
			РезультатМетода.НаименованиеПолное = ОДМ_ОбменДанными.УстановитьСвойство("Строка", ОбъектСсылка.НаименованиеПолное);
			РезультатМетода.Комментарий = ОДМ_ОбменДанными.УстановитьСвойство("Строка", ОбъектСсылка.Комментарий);

			РезультатМетода.ИндивидуальныйПредприниматель = ОДМ_ОбменДанными.УстановитьСвойство("Булево", ОбъектСсылка.ИндивидуальныйПредприниматель);
			РезультатМетода.ГосударственныйОрган = ОДМ_ОбменДанными.УстановитьСвойство("Булево", ОбъектСсылка.ГосударственныйОрган);
			РезультатМетода.КодПоОКПО = ОДМ_ОбменДанными.УстановитьСвойство("Строка", ОбъектСсылка.КодПоОКПО);
			РезультатМетода.ОбособленноеПодразделение = ОДМ_ОбменДанными.УстановитьСвойство("Булево", ОбъектСсылка.ОбособленноеПодразделение);
			РезультатМетода.ЮридическоеФизическоеЛицо = ОДМ_ОбменДанными.УстановитьСвойство("Булево", ОбъектСсылка.ЮридическоеФизическоеЛицо);
			
			ИмяЗначения = ПолучитьИмяЗначенияПеречисления(ОбъектСсылка.ЮридическоеФизическоеЛицо);
			РезультатМетода.ЮридическоеФизическоеЛицо = ОДМ_ОбменДанными.УстановитьСвойство(
			"ПеречислениеСсылка.ЮридическоеФизическоеЛицо", ИмяЗначения);
			ИспользуемаяИБ = ОДМ_ОбменДанными.ВернутьДополнительнуюКонстанту("MRS_DataExchange_Base_" + БазаДанных);
			
			СоответствиеВнешнейБазы = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, ОбъектСсылка.Ссылка);
			
			Если ЗначениеЗаполнено(СоответствиеВнешнейБазы) Тогда
				РезультатМетода.Ссылка = ОДМ_ОбменДанными.УстановитьСвойство(
				"СправочникСсылка.Контрагенты", СоответствиеВнешнейБазы);
			Иначе
				ЗаписатьСобытиеВЖурналРегистрации(ОбъектСсылка.Наименование, ТипЗнч(ОбъектСсылка.Ссылка), БазаДанных);
