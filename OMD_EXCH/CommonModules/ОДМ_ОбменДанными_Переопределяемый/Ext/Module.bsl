			//Если ТипЗнч(ОбъектСсылка.СубконтоДт2) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
			//	РезультатМетода.СубконтоДт2 = ОДМ_ОбменДанными.УстановитьСвойство(
			//	"СправочникСсылка.ДоговорыКонтрагентов", Строка(ОбъектСсылка.ДоговорКонтрагента.УникальныйИдентификатор()));
			//КонецЕсли;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ОбъектСсылка.СубконтоДт2) Тогда
			ЗаполнитьСубконтоДляОбмена(
