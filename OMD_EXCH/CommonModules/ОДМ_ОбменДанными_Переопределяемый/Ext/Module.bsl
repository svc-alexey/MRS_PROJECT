				"СправочникСсылка.СтатьиДвиженияДенежныхСредств", СоответствиеВнешнейБазы);
			Иначе
				СтрокаРасшифровкиПлатежа.СтатьяДвиженияДенежныхСредств = ОДМ_ОбменДанными.УстановитьСвойство(
				"СправочникСсылка.СтатьиДвиженияДенежныхСредств", Строка(СтрокаПлатежа.СтатьяДвиженияДенежныхСредств.Ссылка.УникальныйИдентификатор()));
			КонецЕсли;
			
			СтрокаРасшифровкиПлатежа.СчетУчетаРасчетовПоАвансам = ОДМ_ОбменДанными.УстановитьСвойство(
			"ПланСчетовСсылка.Хозрасчетный", СтрокаПлатежа.СчетУчетаРасчетовПоАвансам.Код);
			
			СтрокаРасшифровкиПлатежа.СчетУчетаРасчетовСКонтрагентом = ОДМ_ОбменДанными.УстановитьСвойство(
