		Если ЗначениеЗаполнено(СоответствиеВнешнейБазы) Тогда
			РезультатМетода.СтатьяДвиженияДенежныхСредств = ОДМ_ОбменДанными.УстановитьСвойство(
			"СправочникСсылка.СтатьиДвиженияДенежныхСредств", СоответствиеВнешнейБазы);
		Иначе
			РезультатМетода.СтатьяДвиженияДенежныхСредств = ОДМ_ОбменДанными.УстановитьСвойство(
			"СправочникСсылка.СтатьиДвиженияДенежныхСредств", Строка(ОбъектСсылка.СтатьяДвиженияДенежныхСредств.Ссылка.УникальныйИдентификатор()));
		КонецЕсли;
		
		//Если ЗначениеЗаполнено(ОбъектСсылка.СтатьяДвиженияДенежныхСредствЗачисление) Тогда
		//	СоответствиеВнешнейБазы = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, ОбъектСсылка.СтатьяДвиженияДенежныхСредствЗачисление);
		//	Если ЗначениеЗаполнено(СоответствиеВнешнейБазы) Тогда
		//		РезультатМетода.СтатьяДвиженияДенежныхСредствЗачисление = ОДМ_ОбменДанными.УстановитьСвойство(
		//		"СправочникСсылка.СтатьиДвиженияДенежныхСредств", СоответствиеВнешнейБазы);
		//	Иначе
		//		РезультатМетода.СтатьяДвиженияДенежныхСредствЗачисление = ОДМ_ОбменДанными.УстановитьСвойство(
		//		"СправочникСсылка.СтатьиДвиженияДенежныхСредств", Строка(ОбъектСсылка.СтатьяДвиженияДенежныхСредствЗачисление.Ссылка.УникальныйИдентификатор()));
		//	КонецЕсли;
		//КонецЕсли;
		
		// НазначениеПлатежа
		РезультатМетода.НазначениеПлатежа = ОДМ_ОбменДанными.УстановитьСвойство("Строка", ОбъектСсылка.НазначениеПлатежа);
		
		// Комментарий (с префиксом)
		РезультатМетода.Комментарий = ОДМ_ОбменДанными.УстановитьСвойство("Строка", "Синхронизация 1С УХ-БП / " + ОбъектСсылка.Комментарий);
		
