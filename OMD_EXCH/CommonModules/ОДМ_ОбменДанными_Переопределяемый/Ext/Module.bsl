// Вспомогательная функция для получения имени значения перечисления
Функция ПолучитьИмяЗначенияПеречисления(ЗначениеПеречисления)
	
	Если Не ЗначениеЗаполнено(ЗначениеПеречисления) Тогда
		Возврат "";
	КонецЕсли;
	
	// Получаем метаданные перечисления
	МетаданныеПеречисления = ЗначениеПеречисления.Метаданные();
	ИмяПеречисления = МетаданныеПеречисления.Имя;
	
	// Находим индекс значения в перечислении
	ИндексЗначения = Перечисления[ИмяПеречисления].Индекс(ЗначениеПеречисления);
	
	// Получаем имя значения по индексу
	ИмяЗначения = МетаданныеПеречисления.ЗначенияПеречисления[ИндексЗначения].Имя;
	
	Возврат ИмяЗначения;
	
КонецФункции

// Вспомогательная функция для получения имени значения перечисления
Функция ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, ОбъектТекущейИБ)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"
	|ВЫБРАТЬ
	|	СоответствиеОбъектовТекущейИВнешнихИБ.ОбъектВнешнейИБ КАК ОбъектВнешнейИБ,
	|	СоответствиеОбъектовТекущейИВнешнихИБ.ИспользуемаяИБ КАК ИспользуемаяИБ
	|ИЗ
	|	РегистрСведений.СоответствиеОбъектовТекущейИВнешнихИБ КАК СоответствиеОбъектовТекущейИВнешнихИБ
	|ГДЕ
	|	СоответствиеОбъектовТекущейИВнешнихИБ.ОбъектТекущейИБ = &ОбъектТекущейИБ
	|	И СоответствиеОбъектовТекущейИВнешнихИБ.ИспользуемаяИБ = &ИспользуемаяИБ
	|";
	
	Запрос.УстановитьПараметр("ИспользуемаяИБ", ИспользуемаяИБ);
	Запрос.УстановитьПараметр("ОбъектТекущейИБ", ОбъектТекущейИБ);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.ОбъектВнешнейИБ;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Процедура ЗаполнитьСубконтоДляОбмена(РезультатМетода, ИмяПоля, ЗначениеСубконто, ИспользуемаяИБ, БазаДанных)
	
	Если НЕ ЗначениеЗаполнено(ЗначениеСубконто) Тогда
		Возврат;
	КонецЕсли;
	
	ТипСубконто = ТипЗнч(ЗначениеСубконто);
	ТипСубконтоСтрокой = Строка(ТипСубконто);
	
	ЭтоСсылочныйТип = Лев(ТипСубконтоСтрокой, 16) = "СправочникСсылка"
		ИЛИ Лев(ТипСубконтоСтрокой, 14) = "ДокументСсылка"
		ИЛИ Лев(ТипСубконтоСтрокой, 27) = "ПланВидовХарактеристикСсылка";
	
	Если НЕ ЭтоСсылочныйТип Тогда
		Возврат;
	КонецЕсли;
	
	СоответствиеВнешнейБазы = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, ЗначениеСубконто);
	Если ЗначениеЗаполнено(СоответствиеВнешнейБазы) Тогда
		РезультатМетода[ИмяПоля] = ОДМ_ОбменДанными.УстановитьСвойство(ТипСубконтоСтрокой, СоответствиеВнешнейБазы);
		Возврат;
	КонецЕсли;
	
	Если ТипСубконтоСтрокой = "СправочникСсылка.ПрочиеДоходыИРасходы"
		ИЛИ ТипСубконтоСтрокой = "СправочникСсылка.ВидыНалоговИПлатежейВБюджет"
		ИЛИ ТипСубконтоСтрокой = "СправочникСсылка.Пользователи" Тогда
		РезультатМетода[ИмяПоля] = ОДМ_ОбменДанными.УстановитьСвойство(ТипСубконтоСтрокой, ЗначениеСубконто.Наименование);
		Возврат;
	КонецЕсли;
	
	РезультатМетода[ИмяПоля] = ОДМ_ОбменДанными.УстановитьСвойство(
		ТипСубконтоСтрокой,
		Строка(ЗначениеСубконто.УникальныйИдентификатор()));
	
	ЗаписатьСобытиеВЖурналРегистрации(ТипСубконтоСтрокой, ТипСубконто, БазаДанных, ЗначениеСубконто);
	
КонецПроцедуры

Функция ОбеспечитьСоответствиеБанковскогоСчета(Счет, БазаДанных)
	
	Если Не ЗначениеЗаполнено(Счет) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ИспользуемаяИБ = ОДМ_ОбменДанными.ВернутьДополнительнуюКонстанту("MRS_DataExchange_Base_" + БазаДанных);
	СоответствиеСчета = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, Счет);
	Если ЗначениеЗаполнено(СоответствиеСчета) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Счет.Банк) Тогда
		Банк = Счет.Банк;
		СоответствиеБанка = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, Банк);
		Если НЕ ЗначениеЗаполнено(СоответствиеБанка) Тогда
			ИдентификаторБанка = НайтиИдентификаторБанкаВоВнешнейБазе(Банк, БазаДанных);
			Если НЕ ЗначениеЗаполнено(ИдентификаторБанка) Тогда
				ИдентификаторБанка = ОтправитьОбъектВоВнешнююБазу(Банк, БазаДанных);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ИдентификаторБанка) Тогда
				ЗаписатьСоответствиеОбъекта(Банк, ИспользуемаяИБ, БазаДанных, ИдентификаторБанка, "Банки");
			Иначе
				Возврат Ложь;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ИдентификаторСчета = ОтправитьОбъектВоВнешнююБазу(Счет, БазаДанных);
	Если НЕ ЗначениеЗаполнено(ИдентификаторСчета) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ЗаписатьСоответствиеОбъекта(Счет, ИспользуемаяИБ, БазаДанных, ИдентификаторСчета, "БанковскиеСчета");
	Возврат Истина;
	
КонецФункции

Функция НайтиИдентификаторБанкаВоВнешнейБазе(Банк, БазаДанных)
	
	Если НЕ ЗначениеЗаполнено(Банк) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ОписаниеЗапроса = ОДМ_ОбменДанными.Конструктор_ОписаниеЗапросаВнешнейБазы();
	ВнешнийИнтерфейс = ОДМ_ОбменДанными.Конструктор_ВнешнийИнтерфейс();
	ВнешнийИнтерфейс.ЗаполнитьПараметрыПодключения(БазаДанных);
	
	Если ЗначениеЗаполнено(Банк.Наименование) Тогда
		ОписаниеЗапроса.ТекстЗапроса =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Банки.Ссылка)) КАК ГУИД
		|ИЗ
		|	Справочник.Банки КАК Банки
		|ГДЕ
		|	НЕ Банки.ПометкаУдаления
		|	И Банки.Наименование = &Наименование";
		ОписаниеЗапроса.Параметры.Вставить("Наименование", Банк.Наименование);
		
		Данные = ВнешнийИнтерфейс.ОтправитьЗапросНаСервер(ОписаниеЗапроса, Ложь);
		Если Данные <> Неопределено И Данные.Количество() > 0 Тогда
			Возврат Строка(Данные[0].ГУИД);
		КонецЕсли;
		
		ОписаниеЗапроса.Параметры.Очистить();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Банк.Код) Тогда
		ОписаниеЗапроса.ТекстЗапроса =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Банки.Ссылка)) КАК ГУИД
		|ИЗ
		|	Справочник.Банки КАК Банки
		|ГДЕ
		|	НЕ Банки.ПометкаУдаления
		|	И Банки.Код = &Код";
		ОписаниеЗапроса.Параметры.Вставить("Код", Банк.Код);
		
		Данные = ВнешнийИнтерфейс.ОтправитьЗапросНаСервер(ОписаниеЗапроса, Ложь);
		Если Данные <> Неопределено И Данные.Количество() > 0 Тогда
			Возврат Строка(Данные[0].ГУИД);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция ОтправитьОбъектВоВнешнююБазу(СсылкаОбъекта, БазаДанных)
	
	ОписаниеИсточника = СформироватьОписание(СсылкаОбъекта, БазаДанных);
	Если ОписаниеИсточника = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ОтправляемыйПакет = ОДМ_ОбменДанными.Конструктор_ОписаниеПакетаЗаписиОбъекта();
	ОтправляемыйПакет.ОчищатьТабличнуюЧасть = ОДМ_ОбменДанными.УстановитьСвойство("Булево", Истина);
	ОтправляемыйПакет.ВключитьОбменДанными = ОДМ_ОбменДанными.УстановитьСвойство("Булево", Истина);
	ОтправляемыйПакет.Данные = ОписаниеИсточника;
	
	ВнешнийИнтерфейс = ОДМ_ОбменДанными.Конструктор_ВнешнийИнтерфейс();
	ВнешнийИнтерфейс.ЗаполнитьПараметрыПодключения(БазаДанных);
	РезультатМетода = ВнешнийИнтерфейс.ОтправитьОбъектНаСервер(ОтправляемыйПакет, Ложь);
	
	Если РезультатМетода <> Неопределено
		И ТипЗнч(РезультатМетода) = Тип("Структура")
		И РезультатМетода.Свойство("Идентификатор") Тогда
		Возврат РезультатМетода.Идентификатор;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Процедура ЗаписатьСоответствиеОбъекта(ОбъектТекущейИБ, ИспользуемаяИБ, БазаДанных, ИдентификаторБП, ИмяОбъектаМетаданных)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	СоответствиеВнешнимИБ.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СоответствиеВнешнимИБ КАК СоответствиеВнешнимИБ
	|ГДЕ
	|	СоответствиеВнешнимИБ.Владелец = &Владелец
	|	И СоответствиеВнешнимИБ.ИмяОбъектаМетаданных = &ИмяОбъектаМетаданных";
	
	Запрос.УстановитьПараметр("Владелец", ИспользуемаяИБ.ТипБД);
	Запрос.УстановитьПараметр("ИмяОбъектаМетаданных", ИмяОбъектаМетаданных);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Если НЕ Выборка.Следующий() Тогда
		Возврат;
	КонецЕсли;
	
	НастройкаСоответствия = Выборка.Ссылка;
	
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Соответствие.ОбъектТекущейИБ КАК ОбъектТекущейИБ,
	|	Соответствие.НастройкаСоответствия КАК НастройкаСоответствия,
	|	Соответствие.ИспользуемаяИБ КАК ИспользуемаяИБ
	|ИЗ
	|	РегистрСведений.СоответствиеОбъектовТекущейИВнешнихИБ КАК Соответствие
	|ГДЕ
	|	Соответствие.ИспользуемаяИБ = &ИспользуемаяИБ
	|	И Соответствие.НастройкаСоответствия = &НастройкаСоответствия
	|	И Соответствие.ОбъектТекущейИБ = &ОбъектТекущейИБ";
	
	Запрос.УстановитьПараметр("ИспользуемаяИБ", ИспользуемаяИБ);
	Запрос.УстановитьПараметр("НастройкаСоответствия", НастройкаСоответствия);
	Запрос.УстановитьПараметр("ОбъектТекущейИБ", ОбъектТекущейИБ);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	МенеджерЗаписи = РегистрыСведений.СоответствиеОбъектовТекущейИВнешнихИБ.СоздатьМенеджерЗаписи();
	Если Выборка.Следующий() Тогда
		МенеджерЗаписи.ОбъектТекущейИБ = Выборка.ОбъектТекущейИБ;
		МенеджерЗаписи.НастройкаСоответствия = Выборка.НастройкаСоответствия;
		МенеджерЗаписи.ИспользуемаяИБ = Выборка.ИспользуемаяИБ;
	Иначе
		МенеджерЗаписи.ОбъектТекущейИБ = ОбъектТекущейИБ;
		МенеджерЗаписи.ИспользуемаяИБ = ИспользуемаяИБ;
		МенеджерЗаписи.НастройкаСоответствия = НастройкаСоответствия;
	КонецЕсли;
	
	МенеджерЗаписи.ОбъектВнешнейИБ = Строка(ИдентификаторБП);
	МенеджерЗаписи.НаименованиеОбъектаВнешнейИБ = ОбъектТекущейИБ.Наименование;
	МенеджерЗаписи.НастройкаСоответствияНаименование = НастройкаСоответствия.Наименование;
	МенеджерЗаписи.ТипОбъектаТекущейИБ = ИмяОбъектаМетаданных;
	МенеджерЗаписи.ТипОбъектаВнешнейИБ = ИмяОбъектаМетаданных;
	МенеджерЗаписи.ИмяОбъектаТекущейИБ = ОбъектТекущейИБ.Метаданные().ПолноеИмя();
	МенеджерЗаписи.ИмяОбъектаВнешнейИБ = "Справочник." + ИмяОбъектаМетаданных;
	МенеджерЗаписи.GUIDОбъектаТекущейИБ = Строка(ОбъектТекущейИБ.УникальныйИдентификатор());
	МенеджерЗаписи.Выгружено = Истина;
	МенеджерЗаписи.Записать();
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

Процедура ЗаписатьСобытиеВЖурналРегистрации(НаименованиеОбъекта, ТипСправочника = "", БазаДанных = "",ЭлементПоиска = "", ОшибкаВыгрузки = "")
	
	СтруктураСобытий = Новый Структура("ИмяСобытия, ПредставлениеУровня, Комментарий,ДатаСобытия");
	
	СтруктураСобытий.ИмяСобытия 		 = "ОДМ_Обмен";
	СтруктураСобытий.ПредставлениеУровня = "Ошибка";	
	
	Если ЗначениеЗаполнено(ОшибкаВыгрузки) Тогда
		ТекстСообщения = "Не выгружен " + НаименованиеОбъекта+ "в базу " + БазаДанных + ". Ошибка: " + ОшибкаВыгрузки;
	Иначе
		ТекстСообщения = "Нет связи для " + ТипСправочника +" " + НаименованиеОбъекта+ " для базы " + БазаДанных + " элемент " + ЭлементПоиска;
	КонецЕсли;
	
	СтруктураСобытий.Комментарий = ТекстСообщения;
	СобытияДляЖурналаРегистрации = Новый СписокЗначений();
	СобытияДляЖурналаРегистрации.Добавить(СтруктураСобытий);
	
	ЖурналРегистрации.ЗаписатьСобытияВЖурналРегистрации(СобытияДляЖурналаРегистрации);
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	
КонецПроцедуры

#КонецОбласти // ТакПисатьНеНадо_Временно


#Область ШаблоныИнтеграции

// Шаблон-обработчик: создаёт ЗаказыНаПеремещение и ЗаказПоставщику из данных ELMA.
// Вызывается кодом шаблона типа «Обработчик» в справочнике ОДМ_МетодыИнтеграции:
//   ОДМ_ОбменДанными_Переопределяемый.Шаблон_СоздатьДокументыЗаказНаПеремещениеЗаказПоставщику(ОписаниеЗадачи);
//
// Параметры:
//   Параметры - Структура - ОписаниеЗадачи обмена. Данные читаются из
//               Параметры.Параметры.Данные (массив; тип документа определяется
//               по ТипЗнч(Элемент["Ссылка"])). Результат записывается в Параметры.Результат.
//
// При ошибке валидации или проведения вызывает исключение (транзакция откатывается).
Процедура Шаблон_СоздатьДокументыЗаказНаПеремещениеЗаказПоставщику(Параметры) Экспорт

	МассивВходных = Параметры.Параметры.Данные;

	// --- Разбор по типу документа ---

	ЗаказыНаПеремещение    = Новый Массив;
	ДанныеЗаказаПоставщику = Неопределено;

	Для Каждого ЭлементДанных Из МассивВходных Цикл

		ТипСсылки = ТипЗнч(ЭлементДанных["Ссылка"]);

		Если ТипСсылки = Тип("ДокументСсылка.ЗаказНаПеремещение") Тогда
			ЗаказыНаПеремещение.Добавить(ЭлементДанных);
		ИначеЕсли ТипСсылки = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
			ДанныеЗаказаПоставщику = ЭлементДанных;
		Иначе
			ВызватьИсключение СтрШаблон(НСтр("ru='Неизвестный тип документа в массиве Данные: %1'"), ТипСсылки);
		КонецЕсли;

	КонецЦикла;

	// --- Проверка состава массива ---

	ОшибкиВалидации = Новый Массив;

	Если ЗаказыНаПеремещение.Количество() = 0 Тогда
		ОшибкиВалидации.Добавить(НСтр("ru='В Данные не передан ни один ЗаказНаПеремещение'"));
	КонецЕсли;

	Если ДанныеЗаказаПоставщику = Неопределено Тогда
		ОшибкиВалидации.Добавить(НСтр("ru='В Данные не передан ЗаказПоставщику'"));
	КонецЕсли;

	Если ОшибкиВалидации.Количество() > 0 Тогда
		ВызватьИсключение СтрСоединить(ОшибкиВалидации, Символы.ПС);
	КонецЕсли;

	// --- Валидация обязательных полей, сбор ссылок для проверки существования ---

	СсылкиДляПроверки = Новый Массив;
	МножествоУИД      = Новый Соответствие;

	Для Каждого ДанныеЗНП Из ЗаказыНаПеремещение Цикл

		УИДПотребности = ДанныеЗНП["УИДПотребности"];
		Описание       = СтрШаблон("ЗаказНаПеремещение (УИД %1)", УИДПотребности);

		Если НЕ ЗначениеЗаполнено(УИДПотребности) Тогда
			ОшибкиВалидации.Добавить(НСтр("ru='ЗаказНаПеремещение: не заполнен УИДПотребности'"));
		Иначе
			МножествоУИД.Вставить(УИДПотребности, Истина);
		КонецЕсли;

		Если НЕ ЗначениеЗаполнено(ДанныеЗНП["Дата"]) Тогда
			ОшибкиВалидации.Добавить(СтрШаблон(НСтр("ru='%1: не заполнена Дата'"), Описание));
		КонецЕсли;

		Для Каждого ИмяПоля Из СтрРазделить("Организация,СкладОтправитель,СкладПолучатель", ",") Цикл

			ЗначениеПоля = ДанныеЗНП[ИмяПоля];

			Если НЕ ЗначениеЗаполнено(ЗначениеПоля) Тогда
				ОшибкиВалидации.Добавить(СтрШаблон(НСтр("ru='%1: не заполнено поле %2'"), Описание, ИмяПоля));
			Иначе
				ЭлементПроверки = Новый Структура("Ссылка, ОписаниеПоля",
					ЗначениеПоля, СтрШаблон("%1.%2", Описание, ИмяПоля));
				СсылкиДляПроверки.Добавить(ЭлементПроверки);
			КонецЕсли;

		КонецЦикла;

		ТоварыЗНП = ДанныеЗНП["Товары"];

		Если ТоварыЗНП = Неопределено ИЛИ ТоварыЗНП.Количество() = 0 Тогда
			ОшибкиВалидации.Добавить(СтрШаблон(НСтр("ru='%1: не заполнена ТЧ Товары'"), Описание));
		Иначе

			Для Каждого СтрокаТоваров Из ТоварыЗНП Цикл

				Номенклатура = СтрокаТоваров["Номенклатура"];

				Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
					ОшибкиВалидации.Добавить(СтрШаблон(НСтр("ru='%1.Товары: не заполнена Номенклатура'"), Описание));
				Иначе
					ЭлементПроверки = Новый Структура("Ссылка, ОписаниеПоля",
						Номенклатура, СтрШаблон("%1.Товары.Номенклатура", Описание));
					СсылкиДляПроверки.Добавить(ЭлементПроверки);
				КонецЕсли;

				Если НЕ ЗначениеЗаполнено(СтрокаТоваров["Количество"]) Тогда
					ОшибкиВалидации.Добавить(СтрШаблон(НСтр("ru='%1.Товары: не заполнено Количество'"), Описание));
				КонецЕсли;

			КонецЦикла;

		КонецЕсли;

	КонецЦикла;

	ШаблонЗаказы_ВалидироватьПоляЗаказаПоставщику(ДанныеЗаказаПоставщику, МножествоУИД, СсылкиДляПроверки, ОшибкиВалидации);

	Если ОшибкиВалидации.Количество() > 0 Тогда
		ВызватьИсключение СтрСоединить(ОшибкиВалидации, Символы.ПС);
	КонецЕсли;

	// --- Проверка существования ссылок в базе данных ---

	ОшибкиСуществования = ШаблонЗаказы_ПроверитьСуществованиеСсылок(СсылкиДляПроверки);

	Если ОшибкиСуществования.Количество() > 0 Тогда
		ВызватьИсключение СтрСоединить(ОшибкиСуществования, Символы.ПС);
	КонецЕсли;

	// --- Создание документов в транзакции ---

	СоответствиеУИДСсылка = Новый Соответствие;

	НачатьТранзакцию();
	Попытка

		Для Каждого ДанныеЗНП Из ЗаказыНаПеремещение Цикл

			ЗНП = Документы.ЗаказНаПеремещение.СоздатьДокумент();
			ШаблонЗаказы_ЗаполнитьЗаказНаПеремещение(ДанныеЗНП, ЗНП);
			ЗНП.Записать(РежимЗаписиДокумента.Проведение);

			СоответствиеУИДСсылка.Вставить(ДанныеЗНП["УИДПотребности"], ЗНП.Ссылка);

		КонецЦикла;

		ЗП = Документы.ЗаказПоставщику.СоздатьДокумент();
		ШаблонЗаказы_ЗаполнитьЗаказПоставщику(ДанныеЗаказаПоставщику, ЗП,
			ЗаказыНаПеремещение, СоответствиеУИДСсылка);
		ЗП.Записать(РежимЗаписиДокумента.Проведение);

		ЗафиксироватьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

	// --- Формирование результата ---

	ЗаказыНаПеремещениеРезультат = Новый Массив;

	Для Каждого ДанныеЗНП Из ЗаказыНаПеремещение Цикл

		УИДПотребности = ДанныеЗНП["УИДПотребности"];
		ЗаказыНаПеремещениеРезультат.Добавить(Новый Структура(
			"УИДПотребности, УИДДокумента",
			УИДПотребности,
			Строка(СоответствиеУИДСсылка[УИДПотребности].УникальныйИдентификатор())));

	КонецЦикла;

	Параметры.Результат = Новый Структура(
		"ЗаказыНаПеремещение, УИДЗаказаПоставщику",
		ЗаказыНаПеремещениеРезультат,
		Строка(ЗП.Ссылка.УникальныйИдентификатор()));

КонецПроцедуры

// Проверяет обязательные поля ЗаказаПоставщику и собирает ссылочные поля
// для последующей проверки существования в базе данных.
//
// Параметры:
//   ДанныеЗП          - Структура    - данные из JSON.
//   МножествоУИД      - Соответствие - УИДПотребности ЗНП для проверки ИдентификаторСтроки.
//   СсылкиДляПроверки - Массив       - дополняется найденными ссылочными полями.
//   ОшибкиВалидации   - Массив       - дополняется найденными ошибками.
Процедура ШаблонЗаказы_ВалидироватьПоляЗаказаПоставщику(ДанныеЗП, МножествоУИД, СсылкиДляПроверки, ОшибкиВалидации)

	Если НЕ ЗначениеЗаполнено(ДанныеЗП["Дата"]) Тогда
		ОшибкиВалидации.Добавить(НСтр("ru='ЗаказПоставщику: не заполнена Дата'"));
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ДанныеЗП["Валюта"]) Тогда
		ОшибкиВалидации.Добавить(НСтр("ru='ЗаказПоставщику: не заполнена Валюта'"));
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ДанныеЗП["СуммаДокумента"]) Тогда
		ОшибкиВалидации.Добавить(НСтр("ru='ЗаказПоставщику: не заполнена СуммаДокумента'"));
	КонецЕсли;

	Для Каждого ИмяПоля Из СтрРазделить("Контрагент,Организация,Склад,Договор,IT_ВременнойСлот", ",") Цикл

		ЗначениеПоля = ДанныеЗП[ИмяПоля];

		Если НЕ ЗначениеЗаполнено(ЗначениеПоля) Тогда
			ОшибкиВалидации.Добавить(СтрШаблон(НСтр("ru='ЗаказПоставщику: не заполнено поле %1'"), ИмяПоля));
		Иначе
			ЭлементПроверки = Новый Структура("Ссылка, ОписаниеПоля",
				ЗначениеПоля, СтрШаблон("ЗаказПоставщику.%1", ИмяПоля));
			СсылкиДляПроверки.Добавить(ЭлементПроверки);
		КонецЕсли;

	КонецЦикла;

	ТоварыЗП = ДанныеЗП["Товары"];

	Если ТоварыЗП = Неопределено ИЛИ ТоварыЗП.Количество() = 0 Тогда
		ОшибкиВалидации.Добавить(НСтр("ru='ЗаказПоставщику: не заполнена ТЧ Товары'"));
	Иначе

		Для Каждого СтрокаТоваров Из ТоварыЗП Цикл

			Если НЕ ЗначениеЗаполнено(СтрокаТоваров["Номенклатура"]) Тогда
				ОшибкиВалидации.Добавить(НСтр("ru='ЗаказПоставщику.Товары: не заполнена Номенклатура'"));
			КонецЕсли;

			Если НЕ ЗначениеЗаполнено(СтрокаТоваров["Количество"]) Тогда
				ОшибкиВалидации.Добавить(НСтр("ru='ЗаказПоставщику.Товары: не заполнено Количество'"));
			КонецЕсли;

			Если НЕ ЗначениеЗаполнено(СтрокаТоваров["Цена"]) Тогда
				ОшибкиВалидации.Добавить(НСтр("ru='ЗаказПоставщику.Товары: не заполнена Цена'"));
			КонецЕсли;

			ИдСтроки = СтрокаТоваров["ИдентификаторСтроки"];

			Если НЕ ЗначениеЗаполнено(ИдСтроки) Тогда
				ОшибкиВалидации.Добавить(НСтр("ru='ЗаказПоставщику.Товары: не заполнен ИдентификаторСтроки'"));
			ИначеЕсли МножествоУИД.Получить(ИдСтроки) = Неопределено Тогда
				ТекстОшибки = СтрШаблон(
					НСтр("ru='ЗаказПоставщику.Товары: ИдентификаторСтроки %1 не соответствует ни одному УИДПотребности ЗаказаНаПеремещение'"),
					ИдСтроки);
				ОшибкиВалидации.Добавить(ТекстОшибки);
			Иначе
				// ИдентификаторСтроки корректен — соответствует одному из ЗНП
			КонецЕсли;

		КонецЦикла;

	КонецЕсли;

КонецПроцедуры

// Заполняет реквизиты объекта ЗаказНаПеремещение из переданных данных интеграции.
// Заполняются только поля, предоставленные внешней системой; 1С-специфические
// реквизиты (ХозяйственнаяОперация, НалогообложениеНДС и т.д.) задаются отдельно.
//
// Параметры:
//   ДанныеЗНП - Структура  - данные из JSON (реквизиты уже десериализованы).
//   ЗНП        - ДокументОбъект.ЗаказНаПеремещение - заполняемый объект документа.
Процедура ШаблонЗаказы_ЗаполнитьЗаказНаПеремещение(ДанныеЗНП, ЗНП)

	ЗНП.Дата             = ДанныеЗНП["Дата"];
	ЗНП.Организация      = ДанныеЗНП["Организация"];
	ЗНП.СкладОтправитель = ДанныеЗНП["СкладОтправитель"];
	ЗНП.СкладПолучатель  = ДанныеЗНП["СкладПолучатель"];

	Если ЗначениеЗаполнено(ДанныеЗНП["Комментарий"]) Тогда
		ЗНП.Комментарий = ДанныеЗНП["Комментарий"];
	КонецЕсли;

	Если ЗначениеЗаполнено(ДанныеЗНП["ЖелаемаяДатаПоступления"]) Тогда
		ЗНП.ЖелаемаяДатаПоступления = ДанныеЗНП["ЖелаемаяДатаПоступления"];
	КонецЕсли;

	Если ЗначениеЗаполнено(ДанныеЗНП["Ответственный"]) Тогда
		ЗНП.Ответственный = ДанныеЗНП["Ответственный"];
	КонецЕсли;

	Если ЗначениеЗаполнено(ДанныеЗНП["Автор"]) Тогда
		ЗНП.Автор = ДанныеЗНП["Автор"];
	КонецЕсли;

	Если ЗначениеЗаполнено(ДанныеЗНП["IT_ДатаОтгрузки"]) Тогда
		ЗНП.IT_ДатаОтгрузки = ДанныеЗНП["IT_ДатаОтгрузки"];
	КонецЕсли;

	Для Каждого СтрокаТоваров Из ДанныеЗНП["Товары"] Цикл

		НоваяСтрока              = ЗНП.Товары.Добавить();
		НоваяСтрока.Номенклатура = СтрокаТоваров["Номенклатура"];
		НоваяСтрока.Количество   = СтрокаТоваров["Количество"];

		Если ЗначениеЗаполнено(СтрокаТоваров["ПЛ_Комментарий"]) Тогда
			НоваяСтрока.ПЛ_Комментарий = СтрокаТоваров["ПЛ_Комментарий"];
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

// Заполняет реквизиты объекта ЗаказПоставщику из переданных данных интеграции
// и устанавливает связь с ЗаказамиНаПеремещение через ДокументОснование и ПЛ_Заказ.
// 1С-специфические реквизиты задаются отдельно.
//
// Параметры:
//   ДанныеЗП              - Структура  - данные из JSON (реквизиты уже десериализованы).
//   ЗП                    - ДокументОбъект.ЗаказПоставщику - заполняемый объект.
//   ЗаказыНаПеремещение   - Массив     - исходные данные ЗНП (для ДокументОснование).
//   СоответствиеУИДСсылка - Соответствие - УИДПотребности → ссылка на созданный ЗНП.
Процедура ШаблонЗаказы_ЗаполнитьЗаказПоставщику(ДанныеЗП, ЗП, ЗаказыНаПеремещение, СоответствиеУИДСсылка)

	ЗП.Дата             = ДанныеЗП["Дата"];
	ЗП.Контрагент       = ДанныеЗП["Контрагент"];
	ЗП.Организация      = ДанныеЗП["Организация"];
	ЗП.Склад            = ДанныеЗП["Склад"];
	ЗП.Валюта           = ДанныеЗП["Валюта"];
	ЗП.СуммаДокумента   = ДанныеЗП["СуммаДокумента"];
	ЗП.Договор          = ДанныеЗП["Договор"];
	ЗП.IT_ВременнойСлот = ДанныеЗП["IT_ВременнойСлот"];

	Если ЗначениеЗаполнено(ДанныеЗП["Менеджер"]) Тогда
		ЗП.Менеджер = ДанныеЗП["Менеджер"];
	КонецЕсли;

	Если ЗначениеЗаполнено(ДанныеЗП["ЦенаВключаетНДС"]) Тогда
		ЗП.ЦенаВключаетНДС = ДанныеЗП["ЦенаВключаетНДС"];
	КонецЕсли;

	Если ЗначениеЗаполнено(ДанныеЗП["ЖелаемаяДатаПоступления"]) Тогда
		ЗП.ЖелаемаяДатаПоступления = ДанныеЗП["ЖелаемаяДатаПоступления"];
	КонецЕсли;

	Если ЗначениеЗаполнено(ДанныеЗП["ДатаСогласования"]) Тогда
		ЗП.ДатаСогласования = ДанныеЗП["ДатаСогласования"];
	КонецЕсли;

	Если ЗначениеЗаполнено(ДанныеЗП["Комментарий"]) Тогда
		ЗП.Комментарий = ДанныеЗП["Комментарий"];
	КонецЕсли;

	Если ЗначениеЗаполнено(ДанныеЗП["Автор"]) Тогда
		ЗП.Автор = ДанныеЗП["Автор"];
	КонецЕсли;

	Если ЗначениеЗаполнено(ДанныеЗП["ПЛ_Заметки"]) Тогда
		ЗП.ПЛ_Заметки = ДанныеЗП["ПЛ_Заметки"];
	КонецЕсли;

	// ДокументОснование заполняется только при единственном ЗаказеНаПеремещение
	Если ЗаказыНаПеремещение.Количество() = 1 Тогда
		ЗП.ДокументОснование = СоответствиеУИДСсылка[ЗаказыНаПеремещение[0]["УИДПотребности"]];
	КонецЕсли;

	Для Каждого СтрокаТоваров Из ДанныеЗП["Товары"] Цикл

		НоваяСтрока              = ЗП.Товары.Добавить();
		НоваяСтрока.Номенклатура = СтрокаТоваров["Номенклатура"];
		НоваяСтрока.Количество   = СтрокаТоваров["Количество"];
		НоваяСтрока.Цена         = СтрокаТоваров["Цена"];
		// Связь строки ЗП с конкретным ЗаказомНаПеремещение по ИдентификаторСтроки = УИДПотребности
		НоваяСтрока.ПЛ_Заказ    = СоответствиеУИДСсылка[СтрокаТоваров["ИдентификаторСтроки"]];

		Если ЗначениеЗаполнено(СтрокаТоваров["ПЛ_Комментарий"]) Тогда
			НоваяСтрока.ПЛ_Комментарий = СтрокаТоваров["ПЛ_Комментарий"];
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

// Проверяет существование переданных ссылок в базе данных.
// Группирует ссылки по типу метаданных и выполняет один запрос на каждую таблицу.
//
// Параметры:
//   СсылкиДляПроверки - Массив структур {Ссылка: ЛюбаяСсылка, ОписаниеПоля: Строка}
//
// Возвращаемое значение:
//   Массив - строки с описанием ненайденных объектов (пустой, если все найдены)
Функция ШаблонЗаказы_ПроверитьСуществованиеСсылок(СсылкиДляПроверки)

	ГруппыПоТаблице = Новый Соответствие;

	Для Каждого Элемент Из СсылкиДляПроверки Цикл

		МетаданныеОбъекта = Метаданные.НайтиПоТипу(ТипЗнч(Элемент.Ссылка));

		Если МетаданныеОбъекта = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		ИмяТаблицы = МетаданныеОбъекта.ПолноеИмя();
		Группа     = ГруппыПоТаблице.Получить(ИмяТаблицы);

		Если Группа = Неопределено Тогда
			Группа = Новый Массив;
			ГруппыПоТаблице.Вставить(ИмяТаблицы, Группа);
		КонецЕсли;

		Группа.Добавить(Элемент);

	КонецЦикла;

	ОшибкиСуществования = Новый Массив;

	// Один запрос на каждый тип метаданных — группировка выполнена выше.
	// Подавляем CreateQueryInCycle: цикл идёт по типам, а не по записям.
	//BSLLS:CreateQueryInCycle-off
	Для Каждого КлючЗначение Из ГруппыПоТаблице Цикл

		ИмяТаблицы = КлючЗначение.Ключ;
		Группа      = КлючЗначение.Значение;

		СписокСсылок = Новый Массив;

		Для Каждого Элемент Из Группа Цикл
			СписокСсылок.Добавить(Элемент.Ссылка);
		КонецЦикла;

		Запрос = Новый Запрос;
		//BSLLS:RefOveruse-off
		Запрос.Текст =
		"ВЫБРАТЬ
		|	т.Ссылка КАК Ссылка
		|ИЗ
		|	" + ИмяТаблицы + " КАК т
		|ГДЕ
		|	т.Ссылка В (&СписокСсылок)";
		//BSLLS:RefOveruse-on
		Запрос.УстановитьПараметр("СписокСсылок", СписокСсылок);

		РезультатЗапроса = Запрос.Выполнить();

		НайденныеСсылки = Новый Соответствие;
		Выборка = РезультатЗапроса.Выбрать();

		Пока Выборка.Следующий() Цикл
			НайденныеСсылки.Вставить(Выборка.Ссылка, Истина);
		КонецЦикла;

		Для Каждого Элемент Из Группа Цикл

			Если НайденныеСсылки.Получить(Элемент.Ссылка) = Неопределено Тогда
				ОшибкиСуществования.Добавить(СтрШаблон(
					НСтр("ru='Объект не найден в базе данных: %1'"),
					Элемент.ОписаниеПоля));
			КонецЕсли;

		КонецЦикла;

	КонецЦикла;
	//BSLLS:CreateQueryInCycle-on

	Возврат ОшибкиСуществования;

КонецФункции

#КонецОбласти // ШаблоныИнтеграции
