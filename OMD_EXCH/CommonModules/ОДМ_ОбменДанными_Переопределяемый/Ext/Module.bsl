			"СправочникСсылка.ДоговорыКонтрагентов", СоответствиеВнешнейБазы);
			//Если ТипЗнч(ОбъектСсылка.СубконтоДт2) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
			//	РезультатМетода.СубконтоДт2 = ОДМ_ОбменДанными.УстановитьСвойство(
