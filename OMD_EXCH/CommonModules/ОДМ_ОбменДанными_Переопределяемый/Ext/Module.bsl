		// ВидОперации
		ИмяЗначения = ПолучитьИмяЗначенияПеречисления(ОбъектСсылка.ВидОперации);
		РезультатМетода.ВидОперации = ОДМ_ОбменДанными.УстановитьСвойство(
		"ПеречислениеСсылка.ВидыОперацийПоступлениеДенежныхСредств", ИмяЗначения);
		
		// СчетОрганизации
		СоответствиеВнешнейБазы = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, ОбъектСсылка.СчетОрганизации);
		Если НЕ ЗначениеЗаполнено(СоответствиеВнешнейБазы) И ЗначениеЗаполнено(ОбъектСсылка.СчетОрганизации) Тогда
			ОбеспечитьСоответствиеБанковскогоСчета(ОбъектСсылка.СчетОрганизации, БазаДанных);
			СоответствиеВнешнейБазы = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, ОбъектСсылка.СчетОрганизации);
		КонецЕсли;
		Если ЗначениеЗаполнено(СоответствиеВнешнейБазы) Тогда
			РезультатМетода.СчетОрганизации = ОДМ_ОбменДанными.УстановитьСвойство(
			"СправочникСсылка.БанковскиеСчета", СоответствиеВнешнейБазы);
		Иначе
			РезультатМетода.СчетОрганизации = ОДМ_ОбменДанными.УстановитьСвойство(
			"СправочникСсылка.БанковскиеСчета", Строка(ОбъектСсылка.СчетОрганизации.УникальныйИдентификатор()));
		КонецЕсли;
		
		// СчетБанк
		РезультатМетода.СчетБанк = ОДМ_ОбменДанными.УстановитьСвойство(
		"ПланСчетовСсылка.Хозрасчетный", ОбъектСсылка.СчетБанк.Код);
		
		//<<ДеевС 24.11.2025 CPM-331 Передача ответственного
		Если ЗначениеЗаполнено(ОбъектСсылка.Ответственный) Тогда
			РезультатМетода.Ответственный = ОДМ_ОбменДанными.УстановитьСвойство(
			"СправочникСсылка.Пользователи", ОбъектСсылка.Ответственный.Наименование);
		КонецЕсли;
		//>>ДеевС
		
		// Контрагент (может быть Контрагенты или ФизическиеЛица, ГУИД из регистра)
		Если ЗначениеЗаполнено(ОбъектСсылка.Контрагент) Тогда
			СоответствиеВнешнейБазы = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, ОбъектСсылка.Контрагент);
			Если ЗначениеЗаполнено(СоответствиеВнешнейБазы) ИЛИ ТипЗнч(ОбъектСсылка.Контрагент) = Тип("СправочникСсылка.ФизическиеЛица")Тогда
				Если ТипЗнч(ОбъектСсылка.Контрагент) = Тип("СправочникСсылка.Контрагенты") Тогда
					РезультатМетода.Контрагент = ОДМ_ОбменДанными.УстановитьСвойство(
					"СправочникСсылка.Контрагенты", СоответствиеВнешнейБазы);
				ИначеЕсли ТипЗнч(ОбъектСсылка.Контрагент) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
					//Если нет прямого сопоставления то ищем по ГУИДу ЗУПа
					Если НЕ ЗначениеЗаполнено(СоответствиеВнешнейБазы) Тогда
						ИспользуемаяИБЗУП = Справочники.ВнешниеИнформационныеБазы.НайтиПоКоду("00000007");//1С ЗУП
						СоответствиеВнешнейБазы = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБЗУП, ОбъектСсылка.Контрагент);
					КонецЕсли;
					
					// Если соответствие так и не нашли, формируем описание физлица "как есть"
					Если НЕ ЗначениеЗаполнено(СоответствиеВнешнейБазы) Тогда
						// Передаем ссылку на физлицо из УХ (GUID уже синхронизирован с ЗУП)
						РезультатМетода.Контрагент = ОДМ_ОбменДанными.УстановитьСвойство(
						"СправочникСсылка.ФизическиеЛица", Строка(ОбъектСсылка.Контрагент.УникальныйИдентификатор()));
					Иначе
						РезультатМетода.Контрагент = ОДМ_ОбменДанными.УстановитьСвойство(
						"СправочникСсылка.ФизическиеЛица", СоответствиеВнешнейБазы);
					КонецЕсли;
				КонецЕсли;
				
				//Если ТипЗнч(ОбъектСсылка.СубконтоДт1) = Тип("СправочникСсылка.Контрагенты") Тогда
				//	РезультатМетода.СубконтоДт1 = ОДМ_ОбменДанными.УстановитьСвойство(
				//	"СправочникСсылка.Контрагенты", СоответствиеВнешнейБазы);
				//КонецЕсли;
			Иначе
				
				ЗаписатьСобытиеВЖурналРегистрации(ОбъектСсылка.Номер, ТипЗнч(ОбъектСсылка.Ссылка), БазаДанных, ОбъектСсылка.Контрагент);
				Возврат Неопределено;
			КонецЕсли;
		КонецЕсли;
		
		// СчетКонтрагента
		СоответствиеВнешнейБазы = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, ОбъектСсылка.СчетКонтрагента);
		Если НЕ ЗначениеЗаполнено(СоответствиеВнешнейБазы) И ЗначениеЗаполнено(ОбъектСсылка.СчетКонтрагента) Тогда
			ОбеспечитьСоответствиеБанковскогоСчета(ОбъектСсылка.СчетКонтрагента, БазаДанных);
			СоответствиеВнешнейБазы = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, ОбъектСсылка.СчетКонтрагента);
		КонецЕсли;
		Если ЗначениеЗаполнено(СоответствиеВнешнейБазы) Тогда
			РезультатМетода.СчетКонтрагента = ОДМ_ОбменДанными.УстановитьСвойство(
			"СправочникСсылка.БанковскиеСчета", СоответствиеВнешнейБазы);
		Иначе
			РезультатМетода.СчетКонтрагента = ОДМ_ОбменДанными.УстановитьСвойство(
			"СправочникСсылка.БанковскиеСчета", Строка(ОбъектСсылка.СчетКонтрагента.УникальныйИдентификатор()));
		КонецЕсли;
		
		// СуммаДокумента
		РезультатМетода.СуммаДокумента = ОДМ_ОбменДанными.УстановитьСвойство("Число", ОбъектСсылка.СуммаДокумента);
		
		РезультатМетода.СуммаУслуг = ОДМ_ОбменДанными.УстановитьСвойство("Число", ОбъектСсылка.СуммаУслуг);
		
		РезультатМетода.НомерВходящегоДокумента = ОДМ_ОбменДанными.УстановитьСвойство("Строка", ОбъектСсылка.НомерВходящегоДокумента);

		// ДатаВходящегоДокумента
		РезультатМетода.ДатаВходящегоДокумента = ОДМ_ОбменДанными.УстановитьСвойство("Дата", ОбъектСсылка.ДатаВходящегоДокумента);
		
		РезультатМетода.Дата = ОДМ_ОбменДанными.УстановитьСвойство("Дата", ОбъектСсылка.Дата);
		// СчетУчетаРасчетовСКонтрагентом
		РезультатМетода.СчетУчетаРасчетовСКонтрагентом = ОДМ_ОбменДанными.УстановитьСвойство(
		"ПланСчетовСсылка.Хозрасчетный", ОбъектСсылка.СчетУчетаРасчетовСКонтрагентом.Код); 
		
		// Логика для СубконтоКт1: если счет в группе 91, заполняем из справочника ПрочиеДоходыИРасходы
		Если ЗначениеЗаполнено(ОбъектСсылка.СчетУчетаРасчетовСКонтрагентом) Тогда
			Если ОбъектСсылка.СчетУчетаРасчетовСКонтрагентом.Код = "91.01" 
				ИЛИ ОбъектСсылка.СчетУчетаРасчетовСКонтрагентом.Код = "91.02" Тогда
				
				Если ЗначениеЗаполнено(ОбъектСсылка.СубконтоКт1) Тогда
					// Использование субконто справочника "ПрочиеДоходыИРасходы"
					РезультатМетода.СубконтоКт1 = ОДМ_ОбменДанными.УстановитьСвойство(
					"СправочникСсылка.ПрочиеДоходыИРасходы", 
					ОбъектСсылка.СубконтоКт1.Наименование
					);
				Иначе
					ЗаписатьСобытиеВЖурналРегистрации(ОбъектСсылка, ТипЗнч(ОбъектСсылка.Ссылка), БазаДанных, , "Не заполнена статья прочих доходов и расходов");
					Возврат Неопределено;
				КонецЕсли;
			КонецЕсли;
		Иначе
			РезультатМетода.СубконтоКт1 = Неопределено;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ОбъектСсылка.СубконтоКт1) Тогда
			ЭтоСчет91 = ЗначениеЗаполнено(ОбъектСсылка.СчетУчетаРасчетовСКонтрагентом)
				И (ОбъектСсылка.СчетУчетаРасчетовСКонтрагентом.Код = "91.01"
				ИЛИ ОбъектСсылка.СчетУчетаРасчетовСКонтрагентом.Код = "91.02");
			Если НЕ ЭтоСчет91 Тогда
				ЗаполнитьСубконтоДляОбмена(
					РезультатМетода,
					"СубконтоКт1",
					ОбъектСсылка.СубконтоКт1,
					ИспользуемаяИБ,
					БазаДанных);
			КонецЕсли;
		КонецЕсли;
		
		СоответствиеВнешнейБазы = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, ОбъектСсылка.ДоговорКонтрагента);
		Если ЗначениеЗаполнено(СоответствиеВнешнейБазы) Тогда
			РезультатМетода.ДоговорКонтрагента = ОДМ_ОбменДанными.УстановитьСвойство(
			"СправочникСсылка.ДоговорыКонтрагентов", СоответствиеВнешнейБазы);
		Иначе
			РезультатМетода.ДоговорКонтрагента = ОДМ_ОбменДанными.УстановитьСвойство(
			"СправочникСсылка.ДоговорыКонтрагентов", Строка(ОбъектСсылка.ДоговорКонтрагента.УникальныйИдентификатор()));
		КонецЕсли;
		
		СоответствиеВнешнейБазы = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, ОбъектСсылка.ВалютаДокумента);
		Если ЗначениеЗаполнено(СоответствиеВнешнейБазы) Тогда
			РезультатМетода.ВалютаДокумента = ОДМ_ОбменДанными.УстановитьСвойство(
			"СправочникСсылка.Валюты", СоответствиеВнешнейБазы);
		Иначе
			РезультатМетода.ВалютаДокумента = ОДМ_ОбменДанными.УстановитьСвойство(
			"СправочникСсылка.Валюты", Строка(ОбъектСсылка.ВалютаДокумента.УникальныйИдентификатор()));
		КонецЕсли;
		
		РезультатМетода.СтатьяДвиженияДенежныхСредств = ОДМ_ОбменДанными.УстановитьСвойство(
		"СправочникСсылка.СтатьиДвиженияДенежныхСредств", 
		Строка(ОбъектСсылка.СтатьяДвиженияДенежныхСредств.Ссылка.УникальныйИдентификатор()));
		
		РасшифровкаПлатежа = Новый Массив;
		
		Для Каждого СтрокаПлатежа из ОбъектСсылка.РасшифровкаПлатежа Цикл
			
		СтрокаРасшифровкиПлатежа = Новый Структура("ДоговорКонтрагента, СтавкаНДС, СуммаПлатежа, СуммаНДС,
														|СпособПогашенияЗадолженности, СтатьяДвиженияДенежныхСредств,
														|КурсВзаиморасчетов, СуммаВзаиморасчетов,
														|СчетУчетаРасчетовПоАвансам, СчетУчетаРасчетовСКонтрагентом,
														|СуммаУслуг");
		
		СоответствиеВнешнейБазы = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, СтрокаПлатежа.ДоговорКонтрагента);
		
		//<<ДеевС 26.11.2025 CPM-323 Обязательные реквизиты: Подразделение, ЦФО, Статья ДДС
		Если Не ЗначениеЗаполнено(СтрокаПлатежа.ЦФО) Тогда
			ЗаписатьСобытиеВЖурналРегистрации(ОбъектСсылка, ТипЗнч(ОбъектСсылка.Ссылка), БазаДанных, , "Не заполнено ЦФО");
			Возврат Неопределено;
		КонецЕсли;
		
		// Статья ДДС
		Если Не ЗначениеЗаполнено(СтрокаПлатежа.СтатьяДвиженияДенежныхСредств) Тогда
			ЗаписатьСобытиеВЖурналРегистрации(ОбъектСсылка, ТипЗнч(ОбъектСсылка.Ссылка), БазаДанных, , "Не заполнена статья ДДС");
			Возврат Неопределено;
		КонецЕсли;
		//>>ДеевС 26.11.2025
		
		Если ЗначениеЗаполнено(СоответствиеВнешнейБазы) Тогда
			СтрокаРасшифровкиПлатежа.ДоговорКонтрагента = ОДМ_ОбменДанными.УстановитьСвойство(
			"СправочникСсылка.ДоговорыКонтрагентов", СоответствиеВнешнейБазы);
		Иначе
			СтрокаРасшифровкиПлатежа.ДоговорКонтрагента = ОДМ_ОбменДанными.УстановитьСвойство(
			"СправочникСсылка.ДоговорыКонтрагентов", Строка(ОбъектСсылка.ДоговорКонтрагента.УникальныйИдентификатор()));
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаПлатежа.СпособПогашенияЗадолженности) Тогда
			СтрокаРасшифровкиПлатежа.СпособПогашенияЗадолженности = ОДМ_ОбменДанными.УстановитьСвойство(
			"ПеречислениеСсылка.СпособыПогашенияЗадолженности", 
			СтрокаПлатежа.СпособПогашенияЗадолженности);
		КонецЕсли;
		
		СтрокаРасшифровкиПлатежа.СуммаПлатежа = ОДМ_ОбменДанными.УстановитьСвойство("Число", СтрокаПлатежа.СуммаПлатежа);
		СтрокаРасшифровкиПлатежа.СуммаУслуг = ОДМ_ОбменДанными.УстановитьСвойство("Число", СтрокаПлатежа.СуммаУслуг);
		СтрокаРасшифровкиПлатежа.СуммаНДС = ОДМ_ОбменДанными.УстановитьСвойство("Число", СтрокаПлатежа.СуммаНДС);
		
		СтрокаРасшифровкиПлатежа.КурсВзаиморасчетов = ОДМ_ОбменДанными.УстановитьСвойство("Число", СтрокаПлатежа.КурсВзаиморасчетов);
		СтрокаРасшифровкиПлатежа.СуммаВзаиморасчетов = ОДМ_ОбменДанными.УстановитьСвойство("Число", СтрокаПлатежа.СуммаВзаиморасчетов);
		
		Если ЗначениеЗаполнено(СтрокаПлатежа.СтавкаНДС) Тогда
			СтрокаРасшифровкиПлатежа.СтавкаНДС = ОДМ_ОбменДанными.УстановитьСвойство(
			"ПеречислениеСсылка.СтавкиНДС", 
			СтрокаПлатежа.СтавкаНДС);
		КонецЕсли;
		
		СоответствиеВнешнейБазы = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, СтрокаПлатежа.СтатьяДвиженияДенежныхСредств);
		Если ЗначениеЗаполнено(СоответствиеВнешнейБазы) Тогда
			СтрокаРасшифровкиПлатежа.СтатьяДвиженияДенежныхСредств = ОДМ_ОбменДанными.УстановитьСвойство(
			"СправочникСсылка.СтатьиДвиженияДенежныхСредств", СоответствиеВнешнейБазы);
		Иначе
			СтрокаРасшифровкиПлатежа.СтатьяДвиженияДенежныхСредств = ОДМ_ОбменДанными.УстановитьСвойство(
			"СправочникСсылка.СтатьиДвиженияДенежныхСредств", Строка(СтрокаПлатежа.СтатьяДвиженияДенежныхСредств.Ссылка.УникальныйИдентификатор()));
		КонецЕсли;
		
		СтрокаРасшифровкиПлатежа.СчетУчетаРасчетовПоАвансам = ОДМ_ОбменДанными.УстановитьСвойство(
		"ПланСчетовСсылка.Хозрасчетный", СтрокаПлатежа.СчетУчетаРасчетовПоАвансам.Код);
		
		СтрокаРасшифровкиПлатежа.СчетУчетаРасчетовСКонтрагентом = ОДМ_ОбменДанными.УстановитьСвойство(
		"ПланСчетовСсылка.Хозрасчетный", СтрокаПлатежа.СчетУчетаРасчетовСКонтрагентом.Код);

		// Добавляем строку в табличную часть
		РасшифровкаПлатежа.Добавить(СтрокаРасшифровкиПлатежа);
	КонецЦикла;
	
	// Устанавливаем табличную часть в результат
	РезультатМетода.РасшифровкаПлатежа = РасшифровкаПлатежа;

		
		// НазначениеПлатежа
		РезультатМетода.НазначениеПлатежа = ОДМ_ОбменДанными.УстановитьСвойство("Строка", ОбъектСсылка.НазначениеПлатежа);
		
		// Комментарий (с префиксом)
		РезультатМетода.Комментарий = ОДМ_ОбменДанными.УстановитьСвойство("Строка", "Синхронизация 1С УХ-БП / " + ОбъектСсылка.Комментарий);
		
		РезультатМетода.ПометкаУдаления = ОДМ_ОбменДанными.УстановитьСвойство("Булево", ОбъектСсылка.ПометкаУдаления);
		
	ИначеЕсли ТипЗнч(ОбъектСсылка.Ссылка) = Тип("ДокументСсылка.СписаниеСРасчетногоСчета") Тогда
		
		НаименованиеБазыДанных = БазаДанных.Наименование;
		НаименованиеБазыДанныхКонстанты = ОДМ_ОбменДанными.ВернутьДополнительнуюКонстанту("БазаБПИНН-" + ОбъектСсылка.Организация.ИНН);
		
		Если НаименованиеБазыДанных <> НаименованиеБазыДанныхКонстанты Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		// Логика для документа СписаниеСРасчетногоСчета
		РезультатМетода = Новый Структура("Ссылка, Дата, Организация, ВидОперации, СчетОрганизации, СчетБанк, Контрагент, СчетКонтрагента, 
		|СуммаДокумента, НомерВходящегоДокумента, ДатаВходящегоДокумента, СчетУчетаРасчетовСКонтрагентом, СтатьяДвиженияДенежныхСредств, 
		| НазначениеПлатежа, Комментарий, ДоговорКонтрагента, ВалютаДокумента, РасшифровкаПлатежа, ПометкаУдаления, Налог, ПодразделениеОрганизации,
		| Ответственный, ПодразделениеДт, СубконтоДт1, СубконтоДт2");
		
		РезультатМетода.Ссылка = ОДМ_ОбменДанными.УстановитьСвойство(
		"ДокументСсылка.СписаниеСРасчетногоСчета", 
		Строка(ОбъектСсылка.Ссылка.УникальныйИдентификатор()));
		
		ИспользуемаяИБ = ОДМ_ОбменДанными.ВернутьДополнительнуюКонстанту("MRS_DataExchange_Base_" + БазаДанных);
		
		// Организация (ГУИД из регистра соответствия)
		СоответствиеВнешнейБазы = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, ОбъектСсылка.Организация);
		Если ЗначениеЗаполнено(СоответствиеВнешнейБазы) Тогда
			РезультатМетода.Организация = ОДМ_ОбменДанными.УстановитьСвойство(
			"СправочникСсылка.Организации", СоответствиеВнешнейБазы);
		Иначе
			ЗаписатьСобытиеВЖурналРегистрации(ОбъектСсылка.Номер, ТипЗнч(ОбъектСсылка.Ссылка), БазаДанных, ОбъектСсылка.Организация);
			Возврат Неопределено;
		КонецЕсли;
		
		//<<ДеевС 26.11.2025 CPM-323 Обязательные реквизиты: Подразделение, ЦФО, Статья ДДС
		// Если не заполнены, документ не отправляем в обмен
		// Подразделение
		Если Не ЗначениеЗаполнено(ОбъектСсылка.ПодразделениеОрганизации) Тогда
			ЗаписатьСобытиеВЖурналРегистрации(ОбъектСсылка, ТипЗнч(ОбъектСсылка.Ссылка), БазаДанных, , "Не заполнено Подразделение");
