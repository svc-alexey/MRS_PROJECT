// Вспомогательная функция для получения имени значения перечисления
Функция ПолучитьИмяЗначенияПеречисления(ЗначениеПеречисления)
	
	Если Не ЗначениеЗаполнено(ЗначениеПеречисления) Тогда
		Возврат "";
	КонецЕсли;
	
	// Получаем метаданные перечисления
	МетаданныеПеречисления = ЗначениеПеречисления.Метаданные();
	ИмяПеречисления = МетаданныеПеречисления.Имя;
	
	// Находим индекс значения в перечислении
	ИндексЗначения = Перечисления[ИмяПеречисления].Индекс(ЗначениеПеречисления);
	
	// Получаем имя значения по индексу
	ИмяЗначения = МетаданныеПеречисления.ЗначенияПеречисления[ИндексЗначения].Имя;
	
	Возврат ИмяЗначения;
	
КонецФункции

// Вспомогательная функция для получения имени значения перечисления
Функция ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, ОбъектТекущейИБ)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"
	|ВЫБРАТЬ
	|	СоответствиеОбъектовТекущейИВнешнихИБ.ОбъектВнешнейИБ КАК ОбъектВнешнейИБ,
	|	СоответствиеОбъектовТекущейИВнешнихИБ.ИспользуемаяИБ КАК ИспользуемаяИБ
	|ИЗ
	|	РегистрСведений.СоответствиеОбъектовТекущейИВнешнихИБ КАК СоответствиеОбъектовТекущейИВнешнихИБ
	|ГДЕ
	|	СоответствиеОбъектовТекущейИВнешнихИБ.ОбъектТекущейИБ = &ОбъектТекущейИБ
	|	И СоответствиеОбъектовТекущейИВнешнихИБ.ИспользуемаяИБ = &ИспользуемаяИБ
	|";
	
	Запрос.УстановитьПараметр("ИспользуемаяИБ", ИспользуемаяИБ);
	Запрос.УстановитьПараметр("ОбъектТекущейИБ", ОбъектТекущейИБ);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.ОбъектВнешнейИБ;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Процедура ЗаполнитьСубконтоДляОбмена(РезультатМетода, ИмяПоля, ЗначениеСубконто, ИспользуемаяИБ, БазаДанных)
	
	Если НЕ ЗначениеЗаполнено(ЗначениеСубконто) Тогда
		Возврат;
	КонецЕсли;
	
	ТипСубконто = ТипЗнч(ЗначениеСубконто);
	ТипСубконтоСтрокой = Строка(ТипСубконто);
	
	ЭтоСсылочныйТип = Лев(ТипСубконтоСтрокой, 16) = "СправочникСсылка"
		ИЛИ Лев(ТипСубконтоСтрокой, 14) = "ДокументСсылка"
		ИЛИ Лев(ТипСубконтоСтрокой, 27) = "ПланВидовХарактеристикСсылка";
	
	Если НЕ ЭтоСсылочныйТип Тогда
		Возврат;
	КонецЕсли;
	
	СоответствиеВнешнейБазы = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, ЗначениеСубконто);
	Если ЗначениеЗаполнено(СоответствиеВнешнейБазы) Тогда
		РезультатМетода[ИмяПоля] = ОДМ_ОбменДанными.УстановитьСвойство(ТипСубконтоСтрокой, СоответствиеВнешнейБазы);
		Возврат;
	КонецЕсли;
	
	Если ТипСубконтоСтрокой = "СправочникСсылка.ПрочиеДоходыИРасходы"
		ИЛИ ТипСубконтоСтрокой = "СправочникСсылка.ВидыНалоговИПлатежейВБюджет"
		ИЛИ ТипСубконтоСтрокой = "СправочникСсылка.Пользователи" Тогда
		РезультатМетода[ИмяПоля] = ОДМ_ОбменДанными.УстановитьСвойство(ТипСубконтоСтрокой, ЗначениеСубконто.Наименование);
		Возврат;
	КонецЕсли;
	
	РезультатМетода[ИмяПоля] = ОДМ_ОбменДанными.УстановитьСвойство(
		ТипСубконтоСтрокой,
		Строка(ЗначениеСубконто.УникальныйИдентификатор()));
	
	ЗаписатьСобытиеВЖурналРегистрации(ТипСубконтоСтрокой, ТипСубконто, БазаДанных, ЗначениеСубконто);
	
КонецПроцедуры

Функция ОбеспечитьСоответствиеБанковскогоСчета(Счет, БазаДанных)
	
	Если Не ЗначениеЗаполнено(Счет) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ИспользуемаяИБ = ОДМ_ОбменДанными.ВернутьДополнительнуюКонстанту("MRS_DataExchange_Base_" + БазаДанных);
	СоответствиеСчета = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, Счет);
	Если ЗначениеЗаполнено(СоответствиеСчета) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Счет.Банк) Тогда
		Банк = Счет.Банк;
		СоответствиеБанка = ПолучитьСоответствиеВнешнейБазы(ИспользуемаяИБ, Банк);
		Если НЕ ЗначениеЗаполнено(СоответствиеБанка) Тогда
			ИдентификаторБанка = НайтиИдентификаторБанкаВоВнешнейБазе(Банк, БазаДанных);
			Если НЕ ЗначениеЗаполнено(ИдентификаторБанка) Тогда
				ИдентификаторБанка = ОтправитьОбъектВоВнешнююБазу(Банк, БазаДанных);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ИдентификаторБанка) Тогда
				ЗаписатьСоответствиеОбъекта(Банк, ИспользуемаяИБ, БазаДанных, ИдентификаторБанка, "Банки");
			Иначе
				Возврат Ложь;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ИдентификаторСчета = ОтправитьОбъектВоВнешнююБазу(Счет, БазаДанных);
	Если НЕ ЗначениеЗаполнено(ИдентификаторСчета) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ЗаписатьСоответствиеОбъекта(Счет, ИспользуемаяИБ, БазаДанных, ИдентификаторСчета, "БанковскиеСчета");
	Возврат Истина;
	
КонецФункции

Функция НайтиИдентификаторБанкаВоВнешнейБазе(Банк, БазаДанных)
	
	Если НЕ ЗначениеЗаполнено(Банк) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ОписаниеЗапроса = ОДМ_ОбменДанными.Конструктор_ОписаниеЗапросаВнешнейБазы();
	ВнешнийИнтерфейс = ОДМ_ОбменДанными.Конструктор_ВнешнийИнтерфейс();
	ВнешнийИнтерфейс.ЗаполнитьПараметрыПодключения(БазаДанных);
	
	Если ЗначениеЗаполнено(Банк.Наименование) Тогда
		ОписаниеЗапроса.ТекстЗапроса =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Банки.Ссылка)) КАК ГУИД
		|ИЗ
		|	Справочник.Банки КАК Банки
		|ГДЕ
		|	НЕ Банки.ПометкаУдаления
		|	И Банки.Наименование = &Наименование";
		ОписаниеЗапроса.Параметры.Вставить("Наименование", Банк.Наименование);
		
		Данные = ВнешнийИнтерфейс.ОтправитьЗапросНаСервер(ОписаниеЗапроса, Ложь);
		Если Данные <> Неопределено И Данные.Количество() > 0 Тогда
			Возврат Строка(Данные[0].ГУИД);
		КонецЕсли;
		
		ОписаниеЗапроса.Параметры.Очистить();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Банк.Код) Тогда
		ОписаниеЗапроса.ТекстЗапроса =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Банки.Ссылка)) КАК ГУИД
		|ИЗ
		|	Справочник.Банки КАК Банки
		|ГДЕ
		|	НЕ Банки.ПометкаУдаления
		|	И Банки.Код = &Код";
		ОписаниеЗапроса.Параметры.Вставить("Код", Банк.Код);
		
		Данные = ВнешнийИнтерфейс.ОтправитьЗапросНаСервер(ОписаниеЗапроса, Ложь);
		Если Данные <> Неопределено И Данные.Количество() > 0 Тогда
			Возврат Строка(Данные[0].ГУИД);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция ОтправитьОбъектВоВнешнююБазу(СсылкаОбъекта, БазаДанных)
	
	ОписаниеИсточника = СформироватьОписание(СсылкаОбъекта, БазаДанных);
	Если ОписаниеИсточника = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ОтправляемыйПакет = ОДМ_ОбменДанными.Конструктор_ОписаниеПакетаЗаписиОбъекта();
	ОтправляемыйПакет.ОчищатьТабличнуюЧасть = ОДМ_ОбменДанными.УстановитьСвойство("Булево", Истина);
	ОтправляемыйПакет.ВключитьОбменДанными = ОДМ_ОбменДанными.УстановитьСвойство("Булево", Истина);
	ОтправляемыйПакет.Данные = ОписаниеИсточника;
	
	ВнешнийИнтерфейс = ОДМ_ОбменДанными.Конструктор_ВнешнийИнтерфейс();
	ВнешнийИнтерфейс.ЗаполнитьПараметрыПодключения(БазаДанных);
	РезультатМетода = ВнешнийИнтерфейс.ОтправитьОбъектНаСервер(ОтправляемыйПакет, Ложь);
	
	Если РезультатМетода <> Неопределено
		И ТипЗнч(РезультатМетода) = Тип("Структура")
		И РезультатМетода.Свойство("Идентификатор") Тогда
		Возврат РезультатМетода.Идентификатор;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Процедура ЗаписатьСоответствиеОбъекта(ОбъектТекущейИБ, ИспользуемаяИБ, БазаДанных, ИдентификаторБП, ИмяОбъектаМетаданных)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	СоответствиеВнешнимИБ.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СоответствиеВнешнимИБ КАК СоответствиеВнешнимИБ
	|ГДЕ
	|	СоответствиеВнешнимИБ.Владелец = &Владелец
	|	И СоответствиеВнешнимИБ.ИмяОбъектаМетаданных = &ИмяОбъектаМетаданных";
	
	Запрос.УстановитьПараметр("Владелец", ИспользуемаяИБ.ТипБД);
	Запрос.УстановитьПараметр("ИмяОбъектаМетаданных", ИмяОбъектаМетаданных);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Если НЕ Выборка.Следующий() Тогда
		Возврат;
	КонецЕсли;
	
	НастройкаСоответствия = Выборка.Ссылка;
	
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Соответствие.ОбъектТекущейИБ КАК ОбъектТекущейИБ,
	|	Соответствие.НастройкаСоответствия КАК НастройкаСоответствия,
	|	Соответствие.ИспользуемаяИБ КАК ИспользуемаяИБ
	|ИЗ
	|	РегистрСведений.СоответствиеОбъектовТекущейИВнешнихИБ КАК Соответствие
	|ГДЕ
	|	Соответствие.ИспользуемаяИБ = &ИспользуемаяИБ
	|	И Соответствие.НастройкаСоответствия = &НастройкаСоответствия
	|	И Соответствие.ОбъектТекущейИБ = &ОбъектТекущейИБ";
	
	Запрос.УстановитьПараметр("ИспользуемаяИБ", ИспользуемаяИБ);
	Запрос.УстановитьПараметр("НастройкаСоответствия", НастройкаСоответствия);
	Запрос.УстановитьПараметр("ОбъектТекущейИБ", ОбъектТекущейИБ);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	МенеджерЗаписи = РегистрыСведений.СоответствиеОбъектовТекущейИВнешнихИБ.СоздатьМенеджерЗаписи();
	Если Выборка.Следующий() Тогда
		МенеджерЗаписи.ОбъектТекущейИБ = Выборка.ОбъектТекущейИБ;
		МенеджерЗаписи.НастройкаСоответствия = Выборка.НастройкаСоответствия;
		МенеджерЗаписи.ИспользуемаяИБ = Выборка.ИспользуемаяИБ;
	Иначе
		МенеджерЗаписи.ОбъектТекущейИБ = ОбъектТекущейИБ;
		МенеджерЗаписи.ИспользуемаяИБ = ИспользуемаяИБ;
		МенеджерЗаписи.НастройкаСоответствия = НастройкаСоответствия;
	КонецЕсли;
	
	МенеджерЗаписи.ОбъектВнешнейИБ = Строка(ИдентификаторБП);
	МенеджерЗаписи.НаименованиеОбъектаВнешнейИБ = ОбъектТекущейИБ.Наименование;
	МенеджерЗаписи.НастройкаСоответствияНаименование = НастройкаСоответствия.Наименование;
	МенеджерЗаписи.ТипОбъектаТекущейИБ = ИмяОбъектаМетаданных;
	МенеджерЗаписи.ТипОбъектаВнешнейИБ = ИмяОбъектаМетаданных;
	МенеджерЗаписи.ИмяОбъектаТекущейИБ = ОбъектТекущейИБ.Метаданные().ПолноеИмя();
	МенеджерЗаписи.ИмяОбъектаВнешнейИБ = "Справочник." + ИмяОбъектаМетаданных;
	МенеджерЗаписи.GUIDОбъектаТекущейИБ = Строка(ОбъектТекущейИБ.УникальныйИдентификатор());
	МенеджерЗаписи.Выгружено = Истина;
	МенеджерЗаписи.Записать();
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

Процедура ЗаписатьСобытиеВЖурналРегистрации(НаименованиеОбъекта, ТипСправочника = "", БазаДанных = "",ЭлементПоиска = "", ОшибкаВыгрузки = "")
	
	СтруктураСобытий = Новый Структура("ИмяСобытия, ПредставлениеУровня, Комментарий,ДатаСобытия");
	
	СтруктураСобытий.ИмяСобытия 		 = "ОДМ_Обмен";
	СтруктураСобытий.ПредставлениеУровня = "Ошибка";	
	
	Если ЗначениеЗаполнено(ОшибкаВыгрузки) Тогда
		ТекстСообщения = "Не выгружен " + НаименованиеОбъекта+ "в базу " + БазаДанных + ". Ошибка: " + ОшибкаВыгрузки;
	Иначе
		ТекстСообщения = "Нет связи для " + ТипСправочника +" " + НаименованиеОбъекта+ " для базы " + БазаДанных + " элемент " + ЭлементПоиска;
	КонецЕсли;
	
	СтруктураСобытий.Комментарий = ТекстСообщения;
	СобытияДляЖурналаРегистрации = Новый СписокЗначений();
	СобытияДляЖурналаРегистрации.Добавить(СтруктураСобытий);
	
	ЖурналРегистрации.ЗаписатьСобытияВЖурналРегистрации(СобытияДляЖурналаРегистрации);
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	
КонецПроцедуры

