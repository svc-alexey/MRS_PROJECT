#Область СлужебныеПроцедурыИФункции

Функция СкомпоноватьРезультатЗапроса(ОписаниеЗапроса, Результат)
	
	Если ОДМ_ОбменДанными.ЭтоПакетныйЗапрос(ОписаниеЗапроса) Тогда
		РезультатМетода = Новый Структура;
		Для Каждого КлючИЗначение Из Результат Цикл
			РезультатМетода.Вставить(КлючИЗначение.Ключ, ОДМ_ОбменДанными.МассивСтруктурВТаблицуЗначений(КлючИЗначение.Значение));
		КонецЦикла;
	Иначе
		РезультатМетода = ОДМ_ОбменДанными.МассивСтруктурВТаблицуЗначений(Результат);
	КонецЕсли;
	
	Возврат РезультатМетода;
	
КонецФункции

Процедура ДополнитьАдресРесурса(АдресРесурса, Знач Асинхронно) //TODO: костыль. подумать
	
	Инициатор = Новый Структура("connectionPath, userOS", СтрокаСоединенияИнформационнойБазы(), "R2D2"); //TODO: в повт_исп написать получения пользователя OS службы
	ИнициаторСтрокой = ОДМ_ОбменДанными.СериализоватьJSON(Инициатор);
	АдресРесурса = СтрШаблон("%1?initiator=%2", АдресРесурса, ИнициаторСтрокой);
	
	Если Асинхронно Тогда
		АдресРесурса = СтрШаблон("%1&async=%2", АдресРесурса, Новый УникальныйИдентификатор);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти // СлужебныеПроцедурыИФункции
