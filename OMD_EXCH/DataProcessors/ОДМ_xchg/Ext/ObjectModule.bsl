Функция УстановитьХТТПСоединение() Экспорт
	
	РезультатМетода = Новый Структура("Успех, ДополнительнаяИнформация", Ложь, "");
	
	Попытка
		//TODO: проверка на наличие БСП
		//если есть, установка через него - тогда будет возможность блока/разрешения соединений в копиях.
		Соединение = Новый HTTPСоединение(АдресСервера, , Логин, Пароль);
		РезультатМетода.Успех = Истина;
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		РезультатМетода.ДополнительнаяИнформация = ОДМ_ОбменДанными.ПолноеОписаниеОшибки(ИнформацияОбОшибке);
	КонецПопытки;
	
	Возврат РезультатМетода;
	
КонецФункции

Функция Пинг() Экспорт
	
	Результат = Новый Структура("Успех, КодСостояния, ДополнительнаяИнформация", Ложь, Неопределено, "");
	
	АдресРесурса = СтрШаблон("/%1/hs/MRS_xchg/ping", ИмяБазы);
	Попытка
		ЗапросHTTP = Новый HTTPЗапрос(АдресРесурса, Заголовки);
		ОтветHTTP = Соединение.Получить(ЗапросHTTP);
		
		ТелоОтвета = ОтветHTTP.ПолучитьТелоКакСтроку();
		
		Результат.Успех = Истина;
		Результат.КодСостояния = ОтветHTTP.КодСостояния;
		Результат.ДополнительнаяИнформация = ОДМ_ОбменДанными.ДесериализоватьJSON(ТелоОтвета);
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		Результат.ДополнительнаяИнформация = ОДМ_ОбменДанными.ПолноеОписаниеОшибки(ИнформацияОбОшибке);
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция СостояниеЗадач(Знач Идентификаторы) Экспорт
	
	АдресРесурса = СтрШаблон("/%1/hs/MRS_xchg/job", ИмяБазы);
	ЗапросHTTP = Новый HTTPЗапрос(АдресРесурса, Заголовки);
	ЗапросHTTP.УстановитьТелоИзСтроки(ОДМ_ОбменДанными.СериализоватьJSON(Идентификаторы));
	ОтветHTTP = ВызватьHTTPМетод("GET", ЗапросHTTP);
	
	ТелоОтветаСтрокой = ОтветHTTP.ПолучитьТелоКакСтроку();
	ТелоОтвета = ОДМ_ОбменДанными.ДесериализоватьJSON(ТелоОтветаСтрокой);
	
	Возврат ТелоОтвета;
	
КонецФункции

Функция ОтправитьЗапросНаСервер(Знач ОписаниеЗапроса, Знач Асинхронно = Ложь) Экспорт
	
	АдресРесурса = СтрШаблон("%1/hs/MRS_xchg/query", ИмяБазы);
	ДополнитьАдресРесурса(АдресРесурса, Асинхронно);
	
	ЗапросHTTP = Новый HTTPЗапрос(АдресРесурса, Заголовки);
	ЗапросHTTP.УстановитьТелоИзСтроки(ОДМ_ОбменДанными.СериализоватьJSON(ОписаниеЗапроса));
	ОтветHTTP = ВызватьHTTPМетод("POST", ЗапросHTTP);
	
	ТелоОтветаСтрокой = ОтветHTTP.ПолучитьТелоКакСтроку();
	//<<ДеевС  25.11.2025 Временно, понять почему могут не выгружаться документы
		СтруктураСобытий = Новый Структура("ИмяСобытия, ПредставлениеУровня, Комментарий,ДатаСобытия");
				
				СтруктураСобытий.ИмяСобытия 		 = "ОДМ_Обмен";
				СтруктураСобытий.ПредставлениеУровня = "Информация";	
				СтруктураСобытий.Комментарий 		 = ТелоОтветаСтрокой;
				
				СобытияДляЖурналаРегистрации = Новый СписокЗначений();
				СобытияДляЖурналаРегистрации.Добавить(СтруктураСобытий);
				
				ЖурналРегистрации.ЗаписатьСобытияВЖурналРегистрации(СобытияДляЖурналаРегистрации);
	//>>ДеевС
	
	ТелоОтвета = ОДМ_ОбменДанными.ДесериализоватьJSON(ТелоОтветаСтрокой);
		
	Если Асинхронно и ТипЗнч(ТелоОтвета) = Тип("Структура") и ТелоОтвета.Свойство("Идентификатор") Тогда
		РезультатМетода = ТелоОтвета;
	Иначе
		РезультатМетода = СкомпоноватьРезультатЗапроса(ОписаниеЗапроса, ТелоОтвета);
	КонецЕсли;
	
	Возврат РезультатМетода;
	
КонецФункции

Функция РезультатЗапроса(Знач Идентификатор) Экспорт
	
	ДанныеЗадачи = СостояниеЗадач(Идентификатор);
	
	Для Каждого Задача Из ДанныеЗадачи Цикл
		Если Задача.Статус = "Выполнен" Тогда
			Задача.Результат = СкомпоноватьРезультатЗапроса(Задача.Параметры, Задача.Результат);
		КонецЕсли;
	КонецЦикла;
	
	Если ДанныеЗадачи.Количество()=1 Тогда
		Возврат ДанныеЗадачи[0];
	Иначе
		Возврат ДанныеЗадачи;
	КонецЕсли;
		
КонецФункции

Функция ОтправитьОбъектНаСервер(Знач ОписаниеОбъекта, Знач Асинхронно = Ложь) Экспорт
	
	АдресРесурса = СтрШаблон("%1/hs/MRS_xchg/object", ИмяБазы);
	ДополнитьАдресРесурса(АдресРесурса, Асинхронно);
	
	ЗапросHTTP = Новый HTTPЗапрос(АдресРесурса, Заголовки);
	ЗапросHTTP.УстановитьТелоИзСтроки(ОДМ_ОбменДанными.СериализоватьJSON(ОписаниеОбъекта));
	ОтветHTTP = ВызватьHTTPМетод("POST", ЗапросHTTP);
	
	ТелоОтветаСтрокой = ОтветHTTP.ПолучитьТелоКакСтроку();
	ТелоОтвета = ОДМ_ОбменДанными.ДесериализоватьJSON(ТелоОтветаСтрокой);
		
	Если Асинхронно и ТипЗнч(ТелоОтвета) = Тип("Структура") и ТелоОтвета.Свойство("Идентификатор") Тогда
		РезультатМетода = ТелоОтвета;
	Иначе
		//сюда гуид?
		РезультатМетода = ТелоОтвета;
	КонецЕсли;
	
	Возврат РезультатМетода;
	
КонецФункции

