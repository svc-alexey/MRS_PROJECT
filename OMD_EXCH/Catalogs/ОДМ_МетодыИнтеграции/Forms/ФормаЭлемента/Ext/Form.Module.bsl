#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЗаполнитьСписокВыбораТипаШаблона();
	
КонецПроцедуры

#КонецОбласти // ОбработчикиСобытийФормы

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ТипШаблонаПриИзменении(Элемент)
	
	НастроитьЗаголовокШаблона();
	
КонецПроцедуры

#КонецОбласти // ОбработчикиСобытийЭлементовФормы

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьСписокВыбораТипаШаблона()
	
	СписокВыбора = Элементы.ТипШаблона.СписокВыбора;
	СписокВыбора.Добавить("ЗаписьОбъектов",  "Запись объектов");
	СписокВыбора.Добавить("Запрос",          "Запрос");
	СписокВыбора.Добавить("Обработчик",      "Обработчик (произвольный код)");
	СписокВыбора.Добавить("Составной",       "Составной (не реализовано)");
	
	НастроитьЗаголовокШаблонаНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура НастроитьЗаголовокШаблонаНаСервере()
	
	ТипШаблона = Объект.ТипШаблона;
	
	Если ТипШаблона = "ЗаписьОбъектов" Тогда
		Элементы.ГруппаШаблон.Заголовок = "Шаблон (BSL-код предобработки данных перед записью объекта; необязательно)";
	ИначеЕсли ТипШаблона = "Запрос" Тогда
		Элементы.ГруппаШаблон.Заголовок = "Шаблон (текст запроса 1С)";
	ИначеЕсли ТипШаблона = "Обработчик" Тогда
		Элементы.ГруппаШаблон.Заголовок = "Шаблон (BSL-код или имя экспортной процедуры)";
	ИначеЕсли ТипШаблона = "Составной" Тогда
		Элементы.ГруппаШаблон.Заголовок = "Шаблон (зарезервировано)";
	Иначе
		Элементы.ГруппаШаблон.Заголовок = "Шаблон";
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьЗаголовокШаблона()
	
	НастроитьЗаголовокШаблонаНаСервере();
	
КонецПроцедуры

#КонецОбласти // СлужебныеПроцедурыИФункции
